            m_lReturn = .Parameters.Add(sName:="PerilTypeID", vValue:=CStr(PerilTypeID), idirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
