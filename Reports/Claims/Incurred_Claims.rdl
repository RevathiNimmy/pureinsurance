  <Code>
Public Function IncludeRecoveries (ByVal parameter1 As String) As Boolean
    Return UCase(parameter1) = "YES"
End Function

Public Function IncludeClosed (ByVal parameter2 As String) As Boolean
    Return UCase(parameter2) = "YES"
End Function

