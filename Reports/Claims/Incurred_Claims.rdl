                      <Value>=IIF(
    (Not(Code.IncludeClosed(Parameters!IncludeClosed.Value)) And Not(Code.IncludeRecoveries(Parameters!IncludeRecoveries.Value))), 
    "Incurred Claims", 
    IIF(
        (Code.IncludeClosed(Parameters!IncludeClosed.Value) And Not(Code.IncludeRecoveries(Parameters!IncludeRecoveries.Value))), 
        "Incurred Claims including Closed Claims", 
        IIF(
            (Not(Code.IncludeClosed(Parameters!IncludeClosed.Value)) And Code.IncludeRecoveries(Parameters!IncludeRecoveries.Value)), 
            "Incurred Claims including Recoveries", 
            "Incurred Claims including Recoveries and Closed Claims"
        )
    )
)</Value>
