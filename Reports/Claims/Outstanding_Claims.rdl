  <Code>
Public Function ReportBasisFormula (ByVal parameter1 As String, ByVal dbField0 As String, ByVal dbField1 As String, ByVal dbField2 As String) As String
        Dim ReportBasis As String

ReportBasis = UCase(Trim(parameter1))

     If ReportBasis = "CLIENT" Then 
        Return dbField0
     ElseIf ReportBasis = "POLICY" Then 
        Return dbField1
     ElseIf ReportBasis = "AGENT" Then 
        Return dbField2
     Else 
        Return ""
     End If 
End Function

Public Function Group_5_Order (ByVal dbField3 As Date) As String
         If (YYearDiff (dbField3) = 0 ) Then 
        Return Nothing
     ElseIf (YYearDiff (dbField3)) &gt; 5.00 Then 
        Return "Over 5 Years Ago"
     ElseIf (YYearDiff (dbField3) &gt;= 2.00 And YYearDiff (dbField3) &lt;= 5.00) Then 
        Return "2 to 5 Years Ago"
     ElseIf YYearDiff (dbField3) = 1 Then 
        Return "Last Year"
     ElseIf YYearDiff (dbField3) = 0 Then 
        Return "This Year"
     Else 
        Return "Others"
     End If 
End Function

Public Function textSalvageAndRecoveries (ByVal parameter2 As String) As String
        Dim SandR As String = (parameter2)

     If SandR = "Include" Then 
        Return "Including Salvage and TP Recovery"
     ElseIf SandR = "Exclude" Then 
        Return "Excluding Salvage and TP Recovery"
     Else 
        Return "Salvage and TP Recovery Only"
     End If 
End Function

Public Function SortGroup_5_Order (ByVal dbField3 As Date) As Decimal
         If (YYearDiff (dbField3) = 0 ) Then 
        Return 0
     ElseIf (YYearDiff (dbField3)) &gt; 5.00 Then 
        Return (-5)
     ElseIf (YYearDiff (dbField3) &gt;= 2.00 And YYearDiff (dbField3) &lt;= 5.00) Then 
        Return (-4)
     ElseIf YYearDiff (dbField3) = 1 Then 
        Return (-3)
     ElseIf YYearDiff (dbField3) = 0 Then 
        Return (-2)
     Else 
        Return 0
     End If 
End Function

Public Function YYear (ByVal dbField3 As Date) As Decimal
    Return 0
End Function

Public Function IsDateBasis (ByVal parameter1 As String) As Boolean
    Return UCase(Trim(parameter1)) = "LOSS DATE"
End Function

Public Function CurrentYear () As Decimal
    Return Year(Today())
End Function

Public Function YYearDiff (ByVal dbField3 As Date) As Decimal
    Return (CurrentYear ()) - (Microsoft.VisualBasic.DateAndTime.Year(dbField3))
End Function

