  <Code>
Public Function Group_3_Order (ByVal dbField7 As String) As String
         If IsNothing(dbField7) Then 
        Return Nothing
     ElseIf UCase(Trim(dbField7)) = "C_CO" Then 
        Return "Initial Reserve"
     ElseIf UCase(Trim(dbField7)) = "C_CR" Then 
        Return "Changes in Reserves"
     ElseIf UCase(Trim(dbField7)) = "C_CP" Then 
        Return "Claim Payment"
     ElseIf UCase(Trim(dbField7)) = "C_SA" Then 
        Return "Claim Salvage"
     ElseIf UCase(Trim(dbField7)) = "C_RV" Then 
        Return "Claim Recovery"
     Else 
        Return "Others"
     End If 
End Function

Public Function SortGroup_3_Order (ByVal dbField7 As String) As Decimal
         If IsNothing(dbField7) Then 
        Return 0
     ElseIf UCase(Trim(dbField7)) = "C_CO" Then 
        Return (-6)
     ElseIf UCase(Trim(dbField7)) = "C_CR" Then 
        Return (-5)
     ElseIf UCase(Trim(dbField7)) = "C_CP" Then 
        Return (-4)
     ElseIf UCase(Trim(dbField7)) = "C_SA" Then 
        Return (-3)
     ElseIf UCase(Trim(dbField7)) = "C_RV" Then 
        Return (-2)
     Else 
        Return 0
     End If 
End Function

</Code>
