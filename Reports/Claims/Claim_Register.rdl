                                  <TextRuns>
                                    <TextRun>
                                      <Value>=Sum(IIf(IsNothing(Fields!Amount1.Value), 0, Fields!Amount1.Value) - 
 (IIf(IsNothing(Fields!Amount2.Value), 0, Fields!Amount2.Value) + 
 IIf(IsNothing(Fields!Amount3.Value), 0, Fields!Amount3.Value) + 
 IIf(IsNothing(Fields!Amount4.Value), 0, Fields!Amount4.Value) + 
 IIf(IsNothing(Fields!Amount5.Value), 0, Fields!Amount5.Value) + 
 IIf(IsNothing(Fields!Duties.Value), 0, Fields!Duties.Value)))</Value>
                                      <Style>
                                        <FontFamily>Arial Narrow</FontFamily>
                                        <FontSize>9pt</FontSize>
                                        <FontWeight>Bold</FontWeight>
                                        <Format>''#,0.00;''-#,0.00;'0.00'</Format>
                                      </Style>
                                    </TextRun>
                                  </TextRuns>
