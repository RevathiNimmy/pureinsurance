  <ReportParameters>
    <ReportParameter Name="Operator">
      <DataType>String</DataType>
      <Prompt>Enter your name</Prompt>
    </ReportParameter>
    <ReportParameter Name="register_type">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>Claim</Value>
        </Values>
      </DefaultValue>
      <Prompt>Register Type:</Prompt>
    </ReportParameter>
    <ReportParameter Name="start_date">
      <DataType>DateTime</DataType>
      <Prompt>From Date:</Prompt>
    </ReportParameter>
    <ReportParameter Name="end_date">
      <DataType>DateTime</DataType>
      <Prompt>To Date:</Prompt>
    </ReportParameter>
    <ReportParameter Name="register_period">
      <DataType>String</DataType>
      <Prompt>Date Period:</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>Specify Dates</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Yesterday</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Today</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Last Full Week</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>This Week</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Last Full Month</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>This Month</Value>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="branch_id">
      <DataType>Float</DataType>
      <DefaultValue>
        <Values>
          <Value>1</Value>
        </Values>
      </DefaultValue>
      <Prompt>branch_id</Prompt>
    </ReportParameter>
    <ReportParameter Name="TypeOfCurrency">
      <DataType>String</DataType>
      <Prompt>Type Of Currency:</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>System</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Base</Value>
          </ParameterValue>
          <ParameterValue>
