  <Code>
Public Function ReportBasis (ByVal parameter4 As String, ByVal dbField2 As String, ByVal dbField1 As String, ByVal dbField3 As String) As String
        Dim Var_ReportBasis As String = (parameter4)

     If Var_ReportBasis = "Client" Then 
        Return dbField2
     ElseIf Var_ReportBasis = "Policy" Then 
        Return dbField1
     Else 
        Return dbField3
     End If 
End Function

Public Function textSalvageAndRecoveries (ByVal parameter6 As String) As String
        Dim Clam As String = (parameter6)

     If Clam = "Include" Then 
        Return "Including Catastrophe Claims"
     ElseIf Clam = "Exclude" Then 
        Return "Excluding Catastrophe Claims"
     Else 
        Return ""
     End If 
End Function

</Code>
