  <Code>
Public Function IsSingleCompanyReport (ByVal parameter3 As String) As Boolean
    Return UCase(Trim(Left(parameter3, 3))) &lt;&gt; "ALL"
End Function

Public Function InsurerReinsurer (ByVal dbField13 As String) As String
         If dbField13 = "A" Then 
        Return "Insurer"
     Else 
        Return "Reinsurer"
     End If 
End Function

</Code>
