  <Code>
Public Function DisplayBranch (ByVal parameter2 As Decimal, ByVal dbField1 As String) As String
        Dim Branch As Decimal = (parameter2)

     If Branch &lt;&gt; 0 Then 
        Return ("For " + Trim(dbField1)) + " Branch"
     Else 
        Return "All Branches"
     End If 
End Function


Public Function PageNumber(ByVal pagenum As Integer) As Integer
	Return pagenum
End Function
</Code>
