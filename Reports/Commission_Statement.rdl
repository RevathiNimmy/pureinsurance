  <Code>
Public Function Address (ByVal dbField11 As String, ByVal dbField12 As String, ByVal dbField13 As String, ByVal dbField14 As String, ByVal dbField15 As String) As String
        Dim AddressDetails As String

AddressDetails = ((AddressDetails + chr(13)) + dbField11)

     If dbField12 &lt;&gt; "" Then 
        AddressDetails = ((AddressDetails + chr(13)) + dbField12)
     Else 
        AddressDetails = AddressDetails
     End If 


     If dbField13 &lt;&gt; "" Then 
        AddressDetails = ((AddressDetails + chr(13)) + dbField13)
     Else 
        AddressDetails = AddressDetails
     End If 


     If dbField14 &lt;&gt; "" Then 
        AddressDetails = ((AddressDetails + chr(13)) + dbField14)
     Else 
        AddressDetails = AddressDetails
     End If 


     If dbField15 &lt;&gt; "" Then 
        AddressDetails = ((AddressDetails + chr(13)) + dbField15)
     Else 
        AddressDetails = AddressDetails
     End If 
End Function


