  <Code>
Public Function DisplaySelectedProductID (ByVal parameter2 As String) As String
        Dim PCode As String = (parameter2)
        Dim PCode2 As String = "ALL"
     If PCode &lt;&gt; "ALL" AndAlso PCode  &lt;&gt; "&lt;ALL&gt;"  Then
		  Return PCode
       Else
	    Return "ALL"
     End If 
End Function


Public Function PageNumber() As Integer
	Return Report.Globals!PageNumber
End Function
