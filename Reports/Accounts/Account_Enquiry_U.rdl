                            <Textbox Name="SummarySumofOSDCAmountCF1">
                              <KeepTogether>true</KeepTogether>
                              <Paragraphs>
                                <Paragraph>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>=Sum (Cdbl(IIF ((Fields!ISCash.Value = 0), (Fields!amount.Value - Fields!DCSettled_amount.Value) , (0 - Fields!DCSettled_amount.Value))))</Value>
                                      <Style>
                                        <FontFamily>Arial Narrow</FontFamily>
                                        <FontWeight>Bold</FontWeight>
                                        <Format>''#,0.00;''-#,0.00;'0.00'</Format>
                                      </Style>
                                    </TextRun>
                                  </TextRuns>
                                  <Style>
                                    <TextAlign>Right</TextAlign>
                                  </Style>
                                </Paragraph>
                              </Paragraphs>
                              <Top>0.46875in</Top>
                              <Left>8.88333in</Left>
                              <Height>0.16667in</Height>
                              <Width>1.22917in</Width>
                              <ZIndex>7</ZIndex>
                              <Style>
                                <Border>
                                  <Style>None</Style>
                                </Border>
                                <TopBorder>
                                  <Style>None</Style>
                                </TopBorder>
                                <BottomBorder>
