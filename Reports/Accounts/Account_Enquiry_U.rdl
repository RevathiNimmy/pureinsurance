                                </LeftBorder>
                                <RightBorder>
                                  <Style>None</Style>
                                </RightBorder>
                              </Style>
                            </Textbox>
                            <Textbox Name="SummarySumofOSCashAmountCF1">
                              <KeepTogether>true</KeepTogether>
                              <Paragraphs>
                                <Paragraph>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>=Sum (Cdbl(IIF ((Fields!ISCash.Value = 1), (Fields!amount.Value - Fields!CashSettled_amount.Value) , (0 - Fields!CashSettled_amount.Value))))</Value>
