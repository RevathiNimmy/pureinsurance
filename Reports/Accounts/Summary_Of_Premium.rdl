  <Code>
Public Function Group_3_Order (ByVal dbField0 As String) As String
         If IsNothing(dbField0) Then 
        Return Nothing
     ElseIf UCase(Trim(dbField0)) = "GRS" Then 
        Return "GRS"
     ElseIf UCase(Trim(dbField0)) = "TTY" Then 
        Return "TTY"
     ElseIf UCase(Trim(dbField0)) = "FAC" Then 
        Return "FAC"
     ElseIf UCase(Trim(dbField0)) = "COI" Then 
        Return "COI"
     Else 
        Return "Others"
     End If 
End Function

Public Function SortGroup_3_Order (ByVal dbField0 As String) As Decimal
         If IsNothing(dbField0) Then 
        Return 0
     ElseIf UCase(Trim(dbField0)) = "GRS" Then 
        Return (-5)
     ElseIf UCase(Trim(dbField0)) = "TTY" Then 
        Return (-4)
     ElseIf UCase(Trim(dbField0)) = "FAC" Then 
        Return (-3)
     ElseIf UCase(Trim(dbField0)) = "COI" Then 
        Return (-2)
     Else 
        Return 0
     End If 
End Function

</Code>
