  <Code>
Public Function ClaimStatus (ByVal dbField1 As Integer) As String
        Dim ID As Decimal = dbField1

     If ID = 1 Then 
        Return "Provisional Open Claim"
     ElseIf ID = 2 Then 
        Return "Live Open Claim"
     ElseIf ID = 3 Then 
        Return "Closed"
     ElseIf ID = 4 Then 
        Return "ReOpened"
     Else 
        Return "ReClosed"
     End If 
End Function

</Code>
