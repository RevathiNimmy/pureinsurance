  <Code>
Public Function Desc (ByVal dbField5 As String, ByVal dbField7 As String, ByVal dbField8 As String) As String
        Dim Descr As String = Trim(dbField5)

     If Not (IsNothing(dbField7)) Then 
        Descr = ((Descr + "/") + dbField7)
     End If 


     If Not (IsNothing(dbField8)) Then 
        Descr = ((Descr + "/") + dbField8)
     End If 


    Return Descr
End Function

