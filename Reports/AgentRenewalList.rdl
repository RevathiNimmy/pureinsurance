  <Code>
Public Function AgentName (ByVal dbField2 As String) As String
        Dim Agent As String = Trim(dbField2)

     If Agent = "" Then 
        Return "No Broker involved"
     Else 
        Return Agent
     End If 
End Function

Public Function Contact (ByVal dbField16 As String, ByVal dbField17 As String, ByVal dbField18 As String) As String
        Dim Code As String = Trim(dbField16)

    Dim Number As String = Trim(dbField17)

    Dim Ext As String = Trim(dbField18)

     If Code &lt;&gt; "" Then 
        Code = (Code + " ")
     End If 


     If Number &lt;&gt; "" Then 
        Number = (Number + " ")
     End If 


     If Ext &lt;&gt; "" Then 
        Ext = ("ext. " + Ext)
     End If 


     If (Code + Number) + Ext &lt;&gt; "" Then 
        Return (("Phone: " + Code) + Number) + Ext
     Else 
        Return ""
     End If 
End Function

</Code>
