  <Code>
Public Function Address(ByVal dbField11 As String, ByVal dbField12 As String, ByVal dbField13 As String, ByVal dbField14 As String, ByVal dbField15 As String) As String
    Dim AddressDetails As String

    AddressDetails = dbField11

    If dbField12 &lt;&gt; "" Then
        AddressDetails = AddressDetails &amp; vbCrLf &amp; dbField12
    End If

    If dbField13 &lt;&gt; "" Then
        AddressDetails = AddressDetails &amp; vbCrLf &amp; dbField13
    End If

    If dbField14 &lt;&gt; "" Then
        AddressDetails = AddressDetails &amp; vbCrLf &amp; dbField14
    End If

    If dbField15 &lt;&gt; "" Then
        AddressDetails = AddressDetails &amp; vbCrLf &amp; dbField15
    End If

    Return AddressDetails
End Function

Public Function PageNumber() As Integer
	Return Report.Globals!PageNumber
End Function
