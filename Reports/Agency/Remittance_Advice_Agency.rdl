  <Code>
Public Function InsurerAddress(ByVal dbField7 As String, ByVal dbField0 As String, ByVal dbField1 As String, ByVal dbField2 As String, ByVal dbField3 As String, ByVal dbField4 As String) As String
    Dim AddressDetails As String = dbField7 + vbCrLf

    If dbField0 &lt;&gt; "" Then
        AddressDetails += vbCrLf + dbField0
    End If

    If dbField1 &lt;&gt; "" Then
        AddressDetails += vbCrLf + dbField1
    End If

    If dbField2 &lt;&gt; "" Then
        AddressDetails += vbCrLf + dbField2
    End If

    If dbField3 &lt;&gt; "" Then
        AddressDetails += vbCrLf + dbField3
    End If

    If dbField4 &lt;&gt; "" Then
        AddressDetails += vbCrLf  + dbField4
    End If

    Return AddressDetails
End Function

Public Function Commission (ByVal dbField18 As Decimal, ByVal dbField19 As Decimal) As Decimal
    Return dbField18 + dbField19
End Function

