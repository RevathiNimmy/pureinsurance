  <Code>
Public Shared Number As String
Public Shared Code As String
Public Function CompanyPhone (ByVal dbField5 As String, ByVal dbField6 As String, ByVal dbField7 As String) As String
        Code =  Trim(dbField5)

    Number =  Trim(dbField6)

    Dim Ext As String = Trim(dbField7)

     If Code &lt;&gt; "" Then 
        Code = (Code + " ")
     End If 


     If Number &lt;&gt; "" Then 
        Number = (Number + " ")
     End If 


     If Ext &lt;&gt; "" Then 
        Ext = ("ext. " + Ext)
     End If 


Return (("Telephone: " + Code) + Number) + Ext
End Function

Public Function FaxNumber (ByVal dbField11 As String, ByVal dbField12 As String) As String
        Code =  Trim(dbField11)

    Number =  Trim(dbField12)

     If Code &lt;&gt; "" Then 
        Code = (Code + " ")
     End If 


     If Number &lt;&gt; "" Then 
        Number = (Number + " ")
     End If 


Return ("Facsimile : " + Code) + Number
End Function


Public Function PageNumber() As Integer
	Return Report.Globals!PageNumber
End Function

Public Function TotalPages() As Integer
	Return Report.Globals!TotalPages
End Function
' dbField8 : Fields!AgentResolvedName.Value
Public Function PagePerClient (ByVal dbField8 As String, ByVal Previous_Var0 As String) As Integer
        Dim P As Integer

     If String.IsNullOrEmpty(dbField8) Then 
        P = 1
     ElseIf Previous_Var0 &lt;&gt; (dbField8) Then 
        P = 1
     'Missing Else Statement!
     Else
        Return 0
     End If 
End Function

Public Function AgingDays (ByVal dbField18 As Date) As Decimal
    Return Round((DateDiff("d", dbField18, Today())) - 1, 0)
End Function

Public Function n0_30 (ByVal dbField26 As Integer, ByVal dbField27 As Integer, ByVal dbField18 As Date) As Boolean
    Return (AgingDays (dbField18) &gt;= dbField26 And AgingDays (dbField18) &lt;= dbField27)
End Function

Public Function n31_60 (ByVal dbField28 As Integer, ByVal dbField29 As Integer, ByVal dbField18 As Date) As Boolean
    Return (AgingDays (dbField18) &gt;= dbField28 And AgingDays (dbField18) &lt;= dbField29)
End Function

Public Function n61_90 (ByVal dbField30 As Integer, ByVal dbField31 As Integer, ByVal dbField18 As Date) As Boolean
    Return (AgingDays (dbField18) &gt;= dbField30 And AgingDays (dbField18) &lt;= dbField31)
End Function

Public Function n91_120 (ByVal dbField32 As Integer, ByVal dbField33 As Integer, ByVal dbField18 As Date) As Boolean
    Return (AgingDays (dbField18) &gt;= dbField32 And AgingDays (dbField18) &lt;= dbField33)
End Function

Public Function NotYetDue (ByVal dbField35 As Integer, ByVal dbField21 As String, ByVal dbField18 As Date) As Boolean
         If dbField35 = 0 And (AgingDays (dbField18)) &lt; 0 Then 
        Return (        LEFT(dbField21, 3) = "INC")
     'Missing Else Statement!
     ' Else
         ' Return False
     End If 
     Return False
End Function

Public Function Over_120 (ByVal dbField34 As Integer, ByVal dbField18 As Date) As Boolean
    Return (AgingDays (dbField18)) &gt;= dbField34
End Function

Public Function CashTransType () As Boolean
    Return False
End Function
