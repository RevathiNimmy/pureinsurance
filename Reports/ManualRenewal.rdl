  <Code>
Public Function SortOrderString (ByVal parameter1 As String, ByVal dbField8 As String, ByVal dbField2 As String, ByVal dbField3 As String, ByVal dbField4 As String) As String
         If UCase(Trim(parameter1)) = "CLIENT" Then 
        Return dbField8
     ElseIf UCase(Trim(parameter1)) = "POLICY NUMBER" Then 
        Return dbField2
     ElseIf UCase(Trim(parameter1)) = "AGENT" Then 
        Return dbField3
     ElseIf UCase(Trim(parameter1)) = "PRODUCT CODE" Then 
        Return dbField4
     Else 
        Return ""
     End If 
End Function

Public Function SortOrderDate (ByVal parameter1 As String, ByVal dbField1 As String) As String

     If UCase(Trim(parameter1)) = "Cover To Date" Then 
        Return dbField1
     Else 
        Return ""
     End If 

End Function

Public Function PageNumber() As Integer
	Return Report.Globals!PageNumber
End Function
</Code>
