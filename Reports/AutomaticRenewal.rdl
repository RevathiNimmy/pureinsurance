  <Code>
Public Function SortOrderString (ByVal parameter1 As String, ByVal dbField6 As String, ByVal dbField1 As String, ByVal dbField2 As String, ByVal dbField5 As String) As String
         If UCase(Trim(parameter1)) = "CLIENT" Then 
        Return dbField6
     ElseIf UCase(Trim(parameter1)) = "POLICY NUMBER" Then 
        Return dbField1
     ElseIf UCase(Trim(parameter1)) = "AGENT" Then 
        Return dbField2
     ElseIf UCase(Trim(parameter1)) = "PRODUCT CODE" Then 
        Return dbField5
     Else 
        Return ""
     End If 
End Function


Public Function PageNumber() As Integer
	Return Report.Globals!PageNumber
End Function
</Code>
