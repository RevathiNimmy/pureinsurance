          <Value>DB-Sirius.underwriting_year.code</Value>
        </Values>
      </DefaultValue>
      <Prompt>Underwriting_Year</Prompt>
    </ReportParameter>
    <ReportParameter Name="start_date">
      <DataType>DateTime</DataType>
      <Prompt>From Date:</Prompt>
    </ReportParameter>
    <ReportParameter Name="end_date">
      <DataType>DateTime</DataType>
      <Prompt>To Date:</Prompt>
    </ReportParameter>
    <ReportParameter Name="TypeOfCurrency">
      <DataType>String</DataType>
      <Prompt>Type Of Currency:</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>Account</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Base</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>System</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Transaction</Value>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="GroupBy">
      <DataType>String</DataType>
	  <Prompt>Group By:</Prompt>
	   <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>No Grouping</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Branch</Value>
          </ParameterValue>          
        </ParameterValues>
      </ValidValues>      
    </ReportParameter>
    <ReportParameter Name="TransactionType">
      <DataType>String</DataType>
      <Prompt>Transaction Types:</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>Premium &amp; Claim Transactions</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Premium Transactions Only</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>Claims Transactions Only</Value>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="AgeAndUnalloc">
      <DataType>String</DataType>
      <Prompt>Age And Display Unallocated Cash:</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>Yes</Value>
          </ParameterValue>
          <ParameterValue>
            <Value>No</Value>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
