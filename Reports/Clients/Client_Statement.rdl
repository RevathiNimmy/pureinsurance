Public Shared P As Decimal
Public Function CompanyPhone (ByVal dbField5 As String, ByVal dbField6 As String, ByVal dbField7 As String) As String
        Dim Code As String = Trim(dbField5)

    Dim Number As String = Trim(dbField6)

    Dim Ext As String = Trim(dbField7)

     If Code &lt;&gt; "" Then 
        Code = (Code + " ")
     End If 


     If Number &lt;&gt; "" Then 
        Number = (Number + " ")
     End If 


     If Ext &lt;&gt; "" Then 
        Ext = ("ext. " + Ext)
     End If 


Return (("Telephone: " + Code) + Number) + Ext
End Function

Public Function Page(ByVal dbField18 As Integer, Optional ByVal Previous_Var0 As Decimal = 0) As Decimal
    Dim P As Decimal = 0 ' Initialize P

    If PagePerClient(dbField18, Previous_Var0) = 0 Then
        P = P + 1
    Else
        Return P
    End If

    Return P ' Ensure P is returned
End Function

Public Function PagePerClient(ByVal dbField18 As Integer, Optional ByVal Previous_Var0 As Decimal = 0) As Decimal
    Dim P As Decimal = 0 ' Initialize P

    If IsNothing(dbField18) Then
        P = 1
    ElseIf Previous_Var0 &lt;&gt; dbField18 Then
        P = 1
    Else
        Return 0 ' Missing Else statement added
    End If

    Return P ' Ensure P is returned
End Function
