  <ReportParameters>
    <ReportParameter Name="PersonalClient">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>DB-Sirius.Party-PC.shortname</Value>
        </Values>
      </DefaultValue>
      <Prompt>Personal Client:</Prompt>
