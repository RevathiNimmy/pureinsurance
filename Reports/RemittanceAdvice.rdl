  <Code>
' dbField12 : Fields!Premium.Value
' dbField14 : Fields!Commission.Value
' dbField17 : Fields!Total_Payment.Value
Public Function Net (ByVal dbField12 As Decimal, ByVal dbField14 As Decimal, ByVal dbField17 As Decimal) As Decimal
        '  WhilePrintingRecords

Return (dbField12 + dbField14) - dbField17
End Function

