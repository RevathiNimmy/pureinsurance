  <Code>
Public Function Agent (ByVal dbField13 As String, ByVal dbField12 As String) As String
        Dim AgentName As String = Trim(dbField13)

     If AgentName = "" Then 
        Return dbField12
     Else 
        Return AgentName
     End If 
End Function

Public Function Analysis (ByVal dbField15 As String, ByVal dbField14 As String) As String
        Dim AnalDesc As String = Trim(dbField15)

     If AnalDesc = "" Then 
        Return dbField14
     Else 
        Return AnalDesc
     End If 
End Function

Public Function Branch (ByVal dbField19 As String, ByVal dbField18 As String) As String
        Dim BranchName As String = Trim(dbField19)

     If BranchName = "" Then 
        Return dbField18
     Else 
        Return BranchName
     End If 
End Function

Public Function TypeOfBusiness (ByVal dbField21 As String, ByVal dbField20 As String) As String
        Dim TOBDesc As String = Trim(dbField21)

     If TOBDesc = "" Then 
        Return dbField20
     Else 
        Return TOBDesc
     End If 
End Function

Public Function Product (ByVal dbField17 As String, ByVal dbField16 As String) As String
        Dim ProdDesc As String = Trim(dbField17)

     If ProdDesc = "" Then 
        Return dbField16
     Else 
        Return ProdDesc
     End If 
End Function

Public Function IsSelectedClient (ByVal parameter2 As String, ByVal parameter4 As String, ByVal parameter3 As String) As Boolean
    Return (parameter2 &lt;&gt; "ALL" Or parameter4 &lt;&gt; "ALL" Or parameter3 &lt;&gt; "ALL")
End Function

Public Function IsSelectedPolicy (ByVal parameter5 As String) As Boolean
    Return parameter5 &lt;&gt; "ALL" And parameter5 &lt;&gt; ""
End Function

Public Function DisplaySelectedClient (ByVal parameter2 As String, ByVal parameter4 As String, ByVal parameter3 As String) As String
         If parameter2 &lt;&gt; "ALL" Then 
        Return parameter2
     ElseIf parameter4 &lt;&gt; "ALL" Then 
        Return parameter4
     Else 
        Return parameter3
     End If 
End Function

Public Function NoTaxDetails (ByVal dbField22 As Decimal, ByVal dbField23 As Decimal, ByVal dbField24 As String, ByVal dbField26 As Decimal) As Boolean
    Return dbField22 = 0 And dbField23 = 0 And dbField24 = "" And dbField26 = 0
End Function

Public Function PageNumber() As String
    Return Me.Report.Globals!PageNumber
End Function

