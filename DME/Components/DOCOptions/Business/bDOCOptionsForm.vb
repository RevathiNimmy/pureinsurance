    ' ************************************************************************
    '
    ' Function: SetSetting
    '
    ' Desc.   : Writes a value to a table + column in the database.
    '
    ' ************************************************************************

    Public Function SetSetting(ByRef sTable As String, ByRef sColumn As String, ByRef sValue As String, ByRef bNumber As Boolean) As Integer

        Dim result As Integer = 0
        Dim sID As String = ""

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Strip off DOC_ prefix from the table name to get id
            sID = sTable.Substring(sTable.Length - (sTable.Length - 4)) & "_id"

            ' string or value?
            If bNumber Then

                m_sSQL = "UPDATE " & sTable & " SET " & sColumn & " = " & sValue &
                         " WHERE " & sID & " = " & CStr(DOCHD1_ID)

            Else

                ' We only have to validate it if it's a string
                m_lReturn = CType(ValidateSQL(sSQLStatement:=sValue), gPMConstants.PMEReturnCode)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If

                m_sSQL = "UPDATE " & sTable & " SET " & sColumn & " = '" & sValue &
                         "' WHERE " & sID & " = " & CStr(DOCHD1_ID)

            End If

            m_lReturn = CType(m_oDatabase.SQLAction(sSQL:=m_sSQL, sSQLName:="SaveSetting", bStoredProcedure:=False, lRecordsAffected:=1), gPMConstants.PMEReturnCode)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            Return result

        Catch excep As System.Exception



            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=g_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Failed to write data to database.", vApp:=ACApp, vClass:=ACClass, vMethod:="GetSetting", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ************************************************************************
    '
    ' Function: GetSetting
    '
    ' Desc.   : Returns a value from a table + column in the database.
    '
    ' ************************************************************************

    Public Function GetSetting(ByRef sTable As String, ByRef sColumn As String, ByRef sValue As String) As Integer

        Dim result As Integer = 0
        Dim vResults(,) As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' construct the sql statement
            m_sSQL = "SELECT " & sColumn & " FROM " & sTable

            ' grab the value from the database
            m_lReturn = CType(m_oDatabase.SQLSelect(sSQL:=m_sSQL, sSQLName:="GetSetting", bStoredProcedure:=False, vResultArray:=vResults), gPMConstants.PMEReturnCode)

            ' store the result
            If Informations.IsArray(vResults) Then

                sValue = CStr(vResults(0, 0))
                'Else

                'sValue = CStr(vResults)
            End If

            Return result

        Catch excep As System.Exception



            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=g_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Failed to read data from database.", vApp:=ACApp, vClass:=ACClass, vMethod:="GetSetting", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ************************************************************************
    '
    ' Function: IsPMBEnvironment
    '
    ' Desc.   : Checks to see if connected to a PM Broking environment.
    '
    ' ************************************************************************

    Public Function IsPMBEnvironment(ByRef bPMBEnv As Boolean) As Integer

        Dim result As Integer = 0
        Dim vResults(,) As Object

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' No longer supported so return false
            bPMBEnv = False

            Return result

            m_sSQL = "SELECT update_history FROM DOC_system"

            ' grab the value from the database
            m_lReturn = CType(m_oDatabase.SQLSelect(sSQL:=m_sSQL, sSQLName:="GetSetting", bStoredProcedure:=False, vResultArray:=vResults), gPMConstants.PMEReturnCode)

            If Informations.IsArray(vResults) Then

                bPMBEnv = (CStr(vResults(0, 0)) = "Y")
            Else
                bPMBEnv = True
            End If

            Return result

        Catch excep As System.Exception



            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=g_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Failed to read data from database.", vApp:=ACApp, vClass:=ACClass, vMethod:="IsPMBEnvironment", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result
        End Try
    End Function
