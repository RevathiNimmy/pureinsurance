    <ProjectReference Include="..\..\..\..\..\..\Sirius Architecture\Components\PMWrkTaskInstance\bPMWrkTaskInstance\bPMWrkTaskInstance.vbproj" />
    <ProjectReference Include="..\..\..\..\..\..\Sirius Back Office Core\Components\Document Production\Document Template\Business\bSIRDocTemplate\bSIRDocTemplate.vbproj" />
    <ProjectReference Include="..\..\..\..\..\..\Sirius Back Office Core\Components\Instalments\Business\bSIRPremiumFinance\bSIRPremiumFinance.vbproj" />
    <ProjectReference Include="..\..\..\..\..\..\SSP.Shared\SSP.Shared.vbproj" />
