	  <add key="CrossSiteGlobalRegex" value="%3C|%3E|\.config|/|%3a|%24|%7b|\$|\{|\}|xp_cmdshell|powershell"  />
	  <add key="CrossSiteRegEx" value="((¼&lt;)[^\n]+(>|¾)*)|javascript|unescape"  />
	  <add key="SQL2Regex" value="(\bSELECT\b|\bUPDATE\b|\bDELETE\b|\bINSERT\b|\bDROP\b|\bUNION\b|\bOR\b)"  />
	  <add key="SQL4Regex" value="(?i)('|\-\-|\bEXEC\b|\bDECLARE\b|\bCAST\b|\bCONVERT\b)"  />
	  <add key="SQL5Regex" value="exec(((\s|\+)+(s|x)p\w+)|(\s@))" />
