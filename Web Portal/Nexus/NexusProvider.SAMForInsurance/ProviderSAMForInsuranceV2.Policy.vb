                        oRIArrangementLine(nCnt).RIName = v_oRIArrangementLines.Item(nCnt).RIName
                        oRIArrangementLine(nCnt).DefaultSharePercent = v_oRIArrangementLines.Item(nCnt).DefaultPerc
                        oRIArrangementLine(nCnt).ThisSharePercent = v_oRIArrangementLines.Item(nCnt).ThisPerc
                        oRIArrangementLine(nCnt).SumInsured = v_oRIArrangementLines.Item(nCnt).SumInsured
                        oRIArrangementLine(nCnt).PremiumValue = v_oRIArrangementLines.Item(nCnt).PremiumValue
                        oRIArrangementLine(nCnt).PremiumTax = v_oRIArrangementLines.Item(nCnt).Tax
                        oRIArrangementLine(nCnt).CommissionPercent = v_oRIArrangementLines.Item(nCnt).CommissionPerc
                        oRIArrangementLine(nCnt).CommissionValue = v_oRIArrangementLines.Item(nCnt).CommissionValue
                        oRIArrangementLine(nCnt).IsCommissionModified = True
                        oRIArrangementLine(nCnt).CommissionTax = v_oRIArrangementLines.Item(nCnt).CommissionTax
                        If v_oRIArrangementLines.Item(nCnt).CommissionTax > 0 Then
                            oRIArrangementLine(nCnt).CommissionTaxSpecified = True
                        End If
                        oRIArrangementLine(nCnt).PremiumPercent = v_oRIArrangementLines.Item(nCnt).ThisPerc
                        oRIArrangementLine(nCnt).AgreementCode = v_oRIArrangementLines.Item(nCnt).AgreementCode
