    ''' <summary>
    ''' To get latest policy version for given search criteria
    ''' </summary>
    ''' <param name="v_sInsuranceRef"></param>
    ''' <param name="v_sProductCode"></param>
    ''' <param name="v_oRecordType"></param>
    ''' <param name="v_nAgentId"></param>
    ''' <param name="v_sInsuredName"></param>
    ''' <param name="v_nMaxRowsToFetch"></param>
    ''' <param name="v_dtCoverStartDate"></param>
    ''' <param name="v_dtQuoteOrLiveDate"></param>
    ''' <param name="v_sBranchCode"></param>
    ''' <param name="v_sRiskIndex"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overrides Function FindLatestPolicyVersions(ByVal v_sInsuranceRef As String, ByVal v_sProductCode As String,
                                            ByVal v_oRecordType As InsuranceQuoteType, ByVal v_nAgentId As Integer,
                                            ByVal v_sInsuredName As String, ByVal v_nMaxRowsToFetch As Integer, Optional ByVal v_dtCoverStartDate As Date = Nothing,
                                            Optional ByVal v_dtQuoteOrLiveDate As Date = Nothing, Optional ByVal v_sBranchCode As String = Nothing, Optional ByVal bRetrieveAssociates As Boolean = False, Optional ByVal v_sRiskIndex As String = Nothing) As InsuranceFileDetailsCollection

        SyncLock oLock

            Dim oFindLatestPolicyVersionsRequest As BaseClasses.FindLatestPolicyVersionsQuery
            Dim oFindLatestPolicyVersionsResponse As BaseClasses.FindLatestPolicyVersionsQueryBaseResponse
            Dim oInsuranceFileDetailsCollection As InsuranceFileDetailsCollection = Nothing
            Dim oNewInsuranceFileDetails As InsuranceFileDetails
            Dim sbLogMessage As StringBuilder

            Try
                oFindLatestPolicyVersionsRequest = New BaseClasses.FindLatestPolicyVersionsQuery
                oFindLatestPolicyVersionsResponse = New BaseClasses.FindLatestPolicyVersionsQueryBaseResponse
                sbLogMessage = New StringBuilder


                With oFindLatestPolicyVersionsRequest
                    .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                    'if the passed parameter v_sBranchCode is empty
                    If String.IsNullOrEmpty(v_sBranchCode) Then
                        'if the branch code is NOT in session 
                        If String.IsNullOrEmpty(sBranchCode) Then
                            'Use the default branch code
                            .BranchCode = sDefaultBranchCode
                        Else
                            'Use the branch code in session 
                            .BranchCode = sBranchCode
                        End If
                    Else
                        'use the passed parameter v_sBranchCode
                        .BranchCode = v_sBranchCode
                    End If

                    'Checking the Quote Type
                    Select Case v_oRecordType
                        Case InsuranceQuoteType.QUOTE
                            .RecordType = PureService.QuoteType.QUOTE
                            .RecordTypeSpecified = True
                        Case InsuranceQuoteType.POLICY
                            .RecordType = PureService.QuoteType.POLICY
                            .RecordTypeSpecified = True
                        Case InsuranceQuoteType.ALL
                            .RecordType = PureService.QuoteType.ALL
                            .RecordTypeSpecified = True
                    End Select
                    .ProductCode = v_sProductCode
                    .InsuranceRef = v_sInsuranceRef
                    .AgentKey = v_nAgentId
                    .InsuredName = v_sInsuredName
                    If v_dtQuoteOrLiveDate <> Nothing Then
                        .QuoteORLiveDate = v_dtQuoteOrLiveDate
                        .QuoteORLiveDateSpecified = True
                    End If
                    If v_dtCoverStartDate <> Nothing Then
                        .CoverStartDate = v_dtCoverStartDate
                        .CoverStartDateSpecified = True
                    End If
