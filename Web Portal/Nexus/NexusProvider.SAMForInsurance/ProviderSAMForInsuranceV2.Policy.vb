                    End If
                End With

                Using trace As New Tracer(Category.Trace)
                    ApiClient._tokenModel = GetApiTokendetails()
                    Dim result As String = ApiClient.Get(ApiMethods.GetPTPoliciesForAmend, oRequest)
                    oResponse = ApiClient.DeserializeJson(Of BaseClasses.GetPTPoliciesForAmendQueryResponse)(result)
