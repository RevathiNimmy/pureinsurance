    ''' <summary>
    ''' RIArrangementRow_Others calculate the other row from RI Table
    ''' </summary>
    Sub RIArrangementRow_Others(ByVal oRITable As DataTable, ByRef oXMLDoc As XmlDocument, ByVal RIBand As XmlElement, ByVal dsParticipentGridData As DataSet, ByVal sPlacement As String)
        Dim prefix As String = If(oRITable.TableName.Contains("Current"), "Current", If(oRITable.TableName.Contains("Original"), "Original", ""))
        If String.IsNullOrEmpty(prefix) Then Return

        For Each myRow As DataRow In oRITable.Rows
            If Not ShouldProcessRow(myRow, sPlacement, oRITable) Then Continue For
            Dim ArrangementRow As XmlElement = CreateArrangementRow(oXMLDoc, oRITable, myRow)
            AddBrokerParticipants(oXMLDoc, ArrangementRow, myRow, dsParticipentGridData, prefix)
            AddFAXParticipants(oXMLDoc, ArrangementRow, myRow, dsParticipentGridData, prefix)
            RIBand.AppendChild(ArrangementRow)
        Next
    End Sub

    Private Function ShouldProcessRow(myRow As DataRow, sPlacement As String, oRITable As DataTable) As Boolean
        Dim placement As String = If(IsDBNull(myRow("Placement")), "", myRow("Placement").ToString().Trim().ToUpper())
        If sPlacement.Trim.ToUpper = "GROSS" Then Return placement = "GROSS"
        If String.IsNullOrEmpty(sPlacement.Trim) AndAlso placement = "GROSS" Then Return False
        ' When placement is empty, only add when is_obligatory is false
        If String.IsNullOrEmpty(sPlacement.Trim) Then
            Dim isObligatory As Boolean = Not IsDBNull(myRow("IsObligatory")) AndAlso Convert.ToBoolean(myRow("IsObligatory"))
            If isObligatory Then Return False
        End If
        Return IsDBNull(myRow("Placement")) OrElse (placement <> "FAC XOL" AndAlso placement <> "FAC PROP")
    End Function
    Private Function CreateArrangementRow(oXMLDoc As XmlDocument, oRITable As DataTable, myRow As DataRow) As XmlElement
        Dim ArrangementRow As XmlElement = oXMLDoc.CreateElement("ArrangementRow")
        For Each myCol As DataColumn In oRITable.Columns
            Dim sValue As String = If(IsDBNull(myRow(myCol.ColumnName)) OrElse String.IsNullOrEmpty(myRow(myCol.ColumnName)), "", myRow(myCol.ColumnName).ToString())
            ArrangementRow.SetAttribute(myCol.ColumnName, sValue)
        Next
        Return ArrangementRow
    End Function

    Private Sub AddBrokerParticipants(oXMLDoc As XmlDocument, ArrangementRow As XmlElement, myRow As DataRow, dsParticipentGridData As DataSet, prefix As String)
        Dim oBrokerPartTable As DataTable = dsParticipentGridData.Tables(prefix & "_Broker_Participent")
        For Each myBrokerPartRow As DataRow In oBrokerPartTable.Rows
            If Not RowKeysMatch(myRow, myBrokerPartRow, prefix = "Original") Then Continue For
            Dim BrokerParticipentRow As XmlElement = CreateElementFromRow(oXMLDoc, "BrokerParticipentRow", oBrokerPartTable, myBrokerPartRow)
            ArrangementRow.AppendChild(BrokerParticipentRow)
        Next
    End Sub

    Private Sub AddFAXParticipants(oXMLDoc As XmlDocument, ArrangementRow As XmlElement, myRow As DataRow, dsParticipentGridData As DataSet, prefix As String)
        Dim oFAXPartTable As DataTable = dsParticipentGridData.Tables(prefix & "_FAX_Participent")
        For Each myFAXPartRow As DataRow In oFAXPartTable.Rows
            If Not RowKeysMatch(myRow, myFAXPartRow, prefix = "Original") Then Continue For
            Dim FAXParticipentRow As XmlElement = CreateElementFromRow(oXMLDoc, "FAXParticipentRow", oFAXPartTable, myFAXPartRow)
            AddFAXBrokerParticipants(oXMLDoc, FAXParticipentRow, myFAXPartRow, dsParticipentGridData, prefix)
            ArrangementRow.AppendChild(FAXParticipentRow)
        Next
    End Sub

    Private Sub AddFAXBrokerParticipants(oXMLDoc As XmlDocument, FAXParticipentRow As XmlElement, myFAXPartRow As DataRow, dsParticipentGridData As DataSet, prefix As String)
        Dim oFAXBrokerPartTable As DataTable = dsParticipentGridData.Tables(prefix & "_FAX_Broker_Participent")
        For Each myFAXBrokerPartRow As DataRow In oFAXBrokerPartTable.Rows
            If Not RowKeysMatch(myFAXPartRow, myFAXBrokerPartRow, prefix = "Original") Then Continue For
            Dim FAXBrokerParticipentRow As XmlElement = CreateElementFromRow(oXMLDoc, "FAXParticipentRow", oFAXBrokerPartTable, myFAXBrokerPartRow)
            FAXParticipentRow.AppendChild(FAXBrokerParticipentRow)
        Next
    End Sub

    Private Function RowKeysMatch(parentRow As DataRow, childRow As DataRow, checkEmpty As Boolean) As Boolean
        If IsDBNull(parentRow("RIArrangementLineKey")) OrElse IsDBNull(parentRow("RIarrangementKey")) Then Return False
        If checkEmpty AndAlso (String.IsNullOrEmpty(parentRow("RIArrangementLineKey")) OrElse String.IsNullOrEmpty(parentRow("RIarrangementKey"))) Then Return False
        Return parentRow("RIArrangementLineKey").Equals(childRow("RIArrangementLineKey")) AndAlso parentRow("RIarrangementKey").Equals(childRow("RIarrangementKey"))
    End Function

    Private Function CreateElementFromRow(oXMLDoc As XmlDocument, elementName As String, table As DataTable, row As DataRow) As XmlElement
        Dim element As XmlElement = oXMLDoc.CreateElement(elementName)
        For Each col As DataColumn In table.Columns
            Dim sValue As String = If(IsDBNull(row(col.ColumnName)) OrElse String.IsNullOrEmpty(row(col.ColumnName)), "", row(col.ColumnName).ToString())
            element.SetAttribute(col.ColumnName, sValue)
        Next
        Return element
    End Function

