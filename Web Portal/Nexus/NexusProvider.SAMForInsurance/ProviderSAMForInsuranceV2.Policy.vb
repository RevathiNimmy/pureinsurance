    Public Overrides Sub CalculateRITax(ByVal v_iRiskKey As Integer,
                                           ByVal v_iPartyKey As Integer,
                                           ByVal v_dPremium As Double,
                                           ByVal v_iInsuranceFileKey As Integer,
                                           ByRef r_dTaxPercentage As Double,
