    Public Overrides Function GetRatingDetails(ByVal v_iriskKeyField As Integer,
                                  ByVal i_InsuranceFileKey As Integer,
                                  Optional ByVal v_sBranchCode As String = Nothing) As RatingCollection
        'Dim oSAM As PurePolicyServiceClient 'SAMForInsuranceV2's Object
        Dim oGetRatingDetailsRequest As GetRatingDetailsQuery ' Request Type
        Dim oGetRatingDetailsResponse As GetRatingDetailsQueryResponse ' Response Type
        Dim oRatings As RatingCollection = Nothing
        Dim oNewRating As Rating 'Object of Rating Class
        Dim sbLogMessage As StringBuilder

        Try
            'oSAM = InitializePolicyServiceMethod()
            oGetRatingDetailsRequest = New GetRatingDetailsQuery
            oGetRatingDetailsResponse = New GetRatingDetailsQueryResponse
            sbLogMessage = New StringBuilder

            With oGetRatingDetailsRequest
                .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                '.WCFSecurityToken = SecurityToken()
                'if the passed parameter v_sBranchCode is empty
                If String.IsNullOrEmpty(v_sBranchCode) Then
                    'if the branch code is NOT in session 
                    If String.IsNullOrEmpty(sBranchCode) Then
                        'Use the default branch code
                        .BranchCode = sDefaultBranchCode
                    Else
                        'Use the branch code in session 
                        .BranchCode = sBranchCode
                    End If
                Else
                    'use the passed parameter v_sBranchCode
                    .BranchCode = v_sBranchCode
                End If
                .RiskKey = v_iriskKeyField
                .InsuranceFileKey = i_InsuranceFileKey
            End With

            'Calling the SAM Method with Request Type
            'add trace to allow us to debug slow SAM calls
            Using trace As New Tracer(Category.Trace)
                ApiClient._tokenModel = GetApiTokendetails()
                Dim result As String = ApiClient.Get(ApiMethods.GetRatingDetails, oGetRatingDetailsRequest)
                oGetRatingDetailsResponse = ApiClient.DeserializeJson(Of GetRatingDetailsQueryResponse)(result)

            End Using

            'NO catches on the try as we want to cascade all exceptions back up the stack for handling.

            ' Disposing the SAM's object

            'Rating Details Collection Object and their Initialization

            oRatings = New RatingCollection

            With oGetRatingDetailsResponse 'With Response Type
                'If .Errors IsNot Nothing Then

                '    'Process the error object if errors, and throw as a single exception
                '    Throw New NexusException(.Errors)
                'Else

                If .RatingDetails IsNot Nothing Then 'Added  on 20th Jan 2009
                    For Each oRating As BaseClasses.BaseGetRatingDetailsResponseTypeRow In .RatingDetails 'Fetching from the  Risk Response Collection
                        oNewRating = New Rating()
                        With oNewRating
                            .RatingSectionType = oRating.RatingSectionType
                            .PolicySectionType = oRating.PolicySectionType
                            .RateTypeCode = oRating.RatingTypeCode
                            .RateType = oRating.RateType
                            .AnnualRate = oRating.AnnualRate
                            .SumInsured = oRating.SumInsured
                            .ThisPremium = oRating.ThisPremium
                            .AnnualPremium = oRating.AnnualPremium
                            .Country = oRating.Country
                            .State = oRating.State
                            .RateSectionID = oRating.RatingSectionId
                            .RatingSectionTypeID = oRating.RatingSectionTypeId
                            .PolicySectionTypeID = oRating.PolicySectionTypeId
                            .RateTypeID = oRating.RateTypeId
                            .OriginalFlag = oRating.OriginalFlag
                            .CurrencyID = oRating.CurrencyId
                            .CountryID = oRating.CountryId
                            .StateID = oRating.StateId
                            .IsAmmended = oRating.IsAmended
                            .CalculatedPremium = oRating.CalculatedPremium
                            .OverrideReason = oRating.OverrideReason
                            .EarningPattern = oRating.EarningPattern
                            .EarningPatternId = oRating.EarningPatternId
                            .StateCode = oRating.StateCode
                            .CountryCode = oRating.CountryCode
                            .RatingTypeCode = oRating.RatingTypeCode
                            .RatingSectionTypeCode = oRating.RatingSectionTypeCode
                            .EarningPatternCode = oRating.EarningPatternCode
                            .CurrencyCode = oRating.CurrencyCode
                        End With
                        oRatings.Add(oNewRating) 'Adding into the Risk Collection
                    Next

                End If
                'End If
            End With


            If Logger.IsLoggingEnabled Then
                sbLogMessage.AppendLine("GetRatingDetails executed ok" & vbCrLf)
                sbLogMessage.AppendLine("Input:" & vbCrLf)
                sbLogMessage.AppendLine("v_iriskKeyField = " & v_iriskKeyField.ToString & vbCrLf)
                sbLogMessage.AppendLine("i_InsuranceFileKey = " & i_InsuranceFileKey.ToString & vbCrLf)

                If Not IsNothing(v_sBranchCode) Then
                    sbLogMessage.AppendLine("v_sBranchCode = " & v_sBranchCode.ToString & vbCrLf)
                Else
                    sbLogMessage.AppendLine("v_sBranchCode = nothing" & vbCrLf)
                End If

                sbLogMessage.AppendLine("Returned " & oRatings.Count.ToString & " results" & vbCrLf)
                LogMessageEntry(sbLogMessage)
            End If

            'Catch ex As FaultException(Of PureService.SAMMethodResponseData)

            'FaultErrorHandler(ex) ' handling fault error messages 

        Catch ex As Exception
            Throw
        Finally
            'oSAM.Close()
            oGetRatingDetailsRequest = Nothing
            oGetRatingDetailsResponse = Nothing
        End Try


        Return oRatings 'Returning Risk Collection

    End Function

