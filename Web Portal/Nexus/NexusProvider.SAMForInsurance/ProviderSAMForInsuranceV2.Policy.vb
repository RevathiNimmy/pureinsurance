                            v_oPolicy.AssociatedClients = v_oCurrentPolicy.AssociatedClients
                            v_oPolicyCollection.Add(v_oPolicy)
                        Next
                    End If
                End With

                If Logger.IsLoggingEnabled Then
                    sbLogMessage.AppendLine("GetAllPolicyVersions executed ok" & vbCrLf)
                    sbLogMessage.AppendLine("Input:" & vbCrLf)
                    sbLogMessage.AppendLine("v_iInsuranceFolderKey = " & v_iInsuranceFolderKey.ToString & vbCrLf)

                    sbLogMessage.AppendLine("Returned " & v_oPolicyCollection.Count.ToString & " results" & vbCrLf)

                    LogMessageEntry(sbLogMessage)
                End If

                'Catch ex As FaultException(Of PureService.SAMMethodResponseData)

                'FaultErrorHandler(ex) ' handling fault error messages 

            Catch ex As Exception
                Throw
            Finally
                'oSAM.Close()
                oGetAllPolicyVersionsRequest = Nothing
                oGetAllPolicyVersionsResponse = Nothing
            End Try


            Return v_oPolicyCollection

        End SyncLock

    End Function

#Region "SAGICOR - 1.13.8 Broker View"
    ''' <summary>
    ''' This method is used to get Broker summary details
    ''' </summary>
    ''' <param name="v_oQuoteType"></param>
    ''' <param name="v_sProductCode"></param>
    ''' <param name="v_sResultsType"></param>
    ''' <param name="v_sInsuranceRef"></param>
    ''' <param name="v_sInsuredName"></param>
    ''' <param name="v_iMaxRowsToFetch"></param> 
    ''' <param name="v_sBranchCode"></param>
    ''' <param name="CoverStartDate"></param>
    ''' <param name="QuoteORLiveDate"></param>
    ''' <param name="Agentkey"></param>
    ''' <returns></returns>
    ''' <remarks></remarks> 
    Public Overrides Function GetBrokerSummary(ByVal v_oQuoteType As InsuranceQuoteType, ByVal v_sProductCode As String, ByVal v_sResultsType As Integer, ByVal v_sInsuranceRef As String, ByVal v_sInsuredName As String, ByVal v_iMaxRowsToFetch As Integer,
                                                  Optional ByVal v_sBranchCode As String = Nothing, Optional ByVal CoverStartDate As Date = Nothing, Optional ByVal QuoteORLiveDate As Date = Nothing, Optional ByVal Agentkey As Integer = Nothing, Optional ByVal v_sRiskIndex As String = Nothing, Optional ByVal v_iFilterQuotes As InsuranceFilterQuotesType = Nothing, Optional ByVal v_iFilterPolicies As InsuranceFilterPoliciesType = Nothing) As PartySummary

        SyncLock oLock

            'Dim oSAM As PurePolicyServiceClient
            Dim oGetBrokerSummaryRequest As SSP.PureInsuranceRestAPIHandler.BaseClasses.GetBrokerSummaryCommand
            Dim oGetBrokerSummaryResponse As SSP.PureInsuranceRestAPIHandler.BaseClasses.GetBrokerSummaryCommandResponse
            Dim oBrokerSummary As PartySummary
            Dim oNewPolicy As Policy
            Dim sbLogMessage As StringBuilder

            Try
                ' oSAM = InitializePolicyServiceMethod()
                oGetBrokerSummaryRequest = New SSP.PureInsuranceRestAPIHandler.BaseClasses.GetBrokerSummaryCommand
                oGetBrokerSummaryResponse = New SSP.PureInsuranceRestAPIHandler.BaseClasses.GetBrokerSummaryCommandResponse
                sbLogMessage = New StringBuilder


                With oGetBrokerSummaryRequest
                    .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                    '.WCFSecurityToken = SecurityToken()
                    'if the passed parameter v_sBranchCode is empty
                    If String.IsNullOrEmpty(v_sBranchCode) Then
                        'if the branch code is NOT in session 
                        If String.IsNullOrEmpty(sBranchCode) Then
                            'Use the default branch code
                            .BranchCode = sDefaultBranchCode
                        Else
                            'Use the branch code in session 
                            .BranchCode = sBranchCode
                        End If
                    Else
                        'use the passed parameter v_sBranchCode
                        .BranchCode = v_sBranchCode
                    End If

                    'to limit the search return from SAM
                    If v_iMaxRowsToFetch > 0 Then
                        .MaxRowsToFetch = v_iMaxRowsToFetch
                        .MaxRowsToFetchSpecified = True
                    Else
                        .MaxRowsToFetchSpecified = False
                    End If

                    'Checking the Product Type
                    .ProductCode = v_sProductCode.ToUpper()

                    'Checking the Results Type
                    Select Case v_sResultsType
                        Case 1
                            .ShowUserOnly = True
                            .ShowUserOnlySpecified = True
                        Case 0
                            .ShowUserOnly = False
                            .ShowUserOnlySpecified = True
                        Case -1
                            .ShowUserOnly = False
                            .ShowUserOnlySpecified = False
                    End Select

                    'use the passed parameter v_sInsuredName
                    .InsuredName = v_sInsuredName

                    'Checking the Quote Type
                    Select Case v_oQuoteType
                        Case InsuranceQuoteType.POLICY
                            .RecordType = Enums.QuoteType.POLICY
                            .RecordTypeSpecified = True
                        Case InsuranceQuoteType.QUOTE
                            .RecordType = Enums.QuoteType.QUOTE
                            .RecordTypeSpecified = True
                        Case Else
                            .RecordTypeSpecified = False
                    End Select
                    'use the passed parameter v_sInsuranceRef
                    .InsuranceRef = v_sInsuranceRef

                    'New Paramenter passed to request as per WPR 63
                    .CoverStartDate = CoverStartDate
                    .QuoteORLiveDate = QuoteORLiveDate
                    If (CoverStartDate.Date <> Date.MinValue) Then
                        .CoverStartDateSpecified = True
                    End If
                    If (QuoteORLiveDate.Date <> Date.MinValue) Then
                        .QuoteORLiveDateSpecified = True
                    End If
                    .AgentKey = Agentkey
                    .RiskIndex = v_sRiskIndex
                    If GetOptionSetting(NexusProvider.OptionType.SystemOption, NexusProvider.SystemOptions.AllowPolicyClientAssociations).OptionValue = "1" Then
                        .RetrieveAssociates = True
                    Else
                        .RetrieveAssociates = False
                    End If


                    Select Case v_iFilterQuotes
                        Case InsuranceFilterQuotesType.All
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.All
                        Case InsuranceFilterQuotesType.ExcludeExpiredQuotes
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.ExcludeExpiredQuotes
                        Case InsuranceFilterQuotesType.ExpiredQuotesOnly
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.ExpiredQuotesOnly
                        Case InsuranceFilterQuotesType.ExcludeCancelledQuotes
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.ExcludeCancelledQuotes
                        Case InsuranceFilterQuotesType.CancelledQuotesOnly
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.CancelledQuotesOnly
                        Case InsuranceFilterQuotesType.ExcludeCancelledandExpiredQuotes
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.ExcludeCancelledandExpiredQuotes
                        Case InsuranceFilterQuotesType.NBQuotesOnly
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.NBQuotesOnly
                        Case InsuranceFilterQuotesType.MTAQuotesOnly
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.MTAQuotesOnly
                        Case InsuranceFilterQuotesType.RenewalQuotesOnly
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.RenewalQuotesOnly
                        Case Else
                            .FilterQuotes = SSP.PureInsuranceRestAPIHandler.Enums.FilterQuotesType.All
                    End Select

                    Select Case v_iFilterPolicies
                        Case InsuranceFilterPoliciesType.All
                            .FilterPolicies = SSP.PureInsuranceRestAPIHandler.Enums.FilterPoliciesType.All
                        Case InsuranceFilterPoliciesType.ExcludeLapsedPolicies
                            .FilterPolicies = SSP.PureInsuranceRestAPIHandler.Enums.FilterPoliciesType.ExcludeLapsedPolicies
                        Case InsuranceFilterPoliciesType.LapsedPoliciesOnly
                            .FilterPolicies = SSP.PureInsuranceRestAPIHandler.Enums.FilterPoliciesType.LapsedPoliciesOnly
                        Case InsuranceFilterPoliciesType.ExcludeCancelledPolicies
                            .FilterPolicies = SSP.PureInsuranceRestAPIHandler.Enums.FilterPoliciesType.ExcludeCancelledPolicies
                        Case InsuranceFilterPoliciesType.CancelledPoliciesOnly
                            .FilterPolicies = SSP.PureInsuranceRestAPIHandler.Enums.FilterPoliciesType.CancelledPoliciesOnly
                        Case InsuranceFilterPoliciesType.ExcludeCancelledandLapsedPolicies
                            .FilterPolicies = SSP.PureInsuranceRestAPIHandler.Enums.FilterPoliciesType.ExcludeCancelledandLapsedPolicies
                        Case Else
                            .FilterPolicies = Enums.FilterPoliciesType.All
                    End Select
                End With


                'add trace to allow us to debug slow SAM calls
                Using trace As New Tracer(Category.Trace)
                    'oGetBrokerSummaryResponse = oSAM.GetBrokerSummary(oGetBrokerSummaryRequest)
                    SSP.PureInsuranceRestAPIHandler.ApiClient._tokenModel = GetApiTokendetails()
                    Dim result As String = SSP.PureInsuranceRestAPIHandler.ApiClient.Get(ApiMethods.GetBrokerSummary, oGetBrokerSummaryRequest)
                    oGetBrokerSummaryResponse = SSP.PureInsuranceRestAPIHandler.ApiClient.DeserializeJson(Of SSP.PureInsuranceRestAPIHandler.BaseClasses.GetBrokerSummaryCommandResponse)(result)
                End Using

                With oGetBrokerSummaryResponse


                    oBrokerSummary = New PartySummary()
                    If .InsuranceFileDetails IsNot Nothing Then

                        oBrokerSummary.Policies = New PolicyCollection()


                        For Each oPolicy As SSP.PureInsuranceRestAPIHandler.BaseClasses.BaseGetBrokerSummaryResponseTypeRow In .InsuranceFileDetails

                            oNewPolicy = New Policy(oPolicy.InsuranceFileKey)

                            With oNewPolicy
                                .InsuranceFileKey = oPolicy.InsuranceFileKey
                                .Reference = oPolicy.InsuranceRef
                                .InsuranceFolderKey = oPolicy.InsuranceFolderKey
                                .DateIssued = oPolicy.IssuedDate
                                .CoverStartDate = oPolicy.StartDate
                                .ExpiryDate = oPolicy.ExpiryDate
                                .PartyKey = oPolicy.PartyKey
                                .ProductCode = oPolicy.ProductCode
                                .ProductDescription = oPolicy.ProductDescription
                                .InsuranceFileTypeCode = oPolicy.InsuranceFileTypeCode
                                .ClientCode = oPolicy.ClientShortName
                                .PolicyStatusCode = oPolicy.PolicyStatusCode
                                .PolicyTypeCode = oPolicy.InsuranceFileTypeCode
                                .PolicyTypeDescription = oPolicy.InsuranceFileTypeDescription
                                .PolicyStatus = oPolicy.PolicyStatusDescription
                                .IsCurrent = oPolicy.IsCurrent
                                .ClientName = oPolicy.ClientName
                                .BaseInsuranceFolderKey = oPolicy.BaseInsuranceFolderKey
                                .QuoteVersion = oPolicy.QuoteVersion
                                .QuoteStatusKey = oPolicy.QuoteStatusKey
                                .LeadAgentKey = oPolicy.AgentKey
                                .LeadAgent = oPolicy.AgentName
                                .QuoteExpiryDate = oPolicy.QuoteExpiryDate
                                .RenewedVersion = oPolicy.RenewedVersion
                                '.QuoteStatus = oPolicy.RiskStatus
                                .RiskStatus = oPolicy.RiskStatus
                                .IsMarketPlacePolicy = oPolicy.IsMarketPlacePolicy
                                .BaseInsuranceFileKey = oPolicy.BaseInsuranceFileKey
                                .IsReinstateLinkVersion = oPolicy.IsReinstateLinkVersion
                                .RiskNumber = oPolicy.RiskNumber
                                .RiskDescription = oPolicy.RiskDescription
                                .AssociatedClients = oPolicy.AssociatedClients
                            End With
                            oBrokerSummary.Policies.Add(oNewPolicy)
                        Next
                    End If
                End With

                If Logger.IsLoggingEnabled Then
                    sbLogMessage.AppendLine("GetBrokerSummary executed ok" & vbCrLf)
                    sbLogMessage.AppendLine("Input:" & vbCrLf)
                    sbLogMessage.AppendLine("v_sInsuredName = " & v_sInsuredName.ToString & vbCrLf)

                    If Not IsNothing(v_sBranchCode) Then
                        sbLogMessage.AppendLine("v_sBranchCode = " & v_sBranchCode.ToString & vbCrLf)
                    Else
                        sbLogMessage.AppendLine("v_sBranchCode = nothing" & vbCrLf)
                    End If

                    If oBrokerSummary.Policies IsNot Nothing Then
                        sbLogMessage.AppendLine("Returned " & oBrokerSummary.Policies.Count.ToString & " results" & vbCrLf)
                    End If

                    LogMessageEntry(sbLogMessage)
                End If

                'Catch ex As FaultException(Of PureService.SAMMethodResponseData)

                'FaultErrorHandler(ex) ' handling fault error messages 

            Catch ex As Exception
                Throw
            Finally
                'oSAM.Close()
                oGetBrokerSummaryRequest = Nothing
                oGetBrokerSummaryResponse = Nothing
            End Try

            Return oBrokerSummary
        End SyncLock
    End Function

