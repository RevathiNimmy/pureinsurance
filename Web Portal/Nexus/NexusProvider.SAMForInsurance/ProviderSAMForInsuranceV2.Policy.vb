                    ' oAddAddressResponse = oSAM.AddAddress(oAddAddressRequest)
                    SSP.PureInsuranceRestAPIHandler.ApiClient._tokenModel = GetApiTokendetails()
                    Dim result As String = SSP.PureInsuranceRestAPIHandler.ApiClient.Post(ApiMethods.AddAddress, oAddAddressRequest)
                    oAddAddressResponse = SSP.PureInsuranceRestAPIHandler.ApiClient.DeserializeJson(Of SSP.PureInsuranceRestAPIHandler.BaseClasses.AddAddressCommandResponse)(result)
                End Using

                With oAddAddressResponse.AddAddressResponse


                    r_oAddress.Key = .AddressKey


                End With

