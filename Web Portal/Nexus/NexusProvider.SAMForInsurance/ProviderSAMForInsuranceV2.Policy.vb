                    .AddressLine9 = r_oAddress.Address9
                    .AddressLine10 = r_oAddress.Address10

                    .AddressTypeCode = r_oAddress.AddressType
                    .CountryCode = r_oAddress.CountryCode

                    If String.IsNullOrEmpty(r_oAddress.PostCode) Then
                        Throw New ArgumentNullException("Address.PostCode")
                    Else
