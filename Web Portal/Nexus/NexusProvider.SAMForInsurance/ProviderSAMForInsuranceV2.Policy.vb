    ''' <param name="nInsuranceFileKey"></param>
    ''' <param name="sTransactionType"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overrides Function SavePremiumFinanceDetails(ByVal oPayment As NexusProvider.Payment,
                                                        ByVal nInsuranceFileKey As Integer,
                                                        ByVal sTransactionType As String)
        SyncLock oLock

            Dim oSavePFDetailsRequest As New BaseClasses.SavePremiumFinanceDetailsCommand
            Dim oSavePFDetailsResponse As New BaseClasses.SavePremiumFinanceDetailsCommandResponse

            With oSavePFDetailsRequest
                .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                If String.IsNullOrEmpty(sBranchCode) Then
                    'Use the default branch code
                    .BranchCode = sDefaultBranchCode
                Else
                    'Use the branch code in session
                    .BranchCode = sBranchCode
                End If

                ' Set ProcessPFMode for claim recovery instalment plans (SR = Salvage, TPR = Third Party Recovery)
                ' This tells the REST API service to use ICC/ICD transaction codes instead of INC/IND
                If sTransactionType IsNot Nothing Then
                    .ProcessPFMode = sTransactionType
                Else
                    If Current.Session("PFProcessMode") IsNot Nothing Then
                        .ProcessPFMode = CStr(Current.Session("PFProcessMode"))
                    End If
                End If


                If nInsuranceFileKey > 0 Then
                    .InsuranceFileKey = nInsuranceFileKey
                Else
                    Throw New ArgumentException("InsuranceFileKey Missing")
                End If

                If oPayment IsNot Nothing Then
                    .SchemeNo = oPayment.SelectedSchemeNo
                    .SchemeVersion = oPayment.SelectedSchemeVersion
                    .PFRF_ID = oPayment.Pref_ID
                    .NetAmount = oPayment.AmountPaid
                    .AmountToFinance = oPayment.AmountToFinance
                    .Deposit = oPayment.InstDepositAmount
                    .PartyBankKey = oPayment.PartyBankKey
                    .BankAccountName = oPayment.BankAccountName
                    .BankAccountNo = oPayment.BankAccountNo
                    .BankAreaCode = oPayment.BankAreaCode
                    .BankBranch = oPayment.BankBranch
                    .BankExtn = oPayment.BankExtn
