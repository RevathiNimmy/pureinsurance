                If Logger.IsLoggingEnabled Then
                    sbLogMessage.AppendLine("UpdateRIArrangementLines executed ok" & vbCrLf)
                    LogMessageEntry(sbLogMessage)
                End If

                'Catch ex As FaultException(Of PureService.SAMMethodResponseData)

                'FaultErrorHandler(ex) ' handling fault error messages 

            Catch ex As Exception
                Throw
            Finally
                'oSAM.Close()
                oUpdateRIArrangementLinesRequest = Nothing
                oUpdateRIArrangementLinesResponse = Nothing
            End Try

