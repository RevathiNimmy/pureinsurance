#Region "WPR75-Backdated MTA Rework"
    ''' <summary>
    ''' For getting backdated MTA versions for a policy
    ''' </summary>
    ''' <param name="v_nInsuranceFileKey">Base insurance file key</param>
    ''' <param name="v_sBranchCode">Branch Code</param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overrides Function GetBackdatedMTAPolicyVersions(ByVal v_nInsuranceFileKey As Integer,
                                        Optional ByVal v_sBranchCode As String = Nothing) As PolicyCollection

        Dim oGetBackdatedMTARiskVersionsRequest As BaseClasses.GetBackdatedMTAPolicyVersionsQuery
        Dim oGetBackdatedMTARiskVersionsResponse As BaseClasses.AddBackDatedMTAQuoteCommandResponse
        Dim oPolicyVersion As Policy
        Dim oPolicyVersions As New PolicyCollection
        Dim iCt As Integer = 0
        Dim sbLogMessage As StringBuilder

        Try
            oGetBackdatedMTARiskVersionsRequest = New BaseClasses.GetBackdatedMTAPolicyVersionsQuery
            oGetBackdatedMTARiskVersionsResponse = New BaseClasses.AddBackDatedMTAQuoteCommandResponse

            With oGetBackdatedMTARiskVersionsRequest

                'if the passed parameter v_sBranchCode is empty
                If String.IsNullOrEmpty(v_sBranchCode) Then
                    'if the branch code is NOT in session 
                    If String.IsNullOrEmpty(sBranchCode) Then
                        'Use the default branch code
                        .BranchCode = sDefaultBranchCode
                    Else
                        'Use the branch code in session 
                        .BranchCode = sBranchCode
                    End If
                Else
                    'use the passed parameter v_sBranchCode
                    .BranchCode = v_sBranchCode
                End If

                'InsuranceFileKey for selected quote
                If v_nInsuranceFileKey > 0 Then
                    .InsuranceFileKey = v_nInsuranceFileKey
                Else
                    Throw New ArgumentNullException("v_iInsuranceFileKey")
                End If
                .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
            End With

            Using trace As New Tracer(Category.Trace)
                ApiClient._tokenModel = GetApiTokendetails()
                Dim result As String = ApiClient.Get(ApiMethods.GetBackdatedMTAPolicyVersions, oGetBackdatedMTARiskVersionsRequest)
                oGetBackdatedMTARiskVersionsResponse = ApiClient.DeserializeJson(Of BaseClasses.AddBackDatedMTAQuoteCommandResponse)(result)
            End Using

            With oGetBackdatedMTARiskVersionsResponse
                If 1 = 0 Then
                    'Process the error object if errors, and throw as a single exception
                    'Throw New NexusException(.Errors)
                Else
                    'Create a collection of PolicyCollection type from backdated versions retrieved from the response
                    If .BackdatedTransactions IsNot Nothing Then
                        For Each oBackdatedTransactionRow As BaseClasses.BaseAddBackDatedMtaQuoteResponseTypeRow In .BackdatedTransactions
                            oPolicyVersion = New Policy()
                            With oBackdatedTransactionRow
                                oPolicyVersion.InsuranceFileKey = oBackdatedTransactionRow.InsuranceFileCnt
                                oPolicyVersion.InsuranceFolderKey = oBackdatedTransactionRow.InsuranceFolderCnt
                                oPolicyVersion.PolicyVersion = oBackdatedTransactionRow.PolicyVersion
                                oPolicyVersion.PolicyTypeDescription = oBackdatedTransactionRow.PolicyType
                                oPolicyVersion.CoverStartDate = oBackdatedTransactionRow.CoverStartDate
                                oPolicyVersion.CoverEndDate = oBackdatedTransactionRow.CoverEndDate
                                oPolicyVersion.Premium = oBackdatedTransactionRow.MTAPremium
                                oPolicyVersion.PolicyStatus = oBackdatedTransactionRow.PolicyStatus
                                oPolicyVersion.CurrencyCode = oBackdatedTransactionRow.CurrencyCode
                                ' New fields according to OOS Redesign spec.
                                oPolicyVersion.OriginalMtaPremium = oBackdatedTransactionRow.OriginalMTAPremium
                                oPolicyVersion.ReversedInsuranceFileCnt = oBackdatedTransactionRow.ReversedInsuranceFileCnt
                                oPolicyVersion.QuoteStatus = oBackdatedTransactionRow.QuoteStatus
                                oPolicyVersion.OriginalCommission = oBackdatedTransactionRow.OriginalCommission
                                oPolicyVersion.MtaCommission = oBackdatedTransactionRow.MTACommission
                                oPolicyVersion.OriginalFee = oBackdatedTransactionRow.OriginalFee
                                oPolicyVersion.MtaFee = oBackdatedTransactionRow.MTAFee

                                If iCt > 0 Then
                                    oPolicyVersion.PrechangeInsuranceFileKey = oGetBackdatedMTARiskVersionsResponse.BackdatedTransactions(iCt - 1).InsuranceFileCnt
                                End If

                                oPolicyVersions.Add(oPolicyVersion)
                                iCt = iCt + 1
                            End With
                        Next
                    End If
                End If
            End With

            If Logger.IsLoggingEnabled Then
                sbLogMessage = New StringBuilder
                sbLogMessage.AppendLine("GetBackdatedMTAPolicyVersions executed ok" & vbCrLf)
                sbLogMessage.AppendLine("Input:" & vbCrLf)
                sbLogMessage.AppendLine("v_iInsuranceFileKey = " & v_nInsuranceFileKey.ToString() & vbCrLf)

                If Not IsNothing(v_sBranchCode) Then
                    sbLogMessage.AppendLine("v_sBranchCode = " & v_sBranchCode.ToString & vbCrLf)
                Else
                    sbLogMessage.AppendLine("v_sBranchCode = nothing" & vbCrLf)
                End If
                LogMessageEntry(sbLogMessage)
            End If

            Return oPolicyVersions
            'Catch ex As FaultException(Of PureService.SAMMethodResponseData)

            'FaultErrorHandler(ex) ' handling fault error messages 

        Catch ex As Exception
            Throw
        Finally
            oGetBackdatedMTARiskVersionsRequest = Nothing
            oGetBackdatedMTARiskVersionsResponse = Nothing
        End Try


    End Function

