                End If
                'Catch ex As FaultException(Of PureService.SAMMethodResponseData)
                'FaultErrorHandler(ex) ' handling fault error messages 
            Catch ex As Exception
                Throw
            Finally
                oRequest = Nothing
                oResponse = Nothing
                sbLogMessage = Nothing
            End Try
            Return oPolicies
        End SyncLock
    End Function

