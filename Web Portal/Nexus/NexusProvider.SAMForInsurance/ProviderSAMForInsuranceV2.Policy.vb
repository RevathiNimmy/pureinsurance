    ''' <summary>
    ''' This method is used for Processing Premium Finance Plan
    ''' </summary>
    ''' <param name="oProcessPfPlan"></param>
    ''' <param name="sBranchCode"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overrides Function ProcessPfPlan(ByRef oProcessPfPlan As PremiumFinancePlan,
                                    Optional ByVal sBranchCode As String = Nothing) As PremiumFinancePlan

        SyncLock oLock

            Dim oProcessPFPlanRequest As New BaseClasses.ProcessPfPlanCommand
            Dim oProcessPFPlanResponse As New BaseClasses.ProcessPfPlanCommandResponse

            Try

                With oProcessPFPlanRequest
                    .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                    'if the passed parameter v_sBranchCode is empty
                    If String.IsNullOrEmpty(sBranchCode) Then
                        'Use the default branch code
                        .BranchCode = sDefaultBranchCode
                    Else
                        'Use the branch code in session 
                        .BranchCode = sBranchCode

                    End If

                    .PFPremFinanceKey = oProcessPfPlan.PFPremFinanceKey
                    .PFPremFinanceVersion = oProcessPfPlan.PFPremFinanceVersion
                    .SaveOnly = oProcessPfPlan.SaveOnly
                    .PartyCode = oProcessPfPlan.PartyCode
                    .TransType = oProcessPfPlan.TransType
                    .Type = oProcessPfPlan.Type

                    If oProcessPfPlan.PFBankDetails IsNot Nothing Then
                        .PFBankDetails = New BaseClasses.BasePFBankDetails
                        .PFBankDetails.BankAccountName = oProcessPfPlan.PFBankDetails.BankAccountName
                        .PFBankDetails.BankAccountNo = oProcessPfPlan.PFBankDetails.BankAccountNo

                        If oProcessPfPlan.PFBankDetails.BankAddress IsNot Nothing Then
                            .PFBankDetails.BankAddress = New BaseClasses.BaseAddressType
                            .PFBankDetails.BankAddress.AddressLine1 = oProcessPfPlan.PFBankDetails.BankAddress.Address1
                            .PFBankDetails.BankAddress.AddressLine2 = oProcessPfPlan.PFBankDetails.BankAddress.Address2
                            .PFBankDetails.BankAddress.AddressLine3 = oProcessPfPlan.PFBankDetails.BankAddress.Address3
                            .PFBankDetails.BankAddress.AddressLine4 = oProcessPfPlan.PFBankDetails.BankAddress.Address4
                            .PFBankDetails.BankAddress.AddressTypeCode = CType(oProcessPfPlan.PFBankDetails.BankAddress.AddressType, PureService.AddressTypeType)
                            .PFBankDetails.BankAddress.CountryCode = oProcessPfPlan.PFBankDetails.BankAddress.CountryCode
                            .PFBankDetails.BankAddress.PostCode = oProcessPfPlan.PFBankDetails.BankAddress.PostCode
                        End If ' End of oProcessPFPlanRequest.PFBankDetails.BankAddress


                        .PFBankDetails.BankAreaCode = oProcessPfPlan.PFBankDetails.BankAreaCode
                        .PFBankDetails.BankBranch = oProcessPfPlan.PFBankDetails.BankBranch
                        .PFBankDetails.BankExtn = oProcessPfPlan.PFBankDetails.BankExtn
                        .PFBankDetails.BankFax = oProcessPfPlan.PFBankDetails.BankFax
                        .PFBankDetails.BankFaxCode = oProcessPfPlan.PFBankDetails.BankFaxCode
                        .PFBankDetails.BankName = oProcessPfPlan.PFBankDetails.BankName
                        .PFBankDetails.BankPhone = oProcessPfPlan.PFBankDetails.BankPhone
                        .PFBankDetails.BankSortCode = oProcessPfPlan.PFBankDetails.BankSortCode
                        .PFBankDetails.PartyBankKey = oProcessPfPlan.PFBankDetails.PartyBankKey
                    End If ' End of oProcessPFPlanRequest.PFBankDetails

                    If oProcessPfPlan.PFCreditCardDetails IsNot Nothing Then
                        .PFCreditCardDetails = New BaseClasses.BaseCreditCardType
                        .PFCreditCardDetails.AccountType = oProcessPfPlan.PFCreditCardDetails.AccountType
                        .PFCreditCardDetails.AuthCode = oProcessPfPlan.PFCreditCardDetails.AuthCode
                        .PFCreditCardDetails.VIAPaymentHub = oProcessPfPlan.PFCreditCardDetails.VIAPaymentHub

                        If Current.Session("FinancePlanDetails") IsNot Nothing Then

                            Dim oFinancePlanDetails As New NexusProvider.FinancePlanDetails
                            oFinancePlanDetails = CType(Current.Session("FinancePlanDetails"), NexusProvider.PremiumFinancePlan).PremiumFinanceDetails

                            If oFinancePlanDetails IsNot Nothing AndAlso oFinancePlanDetails.Authcode <> "" AndAlso oProcessPfPlan.Type <> InstalmentType.AddToNext Then
                                Dim oFinancePlan As NexusProvider.FinancePlan = Current.Session(Nexus.Constants.CNFinancePlan)
                                .PFCreditCardDetails.PartyBankKey = oFinancePlanDetails.PartyBankKey
                            Else
                                .PFCreditCardDetails.PartyBankKey = oProcessPfPlan.PFCreditCardDetails.PartyBankKey
