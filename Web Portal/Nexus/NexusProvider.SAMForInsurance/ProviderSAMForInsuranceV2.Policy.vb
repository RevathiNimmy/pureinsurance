    ''' <summary>
    ''' Method to get the details of the Secondary Associates attached to a Policy
    ''' </summary>
    ''' <param name="nInsuranceFileKey"></param>
    ''' <param name="nInsuranceFolderCnt"></param>
    ''' <param name="v_sBranchCode"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overrides Function GetPolicyAssociates(ByVal nInsuranceFileKey As Integer,
                               Optional ByVal nInsuranceFolderCnt As Integer = 0,
                               Optional ByVal v_sBranchCode As String = Nothing) As PolicyAssociateCollection

        SyncLock oLock

            Dim oGetPolicyAssociatesRequest As New BaseClasses.GetPolicyAssociatesQuery
            Dim oGetPolicyAssociatesResponse As New BaseClasses.GetPolicyAssociatesQueryResponse
            Dim oPolicyAssociateCollection As New PolicyAssociateCollection
            With oGetPolicyAssociatesRequest

                .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                'if the passed parameter v_sBranchCode is empty
                If String.IsNullOrEmpty(v_sBranchCode) Then
                    'if the branch code is NOT in session 
                    If String.IsNullOrEmpty(sBranchCode) Then
                        'Use the default branch code
                        .BranchCode = sDefaultBranchCode
                    Else
                        'Use the branch code in session 
                        .BranchCode = sBranchCode

                    End If
                Else
                    'use the passed parameter v_sBranchCode
                    .BranchCode = v_sBranchCode
                End If
                .InsuranceFileKey = nInsuranceFileKey
                .InsuranceFolderCnt = nInsuranceFolderCnt

            End With

            Try
                'add trace to allow us to debug slow SAM calls
                Using trace As New Tracer(Category.Trace)
                    ApiClient._tokenModel = GetApiTokendetails()
                    Dim result As String = ApiClient.Get(ApiMethods.GetPolicyAssociates, oGetPolicyAssociatesRequest)
                    oGetPolicyAssociatesResponse = ApiClient.DeserializeJson(Of BaseClasses.GetPolicyAssociatesQueryResponse)(result)
                End Using

            Finally
            End Try

            Dim oQuote As New NexusProvider.Quote


            If oGetPolicyAssociatesResponse IsNot Nothing Then
                With oGetPolicyAssociatesResponse
                    If 1 = 0 Then
                        'Process the error object if errors, and throw as a single exception
                        'Throw New NexusException(.Errors)
                    Else
                        If (.AssociatesQuery IsNot Nothing) Then
                            For Each oAssociatesRow As BaseClasses.BaseGetPolicyAssociatesResponseType In .AssociatesQuery
                                Dim oPolicyAssociate As New PolicyAssociate
                                oPolicyAssociate.PartyCode = oAssociatesRow.PartyCode
                                oPolicyAssociate.PartyName = oAssociatesRow.PartyName
                                oPolicyAssociate.AssociationDetail = oAssociatesRow.Associates.AssociationDetail
                                oPolicyAssociate.AssociationTypeKey = oAssociatesRow.Associates.AssociationTypeKey
                                oPolicyAssociate.DateAttached = oAssociatesRow.Associates.DateAttached
                                oPolicyAssociate.DateRemoved = oAssociatesRow.Associates.DateRemoved
                                oPolicyAssociate.InsuranceFileAssociatesKey = oAssociatesRow.Associates.InsuranceFileAssociatesKey
                                oPolicyAssociate.InsuranceFileKey = oAssociatesRow.Associates.InsuranceFileKey
                                oPolicyAssociate.InsuranceFolderCnt = oAssociatesRow.Associates.InsuranceFolderCnt
                                oPolicyAssociate.IsDeleted = oAssociatesRow.Associates.IsDeleted
                                oPolicyAssociate.PartyKey = oAssociatesRow.Associates.PartyKey
                                oPolicyAssociate.RowKey = oAssociatesRow.Associates.RowKey
                                oPolicyAssociate.ActionType = oAssociatesRow.Associates.ActionType
                                oPolicyAssociate.AddUnConfirmed = oAssociatesRow.Associates.IsAddUnConfirmed
                                oPolicyAssociate.DelUnConfirmed = oAssociatesRow.Associates.IsDelUnConfirmed
                                If oAssociatesRow.Address IsNot Nothing Then
                                    oPolicyAssociate.Address = New Address
                                    oPolicyAssociate.Address.Address1 = oAssociatesRow.Address.AddressLine1
                                    oPolicyAssociate.Address.Address2 = oAssociatesRow.Address.AddressLine2
                                    oPolicyAssociate.Address.Address3 = oAssociatesRow.Address.AddressLine3
                                    oPolicyAssociate.Address.Address4 = oAssociatesRow.Address.AddressLine4
                                    oPolicyAssociate.Address.PostCode = oAssociatesRow.Address.PostCode
                                    oPolicyAssociate.PostCode = oAssociatesRow.Address.PostCode
                                End If

                                Select Case Trim(oAssociatesRow.PartyType)
                                    Case PartyTypeType.PC
                                        oPolicyAssociate.PartyType = "Personal Client"
                                    Case PartyTypeType.CC
                                        oPolicyAssociate.PartyType = "Corporate Client"
                                    Case Else
                                        oPolicyAssociate.PartyType = "Other"
                                End Select

                                oPolicyAssociateCollection.Add(oPolicyAssociate)
                            Next
                        End If
                    End If
                End With
            End If
            If Logger.IsLoggingEnabled Then
                Dim sbLogMessage As New StringBuilder
                sbLogMessage.AppendLine("GetPolicyAssociates executed ok" & vbCrLf)
                sbLogMessage.AppendLine("Input :" & vbCrLf)

                If Not IsNothing(v_sBranchCode) Then
                    sbLogMessage.AppendLine("v_sBranchCode = " & v_sBranchCode.ToString & vbCrLf)
                Else
                    sbLogMessage.AppendLine("v_sBranchCode = nothing" & vbCrLf)
                End If

                sbLogMessage.AppendLine("v_iInsuranceFile = " & nInsuranceFileKey.ToString & vbCrLf)

                sbLogMessage.AppendLine("Output:" & vbCrLf)

                sbLogMessage.AppendLine("Returned " & oQuote.Print.Replace("<br />", vbCrLf))

                Dim logEntry As New LogEntry()
                logEntry.Categories.Clear()
                logEntry.Categories.Add(Category.General)
                logEntry.Priority = Priority.Normal
                logEntry.Severity = TraceEventType.Verbose
                logEntry.Message = sbLogMessage.ToString

                Logger.Write(logEntry)
            End If

            Return oPolicyAssociateCollection
        End SyncLock


    End Function

    ''' <summary>
    ''' Method to Add/Update the Policy Associates.
    ''' </summary>
    ''' <param name="v_oPolicyAssociate"></param>
    ''' <param name="v_sBranchCode"></param>
    ''' <remarks></remarks>
    ''' UpdatePolicyAssociates
    Public Overrides Function UpdatePolicyAssociates(ByVal oPolicyAssociates As PolicyAssociateCollection,
                                                 ByVal v_bTimeStamp As Byte(),
                                                Optional ByVal v_sBranchCode As String = Nothing) As PolicyAssociate
        SyncLock oLock

            Dim oUpdatePolicyAssociatesRequest As New BaseClasses.UpdatePolicyAssociatesCommand
            Dim oUpdatePolicyAssociatesResponse As New BaseClasses.UpdatePolicyAssociatesCommandResponse
            Dim oPolicyAssociateCollection As New PolicyAssociateCollection
            With oUpdatePolicyAssociatesRequest

                .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                'if the passed parameter v_sBranchCode is empty
                If String.IsNullOrEmpty(v_sBranchCode) Then
                    'if the branch code is NOT in session 
                    If String.IsNullOrEmpty(sBranchCode) Then
                        'Use the default branch code
                        .BranchCode = sDefaultBranchCode
                    Else
                        'Use the branch code in session 
                        .BranchCode = sBranchCode

                    End If
                Else
                    'use the passed parameter v_sBranchCode
                    .BranchCode = v_sBranchCode
                End If
                'Loop through the collection to populate the Associate array
                Dim oAssociateCount As Integer = oPolicyAssociates.Count
                Dim oAssociatesRequest(oAssociateCount - 1) As BaseClasses.BasePolicyAssociatesType

                If oPolicyAssociates IsNot Nothing And oAssociateCount <> 0 Then

                    For iCount As Integer = 0 To oAssociateCount - 1
                        oAssociatesRequest(iCount) = New BaseClasses.BasePolicyAssociatesType

                        Select Case oPolicyAssociates(iCount).ActionType
                            Case PolicyAssociateActionType.AddRow
                                oAssociatesRequest(iCount).IsDeleted = False
                                oAssociatesRequest(iCount).DateAttached = oPolicyAssociates(iCount).DateAttached
                                oAssociatesRequest(iCount).DateAttachedSpecified = True
                                oAssociatesRequest(iCount).IsAddUnConfirmed = True
                                oAssociatesRequest(iCount).IsDelUnConfirmed = oPolicyAssociates(iCount).DelUnConfirmed
                            Case PolicyAssociateActionType.DeleteRow
                                oAssociatesRequest(iCount).IsDeleted = True
                                oAssociatesRequest(iCount).IsDeletedSpecified = True
                                oAssociatesRequest(iCount).DateRemoved = oPolicyAssociates(iCount).DateRemoved
                                oAssociatesRequest(iCount).DateRemovedSpecified = True
                                oAssociatesRequest(iCount).RowKey = oPolicyAssociates(iCount).RowKey
                                oAssociatesRequest(iCount).DateAttached = oPolicyAssociates(iCount).DateAttached
                                oAssociatesRequest(iCount).DateAttachedSpecified = True
                                oAssociatesRequest(iCount).IsDelUnConfirmed = True
                                oAssociatesRequest(iCount).IsAddUnConfirmed = oPolicyAssociates(iCount).AddUnConfirmed
                            Case PolicyAssociateActionType.EditRow
                                oAssociatesRequest(iCount).IsDeleted = False
                                oAssociatesRequest(iCount).RowKey = oPolicyAssociates(iCount).RowKey
                                oAssociatesRequest(iCount).DateAttached = oPolicyAssociates(iCount).DateAttached
                                oAssociatesRequest(iCount).DateAttachedSpecified = True
                        End Select
                        oAssociatesRequest(iCount).AssociationDetail = oPolicyAssociates(iCount).AssociationDetail
                        oAssociatesRequest(iCount).AssociationTypeKey = oPolicyAssociates(iCount).AssociationTypeKey
                        oAssociatesRequest(iCount).InsuranceFileAssociatesKey = oPolicyAssociates(iCount).InsuranceFileAssociatesKey
