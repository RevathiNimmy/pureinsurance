                    oCmd.Parameters.AddWithValue("@ri_arrangement_id", v_iArrangementKey)
                    Dim oDr As System.Data.SqlClient.SqlDataReader = Nexus.Utils.funcDB.ExecSql(oCmd)
                    Dim dictIsEdited As New Dictionary(Of Integer, Boolean)
                    While oDr.Read()
                        Dim iLineId As Integer = 0
                        Dim bEdited As Boolean = False
                        If Not IsDBNull(oDr("ri_arrangement_line_id")) Then Integer.TryParse(oDr("ri_arrangement_line_id").ToString(), iLineId)
                        If Not IsDBNull(oDr("is_edited")) Then Boolean.TryParse(oDr("is_edited").ToString(), bEdited)
                        If iLineId > 0 Then dictIsEdited(iLineId) = bEdited
                    End While
                    oDr.Close()
                    For Each oLine As ArrangementLinesType In oArrangementLinesRI2007Collection
                        Dim bVal As Boolean = False
                        If dictIsEdited.TryGetValue(oLine.RIArrangementLineKey, bVal) Then
                            oLine.IsEditedDB = bVal
                        End If
                    Next
                End If
            Catch : End Try

            Return oArrangementLinesRI2007Collection
        End SyncLock
    End Function

