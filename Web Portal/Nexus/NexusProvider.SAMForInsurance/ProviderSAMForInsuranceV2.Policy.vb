                    .BankFaxCode = oPayment.BankFaxCode
                    .BankName = oPayment.BankName
                    .BankPhone = oPayment.BankPhone
                    .BankSortCode = oPayment.BankSortCode
                    .EndDate = oPayment.EndDate
                    .MonthDay = oPayment.MonthDay
                    .OverrideInterestRate = oPayment.OverrideInterestRate
                    .OverrideRate = oPayment.OverrideRate
                    .PaymentProtection = oPayment.PaymentProtection
                    .PreferredDate = oPayment.PreferredDate
                    .QuoteDate = oPayment.QuoteDate
                    .StartDate = oPayment.StartDate
                    .WeekDay = oPayment.WeekDay
                    .OverrideCommission = oPayment.OverrideCommission
                    .OverrideDepositAmount = oPayment.OverrideDepositAmount
                    If oPayment IsNot Nothing AndAlso oPayment.BankAddress IsNot Nothing Then
                        .BankAddress = New BaseClasses.BaseAddressType()
                        .BankAddress.AddressLine1 = oPayment.BankAddress.Address1
                        .BankAddress.AddressLine2 = oPayment.BankAddress.Address2
                        .BankAddress.AddressLine3 = oPayment.BankAddress.Address3
                        .BankAddress.AddressLine4 = oPayment.BankAddress.Address4
                        .BankAddress.PostCode = oPayment.BankAddress.PostCode
                        .BankAddress.CountryCode = oPayment.BankAddress.CountryCode
                    End If

                    If oPayment IsNot Nothing AndAlso oPayment.CreditCard IsNot Nothing Then
                        .CreditCard = New BaseClasses.BaseCreditCardType()
                        .CreditCard.NameOnCreditCard = oPayment.CreditCard.NameOnCreditCard
                        .CreditCard.Number = oPayment.CreditCard.Number
                        .CreditCard.ExpiryDate = oPayment.CreditCard.ExpiryDate
                        .CreditCard.StartDate = oPayment.CreditCard.StartDate
                        .CreditCard.Issue = oPayment.CreditCard.Issue
                        .CreditCard.Pin = oPayment.CreditCard.Pin
                        .CreditCard.TypeCode = oPayment.CreditCard.TypeCode
                        .CreditCard.AuthCode = oPayment.CreditCard.AuthCode
                        .CreditCard.PartyBankKey = oPayment.CreditCard.PartyBankKey
                        If oPayment.CreditCard.CreditCardType_CardHolder IsNot Nothing Then
                            .CreditCard.CardHolder = New BaseClasses.BaseCreditCardTypeCardHolder()
                            .CreditCard.CardHolder.Name = oPayment.CreditCard.NameOnCreditCard
                            .CreditCard.CardHolder.AddressLine1 = oPayment.CreditCard.CreditCardType_CardHolder.Address1
                            .CreditCard.CardHolder.AddressLine2 = oPayment.CreditCard.CreditCardType_CardHolder.Address2
                            .CreditCard.CardHolder.AddressLine3 = oPayment.CreditCard.CreditCardType_CardHolder.Address3
                            .CreditCard.CardHolder.AddressLine4 = oPayment.CreditCard.CreditCardType_CardHolder.Address4
                            .CreditCard.CardHolder.PostCode = oPayment.CreditCard.CreditCardType_CardHolder.PostCode
                        End If
                    End If
                End If
            End With

            Try
                Using trace As New Tracer(Category.Trace)
