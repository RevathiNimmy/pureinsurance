                            Next

                        End If

                    End If
                End With

                If Logger.IsLoggingEnabled Then
                    sbLogMessage = New StringBuilder
                    sbLogMessage.AppendLine("GetPTPoliciesForAmend executed ok" & vbCrLf)
                    sbLogMessage.AppendLine("Input:" & vbCrLf)

