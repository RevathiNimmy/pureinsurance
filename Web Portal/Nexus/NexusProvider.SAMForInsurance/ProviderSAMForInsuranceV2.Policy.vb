    ''' <summary>
    ''' Get premium finance plan collection
    ''' </summary>
    ''' <param name="nPartyKey"></param>
    ''' <param name="sStatusKey"></param>
    ''' <param name="sBranchCode"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overrides Function GetFinancePlan(ByVal nPartyKey As Integer,
                                             ByVal sStatusKey As String,
                                            Optional ByVal sBranchCode As String = Nothing
                                                   ) As FinancePlanCollection
        SyncLock oLock

            Dim oFinancePlansRequest As New BaseClasses.GetFinancePlansQuery
            Dim oFinancePlansResponse As New BaseClasses.GetFinancePlansQueryResponse


            With oFinancePlansRequest
                .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                '.WCFSecurityToken = SecurityToken()
                'if the passed parameter v_sBranchCode is empty
                If String.IsNullOrEmpty(sBranchCode) Then
                    'if the branch code is NOT in session 
                    If String.IsNullOrEmpty(sBranchCode) Then
                        'Use the default branch code
                        .BranchCode = sDefaultBranchCode
                    Else
                        'Use the branch code in session 
                        .BranchCode = sBranchCode
                    End If
                Else
                    'use the passed parameter v_sBranchCode
                    .BranchCode = sBranchCode
                End If
                If nPartyKey > 0 Then
                    .PartyKey = nPartyKey
                Else
                    Throw New ArgumentException("FinancePlan.PartyKey")
                End If
                If sStatusKey <> "" Then
                    Select Case sStatusKey
                        Case "000"
                            .StatusKey = Enums.FinancePlanStatus.Item000
                        Case "010"
                            .StatusKey = Enums.FinancePlanStatus.Item010
                        Case "011"
                            .StatusKey = FinancePlanStatus.Item011
                        Case "012"
                            .StatusKey = FinancePlanStatus.Item012
                        Case "040"
                            .StatusKey = FinancePlanStatus.Item040
                        Case "140"
                            .StatusKey = FinancePlanStatus.Item140
                        Case "900"
                            .StatusKey = FinancePlanStatus.Item900
                        Case "990"
                            .StatusKey = FinancePlanStatus.Item990
                        Case "999"
                            .StatusKey = FinancePlanStatus.Item999
                        Case Else
                            .StatusKey = ""
                    End Select
                Else
                    Throw New ArgumentException("FinancePlan.StatusKey")
                End If
            End With

            Try
                'add trace to allow us to debug slow SAM calls
                Using trace As New Tracer(Category.Trace)
                    ApiClient._tokenModel = GetApiTokendetails()
                    Dim result As String = ApiClient.Get(ApiMethods.GetFinancePlan, oFinancePlansRequest)
                    oFinancePlansResponse = ApiClient.DeserializeJson(Of BaseClasses.GetFinancePlansQueryResponse)(result)
                End Using

            Finally

            End Try

            Dim oFinancePlanCollection As FinancePlanCollection = Nothing
            oFinancePlanCollection = New FinancePlanCollection

            Dim oFinancePlan As FinancePlan = Nothing

            Dim oQuote As New NexusProvider.Quote

            If oFinancePlansResponse.GetFinancePlansResponse IsNot Nothing AndAlso oFinancePlansResponse.GetFinancePlansResponse.FinancePlans.Count > 0 Then
                With oFinancePlansResponse

                    For i As Integer = 0 To oFinancePlansResponse.GetFinancePlansResponse.FinancePlans.Count - 1
                        oFinancePlan = New FinancePlan
                        oFinancePlan.AccountNumber = .GetFinancePlansResponse.FinancePlans(i).AccountNumber
                        oFinancePlan.Amount = .GetFinancePlansResponse.FinancePlans(i).Amount
                        oFinancePlan.FinancePlanKey = .GetFinancePlansResponse.FinancePlans(i).FinancePlanKey
                        oFinancePlan.FinancePlanVersion = .GetFinancePlansResponse.FinancePlans(i).FinancePlanVersion
                        oFinancePlan.FinanceProvider = .GetFinancePlansResponse.FinancePlans(i).FinanceProvider
                        oFinancePlan.Frequency = .GetFinancePlansResponse.FinancePlans(i).Frequency
                        oFinancePlan.InsuranceRef = .GetFinancePlansResponse.FinancePlans(i).InsuranceRef
                        oFinancePlan.NextDueDate = .GetFinancePlansResponse.FinancePlans(i).NextDueDate
                        oFinancePlan.PlanReference = .GetFinancePlansResponse.FinancePlans(i).PlanReference
                        oFinancePlan.RemainingInstalments = .GetFinancePlansResponse.FinancePlans(i).RemainingInstalments
                        'to do : convert nexus plan status to enum type
                        oFinancePlan.Status = .GetFinancePlansResponse.FinancePlans(i).Status.ToString()
                        oFinancePlanCollection.Add(oFinancePlan)
                    Next

                    'If .Errors IsNot Nothing Then

                    '    'Process the error object if errors, and throw as a single exception
                    '    Throw New NexusException(.Errors)

                    'Else

                    '    'SAM is returning only InsuranceFile, InsuranceFolder, InsuranceRef of newly created quote
                    '    'currently, we are not using these values in Nexus layer but storing it in quote object for any future use
                    '    'r_oQuote.InsuranceFileKey = .InsuranceFilekey

                    'End If

                End With
            Else
                Return Nothing
            End If
            If Logger.IsLoggingEnabled Then
                Dim sbLogMessage As New StringBuilder
                sbLogMessage.AppendLine("GetFinancePlan executed ok" & vbCrLf)
                sbLogMessage.AppendLine("Input :" & vbCrLf)

                If Not IsNothing(sBranchCode) Then
                    sbLogMessage.AppendLine("sBranchCode = " & sBranchCode.ToString & vbCrLf)
                Else
                    sbLogMessage.AppendLine("v_sBranchCode = nothing" & vbCrLf)
                End If

                sbLogMessage.AppendLine("Partykey = " & nPartyKey & vbCrLf)

                sbLogMessage.AppendLine("Output:" & vbCrLf)

                sbLogMessage.AppendLine("Returned " & oQuote.Print.Replace("<br />", vbCrLf))


                Dim logEntry As New LogEntry()

                logEntry.Categories.Clear()
                logEntry.Categories.Add(Category.General)
                logEntry.Priority = Priority.Normal
                logEntry.Severity = TraceEventType.Verbose
                logEntry.Message = sbLogMessage.ToString

                Logger.Write(logEntry)
            End If

            Return oFinancePlanCollection

        End SyncLock

    End Function

    ''' <summary>
    ''' Get premium finance plans filtered by claim number.
    ''' Reuses the same GetFinancePlan API with an additional ClaimNumber parameter.
    ''' </summary>
    Public Overrides Function GetFinancePlanByClaimNumber(ByVal nPartyKey As Integer,
                                             ByVal sStatusKey As String,
                                             ByVal sClaimNumber As String,
                                             Optional ByVal sBranchCode As String = Nothing) As FinancePlanCollection

        ' Reuse the existing GetFinancePlan search; the claim number filtering
        ' will be applied at the UI/session level since the REST API filters by party/status.
        ' When the REST API supports claim number search natively, this can be optimised.
        Dim allPlans As FinancePlanCollection = GetFinancePlan(nPartyKey, sStatusKey, sBranchCode)

        If allPlans Is Nothing OrElse allPlans.Count = 0 OrElse String.IsNullOrEmpty(sClaimNumber) Then
            Return allPlans
        End If

        ' Filter results by claim number (matching against InsuranceRef or PlanReference containing the claim number)
        Dim filteredPlans As New FinancePlanCollection
        For Each plan As FinancePlan In allPlans
            If (plan.InsuranceRef IsNot Nothing AndAlso plan.InsuranceRef.IndexOf(sClaimNumber, StringComparison.OrdinalIgnoreCase) >= 0) OrElse
               (plan.PlanReference IsNot Nothing AndAlso plan.PlanReference.IndexOf(sClaimNumber, StringComparison.OrdinalIgnoreCase) >= 0) Then
                filteredPlans.Add(plan)
            End If
        Next

        Return filteredPlans
    End Function

    ''' <summary>
    ''' Get premium finance plan details by key
    ''' </summary>
    ''' <param name="sDocumentRef"></param>
    ''' <param name="nPFPremiumFinanceKey"></param>
