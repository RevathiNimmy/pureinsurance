                        oservice.FAXParticipants = .FAXParticipants.ToList().ConvertAll(New Converter(Of BaseClasses.BaseFaxParticipants, BaseClasses.BaseFaxParticipants)(AddressOf ToBaseFaxParticipants))
                    End If
                End If
            End With
        End If
        Return oservice

