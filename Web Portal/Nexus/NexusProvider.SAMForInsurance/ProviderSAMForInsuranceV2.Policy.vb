                            nPriority = nPriority + 1
                            oRIArrangementLine(nCnt).Priority = nPriority
                            oRIArrangementLine(nCnt).PremiumPercent = v_oRIArrangementLines.Item(nCnt).ThisPerc
                            oRIArrangementLine(nCnt).NumberOfLines = 1
