    ''' <summary>
    ''' GetFinancePlanDetails
    ''' </summary>
    ''' <param name="v_iInsuranceFileKey"></param>
    ''' <param name="v_sBranchCode"></param>
    ''' <param name="nPremiumFinanceCnt"></param>
    ''' <param name="nPremiumFinanceVersion"></param>
    ''' <returns></returns>
    Public Overrides Function GetFinancePlanDetails(ByVal v_iInsuranceFileKey As Integer,
                                                    Optional ByVal v_sBranchCode As String = Nothing, Optional ByVal nPremiumFinanceCnt As Integer = 0,
                                                    Optional ByVal nPremiumFinanceVersion As Integer = 0) As FinancePlan
        SyncLock oLock

            'Dim oSAM As PurePolicyServiceClient
            Dim oGetFinancePlanDetailsRequest As SSP.PureInsuranceRestAPIHandler.BaseClasses.GetFinancePlanDetailsQuery
            Dim oGetFinancePlanDetailsResponse As SSP.PureInsuranceRestAPIHandler.BaseClasses.GetFinancePlanDetailsQueryResponse
            Dim oFinancePlan As FinancePlan
            Dim oFinanceBankDetail As Bank
            Dim oInstalmentsCollection As InstalmentsCollection
            Dim oInstalment As Instalment = Nothing
            Dim sbLogMessage As StringBuilder

            Try
                ' oSAM = InitializePolicyServiceMethod()
                oGetFinancePlanDetailsRequest = New SSP.PureInsuranceRestAPIHandler.BaseClasses.GetFinancePlanDetailsQuery
                oGetFinancePlanDetailsResponse = New SSP.PureInsuranceRestAPIHandler.BaseClasses.GetFinancePlanDetailsQueryResponse
                oFinancePlan = New FinancePlan
                oFinanceBankDetail = New Bank
                oInstalmentsCollection = New InstalmentsCollection
                sbLogMessage = New StringBuilder
                Dim oFinancePlanCreditCard As New CreditCardType

                With oGetFinancePlanDetailsRequest
                    .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                    ' .WCFSecurityToken = SecurityToken()
                    If String.IsNullOrEmpty(v_sBranchCode) Then
                        'if the branch code is NOT in session 
                        If String.IsNullOrEmpty(sBranchCode) Then
                            'Use the default branch code
                            .BranchCode = sDefaultBranchCode
                        Else
                            'Use the branch code in session 
                            .BranchCode = sBranchCode
                        End If
                    Else
                        'use the passed parameter v_sBranchCode
                        .BranchCode = v_sBranchCode
                    End If

                    If v_iInsuranceFileKey > 0 Then
                        .InsuranceFileKey = v_iInsuranceFileKey
                    Else
                        Throw New ArgumentException("InstalmentQuotes.InsuranceFileKey")
                    End If
                    If nPremiumFinanceCnt <> 0 Then
                        .FinancePlanKey = nPremiumFinanceCnt
                    End If
                    If nPremiumFinanceVersion <> 0 Then
                        .FinancePlanVersion = nPremiumFinanceVersion
                    End If
                End With


                Using trace As New Tracer(Category.Trace)
                    'oGetFinancePlanDetailsResponse = oSAM.GetFinancePlanDetails(oGetFinancePlanDetailsRequest)
                    SSP.PureInsuranceRestAPIHandler.ApiClient._tokenModel = GetApiTokendetails()
                    Dim result As String = SSP.PureInsuranceRestAPIHandler.ApiClient.Get(ApiMethods.GetFinancePlanDetails, oGetFinancePlanDetailsRequest)
                    oGetFinancePlanDetailsResponse = SSP.PureInsuranceRestAPIHandler.ApiClient.DeserializeJson(Of SSP.PureInsuranceRestAPIHandler.BaseClasses.GetFinancePlanDetailsQueryResponse)(result)
                End Using

                With oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse

                    'TODO()
                    'Process the error object if errors, and throw as a single exception    
                    'Populate the FinancePlan from GetFinancePlanDetails
                    oFinancePlan.FinancePlanKey = .FinacePlanKey
                    oFinancePlan.FinancePlanVersion = .FinacePlanVersion
                    oFinancePlan.StatusDescription = .StatusDescription
                    oFinancePlan.DayOfWeekOrMonth = .DayOfWeekOrMonth
                    oFinancePlan.FinanceAmount = .FinancedAmount
                    oFinancePlan.FirstInstalmentAmount = .FirstInstalmentAmount
                    oFinancePlan.FirstInstalmentDate = .FirstInstalmentDate
                    oFinancePlan.OtherInstalmentAmount = .OtherInstalmentAmount
                    oFinancePlan.NextInstalmentDate = .NextInstalmentDate
                    oFinancePlan.LastInstalmentDate = .LastInstalmentDate
                    oFinancePlan.ProtectionCharge = .ProtectionCharge
                    oFinancePlan.InterestRate = .InterestRate
                    oFinancePlan.InterestAmount = .InterestAmount
                    oFinancePlan.AdminCharge = .AdminCharge
                    oFinancePlan.APRRate = .APRRate
                    oFinancePlan.Deposit = .Deposit
                    oFinancePlan.TaxAmount = .Taxes
                    oFinancePlan.Status = If(.Status.HasValue, .Status.Value.ToString(), String.Empty)
                    oFinancePlan.StatusDescription = .StatusDescription
                    oFinancePlan.TotalInstalmentAmount = .TotalAmount
                    oFinancePlan.NoOfInstalments = .NoOfInstalments
                    'oFinancePlan.InstalmentDetails = .Instalments
                    oFinanceBankDetail.BankKey = .PartyBankKey
                    oFinanceBankDetail.AccountType = .BankAccountType
                    oFinanceBankDetail.BankName = .BankName
                    oFinanceBankDetail.BankAddress = .BankAddress1
                    oFinanceBankDetail.BankBranch = .BankBranchName
                    oFinanceBankDetail.BranchCode = .BankBranchCode
                    oFinanceBankDetail.AccountHolderName = .BankAccountName
                    oFinanceBankDetail.AccountNumber = .BankAccountNumber
                    oFinanceBankDetail.BIC = .BIC
                    oFinanceBankDetail.IBAN = .IBAN
                    oFinanceBankDetail.BankKey = .PartyBankKey
                    oFinancePlan.Frequency = .Frequency
                    oFinancePlan.PaymentMethod = .PaymentMethod
                    oFinancePlan.SchemeName = .SchemeName
                    oFinancePlan.BankDetails = oFinanceBankDetail
                    oFinancePlan.PartyBankKey = .PartyBankKey
                    oFinancePlan.PlanReference = .PlanReference

                    If .CreditCard IsNot Nothing Then
                        With oFinancePlanCreditCard
                            .AuthCode = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.AuthCode
                            .CustomerPresent = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.CustomerPresent
                            .ExpiryDate = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.ExpiryDate
                            .Issue = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.Issue
                            .ManualAuthCode = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.ManualAuthCode
                            .NameOnCreditCard = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.NameOnCreditCard
                            .Number = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.Number
                            .Pin = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.Pin
                            .StartDate = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.StartDate
                            .TransactionCode = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.TransactionCode
                            .TypeCode = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.TypeCode
                            .PartyBankKey = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.PartyBankKey

                            If oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard IsNot Nothing Then
                                .CreditCardType_CardHolder = New CardHolder
                                With .CreditCardType_CardHolder

                                    .Address1 = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.CardHolder.AddressLine1
                                    .Address2 = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.CardHolder.AddressLine2
                                    .Address3 = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.CardHolder.AddressLine3
                                    .Address4 = oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.CreditCard.CardHolder.AddressLine4
                                    .CountryCode = .CountryCode
                                    .Name = .Name
                                    .PostCode = .PostCode
                                End With
                            End If
                            oFinancePlan.CreditCardDetails = oFinancePlanCreditCard
                        End With
                    End If
                    If .Instalments IsNot Nothing Then

                        For Each oBaseInstalment As SSP.PureInsuranceRestAPIHandler.BaseClasses.BaseGetFinancePlanDetailsResponseTypeRow In oGetFinancePlanDetailsResponse.GetFinancePlanDetailsResponse.Instalments
                            oInstalment = New Instalment()

                            With oInstalment
                                .InstalmentNumber = oBaseInstalment.InstalmentNumber
                                .Amount = oBaseInstalment.Amount
                                .PaymentDate = oBaseInstalment.PaymentDate.Date
                                '.PaymentDateStatus = oBaseInstalment.PaymentDateSpecified
                                .DueDate = oBaseInstalment.DueDate
