    ''' <summary>
    ''' To get all the policy details which have been made live against bank guarantee and receipt has to be made.
    ''' It will list only those policies against which there is an outstanding amount.
    ''' </summary>
    ''' <param name="v_iAccountKey"></param>
    ''' <param name="v_oBGGetPoliciesActionType"></param>
    ''' <param name="v_sBranchCode"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overrides Function GetPoliciesOnBankGuaranteeForReceipt(ByVal v_iAccountKey As Integer,
                                    ByVal v_oBGGetPoliciesActionType As BGGetPoliciesActionTypeType,
                                    ByVal v_iPartyKey As Integer,
                                    Optional ByVal v_sBranchCode As String = Nothing) As BankGuaranteePolicy

        SyncLock oLock

            Dim oGetPoliciesOnBankGuaranteeForReceiptRequest As GetPoliciesOnBankGuaranteeForReceiptQuery
            Dim oGetPoliciesOnBankGuaranteeForReceiptResponse As GetPoliciesOnBankGuaranteeForReceiptQueryResponse
            Dim oBankGuaranteePolicy As BankGuaranteePolicy
            Dim oPartyBGPolicyDetails As PartyBGPolicyDetails
            Dim sbLogMessage As StringBuilder

            Try

                oGetPoliciesOnBankGuaranteeForReceiptRequest = New GetPoliciesOnBankGuaranteeForReceiptQuery
                oGetPoliciesOnBankGuaranteeForReceiptResponse = New GetPoliciesOnBankGuaranteeForReceiptQueryResponse
                oBankGuaranteePolicy = New BankGuaranteePolicy
                sbLogMessage = New StringBuilder


                With oGetPoliciesOnBankGuaranteeForReceiptRequest
                    .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                    'if the passed parameter v_sBranchCode is empty
                    If String.IsNullOrEmpty(v_sBranchCode) Then
                        'if the branch code is NOT in session 
                        If String.IsNullOrEmpty(sBranchCode) Then
                            'Use the default branch code
                            .BranchCode = sDefaultBranchCode
                        Else
                            'Use the branch code in session 
                            .BranchCode = sBranchCode
                        End If
                    Else
                        'use the passed parameter v_sBranchCode
                        .BranchCode = v_sBranchCode
                    End If

                    .AccountKey = v_iAccountKey
                    .GetPoliciesFor = v_oBGGetPoliciesActionType
                    .PartyKey = v_iPartyKey

                End With

                'add trace to allow us to debug slow SAM calls
                Using trace As New Tracer(Category.Trace)
                    ApiClient._tokenModel = GetApiTokendetails()
                    Dim result As String = ApiClient.Get(ApiMethods.GetPoliciesOnBankGuaranteeForReceipt, oGetPoliciesOnBankGuaranteeForReceiptRequest)
                    oGetPoliciesOnBankGuaranteeForReceiptResponse = ApiClient.DeserializeJson(Of GetPoliciesOnBankGuaranteeForReceiptQueryResponse)(result)

                End Using


                With oGetPoliciesOnBankGuaranteeForReceiptResponse

                    If .Errors IsNot Nothing Then

                        'Process the error object if errors, and throw as a single exception
                        Throw New NexusException(.Errors)
                    Else

                        oBankGuaranteePolicy.PartyCode = .PartyCode
                        oBankGuaranteePolicy.ResolvedName = .ResolvedName

                        If .GetPoliciesResponse IsNot Nothing AndAlso .GetPoliciesResponse.Count > 0 Then

                            For Each oPartyBGPolicyDetailsRow As BaseGetPoliciesOnBankGuaranteeForReceiptResponseType In oGetPoliciesOnBankGuaranteeForReceiptResponse.GetPoliciesResponse
                                oPartyBGPolicyDetails = New PartyBGPolicyDetails

                                oPartyBGPolicyDetails.BGKey = oPartyBGPolicyDetailsRow.BGKey
                                oPartyBGPolicyDetails.BankNameKey = oPartyBGPolicyDetailsRow.BankNameKey
                                oPartyBGPolicyDetails.BankName = oPartyBGPolicyDetailsRow.BankName
                                oPartyBGPolicyDetails.BankGuaranteeRef = oPartyBGPolicyDetailsRow.BankGuaranteeRef
                                oPartyBGPolicyDetails.BGDueDate = oPartyBGPolicyDetailsRow.BGDueDate
                                oPartyBGPolicyDetails.PolicyKey = oPartyBGPolicyDetailsRow.PolicyKey
                                oPartyBGPolicyDetails.PolicyRef = oPartyBGPolicyDetailsRow.PolicyRef
                                oPartyBGPolicyDetails.PremiumAmount = oPartyBGPolicyDetailsRow.PremiumAmount
                                oPartyBGPolicyDetails.BranchCode = oPartyBGPolicyDetailsRow.BranchCode
                                oPartyBGPolicyDetails.BranchDesc = oPartyBGPolicyDetailsRow.BranchDesc
                                oPartyBGPolicyDetails.ProductCode = oPartyBGPolicyDetailsRow.ProductCode
                                oPartyBGPolicyDetails.ProductDesc = oPartyBGPolicyDetailsRow.ProductDesc
                                oPartyBGPolicyDetails.OutstandingPolicyAmt = oPartyBGPolicyDetailsRow.OutstandingPolicyAmt
                                oPartyBGPolicyDetails.CoverStartDate = oPartyBGPolicyDetailsRow.CoverStartDate
                                oPartyBGPolicyDetails.CoverEndDate = oPartyBGPolicyDetailsRow.CoverEndDate

                                oBankGuaranteePolicy.PartyBGPolicyDetails.Add(oPartyBGPolicyDetails)

                            Next
                        End If
                    End If

                End With

                If Logger.IsLoggingEnabled Then
                    sbLogMessage.AppendLine("GetPoliciesOnBankGuaranteeForReceipt executed ok" & vbCrLf)
                    sbLogMessage.AppendLine("Input:" & vbCrLf)
                    'sbLogMessage.AppendLine("v_iAddressKey = " & v_iAddressKey.ToString & vbCrLf)

                    If Not IsNothing(v_sBranchCode) Then
                        sbLogMessage.AppendLine("v_sBranchCode = " & v_sBranchCode.ToString & vbCrLf)
                    Else
                        sbLogMessage.AppendLine("v_sBranchCode = nothing" & vbCrLf)
                    End If

                    LogMessageEntry(sbLogMessage)
                End If

                'Catch ex As FaultException(Of PureService.SAMMethodResponseData)

                'FaultErrorHandler(ex) ' handling fault error messages 

            Catch ex As Exception
                Throw
            Finally
                oGetPoliciesOnBankGuaranteeForReceiptRequest = Nothing
                oGetPoliciesOnBankGuaranteeForReceiptResponse = Nothing
            End Try


            Return oBankGuaranteePolicy

        End SyncLock
    End Function

