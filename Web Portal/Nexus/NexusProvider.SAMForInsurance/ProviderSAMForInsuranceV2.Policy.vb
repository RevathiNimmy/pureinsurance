                ElseIf v_iQuoteRiskIndex > r_oQuote.Risks.Count - 1 Then
                    Throw New ArgumentOutOfRangeException("QuoteRiskIndex")
                Else

                    With oAddRiskRequest
                        .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
