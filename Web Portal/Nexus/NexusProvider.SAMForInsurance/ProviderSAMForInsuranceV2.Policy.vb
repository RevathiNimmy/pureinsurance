                                    .PartyName = oPolicy.PartyName
                                    .InsuranceFileRef = oPolicy.PolicyNumber
                                    .ProductCode = oPolicy.ProductCode
                                    .ProductDescription = oPolicy.ProductName
                                    .PTRIStatus = oPolicy.PTRIStatus
                                    .TransactionDate = oPolicy.TransactionDate
                                End With

