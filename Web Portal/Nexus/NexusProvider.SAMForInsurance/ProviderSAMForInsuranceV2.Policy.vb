    ''' <summary>
    ''' This method is used for Canceling Premium Finance Policies
    ''' </summary>
    ''' <param name="nPFPremiumFinanceKey"></param>
    ''' <param name="nPFPremiumFinanceVersionKey"></param>
    ''' <param name="sLapsedReasonCode"></param>
    ''' <param name="bSpoolDoc"></param>
    ''' <param name="bWriteOff"></param>
    ''' <param name="dtPolicyLapsedDate"></param>
    ''' <remarks></remarks>
    Public Overrides Sub CancelPFPolicies(ByVal nPFPremiumFinanceKey As Integer,
                                                ByVal nPFPremiumFinanceVersionKey As Integer,
                                                ByVal sLapsedReasonCode As String,
                                                ByVal bSpoolDoc As Boolean,
                                                ByVal bWriteOff As Boolean,
                                                ByVal dtPolicyLapsedDate As Date)
        SyncLock oLock

            'Dim oSAM As PurePolicyServiceClient
            'oSAM = InitializePolicyServiceMethod()
            Dim oCancelPFPoliciesRequest As New BaseClasses.CancelPFPoliciesCommand
            Dim oCancelPFPoliciesResponse As New BaseClasses.CancelPFPoliciesCommandResponse

            With oCancelPFPoliciesRequest
                .LoginUserName = Current.Session(Nexus.Constants.CNLoginName)
                '.WCFSecurityToken = SecurityToken()
                If String.IsNullOrEmpty(sBranchCode) Then
                    'if the branch code is NOT in session
                    If String.IsNullOrEmpty(sBranchCode) Then
                        'Use the default branch code
                        .BranchCode = sDefaultBranchCode
                    Else
                        'Use the branch code in session
                        .BranchCode = sBranchCode
                    End If
                Else
                    'use the passed parameter v_sBranchCode
                    .BranchCode = sBranchCode
                End If

                If nPFPremiumFinanceKey > 0 Then
                    .PFPremiumFinanceKey = nPFPremiumFinanceKey
                Else
                    Throw New ArgumentException("PremiumFinanceKey Missing")
                End If

                If nPFPremiumFinanceVersionKey > 0 Then
                    .PFPremiumFinanceVersionKey = nPFPremiumFinanceVersionKey
                Else
                    Throw New ArgumentException("PremiumFinanceVersionKey Missing")
                End If

                If sLapsedReasonCode <> "" Then
                    .LapsedReasonCode = sLapsedReasonCode
                Else
                    Throw New ArgumentException("LapsedReasonCode Missing")
                End If

                .SpoolDoc = bSpoolDoc
                .WriteOff = bWriteOff

                If IsDate(dtPolicyLapsedDate) Then
                    If dtPolicyLapsedDate <> Date.MinValue Then
                        .PolicyLapsedDate = dtPolicyLapsedDate
                    End If
                End If
            End With

            Try
                Using trace As New Tracer(Category.Trace)
                    ApiClient._tokenModel = GetApiTokendetails()
                    Dim result As String = ApiClient.Post(ApiMethods.CancelPFPolicies, oCancelPFPoliciesRequest)
                    oCancelPFPoliciesResponse = ApiClient.DeserializeJson(Of BaseClasses.CancelPFPoliciesCommandResponse)(result)
                    'oCancelPFPoliciesResponse = oSAM.CancelPFPolicies(oCancelPFPoliciesRequest)
                End Using
            Finally
                'oSAM.Close()
            End Try

            With oCancelPFPoliciesResponse
                If .Errors IsNot Nothing Then
                    'Process the error object if errors, and throw as a single exception
                    Throw New NexusException(.Errors)
                End If
            End With
            If Logger.IsLoggingEnabled Then
                Dim sbLogMessage As New StringBuilder
                sbLogMessage.AppendLine("CancelPFPolicies executed ok" & vbCrLf)
                '' we don't have input here, we have the input on Credentials Method
                sbLogMessage.AppendLine("Input : " & vbCrLf)

                If Not IsNothing(sBranchCode) Then
                    sbLogMessage.AppendLine("sBranchCode = " & sBranchCode.ToString & vbCrLf)
                Else
                    sbLogMessage.AppendLine("sBranchCode = nothing" & vbCrLf)
                End If

                sbLogMessage.AppendLine("PFPremiumFinanceKey = " & nPFPremiumFinanceKey.ToString & vbCrLf)

                sbLogMessage.AppendLine("Output : " & vbCrLf)

                Dim logEntry As New LogEntry()

                logEntry.Categories.Clear()
                logEntry.Categories.Add(Category.General)
                logEntry.Priority = Priority.Normal
                logEntry.Severity = TraceEventType.Verbose
                logEntry.Message = sbLogMessage.ToString
                Logger.Write(logEntry)
            End If

        End SyncLock

    End Sub

