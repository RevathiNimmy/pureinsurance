        For Each oFinancePlanHistory As FinancePlanHistory In List
            'sbPrint.AppendLine(oInstalments.Print())
            sbPrint.AppendLine("<br />")
        Next

        Return sbPrint.ToString()

    End Function

    Public Sub New()
