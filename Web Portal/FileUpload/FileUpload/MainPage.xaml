<UserControl x:Class="FileUpload.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300" d:DesignWidth="400" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" Padding="0" Margin="0,30,0,0">

    <Grid AllowDrop="False" Drop="FileDrop" x:Name="LayoutRoot" Background="White">
        <StackPanel Name="stkDropHolder" Drop="FileDrop" AllowDrop="True" Background="{x:Null}" Orientation="Vertical" HorizontalAlignment="Stretch" OpacityMask="#FFF70000">
            <TextBlock  AllowDrop="True" Drop="FileDrop" Name="txtDrop" Text="Drag Files Here to Upload" VerticalAlignment="Center" Foreground="Black" FontSize="22" TextWrapping="Wrap" OpacityMask="Black" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
