<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="enterpriseLibrary.ConfigurationSource" type="Microsoft.Practices.EnterpriseLibrary.Common.Configuration.ConfigurationSourceSection, Microsoft.Practices.EnterpriseLibrary.Common, Version=2.0.0.1, Culture=neutral, PublicKeyToken=afac53f54d148101" />
    <section name="microsoft.web.services3" type="Microsoft.Web.Services3.Configuration.WebServicesConfiguration, Microsoft.Web.Services3, Version=3.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
  </configSections>
  <enterpriseLibrary.ConfigurationSource selectedSource="Sirius">
    <sources>
      <add name="Sirius" type="Microsoft.Practices.EnterpriseLibrary.Common.Configuration.FileConfigurationSource, Microsoft.Practices.EnterpriseLibrary.Common, Version=2.0.0.1, Culture=neutral, PublicKeyToken=afac53f54d148101" filePath="Sirius.config" />
    </sources>
  </enterpriseLibrary.ConfigurationSource>
  <microsoft.web.services3>
    <security>
      <securityTokenManager>
        <add type="Sirius.Architecture.Security.SiriusUsernameTokenManager, Sirius.Architecture.Security, Culture=neutral, PublicKeyToken=afac53f54d148101" namespace="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd" localName="UsernameToken" />
      </securityTokenManager>
    </security>
    <policy fileName="wse3policyCache.config" />
  </microsoft.web.services3>
</configuration>