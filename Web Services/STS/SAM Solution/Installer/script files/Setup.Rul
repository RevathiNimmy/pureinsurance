    // your script function prototypes

    // your global variables
	BOOL g_bBusinessServer;
	BOOL g_bWebServer;
	BOOL g_bWebServerPreviouslyInstalled;           
	STRING g_szWebServerPath; 
	NUMBER g_nSessionState;                         
	STRING g_szBackOfficeType;
	STRING g_sztcpip;
	STRING g_szSQLip, g_szSQLuserid, g_szSQLpassword; 
	STRING g_szInstallType, g_szVirtualDirectory;  
	STRING g_szPRODUCT_NAME, g_szIISPortNo, g_szLocalHost;
	STRING g_szSTSMachineName; 
	STRING g_bStandard, g_bDeveloper; 
	STRING g_szInstallationType, g_szProductType;
	STRING g_szReleaseFlag;  
	STRING g_szEmailSMTPServer, g_szEmailFromName, g_szEmailFromAddress;



//////////////////////////////////////////////////////////////////////////////
//
	function 	OnAppSearch()
//
//  EVENT:      AppSearch event is used as an entry point to implement code to 
//              search for previous versions of the current application. This
//		        event is sent only for a first time installation.
//
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nLength, nvExitCode, nvSize, nLength2; 
	STRING	szProgram, szCmdLine, szDotNetVersion;
begin
                                 
	// Get the release flag
    nvSize = 256; 
   	MsiGetProperty(ISMSI_HANDLE, "ISReleaseFlags", g_szReleaseFlag, nvSize);
    if g_szReleaseFlag = 'Web' then
    	g_bWebServer = TRUE;
		g_bBusinessServer = FALSE;
		nLength2 = 14;
 	else
 		g_bWebServer = FALSE;
		g_bBusinessServer = TRUE;
		nLength2 = 3;
	endif;

	// .NET version numbering
	//		1,0,3705,1 = Service Pack 1
	//		1,0,3705,2 = Service Pack 2
 
 	nLength = StrLength ( SRCDIR );                
 	// this will remove '\Sirius Online'          
    StrSub ( szProgram , SRCDIR , 0 , (nLength - nLength2) );   
  	szProgram = szProgram ^ "Utilities\\dot Net Framework\\Service Pack 2" ^ "NDP10_SP_Q321884_En.exe" ; 
	szCmdLine = "";                                            
	
//    nvSize = 256; 
//   	MsiGetProperty(ISMSI_HANDLE, "DOTNET_VERSION", szDotNetVersion, nvSize);

//	if szDotNetVersion != "1,0,3705,2" then
		
//		SdShowMsg ( "Installing .NET Service Pack 2" , TRUE );
//     	ExFn_LaunchAppEx ( szProgram , szCmdLine , WAIT, SW_HIDE, -1, nvExitCode );
//    	if nvExitCode != 0 then
//    		MessageBox ("Could not install .NET Service Pack 2.  Please install manually.", SEVERE);
//    	endif;
		//SdShowMsg ( "Installing .NET Service Pack 2" , FALSE );
          
        // because you can cancel the SR2 install, we want
        // to abort this install until SR2 is installed
//   		MessageBox (".NET Service Pack 2 - Exiting installation.", SEVERE);
//    	abort;   
    	
//    endif;
      
end;


//////////////////////////////////////////////////////////////////////////////
//                                                                           
	function	OnFirstUIBefore()
//                                                                           
//  EVENT:      FirstUIBefore event is sent when installation is run for the first
//              time on given machine. In the handler installation usually displays
//              UI allowing end user to specify installation parameters. After this
//              function returns, FeatureTransferData is called to perform file
//              transfer.
//                                                                           
///////////////////////////////////////////////////////////////////////////////
    NUMBER  nResult,nSetupType, nLevel, nvSize, nvDx, nvDy;
    STRING  szTitle, szMsg, szLicenseFile, szQuestion, szDir, szFeatures, 
    		szTargetdir, szField1, szField2, svEdit1, svEdit2, svSetupType,
    		svDir, szData; 
    LIST	listStartCopy;   
begin	                  


	// Change the INSTALLDIR to the PM directory.
    
	// Get the MachineName
    nvSize = 256;
	MsiGetProperty (ISMSI_HANDLE, "ComputerName", g_szLocalHost, nvSize);

    g_szPRODUCT_NAME = "Sirius Online";
    
    if g_bWebServer = TRUE then
        g_szPRODUCT_NAME = g_szPRODUCT_NAME + " - Web Server Installer";
    else                                    
    	g_szPRODUCT_NAME = g_szPRODUCT_NAME + " - Business Server Installer (SAM)";
    endif;

/* 13/4/05 - Switched to BlueTC skin
    SetFont ( FONT_TITLE, STYLE_NORMAL, "Times New Roman" );
    SetTitle( g_szPRODUCT_NAME, 36, BLACK );                                        
    //SetTitle( g_szPRODUCT_NAME, 0, BACKGROUNDCAPTION ); 	                   
    Enable( FULLWINDOWMODE );						   
    Enable( BACKGROUND );							  
    SetColor(BACKGROUND, BK_SOLIDWHITE );					   
    GetExtents (nvDx, nvDy); 
    switch (nvDx)
    	case 640 : PlaceBitmap ( SUPPORTDIR ^ "Sirius_BackGround_640x480.bmp;255,255,255", CENTERED , 0, 0, FULLSCREEN );
    	case 800 : PlaceBitmap ( SUPPORTDIR ^ "Sirius_BackGround_800x600.bmp;255,255,255", CENTERED , 0, 0, FULLSCREEN );
        default  : PlaceBitmap ( SUPPORTDIR ^ "Sirius_BackGround_1024x768.bmp;255,255,255", CENTERED , 0, 0, FULLSCREEN );
    endswitch;
*/

// Set the Dialog title
	SetDialogTitle( DLG_STATUS, "Installation of " + g_szPRODUCT_NAME + "..." );

    
    SHELL_OBJECT_FOLDER = g_szPRODUCT_NAME;
    
    szDir = INSTALLDIR;

Dlg_Start:
    // beginning of dialogs label  


Dlg_SdWelcome:
    szTitle = "Sirius Online Installation";  // @ID_STRING4 from Summary Information Stream 'Title'
    szMsg   = "";
    nResult = SdWelcome( szTitle, szMsg );
    if (nResult = BACK) goto Dlg_Start;

Dlg_SdLicense:
    szLicenseFile = SUPPORTDIR ^ "license.txt";
    szTitle    = "";
    szMsg      = "";
    szQuestion = "";
    nResult    = SdLicense( szTitle, szMsg, szQuestion, szLicenseFile );
    if (nResult = BACK) goto Dlg_SdWelcome;

if g_bWebServer = TRUE then

	Dlg_CustomInstallationType:
    	szTitle    = "Installation Type";
	    szMsg      = "";
    	nResult = SdSetupTypeEx (szTitle, szMsg, "", svSetupType, 0);
		switch (svSetupType)
			case "Developer":
				g_szInstallationType = "Developer";
			case "Standard":                  
				g_szInstallationType = "Standard";
		endswitch;
	
		
 	   //nResult = Dlg_SFSInstallationType();     // ORIGINAL WAY
   	if (nResult = BACK) goto Dlg_SdLicense;   
	
		FeatureSelectItem ( MEDIA , "Developer\\AgentsOnline_Developer"  , FALSE );
		FeatureSelectItem ( MEDIA , "Developer\\CustomersOnline_Developer"  , FALSE );
		FeatureSelectItem ( MEDIA , "Standard\\AgentsOnline"  , FALSE );
		FeatureSelectItem ( MEDIA , "Standard\\CustomersOnline" , FALSE );
   
	Dlg_CustomerProductType:    

	    szTitle    = "Product Type";
    	szMsg      = "";           
    	if g_szInstallationType = "Developer" then
	    	nResult  = SdAskOptionsList ( szTitle , szMsg , "Developer" , EXCLUSIVE );
		else 	                                                                           
			nResult  = SdAskOptionsList ( szTitle , szMsg , "Standard" , EXCLUSIVE );
		endif;

  		if (nResult = BACK) goto Dlg_CustomInstallationType;

	               
		//Developer
	    nResult = FeatureIsItemSelected (MEDIA, "Developer\\AgentsOnline_Developer");
    	if nResult = 1 then
				g_szProductType = "AOL";
				g_szPRODUCT_NAME = "Sirius Online Installer\nAgents Online (Developer)";
		endif;
    	nResult = FeatureIsItemSelected (MEDIA, "Developer\\CustomersOnline_Developer");
	    if nResult = 1 then
				g_szProductType = "COL"; 
				g_szPRODUCT_NAME = "Sirius Online Installer\nCustomers Online (Developer)";
		endif;
          
    	// Standard
    	nResult = FeatureIsItemSelected (MEDIA, "Standard\\AgentsOnline");
    	if nResult = 1 then
				g_szProductType = "AOL";
				g_szPRODUCT_NAME = "Sirius Online Installer\nAgents Online";
		endif;
	    nResult = FeatureIsItemSelected (MEDIA, "Standard\\CustomersOnline");
    	if nResult = 1 then
				g_szProductType = "COL"; 
				g_szPRODUCT_NAME = "Sirius Online Installer\nCustomers Online";
		endif;
          

	// Set the Dialog title
		SetDialogTitle( DLG_STATUS, g_szPRODUCT_NAME );
		// 	SetTitle( g_szPRODUCT_NAME, 36, BLACK );                                        

		// Set the install type 
		nResult = SetupInstallType();
           

	Dlg_CustomPreviouslyInstalled: 
        nResult = Dlg_SFSPreviouslyInstalled();
				
	if g_bWebServerPreviouslyInstalled = YES then

		Dlg_CustomWebServerAddress:
			nResult = Dlg_SFSWebServerAddress();
			if (nResult = BACK) goto Dlg_CustomerProductType;
            
			// Check the WEB Server directory
			nResult = WebServerCheck();
			//if (nResult = FALSE) goto Dlg_CustomWebServerAddress;	// 
	else
	
		g_szWebServerPath = "http://" + g_szLocalHost + "/";
	                  
		//if nResult = NO then
		//if g_bWebServerPreviouslyInstalled = FALSE then
	                                
			Dlg_BackOfficeType:
				nResult = Dlg_SFSBackOfficeType();
				if (nResult = BACK) goto Dlg_CustomerProductType;
				
				                                
			Dlg_CustomSessionState:
				nResult = Dlg_SFSSessionState();
				if (nResult = BACK) goto Dlg_BackOfficeType;

			// Only for State Server
			if g_nSessionState = 2 then
				Dlg_CustomStateServer:
					nResult = Dlg_SFSStateServer();
					if (nResult = BACK) goto Dlg_CustomSessionState;
			endif;

			// Only for SQL Mode
			if g_nSessionState = 3 then
				Dlg_CustomSQLMode:              
					nResult = Dlg_SFSSQLMode();
					if (nResult = BACK) goto Dlg_CustomSessionState;
     		endif;
     
     		Dlg_STSMachineName:
     			nResult = Dlg_SFSSTSMachineName();
     			if (nResult = BACK) then
     				if g_nSessionState = 2 then
     					goto Dlg_CustomStateServer;
     				elseif g_nSessionState = 3 then
     					goto Dlg_CustomSQLMode;     					
     				else                         
     					goto Dlg_CustomSessionState;
     				endif;
     			endif;

	endif;

else
 
 	//Get the Backoffice type 
	nResult = Dlg_SFSBackOfficeType();
 
 	if g_szBackOfficeType = "0" then 
		FeatureSelectItem ( MEDIA , "BusinessServer\\SAMForBroking"  , FALSE );
		FeatureSelectItem ( MEDIA , "BusinessServer\\SAMForUnderwriting"  , TRUE );
	else
		FeatureSelectItem ( MEDIA , "BusinessServer\\SAMForBroking"  , TRUE );
		FeatureSelectItem ( MEDIA , "BusinessServer\\SAMForUnderwriting"  , FALSE );	
	endif;
  
	Dlg_CustomEmail:
		nResult = Dlg_SFSEmail();
		if (nResult = BACK) goto Dlg_SdLicense;
	
endif;

Dlg_SdAskDestPath:
    szTitle = "";
    szMsg   = "";
    nResult = SdAskDestPath( szTitle, szMsg, szDir, 0 );
    INSTALLDIR = szDir;
    if (nResult = BACK) then 
    	if g_bWebServer = TRUE then
    		goto Dlg_STSMachineName;
    	else  
    		goto Dlg_CustomEmail;
    	endif;
    endif;                          
                        
Dlg_SdStartCopy:
    szTitle = "";
    szMsg   = "";
    listStartCopy = ListCreate( STRINGLIST );
    //The following is an example of how to add a string(szName) to a list(listStartCopy).
    //eg. ListAddString(listStartCopy,szName,AFTER);
                       
	// Installation Type
    switch (g_szInstallationType)
    	case "Standard":
    	  	ListAddString (listStartCopy, "    Standard Installation", AFTER);
    	case "Developer":
    		ListAddString (listStartCopy, "    Developer Installation", AFTER); 
    endswitch;
    
    // Add a blank line
    ListAddString (listStartCopy, " ", AFTER);
                     
	// Product Type                     
    switch (g_szProductType)
    	case "AOL":
    		ListAddString (listStartCopy, "    Web Server - Agents Online", AFTER);
    	case "COL":
    		ListAddString (listStartCopy, "    Web Server - Customers Online", AFTER);
    	default:
    		ListAddString (listStartCopy, "    Business Server - SAM", AFTER);
    endswitch;
                
	// Display the Dialog
    nResult = SdStartCopy( szTitle, szMsg, listStartCopy );	
    ListDestroy(listStartCopy);
    if (nResult = BACK) goto Dlg_SdAskDestPath;

	
// set the status window
	SFS_StatusWindowType( "STATUSEX" );
             
	svDir = INSTALLDIR ^ "SiriusFS.SAM.ServiceAgent" ^ "bin";
	if (ExistsDir (svDir) = EXISTS) then	
		nResult = DeleteDir( svDir, ALLCONTENTS );		
		if (nResult != 0) then 
			MessageBox ( "Faled to delete the folder : " + svDir + ".  Please delete this folder before continuing.", WARNING );
		endif;
	endif;

    return 0;

end;


///////////////////////////////////////////////////////////////////////////////
//
	function	OnMaintUIBefore()
//
//  EVENT:      MaintUIBefore event is sent when end user runs installation that
//              has already been installed on the machine. Usually this happens 
//              through Add/Remove Programs applet. In the handler, installation 
//              usually displays UI allowing end user to modify existing installation
//              or uninstall application. After this function returns, 
//              FeatureTransferData is called to perform file transfer.
//
///////////////////////////////////////////////////////////////////////////////
    NUMBER	nResult, nType;
    STRING	szTitle, szMsg, svDir, svResult, szCaption;
begin

    // TO DO: if you want to enable background, window title, and caption bar title   								
    // SetTitle( @PRODUCT_NAME, 24, WHITE );					
    // SetTitle( @PRODUCT_NAME, 0, BACKGROUNDCAPTION );  			
    // SetColor(BACKGROUND,RGB (0, 128, 128));					
    // Enable( FULLWINDOWMODE );						
    // Enable( BACKGROUND );							
	
Dlg_Start:
    Disable(BACKBUTTON);
    nType = SdWelcomeMaint(szTitle, szMsg, MODIFY);
    Enable(BACKBUTTON);

    if (nType = REMOVEALL) then
        svResult = SdLoadString(IFX_MAINTUI_MSG);
        szCaption = SdLoadString(IFX_ONMAINTUI_CAPTION);
        nResult = SprintfBox(MB_OKCANCEL,szCaption,"%s",svResult);
        if (nResult = IDCANCEL) goto Dlg_Start;
    endif;

    nResult = NEXT;

Dlg_SdFeatureTree:

/*
    if (nType = MODIFY) then
        szTitle = "";
        szMsg = "";
        nResult = SdFeatureTree(szTitle, szMsg, TARGETDIR, "", 2);
        if (nResult = BACK) goto Dlg_Start;
    endif;
*/

    switch(nType)
        case REMOVEALL: ComponentRemoveAll();
        case REPAIR:    ComponentReinstall();  
        case MODIFY:	OnFirstUIBefore();
    endswitch;
    
    Enable(STATUSEX);
end;


///////////////////////////////////////////////////////////////////////////////
//
	function	OnFirstUIAfter()
//
//  EVENT:      FirstUIAfter event is sent after file transfer, when installation 
//              is run for the first time on given machine. In this event handler 
//              installation usually displays UI that will inform end user that
//              installation has been completed successfully.
//
///////////////////////////////////////////////////////////////////////////////
	NUMBER	bOpt1, bOpt2, nResult, nvSize;
	STRING	szTitle, szMsg1, szMsg2, szOption1, szOption2, szShareName, szPath, 
			szLocalHost, szInstallType; 
begin

	//Disable(STATUSEX);
    
	// Only Update the Web.config file for the original install
	// otherwise, copy the file from the web install to the local machine

	SetStatusWindow( -1, "Updating config file . . . " );
    //SdShowMsg ("Updating config file . . . ", TRUE);

	// Update the the web.config file
    nResult = WebConfigUpdate_BusinessServer(g_szLocalHost, g_szProductType);

    //SdShowMsg ("Updating config file . . . ", FALSE);

	SetStatusWindow( -1, "Updating database . . . " );
    //SdShowMsg ("Updating database . . . ", TRUE);

		//Run the scripts for the Business Server 	
    //nResult = RunSetupDB();

    //SdShowMsg ("Updating database . . . ", FALSE);
    
    SetStatusWindow( -1, "Updating GIS Lists . . . " );
    
    //call the function to update the GIS Lists
    nResult = STSCreatGISLists();
              
    // Call the method to add the performance counters to the local machine
	nResult = STSPerformanceCounters();
		
    // Call the method to add the Event Source to the local machine
	nResult = CreateEventSource();
            
	// We have finished the install
	bOpt1  = FALSE;
	bOpt2  = FALSE;
	szMsg1 = SdLoadString(IFX_SDFINISH_MSG1);
	SdFinishEx(szTitle, szMsg1, szMsg2, szOption1, szOption2, bOpt1, bOpt2);
 
 end;
 


