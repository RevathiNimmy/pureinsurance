	//SdShowMsg ( "Installing SAM Performance Counters" , FALSE );
	
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
	function	STSCreatGISLists()
//                                                                           //
//  Purpose:  
//                                                                           //
//                                                                           //
///////////////////////////////////////////////////////////////////////////////
    NUMBER	nResult, nvExitCode, nvType, nvSize;
    STRING	szInputString, svValue, szProgram , szCmdLine, svResult, svDir, svDirTemp, svStatus, szMsg, svKey;
    OBJECT 	oGISList;
begin

    // create the object
    set oGISList = CreateObject("bGISList.bGISListCreate");
	
	// Does the PM subkey exist
	RegDBSetDefaultRoot ( HKEY_LOCAL_MACHINE );
	nResult = RegDBKeyExist ( "SOFTWARE\\PM" ); 
	
	// set the key
	svKey = "SOFTWARE\\PM";

	if ( nResult = 1 ) then
		// Get the PMDIR registry settings	
		nResult = RegDBGetKeyValueEx ( svKey , "PMDIR" , nvType , svValue , nvSize );
		StrRemoveLastSlash ( svValue );   			
		szInputString = svValue ^ "PM\\GIS\\Server\\Lists\\RSAList0101.txt";
	else
		szInputString = ProgramFilesFolder ^ "PM\\GIS\\Server\\Lists\\RSAList0101.txt";
	endif;
	                          
    //Set the input file string
    oGISList.InputFile = szInputString;

	//Create the GIS Lists
    nResult = oGISList.Create();
 
 	//If it failed then                                      
	if (nResult != 1) then
		szMsg = "Unable to launch : GISListCreator. it will need to be run manually.";
		MessageBox ( szMsg, SEVERE );		
	endif;
 
    // free the object
    set oGISList = NOTHING;

end;
//////////////////////////////////////////////////////////////////////////////
//
//  FUNCTION:   OnBegin
//
//  EVENT:      Begin event is always sent as the first event during installation.
//
//////////////////////////////////////////////////////////////////////////////
function OnBegin() 
	NUMBER	nResult;
    STRING	szProgram , svResult, svDir, szFileName;
begin
	// TO DO: you may change default non-UI setting, for example
	//
	// You may also perform your custom initialization steps, check requirements, etc.

	SetStatusWindow( -1, "Preparing Install" );
	//SdShowMsg ( "Installing STS Performance Counters" , TRUE );

	svDir = TARGETDIR ^ "SiriusFS.SAM.ServiceAgent\bin";

	DeleteDir( svDir, ALLCONTENTS );		
	
end;

