///////////////////////////////////////////////////////////////////////////////
//
	function 	WebServerCheck()
//
//  COMMENTS:	Check the WEB Server for the .INI and get all the details
//				from the setup.ini file
//				If the file cannot be retrieved then it is incorrectly
//				installed or the incorrect directory path
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nResult;
	STRING	szString, szINIFile, szSection, szKey, svResult, szString1, 
			szString2, szWebServerComputerName, szFileName;
begin
     
    // Convert the web server address
    nResult = StrToUpper ( szWebServerComputerName, g_szWebServerPath ); 
           
	szWebServerComputerName = "\\\\" + szWebServerComputerName ^ "SiriusOnline";
     
    // Check that the Web Server Path is correct
    if (ExistsDir ( szWebServerComputerName )) = NOTEXISTS then
    	MessageBox ( "Web Server Share Not Found", WARNING );
    	return FALSE;
    endif;
        
    nResult = FindFile ( szWebServerComputerName , "setup.ini" , szFileName );	
	if (nResult != 0) then
		MessageBox ( "Can't find setup.ini from Web Server", INFORMATION );
		return FALSE;
	endif;
                                           
	szINIFile = szWebServerComputerName ^ "setup.ini";
	
	szSection = "web.config";
	// Retrieve the value of a key from the file.
	if (GetProfString (szINIFile, szSection, "SQL Address", g_szSQLip) != 0) then
            MessageBox ("Failed to read Setup.ini file on Web Server", INFORMATION);
            return 99;
	endif;
     
    GetProfString (szINIFile, szSection, "SQL Password", g_szSQLpassword);
	GetProfString (szINIFile, szSection, "SQL Username", g_szSQLuserid);
	GetProfString (szINIFile, szSection, "State Mode Address", g_sztcpip);
	GetProfString (szINIFile, szSection, "STS Machine Name", g_szSTSMachineName);
	    
	szSection = "Web Server";
	GetProfString (szINIFile, szSection, "Server Machine Name", svResult);
	    
end;     


///////////////////////////////////////////////////////////////////////////////
//
	function 	WebConfigUpdate_BusinessServer(szLocalHost, szProductType)
//
//  COMMENTS:	Update the Business Server Web.config with email settings
//
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nResult, nvLineNumber, nFileHandle, nvFileHandle, nvExitCode;   
	STRING	svString, szUpdateString1, szUpdateString2, szInsertLine1, szInsertLine2, 
			szInsertLine3, szInsertLine4, szFileName, svReturnLine, szBitInTheMiddle, 
			szvalidationKey, szdecryptionKey, svLine, szFileFolder, szFullName, 
			szProgram, szCmdLine, szLine, szInsertString;
	LIST listID;  
begin
                            
	szFileFolder = INSTALLDIR ^ "SiriusFS.SAM.ServiceAgent";
	
	
	nResult = FindFile ( szFileFolder , "web.config" , szFileName );	
	if (nResult != 0) then
		MessageBox ( "Can't find web.config", INFORMATION );
		return FALSE;
	endif;
	
	szFullName = szFileFolder ^ szFileName;
	
	// Set the read-only flag OFF
	SetFileInfo ( szFullName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "" );


	// EmailSMTPServer	         
    szUpdateString1 = '		<add key="EmailSMTPServer" value="' + g_szEmailSMTPServer + '"/>';
	szInsertString  = '<!-- EmailSMTPServer Setting -->';
	
	nResult = FileGrep ( szFullName , szInsertString , svReturnLine , nvLineNumber , RESTART );		
	if nResult = 0 then
		FileInsertLine ( szFullName, szUpdateString1, nvLineNumber + 1, REPLACE );  
	else
		MessageBox ( "Can't find EmailSMTPServer tag in the Web.Config file.", INFORMATION );
   	endif;

	// FPFromName
    szUpdateString1 = '		<add key="FPFromName" value="' + g_szEmailFromName + '"/>';
    szInsertString  = '<!-- FPFromName Setting -->';
    
	nResult = FileGrep ( szFullName , szInsertString , svReturnLine , nvLineNumber , RESTART );
	if nResult = 0 then
		FileInsertLine ( szFullName , szUpdateString1, nvLineNumber + 1 , REPLACE );
	else
		MessageBox ( "Can't find FPFromName tag in the Web.Config file.", INFORMATION );
	endif;    		           	

	// FPFromEmail
    szUpdateString1 = '		<add key="FPFromEmail" value="' + g_szEmailFromAddress + '"/>';
    szInsertString  = '<!-- FPFromEmail Setting -->';
    
	nResult = FileGrep ( szFullName , szInsertString , svReturnLine , nvLineNumber , RESTART );
	if nResult = 0 then
		FileInsertLine ( szFullName , szUpdateString1, nvLineNumber + 1 , REPLACE );
	else
		MessageBox ( "Can't find FPFromEmail tag in the Web.Config file.", INFORMATION );
	endif;    		           	


	// STSListener                                                                                                   
	szUpdateString1 = '<!--<add name="STSListener" type="System.Diagnostics.TextWriterTraceListener" initializeData="' + INSTALLDIR + 'SiriusFS.SAM.ServiceAgent\\STS_EDI_Log.log" />';
    szInsertString  = '<!-- STSListener Setting -->';
   
    
	nResult = FileGrep ( szFullName , szInsertString , svReturnLine , nvLineNumber , RESTART );
	if nResult = 0 then
		FileInsertLine ( szFullName , szUpdateString1, nvLineNumber + 1 , REPLACE );
	else
	    nResult = NumToStr(svString, nResult);
		MessageBox ( "Can't find STSListener tag in the Web.Config file. Return value - " + svString, INFORMATION );
	endif;    		           	

	// SiriusConfigPath 
	szUpdateString1 = '<add key="SiriusConfigPath" value="' + INSTALLDIR + 'SiriusFS.SAM.ServiceAgent\\"/>';                                     
    szInsertString  = '<!-- SiriusConfigPath Setting -->';
   
    
	nResult = FileGrep ( szFullName , szInsertString , svReturnLine , nvLineNumber , RESTART );
	if nResult = 0 then
		FileInsertLine ( szFullName , szUpdateString1, nvLineNumber + 1 , REPLACE );
	else
		MessageBox ( "Can't find SiriusConfigPath tag in the Web.Config file.", INFORMATION );
	endif;    		           	
                    
                    
	// TransformPath 
	szUpdateString1 = '<add key="TransformPath" value="' + INSTALLDIR + 'SiriusFS.SAM.ServiceAgent\\EDI"/>';
    szInsertString  = '<!-- TransformPath Setting -->';
   
    
	nResult = FileGrep ( szFullName , szInsertString , svReturnLine , nvLineNumber , RESTART );
	if nResult = 0 then
		FileInsertLine ( szFullName , szUpdateString1, nvLineNumber + 1 , REPLACE );
	else
		MessageBox ( "Can't find TransformPath tag in the Web.Config file.", INFORMATION );
	endif;    		           	

	// AnonCustomerDefaultsPath 
	szUpdateString1 = '<add key="AnonCustomerDefaultsPath" value="' + INSTALLDIR + 'SiriusFS.SAM.ServiceAgent\\"/>';
    szInsertString  = '<!-- AnonCustomerDefaultsPath Setting -->';
   
    
	nResult = FileGrep ( szFullName , szInsertString , svReturnLine , nvLineNumber , RESTART );
	if nResult = 0 then
		FileInsertLine ( szFullName , szUpdateString1, nvLineNumber + 1 , REPLACE );
	else
		MessageBox ( "Can't find AnonCustomerDefaultsPath tag in the Web.Config file." , INFORMATION );
	endif; 
	                    
	// DebugPath 
	szUpdateString1 = '<add key="DebugPath" value="' + INSTALLDIR + 'SiriusFS.SAM.ServiceAgent"/>';
    szInsertString  = '<!-- DebugPath Setting -->';
                 
                 
	nResult = FileGrep ( szFullName , szInsertString , svReturnLine , nvLineNumber , RESTART );
	if nResult = 0 then
		FileInsertLine ( szFullName , szUpdateString1, nvLineNumber + 1 , REPLACE );
	else
		MessageBox ( "Can't find DebugPath tag in the Web.Config file.", INFORMATION );
	endif; 
	
	// Set it back to read-only
	SetFileInfo ( szFullName, FILE_ATTRIBUTE, FILE_ATTR_READONLY, "" );
   	
end;


