///////////////////////////////////////////////////////////////////////////////
//
	function 	Dlg_SFSStateServer()
//
//  COMMENTS:	Check the WEB Server for the .INI and get all the details
//				from the setup.ini file
//				If the file cannot be retrieved then it is incorrectly
//				installed or the incorrect directory path
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nResult;
	STRING	svString, szTitle, szMsg, szField1;
begin
	
	szTitle   = "Web Configuration - State Server Mode Settings";
	szMsg     = "Enter the ip address or machine name\n\neg. 127.0.0.1 or stsserver";
	szField1  = "IP Address or Machine Name:";
	g_sztcpip = "";
	nResult   = SdShowDlgEdit1( szTitle, szMsg, szField1, g_sztcpip );     

	//nResult = AskText ( szMsg, g_sztcpip, svResult);        	
	MsiSetProperty(ISMSI_HANDLE, "WEB_CONFIG_STATE_MODE_ADDRESS", g_sztcpip);

	return nResult;
   
end; 

                                    
///////////////////////////////////////////////////////////////////////////////
//
	function 	Dlg_SFSSQLMode()
//
//  COMMENTS:	Check the WEB Server for the .INI and get all the details
//				from the setup.ini file
//				If the file cannot be retrieved then it is incorrectly
//				installed or the incorrect directory path
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nResult; 
	STRING	svString, szTitle, szMsg, szField1, szField2, szField3;
begin

	szTitle  = "Web Configuration - SQL Server Mode Settings";
	szMsg    = "Enter the SQLServer mode details";   
	szField1 = "IP Address or Machine Name:";
	szField2 = "SQL User ID:";                                               
	szField3 = "SQL Password:";                                               
	
	g_szSQLip	 	= "127.0.0.1";
	g_szSQLuserid	= "sa";
	g_szSQLpassword = "";                                               
	
	nResult  = SdShowDlgEdit3( szTitle, szMsg, szField1, szField2, szField3, g_szSQLip, g_szSQLuserid, g_szSQLpassword );     

	MsiSetProperty(ISMSI_HANDLE, "WEB_CONFIG_SQL_ADDRESS", g_szSQLip);
	MsiSetProperty(ISMSI_HANDLE, "WEB_CONFIG_SQL_USERNAME", g_szSQLuserid);
	MsiSetProperty(ISMSI_HANDLE, "WEB_CONFIG_SQL_PASSWORD", g_szSQLpassword);


	return nResult;

end; 

///////////////////////////////////////////////////////////////////////////////
//
	function 	Dlg_SFSSTSMachineName()
//
//  COMMENTS:	Need to get the machine name of the STS server
//
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nResult;
	STRING	svString, szTitle, szMsg, szField1;
begin
	
	szTitle   = "Web Configuration - SAM Machine Name";
	szMsg     = "Enter the Machine Name of the SAM server (Business Server)";
	szField1  = "SAM Server Machine Name:";
	g_szSTSMachineName = "";
	nResult   = SdShowDlgEdit1( szTitle, szMsg, szField1, g_szSTSMachineName );     

	MsiSetProperty(ISMSI_HANDLE, "WEB_CONFIG_SAM_MACHINE_NAME", g_szSTSMachineName);

	return nResult;
   
end; 



///////////////////////////////////////////////////////////////////////////////
//
	function 	Dlg_SFSEmail()
//
//  COMMENTS:	Ask a couple of Email questions for the Business Server
//
///////////////////////////////////////////////////////////////////////////////
