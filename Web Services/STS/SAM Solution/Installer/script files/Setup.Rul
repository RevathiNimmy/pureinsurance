    // your DLL function prototypes


// ---- script function prototypes -----

	prototype Dlg_SFSWebServerAddress();
	prototype Dlg_SFSPreviouslyInstalled();    
	prototype Dlg_SFSSessionState(); 
	prototype Dlg_SFSStateServer();
	prototype Dlg_SFSSQLMode();
	prototype Dlg_SFSSTSMachineName(); 
	prototype Dlg_SFSEmail();
	prototype WebServerCheck();   
	//prototype WebConfigCopyFile();
	prototype WebConfigUpdate_BusinessServer(STRING, STRING);  
	//prototype WebConfigUpdate_WebServer(STRING, STRING);  
	//prototype RunSetupDB();
    prototype Dlg_SFSBackOfficeType();
