	//nResult  = SdShowDlgEdit2( szTitle, szMsg, szField1, szField2, g_szEmailSMTPServer, g_szEmailFromAddress );     
	nResult  = SdShowDlgEdit3 ( szTitle, szMsg, 
								szField1, szField2, szField3, 
								g_szEmailSMTPServer, g_szEmailFromName, g_szEmailFromAddress ); 



//	MsiSetProperty(ISMSI_HANDLE, "WEB_CONFIG_SAM_MACHINE_NAME", g_szSTSMachineName);

	return nResult;
   
end; 


///////////////////////////////////////////////////////////////////////////////
//
	function 	Dlg_SFSPreviouslyInstalled()
//
//  COMMENTS:	
//
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nResult;
	STRING	svString;
begin

		// Set the flag first
		g_bWebServerPreviouslyInstalled = FALSE;

		// enter the WEB server screen
    	if (AskYesNo("Have you previously installed the Web Server " +
    					"on a another machine?", YES) = YES) then

			g_bWebServerPreviouslyInstalled = TRUE;
                           
	   	endif;

	
end;
                                    
///////////////////////////////////////////////////////////////////////////////
//
	function 	Dlg_SFSWebServerAddress()
//
//  COMMENTS:	Check the WEB Server for the .INI and get all the details
//				from the setup.ini file
//				If the file cannot be retrieved then it is incorrectly
//				installed or the incorrect directory path
//
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nResult;                             
	STRING	svString, szTitle, szMsg, szField1, svEdit1; 
begin
       
	szTitle  = "Web Server Address";
	szMsg    = "Enter the Machine Name of the Web Server";   
	szField1 = "Web Server Machine Name:";
	g_szWebServerPath = "WEBSERVER";
	nResult = SdShowDlgEdit1 (szTitle, szMsg, szField1, g_szWebServerPath);

	MsiSetProperty(ISMSI_HANDLE, "WEB_SERVER_MACHINE_NAME", g_szWebServerPath);

	return nResult;

end;


  
///////////////////////////////////////////////////////////////////////////////
//
	function 	Dlg_SFSSessionState()
//
//  COMMENTS:	Check the WEB Server for the .INI and get all the details
//				from the setup.ini file
//				If the file cannot be retrieved then it is incorrectly
//				installed or the incorrect directory path
//
///////////////////////////////////////////////////////////////////////////////
	NUMBER	nResult, nValue, nvCheck1, nvCheck2, nvCheck3;
	STRING	svString, szMsg, szText1, szText2, szText3, svResult, szTitle, 
			szField1, szField2, szField3, svEdit1, svEdit2, svEdit3;
begin
                                  
	szMsg = "Which Session State is required?";
	nValue = EXCLUSIVE; // Option box                                                      
	
	szText1 = "InProc Mode - Enable the use of the Server own state management";
	szText2 = "StateServer Mode";
	szText3 = "SQLServer Mode";
	 
	nvCheck1 = FALSE;
	nvCheck2 = FALSE;
	nvCheck3 = FALSE;

	switch (g_nSessionState)
		case 1: 
			nvCheck1 = TRUE;
		case 2:
			nvCheck2 = TRUE;
		case 3:
			nvCheck3 = TRUE;
		default:
			nvCheck1 = TRUE;
	endswitch;
	
    nResult = AskOptions (nValue, szMsg, szText1, nvCheck1, szText2, nvCheck2, szText3, nvCheck3);

	// Nother more than set the g_nSessionState
	if nvCheck1 = TRUE then	
	
		g_nSessionState = 1;
		
	endif;  
	
	// Set the Session State and get the Connection String attributes
	if nvCheck2 = TRUE then	
	                                            
		g_nSessionState = 2;                                             
		
	endif;
	      
	
	if nvCheck3 = TRUE then	
		
		g_nSessionState = 3;
	 
	endif;
	
	return nResult;	
              
end;  

///////////////////////////////////////////////////////////////////////////////
//
	function 	Dlg_SFSBackOfficeType()
//
//  COMMENTS:	0 = Underwriting, 1 = Broking
//
///////////////////////////////////////////////////////////////////////////////
    NUMBER	nResult, nvExitCode, nvType, nvSize;
    STRING	szInputString, svValue, szProgram , svKey;
			
begin

	// Does the PM subkey exist
	RegDBSetDefaultRoot ( HKEY_LOCAL_MACHINE );
	nResult = RegDBKeyExist ( "SOFTWARE\\PM" ); 
	
	// set the key
	svKey = "SOFTWARE\\PM\\SiriusSolutions\\Setup";

	if ( nResult = 1 ) then
		// Get the PMDIR registry settings	
		nResult = RegDBGetKeyValueEx ( svKey , "Sirius Type" , nvType , svValue , nvSize );
	endif;

	if (svValue = "Underwriting") | (svValue = "Insurance") then	
		g_szBackOfficeType = "0";
	else
		g_szBackOfficeType = "1";
	endif;  
	
	return nResult;	
              
end;  
  

