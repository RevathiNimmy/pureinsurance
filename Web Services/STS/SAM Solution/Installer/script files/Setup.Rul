///////////////////////////////////////////////////////////////////////////////
//                                                                           //
	function	STSPerformanceCounters()
//                                                                           //
//  Purpose:  
//                                                                           //
//                                                                           //
///////////////////////////////////////////////////////////////////////////////
    NUMBER	nResult, nvExitCode, nvType, nvSize;
    STRING	szProgram , szCmdLine, svResult, svDir, svDirTemp, svStatus, szMsg;
begin

	SetStatusWindow( -1, "Installing SAM Performance Counters" );
	//SdShowMsg ( "Installing STS Performance Counters" , TRUE );

	szProgram = TARGETDIR ^ "SiriusFS.SAM.ServiceAgent" ^ "SFSPerfMonCounters.exe";

	szCmdLine = "/SILENT";
     
	SFS_LaunchAppAndWait ( szProgram , szCmdLine , WAIT );
	if (nvExitCode != 0) then
		szMsg = "Unable to launch : " + szProgram + " it will need to be run manually.";
		MessageBox ( szMsg, SEVERE );
		return 0;
	endif;

	//SdShowMsg ( "Installing SAM Performance Counters" , FALSE );
	
end;

