//////////////////////////////////////////////////////////////////////////////
//
	function 	SFS_OnBegin()
//
//  EVENT:	  Begin event is always sent as the first event during installation.
//
//////////////////////////////////////////////////////////////////////////////
	NUMBER	nvResult, nvType, nvValue;
begin

	SFS_MessageBox ( "Procedure: SFS_OnBegin", LOGGING );

// TO DO: you may change default non-UI setting, for example
//
// You may also perform your custom initialization steps, check requirements, etc.

// Run the dummy procedure
	SFS_Dummy();
	
// Get the computer name
	RegDBSetDefaultRoot ( HKEY_LOCAL_MACHINE );
	nvType = REGDB_STRING;
	RegDBGetKeyValueEx ( "SYSTEM\\CurrentControlSet\\Control\\ComputerName\\ActiveComputerName",
							 "ComputerName" , nvType , g_sComputerName, nvValue );
   	MsiSetProperty(ISMSI_HANDLE, "COMPUTER_NAME", g_sComputerName);

// Set up the versions numbers
   	SFS_SetVersions();
   	
// Set the installer into read mode
   	MsiSetProperty(ISMSI_HANDLE, "READ_WRITE", "READ"); 
   	
// Get all the properties for the installation  
	SFS_GetAllProperties();

// Check Administrator permissions for Windows NT users
	SFS_CheckPermissions();

// Get the PMDIR if it exists
	nvResult = SFS_GetInstallDir();
	if ( nvResult < 0 ) then
		// The product is not installed
	else
		// It has been installed before
	endif;
   
// Get the version of the PreReqs currently installed and 
// check a version of PreReqs exists on the CD
	SFS_PreReqs_GetInstalledVersion();
	SFS_PreReqs_GetCDVersion();

// Exit the function
	return 0;

end;

//////////////////////////////////////////////////////////////////////////////
//
	function 	SFS_OnGeneratingMSIScript()
//
//  EVENT:      GeneratingMSIScript event is sent just before the 
//              MSI standard action LauchConditions is executed.
//
///////////////////////////////////////////////////////////////////////////////
	STRING	szFileSharePath, szComputerName;
	NUMBER	nvSize;	
begin

	SFS_MessageBox ( "Procedure: SFS_OnGeneratingMSIScript", LOGGING );

// ---- Get the MSI Properties ----
	SFS_MsiGetProperty (ISMSI_HANDLE, "FILE_SHARE_PATH", szFileSharePath, nvSize);
	SFS_MsiGetProperty (ISMSI_HANDLE, "COMPUTER_NAME", szComputerName, nvSize);

// Set the File Share Path
	if ( szFileSharePath = "" ) then 
		if ( g_bServer ) then
 			
 		else
 		// so set up the UNC path for the client machine
			MsiSetProperty(ISMSI_HANDLE, "FILE_SHARE_PATH", "\\\\" + szComputerName + "\\" );
		endif;
	endif;
 
// Install the prereqs if required
	SFS_PreReqs_Install();
	
end;                                                                            


//////////////////////////////////////////////////////////////////////////////
//
	function 	SFS_PostFileInstall()
//
//  EVENT:      Moved event is sent just before the standard MSI action 
//				InstallFinalize is executed.
//
///////////////////////////////////////////////////////////////////////////////
begin

	SFS_MessageBox ( "Procedure: SFS_PostFileInstall", LOGGING );

// On run on server
	if ( g_bServer ) then

	// make sure the PMSetup share is setup
		SFS_DlgPMSetupShare( FALSE );
		
	// Copy the install set to the PMSetup
		SFS_ClientInstall(  "SIRSOL",
							 	IFX_PRODUCT_NAME,
								IFX_PRODUCT_NAME + " - Client Installation",
								PACKAGE_LOCATION );	

	// Update the Product History
		SFS_ProductUpdateHistory();

	endif;
	
end;

