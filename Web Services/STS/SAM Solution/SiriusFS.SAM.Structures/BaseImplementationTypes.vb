        Public Property CurrencyKey As Integer = 0

        Public Property DocumentKey As Integer = 0

        Public Property AccountCode As String = ""

        Public Property ClaimPaymentAmount As Decimal = CDec(0.0)

        Public Property BankAccountCode As String = ""

        Public Property ClaimPaymentBranchCode As String = ""

        Public Property ClaimPaymentBranchKey As Integer = 0

        Public Property PayeeName As String = ""

        Public Property OurRef As String = ""

        Public Property AccountKey As Integer = 0

        Public Property DocumentRef As String = ""

        Public Sub Validate(ByRef oSAMErrorCollection As SAMErrorCollection)

            If ClaimPaymentKey = 0 Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                                   SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                                "ClaimPaymentKey")
            End If

            If MediaTypeCode = "" Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                            SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                            "MediaTypeCode")
            End If

            If CurrencyCode = "" Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                            SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                            "CurrencyCode")
            End If

            If AccountCode = "" Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                            SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                            "AccountCode")
            End If

            If BankAccountCode = "" Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                            SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                            "BankAccountCode")
            End If

            If ClaimPaymentBranchCode = "" Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                            SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                            "ClaimPaymentBranchCode")
            End If

            If ClaimPaymentAmount < CDec(0.0) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                            SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                            "ClaimPaymentAmount")
            End If

        End Sub

    End Class

