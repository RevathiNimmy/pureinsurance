        Public Overridable Sub Validate(ByRef oErrorCollection As Object)

            Dim oSAMErrorCollection As SAMErrorCollection = CType(oErrorCollection, SAMErrorCollection)


            If String.IsNullOrEmpty(CashDepositRef) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                   SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                   "CashDepositRef")
            End If

            If String.IsNullOrEmpty(PartyCode) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                   SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                   "PartyCode")
            End If

            If String.IsNullOrEmpty(UserName) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                   SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                   "UserName")
            End If


            If (Products IsNot Nothing) Then
                For Each product As BaseCommonCashDepositItemTypeProducts In Products
                    product.Validate(oErrorCollection, Me.CashDepositRef)
                Next
            Else
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "Products are missing for the CD Ref " & Me.CashDepositRef)
            End If

            If (Branches IsNot Nothing) Then
                For Each branch As BaseCommonCashDepositItemTypeBranches In Branches
                    branch.Validate(oErrorCollection, Me.CashDepositRef)
                Next
            Else
                oSAMErrorCollection.AddInvalidData(
                                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                "Branches are missing for the CD Ref " & Me.CashDepositRef)
            End If


        End Sub

