                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "BankGuaranteeref")
            End If

            If Me.BankNameKey = 0 Then
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "BankNameKey  is missing for the BG Ref " & Me.BankGuaranteeRef)
            End If

            If String.IsNullOrEmpty(Me.BankBranch) Then
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "BankBranch is missing for the BG Ref " & Me.BankGuaranteeRef)
            End If

            If Me.PartyKey = 0 Then
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "PartyKey is missing for the BG Ref " & Me.BankGuaranteeRef)
            End If

            If String.IsNullOrEmpty(Me.CustodyBranchCode) Then
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "CustodyBranchCode is missing for the BG Ref " & Me.BankGuaranteeRef)
            End If

            If String.IsNullOrEmpty(Me.BGCurrencyCode) Then
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "BGCurrencyCode is missing for the BG Ref " & Me.BankGuaranteeRef)
            End If


            If Me.BGLimit = 0 Then
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "BGLimit is missing for the BG Ref " & Me.BankGuaranteeRef)
            End If

            If Me.ExpiryDate <= Date.MinValue Then
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "ExpiryDate is missing for the BG Ref " & Me.BankGuaranteeRef)
            End If

            If Me.IssueDate <= Date.MinValue Then
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "IssueDate is missing for the BG Ref " & Me.BankGuaranteeRef)
            End If

            If (Products IsNot Nothing) Then
                For Each product As BaseBankGuaranteeItemTypeProducts In Products
                    product.Validate(oErrorCollection, Me.BankGuaranteeRef)
                Next
            Else
                oSAMErrorCollection.AddInvalidData(
                SAMConstants.SAMInvalidData.MandatoryInputMissing,
                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                "Products are missing for the BG Ref " & Me.BankGuaranteeRef)
            End If

            If (Branches IsNot Nothing) Then
                For Each branch As BaseBankGuaranteeItemTypeBranches In Branches
                    branch.Validate(oErrorCollection, Me.BankGuaranteeRef)
                Next
            Else
                oSAMErrorCollection.AddInvalidData(
