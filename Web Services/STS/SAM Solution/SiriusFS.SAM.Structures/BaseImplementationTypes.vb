        Public Property MtaReasonCode As String

        Public Overrides Sub Validate(ByRef ErrorCollection As Object)

            Dim oSAMErrorCollection As SAMErrorCollection = CType(ErrorCollection, SAMErrorCollection)

            MyBase.Validate(CObj(oSAMErrorCollection))

            If EffectiveDate = New Date Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                                    "EffectiveDate")
            End If

            If MtaReason = String.Empty Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                                    "MtaReason")
            End If

            If TypeOfMta = String.Empty Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                                    "TypeOfMta")
            End If

            If TypeOfMta.ToUpper = "TEMPORARY" Then
                If ExpiryDate = New Date Then
                    oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                                        SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                                        "ExpiryDate")
                End If
            End If

            If InsuranceFileKey = 0 Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                    "InsuranceFileKey")
            End If
            'Start (Sriram P) - (Tech Spec - UIICWR50 - MTC - Policy Header.doc) - (7.3.4.1)

            If String.IsNullOrEmpty(BusinessTypeCode) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                    "BusinessTypeCode", "")
            End If
            If String.IsNullOrEmpty(FrequencyCode) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                    "FrequencyCode", "")
            End If
            If String.IsNullOrEmpty(BranchCode) Then
                oSAMErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                            SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                 "BranchCode")
            End If

            'End(Sriram P) - (Tech Spec - UIICWR50 - MTC - Policy Header.doc) - (7.3.4.1)

        End Sub

