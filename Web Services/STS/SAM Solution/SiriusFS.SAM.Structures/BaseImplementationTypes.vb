        '''<remarks/>
        <System.Xml.Serialization.XmlElementAttribute("History")>
        Public Property History() As BasePartyBankHistoryType()
            Get
                Return Me.historyField
            End Get
            Set(ByVal value As BasePartyBankHistoryType())
                Me.historyField = value
            End Set
        End Property
        Public Sub Validate(ByRef oErrorCollection As Object)

            Dim samErrorCollection As SAMErrorCollection = CType(oErrorCollection, SAMErrorCollection)

            If String.IsNullOrEmpty(Me.BankPaymentTypeCode) Then
                samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "BankPaymentTypeCode")
            End If

            If String.IsNullOrEmpty(Me.AccountHolderName) Then
                samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "AccountHolderName")
            End If

            If String.IsNullOrEmpty(Me.AccountType) Then
                samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "AccountType")
            End If
            If Me.IsBankItem Then
                If Me.CreditCard IsNot Nothing Then
                    samErrorCollection.AddInvalidData(
                                        SAMConstants.SAMInvalidData.ValidationRulesFailed,
                                        "Credit card details provided for a bank item",
                                        "CreditCard")
                End If
                If Me.Bank Is Nothing Then
                    samErrorCollection.AddInvalidData(
                                        SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                        SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                        "Bank")
                Else

                    Me.Bank.Validate(CObj(samErrorCollection))

                End If
            Else

                If Me.CreditCard Is Nothing Then
                    samErrorCollection.AddInvalidData(
                                        SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                        SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                        "CreditCard")
                Else
                    Me.CreditCard.Validate(CObj(samErrorCollection))
                    'Expiry date validation
                    Dim iExpiryMonth As Integer
                    Dim iExpiryYear As Integer
                    Dim dtExpiryDate As Date
                    Dim sExpiryDate As String
                    Dim bValidExpiryDate As Boolean = False
                    Try
                        iExpiryMonth = Convert.ToInt32(Me.CreditCard.ExpiryDate.Substring(0, 2))
                        iExpiryYear = Convert.ToInt32(Me.CreditCard.ExpiryDate.Substring(3, 2))

                        If iExpiryMonth < 1 OrElse iExpiryMonth > 12 Then
                            samErrorCollection.AddInvalidData(
                                            SAMConstants.SAMInvalidData.InvalidDateFormat,
                                             "Invalid Expiry Date",
                                            "Expiry Date")
                        Else

                            sExpiryDate = "01-" & GetMonth(iExpiryMonth) & "-" & iExpiryYear.ToString("D2")
                            'System convert 30 to 1930 if year is greatar than and equal to 1930
                            If iExpiryYear >= 30 Then
                                sExpiryDate = "01-" & GetMonth(iExpiryMonth) & "-" & Now.Year.ToString().Substring(0, 2) & iExpiryYear.ToString("D2")
                            End If
                            dtExpiryDate = Date.Parse(sExpiryDate)

                            If dtExpiryDate.Year < Now.Year OrElse (dtExpiryDate.Year = Now.Year AndAlso dtExpiryDate.Month < Now.Month) Then
                                samErrorCollection.AddInvalidData(
                                                SAMConstants.SAMInvalidData.InvalidDateFormat,
                                                 "Expiry Date must be greater than or equal to current date",
                                                "Expiry Date")
                            Else
                                bValidExpiryDate = True
                            End If
                        End If

                    Catch ex As Exception
                        samErrorCollection.AddInvalidData(
                                                       SAMConstants.SAMInvalidData.InvalidDateFormat,
                                                        "Invalid Expiry Date. Expiry date format is MM/YY",
                                                       "Expiry Date")
                    End Try

                    If Not String.IsNullOrEmpty(Me.CreditCard.StartDate) Then
                        'Start date validation
                        Dim iStartMonth As Integer
                        Dim iStartYear As Integer
                        Dim dtStartDate As Date
                        Dim sStartDate As String

                        Try
                            iStartMonth = Convert.ToInt32(Me.CreditCard.StartDate.Substring(0, 2))
                            iStartYear = Convert.ToInt32(Me.CreditCard.StartDate.Substring(3, 2))

                            If iStartMonth < 1 OrElse iStartMonth > 12 Then
                                samErrorCollection.AddInvalidData(
                                                SAMConstants.SAMInvalidData.InvalidDateFormat,
                                                 "Invalid Start Date",
                                                "Start Date")

                            Else
                                sStartDate = "01-" & GetMonth(iStartMonth) & "-" & iStartYear.ToString("D2")
                                'System convert 30 to 1930 if year is greatar than and equal to 1930
                                If iStartYear >= 30 Then
                                    sStartDate = "01-" & GetMonth(iStartMonth) & "-" & Now.Year.ToString().Substring(0, 2) & iStartYear.ToString("D2")
                                End If
                                dtStartDate = Date.Parse(sStartDate)

                                If dtStartDate.Year > Now.Year OrElse (dtStartDate.Year = Now.Year AndAlso dtStartDate.Month > Now.Month) Then
                                    samErrorCollection.AddInvalidData(
                                                    SAMConstants.SAMInvalidData.InvalidDateFormat,
                                                     "Start Date must be less than or equal to current date",
                                                    "Start Date")
                                ElseIf bValidExpiryDate AndAlso dtExpiryDate.Year < dtStartDate.Year OrElse (dtExpiryDate.Year = dtStartDate.Year AndAlso dtExpiryDate.Month < dtStartDate.Month) Then
                                    samErrorCollection.AddInvalidData(
                                                    SAMConstants.SAMInvalidData.InvalidDateFormat,
                                                     "Start Date must be less than or equal to expiry date",
                                                    "Expiry Date")
                                End If
                            End If

                        Catch ex As Exception
                            samErrorCollection.AddInvalidData(
                                                               SAMConstants.SAMInvalidData.InvalidDateFormat,
                                                                "Invalid Start Date. Start date format is MM/YY",
                                                               "Start Date")
                        End Try
                    End If

                    If Not Me.CreditCard.IsRegisteredCardHolder Then
                        If Me.CreditCard.CardHolder Is Nothing OrElse String.IsNullOrEmpty(Me.CreditCard.CardHolder.AddressLine1) Then
                            samErrorCollection.AddInvalidData(
                                                        SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                        SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                        "AddressLine1")
                        End If
                    End If

                End If
            End If
        End Sub
        Private Function GetMonth(ByVal iMonth As Integer) As String
            Dim sMonth As String = String.Empty
            Select Case iMonth
                Case 1
                    sMonth = "Jan"
                Case 2
                    sMonth = "Feb"
                Case 3
                    sMonth = "Mar"
                Case 4
                    sMonth = "Apr"
                Case 5
                    sMonth = "May"
                Case 6
                    sMonth = "Jun"
                Case 7
                    sMonth = "Jul"
                Case 8
                    sMonth = "Aug"
                Case 9
                    sMonth = "Sep"
                Case 10
                    sMonth = "Oct"
                Case 11
                    sMonth = "Nov"
                Case 12
                    sMonth = "Dec"
            End Select
            Return sMonth
        End Function
    End Class

