        ''' Convert the LockName Enum Into String
        ''' </summary>
        ''' <param name="LockName"></param>
        ''' <value></value>
        ''' <returns></returns>
        ''' <remarks></remarks>
        Public ReadOnly Property TAskLockNameString(ByVal LockName As TaskLockName) As String
            Get
                Select Case LockName
                    Case TaskLockName.InsuranceFileCnt
                        Return "insurance_file_cnt"
                    Case TaskLockName.InsuranceFolderCnt
                        Return "insurance_folder_cnt"
                    Case TaskLockName.PartyCnt
                        Return "party_cnt"
                    Case TaskLockName.ClaimId
                        Return "claim_id"
                    Case TaskLockName.TaskInstanceCnt
                        Return "pmwrk_task_instance_cnt"

                    Case TaskLockName.UserGroupCnt
                        Return "pmuser_group_id"

                    Case TaskLockName.TaskGroupCnt
                        Return "pmwrk_task_group_id"

                    Case TaskLockName.CoverNoteBookId
                        Return "cover_note_book_id"

                    Case TaskLockName.BGId
                        Return "bg_id"

                    Case TaskLockName.RenewalProcess
                        Return "renewal_status_cnt"

                    Case TaskLockName.TransDetailKey
                        Return "transdetail_id"

                    Case TaskLockName.CashListItemID
                        Return "cashlistitem_id"

                    Case TaskLockName.ClaimPaymentCnt
                        Return "claim_payment_id"

                    Case TaskLockName.RiskKey
                        Return "risk_cnt"

                    Case TaskLockName.CashDepositKey
                        Return "cashdeposit_id"

                    Case Else
                        Return String.Empty
                End Select
            End Get
        End Property

        Public ReadOnly Property LockNameStringToEnum(ByVal LockNameString As String) As TaskLockName
            Get
                Select Case LockNameString
                    Case "insurance_file_cnt"
                        Return TaskLockName.InsuranceFileCnt

                    Case "insurance_folder_cnt"
                        Return TaskLockName.InsuranceFolderCnt

                    Case "party_cnt"
                        Return TaskLockName.PartyCnt

                    Case "claim_id"
                        Return TaskLockName.ClaimId

                    Case "pmwrk_task_instance_cnt"
                        Return TaskLockName.TaskInstanceCnt

                    Case "pmuser_group_id"
                        Return TaskLockName.UserGroupCnt

                    Case "pmwrk_task_group_id"
                        Return TaskLockName.TaskGroupCnt

                    Case "cover_note_book_id"
                        Return TaskLockName.CoverNoteBookId

                    Case "bg_id"
                        Return TaskLockName.BGId

                    Case "renewal_status_cnt"
                        Return TaskLockName.RenewalProcess

                    Case "transdetail_id"
                        Return TaskLockName.TransDetailKey

                    Case "cashlistitem_id"
                        Return TaskLockName.CashListItemID

                    Case "claim_payment_id"
                        Return TaskLockName.ClaimPaymentCnt

                    Case "risk_cnt"
                        Return TaskLockName.RiskKey

                    Case "cashdeposit_id"
                        Return TaskLockName.CashDepositKey

                    Case Else
                        Return TaskLockName.InvalidValue
                End Select
            End Get
        End Property

#Region "Public Function - Mandatory Validate"
        'Start (Vijayakumar Ramasamy) -(Tech Spec - UIIC WR33 - Work Manager - Create Task(Additional Changes).doc)- (7.1.4.5)

        Public Overrides Sub Validate(ByRef oErrorCollection As Object)

            Dim oSAMErrorCollection As SAMErrorCollection = CType(oErrorCollection, SAMErrorCollection)

            MyBase.Validate(oErrorCollection)

            If String.IsNullOrEmpty(TaskGroup) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing, SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString(), "TaskGroup")
            End If
            If String.IsNullOrEmpty(Task) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing, SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString(), "Task")
            End If
            If DueDateTime <= Date.MinValue Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing, SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString(), "DueDateTime")
            End If
            If String.IsNullOrEmpty(Client) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing, SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString(), "Client")
            End If
            If String.IsNullOrEmpty(Description) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing, SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString(), "Description")
            End If

            'If String.IsNullOrEmpty(AllocationUser) Then
            '    oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing, SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString(), "AllocationUser")
            'End If

            If String.IsNullOrEmpty(AllocationUserGroup) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing, SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString(), "AllocationUserGroup")
            End If


        End Sub
        'End (Vijayakumar Ramasamy) -(Tech Spec - UIIC WR33 - Work Manager - Create Task(Additional Changes).doc)- (7.1.4.5)

