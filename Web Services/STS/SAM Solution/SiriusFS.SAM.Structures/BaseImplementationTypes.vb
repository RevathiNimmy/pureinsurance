        Public Overrides Sub Validate(ByRef oErrorCollection As Object)

            MyBase.Validate(oErrorCollection)
            Dim oSAMErrorCollection As SAMErrorCollection = CType(oErrorCollection, SAMErrorCollection)
            If PartyCntSpecified = True Then
                If PartyCnt = 0 Then
                    oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                "PartyCnt", Convert.ToString(PartyCnt))
                End If
            End If


            If AccountKeySpecified = True Then
                If AccountKey = 0 Then
                    oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.InvalidPartyKeySpecified,
                                                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString.ToString,
                                                "AccountKey", Convert.ToString(AccountKey))
                    oSAMErrorCollection.CheckForErrors()
                End If
            End If
            If dueDateFromFieldSpecified Then
                If Information.IsNothing(DueDateFrom) Or Not (Information.IsDate(DueDateFrom)) Or (DueDateFrom < #12/30/1899#) Then
                    oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.InvalidDateFormat,
                                             SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString.ToString,
                                             "DueDateFrom", Convert.ToString(DueDateFrom))
                    oSAMErrorCollection.CheckForErrors()
                End If
            End If
            If dueDateToFieldSpecified Then
                If Information.IsNothing(DueDateTo) Or Not (Information.IsDate(DueDateTo)) Or (DueDateTo < #12/30/1899#) Then
                    oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.InvalidDateFormat,
                                             SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString.ToString,
                                             "dueDateTo", Convert.ToString(DueDateTo))
                    oSAMErrorCollection.CheckForErrors()
                End If
            End If
        End Sub
    End Class
