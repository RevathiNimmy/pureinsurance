        Public Property NoTrans() As Boolean
        Public Property IsCallingFromSAM() As Boolean
        Public Overrides Sub Validate(ByRef oErrorCollection As Object)

            MyBase.Validate(oErrorCollection)

            Dim samErrorCollection As SAMErrorCollection = CType(oErrorCollection, SAMErrorCollection)

            If Me.InsuranceFileKey = 0 Then
                samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "InsuranceFileKey")
            End If

            If Me.SelectedInstalmentQuoteSpecified Then

                ' Validate selected instalment quote element 
                ' NB: this would have been done on that actual type
                ' but this base type has been restructured so that all its
                ' properties are included in this type

                If Me.SelectedSchemeNo = 0 Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "SelectedSchemeNo")
                End If

                If Me.SelectedSchemeVersion = 0 Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "SelectedSchemeVersion")
                End If

                If Me.QuoteDate = Date.MinValue Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "QuoteDate")
                End If

                If Me.StartDate = Date.MinValue Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "StartDate")
                End If

                If Me.EndDate = Date.MinValue Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "EndDate")
                End If

                If Me.PreferredDate = Date.MinValue Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "PreferredDate")
                End If

                If Me.MonthDay = 0 Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "MonthDay")
                End If

                If Me.WeekDay = 0 Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "WeekDay")
                End If

                If Me.PFRF_ID = 0 Then
                    samErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.MandatoryInputMissing,
                    SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                    "PFRF_ID")
                End If

                ' Mandatory fields but defaults if not set are valid
                ' PaymentProtection     -> defaults to false
                ' OverrideRate          -> defaults to 0 
                ' OverrideInterestRate  -> defaults to 0
                ' AmountPaid            -> defaults to 0

                If Me.CreditCard IsNot Nothing And Me.TransactionType <> "REN" Then

                    'Me.CreditCard.Validate(oErrorCollection)

                End If

            End If

            If Me.PayNowDetails IsNot Nothing Then

                Me.PayNowDetails.Validate(oErrorCollection)

            End If


        End Sub

    End Class
