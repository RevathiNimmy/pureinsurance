                Me.regardingField = value
            End Set
        End Property

        Public Overloads Sub Validate(ByRef oErrorCollection As Object, ByVal IsUnderwriting As Boolean)

            Dim oSTSError As STSErrorPublisher = CType(oErrorCollection, STSErrorPublisher)

            If Me.PartyKey = 0 Then
                oSTSError.AddInvalidField("PartyKey", CStr(STSErrorPublisher.STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "PartyKey"), "")
            End If

            If Me.CoverStartDate = New Date Then
                oSTSError.AddInvalidField("CoverStartDate", CStr(STSErrorPublisher.STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "CoverStartDate"), "")
            End If

            If Me.CoverEndDate = New Date Then
                oSTSError.AddInvalidField("CoverEndDate", CStr(STSErrorPublisher.STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "CoverEndDate"), "")
            End If

            If String.IsNullOrEmpty(Me.ProductCode) Then
                oSTSError.AddInvalidField("ProductCode", CStr(STSErrorPublisher.STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "ProductCode"), "")
            End If

            If String.IsNullOrEmpty(Me.BranchCode) Then
                oSTSError.AddInvalidField("BranchCode", CStr(STSErrorPublisher.STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "BranchCode"), "")
            End If

            If Not IsUnderwriting Then
                If String.IsNullOrEmpty(Me.RiskCode) Then
                    oSTSError.AddInvalidField("RiskCode", STSErrorPublisher.STSErrorCodes.MandatoryInputMissing.ToString, [String].Format(STSErrorPublisher.MandatoryInputMissing, "RiskCode"), "")
                End If

                If String.IsNullOrEmpty(Me.ScreenCode) Then
                    oSTSError.AddInvalidField("ScreenCode", STSErrorPublisher.STSErrorCodes.MandatoryInputMissing.ToString, [String].Format(STSErrorPublisher.MandatoryInputMissing, "ScreenCode"), "")
                End If
            End If

        End Sub
    End Class

