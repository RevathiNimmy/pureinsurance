    Public Overloads Function GetSharepointFileList(ByVal conGetSharepointFileListRequest As SiriusConnection, ByVal oGetSharepointFileListRequest As BaseGetSharepointFileListRequestType) As BaseGetSharepointFileListResponseType

        Dim oGetSharepointFileListResponse As BaseGetSharepointFileListResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim oFileList As DataTable = Nothing
        Dim destinationURL As String = oGetSharepointFileListRequest.FolderPath
        Dim sIsSharepoinOnline As String
        Dim dtFileList As New DataTable
        Dim oBusiness As New CoreBusiness
        Try

            oGetSharepointFileListResponse = New SAMForInsuranceV2ImplementationTypes.GetSharepointFileListResponseType
            oBusiness.GetSystemOption(oGetSharepointFileListRequest.BranchCode, SystemOption.IsSharepointOnline, sIsSharepoinOnline)

            If Trim(sIsSharepoinOnline) = "1" Then
                Dim oSIRSharepoint As New bSIRSharepointOnline.BusinessSharepointOnline

                InitialiseSBOObject(oObject:=oSIRSharepoint, siriusUser:=_SiriusUser, sObjectName:="bSIRSharepointOnline.BusinessSharepointOnline")

                Dim ret As Integer = oSIRSharepoint.GetFileList(PartyShortname:=oGetSharepointFileListRequest.PartyShortname,
                                      PolicyNumber:=oGetSharepointFileListRequest.PolicyNumber,
                                      ClaimNumber:=oGetSharepointFileListRequest.ClaimNumber,
                                      destinationUrl:=destinationURL,
                                      FileList:=dtFileList, CreateFolder:=oGetSharepointFileListRequest.CreateFolder)

                If ret <> PMEReturnCode.PMTrue Then
                    RaiseComMethodException("bSIRSharepoint.Business.GetFileList Failed", ret)
                End If

            Else
                Dim oSIRSharepoint As New bSIRSharepoint.Business

                InitialiseSBOObject(oObject:=oSIRSharepoint, siriusUser:=_SiriusUser, sObjectName:="bSIRSharepoint.Business")

                Dim ret As Integer = oSIRSharepoint.GetFileList(PartyShortname:=oGetSharepointFileListRequest.PartyShortname,
                                           PolicyNumber:=oGetSharepointFileListRequest.PolicyNumber,
                                           ClaimNumber:=oGetSharepointFileListRequest.ClaimNumber,
                                           destinationUrl:=destinationURL,
                                           FileList:=dtFileList, CreateFolder:=oGetSharepointFileListRequest.CreateFolder)

                If ret <> PMEReturnCode.PMTrue Then
                    RaiseComMethodException("bSIRSharepoint.Business.GetFileList Failed", ret)
                End If

            End If

            oGetSharepointFileListResponse.FolderPath = destinationURL

            If dtFileList IsNot Nothing AndAlso dtFileList.Rows.Count > 0 Then
                Dim oFile() As BaseGetSharepointFileListResponseTypeItemList
                Dim ofileItem As BaseGetSharepointFileListResponseTypeItemList
                ReDim Preserve oFile(dtFileList.Rows.Count - 1)
                For iRow As Integer = 0 To dtFileList.Rows.Count - 1
                    ofileItem = New BaseGetSharepointFileListResponseTypeItemList

                    ofileItem.Title = Convert.ToString((dtFileList.Rows(iRow).Item("Title")))

                    If dtFileList.Rows(iRow).Item("PureUser") IsNot Nothing Then
                        ofileItem.PureUser = ToSafeString(dtFileList.Rows(iRow).Item("PureUser"))
                    End If

                    If dtFileList.Rows(iRow).Item("DocumentGroup") IsNot Nothing Then
                        ofileItem.DocumentTemplateGroup = ToSafeString(dtFileList.Rows(iRow).Item("DocumentGroup"))
                    End If

                    If dtFileList.Rows(iRow).Item("DocumentSubGroup") IsNot Nothing Then
                        ofileItem.DocumentTemplateSubGroup = ToSafeString(dtFileList.Rows(iRow).Item("DocumentSubGroup"))
                    End If

                    If dtFileList.Rows(iRow).Item("FileLeafRef") IsNot Nothing Then
                        ofileItem.Filename = ToSafeString(dtFileList.Rows(iRow).Item("FileLeafRef"))
                    End If

                    If dtFileList.Rows(iRow).Item("FileLeafRef") IsNot Nothing Then
                        If destinationURL.EndsWith("/") Then
                            ofileItem.URL = destinationURL & CStr(dtFileList.Rows(iRow).Item("FileLeafRef"))
                        Else
                            ofileItem.URL = destinationURL & "/" & CStr(dtFileList.Rows(iRow).Item("FileLeafRef"))
                        End If

                    End If

                    If dtFileList.Rows(iRow).Item("DocIcon") IsNot Nothing Then
                        ofileItem.ItemType = ToSafeString(dtFileList.Rows(iRow).Item("DocIcon"))
                    End If

                    If dtFileList.Rows(iRow).Item("CreatedDate") IsNot Nothing Then
                        ofileItem.CreatedDate = ToSafeDate(dtFileList.Rows(iRow).Item("CreatedDate"))
                    End If

                    If dtFileList.Rows(iRow).Item("ModifiedDate") IsNot Nothing Then
                        ofileItem.LastModifiedDate = ToSafeDate(dtFileList.Rows(iRow).Item("ModifiedDate"))
                    End If
                    oFile(iRow) = ofileItem
                Next
                oGetSharepointFileListResponse.ItemList = oFile
            End If

        Catch ex As Exception
            ex = New Exception("GetSharepointFileList failed", ex)
            ExceptionManager.Publish(ex)
            Throw ex
        Finally
            'If Not oSIRSharepoint IsNot Nothing Then
            '    ' oSIRSharepoint.Dispose()
            '    oSIRSharepoint = Nothing
            'End If
        End Try

        Return oGetSharepointFileListResponse
    End Function

    Public Overloads Function GetStandardWordingTemplate(ByVal getStandardWordingTemplateRequest As BaseGetStandardWordingTemplateRequestType) As BaseGetStandardWordingTemplateResponseType

        Dim getStandardWordingTemplateResponse As New BaseGetStandardWordingTemplateResponseType
        Dim samErrorCollection As New SAMErrorCollection
        Dim oCoreBusiness As New CoreBusiness
        Dim documentTypeId As Integer
        Dim documentTemplateId As Integer

        Dim nTypeOfPackage As enumTypeOfPackage

        If getStandardWordingTemplateRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetStandardWordingTemplateRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            getStandardWordingTemplateResponse = New SAMForInsuranceV2ImplementationTypes.GetStandardWordingTemplateResponseType
        End If

        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        getStandardWordingTemplateRequest.Validate(CObj(samErrorCollection))
        samErrorCollection.CheckForErrors()

        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=ConnectionString)

            If getStandardWordingTemplateRequest.DocumentTemplateKey = 0 Then

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_document_template_saa")

                    cmd.AddInParameter("@code", SqlDbType.Char, 10).Value = getStandardWordingTemplateRequest.DocumentTemplateCode
                    cmd.AddOutParameter("@document_template_id", SqlDbType.Int)
                    cmd.AddOutParameter("@document_type_id", SqlDbType.Int)
                    cmd.AddOutParameter("@description", SqlDbType.Char, 255)
                    'cmd.AddOutParameter("@effective_date", SqlDbType.DateTime)

                    Dim returnval As Integer = con.ExecuteNonQuery(cmd)

                    documentTemplateId = Cast.ToInt32(cmd.Parameters("@document_template_id").Value, 0)
                    documentTypeId = Cast.ToInt32(cmd.Parameters("@document_type_id").Value, 0)

                End Using

                getStandardWordingTemplateRequest.DocumentTemplateKey = documentTemplateId

                If documentTemplateId = 0 Then
                    samErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "DocumentTemplateCode", getStandardWordingTemplateRequest.DocumentTemplateCode)
                End If

                '' exit if there are any missing parameters
                samErrorCollection.CheckForErrors()

            Else

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_document_template_sel")

                    cmd.AddInParameter("@document_template_id", SqlDbType.Int).Value = getStandardWordingTemplateRequest.DocumentTemplateKey

                    Dim dtDocumentTemplate As DataTable = con.ExecuteDataTable(cmd)

                    If dtDocumentTemplate IsNot Nothing AndAlso dtDocumentTemplate.Rows.Count > 0 Then
                        documentTypeId = Cast.ToInt32(dtDocumentTemplate.Rows(0).Item("document_type_id"), 0)
                    End If

                End Using

            End If

        End Using

        If documentTypeId = 0 Then
            samErrorCollection.AddInvalidData(Cast.ToInt32(SAMErrorCodes.FailedToRetrieveDocumentTemplateDetails, 0), SAMErrorCodes.FailedToRetrieveDocumentTemplateDetails.ToString, "DocumentTemplateCode", getStandardWordingTemplateRequest.DocumentTemplateCode)
            samErrorCollection.CheckForErrors()
        End If

        Dim documentDirectory As String = String.Empty

        Dim iRet As Integer = SAMFunc.GetPMRegSetting(v_lPMERegSettingRoot:=PMERegSettingRoot.pmeRSRLocalMachine,
               v_lPMEProductFamily:=PMEProductFamily.pmePFSiriusSolutions,
               v_lPMERegSettingLevel:=PMERegSettingLevel.pmeRSLClient,
               v_sSettingName:="DocServer",
               r_sSettingValue:=documentDirectory)

        'Get the original template file details
        Dim clauseDocTemplateDirectory As String = documentDirectory & "\Type " & documentTypeId
        Dim originalDocTemplateFile As String = clauseDocTemplateDirectory & "\Doc " & getStandardWordingTemplateRequest.DocumentTemplateKey & ".zip"

        Dim bSIRDocTemplate As New bSIRDocTemplate.Business

        InitialiseSBOObject(oObject:=bSIRDocTemplate, siriusUser:=_SiriusUser, sObjectName:="bSIRPolicyNumMaint.Business")

        Dim tempZipFolder As String = clauseDocTemplateDirectory & "\" & System.IO.Path.GetRandomFileName
        Dim unzippedFileName As String = tempZipFolder & "\Doc " & getStandardWordingTemplateRequest.DocumentTemplateKey & ".zip"

        Directory.CreateDirectory(tempZipFolder)


        Dim sSourceFileName As String = tempZipFolder & "\Doc " & getStandardWordingTemplateRequest.DocumentTemplateKey & ".xml"

        ' Unzip the new file
        iRet = UnZip(originalDocTemplateFile, tempZipFolder, False)
        If getStandardWordingTemplateRequest.IsTXTextControlEnabled Then
            ConvertDocumentUsingSiriusDocumentUtility(sSourceFileName, sSourceFileName.Replace(".xml", ".docx"))
            iRet = CInt(bSIRDocTemplate.ZipDocument(unzippedFileName, "docx"))
        Else

            If getStandardWordingTemplateRequest.DocumentTemplateFormatSpecified AndAlso CStr(getStandardWordingTemplateRequest.DocumentTemplateFormat) <> "" AndAlso (getStandardWordingTemplateRequest.DocumentTemplateFormat = DocumentFormatType.HTML Or getStandardWordingTemplateRequest.DocumentTemplateFormat = DocumentFormatType.PDF) Then
                iRet = CInt(bSIRDocTemplate.ConvertFormatType(tempZipFolder & "\Doc " & getStandardWordingTemplateRequest.DocumentTemplateKey & ".xml", getStandardWordingTemplateRequest.DocumentTemplateFormat.ToString.Trim))
                iRet = CInt(bSIRDocTemplate.ZipDocument(unzippedFileName, getStandardWordingTemplateRequest.DocumentTemplateFormat.ToString.Trim))
            Else
                ' Zip up the new doc again
                iRet = CInt(bSIRDocTemplate.ZipDocument(unzippedFileName, "xml"))
            End If
        End If

        Dim btByteArray() As Byte

        ' Try to read in the Spooled Zip file into a Filestream
        Try

            Using fsInputFile As FileStream = File.OpenRead(unzippedFileName)

                ReDim btByteArray(CInt(fsInputFile.Length) - 1)

                fsInputFile.Read(btByteArray, 0, CInt(fsInputFile.Length) - 1)
            End Using
        Catch Ex As Exception
            Ex = New Exception("Failed to Read SpooledFilePath : " + unzippedFileName, Ex)
            ExceptionManager.Publish(Ex)
            Throw Ex
        Finally
            bSIRDocTemplate.Dispose()
            bSIRDocTemplate = Nothing
        End Try

        ' Delete the temp folder
        Directory.Delete(tempZipFolder, True)

        getStandardWordingTemplateResponse.DocumentTemplate = btByteArray
        getStandardWordingTemplateResponse.MergedFilePath = tempZipFolder

        Return getStandardWordingTemplateResponse

    End Function

    ''' <summary>
    ''' Update Standard Wording Template
    ''' </summary>
    ''' <param name="updateStandardWordingTemplateRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function UpdateStandardWordingTemplate(ByVal updateStandardWordingTemplateRequest As BaseUpdateStandardWordingTemplateRequestType) As BaseUpdateStandardWordingTemplateResponseType

        Dim updateStandardWordingTemplateResponse As New BaseUpdateStandardWordingTemplateResponseType
        Dim samErrorCollection As New SAMErrorCollection
        Dim oCoreBusiness As New CoreBusiness
        Dim documentTypeId As Integer = 0
        Dim documentTemplateId As Integer = 0
        Dim newDocumentTemplateId As Integer = 0
        Dim newDocumentTemplateCode As String = String.Empty
        Dim bsirDocTemplate As New bSIRDocTemplate.Business
        Dim sDocumentTemplateDescription As String = String.Empty
        Dim nTypeOfPackage As enumTypeOfPackage

        If updateStandardWordingTemplateRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateStandardWordingTemplateRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            updateStandardWordingTemplateResponse = New SAMForInsuranceV2ImplementationTypes.UpdateStandardWordingTemplateResponseType
        End If

        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        updateStandardWordingTemplateRequest.Validate(CObj(samErrorCollection))
        samErrorCollection.CheckForErrors()


        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                           _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID, SiriusUserDefaults.AppName)

            InitialiseSBOObject(Con:=con, oObject:=bsirDocTemplate, SiriusUser:=_SiriusUser, sObjectName:="bSIRDocTemplate.Business")

            Dim isCopied As Boolean

            If updateStandardWordingTemplateRequest.DocumentTemplateKey = 0 Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_document_template_saa")

                    cmd.AddInParameter("@code", SqlDbType.Char, 10).Value = updateStandardWordingTemplateRequest.DocumentTemplateCode
                    cmd.AddOutParameter("@document_template_id", SqlDbType.Int)
                    cmd.AddOutParameter("@document_type_id", SqlDbType.Int)
                    cmd.AddOutParameter("@description", SqlDbType.Char, 255)
                    'cmd.AddOutParameter("@effective_date", SqlDbType.DateTime)

                    Dim returnval As Integer = con.ExecuteNonQuery(cmd)

                    documentTemplateId = Cast.ToInt32(cmd.Parameters("@document_template_id").Value, 0)
                    documentTypeId = Cast.ToInt32(cmd.Parameters("@document_type_id").Value, 0)
                    sDocumentTemplateDescription = Cast.ToString(cmd.Parameters("@description").Value, String.Empty)
                End Using

                updateStandardWordingTemplateRequest.DocumentTemplateKey = documentTemplateId

                If documentTemplateId = 0 Then
                    samErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "DocumentTemplateCode", updateStandardWordingTemplateRequest.DocumentTemplateCode)
                End If

                '' exit if there are any missing parameters
                samErrorCollection.CheckForErrors()

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_document_template_sel")

                    cmd.AddInParameter("@document_template_id", SqlDbType.Int).Value = updateStandardWordingTemplateRequest.DocumentTemplateKey

                    Dim dtDocumentTemplate As DataTable = con.ExecuteDataTable(cmd)

                    If dtDocumentTemplate IsNot Nothing AndAlso dtDocumentTemplate.Rows.Count > 0 Then
                        documentTypeId = Cast.ToInt32(dtDocumentTemplate.Rows(0).Item("document_type_id"), 0)
                        isCopied = Cast.ToBoolean(dtDocumentTemplate.Rows(0).Item("copy_of_original"), False)
                    End If

                End Using

            Else

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_document_template_sel")

                    cmd.AddInParameter("@document_template_id", SqlDbType.Int).Value = updateStandardWordingTemplateRequest.DocumentTemplateKey

                    Dim dtDocumentTemplate As DataTable = con.ExecuteDataTable(cmd)

                    If dtDocumentTemplate IsNot Nothing AndAlso dtDocumentTemplate.Rows.Count > 0 Then
                        documentTypeId = Cast.ToInt32(dtDocumentTemplate.Rows(0).Item("document_type_id"), 0)
                        isCopied = Cast.ToBoolean(dtDocumentTemplate.Rows(0).Item("copy_of_original"), False)
                    End If

                End Using

            End If

            If documentTypeId = 0 Then
                samErrorCollection.AddInvalidData(Cast.ToInt32(SAMErrorCodes.FailedToRetrieveDocumentTemplateDetails, 0), SAMErrorCodes.FailedToRetrieveDocumentTemplateDetails.ToString, "DocumentTemplateCode", updateStandardWordingTemplateRequest.DocumentTemplateCode)
                samErrorCollection.CheckForErrors()
            End If

            Dim ret As Integer = bsirDocTemplate.DuplicateDocument(
                                                    lDocumentTemplateId:=updateStandardWordingTemplateRequest.DocumentTemplateKey,
                                                    r_lNewDocumentTemplateID:=newDocumentTemplateId, v_bCalledFromDocumentTemplate:=True)

            If ret <> PMEReturnCode.PMTrue AndAlso ret <> PMEReturnCode.PMNotFound Then
                RaiseComMethodException("bsirDocTemplate.Business.DuplicateDocument Failed to Copy - " & updateStandardWordingTemplateRequest.DocumentTemplateCode, ret)
            End If

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_document_template_sel")

                cmd.AddInParameter("@document_template_id", SqlDbType.Int).Value = newDocumentTemplateId

                Dim dtDocumentTemplate As DataTable = con.ExecuteDataTable(cmd)

                If dtDocumentTemplate IsNot Nothing AndAlso dtDocumentTemplate.Rows.Count > 0 Then
                    newDocumentTemplateCode = Cast.ToString(dtDocumentTemplate.Rows(0).Item("code"), String.Empty)
                Else
                    samErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "DocumentTemplateID not found", newDocumentTemplateId.ToString)
                    samErrorCollection.CheckForErrors()
                End If

            End Using
        End Using

        Dim documentDirectory As String = String.Empty

        Dim iRet As Integer = SAMFunc.GetPMRegSetting(v_lPMERegSettingRoot:=PMERegSettingRoot.pmeRSRLocalMachine,
               v_lPMEProductFamily:=PMEProductFamily.pmePFSiriusSolutions,
               v_lPMERegSettingLevel:=PMERegSettingLevel.pmeRSLClient,
               v_sSettingName:="DocServer",
               r_sSettingValue:=documentDirectory)

        'Get the original template file details
        Dim clauseDocTemplateDirectory As String = documentDirectory & "\Type " & documentTypeId
        Dim originalDocTemplateFile As String = clauseDocTemplateDirectory & "\Doc " & updateStandardWordingTemplateRequest.DocumentTemplateKey & ".zip"
        Dim newDocTemplateFile As String = clauseDocTemplateDirectory & "\Doc " & newDocumentTemplateId & ".zip"
        Dim tempZipFolder As String = clauseDocTemplateDirectory & "\" & System.IO.Path.GetRandomFileName
        Dim newHTMLTemplateFile As String = clauseDocTemplateDirectory & "\Doc " & newDocumentTemplateId & ".xml"
        Dim originalHTMLDocTemplateFile As String = tempZipFolder & "\Doc " & updateStandardWordingTemplateRequest.DocumentTemplateKey & ".xml"

        ' Write out the file passed in by the calling app
        Using fsInputFile As New FileStream(newDocTemplateFile, FileMode.Create)
            fsInputFile.Write(updateStandardWordingTemplateRequest.DocumentTemplate, 0, updateStandardWordingTemplateRequest.DocumentTemplate.Length)
            fsInputFile.Close()
        End Using
        Directory.CreateDirectory(tempZipFolder)

        ' Unzip the new file
        iRet = CInt(bsirDocTemplate.UnZipDocument(newDocTemplateFile, tempZipFolder, True))
        Dim sFileName As String = tempZipFolder & "\Doc " & updateStandardWordingTemplateRequest.DocumentTemplateKey & ".docx"

        If updateStandardWordingTemplateRequest.IsTXTextControlEnabled Then
            ConvertDocumentUsingSiriusDocumentUtility(sFileName, sFileName.Replace(".docx", ".xml"))
        Else

            If updateStandardWordingTemplateRequest.DocumentTemplateFormatSpecified AndAlso CStr(updateStandardWordingTemplateRequest.DocumentTemplateFormat) <> "" AndAlso (updateStandardWordingTemplateRequest.DocumentTemplateFormat = DocumentFormatType.HTML Or updateStandardWordingTemplateRequest.DocumentTemplateFormat = DocumentFormatType.PDF) Then
                If updateStandardWordingTemplateRequest.DocumentTemplateFormat = DocumentFormatType.HTML Then
                    iRet = CInt(bsirDocTemplate.ConvertFormatType(tempZipFolder & "\Doc " & updateStandardWordingTemplateRequest.DocumentTemplateKey & "." & updateStandardWordingTemplateRequest.DocumentTemplateFormat.ToString.Trim, "xml", True))
                Else
                    iRet = CInt(bsirDocTemplate.ConvertFormatType(tempZipFolder & "\Doc " & updateStandardWordingTemplateRequest.DocumentTemplateKey & "." & updateStandardWordingTemplateRequest.DocumentTemplateFormat.ToString.Trim, "xml"))
                End If
            End If
        End If

        ' Rename the HTM file to the new Template ID
        File.Copy(originalHTMLDocTemplateFile, newHTMLTemplateFile, True)

        ' Zip up the new doc again
        iRet = Zip(newDocTemplateFile.Replace(".xml", ".zip"), "xml")

        ' Delete the temp folder
        Directory.Delete(tempZipFolder, True)

        updateStandardWordingTemplateResponse.NewDocumentTemplateCode = newDocumentTemplateCode
        updateStandardWordingTemplateResponse.NewDocumentTemplateKey = newDocumentTemplateId
        'updateStandardWordingTemplateResponse.NewDocumentTemplateDescription = sDocumentTemplateDescription
        bsirDocTemplate.Dispose()
        bsirDocTemplate = Nothing
        Return updateStandardWordingTemplateResponse

    End Function

