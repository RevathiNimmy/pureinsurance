    ''' ''' <summary>
    '''This method will execute the functionality
    '''</summary>
    '''<remarks></remarks> 
    Public Overloads Function UpdateTaxes(ByVal con As SiriusConnection, ByVal oUpdateTaxesRequest As BaseUpdateTaxesRequestType) As BaseUpdateTaxesResponseType

        Dim oUpdateTaxesResponse As New BaseUpdateTaxesResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oUpdateTaxesRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateTaxesRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oUpdateTaxesResponse = New SAMForInsuranceV2ImplementationTypes.UpdateTaxesResponseType
        End If

        ' Check mandatory fields ...
        If String.IsNullOrEmpty(oUpdateTaxesRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If



        Dim row As BaseUpdateTaxesRequestTypeRow
        For Each row In oUpdateTaxesRequest.Row
            If Not row.TaxCalculationKey >= 1 Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                            SAMInvalidData.MandatoryInputMissing.ToString,
                                            "TaxCalculationKey")
            End If
        Next
        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        For Each row In oUpdateTaxesRequest.Row

            If row.IsEdited Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Tax_Update")
                    'add all the parameters to update
                    cmd.Parameters.Clear()
                    cmd.AddInParameter("@tax_calculation_cnt", SqlDbType.Int).Value = row.TaxCalculationKey
                    cmd.AddInParameter("@IsValue", SqlDbType.TinyInt).Value = Convert.ToByte(row.IsValue)
                    cmd.AddInParameter("@TaxPercentage", SqlDbType.Float).Value = Convert.ToDecimal(row.TaxPercentage)
                    cmd.AddInParameter("@TaxValue", SqlDbType.Decimal).Value = Convert.ToDecimal(row.TaxValue)

                    con.ExecuteNonQuery(cmd)
                End Using
            End If
        Next


        Return oUpdateTaxesResponse

    End Function
