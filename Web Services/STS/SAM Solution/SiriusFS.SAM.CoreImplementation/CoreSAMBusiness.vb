            oResponse = ExecutePRERuleset(con, ExecutePRERulesetRequest)

            Return oResponse

        End Using

    End Function

    Public Overloads Function ExecutePRERuleset(ByVal con As SiriusConnection, ByVal ExecutePRERulesetRequest As BaseExecutePRERulesetRequestType) As BaseExecutePRERulesetResponseType

        Dim oResponse As BaseExecutePRERulesetResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim sDataModelCode As String = String.Empty
        Dim vAdditionalDataArray() As AdditionalData
        Dim vQEMDREAdditionalDataArray(,) As Object
        Dim lType As Int32
        Dim branchCode As String = String.Empty
        Dim sXMLDataset As String = String.Empty
        Dim sUserName As String = ""
        Const ACMethodName As String = "ExecutePRERuleset"

        Dim STSError As New STSErrorPublisher

        Dim oSaveToDBRequest As New SaveToDBIn
        Dim oSaveToDBResponse As SaveToDBOut

        If ExecutePRERulesetRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ExecutePRERulesetRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.ExecutePRERulesetResponseType
            Dim oSamForInsuranceV2Request As SAMForInsuranceV2ImplementationTypes.ExecutePRERulesetRequestType = DirectCast(ExecutePRERulesetRequest, SAMForInsuranceV2ImplementationTypes.ExecutePRERulesetRequestType)
            sUserName = oSamForInsuranceV2Request.UserName
            'Richard Clarke 19/12/2017 - removed all the other checks here as they're not really necessary surely?
            'if they are then will need to add them back in and update all the other ImplementationTypes to contain all the base types
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        'Check Mandatory Fields
        If SAMFunc.NothingToString(ExecutePRERulesetRequest.XMLDataSet) = "" Then
            ' XMLDataSet not set
            STSError.AddInvalidField("XMLDataSet", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "XMLDataSet"), "")
        End If

        If ExecutePRERulesetRequest.BranchCode = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        Else
            branchCode = ExecutePRERulesetRequest.BranchCode
        End If

        If ExecutePRERulesetRequest.InsuranceFileKey = 0 Then
            STSError.AddInvalidField("InsuranceFileKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "InsuranceFileKey"), "")
        End If

        If ExecutePRERulesetRequest.InsuranceFolderKey = 0 Then
            STSError.AddInvalidField("InsuranceFolderKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "InsuranceFolderKey"), "")
        End If

        If ExecutePRERulesetRequest.ScreenCode = "" Then
            STSError.AddInvalidField("ScreenCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "ScreenCode"), "")
        End If

        If ExecutePRERulesetRequest.RiskKey = 0 Then
            STSError.AddInvalidField("RiskKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "RiskKey"), "")
        End If

        If ExecutePRERulesetRequest.QuoteTimeStamp Is Nothing Then
            STSError.AddInvalidField("QuoteTimeStamp", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "QuoteTimeStamp"), "")
        End If

        If ExecutePRERulesetRequest.RiskDescription = "" Then
            STSError.AddInvalidField("RiskDescription", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "RiskDescription"), "")
        End If

        ' default to new business if not provided
        If String.IsNullOrEmpty(ExecutePRERulesetRequest.TransactionType) Then
            ExecutePRERulesetRequest.TransactionType = TransactionTypeCode.NewBusiness
        End If

        ' transactionType - pmproduct lookup
        Dim transactionTypeID As Integer = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.TransactionType, ExecutePRERulesetRequest.TransactionType, "TransactionType")

        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return oResponse
        End If

        ' Check that the timestamp matches and lock the Quote
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.CheckTSAndLock(con,
            BranchCode:=ExecutePRERulesetRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=ExecutePRERulesetRequest.InsuranceFolderKey,
            TStamp:=ExecutePRERulesetRequest.QuoteTimeStamp)
        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oResponse.STSError = AnyError
            Return oResponse
        End If

        ' Get the Data Model Code
        Dim xmlDoc As New System.Xml.XmlDocument
        xmlDoc.LoadXml(ExecutePRERulesetRequest.XMLDataSet)
        sDataModelCode = xmlDoc.SelectSingleNode("DATA_SET").Attributes("DataModelCode").Value
        ' Set up Underwriting additional data
        ReDim vAdditionalDataArray(2)
        Dim oData As AdditionalData
        oData = New AdditionalData
        oData.Name = InternalSAMConstants.CNInsuranceFileCnt
        oData.Value = ExecutePRERulesetRequest.InsuranceFileKey
        vAdditionalDataArray(0) = oData
        oData = New AdditionalData
        oData.Name = InternalSAMConstants.CNInsuranceFolderCnt
        oData.Value = ExecutePRERulesetRequest.InsuranceFolderKey
        vAdditionalDataArray(1) = oData
        oData = New AdditionalData
        oData.Name = InternalSAMConstants.CNCurrentRiskCnt
        oData.Value = ExecutePRERulesetRequest.RiskKey
        vAdditionalDataArray(2) = oData

        sXMLDataset = ExecutePRERulesetRequest.XMLDataSet

        ReDim vQEMDREAdditionalDataArray(0, 2)
        'need to set up the three additional values for the assembly name and the bRunPrePRE and bRunPostPRE rules
        vQEMDREAdditionalDataArray(0, 0) = ExecutePRERulesetRequest.PRERuleAssemblyName
        vQEMDREAdditionalDataArray(0, 1) = ExecutePRERulesetRequest.RunPrePRERule
        vQEMDREAdditionalDataArray(0, 2) = ExecutePRERulesetRequest.RunPostPRERule

        'unfortunately we need to call SaveToDB to fix the addresses in the dataset
        oSaveToDBRequest.BusinessTypeCode = "NB"
        oSaveToDBRequest.DataModelCode = sDataModelCode
        oSaveToDBRequest.XMLDataset = sXMLDataset
        oSaveToDBResponse = oCoreBusiness.SaveToDB(con, oSaveToDBRequest)

        Dim oQuoteOut As NBQuoteOut = Nothing
        Dim oQuoteIn As New NBQuoteIn

        With oQuoteIn
            .DataModelCode = sDataModelCode
            .XMLDataset = ExecutePRERulesetRequest.XMLDataSet
            .AdditionalDataArray = vAdditionalDataArray
            .EffectiveDate = ExecutePRERulesetRequest.CoverStartDate
            .XMLDataset = oSaveToDBResponse.XMLDataset
        End With

        ' Clear all previous quote output
        ClearRiskOutput(sDataModelCode, oQuoteIn.XMLDataset)

        'Call to PRE
        Try
            oQuoteOut = oCoreBusiness.RunPRERuleset(con, oQuoteIn, QuoteTypeRules.Quote, branchCode, ExecutePRERulesetRequest.TransactionType, transactionTypeID, vQEMDREAdditionalDataArray, vAdditionalDataArray)
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to run PRE Ruleset.", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "ExecutePRERulset", True)
        End Try

        With oResponse
            .XMLDataSet = oQuoteOut.XMLDataset
        End With

        ' Unlock and return the new timestamp
        AnyError = oCoreBusiness.UnlockAndGetTS(con,
            BranchCode:=ExecutePRERulesetRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=ExecutePRERulesetRequest.InsuranceFolderKey,
            TStamp:=oResponse.QuoteTimeStamp)

        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Unable to unlock, return the error.
            'oResponse.STSError = AnyError
            'Return oResponse
        End If

        Return oResponse

    End Function
#End Region

#Region "Masterclient Associations"

    ''' <summary>  
    ''' This Function is used to add the starting and opening Element For ClientAssociated string
    ''' </summary>  
    ''' <param name="r_sXmlElementData">String</param>  
    Public Function AddExtraXMLElementForPolicyAssociate(ByRef r_dsPolicyAssociates As DataSet,
                                                         ByVal sDatasetColumnname As String) As Integer
        Dim nReturn As Integer = PMReturnCode.PMTrue
        Dim sOpeningElement As String = String.Empty
        Dim sClosingElement As String = String.Empty

        If Trim(sDatasetColumnname) = "" Then
            Return PMReturnCode.PMFalse
        End If

        If r_dsPolicyAssociates Is Nothing Then
            Return PMReturnCode.PMFalse
        End If
        sOpeningElement = "<Associates>" & Microsoft.VisualBasic.vbCrLf
        sClosingElement = Microsoft.VisualBasic.vbCrLf & "</Associates>"
        For iCount As Integer = 0 To r_dsPolicyAssociates.Tables(0).Rows.Count - 1

            If IsDBNull(r_dsPolicyAssociates.Tables(0).Rows(iCount)(sDatasetColumnname)) = False AndAlso
                           Not r_dsPolicyAssociates.Tables(0).Rows(iCount)(sDatasetColumnname) Is Nothing _
                          AndAlso Trim(CStr(r_dsPolicyAssociates.Tables(0).Rows(iCount)(sDatasetColumnname))) <> "" Then

                r_dsPolicyAssociates.Tables(0).Rows(iCount)(sDatasetColumnname) = Trim(sOpeningElement) &
                Trim(CStr(r_dsPolicyAssociates.Tables(0).Rows(iCount)(sDatasetColumnname))) & Trim(sClosingElement)

            End If
        Next
        Return nReturn
    End Function

