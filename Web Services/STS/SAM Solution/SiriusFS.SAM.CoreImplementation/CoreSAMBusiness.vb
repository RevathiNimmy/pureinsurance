    Private Function GetcontactTypeID(ByVal contactTypeCode As ContactTypeType, Optional ByVal OtherContactTypeCode As String = "") As Integer
        'Get Contact Type Id for a Contact Type Code using LookUp
        Dim contactTypeID As Integer
        Dim oCorebusiness As New CoreBusiness
        Select Case contactTypeCode
            Case ContactTypeType.EMAIL

                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "E-MAIL")
            Case ContactTypeType.HOMEPHONE
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "HOMEPHONE")
            Case ContactTypeType.WORKPHONE
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "WORKPHONE")
            Case ContactTypeType.MOBILE
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "MOBILE")
            Case ContactTypeType.FAX
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "FAX")
            Case ContactTypeType.WEB
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "WEB")
            Case ContactTypeType.MAIN
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "MAIN")
            Case ContactTypeType.TELEPHONE
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "TELEPHONE")
            Case ContactTypeType.OTHER
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "OTHER")
            Case ContactTypeType.LETTER
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "LETTER")
            Case ContactTypeType.MAINEMAILCONTACT
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", "MEMAIL")
            Case Else
                contactTypeID = oCorebusiness.GetListItemFromCode(Core.STSListType.PMLookup, "contact_type", Trim(OtherContactTypeCode.ToString))
        End Select
        Return contactTypeID
    End Function

    Private Overloads Function GetRenewalStatus(ByVal con As SiriusConnection, ByVal request As BaseGetRenewalStatusRequestType) As BaseGetRenewalStatusResponseType

        Dim samErrors As SAMErrorCollection = New SAMErrorCollection
        ' validate the mandatory structure data
        request.Validate(CType(samErrors, Object))

        ' if there were any errors throw an exception
        samErrors.CheckForErrors()

        Dim response As New BaseImplementationTypes.BaseGetRenewalStatusResponseType
        Dim typeOfPackage As enumTypeOfPackage
        Dim renewalStatusData As DataTable = Nothing

        If request.GetType Is GetType(SAMForInsuranceImplementationTypes.GetRenewalStatusRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            response = New SAMForInsuranceImplementationTypes.GetRenewalStatusResponseType
        ElseIf request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetRenewalStatusRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            response = New SAMForInsuranceV2ImplementationTypes.GetRenewalStatusResponseType
        End If

        renewalStatusData = GetRenewalStatus(con, request.InsuranceFileKey)

        If renewalStatusData IsNot Nothing AndAlso renewalStatusData.Rows.Count > 0 Then
