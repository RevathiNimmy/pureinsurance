                If oRequest.WCFSecurityToken = "" Then
                    xmlDocRatingSections.LoadXml(dsResult.GetXml)
                    oResponse.ResultDataset = xmlDocRatingSections.DocumentElement()
                End If

                oResponse.ResultData = dsResult
            End If

        Catch ex As Exception
        End Try
        Return oResponse
    End Function

