    '''<param name="sFieldNameToValidate">Column Name which used to validate</param>
    '''<param name="sValueToValidate">This is Field value which is used to filter</param>

    Public Function GetAndValidateDescriptionById(
       ByVal sTableName As String,
       ByVal sTableKeyNameToReturn As String,
       ByVal sFieldNameToValidate As String,
       ByVal sValueToValidate As String) As String
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
