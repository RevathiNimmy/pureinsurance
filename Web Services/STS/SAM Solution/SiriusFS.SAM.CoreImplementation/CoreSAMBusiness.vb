    '''' <summary>
    '''' This is the private method which is used for Business validation.
    ''''<param name="oSAMErrorCollection" type="SAMErrorCollection"></param>   
    ''''<param name="oGetProductRiskOptionValueRequest" type="BaseProductRiskOptionValueRequestType"></param>
    ''''</summary>
    ''''<remarks></remarks>
    Private Sub ValidateProductRiskBusinessRule(ByVal oGetProductRiskOptionValueRequest As BaseProductRiskOptionValueRequestType,
            ByRef oSAMErrorCollection As SAMErrorCollection)
        If oGetProductRiskOptionValueRequest.ProducRiskOptionSpecified = False And oGetProductRiskOptionValueRequest.RiskTypeOptionSpecified = False Then
            oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                 SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                 "Either of the ProducRiskOption  or RiskTypeOption should be supplied")

        ElseIf oGetProductRiskOptionValueRequest.ProducRiskOptionSpecified = True And oGetProductRiskOptionValueRequest.RiskTypeOptionSpecified = True Then

            oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                   SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                   "Both the ProducRiskOption and RiskTypeOption cant be supplied")
        ElseIf oGetProductRiskOptionValueRequest.ProducRiskOptionSpecified = True And oGetProductRiskOptionValueRequest.RiskTypeOptionSpecified = False Then
            If String.IsNullOrEmpty(oGetProductRiskOptionValueRequest.ProductCode) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                              SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                              "Product code should be supplied")
            End If

        ElseIf oGetProductRiskOptionValueRequest.ProducRiskOptionSpecified = False And oGetProductRiskOptionValueRequest.RiskTypeOptionSpecified = True Then
            If String.IsNullOrEmpty(oGetProductRiskOptionValueRequest.RiskTypeCode) Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                              SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                              "RiskType code should be supplied")
            End If
        End If
    End Sub

