    ''' <summary>  
    '''  This method is used to update bank guarantee.
    ''' </summary>  
    ''' <param name="con">An object of type Sirius.Architecture.Data.SiriusConnection</param>  
    ''' <param name="oBGItem">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseBankGuaranteeItemType</param>  
    ''' <param name="oSAMErrorCollection">An object of type Sirius.Architecture.ExceptionHandling.SAMErrorCollection</param>  
    ''' <returns />
    Private Sub UpdateBankGuaranteeItem(ByVal con As SiriusConnection, ByVal oBGItem As BaseBankGuaranteeItemType,
                                        ByVal oSAMErrorCollection As SAMErrorCollection)
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_PartyBG_Details_upd")
            With oBGItem
                cmd.AddInParameter("@BG_id", SqlDbType.Int).Value = .BGKey
                cmd.AddInParameter("@bank_name_id", SqlDbType.Int).Value = .BankNameKey
                cmd.AddInParameter("@bank_branch", SqlDbType.VarChar, 50).Value = .BankBranch
                cmd.AddInParameter("@BG_currency_id", SqlDbType.Int).Value = .BGCurrencyKey
                cmd.AddInParameter("@BG_ref", SqlDbType.VarChar, 50).Value = .BankGuaranteeRef
                cmd.AddInParameter("@BG_limit", SqlDbType.Decimal, 20, 2).Value = .BGLimit
                cmd.AddInParameter("@available_bal", SqlDbType.Decimal, 20, 2).Value = .LimitAvailable
                cmd.AddInParameter("@custody_branch_id", SqlDbType.Int).Value = .CustodyBranchKey
                cmd.AddInParameter("@expiry_date", SqlDbType.DateTime).Value = .ExpiryDate
                cmd.AddInParameter("@issue_date", SqlDbType.DateTime).Value = .IssueDate
                If (.IsPolicyLock) Then
                    cmd.AddInParameter("@is_policy_lock", SqlDbType.TinyInt).Value = 1
                Else
                    cmd.AddInParameter("@is_policy_lock", SqlDbType.TinyInt).Value = 0
                End If
                con.ExecuteNonQuery(cmd)
            End With
        End Using
    End Sub

