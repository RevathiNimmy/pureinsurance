                        Using oCmd As SiriusCommand = SiriusCommand.FromProcedure("spu_PFPremiumFinance_Sel_Latest_Valid_Plan_2")
                            oCmd.AddInParameter("@insurancefilecnt", SqlDbType.Int).Value = Cast.ToInt32(.InsuranceFileKey)
                            oCmd.AddInParameter("@paymentMethod", SqlDbType.Int).Value = Cast.ToInt16(1)
                            dsPaymentMethod = connection.ExecuteDataSet(cmd, "Row")
                        End Using
                    End Using

                    If dsPaymentMethod.Tables(0).Rows.Count > 0 Then
                        If Not String.IsNullOrEmpty(Cast.ToString(dsPaymentMethod.Tables(0).Rows(0).Item("payment_method"), String.Empty)) Then
                            sPaymentMethodCode = Cast.ToString(dsPaymentMethod.Tables(0).Rows(0).Item("payment_method"), String.Empty)
                        End If
                    End If

                    Dim dsDefaultPaymentTerms As DataSet = Nothing
                    Using connection As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
                        Using cmd3 As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Default_Payment_Terms")
                            cmd3.AddInParameter("@nInsuranceFileCnt", SqlDbType.Int).Value = GetHeaderAndSummariesByKeyRequest.InsuranceFileKey
                            dsDefaultPaymentTerms = connection.ExecuteDataSet(cmd3, "dsDefaultPaymentTerms")
                        End Using
                    End Using

                    If dsDefaultPaymentTerms IsNot Nothing AndAlso dsDefaultPaymentTerms.Tables(0).Rows.Count > 0 Then
                        Dim dr As DataRow = dsDefaultPaymentTerms.Tables(0).Rows(0)
                        .DefaultPaymentMethod = dr.Item("DefaultPaymentMethod").ToString
                        .DefaultInstalmentPlan = Cast.ToInt32(dr.Item("DefaultInstalmentPlan"), 0)
                        .DefaultInstalmentPlanVersion = Cast.ToInt32(dr.Item("DefaultInstalmentPlanVersion"), 0)
                        .DefaultSchemeNumber = Cast.ToInt32(dr.Item("DefaultSchemeNumber"), 0)
                        .DefaultSchemeVersion = Cast.ToInt32(dr.Item("DefaultSchemeVersion"), 0)
                        .SavedPreferredDate = Cast.ToDateTime(dr.Item("SavedPreferredDate"), Date.MinValue)
                        .SavedDayInMonth = Cast.ToInt32(dr.Item("SavedDayInMonth"), 0)
                        'sPaymentMethodCode = dsDefaultPaymentTerms.Tables(0).Rows(0).Item("DefaultPaymentMethod").ToString

                        .Frequency = dr.Item("Frequency").ToString
                    Else
                        .DefaultPaymentMethod = String.Empty
                        .DefaultInstalmentPlan = 0
                        .DefaultInstalmentPlanVersion = 0
                        .DefaultSchemeNumber = 0
                        .DefaultSchemeVersion = 0
                        .DefaultPFRF_ID = 0
                    End If
                    .SenderEmail = Cast.ToString(dsPaymentMethod.Tables(0).Rows(0).Item("Sender_Email"), String.Empty)
                    .ReceiverEmail = Cast.ToString(dsPaymentMethod.Tables(0).Rows(0).Item("Receiver_Email"), String.Empty)

                End With
            End If
        End Using

        Dim dsCoverNoteDetails As DataSet
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Cover_Note_Sheet_By_Policy")
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.ToInt32(GetHeaderAndSummariesByKeyRequest.InsuranceFileKey, 0)
            dsCoverNoteDetails = con.ExecuteDataSet(cmd, "dsCoverNoteDetails")
            If dsCoverNoteDetails IsNot Nothing AndAlso dsCoverNoteDetails.Tables IsNot Nothing AndAlso dsCoverNoteDetails.Tables(0).Rows.Count > 0 Then

                With oResponse
                    .CoverNoteBookNumber = Cast.ToString(dsCoverNoteDetails.Tables(0).Rows(0).Item("Book_Number"), "")
                    .CoverNoteSheetNumber = Cast.ToInt32(dsCoverNoteDetails.Tables(0).Rows(0).Item("Cover_Sheet_Number"), 0)
                End With
            End If
        End Using

        ' Get the Timestamp
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.GetTimestamp(
            BranchCode:=GetHeaderAndSummariesByKeyRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=oResponse.InsuranceFolderKey,
            TStamp:=oResponse.QuoteTimeStamp,
                bCurrentlyLocked:=oResponse.QuoteIsLocked)
        ' Return AnyErrors
        If AnyError Is Nothing = False Then
            oResponse.STSError = AnyError
        End If
        Dim dsInsuredParties As New DataSet

        'Add An Exclusive Lock
        If GetHeaderAndSummariesByKeyRequest.ExclusiveLock Then
            AddExlusiveLock(con,
                            oCoreBusiness,
                            CoreBusiness.LockName.InsuranceFolderCnt,
                            oResponse.InsuranceFolderKey,
                            0, GetHeaderAndSummariesByKeyRequest.SessionValue,
                            _SiriusUser.UserID,
                                GetHeaderAndSummariesByKeyRequest.BranchCode)
        End If

        If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            Dim oResponseAgent As New AgentImplementationTypes.GetHeaderAndSummariesByKeyResponseType
            oResponseAgent = DirectCast(oResponse, AgentImplementationTypes.GetHeaderAndSummariesByKeyResponseType)
            oResponseAgent.InceptionDate = inceptionDate
            oResponseAgent.InsuranceFileVersion = iInsuranceFileVersion
            oResponseAgent.InsuranceFileTypeCode = sInsuranceFileTypeCode
            oResponseAgent.InsuranceFileStatusCode = sInsuranceFileStatusCode
            oResponseAgent.PaymentMethodCode = sPaymentMethodCode

            dsInsuredParties = GetInsuredParties(con, oResponse.PartyKey, oResponse.InsuranceFolderKey)
            If GetHeaderAndSummariesByKeyRequest.WCFSecurityToken = "" Then
                Dim xmlDoc As New System.Xml.XmlDocument
                xmlDoc.LoadXml(dsInsuredParties.GetXml)
                oResponseAgent.InsuredParties = xmlDoc.DocumentElement
            End If

            oResponseAgent.ResultDataInsuredParties = dsInsuredParties
            oResponse = oResponseAgent
        ElseIf nTypeOfPackage = enumTypeOfPackage.CustomersPackage Then
            Dim oResponseCust As New CustomerImplementationTypes.GetHeaderAndSummariesByKeyResponseType
            oResponseCust = DirectCast(oResponse, CustomerImplementationTypes.GetHeaderAndSummariesByKeyResponseType)
            oResponseCust.InceptionDate = inceptionDate
            oResponseCust.InsuranceFileVersion = iInsuranceFileVersion
            oResponseCust.InsuranceFileTypeCode = sInsuranceFileTypeCode
            oResponseCust.InsuranceFileStatusCode = sInsuranceFileStatusCode
            oResponseCust.PaymentMethodCode = sPaymentMethodCode

            dsInsuredParties = GetInsuredParties(con, oResponse.PartyKey, oResponse.InsuranceFolderKey)
            If GetHeaderAndSummariesByKeyRequest.WCFSecurityToken = "" Then
                Dim xmlDoc As New System.Xml.XmlDocument
                xmlDoc.LoadXml(dsInsuredParties.GetXml)
                oResponseCust.InsuredParties = xmlDoc.DocumentElement
            End If
            oResponseCust.ResultDataInsuredParties = dsInsuredParties

            oResponse = oResponseCust

        ElseIf nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage Then

            Dim oResponseSFI As New SAMForInsuranceImplementationTypes.GetHeaderAndSummariesByKeyResponseType
            oResponseSFI = DirectCast(oResponse, SAMForInsuranceImplementationTypes.GetHeaderAndSummariesByKeyResponseType)
            oResponseSFI.InceptionDate = inceptionDate
            oResponseSFI.InsuranceFileVersion = iInsuranceFileVersion
            oResponseSFI.InsuranceFileTypeCode = sInsuranceFileTypeCode
            oResponseSFI.InsuranceFileStatusCode = sInsuranceFileStatusCode
            oResponseSFI.PaymentMethodCode = sPaymentMethodCode

            dsInsuredParties = GetInsuredParties(con, oResponse.PartyKey, oResponse.InsuranceFolderKey)
            If GetHeaderAndSummariesByKeyRequest.WCFSecurityToken = "" Then
                Dim xmlDoc As New System.Xml.XmlDocument
                xmlDoc.LoadXml(dsInsuredParties.GetXml)
                oResponseSFI.InsuredParties = xmlDoc.DocumentElement
            End If
            oResponseSFI.ResultDataInsuredParties = dsInsuredParties
            oResponse = oResponseSFI

        ElseIf nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package Then

            Dim oResponseSFI As New SAMForInsuranceV2ImplementationTypes.GetHeaderAndSummariesByKeyResponseType
            oResponseSFI = DirectCast(oResponse, SAMForInsuranceV2ImplementationTypes.GetHeaderAndSummariesByKeyResponseType)
            oResponseSFI.InceptionDate = inceptionDate
            oResponseSFI.InsuranceFileVersion = iInsuranceFileVersion
            oResponseSFI.InsuranceFileTypeCode = sInsuranceFileTypeCode
            oResponseSFI.InsuranceFileStatusCode = sInsuranceFileStatusCode
            oResponseSFI.PaymentMethodCode = sPaymentMethodCode

            dsInsuredParties = GetInsuredParties(con, oResponse.PartyKey, oResponse.InsuranceFolderKey)
            If GetHeaderAndSummariesByKeyRequest.WCFSecurityToken = "" Then
                Dim xmlDoc As New System.Xml.XmlDocument
                xmlDoc.LoadXml(dsInsuredParties.GetXml)
                oResponseSFI.InsuredParties = xmlDoc.DocumentElement
            End If
            oResponseSFI.ResultDataInsuredParties = dsInsuredParties
            oResponse = oResponseSFI

        End If

        oResponse.PolicyLevelTaxesAndFees = New BaseTaxesAndFeesType
        Dim policytax As Decimal = 0
        Dim policyfee As Decimal = 0

        GetPolicyTaxesAndFees(con, GetHeaderAndSummariesByKeyRequest.InsuranceFileKey, GetHeaderAndSummariesByKeyRequest.BranchCode, policytax, policyfee, oResponse.PolicyLevelTaxesAndFees)

        'Get Active Plan Count by calling the Direct SP And pass the insurance_cnt
        GetAttachedInstalmentPlans(con, GetHeaderAndSummariesByKeyRequest.InsuranceFileKey, oResponse)

        Return oResponse

    End Function
#Region "GetAttachedInstalmentPlan"
    '''<summary>
    '''this Method is being called from the GetheaderandSummaryByKey and evaluate the Activeplans against the policy.
    '''</summary>
    '''<param name="con">SiriusConnection</param>
    '''<param name="oGetAttachedInstalmentPlanStatusRequestType">BaseGetAttachedInstalmentPlanStatusRequestType</param>
    '''<param name="oInsuranceFileKey">Int</param>
    '''<remarks></remarks>
    Private Sub GetAttachedInstalmentPlans(ByVal con As SiriusConnection,
                                           ByVal oInsuranceFileKey As Integer,
                                           ByRef oBaseGetHeaderAndSummariesResponse As BaseGetHeaderAndSummariesResponseType)

        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim dtActivePlancnt As DataTable = Nothing
        Dim oPremiumFinanceBusiness As New bSIRPremiumFinance.Business
        Dim nComReturnValue As Integer = 0
        Dim oSinglePlanParty(,) As Object = Nothing


        SAMFunc.InitialiseSBOObject(oPremiumFinanceBusiness, _SiriusUser, oBaseGetHeaderAndSummariesResponse.BranchCode)

        nComReturnValue = oPremiumFinanceBusiness.IsSinglePlanAgent(nInsuranceFileCnt:=oInsuranceFileKey, r_oSinglePlanParty:=oSinglePlanParty)

        If nComReturnValue <> PMEReturnCode.PMTrue Then
            RaiseComMethodException("bSIRPremiumFinance.Business.IsSinglePlanAgent", nComReturnValue)
        End If

        If (Not oSinglePlanParty Is Nothing) Then
            nComReturnValue = ToSafeInteger(oSinglePlanParty(0, 0))
        End If

        If nComReturnValue = 1 Then
            Try

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_finance_plan_on_status")
                    cmd.AddInParameter("@Insurance_file_cnt", SqlDbType.Int).Value = Nothing
                    cmd.AddInParameter("@sStatus", SqlDbType.VarChar).Value = "040"    'Live=Item040,OnHold=Item140
                    cmd.AddInParameter("@nInsurance_folder_cnt", SqlDbType.Int).Value = oBaseGetHeaderAndSummariesResponse.InsuranceFolderKey
                    dtActivePlancnt = con.ExecuteDataTable(cmd)

                    If Not dtActivePlancnt Is Nothing AndAlso dtActivePlancnt.Rows.Count > 0 Then
                        oBaseGetHeaderAndSummariesResponse.ActivePlans = dtActivePlancnt.Rows.Count
                    End If
                End Using


                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_finance_plan_on_status")
                    cmd.AddInParameter("@Insurance_file_cnt", SqlDbType.Int).Value = Nothing
                    cmd.AddInParameter("@sStatus", SqlDbType.VarChar).Value = "140"    'OnHold=Item140
                    cmd.AddInParameter("@nInsurance_folder_cnt", SqlDbType.Int).Value = oBaseGetHeaderAndSummariesResponse.InsuranceFolderKey
                    dtActivePlancnt = con.ExecuteDataTable(cmd)

                    If Not dtActivePlancnt Is Nothing AndAlso dtActivePlancnt.Rows.Count > 0 Then
                        oBaseGetHeaderAndSummariesResponse.ActivePlans = CInt(oBaseGetHeaderAndSummariesResponse.ActivePlans) + dtActivePlancnt.Rows.Count
                    End If
                End Using


            Catch ex As Exception
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.CollectionDateError,
                          SAMBusinessErrors.CollectionDateError.ToString,
                         "Failed to call Procedure spu_get_finance_plan_on_status ")
                oSAMErrorCollection.CheckForErrors()
            Finally
                oPremiumFinanceBusiness = Nothing
            End Try
        End If

    End Sub
#End Region


    Public Overloads Function GetHeaderAndSummariesByRef(ByVal GetHeaderAndSummariesByRefRequest As BaseGetHeaderAndSummariesByRefRequestType) As BaseGetHeaderAndSummariesResponseType
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Dim oResponse As BaseGetHeaderAndSummariesResponseType

            oResponse = GetHeaderAndSummariesByRef(con, GetHeaderAndSummariesByRefRequest)

            Return oResponse

        End Using

    End Function

    Public Overloads Function GetHeaderAndSummariesByRef(ByVal con As SiriusConnection, ByVal GetHeaderAndSummariesByRefRequest As BaseGetHeaderAndSummariesByRefRequestType) As BaseGetHeaderAndSummariesResponseType

        Const ACMethodName As String = "GetHeaderAndSummariesByRef"

        Dim oResponse As BaseGetHeaderAndSummariesResponseType
        Dim nTypeOfPackage As enumTypeOfPackage

        Dim iRet As System.Int32
        'Dim Utils As Utilities
        Dim oResultArray As Object = Nothing
        Dim sCoverStartDate As String = String.Empty
        Dim sCoverEndDate As String = String.Empty
        Dim sInceptionDate As String = String.Empty
        Dim oAdditionalData() As AdditionalData = Nothing
        Dim sQuoteExpiryDate As String = String.Empty
        Dim sSubBranchCode As String = String.Empty
        Dim oInsuredParties As Object = Nothing
        'Dim lQuoteIsLocked As Int32

        Dim iInsuranceFileVersion As Int32 = 0
        Dim sInsuranceFileTypeCode As String = String.Empty
        Dim sInsuranceFileStatusCode As String = String.Empty
        Dim sPaymentMethodCode As String = String.Empty
        Dim sCurrencyCode As String = String.Empty
        Dim samForBrokingRequest As SAMForBrokingImplementationTypes.GetHeaderAndSummariesByRefRequestType = Nothing

        Dim STSError As New STSErrorPublisher

        If GetHeaderAndSummariesByRefRequest.GetType Is GetType(AgentImplementationTypes.GetHeaderAndSummariesByRefRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AgentsPackage
            oResponse = New AgentImplementationTypes.GetHeaderAndSummariesByRefResponseType
        ElseIf GetHeaderAndSummariesByRefRequest.GetType Is GetType(BaseImplementationTypes.BaseGetHeaderAndSummariesByRefRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            oResponse = New BaseImplementationTypes.BaseGetHeaderAndSummariesResponseType
        ElseIf GetHeaderAndSummariesByRefRequest.GetType Is GetType(CustomerImplementationTypes.GetHeaderAndSummariesByRefRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.CustomersPackage
            oResponse = New CustomerImplementationTypes.GetHeaderAndSummariesByRefResponseType
        ElseIf GetHeaderAndSummariesByRefRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetHeaderAndSummariesByRefRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GetHeaderAndSummariesByRefResponseType
        ElseIf GetHeaderAndSummariesByRefRequest.GetType Is GetType(SAMForBrokingImplementationTypes.GetHeaderAndSummariesByRefRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oResponse = New SAMForBrokingImplementationTypes.GetHeaderAndSummariesByRefResponseType
            samForBrokingRequest = DirectCast(GetHeaderAndSummariesByRefRequest, SAMForBrokingImplementationTypes.GetHeaderAndSummariesByRefRequestType)
        ElseIf GetHeaderAndSummariesByRefRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetHeaderAndSummariesByRefRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetHeaderAndSummariesByRefResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        If GetHeaderAndSummariesByRefRequest.BranchCode = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        End If

        If GetHeaderAndSummariesByRefRequest.InsuranceRef = "" Then
            STSError.AddInvalidField("InsuranceRef", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "InsuranceRef"), "")
        End If

        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Input Validation", True)
            Return oResponse
        End If

        Dim iSourceID As Int32
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        iSourceID% = 1
        ' Convert branch code to ID
        Try
            iSourceID% = oCoreBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "Source", GetHeaderAndSummariesByRefRequest.BranchCode)
        Catch ex As Exception
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.BranchCodeInvalid), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "BranchCode"), GetHeaderAndSummariesByRefRequest.BranchCode)
        End Try

        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Input Validation", True)
            Return oResponse
        End If

        ' Check the insurance Ref is valid
        If oCoreBusiness.CheckInsuranceFileRef(Trim(GetHeaderAndSummariesByRefRequest.InsuranceRef), iSourceID) = False Then
            STSError = New STSErrorPublisher(STSErrorCodes.PolicyRecordNotFound, "Insurance File validation failed", "The Insurance File record does not exist for Ref: " & GetHeaderAndSummariesByRefRequest.InsuranceRef)
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
            Return oResponse
        End If

        If nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            If CoreBusiness.PartyIsAgent(samForBrokingRequest.UserPartyType) Then
                If oCoreBusiness.CheckAgentKey(samForBrokingRequest.UserPartyKey) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.AgentRecordNotFound, "Agent Key validation failed", "The Agent record does not exist for key: " & samForBrokingRequest.UserPartyKey)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Key Validation", True)
                    Return oResponse
                End If

                If oCoreBusiness.AgentSecurityCheck(samForBrokingRequest.UserName, iSourceID%, PMEEntityType.Source) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security Check Failed", samForBrokingRequest.UserName & " does not have permission to access source " & iSourceID%)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetHeaderAndSummariesByRef", True)
                    Return oResponse
                End If
            End If
        End If

        Dim oGIS As bGIS.STS = Nothing
        Try
            oGIS = New bGIS.STS
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bGIS.STS", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "bGISSTS", True)
            Return oResponse
        End Try

        ' Initialise the GIS
        Try
            SAMFunc.InitialiseGISSTS(oGIS, _SiriusUser, GetHeaderAndSummariesByRefRequest.BranchCode)
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to intialise bGIS.STS", ex.Message)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "InitGIS", True)
        End Try

        ' Dimension the Array
        Dim vAdditionalData As Object = Nothing

        ' Add the CalledFromSTS value
        Try
            Utilities.AddCallFromSTS(oAdditionalData)
        Catch oe As Exception
            ' End the recording
            Dim STSErrorEx As New STSErrorPublisher("An error occured calling Utilities.AddCallFromSTS", oe)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "AddCallFromSTS", True)
        End Try

        ' Move the Data from the Classes to the Array
        vAdditionalData = Utilities.ClassesToArray(oAdditionalData)

        ' Call the Method
        Try

            With oResponse

                ' Initialise the parameters
                sSubBranchCode = ""
                sCoverStartDate = ""
                sCoverEndDate = ""
                sInceptionDate = ""
                sQuoteExpiryDate = ""

                If .InsuranceFileRef Is Nothing Then
                    .InsuranceFileRef = String.Empty
                End If

                If .Description Is Nothing Then
                    .Description = String.Empty
                End If

                If .ProductCode Is Nothing Then
                    .ProductCode = String.Empty
                End If

                iRet = oGIS.GetHeaderAndSummariesByRef(
                                v_sInsuranceFileRef:=CType(GetHeaderAndSummariesByRefRequest.InsuranceRef, String),
                                r_lPartyCnt:= .PartyKey,
                                r_sEffectiveDate:=sCoverStartDate,
                                r_sExpirationDate:=sCoverEndDate,
                                r_sInceptionDate:=sInceptionDate,
                                r_sDescription:= .Description,
                                r_sProductCode:= .ProductCode,
                                r_lInsuranceFolderCnt:= .InsuranceFolderKey,
                                r_lInsuranceFileCnt:= .InsuranceFileKey,
                                r_sInsuranceFileRef:= .InsuranceFileRef,
                                r_lInsuranceFileVer:=iInsuranceFileVersion,
                                r_vResultDataset:=oResultArray,
                                r_vAdditionalDataArray:=vAdditionalData,
                                r_sQuoteExpiryDate:=sQuoteExpiryDate,
                                r_sSubBranchCode:=sSubBranchCode,
                                r_vInsuredParties:=oInsuredParties,
                                r_sInsuranceFileTypeCode:=sInsuranceFileTypeCode,
                                r_sInsuranceFileStatusCode:=sInsuranceFileStatusCode,
                                r_sPaymentMethodCode:=sPaymentMethodCode,
                                r_sCurrencyCode:=sCurrencyCode,
                                r_blConsLeadAgntComm:= .ConsolidatedLeadAgentCommission,
                                r_blConsSubAgntComm:= .ConsolidatedSubAgentCommission,
                                r_blContactuserKey:= .ContactuserKey,
                                r_bPutOnNextMTAInstalmentRenewal:= .PutOnNextMTAInstallmentRenewal,
                                r_bAnniversaryCopy:= .AnniversaryCopy,
                                r_lRenewalDayNumber:= .RenewalDayNo,
                                r_bReferredAtRenewal:= .ReferredAtRenewal)

                If iRet = PMEReturnCode.PMNotFound Then

                    Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.QuoteHeaderRecordNotFound, "Quote header record not found", GetHeaderAndSummariesByRefRequest.InsuranceRef)
                    STSErrorEX.SetContext(.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Quote header record not found", True)

                    ' Terminate the reference to the GIS
                    If oGIS IsNot Nothing Then
                        oGIS.Dispose()
                        oGIS = Nothing
                    End If

                    Return oResponse

                ElseIf (iRet = PMEReturnCode.PMBusinessRuleError) Then
                    STSError.AddInvalidField("InsuranceRef", CStr(STSErrorCodes.RecordNotFound), "bSIRFindInsurance.FindQuote returned multiple records when only one was expected.", .InsuranceFileRef)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Input Validation", True)
                    Return oResponse
                ElseIf (iRet <> PMEReturnCode.PMTrue) Then
                    ' End the recording
                    Dim STSErrorEX As New STSErrorPublisher(iRet, "bGIS.STS.GetHeaderAndSummariesByRef failed")
                    STSErrorEX.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GISGetHeaderAndSummariesByKey", True)
                End If

                Dim renewalStatusData As DataTable = Nothing
                renewalStatusData = GetRenewalStatus(con, .InsuranceFileKey)
                If renewalStatusData IsNot Nothing AndAlso renewalStatusData.Rows.Count > 0 Then
                    .RenewalStatusTypeCode = RTrim(Cast.ToString(renewalStatusData.Rows(0)("renewal_status_type_code"), String.Empty))
                    .RenewalStatusTypeDescription = RTrim(Cast.ToString(renewalStatusData.Rows(0)("renewal_status_type_description"), String.Empty))
                End If
                ' Populate required output params
                .SubBranchCode = sSubBranchCode
                .CoverStartDate = CType(sCoverStartDate, Date)
                .CoverEndDate = CType(sCoverEndDate, Date)

                If sQuoteExpiryDate <> "" Then
                    .QuoteExpiryDate = CType(sQuoteExpiryDate, Date)
                End If

                .CurrencyCode = sCurrencyCode

                If nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage Or nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package Then
                    Dim insuranceFileDetails As InsuranceFileDetailsType = New InsuranceFileDetailsType(oResponse.InsuranceFileKey)
                    .AlternativeRef = insuranceFileDetails.AlternativeReference
                End If
                'WPR73-74
                If Cast.ToInt32(.ContactuserKey) > 0 Then
                    Dim dsAgentUsers As DataSet = Nothing
                    Using connection As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_User_Details")
                            cmd.AddInParameter("@UserID", SqlDbType.Int).Value = Cast.ToInt32(.ContactuserKey)
                            dsAgentUsers = connection.ExecuteDataSet(cmd, "Row")
                        End Using
                    End Using

                    If dsAgentUsers.Tables(0).Rows.Count > 0 Then
                        .ContactuserKey = Cast.ToInt32(dsAgentUsers.Tables(0).Rows(0).Item("UserId"), 0)
                        .ContactUserName = Cast.ToString(dsAgentUsers.Tables(0).Rows(0).Item("Username"), String.Empty)
                        .ContactUserEmail = Cast.ToString(dsAgentUsers.Tables(0).Rows(0).Item("EmailAddress"), String.Empty)
                        If String.IsNullOrEmpty(Cast.ToString(dsAgentUsers.Tables(0).Rows(0).Item("FullUsername"), String.Empty)) Then
                            .ContactUserFullName = Cast.ToString(dsAgentUsers.Tables(0).Rows(0).Item("Username"), String.Empty)
                        Else
                            .ContactUserFullName = Cast.ToString(dsAgentUsers.Tables(0).Rows(0).Item("FullUsername"), String.Empty)
                        End If
                        If Cast.ToInt32(dsAgentUsers.Tables(0).Rows(0).Item("IsDeleted")) = 1 Then
                            .IsDeletedContactuser = 1
                        Else
                            .IsDeletedContactuser = 0
                        End If
                    End If
                End If
            End With

        Catch ex As Exception

            ' Terminate the reference to the GIS
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If

            Dim STSErrorEx As New STSErrorPublisher("An error occured calling bGIS.STS.GetHeaderAndSummariesByKey", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetHeaderAndSummariesByKey", True)

        End Try

        Try
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
