                System.IO.File.Move(sTempReportPath, r_sOutputFilename)

            End If

            'Start - Prakash Varghese - PN71492
            'According to Simpy, who raised PN71492, every document should be compressed to zip format 
            'before sending it back in the response
            iReturn = m_oBusinessDocAPI.ZipReport(v_sFileName:=Cast.ToString(IIf(oGetReportRequest.FormatType = DocumentFormatType.HTML Or oGetReportRequest.FormatType = DocumentFormatType.PDF Or oGetReportRequest.FormatType = DocumentFormatType.EXCEL, sTempReportPath, r_sOutputFilename)),
                                                  r_sOutputFilePath:=sCompressedFileName,
                                                  v_bExcludeDirectories:=True)

            If iReturn <> PMEReturnCode.PMTrue Then
                RaiseComMethodException("bSIRDOCAPI.Form.ZipDocument Failed", iReturn)
            End If

            Using fsInputFile As FileStream = File.OpenRead(sCompressedFileName)

                ReDim btCompressedArray(CInt(fsInputFile.Length))

                fsInputFile.Read(btCompressedArray, 0, CInt(fsInputFile.Length))

                If Not fsInputFile Is Nothing Then
                    fsInputFile.Close()
                End If

                oGetReportResponse.ReportDocument = btCompressedArray
            End Using

        Catch ex As Exception
            Throw
        Finally

            If m_oBusinessReportPrint IsNot Nothing Then
                m_oBusinessReportPrint.Dispose()
                m_oBusinessReportPrint = Nothing
            End If
            If m_oBusinessDocAPI IsNot Nothing Then
                m_oBusinessDocAPI.Dispose()
                m_oBusinessDocAPI = Nothing
            End If
        End Try

        Return oGetReportResponse

    End Function
