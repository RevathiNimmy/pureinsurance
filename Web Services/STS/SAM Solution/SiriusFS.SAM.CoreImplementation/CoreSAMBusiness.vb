    Friend Function GetSourceId(ByVal sBranchCode As String) As Integer

        Dim JournalBranchId As Integer
        Dim GetListOutput As Core.GetListOutput
        GetListOutput = New STSCoreStruct.GetListOutput

        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using Cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_User_Source_Details")
                GetListOutput.ListItems = con.ExecuteDataSet(Cmd, "UserSourceDetails")
            End Using
        End Using

        Dim ds As DataSet = Nothing

        ds = GetListOutput.ListItems

        ' for each table ( there will be only one )
        For Each dt As DataTable In ds.Tables
            ' for each row 
            For Each dr As DataRow In dt.Rows

                ' attempt to find the branch we are looking for
                If Cast.ToStringTrim(dr.Item("code")).ToUpper = sBranchCode.ToUpper Then

                    ' get the source id and 
                    JournalBranchId = Cast.ToInt32(dr.Item("source_id"), 0)

                    Exit For
                End If
            Next
        Next
        Return JournalBranchId
    End Function


