    Public Function GetList(ByVal GetListEffectiveInput As BaseGetListRequestType) As BaseGetListResponseType

        Dim oBusiness As New CoreBusiness
        Dim Utils As New Utilities
        Dim oOutput As New BaseImplementationTypes.BaseGetListResponseType
        Dim STSError As New STSErrorPublisher
        Const ACMethodName As String = "GetList"

        Dim oGetListInput As New Core.GetListInput
        Dim oGetListOutput As Core.GetListOutput = Nothing

        Dim nTypeOfPackage As enumTypeOfPackage
        Dim samForBrokingRequest As SAMForBrokingImplementationTypes.GetListRequestType = Nothing

        If GetListEffectiveInput.GetType Is GetType(AnonymousImplementationTypes.GetListRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AnonymousPackage
            oOutput = New AnonymousImplementationTypes.GetListResponseType
        ElseIf GetListEffectiveInput.GetType Is GetType(AgentImplementationTypes.GetListRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AgentsPackage
            oOutput = New AgentImplementationTypes.GetListResponseType
        ElseIf GetListEffectiveInput.GetType Is GetType(BaseImplementationTypes.BaseGetListRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            oOutput = New BaseImplementationTypes.BaseGetListResponseType
        ElseIf GetListEffectiveInput.GetType Is GetType(CustomerImplementationTypes.GetListRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.CustomersPackage
            oOutput = New CustomerImplementationTypes.GetListResponseType
        ElseIf GetListEffectiveInput.GetType Is GetType(SAMForInsuranceImplementationTypes.GetListRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oOutput = New SAMForInsuranceImplementationTypes.GetListResponseType
        ElseIf GetListEffectiveInput.GetType Is GetType(SAMForBrokingImplementationTypes.GetListRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oOutput = New SAMForBrokingImplementationTypes.GetListResponseType
            samForBrokingRequest = DirectCast(GetListEffectiveInput, SAMForBrokingImplementationTypes.GetListRequestType)
        ElseIf GetListEffectiveInput.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetListRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oOutput = New SAMForInsuranceV2ImplementationTypes.GetListResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        If GetListEffectiveInput.BranchCode = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        End If

        If GetListEffectiveInput.ListCode = "" Then
            STSError.AddInvalidField("ListCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "ListCode"), "")
        End If

        ' TODO can we test this??? is 0 not a valid value???
        If GetListEffectiveInput.ListType = 0 Then
            STSError.AddInvalidField("ListType", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "ListType"), "")
        End If

        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oOutput.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return oOutput
        End If

        ' Validate Branch Code
        Dim iSourceId As Integer
        Try
            iSourceId = oBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "Source", GetListEffectiveInput.BranchCode)
        Catch ex As Exception
            ' not set
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.BranchCodeInvalid), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "BranchCode"), GetListEffectiveInput.BranchCode)
        End Try

        ' Check for any errors
        If STSError.HasErrors Then
            ' Set the context
            STSError.SetContext(oOutput.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Input Validation", True)
            ' Return the errors
            Return oOutput
        End If

        If nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            If CoreBusiness.PartyIsAgent(samForBrokingRequest.UserPartyType) Then
                If oBusiness.CheckAgentKey(samForBrokingRequest.UserPartyKey) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.AgentRecordNotFound, "Agent Key validation failed", "The Agent record does not exist for key: " & samForBrokingRequest.UserPartyKey)
                    STSError.SetContext(oOutput.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Key Validation", True)
                    Return oOutput
                End If

                If oBusiness.AgentSecurityCheck(samForBrokingRequest.UserName, iSourceId, PMEEntityType.Source) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security Check Failed", samForBrokingRequest.UserName & " does not have permission to access source " & iSourceId)
                    STSError.SetContext(oOutput.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetList", True)
                    Return oOutput
                End If
            End If
        End If

        oGetListInput.BranchCode = GetListEffectiveInput.BranchCode
        oGetListInput.ListCode = GetListEffectiveInput.ListCode
        Select Case GetListEffectiveInput.ListType
            Case STSListType.Missing
                oGetListInput.ListType = Core.STSListType.Missing
            Case STSListType.GisList
                oGetListInput.ListType = Core.STSListType.GisList
            Case STSListType.PMLookup
                oGetListInput.ListType = Core.STSListType.PMLookup
            Case STSListType.UserDefinedTable
                oGetListInput.ListType = Core.STSListType.UserDefinedTable
        End Select


        oGetListInput.ExcludeDeletedRecords = GetListEffectiveInput.ExcludeDeletedRecords
        oGetListInput.ExcludeEffectiveDate = GetListEffectiveInput.ExcludeEffectiveDate
        oGetListInput.ParentFieldName = GetListEffectiveInput.ParentFieldName
        If (GetListEffectiveInput.ParentFieldValueSpecified = True) Then
            oGetListInput.ParentFieldValue = GetListEffectiveInput.ParentFieldValue

        Else
            oGetListInput.ParentFieldValue = Nothing

        End If

        'If GetListEffectiveInput.Version > 0 Then
        oGetListInput.Version = GetListEffectiveInput.Version
        oGetListInput.EffectiveDate = GetListEffectiveInput.EffectiveDate
        'End If

        'Get the value of the Where Clause from the GetListEffectiveInput
        oGetListInput.valWhereClause = GetListEffectiveInput.WhereClause


        Select Case GetListEffectiveInput.FilterType
            Case GetListFilterType.Missing
                oGetListInput.FilterType = Core.GetListFilterType.Missing
            Case GetListFilterType.Description
                oGetListInput.FilterType = Core.GetListFilterType.Description
            Case GetListFilterType.Code
                oGetListInput.FilterType = Core.GetListFilterType.Code
            Case GetListFilterType.Id
                oGetListInput.FilterType = Core.GetListFilterType.Id
        End Select
        oGetListInput.FilterValue = GetListEffectiveInput.FilterValue

        Try
            ' Do not need to cache the List when called from the WEB Service as the consumer,
            ' (the web tier) will be caching it at their end, so they won't be making multiple calls to this method.
            oGetListOutput = oBusiness.GetList(oGetListInput, False)
        Catch ex As ApplicationException
            Dim STSErrorEx As New STSErrorPublisher("Failed to Get ListItems.", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetList", True)
        End Try

        If (oOutput.STSError Is Nothing) = False Then
            ' GetList failed to run.
            Return oOutput
        End If

        If oGetListOutput.ListItems Is Nothing Then
            STSError.AddInvalidField("ListCode", CStr(STSErrorCodes.InvalidLookupListValue), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "ListCode"), "")
            STSError.SetContext(oOutput.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return oOutput
        End If

        ' Name the dataset, table and columns
        oGetListOutput.ListItems.DataSetName = "BaseGetListResponseTypeList"
        oGetListOutput.ListItems.Tables(0).TableName = "Row"
        oGetListOutput.ListItems.Tables(0).Columns(0).ColumnName = "Key"
        oGetListOutput.ListItems.Tables(0).Columns(1).ColumnName = "Description"
        oGetListOutput.ListItems.Tables(0).Columns(2).ColumnName = "Code"
        oGetListOutput.ListItems.Tables(0).Columns(3).ColumnName = "EffectiveDate"
        oGetListOutput.ListItems.Tables(0).Columns(4).ColumnName = "IsDeleted"
        oGetListOutput.ListItems.Tables(0).Columns(5).ColumnName = "ParentKey"

        Dim dsOutput As New DataSet
        If GetListEffectiveInput.WCFSecurityToken <> "" Then
            dsOutput = oGetListOutput.ListItems
            If Not String.IsNullOrEmpty(oGetListInput.FilterValue) Then
                Dim DV As DataView


                DV = dsOutput.Tables(0).DefaultView
                Dim sFilterQuery As String

                Select Case oGetListInput.FilterType
                    Case Core.GetListFilterType.Description
                        sFilterQuery = "Description='" _
                                      & oGetListInput.FilterValue & "'"
                    Case Core.GetListFilterType.Code
                        sFilterQuery = "Code='" _
                                      & oGetListInput.FilterValue & "'"
                    Case Core.GetListFilterType.Id
                        sFilterQuery = "Key='" _
                                      & oGetListInput.FilterValue & "'"
                End Select

                DV.RowFilter = sFilterQuery

                dsOutput = New DataSet
                dsOutput.Tables.Add(DV.ToTable)

            End If
            oOutput.ResultData = dsOutput
        Else


            Dim oListItems As New System.Xml.XmlDocument
            Dim strData As String = String.Empty

            Try
                strData = oGetListOutput.ListItems.GetXml
                oListItems.LoadXml(strData)
            Catch ex As Exception
                Dim STSErrorEx As New STSErrorPublisher("Failed to retrieve XML.", ex)
                STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetList", True)
            End Try



            If Not String.IsNullOrEmpty(oGetListInput.FilterValue) Then
                Dim sXPathQuery As String

                Select Case oGetListInput.FilterType
                    Case Core.GetListFilterType.Description
                        sXPathQuery = "/BaseGetListResponseTypeList/Row[Description='" _
                                      & oGetListInput.FilterValue & "']"
                    Case Core.GetListFilterType.Code
                        sXPathQuery = "/BaseGetListResponseTypeList/Row[Code='" _
                                      & oGetListInput.FilterValue & "']"
                    Case Core.GetListFilterType.Id
                        sXPathQuery = "/BaseGetListResponseTypeList/Row[Key='" _
                                      & oGetListInput.FilterValue & "']"
                End Select
                Dim oSearchList As XmlNodeList
                oSearchList = oListItems.SelectNodes(sXPathQuery)

                Dim oCollectionNode As XmlNode
                oCollectionNode = oListItems.SelectSingleNode("/BaseGetListResponseTypeList")
                oCollectionNode.RemoveAll()
                For Each xnode As XmlNode In oSearchList
                    oCollectionNode.AppendChild(xnode)
                Next
            End If
            Try
                oOutput.ListItems = oListItems.DocumentElement()

            Catch ex As Exception
                Dim STSErrorEx As New STSErrorPublisher("Failed to convert XML To ListItems.", ex)
                STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetList", True)
            End Try
        End If
        If oGetListInput.ListType = Core.STSListType.PMLookup Then
            Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=ConnectionString)
                Try
                    oOutput.AdditionalResult = GetTableStructureAndData(con, GetListEffectiveInput.ListCode, GetListEffectiveInput.EffectiveDate, GetListEffectiveInput.WhereClause)
                Catch ex As Exception
                    oOutput.AdditionalResult = Nothing
                End Try
            End Using
        End If

        If oGetListOutput.ListItems Is Nothing Then
            STSError.AddInvalidField("ListCode", CStr(STSErrorCodes.InvalidLookupListValue), "MandatoryInputInvalid ListCode", oGetListInput.ListCode)
            STSError.SetContext(oOutput.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Lookup field validation", True)
            Return oOutput
        ElseIf oGetListOutput.ListItems.Tables.Count = 0 Then
            STSError.AddInvalidField("ListCode", CStr(STSErrorCodes.InvalidLookupListValue), "MandatoryInputInvalid ListCode", oGetListInput.ListCode)
            STSError.SetContext(oOutput.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Lookup field validation", True)
            Return oOutput
        ElseIf oGetListOutput.ListItems.Tables(0).Rows.Count = 0 Then
            'STSError.AddInvalidField("ListCode", CStr(STSErrorCodes.InvalidLookupListValue), "MandatoryInputInvalid ListCode", oGetListInput.ListCode)
            'STSError.SetContext(oOutput.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Lookup field validation", True)
            'Return oOutput
