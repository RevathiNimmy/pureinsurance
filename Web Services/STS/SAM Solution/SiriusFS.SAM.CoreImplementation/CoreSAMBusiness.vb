    ''' <param name="con">An object of type SiriusConnection</param>  
    Public Overloads Function CloseCase(ByRef con As SiriusConnection,
    ByVal oRequest As BaseCloseCaseRequestType) As BaseCloseCaseResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseCloseCaseResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim STSError As STSErrorPublisher = Nothing

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.CloseCaseRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.CloseCaseResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        '*******************
        ' STRUCTURE VALIDATION
        '*******************
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' DATA VALIDATION
        '*******************

        If CInt(oRequest.CaseKey) = 0 Or CInt(oRequest.BaseCaseKey) = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                                     SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                                     "CaseKey/BaseCaseKey")
            oSAMErrorCollection.CheckForErrors()
        End If

        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        Else
            oRequest.SourceId = 1
        End If

        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        Else
            oRequest.SourceId = 1
        End If

        ValidateCaseNumberAndID(con, oRequest.CaseKey, oRequest.BaseCaseKey)
        If oRequest.CaseKey = 0 AndAlso oRequest.BaseCaseKey = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMBusinessErrors.InfoOnlyClaim, SAMBusinessErrors.InvalidCase.ToString, "Case Key or Base Case Key is invalid")
            oSAMErrorCollection.CheckForErrors()
        End If
        Try
            Dim dsGetCase As DataSet
            Dim bCanCloseCase As Boolean = True
            Dim iCount As Integer
            Dim oOpenClaims() As String
            Dim iCountOpenClaims As Integer = 0
            Dim sErrorString As String = String.Empty
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Case_Claim_link")
                cmd.AddInParameter("@basecaseid", SqlDbType.Int).Value = oRequest.BaseCaseKey
                dsGetCase = con.ExecuteDataSet(cmd, "CaseDetails")
            End Using
            If dsGetCase Is Nothing = False Then
                If dsGetCase.Tables(0).Rows.Count > 0 Then
                    For iCount = 0 To dsGetCase.Tables(0).Rows.Count - 1
                        If CInt(dsGetCase.Tables(0).Rows(iCount).Item("claim_status_id").ToString) <> 3 AndAlso CInt(dsGetCase.Tables(0).Rows(iCount).Item("claim_status_id").ToString) <> 5 Then
                            bCanCloseCase = False
                            ReDim Preserve oOpenClaims(iCountOpenClaims)
                            oOpenClaims(iCountOpenClaims) = dsGetCase.Tables(0).Rows(iCount).Item("claim_number").ToString
                            iCountOpenClaims = iCountOpenClaims + 1
                        End If
                    Next
                End If
            End If
            If bCanCloseCase Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Update_Case_Progress_Status")
                    cmd.AddInParameter("@case_id", SqlDbType.Int).Value = oRequest.CaseKey
                    con.ExecuteNonQuery(cmd)
                End Using
                CreateCaseEvent(con, oRequest.CaseKey, _SiriusUser.UserID, CStr(oRequest.EventDescription))
            Else
                sErrorString = "The following claims linked to this case are still open :-"
                For iCount = 0 To iCountOpenClaims - 1
                    sErrorString = sErrorString & CStr(oOpenClaims(iCount)) & ";"
                Next
                sErrorString = sErrorString & "This case cannot be closed yet"
                STSError = New STSErrorPublisher(STSErrorCodes.UnableToCloseTheCase, STSErrorCodes.UnableToCloseTheCase.ToString, sErrorString)
                STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), "SaveCase", "SaveCase", True)

            End If

        Catch ex As Exception
            Throw
        Finally

        End Try

        Return oResponse

    End Function

    Public Sub ValidateCaseNumberAndID(ByVal con As SiriusConnection, Optional ByRef iCaseKey As Integer = 0, Optional ByRef iBaseCaseKey As Integer = 0)

        If iCaseKey <> 0 Then
            If GetAndValidateDescriptionById(con, "[Case]", "Case_number", "case_id", iCaseKey.ToString) = "" Then
                iCaseKey = 0
            End If
        End If
        If iBaseCaseKey <> 0 Then
            If GetAndValidateDescriptionById(con, "[Case]", "Case_number", "case_id", iBaseCaseKey.ToString) = "" Then
                iBaseCaseKey = 0
            End If
        End If
    End Sub
