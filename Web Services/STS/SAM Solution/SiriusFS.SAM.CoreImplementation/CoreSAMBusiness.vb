    '''This method sends the request object values to the Stored Procedure and get the reponse object as DataSet
    '''</summary>
    '''<param name="oRequest" type="BaseGetRecoveryCoinsuranceRequestType"></param>
    '''<remarks></remarks>
    Public Function GetRecoveryCoinsurance(ByVal oRequest As BaseGetRecoveryCoinsuranceRequestType) As BaseGetRecoveryCoinsuranceResponseType

        Dim oResponse As New BaseImplementationTypes.BaseGetRecoveryCoinsuranceResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim sourceId As Integer
        Dim typeOfPackage As enumTypeOfPackage

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetRecoveryCoinsuranceRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetRecoveryCoinsuranceResponseType
        Else
            typeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Structure Validation

        oRequest.Validate(CObj(oSAMErrorCollection))
        oSAMErrorCollection.CheckForErrors()

        ' Lookup Codes to ensure they are valid
        If Not String.IsNullOrEmpty(oRequest.BranchCode) Then
            sourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        oSAMErrorCollection.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsFindCoinsuranceRecoveries As DataSet = Nothing
        Using conFindCoinsuranceRecoveries As SiriusConnection = SiriusConnection.FromAny(connectionString:=ConnectionString)
            Using cmdFindCoinsuranceRecoveries As SiriusCommand = SiriusCommand.FromProcedure("spu_claims_recovery_coins_select")

                cmdFindCoinsuranceRecoveries.AddInParameter("@peril_id", SqlDbType.Int).Value = oRequest.ClaimPerilKey

                cmdFindCoinsuranceRecoveries.AddInParameter("@is_salvage", SqlDbType.Int).Value = IIf(oRequest.IsSalvage, 1, 0)

                dsFindCoinsuranceRecoveries = conFindCoinsuranceRecoveries.ExecuteDataSet(cmdFindCoinsuranceRecoveries, "Row")

            End Using
        End Using

        dsFindCoinsuranceRecoveries.DataSetName = "BaseGetRecoveryCoinsuranceResponseTypeCoinsurances"
        Dim xmlDoc As New System.Xml.XmlDocument
        If oRequest.WCFSecurityToken = "" Then
            If (dsFindCoinsuranceRecoveries.Tables.Count >= 1) Then
                If (dsFindCoinsuranceRecoveries.Tables(0).Rows.Count >= 1) Then
                    xmlDoc.LoadXml(dsFindCoinsuranceRecoveries.GetXml)
                    oResponse.ResultDataset = xmlDoc.DocumentElement()
                End If
            End If
        End If

        If (dsFindCoinsuranceRecoveries.Tables.Count >= 1) Then
            If (dsFindCoinsuranceRecoveries.Tables(0).Rows.Count >= 1) Then
                oResponse.ResultData = dsFindCoinsuranceRecoveries
            End If
        End If
        Return oResponse

    End Function

