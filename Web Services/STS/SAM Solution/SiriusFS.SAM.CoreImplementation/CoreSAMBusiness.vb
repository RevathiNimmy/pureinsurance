            oResponse = New SAMForInsuranceV2ImplementationTypes.GetPolicyStatusForMediaTypeStatusResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        oRequest.Validate(CType(oSAMErrorCollection, Object))

        ' throw any structure related errors
        oSAMErrorCollection.CheckForErrors()

        If Not String.IsNullOrEmpty(oRequest.BranchCode) Then
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If
        oSAMErrorCollection.CheckForErrors()

        Dim dsPolicyStatus As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Get_Policy_Status_For_MediaType_Status_Maintenance")
            cmd.AddInParameter("@Insurance_File_Cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oRequest.InsuranceFileKey)
            cmd.AddOutParameter("@IsPolicyCancelled", SqlDbType.TinyInt)
            cmd.AddOutParameter("@IsClaimPaymentInitiated", SqlDbType.TinyInt)
            con.ExecuteNonQuery(cmd)
            oResponse.IsPolicyCanceled = Cast.ToInt32(cmd.Parameters.Item("@IsPolicyCancelled").Value, 0)
            oResponse.IsClaimPaymentInitiated = Cast.ToBoolean(cmd.Parameters.Item("@IsClaimPaymentInitiated").Value, False)
        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Check_Policy_Receipt_MediaType_Status")
            cmd.AddInParameter("@Insurance_File_Cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oRequest.InsuranceFileKey)
            cmd.AddOutParameter("@IsValid", SqlDbType.SmallInt)
            con.ExecuteNonQuery(cmd)
            oResponse.IsUnclearedCashListExists = Cast.ToBoolean(cmd.Parameters.Item("@IsValid").Value, False)
        End Using

        If oRequest.LossDateSpecified Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Check_Policy_Receipt_MediaType_Status")
                cmd.AddInParameter("@Insurance_File_Cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oRequest.InsuranceFileKey)
                cmd.AddInParameter("@Claim_Loss_Date", SqlDbType.DateTime).Value = Cast.NullIfDefault(oRequest.LossDate)
                cmd.AddOutParameter("@IsValid", SqlDbType.SmallInt)
                con.ExecuteNonQuery(cmd)
                oResponse.IsClaimPaymentInitiatedOnLossDate = Cast.ToBoolean(cmd.Parameters.Item("@IsValid").Value, False)
            End Using
        End If

        Return oResponse
    End Function

