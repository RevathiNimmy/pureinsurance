    Public Sub New(ByVal Username As String, ByVal sBranchCode As String)

        If Not String.IsNullOrEmpty(sBranchCode) Then

            Dim UserID As Integer = 0
            Dim LanguageID As Integer = 0
            Dim PartyCnt As Integer = 0
            Dim SAMErrorCollection As New SAMErrorCollection
            Dim _oCache As System.Web.Caching.Cache = HttpContext.Current.Cache()
            Dim sCacheKey As String = String.Empty
            Dim oIdentity As Dictionary(Of String, Integer)

            sCacheKey = "GetIdent" & Username
            ' Try to get the Full List from the Cache
            oIdentity = CType(_oCache(sCacheKey), Dictionary(Of String, Integer))
            If oIdentity Is Nothing Then


                ' validate the request structure against the specified business rules
                Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Check_PMUser_Details")

                        cmd.AddInParameter("@username", SqlDbType.NVarChar, 255).Value = Cast.NullIfDefault(Username)
                        cmd.AddOutParameter("@password", SqlDbType.NVarChar, 30)
                        cmd.AddOutParameter("@user_id", SqlDbType.SmallInt)
                        cmd.AddOutParameter("@language_id", SqlDbType.SmallInt)
                        cmd.AddOutParameter("@email_address", SqlDbType.NVarChar, 255)
                        cmd.AddOutParameter("@party_cnt", SqlDbType.Int)
                        cmd.AddOutParameter("@party_type_code", SqlDbType.NChar, 10)

                        Dim ds As DataSet = con.ExecuteDataSet(cmd, "UserDetails")

                        If IsDBNull(cmd.Parameters("@user_id").Value) Then
                            ' add an error to the SAMErrorCollection
                            SAMErrorCollection.AddInvalidData(
                                              SAMInvalidData.LoginFailureIncorrectUsername,
                                              SAMInvalidData.LoginFailureIncorrectUsername.ToString,
                                              "Username",
                                              Username)
                            SAMErrorCollection.CheckForErrors()
                        Else
                            UserID = Cast.ToInt32(cmd.Parameters("@user_id").Value, 0)
                            LanguageID = Cast.ToInt32(cmd.Parameters("@language_id").Value, 0)
                            PartyCnt = Cast.ToInt32(cmd.Parameters("@party_cnt").Value, 0)

                            oIdentity = New Dictionary(Of String, Integer)
                            oIdentity.Add("user_id", UserID)
                            oIdentity.Add("party_cnt", PartyCnt)
                            oIdentity.Add("language_id", LanguageID)

                            _oCache.Insert(sCacheKey, oIdentity)

                        End If

                    End Using

                End Using
            Else

                ' See if this key exists.
                If oIdentity.ContainsKey("user_id") Then
                    ' Write value of the key.
                    UserID = CInt(oIdentity.Item("user_id"))
                End If
                If oIdentity.ContainsKey("party_cnt") Then
                    ' Write value of the key.
                    PartyCnt = CInt(oIdentity.Item("party_cnt"))
                End If
                If oIdentity.ContainsKey("language_id") Then
                    ' Write value of the key.
                    LanguageID = CInt(oIdentity.Item("language_id"))
                End If
            End If

            _SiriusUser.EmailAddress = String.Empty
            _SiriusUser.LanguageID = CShort(LanguageID)
            _SiriusUser.PartyCnt = PartyCnt
            _SiriusUser.Password = String.Empty
            _SiriusUser.UserID = CShort(UserID)
            _SiriusUser.Username = Username

        End If

        If Not String.IsNullOrEmpty(sBranchCode) Then

            ' load currency and source from specified branch code
            GetSourceDetails(sBranchCode, CInt(_SiriusUser.SourceID), CInt(_SiriusUser.CurrencyID))

        End If

    End Sub


