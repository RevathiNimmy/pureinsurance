    Private Overloads Sub PopulatePolicySections(
    ByVal con As SiriusConnection,
    ByVal XMLDataSet As String,
    ByVal DataModelCode As String,
    ByRef PolicySectionsXml As String,
    ByRef PolicyCoinsurerSectionsXml As String,
    Optional ByVal PSrootElementName As String = "",
    Optional ByVal PSelementTypeName As String = "",
    Optional ByVal PCSrootElementName As String = "",
    Optional ByVal PCSelementTypeName As String = "")

        Dim oBusiness As New CoreBusiness

        Dim policySection As BasePolicySectionType
        Dim policyCoinsurerSection As BasePolicyCoinsurerSectionType

        Dim PolicyCoinsurerSections() As BasePolicyCoinsurerSectionType = Nothing
        Dim PolicySections() As BasePolicySectionType = Nothing

        Dim oDomDocRisk As New System.Xml.XmlDocument ' MSXML2.DOMDocument
        Dim oDomNodeRisk As System.Xml.XmlNode ' MSXML2.IXMLDOMNode
        Dim oDomNodeRiskList As System.Xml.XmlNodeList
        Dim sXpath As String = String.Empty

        Const ACMethodName As String = "PopulatePolicySections"

        Try
            oDomDocRisk.LoadXml(XMLDataSet)
        Catch ex As Exception
            ' Exception handling
        End Try

        sXpath = [String].Format("/DATA_SET/RISK_OBJECTS/{0}_POLICY_BINDER/{0}_OUTPUT/{0}_OUTPUT_SECTIONS", DataModelCode.ToUpper)

        oDomNodeRiskList = oDomDocRisk.SelectNodes(sXpath)

        If (oDomNodeRiskList Is Nothing) = False Then
            For Each oDomNodeRisk In oDomNodeRiskList
                policySection = New BasePolicySectionType
                Try
                    policySection.CommissionTax = Val(oDomNodeRisk.Attributes.GetNamedItem("COMMISSION_TAX").Value)
                Finally
                End Try
                Try
                    Dim commissionTaxGroupId As Int32 = 0
                    If Not IsNothing(oDomNodeRisk.Attributes.GetNamedItem("COMMISSION_TAX_GROUP_ID")) Then
                        commissionTaxGroupId = Cast.ToInt32(oDomNodeRisk.Attributes.GetNamedItem("COMMISSION_TAX_GROUP_ID").Value, 0)
                    End If
                    policySection.CommissionTaxGroupDescription = ""
                    'Get Tax Group Description from Id.
                    If commissionTaxGroupId <> 0 Then
                        oBusiness.GetListItemFromID(Core.STSListType.PMLookup,
                            "Tax_Group",
                            commissionTaxGroupId,
                           policySection.CommissionTaxGroupDescription)
                    End If
                Finally
                End Try
                Try
                    policySection.CommssionValue = Val(oDomNodeRisk.Attributes.GetNamedItem("COMMISSION_NET").Value)
                Finally
                End Try
                Try
                    policySection.PremiumExcTax = Val(oDomNodeRisk.Attributes.GetNamedItem("SECTION_PREMIUM_EXCLUDING_TAX").Value)
                Finally
                End Try
                Try
                    Dim sectionTaxGroupId As Int32 = 0
                    If Not IsNothing(oDomNodeRisk.Attributes.GetNamedItem("SECTION_TAX_GROUP_ID")) Then
                        sectionTaxGroupId = Cast.ToInt32(oDomNodeRisk.Attributes.GetNamedItem("SECTION_TAX_GROUP_ID").Value, 0)
                    End If
                    policySection.PremiumTaxGroupDescription = ""
                    'Get Tax Group Description from Id.
                    If sectionTaxGroupId <> 0 Then
                        oBusiness.GetListItemFromID(Core.STSListType.PMLookup,
                            "Tax_Group",
                            sectionTaxGroupId,
                           policySection.PremiumTaxGroupDescription)
                    End If
                Finally
                End Try
                Try
                    policySection.TaxValue = Val(oDomNodeRisk.Attributes.GetNamedItem("TAX_AMOUNT").Value)
                Finally
                End Try

                Dim ds As DataSet = Nothing
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_PMB_CobRatingSection_sel")
                    cmd.AddInParameter("@cob_rating_section_id", SqlDbType.Int).Value = CInt(oDomNodeRisk.Attributes.GetNamedItem("SECTION_COB_RATING_SECTION_ID").Value)
                    ds = con.ExecuteDataSet(cmd, "RatingSectionId")

                    If ds.Tables("RatingSectionId").Rows.Count > 0 Then
                        Try
                            policySection.SectionDescription = ds.Tables(0).Rows(0).Item(1).ToString
                        Catch ex As Exception
                            Dim STSErrorEx As New STSErrorPublisher("Failed to Get Cob Rating Section for Section.", ex)
                            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "PopulatePolicySections", True)
                        End Try
                    End If
                End Using

                'Add Another Node
                If IsArray(PolicySections) Then
                    ReDim Preserve PolicySections(PolicySections.GetUpperBound(1) + 1)
                Else
                    ReDim PolicySections(0)
                End If
                PolicySections(PolicySections.GetUpperBound(1)) = policySection

                Dim oDomNodeChildRiskList As System.Xml.XmlNodeList
                Dim oDomNodeChildRisk As System.Xml.XmlNode
                Dim sPath As String = String.Empty
                sPath = [String].Format("{0}_OUTPUT_SECTIONS_COINSURERS", DataModelCode.ToUpper)
                oDomNodeChildRiskList = oDomNodeRisk.SelectNodes(sPath)

                For Each oDomNodeChildRisk In oDomNodeChildRiskList

                    policyCoinsurerSection = New BasePolicyCoinsurerSectionType

                    Try
                        'Get Insurer Resolved Name from Party Cnt.
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Party_Details")
                            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = CInt(oDomNodeChildRisk.Attributes.GetNamedItem("PARTY_CNT").Value)
                            ds = con.ExecuteDataSet(cmd, "Party")

                            If ds.Tables("Party").Rows.Count > 0 Then
                                Try
                                    policyCoinsurerSection.InsurerName = ds.Tables(0).Rows(0).Item(1).ToString
                                Catch ex As Exception
                                    Dim STSErrorEx As New STSErrorPublisher("Failed to Get Insurer Name for Coinsurer Section.", ex)
                                    STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "PopulatePolicySections", True)
                                End Try
                            End If
                        End Using
                    Finally
                    End Try

                    Try
                        policyCoinsurerSection.CommissionTax = Val(oDomNodeChildRisk.Attributes.GetNamedItem("COMMISSION_TAX").Value)
                    Finally
                    End Try
                    Try
                        Dim commissionTaxGroupId As Int32 = 0
                        If Not IsNothing(oDomNodeRisk.Attributes.GetNamedItem("COMMISSION_TAX_GROUP_ID")) Then
                            commissionTaxGroupId = Cast.ToInt32(oDomNodeRisk.Attributes.GetNamedItem("COMMISSION_TAX_GROUP_ID").Value, 0)
                        End If
                        policySection.CommissionTaxGroupDescription = ""
                        'Get Tax Group Description from Id.
                        If commissionTaxGroupId <> 0 Then
                            oBusiness.GetListItemFromID(Core.STSListType.PMLookup,
                                "Tax_Group",
                                commissionTaxGroupId,
                               policySection.CommissionTaxGroupDescription)
                        End If
                    Finally
                    End Try

                    Try
                        policyCoinsurerSection.CommssionValue = Val(oDomNodeChildRisk.Attributes.GetNamedItem("COMMISSION_NET").Value)
                    Finally
                    End Try

                    Try
                        policyCoinsurerSection.PremiumExcTax = Val(oDomNodeChildRisk.Attributes.GetNamedItem("SECTION_PREMIUM_EXCLUDING_TAX").Value)
                    Finally
                    End Try

                    Try

                        Dim sectionTaxGroupId As Int32 = 0
                        If Not IsNothing(oDomNodeRisk.Attributes.GetNamedItem("SECTION_TAX_GROUP_ID")) Then
                            sectionTaxGroupId = Cast.ToInt32(oDomNodeRisk.Attributes.GetNamedItem("SECTION_TAX_GROUP_ID").Value, 0)
                        End If
                        policySection.PremiumTaxGroupDescription = ""
                        'Get Tax Group Description from Id.
                        If sectionTaxGroupId <> 0 Then
                            oBusiness.GetListItemFromID(Core.STSListType.PMLookup,
                                "Tax_Group",
                                sectionTaxGroupId,
                               policySection.PremiumTaxGroupDescription)
                        End If
                    Finally
                    End Try

                    Try
                        policyCoinsurerSection.TaxValue = Val(oDomNodeChildRisk.Attributes.GetNamedItem("TAX_AMOUNT").Value)
                    Finally
                    End Try

                    If Not IsNothing(oDomNodeChildRisk.Attributes.GetNamedItem("SECTION_COB_RATING_SECTION_ID")) Then
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_PMB_CobRatingSection_sel")
                            cmd.AddInParameter("@cob_rating_section_id", SqlDbType.Int).Value = Val(oDomNodeChildRisk.Attributes.GetNamedItem("SECTION_COB_RATING_SECTION_ID").Value)
                            ds = con.ExecuteDataSet(cmd, "RatingSectionId")

                            If ds.Tables("RatingSectionId").Rows.Count > 0 Then
                                Try
                                    policyCoinsurerSection.SectionDescription = ds.Tables(0).Rows(0).Item(1).ToString
                                Catch ex As Exception
                                    Dim STSErrorEx As New STSErrorPublisher("Failed to Get Cob Rating Section for Section.", ex)
                                    STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "PopulatePolicySections", True)
                                End Try
                            End If
                        End Using
                    Else
                        policyCoinsurerSection.SectionDescription = ""
                    End If

                    'Add Another Node
                    If IsArray(PolicyCoinsurerSections) Then
                        ReDim Preserve PolicyCoinsurerSections(PolicyCoinsurerSections.GetUpperBound(1) + 1)
                    Else
                        ReDim PolicyCoinsurerSections(0)
                    End If

                    PolicyCoinsurerSections(PolicyCoinsurerSections.GetUpperBound(1)) = policyCoinsurerSection

                Next
            Next
        End If

        Dim oXMLSerializer As Serialization.XmlSerializer
        Dim xmlAttrs As New XmlAttributes()
        Dim xmlRoot As New XmlRootAttribute
        Dim xmlType As New XmlTypeAttribute
        Dim xmloverride As New XmlAttributeOverrides

        If Len(PCSrootElementName) > 0 Or Len(PCSelementTypeName) > 0 Then
            xmlRoot.ElementName = PCSrootElementName
            xmlRoot.IsNullable = False
            xmlAttrs.XmlRoot = xmlRoot
            xmlType.TypeName = PCSelementTypeName
            xmlAttrs.XmlType = xmlType
            xmlAttrs.Xmlns = False
            xmlAttrs.XmlIgnore = True
            xmloverride.Add(GetType(BasePolicyCoinsurerSectionType), xmlAttrs)
            xmloverride.Add(GetType(BasePolicyCoinsurerSectionType()), xmlAttrs)

            oXMLSerializer = New Serialization.XmlSerializer(GetType(BasePolicyCoinsurerSectionType()), xmloverride)

        Else

            oXMLSerializer = New Serialization.XmlSerializer(GetType(BasePolicyCoinsurerSectionType()))

        End If

        Dim Output As New StringWriter
        oXMLSerializer.Serialize(Output, PolicyCoinsurerSections)
        PolicyCoinsurerSectionsXml = Output.ToString()

        If Len(PSrootElementName) > 0 Or Len(PSelementTypeName) > 0 Then

            xmlAttrs = New XmlAttributes()
            xmlRoot = New XmlRootAttribute
            xmlType = New XmlTypeAttribute
            xmloverride = New XmlAttributeOverrides
            xmlRoot.ElementName = PSrootElementName
            xmlRoot.IsNullable = False
            xmlAttrs.XmlRoot = xmlRoot
            xmlType.TypeName = PSelementTypeName
            xmlAttrs.XmlType = xmlType
            xmlAttrs.Xmlns = False
            xmlAttrs.XmlIgnore = True
            xmloverride.Add(GetType(BasePolicySectionType), xmlAttrs)
            xmloverride.Add(GetType(BasePolicySectionType()), xmlAttrs)

            oXMLSerializer = New Serialization.XmlSerializer(GetType(BasePolicySectionType()), xmloverride)
        Else
            oXMLSerializer = New Serialization.XmlSerializer(GetType(BasePolicySectionType()))
        End If

        Output = New StringWriter
        oXMLSerializer.Serialize(Output, PolicySections)
        PolicySectionsXml = Output.ToString()

    End Sub

