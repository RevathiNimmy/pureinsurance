    Public Overloads Function GetAgentCommissionTax(ByVal conAgentCommissionTax As SiriusConnection, ByVal oGetAgentCommissionTaxRequest As BaseGetAgentCommissionTaxRequestType) As BaseGetAgentCommissionTaxResponseType

        Dim oGetAgentCommissionTaxResponse As New BaseGetAgentCommissionTaxResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetAgentCommissionTaxRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetAgentCommissionTaxRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetAgentCommissionTaxResponse = New SAMForInsuranceV2ImplementationTypes.GetAgentCommissionTaxResponseType
        End If
        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetAgentCommissionTaxRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If String.IsNullOrEmpty(oGetAgentCommissionTaxRequest.TaxGroupCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "TaxGroupCode")
        End If

        If String.IsNullOrEmpty(oGetAgentCommissionTaxRequest.CurrencyCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "CurrencyCode")
        End If

        If oGetAgentCommissionTaxRequest.InsuranceFileKey = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If

        ' exit if there are any missing parameters
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Lookup and data Validation
        '*******************************************************************************************

        If Not String.IsNullOrEmpty(oGetAgentCommissionTaxRequest.BranchCode) Then
            oGetAgentCommissionTaxRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oGetAgentCommissionTaxRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If
        Dim iTaxGroupID As Integer
        If Not String.IsNullOrEmpty(oGetAgentCommissionTaxRequest.TaxGroupCode) Then
            iTaxGroupID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.TaxGroup, oGetAgentCommissionTaxRequest.TaxGroupCode, "TaxGroupCode", oSAMErrorCollection)
        End If

        Dim iCurrencyID As Integer
        If Not String.IsNullOrEmpty(oGetAgentCommissionTaxRequest.BranchCode) Then
            iCurrencyID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, oGetAgentCommissionTaxRequest.CurrencyCode, "CurrencyCode", oSAMErrorCollection)
        End If

        oSAMErrorCollection.CheckForErrors()

        Using cmdGetAgentCommissionTax As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Calculate_Tax_Amounts")

            cmdGetAgentCommissionTax.AddInParameter("@company_id", SqlDbType.Int).Value = Cast.NullIfDefault(oGetAgentCommissionTaxRequest.SourceId)
            cmdGetAgentCommissionTax.AddInParameter("@tax_group_id", SqlDbType.Int).Value = Cast.NullIfDefault(iTaxGroupID)
            cmdGetAgentCommissionTax.AddInParameter("@transtype", SqlDbType.VarChar, 10).Value = "TTAC"
            cmdGetAgentCommissionTax.AddInParameter("@currency_id", SqlDbType.Int).Value = iCurrencyID
            cmdGetAgentCommissionTax.AddOutParameter("@tax_currency_amount", SqlDbType.Money).Value = DBNull.Value
            cmdGetAgentCommissionTax.AddOutParameter("@tax_base_amount", SqlDbType.Money).Value = DBNull.Value
            cmdGetAgentCommissionTax.AddInParameter("@amount", SqlDbType.Money).Value = Cast.NullIfDefault(oGetAgentCommissionTaxRequest.AgentCommissionAmount)
            cmdGetAgentCommissionTax.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetAgentCommissionTaxRequest.InsuranceFileKey)
            cmdGetAgentCommissionTax.AddInParameter("@risk_cnt", SqlDbType.Int).Value = DBNull.Value
            'Tell SP to not save results
            cmdGetAgentCommissionTax.AddInParameter("@calculate_only", SqlDbType.Int).Value = 1

            conAgentCommissionTax.ExecuteNonQuery(cmdGetAgentCommissionTax)

            oGetAgentCommissionTaxResponse.TaxCurrencyAmount = Cast.ToDouble(cmdGetAgentCommissionTax.Parameters.Item("@tax_currency_amount").Value, 0)
            oGetAgentCommissionTaxResponse.TaxBaseAmount = Cast.ToDouble(cmdGetAgentCommissionTax.Parameters.Item("@tax_base_amount").Value, 0)

        End Using

        Return oGetAgentCommissionTaxResponse
    End Function
