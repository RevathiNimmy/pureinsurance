    ''' <summary>
    ''' To Get List ID from Code of lookup ITem.
    ''' </summary>
    ''' <param name="ListType"></param>
    ''' <param name="ListCode"></param>
    ''' <param name="ListItemCode"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function GetListIDFromCode(ByVal oListType As Core.STSListType,
                       ByVal sListCode As String,
                       ByVal sListItemCode As String) As Integer

        Const kACMethodName As String = "GetListIDFromCode"

        ' Data View that will hold the returned results		
        Dim dv As DataView = Nothing
        Dim dvID As DataView = Nothing
        Dim sFilter As String = String.Empty
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)

        Dim oIn As New Core.GetListInput
        Dim oOut As Core.GetListOutput
        Dim nID As Integer = 0

        oIn.BranchCode = ""
        oIn.ListType = oListType
        oIn.ListCode = sListCode

        ' Get the List
        oOut = oCoreBusiness.GetList(oIn, True)

        ' If we have not get the data set, either directly from the database
        ' or from the cache then error.
        If oOut.ListItems Is Nothing Then
            Dim ex As New Exception("No Effective List retrieved for List : " + sListCode.ToString)
            ExceptionManager.Publish(ex)
            Throw ex
        End If

        ' Get the DataView For the table
        dv = oOut.ListItems.Tables(0).DefaultView

        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nIsAllowedClaimOnClosed As Integer = 0
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            nIsAllowedClaimOnClosed = GetAndValidateSpecifiedTableCode(con, "source", "closed_allow_claims", "code", sListItemCode,
                                                                       oSAMErrorCollection, "closed_allow_claims")
        End Using

        ' Specify the Filter
        If nIsAllowedClaimOnClosed = 1 Then
            sFilter = "code = '" & Trim(sListItemCode) & "'"
        Else
            sFilter = "code = '" + Trim(sListItemCode) + "' AND (is_deleted = 0 or is_deleted IS NULL)"
        End If

        Try
            ' Create a New Data View filtered by the code
            dvID = New DataView(dv.Table, sFilter, "", DataViewRowState.CurrentRows)

            If dvID Is Nothing Then
                Dim STSError As New STSErrorPublisher(PMEReturnCode.PMNotFound, "No row found for STSList : " & sListCode.ToString + " ID : " &
                                                      sListItemCode.ToString)
                STSError.Raise(HttpContext.Current.Request.Url.ToString(), kACMethodName, "DataView", True)
            End If
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("No row found for STSList : " & sListCode.ToString + " ID : " & sListItemCode.ToString, ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), kACMethodName, "GetDataView", True)
        End Try

        Try
            nID = CInt(dvID.Item(0).Item("id").ToString)
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("No row found for STSList : " + sListCode.ToString + " Code : " + sListItemCode.ToString, ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), kACMethodName, "GetDataView", True)
        End Try

        Return nID

    End Function

