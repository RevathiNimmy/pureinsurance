    Public Overloads Function GetNextCashDepositRef(ByVal conCashDeposit As SiriusConnection, ByVal oGetNextCashDepositRequest As BaseGetNextCashDepositRefRequestType) As BaseGetNextCashDepositRefResponseType

        Dim oGetNextCashDepositResponse As New BaseGetNextCashDepositRefResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetNextCashDepositRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetNextCashDepositRefRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetNextCashDepositResponse = New SAMForInsuranceV2ImplementationTypes.GetNextCashDepositRefResponseType
        End If
        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetNextCashDepositRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetNextCashDepositRequest.PartyCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "PartyCode")
        End If

        ' exit if there are any missing parameters
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Lookup and data Validation
        '*******************************************************************************************
        'Do the data validation
        oGetNextCashDepositRequest.PartyKey = GetAndValidateSpecifiedTableCode(conCashDeposit,
              PMLookupTable.Party, "party_cnt", "shortname", oGetNextCashDepositRequest.PartyCode, oSAMErrorCollection, "PartyCode")
        Dim dsCashDeposit As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Next_CashDeposit_Number")
            cmd.AddInParameter("@Party_Id", SqlDbType.Int).Value = Cast.NullIfDefault(oGetNextCashDepositRequest.PartyKey, 0)
            cmd.AddOutParameter("@NextNumber", SqlDbType.Int)
            conCashDeposit.ExecuteNonQuery(cmd)
            oGetNextCashDepositResponse.NextCashDepositNumber = Cast.ToInt32(cmd.Parameters.Item("@NextNumber").Value, 0)
        End Using
        oGetNextCashDepositResponse.CashDepositRef = oGetNextCashDepositRequest.PartyCode + "-CD" + Format(oGetNextCashDepositResponse.NextCashDepositNumber, "000")

        ' Get the Timestamp
        Dim bIsLocked As Boolean
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.GetTimestamp(
                            oGetNextCashDepositRequest.BranchCode,
                            CoreBusiness.LockName.NextCashDepositNumber,
