    ''' <summary>  
    ''' FindCase
    ''' </summary>  
    ''' <param name="oRequest">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseFindCaseRequestType</param>  
    ''' <param name="con">An object of type SiriusConnection</param>  
    Public Overloads Function FindCase(ByRef con As SiriusConnection,
    ByVal oRequest As BaseFindCaseRequestType) As BaseFindCaseResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseFindCaseResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim STSError As New STSErrorPublisher
        Dim iProductID As Int32 = 0
        Dim dsFindCase As DataSet = Nothing
        Dim oGISSearchDataArray As Object = Nothing
        Dim oResultSet As Object = Nothing
        Dim obCLMCaseBusiness As bCLMCase.Business
        Dim sDisableWildcardSearchOption As String = String.Empty
        Dim sEnablePartialWildcardSearchOption As String = String.Empty
        Dim bDisableWildcardSearchOption As Boolean = False
        Dim bEnablePartialWildcardSearchOption As Boolean = False

        obCLMCaseBusiness = New bCLMCase.Business

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindCaseRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.FindCaseResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        '*******************
        ' STRUCTURE VALIDATION
        '*******************
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' DATA VALIDATION
        '*******************
        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        Else
            oRequest.SourceId = 1
        End If

        If (Not String.IsNullOrEmpty(oRequest.RiskIndex)) Then
            If Informations.inStr(1, oRequest.RiskIndex, "%") <> 0 Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                                    SAMInvalidData.InvalidWildcardSearch.ToString,
                                                    "Enter full RiskIndex Value or leave it Blank")
            End If
        End If
        If (Not String.IsNullOrEmpty(oRequest.ProgressStatusCode)) AndAlso Trim(UCase(oRequest.ProgressStatusCode)) <> "ALL" Then
            oRequest.ProgressStatusCodeID = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.CaseProgressStatusCode, oRequest.ProgressStatusCode, "ProgressStatusCode", oSAMErrorCollection)
        Else
            oRequest.ProgressStatusCodeID = 0
        End If
        oSAMErrorCollection.CheckForErrors()

        If (Not String.IsNullOrEmpty(oRequest.RiskType)) AndAlso Trim(UCase(oRequest.RiskType)) <> "ALL" Then
            oRequest.RiskTypeID = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.RiskType, oRequest.RiskType, "RiskType", oSAMErrorCollection)
        Else
            oRequest.RiskTypeID = 0
        End If
        oSAMErrorCollection.CheckForErrors()

        oBusiness.GetSystemOption(oRequest.BranchCode, SystemOption.DisableWildcardSearch, sDisableWildcardSearchOption)

        oBusiness.GetSystemOption(oRequest.BranchCode, SystemOption.EnablePartialWildcardSearch, sEnablePartialWildcardSearchOption)

        If (Trim(sDisableWildcardSearchOption) = "1") Then
            bDisableWildcardSearchOption = True
        Else
            bDisableWildcardSearchOption = False
        End If

        If (Trim(sEnablePartialWildcardSearchOption) = "1") Then
            bEnablePartialWildcardSearchOption = True
        Else
            bEnablePartialWildcardSearchOption = False
        End If

        If Not oBusiness.ValidWildcardSearch(
          bDisableWildcardSearchOption,
          bEnablePartialWildcardSearchOption,
          oRequest.CaseNumber) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     SAMInvalidData.InvalidWildcardSearch.ToString,
                                     "CaseNumber")
        End If
        oSAMErrorCollection.CheckForErrors()

        If Not oBusiness.ValidWildcardSearch(
        bDisableWildcardSearchOption,
        bEnablePartialWildcardSearchOption,
        oRequest.ClaimNumber) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     SAMInvalidData.InvalidWildcardSearch.ToString,
                                     "ClaimNumber")
        End If

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' PROCESS
        '*******************

        Try

            If Not String.IsNullOrEmpty(oRequest.RiskIndex) Then
                Dim oBackOfficeLinkBusiness As bBackOfficeLink.bBOLink
                oBackOfficeLinkBusiness = New bBackOfficeLink.bBOLink
                oResponse = ProcessRiskIndexBaseCaseDetails(oBackOfficeLinkBusiness, obCLMCaseBusiness,
                oRequest, oResponse)

            Else
                oResponse = ProcessCaseDetails(obCLMCaseBusiness, oRequest, oResponse)
            End If

        Catch ex As Exception
            Throw

        Finally
            If Not obCLMCaseBusiness IsNot Nothing Then
                obCLMCaseBusiness.Dispose()
                obCLMCaseBusiness = Nothing
            End If
        End Try

        Return oResponse

    End Function
    ''End (Sandeep Kumar) - (Tech Spec - WPR 28 FindCase) 
