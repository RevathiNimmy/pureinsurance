    ''' <summary>
    ''' Get Product wise user branch
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oGetProductsForUserBranchRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function GetProductsForUserBranch(ByVal con As SiriusConnection, ByVal oGetProductsForUserBranchRequest As BaseGetProductsForUserBranchRequestType) As BaseGetProductsForUserBranchResponseType

        Dim oGetProductsForUserBranchResponse As New BaseGetProductsForUserBranchResponseType
        Dim nUserId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetProductsForUserBranchRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetProductsForUserBranchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetProductsForUserBranchResponse = New SAMForInsuranceV2ImplementationTypes.GetProductsForUserBranchResponseType
        End If

        ' Dataset that will hold the returned results		
        Dim dsProducts As DataSet = Nothing
        nUserId = GetUserId(con, oGetProductsForUserBranchRequest.LoginUserName)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Products_For_Branch")
            cmd.AddInParameter("@user_id", SqlDbType.Int).Value = nUserId
            dsProducts = con.ExecuteDataSet(cmd, "Row")
        End Using
        Dim dtBranches As DataTable = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Select_All_Product_Source")
            cmd.AddInParameter("@user_id", SqlDbType.Int).Value = nUserId
            dtBranches = con.ExecuteDataTable(cmd)
        End Using

        'End If
        oGetProductsForUserBranchResponse.Products = New BaseGetProductsForUserBranchResponseTypeProducts
        If dsProducts.Tables(0) IsNot Nothing AndAlso dsProducts.Tables(0).Rows.Count > 0 Then
            ReDim oGetProductsForUserBranchResponse.Products.Row(dsProducts.Tables(0).Rows.Count - 1)
            For i As Integer = 0 To dsProducts.Tables(0).Rows.Count - 1
                oGetProductsForUserBranchResponse.Products.Row(i) = New BaseGetProductsForUserBranchResponseTypeProductsRow
                'Copy the products to oGetProductsForUserBranchResponse.Products
                oGetProductsForUserBranchResponse.Products.Row(i).ProductCode = dsProducts.Tables(0).Rows(i).Item("code").ToString()
                oGetProductsForUserBranchResponse.Products.Row(i).ProductDescription = dsProducts.Tables(0).Rows(i).Item("description").ToString()
                oGetProductsForUserBranchResponse.Products.Row(i).ProductKey = Convert.ToInt32(dsProducts.Tables(0).Rows(i).Item("product_id").ToString())

                '  Define the filter
                Dim sfilter As String = "product_id = " & dsProducts.Tables(0).Rows(i).Item("product_id").ToString
                ' Filter the rows using Select() method of DataTable
                Dim FilteredRows() As DataRow = dtBranches.Select(sfilter)
                Dim j As Integer = 0
                ReDim oGetProductsForUserBranchResponse.Products.Row(i).Branches(FilteredRows.Length - 1)
                For Each row As DataRow In FilteredRows
                    'Copy the products to oGetProductsForUserBranchResponse.Products(i).Branches.
                    oGetProductsForUserBranchResponse.Products.Row(i).Branches(j) = New BaseBranchType
                    oGetProductsForUserBranchResponse.Products.Row(i).Branches(j).BranchCode = row.Item("code").ToString()
                    oGetProductsForUserBranchResponse.Products.Row(i).Branches(j).Description = row.Item("description").ToString()
                    j += 1
                Next

            Next
        End If

        Return oGetProductsForUserBranchResponse

    End Function
