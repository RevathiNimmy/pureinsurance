    ''' <summary>
    '''This  method  will perform the business
    '''</summary>
    '''<param name="conGetPolicyBankGuarantee">An object of a class SiriusConnection</param>
    '''<param name="oGetPolicyBankGuarantee">An object of a class BaseGetPolicyBankGuaranteeRequestType</param>
    '''<remarks></remarks>    
    Public Overloads Function GetPolicyBankGuarantee(ByVal conGetPolicyBankGuarantee As SiriusConnection, ByVal oGetPolicyBankGuarantee As BaseGetPolicyBankGuaranteeRequestType) As BaseGetPolicyBankGuaranteeResponseType

        Dim oGetPolicyBankGuaranteeResponse As New BaseGetPolicyBankGuaranteeResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCoreBusiness As New CoreBusiness

        If oGetPolicyBankGuarantee.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetPolicyBankGuaranteeRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetPolicyBankGuaranteeResponse = New SAMForInsuranceV2ImplementationTypes.GetPolicyBankGuaranteeResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        '**********************************************************************************************
        ''Structure Validation(Mandatory Checking)
        '**********************************************************************************************
        oGetPolicyBankGuarantee.Validate(CObj(oSAMErrorCollection))

        oSAMErrorCollection.CheckForErrors()

        '**********************************************************************************************
        'Data Validation
        '**********************************************************************************************
        oGetPolicyBankGuarantee.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
          PMLookupTable.Source, oGetPolicyBankGuarantee.BranchCode, "BranchCode", oSAMErrorCollection)

        oGetPolicyBankGuarantee.InsuranceFileKey = GetAndValidateSpecifiedTableCode(conGetPolicyBankGuarantee,
            PMLookupTable.Insurance_file, "insurance_file_cnt", "insurance_file_cnt", oGetPolicyBankGuarantee.InsuranceFileKey.ToString(), oSAMErrorCollection, "InsuranceFileKey")

        oSAMErrorCollection.CheckForErrors()

        Dim iPolicyBranchId As Integer = 0
        Dim iPolicyProductId As Integer = 0
        Dim sBusinessTypeCode As String = Nothing
        Dim iPartyKey As Integer = 0
        Dim iLeadAgentKey As Integer = 0
        Dim sLeadAgentTypeCode As String = Nothing
        Dim dtCoverFrom As DateTime = Nothing
        Dim bFlag As Boolean = False
        Dim iCurrencyId As Integer = 0

        bFlag = GetCompleteInsuranceFileDetails(conGetPolicyBankGuarantee, oGetPolicyBankGuarantee.InsuranceFileKey,
        iPolicyBranchId, iPolicyProductId, sBusinessTypeCode, iPartyKey, iLeadAgentKey, sLeadAgentTypeCode,
       dtCoverFrom, iCurrencyId)

        If (bFlag = False) Then
            oSAMErrorCollection.AddBusinessRule(SAMConstants.SAMBusinessErrors.InValidInsuranceFileCnt, "Invalid Insurance_File_cnt")
        End If
        oSAMErrorCollection.CheckForErrors()

        Dim iWarningCount As Integer = 0
        If (sBusinessTypeCode.Trim() = InternalSAMConstants.kBusinessTypeDIRECT) Then
            If (oGetPolicyBankGuarantee.GetBGsOf = BGPartyType.Agent) Then
                AddWarning(oGetPolicyBankGuaranteeResponse.Warnings,
                SAMBusinessWarnings.InCaseOfDirectBusinessNoAgentWillBeTheir,
                "In case of direct business no Agent will be their")
            End If
            oGetPolicyBankGuarantee.PartyKey = iPartyKey
        ElseIf (sBusinessTypeCode.Trim() = InternalSAMConstants.kBusinessTypeAGENCY) Then
            If (sLeadAgentTypeCode.Trim() = InternalSAMConstants.sBroker) Then
                If (oGetPolicyBankGuarantee.GetBGsOf = BGPartyType.Client) Then
                    AddWarning(oGetPolicyBankGuaranteeResponse.Warnings,
                    SAMBusinessWarnings.InCaseIfAgentIsABrokerThenOnlyAgentBGsShouldbeRetrieved,
                    "In case if agent is a broker then only Agent BGs should be retrieved")
                End If
                oGetPolicyBankGuarantee.PartyKey = iLeadAgentKey
            ElseIf (sLeadAgentTypeCode.Trim() = InternalSAMConstants.sCommissionAccount) Then
                If (oGetPolicyBankGuarantee.GetBGsOf = BGPartyType.Agent) Then
                    AddWarning(oGetPolicyBankGuaranteeResponse.Warnings,
                    SAMBusinessWarnings.InCaseIfAgentIsACommAccThenOnlyClientBGSShouldBeRetrieved,
                    "In case if agent is a Comm Acc then only Client BGS should be retrieved")
                End If
                oGetPolicyBankGuarantee.PartyKey = iPartyKey
            ElseIf (sLeadAgentTypeCode.Trim() = InternalSAMConstants.sIntermediary) Then
                If (oGetPolicyBankGuarantee.GetBGsOf = BGPartyType.Agent) Then
                    oGetPolicyBankGuarantee.PartyKey = iLeadAgentKey
                ElseIf (oGetPolicyBankGuarantee.GetBGsOf = BGPartyType.Client) Then
                    oGetPolicyBankGuarantee.PartyKey = iPartyKey
                End If
            End If
        ElseIf (sBusinessTypeCode.Trim() = Trim(InternalSAMConstants.kBusinessTypeAGENCYCOINLEAD)) Or (sBusinessTypeCode.Trim() = Trim(InternalSAMConstants.kBusinessTypeAGENCYCOINFOLLOW)) Then
            oGetPolicyBankGuarantee.PartyKey = iLeadAgentKey
        End If

        ' Dataset that will hold the returned results	
        Dim dtDueDate As DateTime = Nothing
        Dim dsBankGuaranteeDetails As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_BGs_for_policy")
            cmd.AddInParameter("@Product_Id", SqlDbType.Int).Value = iPolicyProductId
            cmd.AddInParameter("@Source_Id", SqlDbType.Int).Value = iPolicyBranchId
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oGetPolicyBankGuarantee.InsuranceFileKey
            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oGetPolicyBankGuarantee.PartyKey
            cmd.AddInParameter("@cover_from_date", SqlDbType.DateTime).Value = dtCoverFrom
            cmd.AddInParameter("@Total_Premium", SqlDbType.Decimal).Value = GetTotalPremiumAmount(conGetPolicyBankGuarantee, oGetPolicyBankGuarantee.InsuranceFileKey)
            cmd.AddInParameter("@TranCurrency_Id", SqlDbType.Int).Value = iCurrencyId
            cmd.AddOutParameter("@DueDate", SqlDbType.DateTime)
            dsBankGuaranteeDetails = conGetPolicyBankGuarantee.ExecuteDataSet(cmd, "PolicyBankGuarantee")
            dtDueDate = Cast.ToDateTime(cmd.Parameters.Item("@DueDate").Value, Nothing)
        End Using
        If (dsBankGuaranteeDetails IsNot Nothing) Then
            If (dsBankGuaranteeDetails.Tables.Count >= 1) Then
                dsBankGuaranteeDetails.Tables(0).Columns("bg_id").ColumnName = "BGKey"
                dsBankGuaranteeDetails.Tables(0).Columns("bg_ref").ColumnName = "BankGuaranteeRef"
                dsBankGuaranteeDetails.Tables(0).Columns("BG_Limit").ColumnName = "BGLimit"
                dsBankGuaranteeDetails.Tables(0).Columns("bank_name_id").ColumnName = "BankNameKey"
                dsBankGuaranteeDetails.Tables(0).Columns.Remove("BG_currency_id")
                dsBankGuaranteeDetails.Tables(0).Columns.Remove("Party_Cnt")
                dsBankGuaranteeDetails.Tables(0).Columns("expiry_date").ColumnName = "ExpiryDate"
                dsBankGuaranteeDetails.Tables(0).Columns("available_bal").ColumnName = "AvailableBalance"
                dsBankGuaranteeDetails.Tables(0).Columns.Remove("issue_date")
                dsBankGuaranteeDetails.Tables(0).Columns("Shortname").ColumnName = "ClientShortName"
                dsBankGuaranteeDetails.Tables(0).Columns("Resolved_Name").ColumnName = "ClientName"
                dsBankGuaranteeDetails.Tables(0).Columns("bank_name").ColumnName = "BankName"
                dsBankGuaranteeDetails.Tables(0).Columns.Add("DueDate", GetType(System.DateTime))
                Dim iRowCount As Integer = 0
                For Each row As DataRow In dsBankGuaranteeDetails.Tables(0).Rows
                    dsBankGuaranteeDetails.Tables(0).Rows(iRowCount).Item("DueDate") = dtDueDate
                    iRowCount += 1
                Next
                Dim xmlDoc As New XmlDocument
                dsBankGuaranteeDetails.DataSetName = "BaseGetPolicyBankGuaranteeResponseTypeBankGuarantee"
                dsBankGuaranteeDetails.Tables(0).TableName = "Row"

                If oGetPolicyBankGuarantee.WCFSecurityToken = "" Then
                    xmlDoc.LoadXml(dsBankGuaranteeDetails.GetXml())
                    oGetPolicyBankGuaranteeResponse.ResultDataset = xmlDoc.DocumentElement
                End If

                oGetPolicyBankGuaranteeResponse.ResultData = dsBankGuaranteeDetails
            End If
        End If

        Return oGetPolicyBankGuaranteeResponse
    End Function

