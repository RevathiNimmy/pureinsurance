        If oGetUserAuthorityValueRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetUserAuthorityValueRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetUserAuthorityValueResponse = New SAMForInsuranceV2ImplementationTypes.GetUserAuthorityValueResponseType
        End If
        ' validate the mandatory
        oGetUserAuthorityValueRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()
        ' Look Up validation 
        Dim iUserId As Integer = GetAndValidateSpecifiedTableCode(con, "pmuser", "User_Id", "username", oGetUserAuthorityValueRequest.UserCode, oSAMErrorCollection, "User_Id")
        oSAMErrorCollection.CheckForErrors()

        Dim nSourceId As Integer
        Dim dtDateOfPayments As Date
        Dim nPaymentAmount As Double
        Dim nCurrencyID As Integer
        Dim nCurrencyFromToBaseXRate As Decimal

        If (Not String.IsNullOrEmpty(oGetUserAuthorityValueRequest.BranchCode)) Then
            nSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oGetUserAuthorityValueRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If
        Dim dsUserAuthority As DataSet
        dsUserAuthority = GetValueForUserAuthority(con, iUserId, oGetUserAuthorityValueRequest)


        If dsUserAuthority IsNot Nothing AndAlso dsUserAuthority.Tables.Count > 0 AndAlso dsUserAuthority.Tables(0).Rows.Count > 0 Then
            If dsUserAuthority.Tables(0).Rows(0).ItemArray.Length = 1 Then
                oGetUserAuthorityValueResponse.UserAuthorityValue = dsUserAuthority.Tables(0).Rows(0)(0).ToString()
            ElseIf dsUserAuthority.Tables(0).Rows(0).ItemArray.Length = 2 Then
                oGetUserAuthorityValueResponse.UserAuthorityValue = dsUserAuthority.Tables(0).Rows(0)(0).ToString()
                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue1 = Cast.ToInt32(dsUserAuthority.Tables(0).Rows(0)(1), 0)
                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue1Specified = True
            ElseIf dsUserAuthority.Tables(0).Rows(0).ItemArray.Length = 4 Then
                oGetUserAuthorityValueResponse.UserAuthorityValue = dsUserAuthority.Tables(0).Rows(0)(0).ToString()
                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue1 = Cast.ToInt32(dsUserAuthority.Tables(0).Rows(0)(1), 0)
                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue1Specified = True
                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue2 = Cast.ToDouble(dsUserAuthority.Tables(0).Rows(0)(2), 0.0)
                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue2Specified = True
                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue3 = dsUserAuthority.Tables(0).Rows(0)(3).ToString()

                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue3Specified = True
                nCurrencyID = Cast.ToInt32(dsUserAuthority.Tables(0).Rows(0)(1), 0)
                GetCurrencyToBaseXRate(con, nCurrencyID, nSourceId, Date.Now, nCurrencyFromToBaseXRate)
                oGetUserAuthorityValueResponse.UserAuthorityOptionalValue3_BaseAmount = oGetUserAuthorityValueResponse.UserAuthorityOptionalValue2 * nCurrencyFromToBaseXRate

            End If
        End If
        Return oGetUserAuthorityValueResponse
    End Function

    ''' <summary>
    '''This method sends the request object values to the Stored Procedure and get the reponse object as DataSet
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="iproductid" type="Integer"></param>
    '''<param name="oGetProductRiskOptionValueRequest" type="BaseProductRiskOptionValueRequestType"></param>
    '''<returns Dataset></returns>
    '''<remarks></remarks>
    Private Function GetProductRiskOptions(ByVal con As SiriusConnection, ByVal iproductid As Integer,
ByVal oGetProductRiskOptionValueRequest As BaseProductRiskOptionValueRequestType) As String
        Dim dsProductRiskOptions As DataSet = Nothing
        Dim oCoreBusiness As New CoreBusiness
        Dim sProductRiskOption As String
        Dim sResult As String = String.Empty

        Dim _oCache As System.Web.Caching.Cache = HttpContext.Current.Cache()

        sProductRiskOption = oCoreBusiness.ProductRiskOptionString(CType([Enum].ToObject(GetType(ProductRiskOptions), oGetProductRiskOptionValueRequest.ProducRiskOption), CoreBusiness.ProductRiskOptions))
        Dim sCacheKey As String = ("Product_id_" & iproductid & "Option_ " & sProductRiskOption).ToLower

        If Not _oCache(sCacheKey) Is Nothing Then
            sResult = CType(_oCache(sCacheKey), String)
        Else
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Product_sel")
                cmd.AddInParameter("@product_id", SqlDbType.Int).Value = iproductid
                cmd.AddInParameter("@column_name", SqlDbType.VarChar, 255).Value = sProductRiskOption
                dsProductRiskOptions = con.ExecuteDataSet(cmd, "Row")
                If dsProductRiskOptions.Tables(0).Rows.Count > 0 Then
                    sResult = (dsProductRiskOptions.Tables(0).Rows(0)(0)).ToString()
                Else
                    sResult = ""
                End If
            End Using
            _oCache.Insert(sCacheKey, sResult)
        End If
        Return sResult
    End Function

