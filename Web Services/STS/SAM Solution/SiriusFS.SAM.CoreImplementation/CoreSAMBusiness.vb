    ''' <summary>
    ''' This method is used to update CoInsurance details (arrangement and values)
    '''</summary>
    '''<param name="cOn" type="SiriusConnection"></param>   
    '''<param name="UpdateCoinsuranceValuesRequest" type="BaseUpdateCoinsuranceValuesRequestType"></param>   
    '''<returns>BaseUpdateCoinsuranceValuesResponseType</returns>
    '''<remarks></remarks>
    Public Overloads Function UpdateCoinsuranceValues(ByVal con As SiriusConnection, ByVal UpdateCoinsuranceValuesRequest As BaseUpdateCoinsuranceValuesRequestType) As BaseUpdateCoinsuranceValuesResponseType

        Dim oUpdateCoinsuranceValuesResponse As New BaseUpdateCoinsuranceValuesResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        'Dim iSourceId As Integer 'unused
        Dim nTypeOfPackage As enumTypeOfPackage

        If UpdateCoinsuranceValuesRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateCoinsuranceValuesRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oUpdateCoinsuranceValuesResponse = New SAMForInsuranceV2ImplementationTypes.UpdateCoinsuranceValuesResponseType
        End If

        '*******************
        ' STRUCTURE VALIDATION
        '*******************
        UpdateCoinsuranceValuesRequest.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        If Not GetDetailsFromId(con, "insurance_file", "insurance_file_cnt", UpdateCoinsuranceValuesRequest.InsuranceFileKey.ToString()) Then
            oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                SAMInvalidData.InvalidLookupListValue.ToString,
                "InsuranceFileKey", UpdateCoinsuranceValuesRequest.InsuranceFileKey.ToString)
        End If

        If UpdateCoinsuranceValuesRequest.CoInsurers IsNot Nothing Then
            With UpdateCoinsuranceValuesRequest.CoInsurers
                If .Row IsNot Nothing Then
                    For Each oRow As BaseUpdateCoinsuranceValuesRequestTypeCoInsurersRow In .Row
                        If Not GetDetailsFromId(con, "party", "party_cnt", oRow.CoInsurerKey.ToString()) Then
                            oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                SAMInvalidData.InvalidLookupListValue.ToString,
                                "CoInsurerKey", oRow.CoInsurerKey.ToString)
                        End If
                    Next
                End If
            End With
        End If

        '*******************
        ' BUSINESS RULE VALIDATION
        '*******************
        Dim o_insuranceFileTypeId As Integer = 0
        Dim o_insuranceFileTypeCode As String = String.Empty
        GetInsuranceFileType(con, UpdateCoinsuranceValuesRequest.InsuranceFileKey, o_insuranceFileTypeId, o_insuranceFileTypeCode)

        If o_insuranceFileTypeCode = InsuranceFileType.LivePolicy Then
            oErrors.AddBusinessRule(SAMBusinessErrors.CanNotUpdateLivePolicyDetails,
                SAMBusinessErrors.CanNotUpdateLivePolicyDetails.ToString,
                "Can Not update coinsurer details For a live poilcy")
        End If

        ' exit if there are any structure validation errors or business rule validation errors
        oErrors.CheckForErrors()

        ' Vivek: As per discussion with Rahul,
        ' getting InsuranceFolderCnt from InsuranceFileCnt for locking and unlocking
        Dim r_lInsFolderCnt As Integer = 0
        Dim r_lSourceId As Integer = 0
        oCoreBusiness.CheckInsuranceFile(con, UpdateCoinsuranceValuesRequest.InsuranceFileKey, r_lInsFolderCnt, r_lSourceId)

        'India : Use the time stamp for record locking purposes
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.CheckTSAndLock(con,
            BranchCode:=UpdateCoinsuranceValuesRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=r_lInsFolderCnt,
            TStamp:=UpdateCoinsuranceValuesRequest.TimeStamp)
        ' Check for Errors
        If AnyError IsNot Nothing Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oUpdateCoinsuranceValuesResponse.STSError = AnyError
            Return oUpdateCoinsuranceValuesResponse
        End If

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_COI_Value_del")

            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(UpdateCoinsuranceValuesRequest.InsuranceFileKey)
            con.ExecuteNonQuery(cmd)

        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_COI_Arrangement_del")

            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(UpdateCoinsuranceValuesRequest.InsuranceFileKey)
            con.ExecuteNonQuery(cmd)

        End Using

        'Now add the arrangement data
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_COI_Arrangement_add")

            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = UpdateCoinsuranceValuesRequest.InsuranceFileKey
            cmd.AddInParameter("@is_recovered", SqlDbType.TinyInt).Value = Cast.ToByte(UpdateCoinsuranceValuesRequest.IsRecovered, 0)
            cmd.AddInParameter("@is_surcharged", SqlDbType.TinyInt).Value = Cast.ToByte(UpdateCoinsuranceValuesRequest.IsSurcharged, 0)
            cmd.AddInParameter("@coi_default_id", SqlDbType.Int).Value = UpdateCoinsuranceValuesRequest.DefaultId
            con.ExecuteNonQuery(cmd)

        End Using

        'Using the examples above, loop through the coinsurers and use the stored procedure spe_COI_Value_add to add the various coninsurance values
        If UpdateCoinsuranceValuesRequest.CoInsurers IsNot Nothing Then
            With UpdateCoinsuranceValuesRequest.CoInsurers
                If .Row IsNot Nothing Then
                    Dim iCoiValueId As Integer = 0
                    For Each oRow As BaseUpdateCoinsuranceValuesRequestTypeCoInsurersRow In .Row

                        iCoiValueId = iCoiValueId + 1

                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_COI_Value_add")
                            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = UpdateCoinsuranceValuesRequest.InsuranceFileKey
                            cmd.AddInParameter("@coi_value_id", SqlDbType.Int).Value = iCoiValueId
                            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oRow.CoInsurerKey)
                            cmd.AddInParameter("@arrangement_ref", SqlDbType.VarChar, 30).Value = oRow.ArrangementRef
                            cmd.AddInParameter("@share_percent", SqlDbType.Decimal, 12, 8).Value = oRow.SharePerc
                            cmd.AddInParameter("@commission_percent", SqlDbType.Decimal, 12, 8).Value = oRow.CommissionPerc
                            cmd.AddInParameter("@share_premium", SqlDbType.Decimal, 19, 4).Value = 0D
                            cmd.AddInParameter("@commission_value", SqlDbType.Decimal, 19, 4).Value = 0D
                            cmd.AddInParameter("@surcharge_percent", SqlDbType.Decimal, 12, 8).Value = 0D
                            cmd.AddInParameter("@surcharge_value", SqlDbType.Decimal, 19, 4).Value = 0D
                            cmd.AddInParameter("@is_standard_surcharge", SqlDbType.TinyInt).Value = Cast.ToByte(0)
                            cmd.AddInParameter("@premium_tax_recovery_percent", SqlDbType.Decimal, 12, 8).Value = 0D
                            cmd.AddInParameter("@premium_tax_recovery_value", SqlDbType.Decimal, 19, 4).Value = 0D
                            cmd.AddInParameter("@is_manual_premium_tax_rec", SqlDbType.TinyInt).Value = Cast.ToByte(0)

                            con.ExecuteNonQuery(cmd)
                        End Using
                    Next
                End If
            End With
        End If

        'Populate the response with any error code, as well as the used timestamp for locking
        AnyError = oCoreBusiness.UnlockAndGetTS(con,
            BranchCode:=UpdateCoinsuranceValuesRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=r_lInsFolderCnt,
            TStamp:=oUpdateCoinsuranceValuesResponse.TimeStamp)

        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Unable to unlock, return the error.
            oUpdateCoinsuranceValuesResponse.STSError = AnyError
            Return oUpdateCoinsuranceValuesResponse
        End If

        Return oUpdateCoinsuranceValuesResponse

    End Function

