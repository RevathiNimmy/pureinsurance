    '''<summary>
    ''' This method is used to update status to either amend or accept
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="oUpdateRIAmendmentStatusRequestType" type="BaseUpdateRIAmendmentStatusRequestType"></param>    
    '''<returns>BaseUpdateRIAmendmentStatusResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function UpdateRIAmendmentStatus(ByVal con As SiriusConnection, ByVal oUpdateRIAmendmentStatusRequestType As BaseUpdateRIAmendmentStatusRequestType) As BaseUpdateRIAmendmentStatusResponseType
        Dim oResponse As New BaseUpdateRIAmendmentStatusResponseType
        Dim oCoreBusiness As New CoreBusiness
        If oUpdateRIAmendmentStatusRequestType.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateRIAmendmentStatusRequestType) Then
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateRIAmendmentStatusResponseType
        End If

        Dim nInsFolderCnt As Integer
        Dim nSourceId As Integer
        oCoreBusiness.CheckInsuranceFile(con, oUpdateRIAmendmentStatusRequestType.insuranceFileKey, nInsFolderCnt, nSourceId)

        'Use the time stamp for record locking purposes
        Dim oAnyError As STSErrorType
        'lock based on InsuranceFolderKey)
        oAnyError = oCoreBusiness.CheckTSAndLock(
            BranchCode:=oUpdateRIAmendmentStatusRequestType.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=nInsFolderCnt,
            TStamp:=oUpdateRIAmendmentStatusRequestType.TimeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oResponse.STSError = oAnyError
            Return oResponse
        End If

        If oUpdateRIAmendmentStatusRequestType.ProcessType.ToUpper = "CLONETRANSFER" Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Clone_RI_Usage_upd")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oUpdateRIAmendmentStatusRequestType.insuranceFileKey
                cmd.AddInParameter("@Clone_RI_status_type_id", SqlDbType.Int).Value = oUpdateRIAmendmentStatusRequestType.Status
                con.ExecuteNonQuery(cmd)
            End Using

        ElseIf oUpdateRIAmendmentStatusRequestType.ProcessType.ToUpper = "PORTFOLIOTRANSFER" Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_PT_RI_Usage_upd")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oUpdateRIAmendmentStatusRequestType.insuranceFileKey
                cmd.AddInParameter("@PT_RI_status_type_id", SqlDbType.Int).Value = oUpdateRIAmendmentStatusRequestType.Status
                con.ExecuteNonQuery(cmd)
            End Using

        End If

        oAnyError = oCoreBusiness.UnlockAndGetTS(
       BranchCode:=oUpdateRIAmendmentStatusRequestType.BranchCode,
       Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
       LockValue:=nInsFolderCnt,
       TStamp:=oResponse.TimeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Unable to unlock, return the error.
            oResponse.STSError = oAnyError
            Return oResponse
        End If

        Return oResponse

    End Function
