    '''<summary>
    ''' This is core SAM method for GetCoverNoteBook
    '''</summary>
    '''<param name="cOn" type="SiriusConnection"></param>   
    '''<param name="oGetCoverNoteBookRequest" type="BaseGetCoverNoteBookRequestType"></param>   
    '''<returns>BaseGetCoverNoteBookResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function GetCoverNoteBook(ByVal con As SiriusConnection, ByVal oGetCoverNoteBookRequest As BaseGetCoverNoteBookRequestType) As BaseGetCoverNoteBookResponseType

        Dim oGetCoverNoteBookResponse As New BaseGetCoverNoteBookResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetCoverNoteBookRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetCoverNoteBookRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetCoverNoteBookResponse = New SAMForInsuranceV2ImplementationTypes.GetCoverNoteBookResponseType
        End If

        oGetCoverNoteBookRequest.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsCoverNoteBookDetails As DataSet = Nothing
        Dim dsCoverNoteSheets As DataSet = Nothing
        Dim dsCoverNoteBookProducts As DataSet = Nothing
        Dim dsResultantCoverNoteSheets As DataSet = Nothing
        Dim dsResultantCoverNoteBookProducts As DataSet = Nothing
        Dim DocCoverNoteSheets As New System.Xml.XmlDocument
        Dim DocCoverNoteBookProducts As New System.Xml.XmlDocument

        'Get the cover note book details
        dsCoverNoteBookDetails = GetCoverNoteBookDetails(con, oGetCoverNoteBookRequest.CoverNoteBookKey)

        If dsCoverNoteBookDetails IsNot Nothing Then
            If dsCoverNoteBookDetails.Tables(0).Rows.Count = 1 Then
                oGetCoverNoteBookResponse.BookNumber = dsCoverNoteBookDetails.Tables(0).Rows(0).Item("book_number").ToString()
                oGetCoverNoteBookResponse.StartNumber = Cast.ToInt32(dsCoverNoteBookDetails.Tables(0).Rows(0).Item("start_number"), 0)
                oGetCoverNoteBookResponse.EndNumber = Cast.ToInt32(dsCoverNoteBookDetails.Tables(0).Rows(0).Item("end_number"), 0)

                oGetCoverNoteBookResponse.EffectiveDate = Cast.ToDateTime(dsCoverNoteBookDetails.Tables(0).Rows(0).Item("effective_date"), Date.MinValue)

                If oGetCoverNoteBookResponse.EffectiveDate <= Date.MinValue Then
                    oGetCoverNoteBookResponse.EffectiveDateSpecified = False
                Else
                    oGetCoverNoteBookResponse.EffectiveDateSpecified = True
                End If

                oGetCoverNoteBookResponse.AgentKey = Cast.ToInt32(dsCoverNoteBookDetails.Tables(0).Rows(0).Item("agent_cnt"), 0)
                If oGetCoverNoteBookResponse.AgentKey <= 0 Then
                    oGetCoverNoteBookResponse.AgentKeySpecified = False
                Else
                    oGetCoverNoteBookResponse.AgentKeySpecified = True
                End If

                oGetCoverNoteBookResponse.AgentName = dsCoverNoteBookDetails.Tables(0).Rows(0).Item("Name").ToString()
                oGetCoverNoteBookResponse.CoverNoteBranchKey = Cast.ToInt32(dsCoverNoteBookDetails.Tables(0).Rows(0).Item("source_id"), 0)

                If oGetCoverNoteBookResponse.CoverNoteBranchKey <= 0 Then
                    oGetCoverNoteBookResponse.CoverNoteBranchKeySpecified = False
                Else
                    oGetCoverNoteBookResponse.CoverNoteBranchKeySpecified = True
                End If

                oGetCoverNoteBookResponse.CoverNoteBranchCode = dsCoverNoteBookDetails.Tables(0).Rows(0).Item("CoverNoteBranchCode").ToString()

                oGetCoverNoteBookResponse.CoverNoteBookStatusKey = Cast.ToInt32(dsCoverNoteBookDetails.Tables(0).Rows(0).Item("cover_note_book_status_id"), 0)
                If oGetCoverNoteBookResponse.CoverNoteBookStatusKey <= 0 Then
                    oGetCoverNoteBookResponse.CoverNoteBookStatusKeySpecified = False
                Else
                    oGetCoverNoteBookResponse.CoverNoteBookStatusKeySpecified = True
                End If

                oGetCoverNoteBookResponse.CoverNoteBookStatusCode = dsCoverNoteBookDetails.Tables(0).Rows(0).Item("CoverNoteBookStatusCode").ToString()
                oGetCoverNoteBookResponse.DateCreated = Cast.ToDateTime(dsCoverNoteBookDetails.Tables(0).Rows(0).Item("created_date"), Date.MinValue)

                dsCoverNoteBookProducts = GetCoverNoteBookProducts(con, oGetCoverNoteBookRequest.CoverNoteBookKey)
                If dsCoverNoteBookProducts IsNot Nothing Then
                    If dsCoverNoteBookProducts.Tables(0).Rows.Count > 0 Then
                        dsResultantCoverNoteBookProducts = New DataSet
                        With dsCoverNoteBookProducts.Tables(0)

                            dsResultantCoverNoteBookProducts.Tables.Add()
                            dsResultantCoverNoteBookProducts.Tables(0).Columns.Add("ProductKey", GetType(System.Int32))
                            dsResultantCoverNoteBookProducts.Tables(0).Columns.Add("ProductCode", GetType(System.String))
                            dsResultantCoverNoteBookProducts.Tables(0).Columns.Add("Description", GetType(System.String))
                            dsResultantCoverNoteBookProducts.Tables(0).Columns.Add("Chosen", GetType(System.String))

                            For icount As Integer = 0 To .Rows.Count - 1
                                dsResultantCoverNoteBookProducts.Tables(0).Rows.Add()
                                dsResultantCoverNoteBookProducts.Tables(0).Rows(icount)("ProductKey") = .Rows(icount).Item("Product_Id")
                                dsResultantCoverNoteBookProducts.Tables(0).Rows(icount)("ProductCode") = .Rows(icount).Item("ProductCode")
                                dsResultantCoverNoteBookProducts.Tables(0).Rows(icount)("Description") = .Rows(icount).Item("description")
                                dsResultantCoverNoteBookProducts.Tables(0).Rows(icount)("Chosen") = .Rows(icount).Item("Chosen")
                            Next
                        End With
                        dsResultantCoverNoteBookProducts.DataSetName = "BaseGetCoverNoteBookResponseTypeCoverNoteBookProducts"
                        dsResultantCoverNoteBookProducts.Tables(0).TableName = "Row"
                        If oGetCoverNoteBookRequest.WCFSecurityToken = "" Then
                            DocCoverNoteBookProducts.LoadXml(dsResultantCoverNoteBookProducts.GetXml())
                            oGetCoverNoteBookResponse.ResultCoverNoteBookProductsDataset = DocCoverNoteBookProducts.DocumentElement()
                        End If

                        oGetCoverNoteBookResponse.ResultDataCoverNoteBookProduct = dsResultantCoverNoteBookProducts

                    End If
                End If

                dsCoverNoteSheets = GetCoverNoteSheets(con, oGetCoverNoteBookRequest.CoverNoteBookKey)
                If dsCoverNoteSheets IsNot Nothing Then
                    If dsCoverNoteSheets.Tables(0).Rows.Count > 0 Then

                        dsResultantCoverNoteSheets = New DataSet
                        With dsCoverNoteSheets.Tables(0)

                            dsResultantCoverNoteSheets.Tables.Add()
                            dsResultantCoverNoteSheets.Tables(0).Columns.Add("CoverNoteSheetKey", GetType(System.Int32))
                            dsResultantCoverNoteSheets.Tables(0).Columns.Add("CoverNoteSheetNumber", GetType(System.Int32))
