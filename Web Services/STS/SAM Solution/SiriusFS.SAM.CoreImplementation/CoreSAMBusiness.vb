    ''' <summary>
    ''' RunBatchRenewal
    ''' </summary>
    ''' <param name="request"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function RunBatchRenewal(ByVal con As SiriusConnection, ByVal request As BaseRunBatchRenewalRequestType) As BaseRunBatchRenewalResponseType
        Dim oResponse As New BaseRunBatchRenewalResponseType
        Dim oBatchJob As DataSet
        Dim sJobType As String = String.Empty
        Dim nInsuranceFileCnt As Integer = 0
        Dim sReference As String = String.Empty
        Dim nJobKey As Integer = 0
        Dim nRecordsInBatch As Integer = 0
        Dim nResult As Integer = PMEReturnCode.PMTrue
        Dim sMessage As String = String.Empty
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        If request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.RunBatchRenewalRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceV2ImplementationTypes.RunBatchRenewalResponseType
        End If

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Batch_Renewal_Job_Get")
            cmd.AddInParameter("@batch_id", SqlDbType.Int).Value = request.BatchId
            cmd.AddInParameter("@insurance_folder_cnt", SqlDbType.Int).Value = request.InsuranceFolderKey
            oBatchJob = con.ExecuteDataSet(cmd, "BatchDetails")
        End Using

        Debug.Assert(oBatchJob IsNot Nothing)
        Debug.Assert(oBatchJob.Tables.Contains("BatchDetails"))
        Debug.Assert(oBatchJob.Tables("BatchDetails").Rows.Count = 1)

        nJobKey = CInt(oBatchJob.Tables("BatchDetails").Rows(0).Item("batch_renewal_job_id"))
        sJobType = CStr(oBatchJob.Tables("BatchDetails").Rows(0).Item("job_type"))
        nRecordsInBatch = CInt(oBatchJob.Tables("BatchDetails").Rows(0).Item("records_in_batch"))
        sReference = CStr(oBatchJob.Tables("BatchDetails").Rows(0).Item("comment"))
        Try

            'Execute correct batch job
            Select Case sJobType
                Case "SEL"
                    nResult = RunRenewalSelectionBatch(con, request.BranchCode, request.BatchId, request.InsuranceFolderKey, nInsuranceFileCnt, sMessage)
                Case "INV"
                    Dim executeRequest As New SAMForInsuranceV2ImplementationTypes.RunRenewalInviteRequestType()
                    nInsuranceFileCnt = CInt(oBatchJob.Tables("BatchDetails").Rows(0).Item("new_insurance_file_cnt"))
                    executeRequest.BatchRenewalJobKey = nJobKey
                    executeRequest.BranchCode = request.BranchCode
                    executeRequest.GUID = sReference
                    executeRequest.InsuranceFileKey = nInsuranceFileCnt
                    executeRequest.LoginUserName = request.LoginUserName
                    executeRequest.SourceId = request.SourceId
                    executeRequest.RecordsCount = nRecordsInBatch
                    StartRenewalJob(con, request.BatchId, request.InsuranceFolderKey, nInsuranceFileCnt)
                    RunRenewalInvitation(con, executeRequest)
                    CompleteRenewalJob(con, request.BatchId, request.InsuranceFolderKey, nInsuranceFileCnt)
                Case "ACC"
                    Dim executeRequest As New SAMForInsuranceV2ImplementationTypes.RunRenewalAcceptRequestType()
                    nInsuranceFileCnt = CInt(oBatchJob.Tables("BatchDetails").Rows(0).Item("new_insurance_file_cnt"))
                    executeRequest.BatchRenewalJobKey = nJobKey
                    executeRequest.BranchCode = request.BranchCode
                    executeRequest.GUID = sReference
                    executeRequest.InsuranceFileKey = nInsuranceFileCnt
                    executeRequest.LoginUserName = request.LoginUserName
                    executeRequest.SourceId = request.SourceId
                    executeRequest.RecordsCount = nRecordsInBatch
                    StartRenewalJob(con, request.BatchId, request.InsuranceFolderKey, nInsuranceFileCnt)
                    RunRenewalAccept(con, executeRequest)
                    CompleteRenewalJob(con, request.BatchId, request.InsuranceFolderKey, nInsuranceFileCnt)
                Case Else
                    Throw New NotImplementedException(String.Format("Job Type: {0} is not implemented", sJobType))
            End Select
        Catch ex As Exception
            nResult = PMEReturnCode.PMError
            sMessage = ex.Message
        End Try

        oResponse.result = nResult
        oResponse.message = sMessage
        oResponse.insuranceFileKey = nInsuranceFileCnt
        Return oResponse
    End Function
    ''' <summary>
    ''' Start Renewal Job
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="batchId"></param>
    ''' <param name="insuranceFolderKey"></param>
    ''' <param name="insuranceFileKey"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function StartRenewalJob(ByVal con As SiriusConnection, ByVal batchId As Integer, ByVal insuranceFolderKey As Integer, ByVal insuranceFileKey As Integer) As Boolean
        Dim dsResult As DataSet

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Batch_Renewal_Job_Start")
            cmd.AddInParameter("@batch_id", SqlDbType.Int).Value = batchId
            cmd.AddInParameter("@insurance_folder_cnt", SqlDbType.Int).Value = insuranceFolderKey
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = insuranceFileKey
            dsResult = con.ExecuteDataSet(cmd, "BatchDetails")
        End Using

        If dsResult Is Nothing OrElse Not dsResult.Tables.Contains("BatchDetails") Then
            Return False
        End If

        Return dsResult.Tables("BatchDetails").Rows.Count = 1

    End Function
