    ByVal oRequest As BaseGetRatingSectionByRiskTypeRequestType) As BaseGetRatingSectionByRiskTypeResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseGetRatingSectionByRiskTypeResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iRiskTypeId As Integer
        Dim dsResult As DataSet

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetRatingSectionByRiskTypeRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetRatingSectionByRiskTypeResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        oRequest.Validate(CType(oSAMErrorCollection, Object))

        oSAMErrorCollection.CheckForErrors()

        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        If (Not String.IsNullOrEmpty(oRequest.RiskTypeCode)) Then
            iRiskTypeId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.RiskType, oRequest.RiskTypeCode, "RiskTypeCode", oSAMErrorCollection)
        End If

        ' validate the policy number 
        oSAMErrorCollection.CheckForErrors()

        Try
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Rating_Section_For_Risk_Type")
                cmd.AddInParameter("@risk_type_id", SqlDbType.Int, 10).Value = iRiskTypeId
                dsResult = con.ExecuteDataSet(cmd, "Row")
