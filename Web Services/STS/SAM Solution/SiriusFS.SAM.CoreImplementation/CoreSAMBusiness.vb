    Public Overloads Function RetrieveRisk(ByVal con As SiriusConnection, ByVal RetrieveRiskInput As BaseGetRiskRequestType,
                                           ByVal TransactionType As String, ByRef r_onIsOOSMTAReplacedVersion As Integer) As BaseGetRiskResponseType

        Const ACMethodName As String = "RetrieveRisk"

        Dim iRet As Integer
        Dim oBusiness As New CoreBusiness(_SiriusUser)
        Dim Utils As New Utilities
        Dim oGetRiskOut As New BaseImplementationTypes.BaseGetRiskResponseType
        Dim oRetrievePremiumData As New BaseImplementationTypes.BaseGetRiskResponseType
        Dim oLoadRiskFromDBIn As New LoadRiskFromDBIn
        Dim oLoadRiskFromDBOut As New LoadRiskFromDBOut
        Dim oErrors As New SAMErrorCollection
        Dim blAlreadyLocked As Boolean
        Dim errLockError As STSErrorType = Nothing
        Dim oDatabase As Object = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oAgentRequest As AgentImplementationTypes.GetRiskRequestType = Nothing
        Dim samForBrokingRequest As SAMForBrokingImplementationTypes.GetRiskRequestType = Nothing
        Dim sDataModelCode As String = String.Empty

        If RetrieveRiskInput.GetType Is GetType(AgentImplementationTypes.GetRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AgentsPackage
            oGetRiskOut = New AgentImplementationTypes.GetRiskResponseType
            oAgentRequest = DirectCast(RetrieveRiskInput, AgentImplementationTypes.GetRiskRequestType)
        ElseIf RetrieveRiskInput.GetType Is GetType(AnonymousImplementationTypes.GetRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AnonymousPackage
            oGetRiskOut = New AnonymousImplementationTypes.GetRiskResponseType
        ElseIf RetrieveRiskInput.GetType Is GetType(CustomerImplementationTypes.GetRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.CustomersPackage
            oGetRiskOut = New CustomerImplementationTypes.GetRiskResponseType
        ElseIf RetrieveRiskInput.GetType Is GetType(BaseImplementationTypes.BaseGetRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            oGetRiskOut = New BaseImplementationTypes.BaseGetRiskResponseType
        ElseIf RetrieveRiskInput.GetType Is GetType(SAMForInsuranceImplementationTypes.GetRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetRiskOut = New SAMForInsuranceImplementationTypes.GetRiskResponseType
        ElseIf RetrieveRiskInput.GetType Is GetType(SAMForBrokingImplementationTypes.GetRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oGetRiskOut = New SAMForBrokingImplementationTypes.GetRiskResponseType
            samForBrokingRequest = DirectCast(RetrieveRiskInput, SAMForBrokingImplementationTypes.GetRiskRequestType)
        ElseIf RetrieveRiskInput.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetRiskOut = New SAMForInsuranceV2ImplementationTypes.GetRiskResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim STSError As New STSErrorPublisher
        If nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            If CoreBusiness.PartyIsAgent(samForBrokingRequest.UserPartyType) Then
                If oBusiness.CheckAgentKey(samForBrokingRequest.UserPartyKey) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.AgentRecordNotFound, "Agent Key validation failed", "The Agent record does not exist for key: " & samForBrokingRequest.UserPartyKey)
                    STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Key Validation", True)
                    Return oGetRiskOut
                End If

                If oBusiness.AgentSecurityCheck(samForBrokingRequest.UserName, samForBrokingRequest.InsuranceFileKey, PMEEntityType.InsuranceFile) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security Check Failed", samForBrokingRequest.UserName & " does not have permission to access insurance file " & samForBrokingRequest.InsuranceFileKey)
                    STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "RetrieveRisk", True)
                    Return oGetRiskOut
                End If
            End If
        End If

        If RetrieveRiskInput.BranchCode = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        End If

        If RetrieveRiskInput.InsuranceFolderKey = 0 Then
            STSError.AddInvalidField("InsuranceFolderKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "InsuranceFolderKey"), "")
        End If

        If RetrieveRiskInput.InsuranceFileKey = 0 Then
            STSError.AddInvalidField("InsuranceFileKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "InsuranceFileKey"), "")
        End If

        If RetrieveRiskInput.RiskKey = 0 Then
            STSError.AddInvalidField("RiskKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "RiskKey"), "")
        End If

        If RetrieveRiskInput.QuoteTimeStamp Is Nothing Then
            STSError.AddInvalidField("QuoteTimeStamp", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "QuoteTimeStamp"), "")
        End If

        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return oGetRiskOut
        End If

        Dim iSourceID As Int32
        iSourceID% = 1
        ' Convert branch code to ID      
        If (Not String.IsNullOrEmpty(RetrieveRiskInput.BranchCode)) Then
            iSourceID% = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
            PMLookupTable.Source, RetrieveRiskInput.BranchCode, "BranchCode", oErrors)
        End If

        If STSError.HasErrors Then
            STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Lookup field validation", True)
            Return oGetRiskOut
        End If

        ' Check the insurance folder cnt is valid
        'If oBusiness.CheckInsuranceFolder(con, RetrieveRiskInput.InsuranceFolderKey) = False Then
        '    STSError = New STSErrorPublisher(STSErrorCodes.PolicyRecordNotFound, "Insurance Folder validation failed", "The Insurance Folder record does not exist for key: " & RetrieveRiskInput.InsuranceFolderKey)
        '    STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
        '    Return oGetRiskOut
        'End If
        '' Check the insurance file cnt is valid
        'Dim iFileFolderCnt As Integer
        'If oBusiness.CheckInsuranceFile(con, RetrieveRiskInput.InsuranceFileKey, iFileFolderCnt) = False Then
        '    STSError = New STSErrorPublisher(STSErrorCodes.PolicyRecordNotFound, "Insurance File validation failed", "The Insurance File record does not exist for key: " & RetrieveRiskInput.InsuranceFileKey)
        '    STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
        '    Return oGetRiskOut
        'End If
        Dim iFileFolderCnt As Integer

        If oBusiness.CheckInsuranceParams(con:=con,
                                          nInsurancefolderCnt:=RetrieveRiskInput.InsuranceFolderKey,
                                          nInsuranceFileCnt:=RetrieveRiskInput.InsuranceFileKey,
                                          nRiskCnt:=RetrieveRiskInput.RiskKey,
                                          r_nInsuranceFolderCnt:=iFileFolderCnt) = False Then
            STSError = New STSErrorPublisher(STSErrorCodes.PolicyRecordNotFound, "Validation failed", "The InsuranceFolder/InsuranceFile/Risk record does not exist for:  Insurance Folder" & RetrieveRiskInput.InsuranceFolderKey & " , Insurance File : " & RetrieveRiskInput.InsuranceFileKey & " , Risk cnt = " & RetrieveRiskInput.RiskKey)
            STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
            Return oGetRiskOut
        End If
        If iFileFolderCnt <> RetrieveRiskInput.InsuranceFolderKey Then
            STSError = New STSErrorPublisher(STSErrorCodes.PolicyMismatch, "Insurance File validation failed", "The Insurance File's Folder does not match the passed InsuranceFolder")
            STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
            Return oGetRiskOut
        End If
        '' Check the risk cnt is valid
        'If oBusiness.CheckRisk(con, RetrieveRiskInput.RiskKey) = False Then
        '    STSError = New STSErrorPublisher(STSErrorCodes.RiskRecordNotFound, "Risk validation failed", "The Risk record does not exist for key: " & RetrieveRiskInput.RiskKey)
        '    STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
        '    Return oGetRiskOut
        'End If
        'If oBusiness.CheckPolicyRiskLink(con, RetrieveRiskInput.InsuranceFileKey, RetrieveRiskInput.RiskKey) = False Then
        '    STSError = New STSErrorPublisher(STSErrorCodes.PolicyRiskLinkRecordNotFound, "Risk validation failed", "The Risk (" & RetrieveRiskInput.RiskKey & ") is not linked to the Insurance File key: " & RetrieveRiskInput.InsuranceFileKey)
        '    STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
        '    Return oGetRiskOut
        'End If

        If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            If (oBusiness.AgentSecurityCheck(oAgentRequest.UserName, oAgentRequest.InsuranceFileKey, PMEEntityType.InsuranceFile) = False) Then
                Dim STSErr As New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security check failed", oAgentRequest.UserName & " does not have permission to access policy " & oAgentRequest.InsuranceFileKey)
                STSErr.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "RetrieveRisk", True)
                Return oGetRiskOut
            End If
        End If

        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return oGetRiskOut
        End If

        Dim AnyError As STSErrorType

        If Not RetrieveRiskInput.IgnoreLocking Then

            ' Check that the timestamp matches and lock the Quote
            AnyError = oBusiness.CheckTSAndLock(
                BranchCode:=RetrieveRiskInput.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=RetrieveRiskInput.InsuranceFolderKey,
                TStamp:=RetrieveRiskInput.QuoteTimeStamp)

            If AnyError Is Nothing = False Then
                errLockError = AnyError
                blAlreadyLocked = True
            End If

        End If
        Dim nriskKey As Integer = RetrieveRiskInput.RiskKey
        If RetrieveRiskInput.isForEdit AndAlso
            (RetrieveRiskInput.riskLinkStatusFlag.ToUpper() = RiskLinkStatusType.Unchanged OrElse
            RetrieveRiskInput.riskLinkStatusFlag.ToUpper() = RiskLinkStatusType.Renewed) Then
            If RetrieveRiskInput.riskLinkStatusFlag.ToUpper() = RiskLinkStatusType.Renewed Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_DeleteTaxDetailsForBatchRenewals")
                    cmd.AddInParameter("@InsuranceFileCnt", SqlDbType.Int).Value = RetrieveRiskInput.InsuranceFileKey
                    cmd.AddInParameter("@RiskCnt", SqlDbType.Int).Value = RetrieveRiskInput.RiskKey
                    con.ExecuteNonQuery(cmd)
                End Using
            End If
            Dim tranType As TransactionType = BaseImplementationTypes.TransactionType.MTA
            ProcessCopyMTARisk(con, RetrieveRiskInput.BranchCode, RetrieveRiskInput.InsuranceFileKey, RetrieveRiskInput.RiskKey, nriskKey, tranType)
            If nriskKey <> 0 Then
                RetrieveRiskInput.RiskKey = nriskKey
            End If
        End If
        oLoadRiskFromDBIn.InsuranceFileCnt = RetrieveRiskInput.InsuranceFolderKey
        oLoadRiskFromDBIn.InsuranceFolderCnt = RetrieveRiskInput.InsuranceFolderKey
        oLoadRiskFromDBIn.RiskID = RetrieveRiskInput.RiskKey

        Try
            oLoadRiskFromDBOut = oBusiness.LoadRiskFromDB(con, oLoadRiskFromDBIn)
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToLoadRiskDB, "Failed to load risk data", ex.Message)
            STSErrorEx.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "LoadRiskData", True)
            Return oGetRiskOut
        End Try

        oGetRiskOut.XMLDataSet = oLoadRiskFromDBOut.XMLDataSet

        Dim oGIS As bGIS.Application = Nothing
        Try
            oGIS = New bGIS.Application
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bGIS.Application", ex.Message)
            STSErrorEx.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "CreatebGISSTS", True)
            Return oGetRiskOut
        End Try

        Try
            SAMFunc.InitialiseGIS(Con:=con, oGIS:=oGIS, SiriusUser:=_SiriusUser, sBranchCode:=RetrieveRiskInput.BranchCode)
        Catch ex As Exception
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bGIS.Application", ex.Message)
            STSErrorEx.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "oGIS.Initialise", True)
            Return oGetRiskOut
        End Try

        Dim insuranceFileTypeId As Integer
        Dim insuranceFileTypeCode As String
        Dim sProductCode As String = "NB"

        GetInsuranceFileType(con, RetrieveRiskInput.InsuranceFileKey, insuranceFileTypeId, insuranceFileTypeCode, 0, r_onIsOOSMTAReplacedVersion)

        Select Case insuranceFileTypeCode
            Case InsuranceFileType.LivePolicy, InsuranceFileType.Quote
                sProductCode = "NB"

            Case InsuranceFileType.MTAPermanentQuotation, InsuranceFileType.MTATemporaryQuotation,
                 InsuranceFileType.MTAPermanent, InsuranceFileType.MTATemporary,
                 InsuranceFileType.MTAQuotationReinstatement, InsuranceFileType.MTAReinstated, InsuranceFileType.MTAQuotationCancellation

                sProductCode = "MTA"

            Case InsuranceFileType.Renewal
                sProductCode = "REN"

            Case InsuranceFileType.MTACancellation
                sProductCode = "MTC"

        End Select
        iRet = oGIS.SetProcessModes(SAMComponentAction.PMEdit, 0, 0, Cast.ToObjString(sProductCode), Now)

        Dim decPremiumDueGross As Decimal
        Dim decPremiumDueNet As Decimal
        Dim decPremiumDueTax As Decimal
        Dim decTotalAnnualTax As Decimal
        Dim decPolicyLevelTax As Decimal
        Dim decPolicyFeesAmount As Decimal
        Dim decRiskFeesAmount As Decimal

        Try


            Dim decPremiumDueGrossObject As Decimal = decPremiumDueGross
            Dim decPremiumDueNetObject As Decimal = decPremiumDueNet
            Dim decPremiumDueTaxObject As Decimal = decPremiumDueTax
            Dim decTotalAnnualTaxObject As Decimal = decTotalAnnualTax

            iRet = oGIS.GetPremiumData(
                            v_lInsuranceFileCnt:=RetrieveRiskInput.InsuranceFileKey,
                            v_lInsuranceFolderCnt:=RetrieveRiskInput.InsuranceFolderKey,
                            v_lRiskID:=RetrieveRiskInput.RiskKey,
                            r_cPremiumDueGross:=decPremiumDueGrossObject,
                            r_cPremiumDueNet:=decPremiumDueNetObject,
                            r_cPremiumDueTax:=decPremiumDueTaxObject,
                            r_cTotalAnnualTax:=decTotalAnnualTaxObject)

            If (iRet <> 1) Then
                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToRetrievePremiumDetails, "Failed to load premium data", RetrieveRiskInput.InsuranceFileKey.ToString)
                STSErrorEx.SetContext(oGetRiskOut.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "LoadPremiumData", True)
            End If

            decPremiumDueGross = Cast.ToDecimal(decPremiumDueGrossObject, 0)
            decPremiumDueNet = Cast.ToDecimal(decPremiumDueNetObject, 0)
            decPremiumDueTax = Cast.ToDecimal(decPremiumDueTaxObject, 0)
            decTotalAnnualTax = Cast.ToDecimal(decTotalAnnualTaxObject, 0)

        Catch ex As Exception
            Dim STSError3 As New STSErrorPublisher("bGis.Application.GetPremiumData failed", ex)
            STSError3.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetPremiumDataReturn", True)
        End Try

        Try
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to terminate business", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "Terminate", True)
        End Try

        oGetRiskOut.RiskLevelTaxesAndFees = New BaseTaxesAndFeesType
        oGetRiskOut.PolicyLevelTaxesAndFees = New BaseTaxesAndFeesType

        Call GetProRataRate(con, RetrieveRiskInput.RiskKey, oGetRiskOut.proRataRate)

        Call GetRiskTaxesAndFees(con, RetrieveRiskInput.InsuranceFileKey, RetrieveRiskInput.RiskKey, RetrieveRiskInput.BranchCode, decPremiumDueTax, decRiskFeesAmount, oGetRiskOut.RiskLevelTaxesAndFees)

        Call GetPolicyTaxesAndFees(con, RetrieveRiskInput.InsuranceFileKey, RetrieveRiskInput.BranchCode, decPolicyLevelTax, decPolicyFeesAmount, oGetRiskOut.PolicyLevelTaxesAndFees)

        ' Work out the new Gross premium for the risk only
        decPremiumDueGross = decPremiumDueNet + decPremiumDueTax

        decPremiumDueGross = decPremiumDueGross + decRiskFeesAmount

        With oGetRiskOut
            .PremiumDueGross = Decimal.Round(decPremiumDueGross, 2)
            .PremiumDueNet = Decimal.Round(decPremiumDueNet, 2)
            .PremiumDueTax = Decimal.Round(decPremiumDueTax, 2)
            .TotalAnnualTax = Decimal.Round(decTotalAnnualTax, 2)
            .PolicyLevelTax = Decimal.Round(decPolicyLevelTax, 2)
            .PolicyLevelFees = Decimal.Round(decPolicyFeesAmount, 2)
            .QuoteTimeStamp = RetrieveRiskInput.QuoteTimeStamp
            .riskKey = nriskKey
        End With

        If Not RetrieveRiskInput.IgnoreLocking Then

            ' If the record was already locked then don't attempt to unlock, just return the lock message
            If blAlreadyLocked = True Then
                oGetRiskOut.STSError = errLockError
                Return oGetRiskOut
            Else
                ' Unlock and return the new timestamp
                AnyError = oBusiness.UnlockAndGetTS(
                    BranchCode:=RetrieveRiskInput.BranchCode,
                    Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                    LockValue:=RetrieveRiskInput.InsuranceFolderKey,
                    TStamp:=oGetRiskOut.QuoteTimeStamp)
                ' Check for Errors
                If AnyError Is Nothing = False Then
                    ' Unable to unlock, return the error. 
                    oGetRiskOut.STSError = AnyError
                    Return oGetRiskOut
                End If
            End If

        End If

        If nTypeOfPackage = enumTypeOfPackage.AnonymousPackage Then
            Dim oGetRiskOutAnon As New AnonymousImplementationTypes.GetRiskResponseType
            oGetRiskOutAnon = DirectCast(oGetRiskOut, AnonymousImplementationTypes.GetRiskResponseType)
            oGetRiskOut = oGetRiskOutAnon
        ElseIf nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            Dim oGetRiskOutAgent As New AgentImplementationTypes.GetRiskResponseType
            oGetRiskOutAgent = DirectCast(oGetRiskOut, AgentImplementationTypes.GetRiskResponseType)
            oGetRiskOut = oGetRiskOutAgent
        ElseIf nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            Dim oGetRiskOutsamforbroking As New SAMForBrokingImplementationTypes.GetRiskResponseType
            oGetRiskOutsamforbroking = DirectCast(oGetRiskOut, SAMForBrokingImplementationTypes.GetRiskResponseType)
            Dim xmlDoc As New System.Xml.XmlDocument
            xmlDoc.LoadXml(oGetRiskOutsamforbroking.XMLDataSet)
            sDataModelCode = xmlDoc.SelectSingleNode("DATA_SET").Attributes("DataModelCode").Value

            'READ XML OUTPUT AND SET PREMIUMValues
            Dim cPremiumDueNet As Decimal
            Dim cPremiumDueTax As Decimal
            Dim cCommissionAmount As Decimal
            Dim lGisPolicyLinkId As Long
            Dim dTaxRate As Decimal

            If Not IsNothing(xmlDoc.SelectSingleNode("DATA_SET").SelectSingleNode("RISK_OBJECTS").SelectSingleNode(sDataModelCode & "_POLICY_BINDER").SelectSingleNode(sDataModelCode & "_OUTPUT")) Then
                cPremiumDueNet = Cast.ToDecimal(xmlDoc.SelectSingleNode("DATA_SET").SelectSingleNode("RISK_OBJECTS").SelectSingleNode(sDataModelCode & "_POLICY_BINDER").SelectSingleNode(sDataModelCode & "_OUTPUT").Attributes("PREMIUM_MINUS_IPT").Value, 0)
            End If

            If Not IsNothing(xmlDoc.SelectSingleNode("DATA_SET").SelectSingleNode("RISK_OBJECTS").SelectSingleNode(sDataModelCode & "_POLICY_BINDER")) Then
                lGisPolicyLinkId = Cast.ToInt64(xmlDoc.SelectSingleNode("DATA_SET").SelectSingleNode("RISK_OBJECTS").SelectSingleNode(sDataModelCode & "_POLICY_BINDER").Attributes("GIS_POLICY_LINK_ID").Value, 0)
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ipt_from_policy_link_sel")
                    Dim ds As DataSet
                    cmd.AddInParameter("@gis_policy_link_id", SqlDbType.Int).SqlValue = lGisPolicyLinkId
                    cmd.AddInParameter("@effective_date", SqlDbType.DateTime).SqlValue = Now()
                    ds = con.ExecuteDataSet(cmd, "TaxRate")

                    If ds.Tables("TaxRate").Rows.Count > 0 Then
                        Try
                            dTaxRate = Cast.ToDecimal(ds.Tables(0).Rows(0).Item(0).ToString, 0)
                        Catch ex As Exception
                            Dim STSErrorEx As New STSErrorPublisher("Failed to Get Tax Rate.", ex)
                            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "RetrieveRisk", True)
                        End Try
                    End If
                End Using
                If dTaxRate <> 0 Then
                    cPremiumDueTax = cPremiumDueNet * (dTaxRate / 100)
                End If
            End If

            If Not IsNothing(xmlDoc.SelectSingleNode("DATA_SET").SelectSingleNode("RISK_OBJECTS").SelectSingleNode(sDataModelCode & "_POLICY_BINDER").SelectSingleNode(sDataModelCode & "_OUTPUT")) Then
                If Not IsNothing(xmlDoc.SelectSingleNode("DATA_SET").SelectSingleNode("RISK_OBJECTS").SelectSingleNode(sDataModelCode & "_POLICY_BINDER").SelectSingleNode(sDataModelCode & "_OUTPUT").SelectSingleNode(sDataModelCode & "_OUTPUT_FEES")) Then
                    cCommissionAmount = Cast.ToDecimal(xmlDoc.SelectSingleNode("DATA_SET").SelectSingleNode("RISK_OBJECTS").SelectSingleNode(sDataModelCode & "_POLICY_BINDER").SelectSingleNode(sDataModelCode & "_OUTPUT").SelectSingleNode(sDataModelCode & "_OUTPUT_FEES").Attributes("COMMISSION_AMOUNT").Value, 0)
                End If
            End If
            oGetRiskOutsamforbroking.PremiumDueNet = cPremiumDueNet
            oGetRiskOutsamforbroking.PremiumDueTax = cPremiumDueTax
            oGetRiskOutsamforbroking.CommissionAmount = cCommissionAmount
            oGetRiskOutsamforbroking.PremiumDueGross = oGetRiskOutsamforbroking.PremiumDueNet + oGetRiskOutsamforbroking.PremiumDueTax
            oGetRiskOutsamforbroking.TotalAnnualTax = oGetRiskOutsamforbroking.PremiumDueTax
            PopulatePolicySections(con,
                  oGetRiskOutsamforbroking.XMLDataSet,
                  sDataModelCode,
                  oGetRiskOutsamforbroking.PolicySectionsXml,
                  oGetRiskOutsamforbroking.PolicyCoinsurerSectionsXml,
                  "GetRiskResponseTypePolicySections",
                  "Row",
                  "GetRiskResponseTypePolicyCoinsurerSections",
                  "Row")

            oGetRiskOut = oGetRiskOutsamforbroking
        End If

        Return oGetRiskOut
    End Function

    ' ***************************************************************** '
    ' Name: UpdateRisk
    '
    ' Description: 
    '
    ' ***************************************************************** '
    Public Overloads Function UpdateRisk(ByVal UpdateRiskRequest As BaseUpdateRiskRequestType) As BaseUpdateRiskResponseType
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)
            Dim oResponse As BaseUpdateRiskResponseType

            oResponse = UpdateRisk(con, UpdateRiskRequest)

            Return oResponse

        End Using

    End Function

    Public Overloads Function UpdateRisk(ByVal con As SiriusConnection, ByVal UpdateRiskRequest As BaseUpdateRiskRequestType) As BaseUpdateRiskResponseType

        Dim oResponse As BaseUpdateRiskResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim sDataModelCode As String = String.Empty
        Dim vAdditionalDataArray() As AdditionalData
        Dim iSourceID As Int32
        Dim sXMLDataset As String = String.Empty
        Dim sUserName As String = ""
        Const ACMethodName As String = "UpdateRisk"

        Dim STSError As New STSErrorPublisher

        'Write Away Data and Generate return Values (if rules to be ran).
        Dim oSaveToDBRequest As New SaveToDBIn
        Dim oSaveToDBResponse As SaveToDBOut
        Dim oAgentRequest As AgentImplementationTypes.UpdateRiskRequestType = Nothing
        Dim samForBrokingRequest As SAMForBrokingImplementationTypes.UpdateRiskRequestType = Nothing

        If UpdateRiskRequest.GetType Is GetType(AnonymousImplementationTypes.UpdateRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AnonymousPackage
            oResponse = New AnonymousImplementationTypes.UpdateRiskResponseType
        ElseIf UpdateRiskRequest.GetType Is GetType(AgentImplementationTypes.UpdateRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AgentsPackage
            oResponse = New AgentImplementationTypes.UpdateRiskResponseType
            oAgentRequest = DirectCast(UpdateRiskRequest, AgentImplementationTypes.UpdateRiskRequestType)
        ElseIf UpdateRiskRequest.GetType Is GetType(CustomerImplementationTypes.UpdateRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.CustomersPackage
            oResponse = New CustomerImplementationTypes.UpdateRiskResponseType
        ElseIf UpdateRiskRequest.GetType Is GetType(BaseImplementationTypes.BaseUpdateRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            oResponse = New BaseImplementationTypes.BaseUpdateRiskResponseType
        ElseIf UpdateRiskRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.UpdateRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.UpdateRiskResponseType
            Dim oSamForInsuranceRequest As SAMForInsuranceImplementationTypes.UpdateRiskRequestType = DirectCast(UpdateRiskRequest, SAMForInsuranceImplementationTypes.UpdateRiskRequestType)
            sUserName = oSamForInsuranceRequest.UserName
        ElseIf UpdateRiskRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateRiskResponseType
            Dim oSamForInsuranceV2Request As SAMForInsuranceV2ImplementationTypes.UpdateRiskRequestType = DirectCast(UpdateRiskRequest, SAMForInsuranceV2ImplementationTypes.UpdateRiskRequestType)
            sUserName = oSamForInsuranceV2Request.UserName
        ElseIf UpdateRiskRequest.GetType Is GetType(SAMForBrokingImplementationTypes.UpdateRiskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oResponse = New SAMForBrokingImplementationTypes.UpdateRiskResponseType
            samForBrokingRequest = DirectCast(UpdateRiskRequest, SAMForBrokingImplementationTypes.UpdateRiskRequestType)
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        If nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            If CoreBusiness.PartyIsAgent(samForBrokingRequest.UserPartyType) Then
                If oCoreBusiness.CheckAgentKey(samForBrokingRequest.UserPartyKey) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.AgentRecordNotFound, "Agent Key validation failed", "The Agent record does not exist for key: " & samForBrokingRequest.UserPartyKey)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Key Validation", True)
                    Return oResponse
                End If

                If oCoreBusiness.AgentSecurityCheck(samForBrokingRequest.UserName, samForBrokingRequest.InsuranceFileKey, PMEEntityType.InsuranceFile) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security Check Failed", samForBrokingRequest.UserName & " does not have permission to access insurancefile " & samForBrokingRequest.InsuranceFileKey)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", True)
                    Return oResponse
                End If
            End If
        End If

        'Check Mandatory Fields
        If SAMFunc.NothingToString(UpdateRiskRequest.XMLDataSet) = "" Then
            ' XMLDataSet not set
            STSError.AddInvalidField("XMLDataSet", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "XMLDataSet"), "")
        End If

        If UpdateRiskRequest.BranchCode = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        End If

        If UpdateRiskRequest.InsuranceFileKey = 0 Then
            STSError.AddInvalidField("InsuranceFileKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "InsuranceFileKey"), "")
        End If

        If UpdateRiskRequest.InsuranceFolderKey = 0 Then
            STSError.AddInvalidField("InsuranceFolderKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "InsuranceFolderKey"), "")
        End If

        If UpdateRiskRequest.ScreenCode = "" Then
            STSError.AddInvalidField("ScreenCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "ScreenCode"), "")
        End If

        If UpdateRiskRequest.RiskKey = 0 Then
            STSError.AddInvalidField("RiskKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "RiskKey"), "")
        End If

        If UpdateRiskRequest.QuoteTimeStamp Is Nothing Then
            STSError.AddInvalidField("QuoteTimeStamp", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "QuoteTimeStamp"), "")
        End If

        If UpdateRiskRequest.RiskDescription = "" Then
            STSError.AddInvalidField("RiskDescription", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "RiskDescription"), "")
        End If

        ' default to new business if not provided
        If String.IsNullOrEmpty(UpdateRiskRequest.TransactionType) Then
            UpdateRiskRequest.TransactionType = TransactionTypeCode.NewBusiness
        End If

        ' transactionType - pmproduct lookup
        Dim transactionTypeID As Integer = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.TransactionType, UpdateRiskRequest.TransactionType, "TransactionType")

        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return oResponse
        End If

        ' If this is a renewal then check that the policy is in the renewals cycle
        If UpdateRiskRequest.TransactionType = TransactionTypeCode.Renewals Then
            ValidatePolicyIsInRenewal(con, UpdateRiskRequest.InsuranceFileKey)
        End If

        iSourceID% = 1

        ' Convert branch code to ID
        Try
            iSourceID% = oCoreBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "Source", UpdateRiskRequest.BranchCode)
        Catch ex As Exception
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.BranchCodeInvalid), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "BranchCode"), UpdateRiskRequest.BranchCode)
        End Try

        'Try
        '    Dim xmlDocTest As New System.Xml.XmlDocument
        '    xmlDocTest.LoadXml(UpdateRiskRequest.XMLDataSet)
        'Catch ex As Exception
        '    STSError.AddInvalidField("XmlDataSet", CStr(STSErrorCodes.XmldatasetBadlyFormed), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "XmlDataSet"), UpdateRiskRequest.XMLDataSet)
        'End Try

        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Lookup field validation", True)
            Return oResponse
        End If

        Dim iFileFolderCnt As Integer
        ' Check the insurance folder cnt/insurance file cnt is valid

        If oCoreBusiness.CheckInsuranceParams(con:=con, nInsurancefolderCnt:=UpdateRiskRequest.InsuranceFolderKey,
                                              nInsuranceFileCnt:=UpdateRiskRequest.InsuranceFileKey,
                                              nRiskCnt:=UpdateRiskRequest.RiskKey, r_nInsuranceFolderCnt:=iFileFolderCnt, bCheckStatusForUpdating:=True) = False Then
            STSError = New STSErrorPublisher(STSErrorCodes.PolicyRecordNotFound, "Validation failed", "The InsuranceFolder/InsuranceFile/Risk record does not exist for:  Insurance Folder" & UpdateRiskRequest.InsuranceFolderKey & " , Insurance File : " & UpdateRiskRequest.InsuranceFileKey & " , Risk cnt = " & UpdateRiskRequest.RiskKey)
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
            Return oResponse
        End If

        If iFileFolderCnt <> UpdateRiskRequest.InsuranceFolderKey Then
            STSError = New STSErrorPublisher(STSErrorCodes.PolicyMismatch, "Insurance File validation failed", "The Insurance File's Folder does not match the passed InsuranceFolder")
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
            Return oResponse
        End If

        If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            If (oCoreBusiness.AgentSecurityCheck(con, oAgentRequest.UserName, oAgentRequest.InsuranceFileKey, PMEEntityType.InsuranceFile) = False) Then
                STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security check failed", oAgentRequest.UserName & " does not have permission to access policy " & oAgentRequest.InsuranceFileKey)
                STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", True)
                Return oResponse
            End If
        ElseIf nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            If (oCoreBusiness.AgentSecurityCheck(con, samForBrokingRequest.UserName, samForBrokingRequest.InsuranceFileKey, PMEEntityType.InsuranceFile) = False) Then
                STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security check failed", samForBrokingRequest.UserName & " does not have permission to access policy " & samForBrokingRequest.InsuranceFileKey)
                STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", True)
                Return oResponse
            End If
        End If

        ' Check that the timestamp matches and lock the Quote
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.CheckTSAndLock(con,
            BranchCode:=UpdateRiskRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=UpdateRiskRequest.InsuranceFolderKey,
            TStamp:=UpdateRiskRequest.QuoteTimeStamp)
        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oResponse.STSError = AnyError
            Return oResponse
        End If

        ' Get the Data Model Code
        Dim xmlDoc As New System.Xml.XmlDocument
        xmlDoc.LoadXml(UpdateRiskRequest.XMLDataSet)
        sDataModelCode = xmlDoc.SelectSingleNode("DATA_SET") _
            .Attributes("DataModelCode").Value
        ' Set up Underwriting additional data
        ReDim vAdditionalDataArray(2)
        Dim oData As AdditionalData
        oData = New AdditionalData
        oData.Name = InternalSAMConstants.CNInsuranceFileCnt
        oData.Value = UpdateRiskRequest.InsuranceFileKey
        vAdditionalDataArray(0) = oData
        oData = New AdditionalData
        oData.Name = InternalSAMConstants.CNInsuranceFolderCnt
        oData.Value = UpdateRiskRequest.InsuranceFolderKey
        vAdditionalDataArray(1) = oData
        oData = New AdditionalData
        oData.Name = InternalSAMConstants.CNCurrentRiskCnt
        oData.Value = UpdateRiskRequest.RiskKey
        vAdditionalDataArray(2) = oData

        sXMLDataset = UpdateRiskRequest.XMLDataSet

        oSaveToDBRequest.BusinessTypeCode = "NB"
        oSaveToDBRequest.DataModelCode = sDataModelCode
        oSaveToDBRequest.XMLDataset = sXMLDataset

        oSaveToDBResponse = oCoreBusiness.SaveToDB(con, oSaveToDBRequest)

        'Run Rules
        Dim oQuoteOut As NBQuoteOut = Nothing
        Dim oQuoteIn As New NBQuoteIn
        Dim iScreenID As Integer

        Try
            iScreenID% = oCoreBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "gis_screen", UpdateRiskRequest.ScreenCode)
        Catch ex As Exception
            STSError.AddInvalidField("ScreenCode", CStr(STSErrorCodes.InvalidLookupListValue), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "ScreenCode"), UpdateRiskRequest.ScreenCode)
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Lookup field validation", True)
            Return oResponse
        End Try

        With oQuoteIn
            .BusinessTypeCode = "NB"
            .DataModelCode = sDataModelCode
            .EffectiveDate = Date.Today
            .RiskScreenId = iScreenID
            .XMLDataset = oSaveToDBResponse.XMLDataset
            .AdditionalDataArray = vAdditionalDataArray
        End With

        Dim blReferred As Boolean
        Dim blDeclined As Boolean

        ' Clear all previous quote output
        ClearRiskOutput(sDataModelCode, oQuoteIn.XMLDataset)

        '****************************************'****************************************'****************************************
        '****************************************'****************************************'****************************************
        '****************************************' Validate ************************************************
        '****************************************'****************************************'****************************************'****************************************
        '****************************************'****************************************'****************************************
        Try
            oQuoteOut = oCoreBusiness.RunQuote(con, oQuoteIn, QuoteTypeRules.Validate, UpdateRiskRequest.TransactionType, transactionTypeID)
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to validate quote values.", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", True)
        End Try

        ' Get the XML so we can pass it back in
        oQuoteIn.XMLDataset = oQuoteOut.XMLDataset
        oQuoteIn.AdditionalDataArray = oQuoteOut.AdditionalDataArray

        Call SAMFunc.CheckForRefersAndDeclines(v_sXMLDataset:=oQuoteIn.XMLDataset,
                           v_sDataModelCode:=oQuoteIn.DataModelCode,
                           r_blReferred:=blReferred,
                           r_blDeclined:=blDeclined)

        If blReferred = True Then

            ' Unlock and return the new timestamp
            AnyError = oCoreBusiness.UnlockAndGetTS(con,
                BranchCode:=UpdateRiskRequest.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=UpdateRiskRequest.InsuranceFolderKey,
                TStamp:=oResponse.QuoteTimeStamp)

            oResponse.XMLDataSet = oQuoteOut.XMLDataset
            Return oResponse

        ElseIf blDeclined = True Then

            ' Unlock and return the new timestamp
            AnyError = oCoreBusiness.UnlockAndGetTS(con,
                BranchCode:=UpdateRiskRequest.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=UpdateRiskRequest.InsuranceFolderKey,
                TStamp:=oResponse.QuoteTimeStamp)

            oResponse.XMLDataSet = oQuoteOut.XMLDataset
            Return oResponse

        End If

        ' We only need to do this for Underwriting when the user is known.
        If (nTypeOfPackage = enumTypeOfPackage.AgentsPackage) Or
            (nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage) Or
            (nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package) Then

            If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
                oQuoteIn.Username = oAgentRequest.UserName
            ElseIf nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage Or nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package Then
                oQuoteIn.Username = sUserName
            End If

            '***************************************************************************************
            '***************************************************************************************
            '*****************************  USER AUTHORITY L (UAL) *********************************
            '***************************************************************************************
            '***************************************************************************************
            Try
                oQuoteOut = oCoreBusiness.RunQuote(con, oQuoteIn, QuoteTypeRules.Ual, UpdateRiskRequest.TransactionType, transactionTypeID)


            Catch ex As Exception
                Dim STSErrorEx As New STSErrorPublisher("Failed on Underwriting Authority Limits script.", ex)
                STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", True)
            End Try

            ' Get the XML so we can pass it back in
            oQuoteIn.XMLDataset = oQuoteOut.XMLDataset

            Call SAMFunc.CheckForRefersAndDeclines(v_sXMLDataset:=oQuoteIn.XMLDataset,
                   v_sDataModelCode:=oQuoteIn.DataModelCode,
                   r_blReferred:=blReferred,
                   r_blDeclined:=blDeclined)

            If blReferred = True Then

                ' Unlock and return the new timestamp
                AnyError = oCoreBusiness.UnlockAndGetTS(con,
                    BranchCode:=UpdateRiskRequest.BranchCode,
                    Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                    LockValue:=UpdateRiskRequest.InsuranceFolderKey,
                    TStamp:=oResponse.QuoteTimeStamp)

                Dim STSErrorEx As STSErrorPublisher = New STSErrorPublisher(STSErrorCode:=STSErrorCodes.UALRulesReferred, Description:="User Authority Level rules referred", Detail:="User Authority Level rules referred")
                STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", False)
                oResponse.XMLDataSet = oQuoteOut.XMLDataset
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Risk_Status")
                    cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = UpdateRiskRequest.RiskKey
                    cmd.AddInParameter("@risk_status_code", SqlDbType.VarChar, 20).Value = "REFERRED"
                    con.ExecuteNonQuery(cmd)
                End Using
                Return oResponse

            ElseIf blDeclined = True Then

                ' Unlock and return the new timestamp
                AnyError = oCoreBusiness.UnlockAndGetTS(con,
                    BranchCode:=UpdateRiskRequest.BranchCode,
                    Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                    LockValue:=UpdateRiskRequest.InsuranceFolderKey,
                    TStamp:=oResponse.QuoteTimeStamp)

                Dim STSErrorEx As STSErrorPublisher = New STSErrorPublisher(STSErrorCode:=STSErrorCodes.UALRulesDeclined, Description:="User Authority Level rules declined", Detail:="User Authority Level rules declined")
                STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", False)
                oResponse.XMLDataSet = oQuoteOut.XMLDataset
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Risk_Status")
                    cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = UpdateRiskRequest.RiskKey
                    cmd.AddInParameter("@risk_status_code", SqlDbType.VarChar, 20).Value = "DECLINED"
                    con.ExecuteNonQuery(cmd)
                End Using
                Return oResponse
            Else
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Risk_Status")
                    cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = UpdateRiskRequest.RiskKey
                    cmd.AddInParameter("@risk_status_code", SqlDbType.VarChar, 20).Value = "QUOTED"
                    con.ExecuteNonQuery(cmd)
                End Using

                ' Update the Risk table values from the special Dataset Properties

                UpdateRiskFromGIS(con, UpdateRiskRequest.InsuranceFileKey, UpdateRiskRequest.RiskKey, oQuoteIn.XMLDataset, sDataModelCode)

            End If

        End If

        Try

            '****************************************************************************************
            '****************************************************************************************
            '*****************************  QUOTE  **************************************************
            '****************************************************************************************
            '****************************************************************************************
            oQuoteOut = oCoreBusiness.RunQuote(con, oQuoteIn, QuoteTypeRules.Quote, UpdateRiskRequest.TransactionType, transactionTypeID)

            If UpdateRiskRequest.TransactionType.Trim() = "MTR" Then
                Using cmd1 As SiriusCommand = SiriusCommand.FromText("SELECT fee_rate_amount ,base_fee_amount ,currency_amount   from policy_fee_u where insurance_file_cnt=" & UpdateRiskRequest.InsuranceFileKey.ToString())
                    Dim dt As New DataTable
                    dt = con.ExecuteDataTable(cmd1)
                    If dt.Rows.Count > 0 Then
                        Dim fee_rate_amount, base_fee_amount, currency_amount As Double
                        fee_rate_amount = Convert.ToDouble(dt.Rows(0)("fee_rate_amount").ToString())
                        base_fee_amount = Convert.ToDouble(dt.Rows(0)("base_fee_amount").ToString())
                        currency_amount = Convert.ToDouble(dt.Rows(0)("currency_amount").ToString())
                        If fee_rate_amount < 0 Then


                            fee_rate_amount = -(fee_rate_amount)
                            base_fee_amount = -(base_fee_amount)
                            currency_amount = -(currency_amount)


                            Using cmd2 As SiriusCommand = SiriusCommand.FromText("update policy_fee_u set fee_rate_amount=" & fee_rate_amount & ", base_fee_amount=" & base_fee_amount & ", currency_amount=" & currency_amount & " where insurance_file_cnt=" & UpdateRiskRequest.InsuranceFileKey.ToString())

                                con.ExecuteNonQuery(cmd2)
                            End Using


                        End If

                    End If

                End Using
            End If

        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed when running the actual quote.", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", True)
        End Try

        Call SAMFunc.CheckForRefersAndDeclines(v_sXMLDataset:=oQuoteOut.XMLDataset,
               v_sDataModelCode:=oQuoteIn.DataModelCode,
               r_blReferred:=blReferred,
               r_blDeclined:=blDeclined)

        If blReferred = True Then

            ' Unlock and return the new timestamp
            AnyError = oCoreBusiness.UnlockAndGetTS(con,
                BranchCode:=UpdateRiskRequest.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=UpdateRiskRequest.InsuranceFolderKey,
                TStamp:=oResponse.QuoteTimeStamp)

            Dim STSErrorEx As STSErrorPublisher = New STSErrorPublisher(STSErrorCode:=STSErrorCodes.RatingRulesReferred, Description:="Rating rules referred", Detail:="Rating rules referred")
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", False)
            oResponse.XMLDataSet = oQuoteOut.XMLDataset
            Return oResponse

        ElseIf blDeclined = True Then

            ' Unlock and return the new timestamp
            AnyError = oCoreBusiness.UnlockAndGetTS(con,
                BranchCode:=UpdateRiskRequest.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=UpdateRiskRequest.InsuranceFolderKey,
                TStamp:=oResponse.QuoteTimeStamp)

            Dim STSErrorEx As STSErrorPublisher = New STSErrorPublisher(STSErrorCode:=STSErrorCodes.RatingRulesDeclined, Description:="Rating rules declined", Detail:="Rating rules declined")
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "UpdateRisk", False)
            oResponse.XMLDataSet = oQuoteOut.XMLDataset
            Return oResponse

        End If

        With oResponse
            .CommissionAmount = 0
            .PremiumDueGross = 0
            .PremiumDueNet = 0
            .TotalAnnualTax = 0
            .PremiumDueTax = 0
            .XMLDataSet = oQuoteOut.XMLDataset
        End With

        Dim dBilledPremium As Decimal = 0
        Dim mandatoryAddOnXml As String = String.Empty
        Dim selectableAddOnsXml As String = String.Empty
        Dim policySectionsXml As String = String.Empty
        Dim policyCoinsurerSectionsXml As String = String.Empty

        ' update risk to indicate it has been manually changed and that is has been edited 
        UpdateRiskEditedIndicators(con, UpdateRiskRequest.InsuranceFileKey, UpdateRiskRequest.RiskKey, True)

        UpdateRiskDescription(con, UpdateRiskRequest.RiskKey, UpdateRiskRequest.RiskDescription)

        'Update InsuranceFileRiskLink if Risk Status Code = 'QUOTED'
        UpdateInsuranceFileRiskLinkStatus(con, UpdateRiskRequest.RiskKey, UpdateRiskRequest.InsuranceFileKey)

        'Retrieve the premium details from the DB
        Dim oGetRiskRequest As New BaseImplementationTypes.BaseGetRiskRequestType
        Dim oGetRiskResponse As BaseGetRiskResponseType

        oGetRiskRequest.BranchCode = UpdateRiskRequest.BranchCode
        oGetRiskRequest.InsuranceFileKey = UpdateRiskRequest.InsuranceFileKey
        oGetRiskRequest.InsuranceFolderKey = UpdateRiskRequest.InsuranceFolderKey
        oGetRiskRequest.QuoteTimeStamp = UpdateRiskRequest.QuoteTimeStamp
        oGetRiskRequest.RiskKey = UpdateRiskRequest.RiskKey

        oGetRiskRequest.IgnoreLocking = True

        Dim nIsOOSMTAReplaced As Integer
        oGetRiskResponse = RetrieveRisk(con, oGetRiskRequest, UpdateRiskRequest.TransactionType, nIsOOSMTAReplaced)

        oResponse.CommissionAmount = oGetRiskResponse.CommissionAmount
        oResponse.PremiumDueGross = oGetRiskResponse.PremiumDueGross
        oResponse.PremiumDueNet = oGetRiskResponse.PremiumDueNet
        oResponse.PremiumDueTax = oGetRiskResponse.PremiumDueTax
        oResponse.QuoteTimeStamp = oGetRiskResponse.QuoteTimeStamp
        oResponse.TotalAnnualTax = oGetRiskResponse.TotalAnnualTax
        oResponse.PolicyLevelTax = oGetRiskResponse.PolicyLevelTax
        oResponse.PolicyLevelFees = oGetRiskResponse.PolicyLevelFees
        oResponse.STSError = oGetRiskResponse.STSError
        oResponse.XMLDataSet = oGetRiskResponse.XMLDataSet
        oResponse.PolicyLevelTaxesAndFees = oGetRiskResponse.PolicyLevelTaxesAndFees
        oResponse.RiskLevelTaxesAndFees = oGetRiskResponse.RiskLevelTaxesAndFees
        oResponse.ProRataRate = oGetRiskResponse.proRataRate

        xmlDoc.LoadXml(oGetRiskResponse.XMLDataSet)
        sDataModelCode = xmlDoc.SelectSingleNode("DATA_SET") _
            .Attributes("DataModelCode").Value
        ' Update the Risk table values from the special Dataset Properties

        UpdateRiskFromGIS(con, UpdateRiskRequest.InsuranceFileKey, UpdateRiskRequest.RiskKey, oResponse.XMLDataSet, sDataModelCode)
        ProcessMandatoryRisk(con, UpdateRiskRequest.BranchCode, UpdateRiskRequest.InsuranceFileKey, UpdateRiskRequest.RiskKey, CType([Enum].Parse(GetType(TransactionType), UpdateRiskRequest.TransactionType, True), TransactionType))

        If nIsOOSMTAReplaced = 1 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Unquote_Risks_Forward")
                cmd.AddInParameter("@nRiskCnt", SqlDbType.Int).Value = UpdateRiskRequest.RiskKey
                con.ExecuteNonQuery(cmd)
            End Using
        End If
        ' Wpr53 : To Unquote Mandatory Risk during operations on other risks

        If UpdateRiskRequest.RiskKey > 0 And UpdateRiskRequest.InsuranceFileKey > 0 Then
            Dim sRiskDescription As String = String.Empty
            Dim iVariationNumber As Int32 = 0
            Dim iRiskCnt As Int32 = 0
            Dim dsResult As DataSet = Nothing
            Dim iCommandReturn As Int32


            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Mandatory_Risk")
                cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = UpdateRiskRequest.RiskKey

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = UpdateRiskRequest.InsuranceFileKey
                dsResult = con.ExecuteDataSet(cmd, "GetMandatoryRisk")
            End Using
            If dsResult IsNot Nothing Then
                If dsResult.Tables.Count > 0 Then
                    If dsResult.Tables(0).Rows.Count > 0 Then
                        iRiskCnt = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("risk_cnt"), 0)
                        sRiskDescription = Cast.ToString(dsResult.Tables(0).Rows(0).Item("description"), "")
                        iVariationNumber = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("variation_number"), 0)
                    End If
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Mandatory_Risk_Details")
                        cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = iRiskCnt
                        cmd.AddInParameter("@risk_status_id", SqlDbType.Int).Value = 4 ' For Status to Unquote Risk
                        cmd.AddInParameter("@description", SqlDbType.Text).Value = sRiskDescription
                        cmd.AddInParameter("@variation_number", SqlDbType.Int).Value = iVariationNumber
                        iCommandReturn = con.ExecuteNonQuery(cmd)
                    End Using
                End If
            End If
        End If
        'Retrieve if return premium is > billed premium
        dBilledPremium = GetBilledPremiumForRisk(con, UpdateRiskRequest.RiskKey)
        'If yes then Mark Risk Unquoted and Set Flag to be True
        If Math.Round(oResponse.PremiumDueNet, 2) + Math.Round(dBilledPremium, 2) < 0 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Risk_Status")
                cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = UpdateRiskRequest.RiskKey
                cmd.AddInParameter("@risk_status_code", SqlDbType.VarChar, 20).Value = RiskStatusCode.Unquoted
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = UpdateRiskRequest.InsuranceFileKey
                con.ExecuteNonQuery(cmd)
            End Using
            oResponse.ReturnPremiumMoreThanBilled = True
        Else
            oResponse.ReturnPremiumMoreThanBilled = False
        End If

        ' Unlock and return the new timestamp
        AnyError = oCoreBusiness.UnlockAndGetTS(con,
            BranchCode:=UpdateRiskRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=UpdateRiskRequest.InsuranceFolderKey,
            TStamp:=oResponse.QuoteTimeStamp)

        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Unable to unlock, return the error.
            'oResponse.STSError = AnyError
            'Return oResponse
        End If
        xmlDoc = Nothing

        Return oResponse

    End Function

