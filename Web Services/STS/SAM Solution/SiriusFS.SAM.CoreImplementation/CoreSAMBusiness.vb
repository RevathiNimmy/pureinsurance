    ''' <param name="con">An object of type SiriusConnection</param>  
    Public Overloads Function SaveCase(ByRef con As SiriusConnection,
    ByVal oRequest As BaseCaseItemsRequestType) As BaseSaveCaseResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseSaveCaseResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim STSError As New STSErrorPublisher
        Dim iProductID As Int32 = 0
        Dim dsFindCase As DataSet = Nothing
        Dim oGISSearchDataArray As Object = Nothing
        Dim oResultSet As Object = Nothing
        Dim sEventDescription As String = String.Empty

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.SaveCaseRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.SaveCaseResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        '*******************
        ' STRUCTURE VALIDATION
        '*******************
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' DATA VALIDATION
        '*******************
        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        Else
            oRequest.SourceId = 1
        End If

        oSAMErrorCollection.CheckForErrors()

        Try
            If Cast.ToInt32(oRequest.CaseKey, 0) <> 0 Then
                oResponse = CreateCaseVersion(con, oRequest, oResponse)
                If String.IsNullOrEmpty(oRequest.EventDescription) AndAlso (oRequest.EventDescription IsNot Nothing) Then
                    sEventDescription = oRequest.EventDescription.ToString
                End If
                oRequest.CaseKey = oResponse.CaseKey
            End If

            If Cast.ToInt32(oRequest.CaseKey, 0) = 0 Then
                sEventDescription = "Opened Case"
            Else
                sEventDescription = oRequest.EventDescription
            End If

            oResponse = ProcessAddCase(con, oRequest, oResponse, oBusiness, oSAMErrorCollection)
            oSAMErrorCollection.CheckForErrors()



            UpdateCaseIsDirtyFlag(con, oRequest.CaseKey, 0)
            CreateCaseEvent(con, oRequest.CaseKey, _SiriusUser.UserID, sEventDescription)
            If oResponse.CaseKey = 0 Then
                oResponse.CaseKey = oRequest.CaseKey
            End If

        Catch ex As Exception
            Throw
        Finally
            ''TODO : Dispose COM objects
        End Try

        Return oResponse

    End Function
