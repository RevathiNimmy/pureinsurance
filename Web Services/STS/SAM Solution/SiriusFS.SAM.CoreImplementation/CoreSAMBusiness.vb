    ''' <summary>
    '''This method pass the request object to the stored procedure and the cover note is being added
    '''</summary>
    '''<param name="oAddCoverNoteBookRequest" type="BaseGetTaskGroupTasksRequestType"></param>
    '''<param name="con" type="SiriusConnection"></param>
    ''' <returns>An object of type SiriusFS.SAM.SFI.BaseImplementationTypes.BaseAddCoverNoteBookResponseType</returns>
    '''<remarks></remarks>
    Public Overloads Function AddCoverNoteBook(ByVal con As SiriusConnection, ByVal oAddCoverNoteBookRequest As BaseAddCoverNoteBookRequestType) As BaseAddCoverNoteBookResponseType
        Dim oAddCoverNoteBookResponse As New BaseAddCoverNoteBookResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim iCoverNoteStatusKey As Int32
        Dim iProductKey As Nullable(Of Int32)
        Dim isourceId As Nullable(Of Int32)
        Dim iAgentKeyvalue As Nullable(Of Int32)
        Dim nTypeOfPackage As enumTypeOfPackage

        If oAddCoverNoteBookRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AddCoverNoteBookRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oAddCoverNoteBookResponse = New SAMForInsuranceV2ImplementationTypes.AddCoverNoteBookResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If
        'Manditory validation
        oAddCoverNoteBookRequest.Validate(CObj(oSAMErrorCollection))
        oSAMErrorCollection.CheckForErrors()

        'Lookupvalidation
        ValidateCoverNoteBookLookup(CObj(oSAMErrorCollection), iCoverNoteStatusKey, oAddCoverNoteBookRequest.BranchCode, oAddCoverNoteBookRequest.CoverNoteStatusCode)
        oSAMErrorCollection.CheckForErrors()

        'Data validation
        ValidateCoverNoteBookData(CObj(oSAMErrorCollection), oAddCoverNoteBookRequest)
        oSAMErrorCollection.CheckForErrors()

        'Business rule validation
        ValidateCoverNoteBookBusinessRule(CObj(oSAMErrorCollection), isourceId, iAgentKeyvalue, iProductKey, oAddCoverNoteBookRequest.AgentKey, oAddCoverNoteBookRequest, oAddCoverNoteBookRequest.CoverNoteBranchCode, oAddCoverNoteBookRequest.AgentKeySpecified)
        oSAMErrorCollection.CheckForErrors()

        ' Add Cover Note Book Details	
        Dim iCoverbookID As Int32
        Using cmdAddcovernote As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Cover_Note_Book_Add")

            cmdAddcovernote.AddInParameter("@book_number", SqlDbType.VarChar).Value = oAddCoverNoteBookRequest.BookNumber
            cmdAddcovernote.AddInParameter("@start_number", SqlDbType.Int).Value = oAddCoverNoteBookRequest.StartNumber
            cmdAddcovernote.AddInParameter("@end_number", SqlDbType.Int).Value = oAddCoverNoteBookRequest.EndNumber
            cmdAddcovernote.AddInParameter("@effective_date", SqlDbType.DateTime).Value = oAddCoverNoteBookRequest.EffectiveDate
            cmdAddcovernote.AddInParameter("@agent_cnt", SqlDbType.Int).Value = iAgentKeyvalue
            cmdAddcovernote.AddInParameter("@source_id", SqlDbType.Int).Value = isourceId
            cmdAddcovernote.AddInParameter("@user_id", SqlDbType.Int).Value = _SiriusUser.UserID
            cmdAddcovernote.AddInParameter("@cover_note_book_status_id", SqlDbType.Int).Value = iCoverNoteStatusKey
            cmdAddcovernote.AddOutParameter("@new_book_id", SqlDbType.Int)
            con.ExecuteNonQuery(cmdAddcovernote)
            iCoverbookID = Convert.ToInt32(cmdAddcovernote.Parameters.Item("@new_book_id").Value)
        End Using
        AddCoverNoteBookProducts(con, oAddCoverNoteBookRequest, iCoverbookID)

        ' Get the Timestamp
        Dim AnyError As STSErrorType
        Dim bIsLocked As Boolean
        AnyError = oCoreBusiness.GetTimestamp(
                            oAddCoverNoteBookRequest.BranchCode,
                            CoreBusiness.LockName.CoverNoteBookId,
                            iCoverbookID,
                            oAddCoverNoteBookResponse.CoverNoteBookTimestamp,
                            bIsLocked)
        ' Return AnyErrors
        If AnyError Is Nothing = False Then
            oAddCoverNoteBookResponse.STSError = AnyError
        End If

        Return oAddCoverNoteBookResponse
    End Function

    ''' <summary>
    '''This method sends the request object values to the Stored Procedure
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="lCoverbookid" type="Integer"></param>
    '''<param name="oAddCoverNoteBookRequest" type="BaseAddCoverNoteBookRequestType"></param>
    '''<remarks></remarks>
    Private Sub AddCoverNoteBookProducts(ByVal con As SiriusConnection,
ByVal oAddCoverNoteBookRequest As BaseAddCoverNoteBookRequestType, ByVal lCoverbookid As Integer)
        Dim iProductKey As Nullable(Of Int32)
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        Using cmdAddCovernotebookID As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Delete_CoverNoteProducts")
            cmdAddCovernotebookID.AddInParameter("@product_id", SqlDbType.Int).Value = SqlTypes.SqlInt32.Null
            cmdAddCovernotebookID.AddInParameter("@cover_note_book_id", SqlDbType.Int).Value = lCoverbookid
            con.ExecuteNonQuery(cmdAddCovernotebookID)
        End Using

        If oAddCoverNoteBookRequest.CoverNoteProducts IsNot Nothing AndAlso oAddCoverNoteBookRequest.CoverNoteProducts.Row IsNot Nothing Then
            Dim iLength As Int32 = oAddCoverNoteBookRequest.CoverNoteProducts.Row.Length
            For icount As Integer = 0 To iLength - 1
                iProductKey = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
               "product", oAddCoverNoteBookRequest.CoverNoteProducts.Row(icount).ProductCode, "Product_id", oSAMErrorCollection)
                oSAMErrorCollection.CheckForErrors()
                Using cmdAddCoverNoteProducts As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Save_CoverNoteProducts")
                    cmdAddCoverNoteProducts.AddInParameter("@cover_note_book_id", SqlDbType.Int).Value = lCoverbookid
                    cmdAddCoverNoteProducts.AddInParameter("@product_id", SqlDbType.Int).Value = iProductKey
                    cmdAddCoverNoteProducts.AddOutParameter("@return_status", SqlDbType.Int)
                    con.ExecuteNonQuery(cmdAddCoverNoteProducts)
                End Using
            Next
        End If

    End Sub

