    Public Sub AddCashDepositItem(ByRef oSAMErrorCollection As SAMErrorCollection, ByVal oCoreBusiness As CoreBusiness, ByVal conCashDeposit As SiriusConnection, ByVal oCashDeposit As BaseCommonCashDepositItemType)

        CreateCDAccount(oSAMErrorCollection, oCoreBusiness, conCashDeposit, oCashDeposit)

        Using cmdAddCashDeposit As SiriusCommand = SiriusCommand.FromProcedure("spu_CashDeposit_Add")
            cmdAddCashDeposit.AddOutParameter("@CashDeposit_ID", SqlDbType.Int)
            cmdAddCashDeposit.AddInParameter("@CashDeposit_Ref", SqlDbType.NVarChar, 30).Value = oCashDeposit.CashDepositRef
            cmdAddCashDeposit.AddInParameter("@Account_ID", SqlDbType.Int).Value = oCashDeposit.AccountKey
            cmdAddCashDeposit.AddInParameter("@Party_ID", SqlDbType.Int).Value = oCashDeposit.PartyKey
            cmdAddCashDeposit.AddInParameter("@Is_SinglePolicy", SqlDbType.TinyInt).Value = IIf(oCashDeposit.IsSinglePolicy, 1, 0)
            cmdAddCashDeposit.AddInParameter("@User_ID", SqlDbType.TinyInt).Value = GetAndValidateSpecifiedTableCode(conCashDeposit,
                "PMUser", "User_id", "UserName", oCashDeposit.UserName, oSAMErrorCollection, "UserName")
            conCashDeposit.ExecuteNonQuery(cmdAddCashDeposit)
            oCashDeposit.CashDepositKey = Cast.ToInt32(cmdAddCashDeposit.Parameters.Item("@CashDeposit_ID").Value, 0)
        End Using
    End Sub

