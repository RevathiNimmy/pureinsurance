    ''' <summary>
    '''This method sends the request to the function 
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="oGetCurrencyToCurrencyExchangeRateRequest" type="BaseGetCurrencyToCurrencyExchangeRateRequestType"></param>
    '''<remarks></remarks>
    Public Overloads Function GetCurrencyToCurrencyExchangesRate(ByVal con As SiriusConnection, ByVal oGetCurrencyToCurrencyExchangeRateRequest As BaseGetCurrencyToCurrencyExchangeRateRequestType) As BaseGetCurrencyToCurrencyExchangeRateResponseType

        Dim oGetCurrencyToCurrencyExchangeRateResponse As New BaseGetCurrencyToCurrencyExchangeRateResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        Dim dCurrencyFromToBaseXRate As Decimal
        Dim dCurrencyToToBaseXRate As Decimal
        Dim dBaseAmount As Decimal
        Dim iCurrencyFromId As Integer
        Dim iCurrencyToId As Integer
        Dim dTransactionDate As Date = Date.Today.Date
        Dim dCurrencyFromToCurrencyToExchangeRate As Decimal

        If oGetCurrencyToCurrencyExchangeRateRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetCurrencyToCurrencyExchangeRateRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetCurrencyToCurrencyExchangeRateResponse = New SAMForInsuranceV2ImplementationTypes.GetCurrencyToCurrencyExchangeRateResponseType
        End If

        'Mandatory validations
        oGetCurrencyToCurrencyExchangeRateRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        'Data validations

        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oGetCurrencyToCurrencyExchangeRateRequest.BranchCode, "Source", oErrors)

        iCurrencyFromId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Currency, oGetCurrencyToCurrencyExchangeRateRequest.CurrencyCodeFrom, "Currency", oErrors)

        iCurrencyToId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                        PMLookupTable.Currency, oGetCurrencyToCurrencyExchangeRateRequest.CurrencyCodeTo, "Currency", oErrors)


        If oGetCurrencyToCurrencyExchangeRateRequest.CurrencyCodeFrom <> oGetCurrencyToCurrencyExchangeRateRequest.CurrencyCodeTo Then
            ' get the payment currency to base currency exchange rate
            GetCurrencyToBaseXRate(con, iCurrencyFromId, iSourceId, dTransactionDate, dCurrencyFromToBaseXRate)


            If dCurrencyFromToBaseXRate = 0 Then
                RaiseBusinessError(SAMBusinessErrors.FailedToGetCurrencyToBaseExchangeRate,
                    "Failed to get CurrencyToBase exchange rate for currency_id : " + iCurrencyFromId.ToString +
                    " source_id :=" + iSourceId.ToString + " effective_date:=" + dTransactionDate.ToString)
            End If

            ' get the loss currency to base currency exchange rate
            GetCurrencyToBaseXRate(con, iCurrencyToId, iSourceId, Date.Today.Date, dCurrencyToToBaseXRate)

            If dCurrencyToToBaseXRate = 0 Then
                RaiseBusinessError(SAMBusinessErrors.FailedToGetCurrencyToBaseExchangeRate,
                    "Failed To GetCurrencyToBase exchange rate for currency_id : " + iCurrencyToId.ToString +
                    " source_id :=" + iSourceId.ToString + " effective_date:=" + dTransactionDate.ToString)
            End If

            ' get the payment to loss currency exchange rate and store it on the payment
            dCurrencyFromToCurrencyToExchangeRate = dCurrencyFromToBaseXRate / dCurrencyToToBaseXRate
        Else

            dCurrencyFromToCurrencyToExchangeRate = 1
            dCurrencyFromToBaseXRate = 1
            dCurrencyToToBaseXRate = 1
        End If

        With oGetCurrencyToCurrencyExchangeRateResponse
            .ConversionRate = dCurrencyFromToCurrencyToExchangeRate
            If oGetCurrencyToCurrencyExchangeRateRequest.CurrencyAmountUnRoundedSpecified Then
                .BaseAmount = oGetCurrencyToCurrencyExchangeRateRequest.CurrencyAmountUnRounded * dCurrencyFromToBaseXRate
                .CurrencyAmount = (oGetCurrencyToCurrencyExchangeRateRequest.CurrencyAmountUnRounded * dCurrencyFromToBaseXRate) / dCurrencyToToBaseXRate

            End If
        End With
        Return oGetCurrencyToCurrencyExchangeRateResponse
    End Function


    '''<summary>
    ''' This method is used to get valid primary causes for a claim based on the insurance file key of policy 
    '''</summary>
    '''<param name="GetValidPrimaryCausesRequest" type="BaseGetValidPrimaryCausesRequestType"></param>   
    '''<returns>BaseGetValidPrimaryCausesResponseType</returns>
    '''<remarks></remarks> 
    Public Function GetValidPrimaryCauses(ByVal GetValidPrimaryCausesRequest As BaseGetValidPrimaryCausesRequestType) As BaseGetValidPrimaryCausesResponseType

        Dim oErrors As New SAMErrorCollection
        Dim iRet As Integer

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseGetValidPrimaryCausesResponseType
        Dim nTypeOfPackage As enumTypeOfPackage

        If GetValidPrimaryCausesRequest.GetType Is GetType(BaseImplementationTypes.BaseGetValidPrimaryCausesRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            oResponse = New BaseImplementationTypes.BaseGetValidPrimaryCausesResponseType
        ElseIf GetValidPrimaryCausesRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetValidPrimaryCausesRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetValidPrimaryCausesResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        'Dim STSError As New STSErrorPublisher
        If GetValidPrimaryCausesRequest.InsuranceFileKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                   SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                    "InsuranceFileKey")
        End If
        If NothingToString(GetValidPrimaryCausesRequest.BranchCode) = "" Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                   SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                    "BranchCode")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        Dim iSourceID As Int32
        iSourceID% = 1
        ' Convert branch code to ID
        iSourceID% = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
          PMLookupTable.Source, GetValidPrimaryCausesRequest.BranchCode, "BranchCode", oErrors)

        Dim dr As DataSet

        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Valid_Primary_Causes")
                cmd.AddInParameter("@ins_file_cnt", SqlDbType.Int).Value = GetValidPrimaryCausesRequest.InsuranceFileKey
                If GetValidPrimaryCausesRequest.ModeSpecified Then
                    cmd.AddInParameter("@mode", SqlDbType.Int).Value = GetValidPrimaryCausesRequest.Mode
                End If
                dr = con.ExecuteDataSet(cmd, "dr")
            End Using
        End Using

        dr.DataSetName = "BaseGetValidPrimaryCausesResponseTypePrimaryCauses"
        dr.Tables(0).TableName = "Row"
        Dim dt As DataTable
        Dim i As Integer
        Dim Table1 As DataTable
        Table1 = New DataTable("Row")
        Dim Row1 As DataRow
        Dim code As DataColumn = New DataColumn("code")
        code.DataType = System.Type.GetType("System.String")
        Table1.Columns.Add(code)
        Dim description As DataColumn = New DataColumn("description")
        description.DataType = System.Type.GetType("System.String")
        Table1.Columns.Add(description)
        Dim primary_cause_id As DataColumn = New DataColumn("primary_cause_id")
        Table1.Columns.Add(primary_cause_id)
        For i = 0 To dr.Tables("Row").Rows.Count - 1
            Row1 = Table1.NewRow()
            Row1.Item("code") = oBusiness.GetListItemFromID(Core.STSListType.PMLookup, PMLookupTable.PrimaryCause, Cast.ToInt32(dr.Tables("Row").Rows(i).Item(0), 0), bIsViewClaim:=GetValidPrimaryCausesRequest.ModeSpecified).ToString
            Row1.Item("description") = dr.Tables("Row").Rows(i).Item(1)
            Row1.Item("primary_cause_id") = dr.Tables("Row").Rows(i).Item(0)
            Table1.Rows.Add(Row1)
        Next
        Dim ds As New DataSet
        ds.DataSetName = "BaseGetValidPrimaryCausesResponseTypePrimaryCauses"
        ds.Tables.Add(Table1)
        Dim oXMLDoc As New System.Xml.XmlDocument

        If GetValidPrimaryCausesRequest.WCFSecurityToken = "" Then
            oXMLDoc.LoadXml(ds.GetXml)
            oResponse.PrimaryCauses = oXMLDoc.DocumentElement
        End If

        oResponse.ResultData = ds
        Return oResponse
    End Function

