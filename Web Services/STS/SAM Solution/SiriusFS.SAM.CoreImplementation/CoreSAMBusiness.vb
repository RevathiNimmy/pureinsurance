    Public Overloads Function DeleteRenewal(ByVal conDeleteRenewal As SiriusConnection, ByVal oDeleteRenewalRequest As BaseDeleteRenewalRequestType) As BaseDeleteRenewalResponseType
        Dim oCoreBusiness As CoreBusiness
        Dim SiriusUser As New SIRIUSUSER
        SiriusUser.UserID = Convert.ToInt16(oDeleteRenewalRequest.CreatedById)
        If oDeleteRenewalRequest.CreatedById = 0 Then
            oCoreBusiness = New CoreBusiness
        Else
            oCoreBusiness = New CoreBusiness(SiriusUser)
        End If
        Dim iReturn As Integer = 0
        Dim oErrors As New SAMErrorCollection
        Dim oResponse As New BaseDeleteRenewalResponseType
        ' For delete functionality, we dont have timestamp on response, this variable is just a dummy variable while calling unlock timestamp method
        Dim o_aRetrunTimeStamp() As Byte = Nothing
        ' For getting timstamp on RenewalStatusKey, creating a timestamp variable
        Dim r_aRenewalTimeStamp() As Byte = Nothing
        Dim nTypeofPackage As enumTypeOfPackage

        If oDeleteRenewalRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.DeleteRenewalRequestType) Then
            nTypeofPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.DeleteRenewalResponseType
        Else
            nTypeofPackage = enumTypeOfPackage.UnknownPackage
            Return oResponse
        End If

        ' Check Mandatory Field
        oDeleteRenewalRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        ' Look up validation
        Dim iSourceId As Integer
        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oDeleteRenewalRequest.BranchCode, "BranchCode", oErrors)
        oErrors.CheckForErrors()

        'Check insurance file key for validity
        If Not oCoreBusiness.CheckInsuranceFile(conDeleteRenewal, oDeleteRenewalRequest.InsuranceFileKey, oDeleteRenewalRequest.InsuranceFolderKey) Then
            oErrors.AddInvalidData(SAMConstants.SAMInvalidData.InvalidLookupListValue,
                            SAMConstants.SAMInvalidData.InvalidLookupListValue.ToString,
                                 "InsuranceFileKey")
            oErrors.CheckForErrors()
        End If
        ' Get Insurance ref
        Dim oInsuranceFileType As New InsuranceFileDetailsType(oDeleteRenewalRequest.InsuranceFileKey)

        oDeleteRenewalRequest.InsuranceRef = oInsuranceFileType.InsuranceRef

        ' Get renewal status information
        Dim tbRenewalStatusDetails As DataTable = Nothing

        tbRenewalStatusDetails = GetRenewalStatus(conDeleteRenewal, oDeleteRenewalRequest.InsuranceFileKey)
        If tbRenewalStatusDetails IsNot Nothing AndAlso tbRenewalStatusDetails.Rows.Count > 0 Then
            oDeleteRenewalRequest.InsuranceHolderKey = Cast.ToInt32(tbRenewalStatusDetails.Rows(0)("insurance_holder_cnt"), 0)
            oDeleteRenewalRequest.RenewalStatusKey = Cast.ToInt32(tbRenewalStatusDetails.Rows(0)("renewal_status_cnt"), 0)
        Else
            'If table contains no result, we have to raise error and exit
            oErrors.AddBusinessRule(
                SAMBusinessErrors.InvalidTransactionType,
                SAMBusinessErrors.InvalidTransactionType.ToString,
                "Attempted a renewals call on a policy that isnt in renewals")

            oErrors.CheckForErrors()
        End If

        Try
            conDeleteRenewal.BeginTransaction()

            ' Check that the timestamp matches and put lock on the given insurance folder key
            oCoreBusiness.CheckSAMTSAndLock(Con:=conDeleteRenewal,
                                            BranchCode:=oDeleteRenewalRequest.BranchCode,
                                            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                                            LockValue:=oDeleteRenewalRequest.InsuranceFolderKey,
                                            TStamp:=oDeleteRenewalRequest.QuoteTimeStamp)

            ' Get a timestamp on RenewalStatusKey
            Dim o_bLocked As Boolean
            oCoreBusiness.GetSAMTimestamp(
                                           Con:=conDeleteRenewal,
                                           BranchCode:=oDeleteRenewalRequest.BranchCode,
                                           Lockname:=CoreBusiness.LockName.RenewalProcess,
                                           LockValue:=oDeleteRenewalRequest.RenewalStatusKey,
                                           TStamp:=r_aRenewalTimeStamp,
                                           bCurrentlyLocked:=o_bLocked)

            ' Check the method call succeeded
            If o_bLocked Then

                oErrors.AddBusinessRule(SAMBusinessErrors.RecordLockedByAnotherUser,
                                        "The renewal record for policy is already locked by another user.")
                oErrors.CheckForErrors()
            End If

            ' Check that the timestamp matches and put lock on the given renewal status key
            oCoreBusiness.CheckSAMTSAndLock(Con:=conDeleteRenewal,
                                            BranchCode:=oDeleteRenewalRequest.BranchCode,
                                            Lockname:=CoreBusiness.LockName.RenewalProcess,
                                            LockValue:=oDeleteRenewalRequest.RenewalStatusKey,
                                            TStamp:=r_aRenewalTimeStamp)

            DeleteRenewal(
                           conDeleteRenewal,
                           oDeleteRenewalRequest.InsuranceFileKey,
                           oDeleteRenewalRequest.BranchCode,
                           oDeleteRenewalRequest.InsuranceRef,
                           oDeleteRenewalRequest.InsuranceHolderKey)

            'Unlock the lock on renewal status key
            oCoreBusiness.UnlockAndGetSAMTS(
                                             Con:=conDeleteRenewal,
                                             BranchCode:=oDeleteRenewalRequest.BranchCode,
                                             Lockname:=CoreBusiness.LockName.RenewalProcess,
                                             LockValue:=oDeleteRenewalRequest.RenewalStatusKey,
                                             TStamp:=o_aRetrunTimeStamp)

            ' Unlock the lock on insurance folder key
            ' Deviation from Tech spec: Rahul told that the timestamp returned by the UnlockAndGetTS method is not needed.
            ' After deleting the policy, we practically can not do anything with the timestamp returned. 
            ' Even in tech spec it is not specified in the schema that a TimeStamp field should be there in response.
            oCoreBusiness.UnlockAndGetSAMTS(
                                             Con:=conDeleteRenewal,
                                             BranchCode:=oDeleteRenewalRequest.BranchCode,
                                             Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                                             LockValue:=oDeleteRenewalRequest.InsuranceFolderKey,
                                             TStamp:=o_aRetrunTimeStamp)

            conDeleteRenewal.CommitTransaction()
        Catch ex As Exception
            conDeleteRenewal.RollbackTransaction()
            Throw
        End Try

        Return oResponse
    End Function

