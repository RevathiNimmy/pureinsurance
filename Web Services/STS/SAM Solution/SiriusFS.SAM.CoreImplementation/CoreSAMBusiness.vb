    Public Overloads Function GetHeaderAndAgentCommissionByKey(ByVal con As SiriusConnection, ByVal GetHeaderAndAgentCommissionByKeyRequest As BaseGetHeaderAndAgentCommissionByKeyRequestType) As BaseGetHeaderAndAgentCommissionByKeyResponseType

        Dim oGetHeaderAndAgentCommissionByKeyResponse As New BaseGetHeaderAndAgentCommissionByKeyResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        'Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If GetHeaderAndAgentCommissionByKeyRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetHeaderAndAgentCommissionByKeyRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetHeaderAndAgentCommissionByKeyResponse = New SAMForInsuranceV2ImplementationTypes.GetHeaderAndAgentCommissionByKeyResponseType
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(GetHeaderAndAgentCommissionByKeyRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If Not GetHeaderAndAgentCommissionByKeyRequest.InsuranceFileKey >= 1 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsAgentCommissions As DataSet = Nothing
        Dim dsHeader As DataSet = Nothing

        If GetHeaderAndAgentCommissionByKeyRequest.InsuranceFileKey <> 0 Then

            Dim dTotalCommissionLeadAgent As Double = 0.0
            Dim dTotalTaxLeadAgent As Double = 0.0
            Dim dTotalNetPremiumLeadAgent As Double = 0.0
            Dim dTotalCommissionSubAgent As Double = 0.0
            Dim dTotalTaxSubAgent As Double = 0.0
            Dim dTotalNetPremiumSubAgent As Double = 0.0
            Dim DocAgentCommissions As New System.Xml.XmlDocument

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_sir_agent_commission_sel")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndAgentCommissionByKeyRequest.InsuranceFileKey)

                dsAgentCommissions = con.ExecuteDataSet(cmd, "Row")
                If (dsAgentCommissions.Tables.Count > 0) Then

                    If (dsAgentCommissions.Tables(0).Rows.Count > 0) Then

                        For icount As Integer = 0 To dsAgentCommissions.Tables(0).Rows.Count - 1
                            If Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item(7), False) Then
                                dTotalCommissionLeadAgent = dTotalCommissionLeadAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(6), 0.0)
                                dTotalTaxLeadAgent = dTotalTaxLeadAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(16), 0.0)
                            Else
                                dTotalCommissionSubAgent = dTotalCommissionSubAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(6), 0.0)
                                dTotalTaxSubAgent = dTotalTaxSubAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(16), 0.0)
                            End If

                            If Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("Is_Value"), False) = True Then
                                dsAgentCommissions.Tables(0).Rows(icount).Item("commission_value") = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage"), 0)
                                If Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage"), 0) = 0 Or Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("premium"), 0) = 0 Then
                                    dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage") = 0
                                Else
                                    dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage") = Cast.ToDouble(((Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage"), 0) / Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("Premium"), 0)) * 100), 0)
                                End If
                            End If

                        Next

                        dTotalNetPremiumLeadAgent = dTotalCommissionLeadAgent + dTotalTaxLeadAgent
                        dTotalNetPremiumSubAgent = dTotalCommissionSubAgent + dTotalTaxSubAgent
                        dsAgentCommissions.Tables(0).Columns(0).ColumnName = "Agent"
                        dsAgentCommissions.Tables(0).Columns(1).ColumnName = "AgentType"
                        dsAgentCommissions.Tables(0).Columns(2).ColumnName = "RiskType"
                        dsAgentCommissions.Tables(0).Columns(3).ColumnName = "CommissionBand"
                        dsAgentCommissions.Tables(0).Columns(4).ColumnName = "Premium"
                        dsAgentCommissions.Tables(0).Columns(5).ColumnName = "CommissionRate"
                        dsAgentCommissions.Tables(0).Columns(6).ColumnName = "CommissionValue"
                        dsAgentCommissions.Tables(0).Columns(7).ColumnName = "IsLeadAgent"
                        dsAgentCommissions.Tables(0).Columns(15).ColumnName = "TaxGroup"
                        dsAgentCommissions.Tables(0).Columns(16).ColumnName = "TaxValue"
                        dsAgentCommissions.Tables(0).Columns(20).ColumnName = "IsValue"

                        'Filtering fields which are not required
                        dsAgentCommissions.Tables(0).Columns.Remove("is_amended")
                        dsAgentCommissions.Tables(0).Columns.Remove("party_cnt")
                        dsAgentCommissions.Tables(0).Columns.Remove("Party_Agent_Type_id")
                        dsAgentCommissions.Tables(0).Columns.Remove("risk_type_id")
                        dsAgentCommissions.Tables(0).Columns.Remove("commission_band_id")
                        dsAgentCommissions.Tables(0).Columns.Remove("description1")
                        dsAgentCommissions.Tables(0).Columns.Remove("tax_group_id")
                        dsAgentCommissions.Tables(0).Columns.Remove("calculated_commission_value")
                        dsAgentCommissions.Tables(0).Columns.Remove("override_reason")
                    End If
                End If
            End Using
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Insurance_File_Details")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndAgentCommissionByKeyRequest.InsuranceFileKey)

                dsAgentCommissions.DataSetName = "BaseGetHeaderAndAgentCommissionByKeyResponseTypeAgentCommission"
                dsAgentCommissions.Tables(0).TableName = "Row"


                dsHeader = con.ExecuteDataSet(cmd, "Row")
                If GetHeaderAndAgentCommissionByKeyRequest.WCFSecurityToken = "" Then
                    DocAgentCommissions.LoadXml(dsAgentCommissions.GetXml)
                End If

                If (dsHeader.Tables.Count > 0) Then
                    If (dsHeader.Tables(0).Rows.Count > 0) Then
                        With oGetHeaderAndAgentCommissionByKeyResponse
                            .InsuranceFileKey = GetHeaderAndAgentCommissionByKeyRequest.InsuranceFileKey
                            .ClientCode = dsHeader.Tables(0).Rows(0).Item(4).ToString()
                            .InsuranceFileRef = dsHeader.Tables(0).Rows(0).Item(0).ToString()
                            .Agent = dsHeader.Tables(0).Rows(0).Item(9).ToString()
                            If IsDate(dsHeader.Tables(0).Rows(0).Item(1)) Then
                                .InceptionDate = CDate(dsHeader.Tables(0).Rows(0).Item(1))
                            End If
                            If IsDate(dsHeader.Tables(0).Rows(0).Item(2)) Then
                                .CoverStartDate = CDate(dsHeader.Tables(0).Rows(0).Item(2))
                            End If
                            If IsDate(dsHeader.Tables(0).Rows(0).Item(3)) Then
                                .ExpiryDate = CDate(dsHeader.Tables(0).Rows(0).Item(3))
                            End If
                            .Currency = dsHeader.Tables(0).Rows(0).Item(10).ToString()
                            .TotalCommissionLeadAgent = dTotalCommissionLeadAgent
                            .TotalTaxLeadAgent = dTotalTaxLeadAgent
                            .TotalNetPremiumLeadAgent = dTotalNetPremiumLeadAgent
                            .TotalCommissionSubAgent = dTotalCommissionSubAgent
                            .TotalTaxSubAgent = dTotalTaxSubAgent
                            .TotalNetPremiumSubAgent = dTotalNetPremiumSubAgent
                            .ResultDataset = DocAgentCommissions.DocumentElement
                        End With
                    End If
                End If

                oGetHeaderAndAgentCommissionByKeyResponse.ResultData = dsAgentCommissions
            End Using
        End If
        Return oGetHeaderAndAgentCommissionByKeyResponse
    End Function

