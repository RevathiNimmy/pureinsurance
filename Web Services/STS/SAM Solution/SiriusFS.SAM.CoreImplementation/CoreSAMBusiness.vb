    ''' <summary>  
    ''' GetBrokerSummary
    ''' </summary>  
    ''' <param name="oRequest">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseGetBrokerSummaryRequestType</param>  
    ''' <param name="con">An object of type SiriusConnection</param>  
    Public Overloads Function GetBrokerSummary(ByRef con As SiriusConnection,
    ByVal oRequest As BaseGetBrokerSummaryRequestType) As BaseGetBrokerSummaryResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseGetBrokerSummaryResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim STSError As New STSErrorPublisher
        Dim iProductID As Int32 = 0
        Dim dsGetBrokerSummary As DataSet = Nothing

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetBrokerSummaryRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetBrokerSummaryResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        '*******************
        ' STRUCTURE VALIDATION
        '*******************
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' DATA VALIDATION
        '*******************
        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        ' validate the policy number 
        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' PROCESS
        '*******************

        ' Convert Product code to ID
        Try
            If Not (oRequest.ProductCode = Nothing) Then
                If Not (UCase(oRequest.ProductCode) = "ALL") Or (String.IsNullOrEmpty(oRequest.ProductCode)) Then
                    iProductID = oBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "Product", oRequest.ProductCode)
                End If
            End If
        Catch ex As Exception
            STSError.AddInvalidField("ProductCode", CStr(STSErrorCodes.InvalidLookupListValue), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "ProductCode"), oRequest.ProductCode)
        End Try

        Try
            If oRequest.RiskIndex IsNot Nothing AndAlso Not String.IsNullOrEmpty(oRequest.RiskIndex) Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetBroker_Summary_By_RiskIndex ")
                    cmd.AddInParameter("@search_value", SqlDbType.VarChar).Value = Cast.NullIfDefault(oRequest.RiskIndex)
                    cmd.AddInParameter("@AgentKey", SqlDbType.Int).Value = Cast.NullIfDefault(oRequest.AgentKey)
                    cmd.AddInParameter("@SourceID", SqlDbType.Int).Value = oRequest.SourceId
                    dsGetBrokerSummary = con.ExecuteDataSet(cmd, "Row")
                End Using
            Else
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Broker_Summary")
                    cmd.AddInParameter("@AgentKey", SqlDbType.Int).Value = Cast.NullIfDefault(oRequest.AgentKey)
                    If Not (oRequest.InsuranceRef = Nothing) Then
                        cmd.AddInParameter("@InsuranceRef", SqlDbType.VarChar).Value = Cast.NullIfDefault(oRequest.InsuranceRef)
                    End If
                    If oRequest.RecordTypeSpecified = True Then
                        cmd.AddInParameter("@QuoteType", SqlDbType.VarChar).Value = Cast.NullIfDefault(oRequest.RecordType)
                    Else
                        cmd.AddInParameter("@QuoteType", SqlDbType.VarChar).Value = "ALL"
                    End If
                    cmd.AddInParameter("@ProductId", SqlDbType.Int).Value = Cast.NullIfDefault(iProductID)
                    If Not (oRequest.InsuredName = Nothing) Then
                        cmd.AddInParameter("@InsuredName", SqlDbType.VarChar).Value = Cast.NullIfDefault(oRequest.InsuredName)
                    End If
                    If oRequest.ShowUserOnlySpecified = True Then
                        If oRequest.ShowUserOnly = True Then
                            cmd.AddInParameter("@bUserOnly", SqlDbType.TinyInt).Value = 1
                        Else
                            cmd.AddInParameter("@bUserOnly", SqlDbType.TinyInt).Value = 0
                        End If
                    Else
                        cmd.AddInParameter("@bUserOnly", SqlDbType.TinyInt).Value = 0
                    End If
                    cmd.AddInParameter("@UserID", SqlDbType.Int).Value = _SiriusUser.UserID
                    If oRequest.CoverStartDateSpecified = True Then
                        cmd.AddInParameter("@CoverStartdate", SqlDbType.Date).Value = oRequest.CoverStartDate
                    End If

                    If oRequest.QuoteORLiveDateSpecified = True Then
                        cmd.AddInParameter("@QuoteORLiveDate", SqlDbType.Date).Value = oRequest.QuoteORLiveDate
                    End If
                    cmd.AddInParameter("@MaxRowsToFetch", SqlDbType.Int).Value = oRequest.MaxRowsToFetch
                    cmd.AddInParameter("@BranchId", SqlDbType.Int).Value = oRequest.SourceId
                    'WPR73-74
                    If oRequest.UserKeySpecified = True Then
                        cmd.AddInParameter("@ContactUserId", SqlDbType.Int).Value = oRequest.UserKey
                    End If
                    cmd.AddInParameter("@RetrieveAssociates", SqlDbType.TinyInt).Value = IIf(oRequest.RetrieveAssociates = True, 1, 0)
                    cmd.AddInParameter("@nFilterQuotes", SqlDbType.Int).Value = Cast.NullIfDefault(oRequest.FilterQuotes)
                    cmd.AddInParameter("@nFilterPolicies", SqlDbType.Int).Value = Cast.NullIfDefault(oRequest.FilterPolicies)
                    dsGetBrokerSummary = con.ExecuteDataSet(cmd, "Row")
                End Using
            End If
            If oRequest.RetrieveAssociates Then
                AddExtraXMLElementForPolicyAssociate(dsGetBrokerSummary, "AssociatedClients")
            End If
            dsGetBrokerSummary.DataSetName = "BaseGetBrokerSummaryResponseTypeInsuranceFileDetails"
            dsGetBrokerSummary.Tables(0).TableName = "Row"

            Dim oXMLDoc As New System.Xml.XmlDocument

            Try
                If oRequest.WCFSecurityToken = "" Then
                    Try
                        oXMLDoc.LoadXml(dsGetBrokerSummary.GetXml)
                    Catch ex As Exception
                        Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.XMLDocumentBadlyFormed, "Unable to load SQL output as XML", ex.Message)
                        STSErrorEX.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), "GetBrokerSummary", "", True)
                        Return oResponse
                    End Try
                    oResponse.ResultDataset = oXMLDoc.DocumentElement
                End If

                oResponse.ResultData = dsGetBrokerSummary
            Catch ex As Exception
                Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.XMLDocumentBadlyFormed, "Unable to pass Document Element", ex.Message)
                STSErrorEX.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), "GetBrokerSummary", "", True)
                Return oResponse
            End Try
        Catch ex As Exception
        End Try
        Return oResponse
    End Function

