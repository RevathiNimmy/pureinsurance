    ''' <summary>
    ''' Update Policy Payment Method
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oUpdatePolicyPaymentMethodRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function UpdatePolicyPaymentMethod(ByVal con As SiriusConnection, ByVal oUpdatePolicyPaymentMethodRequest As BaseUpdatePolicyPaymentMethodRequestType) As BaseUpdatePolicyPaymentMethodResponseType
        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oCoreBusiness As New CoreBusiness
        Dim oResponse As BaseImplementationTypes.BaseUpdatePolicyPaymentMethodResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iSourceId As Integer

        ' determine the type of package and thus the type of response
        If oUpdatePolicyPaymentMethodRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdatePolicyPaymentMethodRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdatePolicyPaymentMethodResponseType
        Else
            oResponse = New BaseImplementationTypes.BaseUpdatePolicyPaymentMethodResponseType
        End If

        ' validate the mandatory structure data
        oUpdatePolicyPaymentMethodRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()

        If Not String.IsNullOrEmpty(oUpdatePolicyPaymentMethodRequest.BranchCode) Then
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oUpdatePolicyPaymentMethodRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        oSAMErrorCollection.CheckForErrors()

        If oCoreBusiness.CheckInsuranceFile(oUpdatePolicyPaymentMethodRequest.InsuranceFileKey, oUpdatePolicyPaymentMethodRequest.InsuranceFolderKey) = False Then
            oSAMErrorCollection.AddBusinessRule(SAMConstants.
                    SAMInvalidData.InvalidInsuranceFileType,
                    "Invalid Insurance File Key Provided.")
        End If

        oSAMErrorCollection.CheckForErrors()

        Dim oAnyError As STSErrorType
        oAnyError = oCoreBusiness.CheckTSAndLock(
            BranchCode:=oUpdatePolicyPaymentMethodRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=oUpdatePolicyPaymentMethodRequest.InsuranceFolderKey,
            TStamp:=oUpdatePolicyPaymentMethodRequest.QuoteTimeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oResponse.STSError = oAnyError
            Return oResponse
        End If

        UpdatePolicyPaymentValidateBusiness(oSAMErrorCollection, con, oUpdatePolicyPaymentMethodRequest)
        oSAMErrorCollection.CheckForErrors()

        Try

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Update_Payment_Method")
                cmd.AddInParameter("@InsuranceFileKey", SqlDbType.Int).Value = oUpdatePolicyPaymentMethodRequest.InsuranceFileKey
                cmd.AddInParameter("@PaymentMethod", SqlDbType.VarChar, 60).Value = oUpdatePolicyPaymentMethodRequest.PolicyPaymentMethod
                con.ExecuteNonQuery(cmd)
            End Using

            oCoreBusiness.UnlockAndGetSAMTS(Con:=con,
                BranchCode:=oUpdatePolicyPaymentMethodRequest.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=oUpdatePolicyPaymentMethodRequest.InsuranceFolderKey,
                TStamp:=oUpdatePolicyPaymentMethodRequest.QuoteTimeStamp)

            ' Check for Errors
            If oAnyError Is Nothing = False Then
                ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
                oResponse.STSError = oAnyError
                Return oResponse
            End If
            oResponse.QuoteTimeStamp = oUpdatePolicyPaymentMethodRequest.QuoteTimeStamp

        Catch
            Throw
        End Try

        Return oResponse
    End Function

    Private Sub UpdatePolicyPaymentValidateBusiness(ByRef oSAMErrorCollection As SAMErrorCollection,
                                                        ByVal con As SiriusConnection,
                                                        ByVal oUpdatePolicyPaymentMethodRequest As BaseUpdatePolicyPaymentMethodRequestType)
        Dim InsuranceFileTypeKey As Integer
        Dim InsuranceFileTypeCode As String
        Dim oCoreBusiness As New CoreBusiness
        GetInsuranceFileType(con, oUpdatePolicyPaymentMethodRequest.InsuranceFileKey,
                                InsuranceFileTypeKey, InsuranceFileTypeCode)

        If LCase(InsuranceFileTypeCode) <> "renewal" Then
            oSAMErrorCollection.AddBusinessRule(SAMConstants.
                     SAMInvalidData.InvalidInsuranceFileType,
                     "Only Policy Under Renewal is supported for this method.")
        End If
    End Sub
