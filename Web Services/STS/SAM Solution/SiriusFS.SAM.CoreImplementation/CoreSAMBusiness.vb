    ''' <summary>
    '''In this function , three kinds are records are fetched from the database 
    ''' they are "Fees,total and InsuranceFile details.
    '''</summary>
    '''<param name="BaseGetHeaderAndPolicyFeesByKeyRequestType" type="BaseGetHeaderAndPolicyFeesByKeyResponseType"></param>   
    '''<remarks></remarks> 
    Public Overloads Function GetHeaderAndPolicyFeesByKey(ByVal con As SiriusConnection, ByVal GetHeaderAndPolicyFeesByKeyRequest As BaseGetHeaderAndPolicyFeesByKeyRequestType) As BaseGetHeaderAndPolicyFeesByKeyResponseType

        Dim oGetHeaderAndPolicyFeesByKeyResponse As New BaseGetHeaderAndPolicyFeesByKeyResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        'Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If GetHeaderAndPolicyFeesByKeyRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetHeaderAndPolicyFeesByKeyRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetHeaderAndPolicyFeesByKeyResponse = New SAMForInsuranceV2ImplementationTypes.GetHeaderAndPolicyFeesByKeyResponseType
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(GetHeaderAndPolicyFeesByKeyRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If Not GetHeaderAndPolicyFeesByKeyRequest.InsuranceFileKey >= 1 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsFees As DataSet = Nothing
        Dim dsHeader As DataSet = Nothing
        Dim dsTotals As DataSet = Nothing
        Dim dsFilter As DataSet = Nothing

        If GetHeaderAndPolicyFeesByKeyRequest.InsuranceFileKey <> 0 Then

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_FeeNotIncludedInInstalments")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndPolicyFeesByKeyRequest.InsuranceFileKey)

                dsTotals = con.ExecuteDataSet(cmd, "Row")

            End Using

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Policy_Fees_Select")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndPolicyFeesByKeyRequest.InsuranceFileKey)

                dsFees = con.ExecuteDataSet(cmd, "Row")

            End Using

            'Safe code included
            If (dsFees.Tables.Count >= 1) Then
                dsFilter = New DataSet
                With dsFees.Tables(0)
                    dsFilter.Tables.Add()

                    dsFilter.Tables(0).Columns.Add("PolicyFeeKey", GetType(System.Int32))
                    dsFilter.Tables(0).Columns.Add("FeeName", GetType(System.String))
                    dsFilter.Tables(0).Columns.Add("CurrencyCode", GetType(System.String))
                    dsFilter.Tables(0).Columns.Add("AppliedTo", GetType(System.String))
                    dsFilter.Tables(0).Columns.Add("Premium", GetType(System.Double))
                    dsFilter.Tables(0).Columns.Add("Rate", GetType(System.Double))
                    dsFilter.Tables(0).Columns.Add("FeeAmount", GetType(System.Double))
                    dsFilter.Tables(0).Columns.Add("TaxAmount", GetType(System.Double))
                    dsFilter.Tables(0).Columns.Add("TotalAmount", GetType(System.Double))
                    dsFilter.Tables(0).Columns.Add("TaxGroup", GetType(System.String))
                    dsFilter.Tables(0).Columns.Add("IncludeInInstallment", GetType(System.Int16))
                    dsFilter.Tables(0).Columns.Add("SpreadAcrossInstallment", GetType(System.Int16))
                    dsFilter.Tables(0).Columns.Add("IsValue", GetType(System.Boolean))
                    dsFilter.Tables(0).Columns.Add("CalculationBasis", GetType(System.Int16))
                    dsFilter.Tables(0).Columns.Add("DoPaymentTermsId", GetType(System.Int32))
                    dsFilter.Tables(0).Columns.Add("MakeLiveOptionsId", GetType(System.Int32))
                    dsFilter.Tables(0).Columns.Add("IsProrated", GetType(System.Int16))
                    dsFilter.Tables(0).Columns.Add("ProRataRate", GetType(System.Double))

                    Dim iCount As Integer
                    Dim dRate_Percentage As Double
                    Dim dRate_Amount As Double  'WPR13 (Issue fix 78355)
                    Dim dCurrency_Amount As Double
                    Dim dCurrency_Tax_Amount As Double
                    Dim IsFeeTypePercent As Boolean

                    For iCount = 0 To dsFees.Tables(0).Rows.Count - 1
                        dsFilter.Tables(0).Rows.Add()
                        dsFilter.Tables(0).Rows(iCount)("PolicyFeeKey") = Cast.ToInt32(dsFees.Tables(0).Rows(iCount).Item("policy_fee_u_id"), 0)
                        dsFilter.Tables(0).Rows(iCount)("FeeName") = Cast.ToString(dsFees.Tables(0).Rows(iCount).Item("resolved_name"), String.Empty)
                        dsFilter.Tables(0).Rows(iCount)("CurrencyCode") = Cast.ToString(dsFees.Tables(0).Rows(iCount).Item("iso_code"), String.Empty)
                        dsFilter.Tables(0).Rows(iCount)("AppliedTo") = Cast.ToString(dsFees.Tables(0).Rows(iCount).Item("ProductDesc"), String.Empty)
                        dsFilter.Tables(0).Rows(iCount)("Premium") = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("fee_premium"), 0.0)
                        dRate_Percentage = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("fee_rate_percentage"), 0.0)
                        IsFeeTypePercent = CBool(Cast.ToBoolean(dsFees.Tables(0).Rows(iCount).Item("FeeTypePercent"), False))

                        dRate_Amount = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("fee_rate_amount"), 0.0)


                        If Not (IsFeeTypePercent) Then
                            dsFilter.Tables(0).Rows(iCount)("Rate") = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("fee_rate_amount"), 0.0)
                            dsFilter.Tables(0).Rows(iCount)("IsValue") = True
                        Else
                            dsFilter.Tables(0).Rows(iCount)("Rate") = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("fee_rate_percentage"), 0.0)
                            dsFilter.Tables(0).Rows(iCount)("IsValue") = False
                        End If

                        dsFilter.Tables(0).Rows(iCount)("FeeAmount") = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("currency_amount"), 0.0)
                        dsFilter.Tables(0).Rows(iCount)("TaxAmount") = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("currency_tax_amount"), 0.0)
                        dCurrency_Amount = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("currency_amount"), 0.0)
                        dCurrency_Tax_Amount = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("currency_tax_amount"), 0.0)
                        dsFilter.Tables(0).Rows(iCount)("TotalAmount") = dCurrency_Amount + dCurrency_Tax_Amount
                        dsFilter.Tables(0).Rows(iCount)("TaxGroup") = Cast.ToString(dsFees.Tables(0).Rows(iCount).Item("description4"), String.Empty)
                        dsFilter.Tables(0).Rows(iCount)("IncludeInInstallment") = Cast.ToInt16(dsFees.Tables(0).Rows(iCount).Item("include_fee_in_instalments"), 0)
                        dsFilter.Tables(0).Rows(iCount)("SpreadAcrossInstallment") = Cast.ToInt16(dsFees.Tables(0).Rows(iCount).Item("spread_fee_across_instalments"), 0)
                        dsFilter.Tables(0).Rows(iCount)("PolicyFeeKey") = Cast.ToInt32(dsFees.Tables(0).Rows(iCount).Item("policy_fee_u_id"), 0)
                        dsFilter.Tables(0).Rows(iCount)("CalculationBasis") = Cast.ToInt16(dsFees.Tables(0).Rows(iCount).Item("calculation_basis"), 0)
                        dsFilter.Tables(0).Rows(iCount)("DoPaymentTermsId") = Cast.ToInt32(dsFees.Tables(0).Rows(iCount).Item("dopaymentterms_id"), 0)
                        dsFilter.Tables(0).Rows(iCount)("MakeLiveOptionsId") = Cast.ToInt32(dsFees.Tables(0).Rows(iCount).Item("makeliveoptions_id"), 0)
                        dsFilter.Tables(0).Rows(iCount)("IsProrated") = Cast.ToInt16(dsFees.Tables(0).Rows(iCount).Item("is_prorated"), 0)
                        dsFilter.Tables(0).Rows(iCount)("ProRataRate") = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("pro_rata_rate"), 0.0)

                    Next
                End With
            End If

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Insurance_File_Details")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndPolicyFeesByKeyRequest.InsuranceFileKey)

                dsHeader = con.ExecuteDataSet(cmd, "Row")

            End Using

        End If

        'To populate the XML Document with the dsHeader, dsfees and dsTotals information

        If (dsHeader.Tables.Count >= 1) Then
            If (dsHeader.Tables(0).Rows.Count >= 1) Then

                With dsHeader.Tables(0)
                    oGetHeaderAndPolicyFeesByKeyResponse.InsuranceFileKey = Cast.ToInt32(.Rows(0).Item("insurance_file_cnt"), 0)
                    oGetHeaderAndPolicyFeesByKeyResponse.ClientCode = .Rows(0).Item("shortname").ToString
                    oGetHeaderAndPolicyFeesByKeyResponse.InsuranceFileRef = .Rows(0).Item("insurance_ref").ToString
                    oGetHeaderAndPolicyFeesByKeyResponse.Agent = .Rows(0).Item("name1").ToString
                    oGetHeaderAndPolicyFeesByKeyResponse.InceptionDate = Cast.ToDateTime(.Rows(0).Item("inception_date"), Date.Now)
                    oGetHeaderAndPolicyFeesByKeyResponse.CoverStartDate = Cast.ToDateTime(.Rows(0).Item("cover_start_date"), Date.Now)
                    oGetHeaderAndPolicyFeesByKeyResponse.ExpiryDate = Cast.ToDateTime(.Rows(0).Item("expiry_date"), Date.Now)
                    oGetHeaderAndPolicyFeesByKeyResponse.Currency = .Rows(0).Item("description").ToString

                End With
            End If
        End If
        If (dsTotals.Tables.Count >= 1) Then
            If (dsTotals.Tables(0).Rows.Count >= 1) Then
                With dsTotals.Tables(0)

                    oGetHeaderAndPolicyFeesByKeyResponse.TotalRiskFees = Cast.ToDouble(.Rows(0).Item(0), 0.0)
                    oGetHeaderAndPolicyFeesByKeyResponse.TotalPolicyFees = Cast.ToDouble(.Rows(0).Item(1), 0.0)
                    oGetHeaderAndPolicyFeesByKeyResponse.TotalRiskFeesEligibleForFinancing = Cast.ToDouble(.Rows(0).Item(2), 0.0)
                    oGetHeaderAndPolicyFeesByKeyResponse.TotalPolicyFeesEligibleForFinancing = Cast.ToDouble(.Rows(0).Item(3), 0.0)
                    oGetHeaderAndPolicyFeesByKeyResponse.TotalRiskFeesExcludedFromFinancing = Cast.ToDouble(.Rows(0).Item(4), 0.0)
                    oGetHeaderAndPolicyFeesByKeyResponse.TotalPolicyFeesExcludedFromFinancing = Cast.ToDouble(.Rows(0).Item(5), 0.0)

                End With
            End If
        End If

        Dim xmlDoc As New System.Xml.XmlDocument

        dsFilter.DataSetName = "BaseGetHeaderAndPolicyFeesByKeyResponseTypePolicyFees"
        dsFilter.Tables(0).TableName = "Row"
        If GetHeaderAndPolicyFeesByKeyRequest.WCFSecurityToken = "" Then
            xmlDoc.LoadXml(dsFilter.GetXml)
            If (dsFilter.Tables.Count >= 1) Then
                oGetHeaderAndPolicyFeesByKeyResponse.ResultDataset = xmlDoc.DocumentElement()
            End If
        End If

        If (dsFilter.Tables.Count >= 1) Then
            oGetHeaderAndPolicyFeesByKeyResponse.ResultData = dsFilter
        End If

        Return oGetHeaderAndPolicyFeesByKeyResponse

    End Function


