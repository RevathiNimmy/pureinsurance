    '''<summary>
    '''Generic Function Which is used to fetch Description by specifiying Description ID 
    '''<summary>
    '''<param name="SiriusConnection">This parameter used to open the Database connection </param>
    '''<param name="sTableName">This is the Name of Table </param>
    '''<param name="sTableKeyNameToReturn">column Name which needs to be return</param>
    '''<param name="sFieldNameToValidate">Column Name which used to validate</param>
    '''<param name="sValueToValidate">This is Field value which is used to filter</param>

    Private Function GetAndValidateDescriptionById(
       ByVal con As SiriusConnection,
       ByVal sTableName As String,
       ByVal sTableKeyNameToReturn As String,
       ByVal sFieldNameToValidate As String,
       ByVal sValueToValidate As String) As String

        Dim dt As DataTable = Nothing
        Dim sReturn As String = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_And_Validate_Field")

            cmd.AddInParameter("@table_name", SqlDbType.VarChar, 255).Value = sTableName
            cmd.AddInParameter("@field_to_return_name", SqlDbType.VarChar, 255).Value = sTableKeyNameToReturn
            cmd.AddInParameter("@field_to_validate_name", SqlDbType.VarChar, 255).Value = sFieldNameToValidate
            cmd.AddInParameter("@field_to_validate_value", SqlDbType.VarChar, 255).Value = sValueToValidate

            dt = con.ExecuteDataTable(cmd)

        End Using

        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            ' there should be only 1
            For Each dr As DataRow In dt.Rows
                sReturn = dr.Item(0).ToString
            Next
        Else
            sReturn = String.Empty
        End If

        Return sReturn
    End Function

    '''<summary>
    '''Generic Public Function Which is used to fetch Description by specifiying Description ID 
    '''<summary>
    '''<param name="sTableName">This is the Name of Table </param>
