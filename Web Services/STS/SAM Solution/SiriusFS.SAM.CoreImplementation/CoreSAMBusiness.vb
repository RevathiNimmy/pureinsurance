    ''' <summary>
    ''' This  method for MarkUnmarkTransaction
    '''<param name="con" type="SiriusConnection"></param>   
    '''<param name="oMarkUnmarkTransactionRequest" type="BaseMarkUnmarkTransactionRequestType"></param>   
    '''<returns>BaseMarkUnmarkTransactionResponseType</returns>
    '''</summary>
    '''<remarks></remarks> 
    Public Overloads Function MarkUnmarkTransaction(ByVal con As SiriusConnection,
                                        ByVal oMarkUnmarkTransactionRequest As BaseMarkUnmarkTransactionRequestType) _
                                        As BaseMarkUnmarkTransactionResponseType

        Dim oMarkUnmarkTransactionResponse As New BaseMarkUnmarkTransactionResponseType
        Dim oErrors As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iCurrency As Integer
        Dim iDocId As Integer
        Dim iRet As Integer
        If oMarkUnmarkTransactionRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.MarkUnmarkTransactionRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oMarkUnmarkTransactionResponse = New SAMForInsuranceV2ImplementationTypes.MarkUnmarkTransactionResponseType
        End If

        oMarkUnmarkTransactionRequest.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        iDocId = GetAndValidateSpecifiedTableCode(con, "transdetail", "document_id", "transdetail_id", oMarkUnmarkTransactionRequest.TransactionKey.ToString(), oErrors, "TransactionKey")
        iCurrency = GetAndValidateSpecifiedTableCode(con, PMLookupTable.Currency, "Currency_id", "Code", oMarkUnmarkTransactionRequest.CurrencyCode.ToString(), oErrors, "CurrencyKey")
        oErrors.CheckForErrors()

        Const sACMethodName As String = "MarkUnmarkTransaction"
        Dim oDatabase As dPMDAO.Database = Nothing
        Dim oDatabaseObject As Object = oDatabase
        Dim oInsurerPayment As bACTInsurerPaymentSFU.Business = Nothing
        Try
            oInsurerPayment = New bACTInsurerPaymentSFU.Business
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bACTInsurerPaymentSFU.Business ", ex.Message)
            STSErrorEx.SetContext(oMarkUnmarkTransactionResponse.STSError, HttpContext.Current.Request.Url.ToString(), sACMethodName, "CreatebGISSTS", True)
            Return oMarkUnmarkTransactionResponse
        End Try

        Try
            oInsurerPayment.Initialise(sUsername:=_SiriusUser.Username, sPassword:=_SiriusUser.Password, iUserID:=_SiriusUser.UserID, iSourceID:=_SiriusUser.SourceID, iLanguageID:=_SiriusUser.LanguageID, iCurrencyID:=_SiriusUser.CurrencyID, iLogLevel:=SiriusUserDefaults.LogLevel, sCallingAppName:=sACMethodName, vDatabase:=oDatabaseObject)
        Catch ex As Exception
            If oInsurerPayment IsNot Nothing Then
                oInsurerPayment.Dispose()
                oInsurerPayment = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bACTInsurerPaymentSFU.Application", ex.Message)
            STSErrorEx.SetContext(oMarkUnmarkTransactionResponse.STSError, HttpContext.Current.Request.Url.ToString(), sACMethodName, "bACTInsurerPaymentSFU.Initialise", True)
            Return oMarkUnmarkTransactionResponse
        End Try

        If oMarkUnmarkTransactionRequest.MarkStatus = MarkStatusType.Mark Then
            iRet = oInsurerPayment.MarkTransaction(v_lTransactionID:=oMarkUnmarkTransactionRequest.TransactionKey,
                       v_iCurrencyID:=Convert.ToInt16(iCurrency),
                        v_cPayment:=oMarkUnmarkTransactionRequest.PaymentAmount)
        Else
            Dim sIsWriteOff As String = String.Empty
            sIsWriteOff = GetAndValidateDescriptionById(con, "transdetail", "spare", "transdetail_id", oMarkUnmarkTransactionRequest.TransactionKey.ToString())
            If sIsWriteOff = "WRITEOFF" Then
                iRet = oInsurerPayment.DeleteWriteOffTransaction(Docid:=iDocId)
            Else
                iRet = oInsurerPayment.UnMarkTransaction(v_lTransDetailId:=oMarkUnmarkTransactionRequest.TransactionKey)
            End If
        End If
        'PN-71611
        If (iRet <> PMReturnCode.PMTrue And iRet <> PMReturnCode.PMNotFound) Then
            RaiseComMethodException("bACTInsurerPaymentSFU.Business", iRet)
        End If

        Try
            If oInsurerPayment IsNot Nothing Then
                oInsurerPayment.Dispose()
                oInsurerPayment = Nothing
            End If
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to terminate business", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), sACMethodName, "Terminate", True)
        End Try
        Return oMarkUnmarkTransactionResponse
    End Function

