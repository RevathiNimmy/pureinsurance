        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oCoreBusiness As New CoreBusiness
        Dim oResponse As BaseImplementationTypes.BaseGetPoliciesForRenewalSelectionResponseType
        Dim nTypeOfPackage As enumTypeOfPackage

        ' determine the type of package and thus the type of response
        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetPoliciesForRenewalSelectionRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetPoliciesForRenewalSelectionResponseType
        Else
            oResponse = New BaseImplementationTypes.BaseGetPoliciesForRenewalSelectionResponseType
        End If

        '*********************
        ' STRUCTURE VALIDATION 
        '*********************

        ' validate the mandatory structure data
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        ' if there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        '*********************
        ' DATA VALIDATION 
        '*********************

        ' Look up validation for branch code if provided
        If Not String.IsNullOrEmpty(oRequest.BranchCode) Then
            oRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
            oSAMErrorCollection.CheckForErrors()
        End If

        ' Look up validation for product code if provided
        If Not String.IsNullOrEmpty(oRequest.ProductCode) Then
            oRequest.ProductID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Product, oRequest.ProductCode, "ProductCode", oSAMErrorCollection)
            oSAMErrorCollection.CheckForErrors()
        End If
        '*********************
        ' Get Required Information 
        '*********************

        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=ConnectionString)

            Dim dsPoliciesForRenewalSelection As DataSet = GetPoliciesForRenewalSelectionDataset(con, oRequest)

            dsPoliciesForRenewalSelection.DataSetName = "BaseGetPoliciesForRenewalSelectionResponseTypePolicies"

