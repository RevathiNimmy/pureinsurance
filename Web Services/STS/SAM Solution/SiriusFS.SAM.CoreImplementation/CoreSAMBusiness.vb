    Public Overloads Function UpdateStandardPolicyWordings(ByVal conUpdateWordings As SiriusConnection, ByVal oUpdateStandardPolicyWordingsRequest As BaseUpdateStandardPolicyWordingsRequestType) As BaseUpdateStandardPolicyWordingsResponseType
        Dim insuranceFileTypeId As Integer = 0
        Dim insuranceFileTypeCode As String = String.Empty

        Dim oUpdateStandardPolicyWordingsResponse As New BaseUpdateStandardPolicyWordingsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oUpdateStandardPolicyWordingsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateStandardPolicyWordingsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateStandardPolicyWordingsResponse = New SAMForInsuranceV2ImplementationTypes.UpdateStandardPolicyWordingsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If
        'validation of input data
        ' Check mandatory fields
        If String.IsNullOrEmpty(oUpdateStandardPolicyWordingsRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If
        If oUpdateStandardPolicyWordingsRequest.InsuranceFileKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        If oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings IsNot Nothing Then
            If oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row IsNot Nothing Then
                For iCount As Integer = 0 To oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row.Length - 1

                    If String.IsNullOrEmpty(oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row(iCount).Code) Then
                        oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                    SAMInvalidData.MandatoryInputMissing.ToString,
                                                    "Code")
                    End If
                Next
                oErrors.CheckForErrors()
            End If
        End If
        oErrors.CheckForErrors()

        'Business rule validation
        GetInsuranceFileType(conUpdateWordings, oUpdateStandardPolicyWordingsRequest.InsuranceFileKey, insuranceFileTypeId, insuranceFileTypeCode)

        If insuranceFileTypeCode = InsuranceFileType.LivePolicy Then
            oErrors.AddBusinessRule(SAMBusinessErrors.CanNotUpdateLivePolicyDetails,
                SAMBusinessErrors.CanNotUpdateLivePolicyDetails.ToString,
                "Can not update StandardPolicyWordings details for a live poilcy")
        End If
        oErrors.CheckForErrors()

        'As said by Gaurav to get the insurance folder key
        Dim r_lInsFolderCnt As Integer = 0
        Dim r_lSourceId As Integer = 0
        oCoreBusiness.CheckInsuranceFile(conUpdateWordings, oUpdateStandardPolicyWordingsRequest.InsuranceFileKey, r_lInsFolderCnt, r_lSourceId)

        'Use the time stamp for record locking purposes
        Dim oAnyError As STSErrorType
        oAnyError = oCoreBusiness.CheckTSAndLock(
            BranchCode:=oUpdateStandardPolicyWordingsRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=r_lInsFolderCnt,
            TStamp:=oUpdateStandardPolicyWordingsRequest.TimeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oUpdateStandardPolicyWordingsResponse.STSError = oAnyError
            Return oUpdateStandardPolicyWordingsResponse
        End If

        Try
            'Handle current selected documents to ensure we retain the correct document template ids
            If oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings IsNot Nothing AndAlso oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row IsNot Nothing Then
                For iCount As Integer = 0 To oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row.Length - 1
                    If oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row(iCount).DocumentTemplateKey = 0 And
                        oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row(iCount).Code.TrimEnd.EndsWith("_ED") Then

                        Using cmd As SiriusCommand = SiriusCommand.FromText("select @document_template_id=psw.document_template_id from policy_standard_wording psw " &
                            "inner join Document_Template dt ON dt.document_template_id=psw.document_template_id " &
                            "where psw.insurance_file_cnt = @insurance_file_cnt and dt.code=@code")

                            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oUpdateStandardPolicyWordingsRequest.InsuranceFileKey)
                            cmd.AddInParameter("@code", SqlDbType.VarChar, 255).Value = oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row(iCount).Code.TrimEnd
                            cmd.AddOutParameter("@document_template_id", SqlDbType.Int).Value = 0
                            conUpdateWordings.ExecuteNonQuery(cmd)

                            oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row(iCount).DocumentTemplateKey = Cast.ToInt32(cmd.Parameters("@document_template_id").Value, 0)
                        End Using
                    End If
                Next iCount
            End If

            conUpdateWordings.BeginTransaction()
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Del_Standard_Policy_Wordings")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oUpdateStandardPolicyWordingsRequest.InsuranceFileKey)
                conUpdateWordings.ExecuteNonQuery(cmd)
            End Using

            Dim policyStandardWordingId As Integer
            Dim DocumentTemplateId As Integer
            Dim strcode As String
            'The parameter @policy_standard_wording_id is a manually calculated incremental field, starting with 1 in the first iteration.
            policyStandardWordingId = 1
            If oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings IsNot Nothing AndAlso oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row IsNot Nothing Then
                For iCount As Integer = 0 To oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row.Length - 1
                    Using cmdUpdateWordings As SiriusCommand = SiriusCommand.FromProcedure("spe_policy_standard_wordin_add")
                        If oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row(iCount).DocumentTemplateKey = 0 Then
                            strcode = oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row(iCount).Code
                            DocumentTemplateId = GetAndValidateSpecifiedTableCode(conUpdateWordings, "Document_Template", "Document_Template_ID", "code", strcode, oErrors, "strcode")
                        Else
                            DocumentTemplateId = oUpdateStandardPolicyWordingsRequest.PolicyStandardWordings.Row(iCount).DocumentTemplateKey
                        End If
                        cmdUpdateWordings.Parameters.Clear()
                        cmdUpdateWordings.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oUpdateStandardPolicyWordingsRequest.InsuranceFileKey
                        cmdUpdateWordings.AddInParameter("@policy_standard_wording_id", SqlDbType.Int).Value = policyStandardWordingId
                        cmdUpdateWordings.AddInParameter("@document_template_id", SqlDbType.Int).Value = DocumentTemplateId
                        conUpdateWordings.ExecuteNonQuery(cmdUpdateWordings)
                    End Using
                    policyStandardWordingId = policyStandardWordingId + 1
                Next
            End If

            conUpdateWordings.CommitTransaction()
        Catch ex As Exception
            conUpdateWordings.RollbackTransaction()
        End Try

        'Populate the response with any error code, as well as the used timestamp for locking
        oAnyError = oCoreBusiness.UnlockAndGetTS(
       BranchCode:=oUpdateStandardPolicyWordingsRequest.BranchCode,
       Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
       LockValue:=r_lInsFolderCnt,
       TStamp:=oUpdateStandardPolicyWordingsResponse.TimeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Unable to unlock, return the error.
            oUpdateStandardPolicyWordingsResponse.STSError = oAnyError
            Return oUpdateStandardPolicyWordingsResponse
        End If

        Return oUpdateStandardPolicyWordingsResponse

    End Function

