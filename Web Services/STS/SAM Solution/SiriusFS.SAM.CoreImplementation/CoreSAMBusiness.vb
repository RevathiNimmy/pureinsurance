    ''' <summary>
    '''This  method  will perform the business
    '''</summary>
    '''<param name="conBankGuarantee">An object of a class SiriusConnection</param>
    '''<param name="oAddBankGuaranteeRequest">An object of a class BaseAddBankGuaranteeRequestType</param>
    '''<remarks></remarks> 
    Public Overloads Function AddBankGuarantee(ByVal conBankGuarantee As SiriusConnection, ByVal oAddBankGuaranteeRequest As BaseAddBankGuaranteeRequestType) As BaseAddBankGuaranteeResponseType
        Dim oAddBankGuaranteeResponse As New BaseAddBankGuaranteeResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage

        If oAddBankGuaranteeRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AddBankGuaranteeRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oAddBankGuaranteeResponse = New SAMForInsuranceV2ImplementationTypes.AddBankGuaranteeResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        If String.IsNullOrEmpty(oAddBankGuaranteeRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        For Each BankGuarantee As BaseBankGuaranteeItemType In oAddBankGuaranteeRequest.BankGuarantee
            BankGuarantee.Validate(CObj(oSAMErrorCollection))
        Next
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Data Validation
        '*******************************************************************************************

        oAddBankGuaranteeRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
            PMLookupTable.Source, oAddBankGuaranteeRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        For Each BankGuarantee As BaseBankGuaranteeItemType In oAddBankGuaranteeRequest.BankGuarantee
            ValidateDataBankGuaranteeItem(oSAMErrorCollection, oCoreBusiness, conBankGuarantee, BankGuarantee)
        Next
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        ' Business Rule Validation
        '*******************************************************************************************
        For Each BankGuarantee As BaseBankGuaranteeItemType In oAddBankGuaranteeRequest.BankGuarantee
            ValidateBusinessBankGuaranteeItem(oSAMErrorCollection, conBankGuarantee, BankGuarantee, oAddBankGuaranteeRequest.SourceId)
        Next
        oSAMErrorCollection.CheckForErrors()

        Using conBankGuarantee
            conBankGuarantee.BeginTransaction()
            Dim iCount As Integer = 0
            Dim iBG_id As Integer
            Dim bIsLocked As Boolean
            Try
                ' For each row in the request
                oAddBankGuaranteeResponse.BankGuarantee = New BaseAddBankGuaranteeResponseTypeBankGuarantee
                For Each BankGuarantee As BaseBankGuaranteeItemType In oAddBankGuaranteeRequest.BankGuarantee
                    iBG_id = 0
                    BankGuarantee.LimitAvailable = BankGuarantee.BGLimit
                    If (BankGuarantee IsNot Nothing) Then
                        AddBankGuaranteeItem(oSAMErrorCollection, oCoreBusiness, conBankGuarantee,
                        BankGuarantee, iBG_id)
                        AddBankGuaranteEvents(oSAMErrorCollection, conBankGuarantee, BankGuarantee, iBG_id)
                    End If
                    ReDim Preserve oAddBankGuaranteeResponse.BankGuarantee.Row(iCount)
                    oAddBankGuaranteeResponse.BankGuarantee.Row(iCount) = New BaseAddBankGuaranteeResponseTypeBankGuaranteeRow
                    oAddBankGuaranteeResponse.BankGuarantee.Row(iCount).BGKey = iBG_id
                    oAddBankGuaranteeResponse.BankGuarantee.Row(iCount).BGRef = BankGuarantee.BankGuaranteeRef
                    Dim AnyError As STSErrorType
                    AnyError = oCoreBusiness.GetTimestamp(
                        oAddBankGuaranteeRequest.BranchCode,
                        CoreBusiness.LockName.BGId,
                        iBG_id,
                         oAddBankGuaranteeResponse.BankGuarantee.Row(iCount).BGTimeStamp,
                         bIsLocked)
                    If AnyError Is Nothing = False Then
                        oAddBankGuaranteeResponse.STSError = AnyError
                    End If

                    If (BankGuarantee.Products IsNot Nothing) Then
                        For Each products As BaseBankGuaranteeItemTypeProducts In BankGuarantee.Products
                            AddBankGuaranteeProducts(oSAMErrorCollection, conBankGuarantee,
                           products, iBG_id)
                        Next
                    End If
                    If (BankGuarantee.Branches IsNot Nothing) Then
                        For Each Branches As BaseBankGuaranteeItemTypeBranches In BankGuarantee.Branches
                            AddBankGuaranteeBranches(oSAMErrorCollection, conBankGuarantee,
                           Branches, iBG_id)
                        Next
                    End If
                    iCount += 1
                Next
                conBankGuarantee.CommitTransaction()
            Catch ex As Exception
                conBankGuarantee.RollbackTransaction()
                Throw
            End Try
        End Using
        Return oAddBankGuaranteeResponse
    End Function

