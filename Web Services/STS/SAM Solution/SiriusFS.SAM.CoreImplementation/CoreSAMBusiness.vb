    Public Overloads Function GetCashDeposit(ByVal conCashDeposit As SiriusConnection, ByVal oGetCashDepositRequest As BaseGetCashDepositRequestType) As BaseGetCashDepositResponseType

        Dim oGetCashDepositResponse As New BaseGetCashDepositResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetCashDepositRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetCashDepositRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetCashDepositResponse = New SAMForInsuranceV2ImplementationTypes.GetCashDepositResponseType
        End If
        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetCashDepositRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If String.IsNullOrEmpty(oGetCashDepositRequest.CashDepositRef) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "CashDepositRef")
        End If

        ' exit if there are any missing parameters
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Lookup and data Validation
        '*******************************************************************************************

        oGetCashDepositRequest.CashDepositKey = GetAndValidateSpecifiedTableCode(conCashDeposit,
                "CashDeposit", "CashDeposit_ID", "CashDeposit_Ref", oGetCashDepositRequest.CashDepositRef, oSAMErrorCollection, "CashDepositRef")

        Dim dsCashDeposit As DataSet = Nothing
        Dim dsCashDepositProducts As DataSet = Nothing
        Dim dsCashDepositBranches As DataSet = Nothing

        If String.IsNullOrEmpty(oGetCashDepositRequest.PartyCode) Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_party_code_for_cash_deposit")
                cmd.AddInParameter("@CashDeposit_Ref", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(oGetCashDepositRequest.CashDepositRef, "")
                dsCashDeposit = conCashDeposit.ExecuteDataSet(cmd, "CashDeposit")
                If (dsCashDeposit IsNot Nothing) Then
                    If (dsCashDeposit.Tables.Count >= 1) Then
                        If (dsCashDeposit.Tables(0).Rows.Count >= 1) Then

                            With oGetCashDepositRequest
                                .PartyCode = dsCashDeposit.Tables(0).Rows(0).Item("shortname").ToString

                            End With

                        End If
                    End If
                End If
            End Using
        End If

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_CashDeposit_For_CD_Maintenance")
            cmd.AddInParameter("@Party_Code", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(oGetCashDepositRequest.PartyCode, "")
            cmd.AddInParameter("@CashDeposit_Ref", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(oGetCashDepositRequest.CashDepositRef, "")
            'cmd.AddInParameter("@Branch_Code", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(oGetCashDepositRequest.BranchCode, "")
            dsCashDeposit = conCashDeposit.ExecuteDataSet(cmd, "CashDeposit")
            If (dsCashDeposit IsNot Nothing) Then
                If (dsCashDeposit.Tables.Count >= 1) Then
                    If (dsCashDeposit.Tables(0).Rows.Count >= 1) Then

                        With oGetCashDepositResponse
                            .AccountKey = Cast.ToInt32(dsCashDeposit.Tables(0).Rows(0).Item("Account_ID"), 0)
                            .CashDepositKey = Cast.ToInt32(dsCashDeposit.Tables(0).Rows(0).Item("CashDeposit_ID"), 0)
                            .PartyKey = Cast.ToInt32(dsCashDeposit.Tables(0).Rows(0).Item("Party_ID"), 0)
                            .IsSinglePolicy = Cast.ToBoolean(dsCashDeposit.Tables(0).Rows(0).Item("Is_SinglePolicy"), False)
                            .IsDeleted = Cast.ToInt16(dsCashDeposit.Tables(0).Rows(0).Item("Is_Deleted"), 0)
                        End With

                    End If
                End If
            End If
        End Using

        Dim uBound As Integer = 0
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CashDeposit_Product_Sel")
            cmd.AddInParameter("@CashDeposit_ID", SqlDbType.Int).Value = Cast.NullIfDefault(oGetCashDepositRequest.CashDepositKey, 0)
            dsCashDepositProducts = conCashDeposit.ExecuteDataSet(cmd, "CashDepositItemProducts")
            If (dsCashDepositProducts IsNot Nothing) Then
                If (dsCashDepositProducts.Tables.Count >= 1) Then
                    If (dsCashDepositProducts.Tables(0).Rows.Count >= 1) Then

                        For iCount As Integer = 0 To dsCashDepositProducts.Tables(0).Rows.Count - 1
                            ReDim Preserve oGetCashDepositResponse.Products(iCount)
                            oGetCashDepositResponse.Products(iCount) = New BaseGetCashDepositResponseTypeProducts
                            With oGetCashDepositResponse.Products(iCount)
                                .Description = Cast.ToString(dsCashDepositProducts.Tables(0).Rows(iCount).Item("description"), Nothing)
                                .ProductCode = Cast.ToString(dsCashDepositProducts.Tables(0).Rows(iCount).Item("Code"), Nothing)
                                .ProductKey = Cast.ToInt32(dsCashDepositProducts.Tables(0).Rows(iCount).Item("Product_id"), 0)
                            End With
                        Next
                    End If
                End If
            End If

        End Using

        uBound = 0

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CashDeposit_Branch_Sel")
            cmd.AddInParameter("@CashDeposit_ID", SqlDbType.Int).Value = Cast.NullIfDefault(oGetCashDepositRequest.CashDepositKey, 0)
            dsCashDepositBranches = conCashDeposit.ExecuteDataSet(cmd, "CashDepositItemBranches")
            If (dsCashDepositBranches IsNot Nothing) Then
                If (dsCashDepositProducts.Tables.Count >= 1) Then
                    If (dsCashDepositBranches.Tables(0).Rows.Count >= 1) Then

                        For iCount As Integer = 0 To dsCashDepositBranches.Tables(0).Rows.Count - 1
                            ReDim Preserve oGetCashDepositResponse.Branches(iCount)
                            oGetCashDepositResponse.Branches(iCount) = New BaseGetCashDepositResponseTypeBranches
                            With oGetCashDepositResponse.Branches(iCount)
                                .BranchCode = Cast.ToString(dsCashDepositBranches.Tables(0).Rows(iCount).Item("code"), Nothing)
                                .Description = Cast.ToString(dsCashDepositBranches.Tables(0).Rows(iCount).Item("description"), ToString)
                                .BranchKey = Cast.ToInt32(dsCashDepositBranches.Tables(0).Rows(iCount).Item("Source_id"), 0)
                            End With
                        Next

                    End If
                End If
            End If

        End Using

        ' Get the Timestamp
        Dim bIsLocked As Boolean
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.GetTimestamp(
                            oGetCashDepositRequest.BranchCode,
                            CoreBusiness.LockName.CashDepositKey,
                            oGetCashDepositRequest.CashDepositKey,
                            oGetCashDepositResponse.CDTimeStamp,
                            bIsLocked)
        ' Return AnyErrors
        If AnyError Is Nothing = False Then
            oGetCashDepositResponse.STSError = AnyError
        End If

        Return oGetCashDepositResponse
    End Function

