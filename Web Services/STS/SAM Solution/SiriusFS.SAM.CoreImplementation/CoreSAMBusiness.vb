    ''' <summary>
    ''' This  method is used to Update the Receipt Media Type Status.
    '''<param name="oRequest" type="BaseUpdateReceiptMediaTypeStatusRequestType"></param>
    '''<param name="con" type="SiriusConnection"></param> 
    '''<returns>BaseUpdateReceiptMediaTypeStatusResponseType</returns>
    '''<remarks></remarks>   
    Public Function UpdateReceiptMediaTypeStatus(ByVal con As SiriusConnection,
    ByVal oRequest As BaseUpdateReceiptMediaTypeStatusRequestType) As BaseUpdateReceiptMediaTypeStatusResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseUpdateReceiptMediaTypeStatusResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iMediaTypeId As Int32
        Dim iMediaTypeStatusId As Int32

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateReceiptMediaTypeStatusRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateReceiptMediaTypeStatusResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        If oRequest.CashListItems IsNot Nothing AndAlso oRequest.CashListItems.Row IsNot Nothing Then
            For iCount As Integer = 0 To oRequest.CashListItems.Row.Length - 1

                If oRequest.CashListItems.Row(iCount).CashListItemKey = 0 Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "CashListItemKey")
                End If

                If String.IsNullOrEmpty(oRequest.CashListItems.Row(iCount).MediaTypeCode) Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "MediaTypeCode")
                End If
                If String.IsNullOrEmpty(oRequest.CashListItems.Row(iCount).MediaTypeStatusCode) Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "MediaTypeStatusCode")
                End If
                If oRequest.CashListItems.Row(iCount).ModifiedDate = Date.MinValue Or oRequest.CashListItems.Row(iCount).ModifiedDate = Nothing Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "ModifiedDate")
                End If
            Next
        End If
        ' throw any structure related errors
        oSAMErrorCollection.CheckForErrors()
        ValidateUpdateReceiptMediaTypeStatusLookup(con, oBusiness, oSAMErrorCollection, oRequest)
        oSAMErrorCollection.CheckForErrors()
        Try
            con.BeginTransaction()

            If oRequest.CashListItems IsNot Nothing AndAlso oRequest.CashListItems.Row IsNot Nothing Then
                For iCount As Integer = 0 To oRequest.CashListItems.Row.Length - 1
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Update_Receipt_MediaType_Status")
                        cmd.Parameters.Clear()
                        cmd.AddInParameter("@CashListItem_Id", SqlDbType.Int).Value = oRequest.CashListItems.Row(iCount).CashListItemKey
                        cmd.AddInParameter("@Comments", SqlDbType.VarChar, 255).Value = oRequest.CashListItems.Row(iCount).Comments
                        cmd.AddInParameter("@User_Id", SqlDbType.SmallInt).Value = _SiriusUser.UserID
                        cmd.AddInParameter("@Date_Modified", SqlDbType.DateTime).Value = oRequest.CashListItems.Row(iCount).ModifiedDate
                        If oRequest.CashListItems.Row(iCount).InsuranceFileKey <> 0 Then
                            cmd.AddInParameter("@Insurance_File_Cnt", SqlDbType.Int).Value = oRequest.CashListItems.Row(iCount).InsuranceFileKey
                        End If
                        If Not String.IsNullOrEmpty(oRequest.CashListItems.Row(iCount).DocumentRef) Then
                            cmd.AddInParameter("@Document_Ref", SqlDbType.VarChar, 25).Value = oRequest.CashListItems.Row(iCount).DocumentRef
                        End If
                        If Not String.IsNullOrEmpty(oRequest.CashListItems.Row(iCount).MediaTypeCode) Then
                            iMediaTypeId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.MediaType, oRequest.CashListItems.Row(iCount).MediaTypeCode, "MediaTypeCode", oSAMErrorCollection)
                        End If
                        If Not String.IsNullOrEmpty(oRequest.CashListItems.Row(iCount).MediaTypeStatusCode) Then
                            iMediaTypeStatusId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.MediaTypeStatus, oRequest.CashListItems.Row(iCount).MediaTypeStatusCode, "MediaTypeStatusCode", oSAMErrorCollection)
                        End If
                        cmd.AddInParameter("@MediaType_Id", SqlDbType.Int).Value = iMediaTypeId
                        cmd.AddInParameter("@MediaTypeStatus_Id", SqlDbType.Int).Value = iMediaTypeStatusId
                        con.ExecuteNonQuery(cmd)
                    End Using

                    If Not String.IsNullOrEmpty(oRequest.CashListItems.Row(iCount).MediaTypeStatusCode) Then
                        If oRequest.CashListItems.Row(iCount).MediaTypeStatusCode = "SRPB" Then
                            Dim ocreateWMTaskRequest As New SAMForInsuranceV2ImplementationTypes.CreateWmTaskRequestType
                            Dim ocreateWMTaskResponse As BaseCreateWmTaskResponseType
                            Dim sInsuranceRef As String
                            sInsuranceRef = GetAndValidateDescriptionById(con, "Insurance_file", "insurance_ref", "Insurance_file_cnt", oRequest.CashListItems.Row(iCount).InsuranceFileKey.ToString())
                            'TODO - Use correct user/user group fromt the system options
                            ocreateWMTaskRequest.AllocationUser = _SiriusUser.Username
                            ocreateWMTaskRequest.AllocationUserGroup = "SYSADMIN"
                            ocreateWMTaskRequest.BranchCode = oRequest.BranchCode
                            ocreateWMTaskRequest.Client = "Customer"
                            ocreateWMTaskRequest.Description = "Cancel the policy  " & sInsuranceRef
                            ocreateWMTaskRequest.DueDateTime = Now
                            ocreateWMTaskRequest.IsComplete = False
                            ocreateWMTaskRequest.Task = "UWCancel"
                            ocreateWMTaskRequest.TaskGroup = "UNDER"
                            ocreateWMTaskRequest.UserId = _SiriusUser.UserID
                            ocreateWMTaskResponse = CreateWmTask(con, ocreateWMTaskRequest)
                        End If
                    End If
                Next
            End If
            con.CommitTransaction()
        Catch ex As Exception
            con.RollbackTransaction()
        End Try
        Return oResponse
    End Function

