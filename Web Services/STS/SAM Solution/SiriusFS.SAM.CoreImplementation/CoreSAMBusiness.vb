    Private Overloads Sub UpdateRiskFromGIS(ByVal con As SiriusConnection,
                                  ByVal lInsuranceFileCnt As Int32,
                                  ByVal lRiskCnt As Int32,
                                  ByVal sXMLDataSet As String,
                                  ByVal sDataModelCode As String)

        Const ACMethodName As String = "UpdateRiskFromGIS"

        Dim oGIS As bGIS.Application = Nothing
        Dim iRet As System.Int32
        Dim ErrEx As Exception = Nothing
        'Dim Utils As Utilities
        Dim vRiskArray As System.Array
        Dim vRiskArrayObject As Object = Nothing

        Dim dr As DataSet = Nothing
        Dim arParams(0) As SqlParameter

        ' Get the RiskCnt if not passed (broking)
        '-----------------------------------------

        If lRiskCnt = 0 Then

            ' BSJ April 09 - SQL Mixed Mode Compliance
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetRiskcntInsuranceFolderCnt_for_Insurancefilecnt")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = lInsuranceFileCnt
                dr = con.ExecuteDataSet(cmd, "dr")
            End Using

            'arParams(0) = New SqlParameter("@insurance_file_cnt", lInsuranceFileCnt)
            '
            '
            'dr = SqlHelper.ExecuteDataset(SAMFunc.ConnectionString, _
            '    CommandType.StoredProcedure, _
            '    "spu_SAM_GetRiskcntInsuranceFolderCnt_for_Insurancefilecnt", _
            '    arParams)

            If dr.Tables(0).Rows.Count = 1 Then
                Try
                    lRiskCnt = CInt(dr.Tables(0).Rows(0).Item(0).ToString)
                Catch ex As Exception
                    Dim STSErrorEx As New STSErrorPublisher("Failed to Get Risk/InsuranceFile for InsuranceFile.", ex)
                    STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "BindQuote", True)
                End Try
            End If
        End If

        ' Initialise and prepare the GIS object
        '---------------------------------------

        ' Create the GIS object
        Try
            oGIS = New bGIS.Application
        Catch ex As Exception
            ExceptionManager.Publish(ex)
            Debug.WriteLine(ex.Message)
        Finally
        End Try

        SAMFunc.InitialiseGIS(Con:=con, oGIS:=oGIS, SiriusUser:=_SiriusUser)

        Try
            iRet = oGIS.LoadFromXML(v_sDataModelCode:=sDataModelCode,
                                            v_sXMLDataSet:=sXMLDataSet)
        Catch ex As Exception
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
            ErrEx = New Exception("Failed to call bGIS.Application.LoadFromXML", ex)
            ExceptionManager.Publish(ErrEx)
            Throw ErrEx
        Finally
            If (ErrEx Is Nothing) Then
                If (iRet <> 1) Then
                    ErrEx = New Exception("bGIS.Application.LoadFromXML FAILED. Return Value = " + iRet.ToString)
                    ExceptionManager.Publish(ErrEx)
                    Throw ErrEx
                End If
            End If
        End Try

        ' Get the risk array from the DB Risk record
        '--------------------------------------------

        Dim dsRiskArray As DataSet = Nothing
        Dim objRskStatus As Object
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_Risk_sel")
            'WPR 33-75 added 
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = lRiskCnt
            cmd.AddInParameter("@isDeferredStatusRequired", SqlDbType.Int).Value = 1
            ' cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = UpdateRiskRequest.RiskKey
            dsRiskArray = con.ExecuteDataSet(cmd, "RiskArray")
            Try
                For i As Integer = 0 To dsRiskArray.Tables(0).Rows.Count - 1
                    'PM018420 - JP 01/03/2012
                    objRskStatus = dsRiskArray.Tables(0).Rows(i).Item("risk_status_id")
                    If objRskStatus Is DBNull.Value OrElse CInt(objRskStatus) = 0 Then
                        dsRiskArray.Tables(0).Rows(i).Item("risk_status_id") = 3
                    ElseIf CInt(objRskStatus) = 5 OrElse CInt(objRskStatus) = 6 OrElse CInt(objRskStatus) = 7 OrElse CInt(objRskStatus) = 8 Then
                        'do nothing, let it return 
                    ElseIf CInt(objRskStatus) = 9 Then
                        dsRiskArray.Tables(0).Rows(i).Item("risk_status_id") = 9
                    Else

                        dsRiskArray.Tables(0).Rows(i).Item("risk_status_id") = 3
                    End If
                Next
            Catch ex As Exception
            End Try

            ' Convert the returned dataset into the Risk Array
            vRiskArray = Utilities.DataSetToArray(dsRiskArray)

        End Using

        ' Call the backoffice method to update special property values in the Risk Array
        '---------------------------------------------------------------------------------

        ' Create the RiskScreen.Stateless object
        Dim oRiskScreenStateless As bSIRRiskScreen.Stateless = Nothing
        Try
            oRiskScreenStateless = New bSIRRiskScreen.Stateless
        Catch ex As Exception
            ExceptionManager.Publish(ex)
        Finally

        End Try

        SAMFunc.InitialiseSBOObject(Con:=con, oObject:=oRiskScreenStateless, SiriusUser:=_SiriusUser, sObjectName:="bSIRRiskScreen.Stateless")

        Try

            Dim oGisObject As Object = oGIS
            vRiskArrayObject = vRiskArray

            iRet = oRiskScreenStateless.UpdateRiskArrayFromGIS(oGisObject, sDataModelCode, CType(CObj(vRiskArrayObject), Object(,)))

            oGIS = DirectCast(oGisObject, bGIS.Application)
            vRiskArray = DirectCast(vRiskArrayObject, System.Array)

        Catch ex As Exception
            If oRiskScreenStateless IsNot Nothing Then
                oRiskScreenStateless.Dispose()
                oRiskScreenStateless = Nothing
            End If
            Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.DatasetPathRegistrySettingNotFound, "bSIRRiskScreen.UpdateRiskArrayFromGIS. failed", "Failed to Update the Risk Array. Return Value = " + iRet.ToString)
            STSErrorEX.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
        End Try

        If (iRet <> 1) Then
            If oRiskScreenStateless IsNot Nothing Then
                oRiskScreenStateless.Dispose()
                oRiskScreenStateless = Nothing
            End If
            Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.DatasetPathRegistrySettingNotFound, "bSIRRiskScreen.UpdateRiskArrayFromGIS failed", "Failed to run bSIRRiskScreen.UpdateRiskArrayFromGIS successfully. Return Value = " + iRet.ToString)
            STSErrorEX.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
        End If

        ' Clear up
        If oRiskScreenStateless IsNot Nothing Then
            oRiskScreenStateless.Dispose()
            oRiskScreenStateless = Nothing
        End If

        ' Update the Risk record using the existing backoffice method
        '-------------------------------------------------------------

        ' Create the RiskScreen.Business object
        Dim oRiskScreenBusiness As bSIRRiskScreen.Business = Nothing
        Try
            oRiskScreenBusiness = New bSIRRiskScreen.Business
        Catch ex As Exception
            ExceptionManager.Publish(ex)
        Finally

        End Try

        ' Initialise the COM object
        SAMFunc.InitialiseSBOObject(Con:=con, oObject:=oRiskScreenBusiness, SiriusUser:=_SiriusUser, sObjectName:="bSIRRiskScreen.Business")

        ' TODO really need to look at why the initialise fails, though does
        ' not seem to effect the rest of the processing
        'If (iRet <> 1) Then
        '    SAMFunc.DestroyCOMInterop(oRiskScreenBusiness)
        '    Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.DatasetPathRegistrySettingNotFound, "bSIRRiskScreen.Initialise failed", "Failed to Initialise bRiskScreen. Return Value = " + iRet.ToString)
        '    STSErrorEX.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)


        Try

            vRiskArrayObject = vRiskArray

            iRet = oRiskScreenBusiness.UpdateRisk_Stateless(CType(CObj(vRiskArrayObject), Object(,)), lRiskCnt)

            vRiskArray = DirectCast(vRiskArrayObject, System.Array)

        Catch ex As Exception
            If oRiskScreenBusiness IsNot Nothing Then
                oRiskScreenBusiness.Dispose()
                oRiskScreenBusiness = Nothing
            End If
            Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.DatasetPathRegistrySettingNotFound, "bSIRRiskScreen.UpdateRisk_Stateless. failed", "Failed to Update the Risk. Return Value = " + iRet.ToString)
            STSErrorEX.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
        End Try

        If (iRet <> 1) Then
            If oRiskScreenBusiness IsNot Nothing Then
                oRiskScreenBusiness.Dispose()
                oRiskScreenBusiness = Nothing
            End If
            Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.DatasetPathRegistrySettingNotFound, "bRiskScreen.UpdateRisk_Stateless failed", "bRiskScreen.UpdateRisk_Stateless failed. Return Value = " + iRet.ToString)
            STSErrorEX.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
        End If

        ' Clear up
        If oRiskScreenBusiness IsNot Nothing Then
            oRiskScreenBusiness.Dispose()
            oRiskScreenBusiness = Nothing
        End If

        ' Clear up
        If oGIS IsNot Nothing Then
            oGIS.Dispose()
            oGIS = Nothing
        End If

    End Sub
