            cmd.AddInParameter("@Ri_arrangement_line_id", SqlDbType.Int).Value = lArrangementLineKey
            cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = IIf(bIsPolicy, 1, 2)
