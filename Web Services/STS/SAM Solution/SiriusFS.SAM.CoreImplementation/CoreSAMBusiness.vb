    ''' <summary>  
    '''  This method is used to update bank guarantee.
    ''' </summary>  
    ''' <param name="con">An object of type Sirius.Architecture.Data.SiriusConnection</param>  
    ''' <param name="oUpdateBankGuaranteeRequest">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseUpdateBankGuaranteeRequestType</param>  
    ''' <returns>An object of type SiriusFS.SAM.BaseImplementationTypes.BaseUpdateBankGuaranteeResponseType</returns>  
    Public Overloads Function UpdateBankGuarantee(ByVal con As SiriusConnection, ByVal oUpdateBankGuaranteeRequest As BaseUpdateBankGuaranteeRequestType) As BaseUpdateBankGuaranteeResponseType

        Dim oResponse As BaseUpdateBankGuaranteeResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCorebusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        If oUpdateBankGuaranteeRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateBankGuaranteeRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateBankGuaranteeResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        If String.IsNullOrEmpty(oUpdateBankGuaranteeRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode")
        Else
            oCorebusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                    PMLookupTable.Source, oUpdateBankGuaranteeRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If
        oSAMErrorCollection.CheckForErrors()

        Dim iRowCounter As Integer

        With oUpdateBankGuaranteeRequest
            For iRowCounter = 0 To .BankGuarantee.GetUpperBound(0)
                Dim lBGStatusId As Integer

                'Validate BGKey
                If (.BankGuarantee(iRowCounter).BGKey = 0) Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "BGKey  is missing for the BG Ref " & .BankGuarantee(iRowCounter).BankGuaranteeRef)
                Else
                    GetAndValidateSpecifiedTableCode(con, PMLookupTable.Bank_Guarantee, "BG_id", "BG_id", .BankGuarantee(iRowCounter).BGKey.ToString(), oSAMErrorCollection, "BGKey")
                End If
                oSAMErrorCollection.CheckForErrors()

                'Mandatory Validation
                .BankGuarantee(iRowCounter).Validate(CObj(oSAMErrorCollection))
                oSAMErrorCollection.CheckForErrors()

                'Look Up Validation
                ValidateDataBankGuaranteeItem(oSAMErrorCollection, oCorebusiness, con, .BankGuarantee(iRowCounter))
                oSAMErrorCollection.CheckForErrors()

                'BG can't edited if BGCode is Invoked or Issued
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_BG_Status")
                    cmd.AddInParameter("@bg_id", SqlDbType.Int).Value = .BankGuarantee(iRowCounter).BGKey
                    cmd.AddOutParameter("@Master_BG_Status", SqlDbType.Int)
                    lBGStatusId = Convert.ToInt32(con.ExecuteScalar(cmd))
                End Using
                If (lBGStatusId = CoreBusiness.BGStatus.Invoked) Or (lBGStatusId = CoreBusiness.BGStatus.Issued) Or (lBGStatusId = 0) Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                           SAMInvalidData.ValidationRulesFailed.ToString, "BGStatusCode")
                End If
                oSAMErrorCollection.CheckForErrors()

                'Business Rule Validation
                ValidateBusinessBankGuaranteeItem(oSAMErrorCollection, con, .BankGuarantee(iRowCounter), oUpdateBankGuaranteeRequest.SourceId)
                oSAMErrorCollection.CheckForErrors()
            Next
        End With

        Try
            con.BeginTransaction()

            Dim oBankGuarantee As BaseBankGuaranteeItemType
            For Each oBankGuarantee In oUpdateBankGuaranteeRequest.BankGuarantee
                oCorebusiness.CheckSAMTSAndLock(Con:=con,
                    BranchCode:=oUpdateBankGuaranteeRequest.BranchCode,
                    Lockname:=CoreBusiness.LockName.BGId,
                    LockValue:=oBankGuarantee.BGKey,
                    TStamp:=oBankGuarantee.BGTimeStamp)
            Next

            Dim sDescription As String

            For Each oBankGuarantee In oUpdateBankGuaranteeRequest.BankGuarantee

                Dim oGetBankGuaranteeResponseType As New BaseGetBankGuaranteeResponseType
                Dim sBGStatusDesc, sBankName As String
                Dim dsBankGuarantee As DataSet

                'Fetch the Bank Guarantee details to update Event Log
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_PartyBG_Details_Sel")
                    cmd.AddInParameter("@bg_id", SqlDbType.Int).Value = oBankGuarantee.BGKey
                    dsBankGuarantee = con.ExecuteDataSet(cmd, "Bank_Guarantee")

                    With oGetBankGuaranteeResponseType
                        .BankGuarantee = New BaseBankGuaranteeItemType
                        .BankGuarantee.BankBranch = Cast.ToString(dsBankGuarantee.Tables(0).Rows(0).Item("bank_branch"), Nothing)
