                                                                          TStamp:=oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).PremiumAllocationTimeStamp,
                                                                          bCurrentlyLocked:=bPolicyLocked)
                                    Else
                                        oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).PremiumAllocationTimeStamp = oGetPolicyTransactionDetailsTransactionsExtended(0).PremiumAllocationTimeStamp
                                    End If


                                ElseIf Cast.ToStringTrim(dataViewtrans.ToTable.Rows(iCntLevel2).Item("Transdetail_Type_Code")).ToUpper = "TAX" Then
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).PremiumTax = Cast.ToDecimal(dataViewtrans.ToTable.Rows(iCntLevel2).Item("currency_amount"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).PremiumTaxOutstanding = Cast.ToDecimal(dataViewtrans.ToTable.Rows(iCntLevel2).Item("outstanding_currency_amount"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).PremiumTaxTransDetailExtendedId = Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetailex_id"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).PremiumTaxTransDetailId = Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetail_id"), 0)

                                    If nBuckets = 1 Then
                                        AnyError = oBusiness.GetTimestamp(BranchCode:=oGetPolicyTransactionDetailsRequest.BranchCode,
                                                                          Lockname:=CoreBusiness.LockName.TransDetailKey,
                                                                          LockValue:=Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetail_id"), 0),
                                                                          TStamp:=oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).PremiumTaxAllocationTimeStamp,
                                                                          bCurrentlyLocked:=bPolicyLocked)
                                    Else
                                        oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).PremiumTaxAllocationTimeStamp = oGetPolicyTransactionDetailsTransactionsExtended(0).PremiumTaxAllocationTimeStamp
                                    End If


                                ElseIf Cast.ToStringTrim(dataViewtrans.ToTable.Rows(iCntLevel2).Item("Transdetail_Type_Code")).ToUpper = "COMM" Then
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).Commission = Cast.ToDecimal(dataViewtrans.ToTable.Rows(iCntLevel2).Item("currency_amount"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionOutstanding = Cast.ToDecimal(dataViewtrans.ToTable.Rows(iCntLevel2).Item("outstanding_currency_amount"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionTransDetailExtendedId = Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetailex_id"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionTransDetailId = Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetail_id"), 0)

                                    If nBuckets = 1 Then
                                        AnyError = oBusiness.GetTimestamp(BranchCode:=oGetPolicyTransactionDetailsRequest.BranchCode,
                                                                          Lockname:=CoreBusiness.LockName.TransDetailKey,
                                                                          LockValue:=Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetail_id"), 0),
                                                                          TStamp:=oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionAllocationTimeStamp,
                                                                          bCurrentlyLocked:=bPolicyLocked)
                                    Else
                                        oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionAllocationTimeStamp = oGetPolicyTransactionDetailsTransactionsExtended(0).CommissionAllocationTimeStamp
                                    End If


                                ElseIf Cast.ToStringTrim(dataViewtrans.ToTable.Rows(iCntLevel2).Item("Transdetail_Type_Code")).ToUpper = "COMMTAX" Then
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionTax = Cast.ToDecimal(dataViewtrans.ToTable.Rows(iCntLevel2).Item("currency_amount"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionTaxOutstanding = Cast.ToDecimal(dataViewtrans.ToTable.Rows(iCntLevel2).Item("outstanding_currency_amount"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionTaxTransDetailExtendedId = Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetailex_id"), 0)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionTaxTransDetailId = Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetail_id"), 0)

                                    If nBuckets = 1 Then
                                        AnyError = oBusiness.GetTimestamp(BranchCode:=oGetPolicyTransactionDetailsRequest.BranchCode,
                                                                          Lockname:=CoreBusiness.LockName.TransDetailKey,
                                                                          LockValue:=Cast.ToInt32(dataViewtrans.ToTable.Rows(iCntLevel2).Item("transdetail_id"), 0),
                                                                          TStamp:=oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionTaxAllocationTimeStamp,
                                                                          bCurrentlyLocked:=bPolicyLocked)

                                    Else
                                        oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).CommissionTaxAllocationTimeStamp = oGetPolicyTransactionDetailsTransactionsExtended(0).CommissionTaxAllocationTimeStamp
                                    End If

                                End If

                                If dtCurrentFeeDueDate <> dtCurrentDueDate Then
                                    dtCurrentFeeDueDate = dtCurrentDueDate

                                    Dim dataViewFEE As DataView = New DataView
                                    With dataViewFEE
                                        .Table = dsTransactions.Tables(0)
                                        .RowFilter = "DOCUMENT_ID = " + Convert.ToString(iCurrentDocumentDetailId) +
                                                        "AND EffectiveDate = '" + Convert.ToString(dtCurrentDueDate) +
                                                            "' AND FEE_TYPE IS NOT NULL"
                                    End With

                                    With dataViewFEE.ToTable
                                        ReDim oGetPolicyTransactionDetailsTransactionsExtendedFees(.Rows.Count - 1)

                                        For iCntLevel3 = 0 To dataViewFEE.ToTable.Rows.Count - 1
                                            If sCurrentFeeType <> Cast.ToStringTrim(dataViewFEE.ToTable.Rows(iCntLevel3).Item("Fee_Type")) Then
                                                sCurrentFeeType = Cast.ToStringTrim(dataViewFEE.ToTable.Rows(iCntLevel3).Item("Fee_Type"))
                                                ReDim Preserve oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees)
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees) = New BaseGetPolicyTransactionDetailsResponseTypeTransactionsExtendedFees
                                                nFees = nFees + 1
                                            End If

                                            If Convert.ToString(dataViewFEE.ToTable.Rows(iCntLevel3).Item("Transdetail_Type_Code")).ToUpper = "FEE" Then
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).Amount = Cast.ToDecimal(dataViewFEE.ToTable.Rows(iCntLevel3).Item("currency_amount"), 0)
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).AmountOutstanding = Cast.ToDecimal(dataViewFEE.ToTable.Rows(iCntLevel3).Item("outstanding_currency_amount"), 0)
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeTransDetailId = Cast.ToInt32(dataViewFEE.ToTable.Rows(iCntLevel3).Item("transdetail_id"), 0)
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeTransDetailExtendedId = Cast.ToInt32(dataViewFEE.ToTable.Rows(iCntLevel3).Item("transdetailex_id"), 0)

                                                If nBuckets = 1 Then
                                                    AnyError = oBusiness.GetTimestamp(BranchCode:=oGetPolicyTransactionDetailsRequest.BranchCode,
                                                                                      Lockname:=CoreBusiness.LockName.TransDetailKey,
                                                                                      LockValue:=Cast.ToInt32(dataViewFEE.ToTable.Rows(iCntLevel3).Item("transdetail_id"), 0),
                                                                                      TStamp:=oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeAllocationTimeStamp,
                                                                                      bCurrentlyLocked:=bPolicyLocked)
                                                Else
                                                    oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeAllocationTimeStamp = (oGetPolicyTransactionDetailsTransactionsExtended(0)).Fees(nFees - 1).FeeAllocationTimeStamp
                                                End If


                                            ElseIf Convert.ToString(dataViewFEE.ToTable.Rows(iCntLevel3).Item("Transdetail_Type_Code")).ToUpper = "FEETAX" Then
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).TaxAmount = Cast.ToDecimal(dataViewFEE.ToTable.Rows(iCntLevel3).Item("currency_amount"), 0)
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).TaxAmountOutstanding = Cast.ToDecimal(dataViewFEE.ToTable.Rows(iCntLevel3).Item("outstanding_currency_amount"), 0)
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeTaxTransDetailId = Cast.ToInt32(dataViewFEE.ToTable.Rows(iCntLevel3).Item("transdetail_id"), 0)
                                                oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeTaxTransDetailExtendedId = Cast.ToInt32(dataViewFEE.ToTable.Rows(iCntLevel3).Item("transdetailex_id"), 0)

                                                If nBuckets = 1 Then
                                                    AnyError = oBusiness.GetTimestamp(BranchCode:=oGetPolicyTransactionDetailsRequest.BranchCode,
                                                                                      Lockname:=CoreBusiness.LockName.TransDetailKey,
                                                                                      LockValue:=Cast.ToInt32(dataViewFEE.ToTable.Rows(iCntLevel3).Item("transdetail_id"), 0),
                                                                                      TStamp:=oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeTaxAllocationTimeStamp,
                                                                                      bCurrentlyLocked:=bPolicyLocked)

                                                Else
                                                    oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeTaxAllocationTimeStamp = (oGetPolicyTransactionDetailsTransactionsExtended(0)).Fees(nFees - 1).FeeTaxAllocationTimeStamp
                                                End If

                                            End If
                                            oGetPolicyTransactionDetailsTransactionsExtendedFees(nFees - 1).FeeType = Cast.ToStringTrim(dataViewFEE.ToTable.Rows(iCntLevel3).Item("Fee_Type"))

                                        Next iCntLevel3 ' Fees
                                        oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).Fees = oGetPolicyTransactionDetailsTransactionsExtendedFees
                                    End With
                                    sCurrentFeeType = ""
                                    nFees = 0 'reset fee loop
                                End If
                            Next iCntLevel2

                            oGetPolicyTransactionDetailsTransactions(nTransactions).Extended = oGetPolicyTransactionDetailsTransactionsExtended

                        End With
                        nTransactions = nTransactions + 1
                    End If

                Next iCnt
                oResponse.Transactions = oGetPolicyTransactionDetailsTransactions

            End If
        End If

        oResponse.STSError = AnyError
        Return oResponse

    End Function

#End Region

#Region "Reverse Allocation Batch"

    Public Overloads Function ReverseAllocationBatch(ByVal ReverseAllocationBatchRequest As BaseReverseAllocationBatchRequestType) As BaseReverseAllocationBatchResponseType

        ' validate the request structure against the specified business rules
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Dim oResponse As BaseReverseAllocationBatchResponseType

            oResponse = ReverseAllocationBatch(con, ReverseAllocationBatchRequest)

            Return oResponse

        End Using

    End Function
    ''' <summary>  
    ''' ReverseAllocationBatch
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oReverseAllocationBatchRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function ReverseAllocationBatch(ByVal con As SiriusConnection, ByVal oReverseAllocationBatchRequest As BaseReverseAllocationBatchRequestType) As BaseReverseAllocationBatchResponseType

        Dim oReverseAllocationBatchResponse As New BaseReverseAllocationBatchResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim iBranchId As Integer
        Dim iAllocDays As Integer
        Dim iRet As Integer
        Dim iTransdetailCnt As Integer = 0
        Dim iAllocationCnt As Integer = 0

        Dim nTypeOfPackage As enumTypeOfPackage

        If oReverseAllocationBatchRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ReverseAllocationBatchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oReverseAllocationBatchResponse = New SAMForInsuranceV2ImplementationTypes.ReverseAllocationBatchResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        'Mandatory validations
        oReverseAllocationBatchRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        Try
            iBranchId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oReverseAllocationBatchRequest.BranchCode, "BranchCode")
        Catch ex As Exception
            oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                        SAMInvalidData.InvalidLookupListValue.ToString,
                                        "BranchCode",
                                        oReverseAllocationBatchRequest.BranchCode)
        End Try
        oErrors.CheckForErrors()

        Dim oGetUserAuthorityValueRequest As New BaseGetUserAuthorityValueRequestType
        Dim oGetUserAuthorityValueResponse As New BaseGetUserAuthorityValueResponseType
        With oGetUserAuthorityValueRequest
            .SourceId = iBranchId
            .UserCode = _SiriusUser.Username
            .UserAuthorityOption = UserAuthorityOptions.AllowReverseAllocation
            .BranchCode = oReverseAllocationBatchRequest.BranchCode
        End With
        oGetUserAuthorityValueResponse = GetUserAuthorityValue(con, oGetUserAuthorityValueRequest)
        If oGetUserAuthorityValueResponse.Errors Is Nothing Then
            If oGetUserAuthorityValueResponse.UserAuthorityValue = "1" Then
                Dim dsTransations As New DataSet
                Dim iCount As Integer = 0

                'Get Transaction Details
                Dim dtTransactionDate As DateTime, dtAllocationDate As DateTime
                Dim sTransationSpare As String = ""
                Using ocon As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Select_Primary_Allocation")
                        cmd.AddInParameter("@allocationbatch_id", SqlDbType.Int).Value = Cast.NullIfDefault(oReverseAllocationBatchRequest.AllocationBatchKey)
                        dsTransations = ocon.ExecuteDataSet(cmd, "PayClaim")
                    End Using

                    If (dsTransations IsNot Nothing) Then
                        If (dsTransations.Tables.Count > 0) Then
                            If (dsTransations.Tables(0).Rows.Count > 0) Then
                                iTransdetailCnt = Cast.ToInt32(dsTransations.Tables(0).Rows(iCount).Item("transdetail_id"), 0)
                                iAllocationCnt = Cast.ToInt32(dsTransations.Tables(0).Rows(iCount).Item("allocation_id"), 0)
                                dtAllocationDate = Cast.ToDateTime(dsTransations.Tables(0).Rows(iCount).Item("allocation_date"), Date.Now)
                            End If
                        End If
                    End If

                    GetTransactionDetail(ocon,
                                           iTransdetailCnt,
                                           dtTransactionDate,
                                           sTransationSpare)
                End Using

                iAllocDays = Cast.ToInt32(oGetUserAuthorityValueResponse.UserAuthorityOptionalValue1, 0)

                If dtAllocationDate.AddDays(iAllocDays) < DateTime.Today Then
                    oErrors.AddBusinessRule(SAMBusinessErrors.UserDoesNotHaveReverseAllocationAuthority,
                                                            "Unable to reverse allocation, time limit exceeded")
                End If

                If sTransationSpare.ToUpper().StartsWith("REVER") Then
                    oErrors.AddBusinessRule(SAMBusinessErrors.CannotReverseAllocate,
                            "Cannot reverse an allocation on a reversed/reversal transaction")
                End If
            Else
                oErrors.AddBusinessRule(SAMBusinessErrors.UserDoesNotHaveReverseAllocationAuthority,
                                                            "Cannot reverse an allocation , user has no rights")
            End If

            oErrors.CheckForErrors()
        Else
            oErrors.CheckForErrors()
        End If

        Dim oAllocate As bACTAllocationPost.Automated = Nothing
        Try
            oAllocate = New bACTAllocationPost.Automated
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bACTAllocationPost.Automated", ex.Message)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), "ReverseAllocationBatch", "CreatebACTAllocationPost.Automated Failed", True)
        End Try

        ' Initialise the business object
        Try
            SAMFunc.InitialiseSBOObject(Con:=con, oObject:=oAllocate, SiriusUser:=_SiriusUser, sBranchCode:=oReverseAllocationBatchRequest.BranchCode, sObjectName:="bACTAllocationPost.Automated")
        Catch ex As Exception
            If oAllocate IsNot Nothing Then
                oAllocate.Dispose()
                oAllocate = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bACTAllocationPost.Automated", ex.Message)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), "ReverseAllocationBatch", "bACTAllocationPost.Automated.Initialise", True)
        End Try

        con.BeginTransaction()
        Try
            iRet = oAllocate.ReverseAllocation(
                          v_lTransDetailID:=iTransdetailCnt,
                          v_lAllocationID:=iAllocationCnt,
                          bReverseWriteOff:=True)
            If iRet <> PMEReturnCode.PMTrue Then
                ' if the account processing fails then throw a business rule error
                oErrors.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bSIRAllocate.Business.ReverseAllocation Failed")
                oErrors.CheckForErrors()
            End If
            oAllocate.Dispose()
            oAllocate = Nothing
            con.CommitTransaction()
        Catch ex As Exception
            con.RollbackTransaction()
            Throw
        End Try
        Return oReverseAllocationBatchResponse

    End Function

#End Region

#Region "UpdateTaskStatus"
    ''' <summary>  
    ''' This method is used for Updating Task Status
    '''<param name="oUpdateTaskStatusRequest" type="BaseUpdateTaskStatusRequestType"></param>   
    '''<returns>BaseUpdateTaskStatusResponseType</returns>
    '''<remarks></remarks>
    Public Overloads Function UpdateTaskStatus(ByVal oUpdateTaskStatusRequest As BaseUpdateTaskStatusRequestType) As BaseUpdateTaskStatusResponseType
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)
            Dim oResponse As BaseUpdateTaskStatusResponseType

            Try
                con.BeginTransaction()
                oResponse = UpdateTaskStatus(con, oUpdateTaskStatusRequest)
                con.CommitTransaction()
            Catch
                con.RollbackTransaction()
                Throw
            End Try
            Return oResponse

        End Using

    End Function

    ''' <summary>
    '''This function will pass the request object to the stored proceudre and returns the reponse object
    '''</summary>
    '''<param name="oCon" type="SiriusConnection"></param>  
    '''<param name="oUpdateTaskStatusRequest" type="BaseUpdateTaskStatusRequestType"></param>  
    '''<returns> object of type BaseUpdateTaskStatusResponseType</returns>
    '''<remarks></remarks>
    Public Overloads Function UpdateTaskStatus(ByVal oCon As SiriusConnection,
                                           ByVal oUpdateTaskStatusRequest As BaseUpdateTaskStatusRequestType
                                           ) As BaseUpdateTaskStatusResponseType

        Dim oResponse As BaseUpdateTaskStatusResponseType


        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCorebusiness As New CoreBusiness(_SiriusUser)
        Dim nComReturnValue As Integer

        Dim oSAMErrorCollection As New SAMErrorCollection

        If oUpdateTaskStatusRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateTaskStatusRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateTaskStatusResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        'Verify mandatory fields
        If oUpdateTaskStatusRequest.TaskInstanceKey = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "TaskInstanceKey")
        End If

        If oUpdateTaskStatusRequest.TaskStatusKey < 0 And oUpdateTaskStatusRequest.TaskStatusKey > 4 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "TaskStatus")
        End If

        oSAMErrorCollection.CheckForErrors()

        'Try and convert the GUID string to System.GUID before sending it to BO
        Try

            If oUpdateTaskStatusRequest.GuidPMExternalItem <> "" Then
                Dim guidPMExternaItem As New System.Guid(oUpdateTaskStatusRequest.GuidPMExternalItem.ToString())
            End If
        Catch ex As Exception
            Throw
        End Try

        Dim oWrkTaskInstance As New bPMWrkTaskInstance.TaskControl
        Dim sErrorMessage As String = String.Empty

        Try
            InitialiseSBOObject(oCon, oWrkTaskInstance, _SiriusUser, "HeadOff", "bPMWrkTaskInstance.TaskControl")

            nComReturnValue = oWrkTaskInstance.UpdateTaskStatus(nPMWrkTaskInstanceCnt:=oUpdateTaskStatusRequest.TaskInstanceKey,
                                              bViaBackgrounJobProcess:=False,
                                              nTaskStatus:=oUpdateTaskStatusRequest.TaskStatusKey,
                                              sGuidPMExternalItem:=oUpdateTaskStatusRequest.GuidPMExternalItem,
                                              nExternalTaskStatus:=oUpdateTaskStatusRequest.ExternalTaskStatus, sErrMessageUpdateTask:=sErrorMessage)

            If nComReturnValue <> PMEReturnCode.PMTrue Then
                If Not String.IsNullOrEmpty(sErrorMessage) Then
                    RaiseComMethodException(sErrorMessage, nComReturnValue)
                Else
                    RaiseComMethodException("bPMWrkTaskInstance.TaskControl.UpdateTaskStatus", nComReturnValue)
                End If
            End If
        Catch ex As Exception
            Throw
        Finally
            If oWrkTaskInstance IsNot Nothing Then
                oWrkTaskInstance.Dispose()
                oWrkTaskInstance = Nothing
            End If
        End Try


        Return oResponse

    End Function

#End Region

#Region "GetLockDetails"

    ''' <summary>
    ''' Calls the overloaded implementation function GetLockDetails
    ''' </summary>
    ''' <param name="GetLockDetailsRequest"></param>
    ''' <returns>BaseImplementationTypes.BaseGetLockDetailsResponseType</returns>
    ''' <remarks></remarks>
    Public Overloads Function GetLockDetails(ByVal oGetLockDetailsRequest As BaseGetLockDetailsRequestType) As BaseGetLockDetailsResponseType
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Dim oResponse As New BaseGetLockDetailsResponseType
            oResponse = GetLockDetails(con:=con, oGetLockDetailsRequest:=oGetLockDetailsRequest)
            Return oResponse
        End Using

    End Function


    ''' <summary>
    ''' Calls the relvant SP to fetch the LockDetails
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oGetLockDetailsRequest">BaseGetLockDetailsRequestType</param>
    ''' <returns>BaseImplementationTypes.BaseGetLockDetailsResponseType</returns>
    ''' <remarks></remarks>
    Public Overloads Function GetLockDetails(ByRef con As SiriusConnection,
                                                            ByVal oGetLockDetailsRequest As BaseGetLockDetailsRequestType) As BaseGetLockDetailsResponseType

        Dim oGetLockDetailsResponse As New BaseGetLockDetailsResponseType
        Dim oErrors As New SAMErrorCollection
        Dim dsResult As DataSet = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetLockDetailsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetLockDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetLockDetailsResponse = New SAMForInsuranceV2ImplementationTypes.GetLockDetailsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        oGetLockDetailsRequest.Validate(CType(oErrors, SAMErrorCollection))
        oErrors.CheckForErrors()

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_select_all_pmlock")
            dsResult = con.ExecuteDataSet(cmd, "GetLockDetails")
        End Using

        If (dsResult.Tables.Count > 0) Then

            If (dsResult.Tables(0).Rows.Count > 0) Then

                Dim dsFilter As DataSet = Nothing
                dsFilter = New DataSet
                With dsFilter
                    .Tables.Add()
                    .Tables(0).Columns.Add("LockName", GetType(System.String))
                    .Tables(0).Columns.Add("LockValue", GetType(System.Int32))
                    .Tables(0).Columns.Add("UserName", GetType(System.String))
                    .Tables(0).Columns.Add("LockedTime", GetType(System.DateTime))
                    .Tables(0).Columns.Add("LockedByID", GetType(System.Int32))
                    .Tables(0).Columns.Add("Lock2Value", GetType(System.Int32))
                    .Tables(0).Columns.Add("IsSystemLock", GetType(System.Int32))
                    .Tables(0).Columns.Add("Lock3Value", GetType(System.String))
                    .Tables(0).Columns.Add("IsExclusiveLock", GetType(System.Int32))
                End With

                Dim iCount As Integer
                With dsFilter.Tables(0)
                    For iCount = 0 To dsResult.Tables(0).Rows.Count - 1
                        .Rows.Add()
                        .Rows(iCount)("LockName") = Trim(dsResult.Tables(0).Rows(iCount).Item("lock_name").ToString())
                        .Rows(iCount)("LockValue") = Cast.ToInt32(dsResult.Tables(0).Rows(iCount).Item("lock_value"), 0)
                        .Rows(iCount)("UserName") = Trim(dsResult.Tables(0).Rows(iCount).Item("username").ToString())
                        .Rows(iCount)("LockedTime") = Cast.ToDateTime(dsResult.Tables(0).Rows(iCount).Item("locked_time"))
                        .Rows(iCount)("LockedByID") = Cast.ToInt32(dsResult.Tables(0).Rows(iCount).Item("locked_by_id"), 0)
                        .Rows(iCount)("Lock2Value") = Cast.ToInt32(dsResult.Tables(0).Rows(iCount).Item("lock2_value"), 0)
                        .Rows(iCount)("IsSystemLock") = Cast.ToInt32(dsResult.Tables(0).Rows(iCount).Item("is_system_lock"), 0)
                        .Rows(iCount)("Lock3Value") = Trim(dsResult.Tables(0).Rows(iCount).Item("lock3_value").ToString())
                        .Rows(iCount)("IsExclusiveLock") = Cast.ToInt32(dsResult.Tables(0).Rows(iCount).Item("is_exclusive_lock"), 0)
                    Next
                End With

                Dim xmlDoc As New System.Xml.XmlDocument
                dsFilter.DataSetName = "BaseGetLockDetailsResponseTypeDetails"
                dsFilter.Tables(0).TableName = "Row"
                xmlDoc.LoadXml(dsFilter.GetXml)
                If (dsFilter.Tables.Count >= 1) Then
                    oGetLockDetailsResponse.ResultDataSet = xmlDoc.DocumentElement()
                End If
                oGetLockDetailsResponse.ResultData = dsFilter
            End If
        End If

        Return oGetLockDetailsResponse

    End Function

#End Region

#Region "MaintainLock"

    ''' <summary>
    ''' Calls the overloaded implementation function MaintainLock
    ''' </summary>
    ''' <param name="oMaintainLockRequest"></param>
    ''' <returns>BaseImplementationTypes.BaseMaintainLockResponseType</returns>
    ''' <remarks></remarks>
    Public Overloads Function MaintainLock(ByVal oMaintainLockRequest As BaseMaintainLockRequestType) As BaseMaintainLockResponseType
        Using conObject As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Dim oResponse As New BaseMaintainLockResponseType
            oResponse = MaintainLock(conObject:=conObject, oMaintainLockRequest:=oMaintainLockRequest)
            Return oResponse
        End Using

    End Function

    ''' <summary>
    ''' Calls the relvant SP to fetch the LockDetails
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oMaintainLockRequest">BaseMaintainLockRequestType</param>
    ''' <returns>BaseImplementationTypes.BaseGetLockDetailsResponseType</returns>
    ''' <remarks></remarks>
    Public Overloads Function MaintainLock(ByRef conObject As SiriusConnection,
                                                            ByVal oMaintainLockRequest As BaseMaintainLockRequestType) As BaseMaintainLockResponseType

        Dim oMaintainLockResponse As New BaseMaintainLockResponseType
        Dim oErrors As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage

        If oMaintainLockRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.MaintainLockRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oMaintainLockResponse = New SAMForInsuranceV2ImplementationTypes.MaintainLockResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        oMaintainLockRequest.Validate(CType(oErrors, SAMErrorCollection))
        oErrors.CheckForErrors()

        Dim oLockDetail As Object(,)
        Dim sMode As String = ""
        If oMaintainLockRequest.LogOutSessionValue IsNot Nothing AndAlso oMaintainLockRequest.LogOutSessionValue <> "" Then
            'Delete All locks for the user with this session value

            sMode = "LOGOUT"
            ReDim Preserve oLockDetail(0, 1)
            oLockDetail(0, 0) = _SiriusUser.UserID
            oLockDetail(0, 1) = oMaintainLockRequest.LogOutSessionValue

            AddDeleteLocks(conObject, sMode, oLockDetail)

        ElseIf oMaintainLockRequest.ClearAllLocks = True Then
            'Delete All the  locks , excpet Is_System_Lock = 1. Which can only be cleared by E5 functionality
            sMode = "DELETE_ALL_LOCKS"
            AddDeleteLocks(conObject, sMode, Nothing)

        ElseIf oMaintainLockRequest.LockDetails IsNot Nothing AndAlso IsArray(oMaintainLockRequest.LockDetails) Then
            'Delete individual locks 

            sMode = "DELETE_LOCK"
            ReDim Preserve oLockDetail(1, oMaintainLockRequest.LockDetails.Length - 1)

            For nCount As Integer = 0 To oMaintainLockRequest.LockDetails.Length - 1
                oLockDetail(0, nCount) = oMaintainLockRequest.LockDetails(nCount).LockName
                oLockDetail(1, nCount) = oMaintainLockRequest.LockDetails(nCount).LockValue
            Next

            AddDeleteLocks(conObject, sMode, oLockDetail)

        End If

        Return oMaintainLockResponse

    End Function

    ''' <summary>
    ''' Calls the relvant SP to clear locks based on the relevant process
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="sMode"></param>
    ''' <param name="oLockDetails"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Sub AddDeleteLocks(ByRef con As SiriusConnection, ByVal sMode As String, ByVal oLockDetails As Object(,))

        Dim nRowsAffected As Integer = 0
        Select Case sMode

            Case "LOGOUT"
                'Delete All locks for the user which have been locked by Portal via SAM. 
                'Therefore bIsExclusiveLock = 1

                If oLockDetails IsNot Nothing Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_delete_pmlock_user")
                        cmd.AddInParameter("@user_id", SqlDbType.SmallInt).Value = oLockDetails(0, 0)
                        cmd.AddInParameter("@bIsExclusiveLock", SqlDbType.TinyInt).Value = 1
                        cmd.AddInParameter("@sLock3Value", SqlDbType.VarChar, 250).Value = oLockDetails(0, 1)
                        nRowsAffected = con.ExecuteNonQuery(cmd)
                    End Using
                End If
            Case "DELETE_ALL_LOCKS"
                'Delete All the  locks , excepet where Is_System_Lock = 1. 
                'Which can only be cleared by E5 functionality

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_delete_pmlock_all")
                    nRowsAffected = con.ExecuteNonQuery(cmd)
                End Using

            Case "DELETE_LOCK"
                'Delete individual locks , single or multiple can be deleted using this SP.

                If oLockDetails IsNot Nothing Then
                    Dim nLowerBound As Integer = oLockDetails.GetLowerBound(1)
                    Dim nUpperBound As Integer = oLockDetails.GetUpperBound(1)
                    Dim dtLockDetailsTable As DataTable = New DataTable()
                    Dim drLockDetailsRow As DataRow = Nothing


                    dtLockDetailsTable.Columns.Add("lock_name")
                    dtLockDetailsTable.Columns.Add("lock_value")

                    For nCount As Integer = nLowerBound To nUpperBound
                        drLockDetailsRow = dtLockDetailsTable.NewRow()
                        drLockDetailsRow("lock_name") = oLockDetails(0, nCount)
                        drLockDetailsRow("lock_value") = oLockDetails(1, nCount)
                        dtLockDetailsTable.Rows.Add(drLockDetailsRow)
                    Next

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_delete_pmlock_multiple")
                        cmd.Parameters.AddWithValue("@multiple_lock_details", dtLockDetailsTable)
                        nRowsAffected = con.ExecuteNonQuery(cmd)
                    End Using

                End If

            Case "DELETE_EXCLUSIVE_LOCK"

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_delete_pmlock_key")
                    cmd.AddInParameter("@key_name", SqlDbType.Char, 30).Value = oLockDetails(0, 0)
                    cmd.AddInParameter("@key_value", SqlDbType.Int).Value = oLockDetails(1, 0)
                    cmd.AddInParameter("@bIsExclusiveLock", SqlDbType.TinyInt).Value = 1
                    nRowsAffected = con.ExecuteNonQuery(cmd)
                End Using


            Case "ADD"
                'Add an exclusive lock

                Dim sLockedBy As String = ""
                If oLockDetails IsNot Nothing Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_add_pmlock2")
                        cmd.AddOutParameter("@locked_by", SqlDbType.VarChar, 255)
                        cmd.AddInParameter("@key_name", SqlDbType.Char, 30).Value = oLockDetails(0, 0)
                        cmd.AddInParameter("@key_value", SqlDbType.Int).Value = oLockDetails(1, 0)
                        cmd.AddInParameter("@user_id", SqlDbType.SmallInt).Value = oLockDetails(4, 0)
                        cmd.AddInParameter("@is_system_lock", SqlDbType.TinyInt).Value = 0 'System Locks are for E5 functionality
                        cmd.AddInParameter("@bIsExclusiveLock", SqlDbType.TinyInt).Value = 1
                        cmd.AddInParameter("@sLock3Value", SqlDbType.VarChar, 250).Value = oLockDetails(3, 0)
                        nRowsAffected = con.ExecuteNonQuery(cmd)

                        sLockedBy = Cast.ToStringTrim(cmd.Parameters.Item("@locked_by").Value, "")
                    End Using

                    If sLockedBy IsNot Nothing AndAlso sLockedBy <> "" Then
                        Dim oSAMErrorCollection As New SAMErrorCollection
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.FailedToAddAnExclusiveLock,
                                                            SAMBusinessErrors.FailedToAddAnExclusiveLock.ToString,
                                                            "An exclusive lock already exist on this record by:" & sLockedBy)
                        oSAMErrorCollection.CheckForErrors()
                    End If

                End If
        End Select

    End Sub
#End Region

    ''' <summary>
    ''' GetPaymentName
    ''' </summary>
    ''' <param name="sValue"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function GetPaymentName(ByVal sValue As String) As String
        Dim sReturn As String = ""
        sReturn = sValue
        If Not String.IsNullOrEmpty(sValue) AndAlso Trim(Convert.ToString(sValue)) <> "" AndAlso Len(sValue) > 60 Then
            sReturn = Left(sValue, 60)
        End If
        Return sReturn
    End Function

