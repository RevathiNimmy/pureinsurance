    Public Overloads Function GetClaimReinsuranceBands(ByVal con As SiriusConnection, ByVal GetClaimReinsuranceBandsRequest As BaseGetClaimReinsuranceBandsRequestType) As BaseGetClaimReinsuranceBandsResponseType

        Dim oGetClaimReinsuranceBandsResponse As New BaseGetClaimReinsuranceBandsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If GetClaimReinsuranceBandsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReinsuranceBandsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetClaimReinsuranceBandsResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimReinsuranceBandsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(GetClaimReinsuranceBandsRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode")
        End If
        oErrors.CheckForErrors()

        If (GetClaimReinsuranceBandsRequest.ClaimId = 0) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString, "ClaimId")
        End If
        oErrors.CheckForErrors()

        ' Lookup Codes to ensure they are valid
        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, GetClaimReinsuranceBandsRequest.BranchCode, "BranchCode", oErrors)
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsBands As DataSet = Nothing

        'If GetClaimReinsuranceBandsRequest.ClaimId <> 0 Then
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_sel_bands")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = Cast.NullIfDefault(GetClaimReinsuranceBandsRequest.ClaimId)
            dsBands = con.ExecuteDataSet(cmd, "Row")
        End Using

        dsBands.Tables(0).Columns("ri_band_id").ColumnName = "BandId"
        dsBands.Tables(0).Columns("description").ColumnName = "Band"

        Dim xmlDoc As New System.Xml.XmlDocument
        dsBands.DataSetName = "BaseGetClaimReinsuranceBandsResponseTypeReinsuranceBands"
        dsBands.Tables(0).TableName = "Row"

        If GetClaimReinsuranceBandsRequest.WCFSecurityToken = "" Then
            xmlDoc.LoadXml(dsBands.GetXml)
            oGetClaimReinsuranceBandsResponse.ResultDataset = xmlDoc.DocumentElement()
        End If

        oGetClaimReinsuranceBandsResponse.ResultData = dsBands
        Return oGetClaimReinsuranceBandsResponse

    End Function

    ''' <summary>  
    ''' Retrieves Reinsurance Arrangement details for a claim. 
    ''' </summary>  
    ''' <param name="GetClaimReinsuranceArrangementsRequest">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseGetClaimReinsuranceArrangementsRequestType</param>  
    ''' <returns>An object of type SiriusFS.SAM.BaseImplementationTypes.BaseGetClaimReinsuranceArrangementsResponseType</returns>  
    Public Overloads Function GetClaimReinsuranceArrangements(ByVal GetClaimReinsuranceArrangementsRequest As BaseGetClaimReinsuranceArrangementsRequestType) As BaseGetClaimReinsuranceArrangementsResponseType
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)
            Dim oResponse As BaseGetClaimReinsuranceArrangementsResponseType
            oResponse = GetClaimReinsuranceArrangements(con, GetClaimReinsuranceArrangementsRequest)
            Return oResponse
        End Using
    End Function

    Public Overloads Function GetClaimReinsuranceArrangements(ByVal con As SiriusConnection, ByVal GetClaimReinsuranceArrangementsRequest As BaseGetClaimReinsuranceArrangementsRequestType) As BaseGetClaimReinsuranceArrangementsResponseType

        Dim oGetClaimReinsuranceArrangementsResponse As New BaseGetClaimReinsuranceArrangementsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If GetClaimReinsuranceArrangementsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReinsuranceArrangementsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetClaimReinsuranceArrangementsResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimReinsuranceArrangementsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(GetClaimReinsuranceArrangementsRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode")
        End If
        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        If (GetClaimReinsuranceArrangementsRequest.ClaimId = 0) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString, "ClaimId")
        End If
        oErrors.CheckForErrors()

        ' Lookup Codes to ensure they are valid
        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, GetClaimReinsuranceArrangementsRequest.BranchCode, "BranchCode", oErrors)
        oErrors.CheckForErrors()

        Dim dsTransTypeCode As DataSet = Nothing
        Dim sTransTypeCode As String = ""
        Dim bSalvageRecovery As Boolean = False
        Dim bIsRecovery As Boolean = False

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Transaction_Type")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = Cast.NullIfDefault(GetClaimReinsuranceArrangementsRequest.ClaimId)

            dsTransTypeCode = con.ExecuteDataSet(cmd, "TransactionType")
            sTransTypeCode = dsTransTypeCode.Tables(0).Rows(0).Item("code").ToString
        End Using

        If sTransTypeCode = TransactionTypeCode.SalvageRecovery Then
            bSalvageRecovery = True
            bIsRecovery = True
        ElseIf sTransTypeCode = TransactionTypeCode.ThirdPartyRecovery Then
            bSalvageRecovery = False
            bIsRecovery = True
        End If
        ' Dataset that will hold the returned results		
        Dim dsArrangements As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_saa")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = Cast.NullIfDefault(GetClaimReinsuranceArrangementsRequest.ClaimId)
            If GetClaimReinsuranceArrangementsRequest.ModeSpecified Then
                cmd.AddInParameter("@mode", SqlDbType.Int).Value = Convert.ToInt32(GetClaimReinsuranceArrangementsRequest.Mode)
            End If
            If bIsRecovery Then
                cmd.AddInParameter("@recovery", SqlDbType.Int).Value = IIf(bSalvageRecovery, 1, 0)
                If GetClaimReinsuranceArrangementsRequest.ModeSpecified = False Then
                    cmd.AddInParameter("@mode", SqlDbType.Int).Value = 0
                End If
            End If
            dsArrangements = con.ExecuteDataSet(cmd, "Row")
        End Using

        With dsArrangements.Tables(0)
            .Columns("ri_arrangement_id").ColumnName = "ArrangementId"
            .Columns("ri_band_id").ColumnName = "BandId"
            .Columns("sum_insured").ColumnName = "SumInsured"
            .Columns("reserve").ColumnName = "ReserveToDate"
            .Columns("this_reserve").ColumnName = "ThisReserve"
            .Columns("payment").ColumnName = "PaymentToDate"
            .Columns("this_payment").ColumnName = "ThisPayment"
            .Columns("RecoveryToDate").ColumnName = "RecoveryToDate"
        End With

        Dim tcBalance As DataColumn
        tcBalance = New DataColumn("Balance")
        tcBalance.DataType = GetType(Double)
        If bIsRecovery Then
            tcBalance.Expression = "(ReserveToDate + ThisReserve) - (PaymentToDate)"
        Else
            tcBalance.Expression = "(ReserveToDate + ThisReserve) - (PaymentToDate + ThisPayment)"
        End If
        dsArrangements.Tables("Row").Columns.Add(tcBalance)

        dsArrangements.DataSetName = "BaseGetClaimReinsuranceArrangementsResponseTypeReinsuranceArrangements"
        dsArrangements.Tables(0).TableName = "Row"

        Dim xmlDoc As New System.Xml.XmlDocument
        If GetClaimReinsuranceArrangementsRequest.WCFSecurityToken = "" Then
            xmlDoc.LoadXml(dsArrangements.GetXml)
            oGetClaimReinsuranceArrangementsResponse.ResultDataset = xmlDoc.DocumentElement()
        End If

        oGetClaimReinsuranceArrangementsResponse.ResultData = dsArrangements
        Return oGetClaimReinsuranceArrangementsResponse

    End Function

