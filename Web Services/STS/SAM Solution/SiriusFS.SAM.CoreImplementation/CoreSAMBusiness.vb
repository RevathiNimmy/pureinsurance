    'Note:Gaurav told to add this new generic function to add the warnings
    ''' <summary>
    ''' adds the specified warning to the warning collection
    ''' </summary>
    ''' <param name="oResponse">An object of type BaseGeneralWarningResponseType</param>
    ''' <param name="Code"></param>
    ''' <param name="Description"></param>
    ''' <remarks></remarks>
    Private Sub AddWarning(ByRef oResponse As BaseGeneralWarningResponseType(),
                           ByVal Code As Integer,
                           ByVal Description As String)

        Dim iUBound As Integer
        If oResponse Is Nothing Then
            iUBound = 0
        Else
            iUBound = oResponse.Length
        End If
        ReDim Preserve oResponse(iUBound)
        oResponse(iUBound) = New BaseGeneralWarningResponseType
        oResponse(iUBound).Code = Code
        oResponse(iUBound).Description = Description
    End Sub

    ''' <summary>  
    ''' adds the specified warning to the warning collection
    ''' </summary>
    ''' <param name="oResponse">An object of type BaseGeneralWarningResponseType</param>
    ''' <param name="Code"></param>
    ''' <param name="Description"></param>
    ''' <remarks></remarks>
    Private Sub AddWarning(ByRef oResponse As System.Collections.Generic.List(Of BaseGeneralWarningResponseType),
                           ByVal Code As Integer,
                           ByVal Description As String)

        Dim oItem As New BaseGeneralWarningResponseType
        oItem.Code = Code
        oItem.Description = Description
        oResponse.Add(oItem)
    End Sub

