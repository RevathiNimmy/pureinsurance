    ''' <summary>  
    ''' GetCaseDetails
    ''' </summary>  
    Public Overloads Function GetCaseDetails(ByVal oGetCaseDetailsRequest As BaseCaseItemsRequestType) As BaseCaseItemsResponseType


        ' validate the request structure against the specified business rules
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Dim oResponse As BaseCaseItemsResponseType

            oResponse = GetCaseDetails(con, oGetCaseDetailsRequest)

            Return oResponse

        End Using

    End Function

    Public Overloads Function GetCaseDetails(ByRef con As SiriusConnection,
    ByVal oRequest As BaseCaseItemsRequestType) As BaseCaseItemsResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseCaseItemsResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim STSError As New STSErrorPublisher
        Dim iProductID As Int32 = 0
        Dim dsFindCase As DataSet = Nothing
        Dim oResultSet As Object = Nothing

        Dim oSAMErrorCollection As New SAMErrorCollection

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetCaseDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetCaseDetailsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        '*******************
        ' STRUCTURE VALIDATION
        '*******************
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' DATA VALIDATION
        '*******************
        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        Else
            oRequest.SourceId = 1
        End If

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' PROCESS
        '*******************

        Try
            Dim dsGetCase As DataSet
            Dim dsGetCaseClaimLink As DataSet
            Dim xmlDoc As New XmlDocument
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Case_Select")
                cmd.AddInParameter("@case_id", SqlDbType.Int).Value = oRequest.CaseKey
                dsGetCase = con.ExecuteDataSet(cmd, "CaseDetails")
            End Using

            If (dsGetCase IsNot Nothing) Then
                If (dsGetCase.Tables(0).Rows.Count >= 1) Then
                    With oResponse
                        .CaseKey = CInt(dsGetCase.Tables(0).Rows(0).Item("case_id"))
                        .CaseNumber = CStr(dsGetCase.Tables(0).Rows(0).Item("case_number"))
                        .CaseOpenedDate = CDate(dsGetCase.Tables(0).Rows(0).Item("case_opened_date"))
                        If CInt(dsGetCase.Tables(0).Rows(0).Item("analyst_handler_id")) > 0 Then
                            oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.Handler, CInt(dsGetCase.Tables(0).Rows(0).Item("analyst_handler_id")), "Code", Nothing, Nothing, .Analyst)
                        End If
                        If CInt(dsGetCase.Tables(0).Rows(0).Item("admin_handler_id")) > 0 Then
                            oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.Handler, CInt(dsGetCase.Tables(0).Rows(0).Item("admin_handler_id")), "Code", Nothing, Nothing, .Assistant)
                        End If
                        If CInt(dsGetCase.Tables(0).Rows(0).Item("case_progress_id")) > 0 Then
                            oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.CaseProgressStatusCode, CInt(dsGetCase.Tables(0).Rows(0).Item("case_progress_id")), "Description", Nothing, .CaseProgressDescription)
                        End If
                        If CInt(dsGetCase.Tables(0).Rows(0).Item("case_progress_id")) > 0 Then
                            oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.CaseProgressStatusCode, CInt(dsGetCase.Tables(0).Rows(0).Item("case_progress_id")), "Code", Nothing, Nothing, .CaseProgressStatusCode)
                        End If
                        .BaseCaseKey = CInt(dsGetCase.Tables(0).Rows(0).Item("Base_case_id"))
                        .CaseVersion = CInt(dsGetCase.Tables(0).Rows(0).Item("case_version"))
                    End With

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Case_Claim_Link")
                        cmd.AddInParameter("@basecaseid", SqlDbType.Int).Value = Cast.ToInt32(dsGetCase.Tables(0).Rows(0).Item("base_case_id"), 0)
                        dsGetCaseClaimLink = con.ExecuteDataSet(cmd, "Row")
                    End Using
                    If (dsGetCaseClaimLink IsNot Nothing) Then
                        If (dsGetCaseClaimLink.Tables(0).Rows.Count >= 1) Then
                            dsGetCaseClaimLink.Tables(0).Columns("claim_id").ColumnName = "ClaimKey"
                            dsGetCaseClaimLink.Tables(0).Columns("claim_number").ColumnName = "ClaimNumber"
                            dsGetCaseClaimLink.Tables(0).Columns("loss_date").ColumnName = "LossDate"
                            dsGetCaseClaimLink.Tables(0).Columns("Claim Handler").ColumnName = "ClaimHandler"
                            dsGetCaseClaimLink.Tables(0).Columns("Risk Type").ColumnName = "RiskType"
                            dsGetCaseClaimLink.Tables(0).Columns("status").ColumnName = "Status"
                            dsGetCaseClaimLink.Tables(0).Columns("total_indemnity").ColumnName = "TotalIndemnity"
                            dsGetCaseClaimLink.Tables(0).Columns("total_expense").ColumnName = "TotalExpense"
                            dsGetCaseClaimLink.Tables(0).Columns("total_excess").ColumnName = "TotalExcess"
                            dsGetCaseClaimLink.Tables(0).Columns("policy_id").ColumnName = "InsuranceFileKey"
                        End If

                        If (oResponse.CaseNumber.Contains("NA") AndAlso dsGetCaseClaimLink.Tables(0).Rows.Count = 1) Then
                            Dim oGetNumberingSchemeNoRequestType As New BaseGetNumberingSchemeNoRequestType
                            Dim oGetNumberingSchemeNoResponseType As New BaseGetNumberingSchemeNoResponseType
                            Dim sCaseNumberingSchemeCode As String = String.Empty

                            With oGetNumberingSchemeNoRequestType
                                .SchemeType = NumberingSchemeType.Case
                                .SourceId = oRequest.SourceId
                                .ClaimKey = Cast.ToInt32(dsGetCaseClaimLink.Tables(0).Rows(0).Item("ClaimKey"), 0)
                            End With

                            oGetNumberingSchemeNoResponseType = GetNumberingSchemeNo(con, oGetNumberingSchemeNoRequestType, True)

                            With oGetNumberingSchemeNoResponseType
                                If .Errors IsNot Nothing Or .STSError IsNot Nothing Then
                                    oResponse.Errors = .Errors
                                    oResponse.STSError = .STSError
                                End If

                                oResponse.CaseNumber = .GeneratedCode
                            End With

                        End If
                    End If


                    dsGetCaseClaimLink.DataSetName = "BaseCaseItemsResponseTypeLinkedClaims"
                    dsGetCaseClaimLink.Tables(0).TableName = "Row"

                    If oRequest.WCFSecurityToken = "" Then
                        xmlDoc.LoadXml(dsGetCaseClaimLink.GetXml())
                        oResponse.ResultDataset = xmlDoc.DocumentElement
                    End If

                    oResponse.ResultData = dsGetCaseClaimLink

                End If
            End If
        Catch ex As Exception
            Throw
        Finally

        End Try

        Return oResponse

    End Function

