    Public Overloads Function ReAssignMultipleWmTasks(ByVal con As SiriusConnection, ByVal ReAssignMultipleWmTasksRequest As BaseReAssignMultipleWmTasksRequestType) As BaseReAssignMultipleWmTasksResponseType
        Dim oResponse As BaseReAssignMultipleWmTasksResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCorebusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        If ReAssignMultipleWmTasksRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ReAssignMultipleWmTasksRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.ReAssignMultipleWmTasksResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If
        'Check Mandatory Fields
        If String.IsNullOrEmpty(ReAssignMultipleWmTasksRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode")
        End If

        Dim iCount As Integer = 0

        For iCount = 0 To ReAssignMultipleWmTasksRequest.Tasks.Row.Length - 1

            'Check Mandatory Fields
            If ReAssignMultipleWmTasksRequest.Tasks.Row(iCount).TaskInstanceKey = 0 Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "TaskInstanceKey")
            End If

            Dim lUserGroupId As Integer
            Dim lUserId As Integer

            'Get UserGroupId
            lUserGroupId = oCorebusiness.GetAndValidateListItemFromCode(CType(STSListType.PMLookup, Core.STSListType), "pmuser_group", ReAssignMultipleWmTasksRequest.Tasks.Row(iCount).UserGroupCode, "pmuser_group_id", oSAMErrorCollection)

            'Get UserId
            lUserId = GetUserId(con, ReAssignMultipleWmTasksRequest.Tasks.Row(iCount).UserCode)
            If lUserId <= 0 Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.UserDoesNotExist, SAMInvalidData.UserDoesNotExist.ToString, "user_id")
            End If

            oSAMErrorCollection.CheckForErrors()

            ReAssignMultipleTasks(con, ReAssignMultipleWmTasksRequest.Tasks.Row(iCount).TaskInstanceKey, lUserGroupId, lUserId, Now, _SiriusUser.UserID)
        Next

        Return oResponse

    End Function

    Private Sub ReAssignMultipleTasks(ByVal con As SiriusConnection,
        ByVal lTaskInstanceCnt As Integer,
        ByVal lUserGroupId As Integer,
        ByVal lUserId As Integer,
        ByVal dtLastModified As Date,
        ByVal lModifiedById As Integer)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_PMWrk_Task_Instance_Multiple_upd")

            cmd.AddInParameter("@pmwrk_task_instance_cnt", SqlDbType.Int).Value = lTaskInstanceCnt

            cmd.AddInParameter("@pmuser_group_id", SqlDbType.Int).Value = lUserGroupId

            cmd.AddInParameter("@user_id", SqlDbType.Int).Value = Cast.NullIfDefault(lUserId, 0)
            cmd.AddInParameter("@last_modified", SqlDbType.DateTime).Value = dtLastModified
            cmd.AddInParameter("@modified_by_id", SqlDbType.Int).Value = lModifiedById

            con.ExecuteNonQuery(cmd)

        End Using

    End Sub

    ''' <summary>
    '''This method pass the request object to the stored procedure and gets eventkey,EventPublicTextKey as  response value
    '''</summary>
    '''<param name="oAddEventNoteRequest" type="BaseAddEventNoteRequestType"></param>
    ''' <returns>An object of type SiriusFS.SAM.SFI.BaseImplementationTypes.BaseAddEventNoteResponseType</returns>
    '''<remarks></remarks>
    Public Overloads Function AddEventNote(ByVal oAddEventNoteRequest As BaseAddEventNoteRequestType) As BaseAddEventNoteResponseType
        Dim oAddEventResponse As New BaseAddEventNoteResponseType
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oAddEventNoteRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AddEventNoteRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oAddEventResponse = New SAMForInsuranceV2ImplementationTypes.AddEventNoteResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oAddEventNoteRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If oAddEventNoteRequest.EventKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "EventKey")
        End If
        If String.IsNullOrEmpty(oAddEventNoteRequest.EventText) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "EventText ")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        Dim sUserDate As String
        Dim sUsername As String
        Dim dtEventDate As DateTime
        dtEventDate = DateTime.Now
        sUsername = _SiriusUser.Username

        Using conAddevent As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            sUserDate = "[" + sUsername.ToUpper + " " + Convert.ToString(dtEventDate) + "]" + vbNewLine
            Try

                conAddevent.BeginTransaction() 'Said by Rahul

                Using cmdPublicText As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Event_Public_Text_add")
                    cmdPublicText.AddInParameter("@event_cnt", SqlDbType.Int).Value = oAddEventNoteRequest.EventKey
                    cmdPublicText.AddInParameter("@text_line", SqlDbType.VarChar, 7500).Value = sUserDate
                    cmdPublicText.AddOutParameter("@event_public_text_id", SqlDbType.Int)
                    conAddevent.ExecuteNonQuery(cmdPublicText)
                End Using
                Using cmdPublicTextDesc As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Event_Public_Text_add")
                    cmdPublicTextDesc.AddInParameter("@event_cnt", SqlDbType.Int).Value = oAddEventNoteRequest.EventKey
                    cmdPublicTextDesc.AddInParameter("@text_line", SqlDbType.VarChar, 7500).Value = oAddEventNoteRequest.EventText
                    cmdPublicTextDesc.AddOutParameter("@event_public_text_id", SqlDbType.Int)
                    conAddevent.ExecuteNonQuery(cmdPublicTextDesc)
                    oAddEventResponse.EventPublicTextKey = Cast.ToInt32(cmdPublicTextDesc.Parameters.Item("@event_public_text_id").Value, 0)
                End Using
                conAddevent.CommitTransaction()
            Catch ex As Exception
                conAddevent.RollbackTransaction()
            End Try
        End Using
        oAddEventResponse.EventKey = oAddEventNoteRequest.EventKey

        Return oAddEventResponse
    End Function

