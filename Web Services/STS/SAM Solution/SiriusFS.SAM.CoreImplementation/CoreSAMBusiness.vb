    ''' <summary>
    ''' GetAgentSettings
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oGetAgentSettingsRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function GetAgentSettings(ByVal con As SiriusConnection, ByVal oGetAgentSettingsRequest As BaseGetAgentSettingsRequestType) As BaseGetAgentSettingsResponseType
        Dim oGetAgentSettingsResponse As New BaseGetAgentSettingsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        'Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetAgentSettingsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetAgentSettingsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetAgentSettingsResponse = New SAMForInsuranceV2ImplementationTypes.GetAgentSettingsResponseType
        End If
        oGetAgentSettingsRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsAgentSettings As DataSet = Nothing
        Dim dsAgentUsers As DataSet = Nothing
        Dim dsContacts As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_party_agent_sel")
            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetAgentSettingsRequest.AgentKey)
            dsAgentSettings = con.ExecuteDataSet(cmd, "Row")
        End Using
        'WPR73-74
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_sir_select_agencyuser")
            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetAgentSettingsRequest.AgentKey)
            cmd.AddInParameter("@deleted_users", SqlDbType.Int).Value = 0
            dsAgentUsers = con.ExecuteDataSet(cmd, "Row")
        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Party_Contacts")
            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetAgentSettingsRequest.AgentKey)
            dsContacts = con.ExecuteDataSet(cmd, "Row")
        End Using

        With oGetAgentSettingsResponse
            .AllowConsolidatedCommission = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("allow_consolidated_commission"), 0)
            .AlternateReferenceForEachTransaction = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("alternate_reference_for_each_transaction"), 0)
            .AlternateReferenceMandatory = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("alternate_reference_mandatory"), 0)
            .CanMakeLiveBankGuarantee = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("can_make_live_bankguarantee"), 0)
            .CanMakeLiveInstalments = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("can_make_live_instalments"), 0)
            .CanMakeLiveInvoice = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("can_make_live_invoice"), 0)
            .CanMakeLivePaynow = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("can_make_live_paynow"), 0)
            .DaysAllowed = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("days_allowed"), 0)
            .DomiciledForTax = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("domiciled_for_tax"), 0)
            .ExpectedDailyPremium = Cast.ToDecimal(dsAgentSettings.Tables(0).Rows(0).Item("expected_daily_premium"), 0)
            .FloatBalanceLimit = Cast.ToDecimal(dsAgentSettings.Tables(0).Rows(0).Item("float_balance_limit"), 0)
            .IsFloatBalanceAccount = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("is_float_balance_account"), 0)
            .IsOverdraftAccount = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("is_overdraft_account"), 0)
            .IsPrepaymentAccount = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("is_prepayment_account"), 0)
            .IsStandardAccount = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("is_standard_account"), 0)
            .OverdraftExpiry = Cast.ToDateTime(dsAgentSettings.Tables(0).Rows(0).Item("overdraft_expiry"), Nothing)
            .OverdraftLimit = Cast.ToDecimal(dsAgentSettings.Tables(0).Rows(0).Item("overdraft_limit"), 0)
            .UseOverrideCommissionRate = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("use_override_commission_rate"), 0)
            .CanMakeLiveCashDeposit = Cast.ToInt32(dsAgentSettings.Tables(0).Rows(0).Item("can_make_live_cashdeposit"), 0)
            .PartyAgentDateCancelled = Cast.ToDateTime(dsAgentSettings.Tables(0).Rows(0).Item("date_cancelled"), Nothing)
            .CorrespondenceType = ToSafeString(dsAgentSettings.Tables(0).Rows(0).Item("correspondence_type"))
            .IsReceiveClientCorrespondence = ToSafeBoolean(dsAgentSettings.Tables(0).Rows(0).Item("receives_client_correspondence"), False)
            If dsAgentUsers IsNot Nothing AndAlso dsAgentUsers.Tables.Count > 0 AndAlso dsAgentUsers.Tables(0).Rows IsNot Nothing AndAlso dsAgentUsers.Tables(0).Rows.Count > 0 Then
                With dsAgentUsers.Tables(0)
                    ReDim oGetAgentSettingsResponse.Users(dsAgentUsers.Tables(0).Rows.Count - 1)

                    Dim iCnt As Integer = 0
                    For iCnt = 0 To dsAgentUsers.Tables(0).Rows.Count - 1
                        oGetAgentSettingsResponse.Users(iCnt) = New BaseUserDetailsType
                        oGetAgentSettingsResponse.Users(iCnt).UserKey = Cast.ToInt32(dsAgentUsers.Tables(0).Rows(iCnt).Item("user_id"), 0)
                        oGetAgentSettingsResponse.Users(iCnt).EmailAddress = Cast.ToString(dsAgentUsers.Tables(0).Rows(iCnt).Item("email_address"), String.Empty)
                        oGetAgentSettingsResponse.Users(iCnt).UserName = Cast.ToString(dsAgentUsers.Tables(0).Rows(iCnt).Item("username"), String.Empty)
                        If String.IsNullOrEmpty(Cast.ToString(dsAgentUsers.Tables(0).Rows(iCnt).Item("full_name"), String.Empty)) Then
                            oGetAgentSettingsResponse.Users(iCnt).FullName = Cast.ToString(dsAgentUsers.Tables(0).Rows(iCnt).Item("username"), String.Empty)
                        Else
                            oGetAgentSettingsResponse.Users(iCnt).FullName = Cast.ToString(dsAgentUsers.Tables(0).Rows(iCnt).Item("full_name"), String.Empty)
                        End If
                        oGetAgentSettingsResponse.Users(iCnt).EffectiveDate = Cast.ToDateTime(dsAgentUsers.Tables(0).Rows(iCnt).Item("effective_date"), Date.MinValue)
                    Next
                End With
            End If

            If dsContacts IsNot Nothing AndAlso dsContacts.Tables.Count > 0 AndAlso dsContacts.Tables(0).Rows IsNot Nothing AndAlso dsContacts.Tables(0).Rows.Count > 0 Then
                With dsContacts.Tables(0)
                    ReDim oGetAgentSettingsResponse.Contacts(dsContacts.Tables(0).Rows.Count - 1)

                    Dim iCnt As Integer = 0
                    For iCnt = 0 To dsContacts.Tables(0).Rows.Count - 1
                        oGetAgentSettingsResponse.Contacts(iCnt) = New BaseContactType
                        oGetAgentSettingsResponse.Contacts(iCnt).AreaCode = Cast.ToString(dsContacts.Tables(0).Rows(iCnt).Item("area_code"), String.Empty)
                        oGetAgentSettingsResponse.Contacts(iCnt).OtherContactTypeCode = Cast.ToString(dsContacts.Tables(0).Rows(iCnt).Item("contact_type_code"), String.Empty)
                        oGetAgentSettingsResponse.Contacts(iCnt).Description = Cast.ToString(dsContacts.Tables(0).Rows(iCnt).Item("number"), String.Empty)
                        oGetAgentSettingsResponse.Contacts(iCnt).Extension = Cast.ToString(dsContacts.Tables(0).Rows(iCnt).Item("extension"), String.Empty)
                        Dim sContactType As String = Cast.ToString(dsContacts.Tables(0).Rows(iCnt).Item("Contact_Type_Code"), String.Empty).Trim

                        Select Case sContactType
                            Case ContactType.Email
                                oGetAgentSettingsResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.EMAIL
                            Case ContactType.Telephone
                                oGetAgentSettingsResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.HOMEPHONE
                            Case ContactType.Mobile
                                oGetAgentSettingsResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.MOBILE
                            Case ContactType.Fax
                                oGetAgentSettingsResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.FAX
                            Case ContactType.Web
                                oGetAgentSettingsResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.WEB
                            Case ContactType.Main
                                oGetAgentSettingsResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.MAIN
                            Case Else
                                oGetAgentSettingsResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.OTHER
                        End Select
                    Next
                End With
            End If
        End With

        Dim dsAgentBranches As DataSet = Nothing
        Dim dsFilter As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_AgentBranches")
            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetAgentSettingsRequest.AgentKey)
            dsAgentBranches = con.ExecuteDataSet(cmd, "Row")
        End Using

        If dsAgentBranches IsNot Nothing AndAlso dsAgentBranches.Tables IsNot Nothing AndAlso dsAgentBranches.Tables.Count > 0 AndAlso dsAgentBranches.Tables(0).Rows IsNot Nothing AndAlso dsAgentBranches.Tables(0).Rows.Count > 0 Then
