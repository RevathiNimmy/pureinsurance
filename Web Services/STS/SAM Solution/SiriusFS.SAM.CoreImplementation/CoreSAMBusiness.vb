    Public Overloads Function GetSubAgents(ByVal conSubAgent As SiriusConnection, ByVal oGetSubAgentsRequest As BaseGetSubAgentsRequestType) As BaseGetSubAgentsResponseType
        Dim oGetSubAgentsResponse As New BaseGetSubAgentsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetSubAgentsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetSubAgentsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetSubAgentsResponse = New SAMForInsuranceV2ImplementationTypes.GetSubAgentsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing

        End If

        oGetSubAgentsRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetSubAgentsRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If
        If oGetSubAgentsRequest.InsuranceFileKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If
        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsSubAgents As DataSet = Nothing
        If oGetSubAgentsRequest.InsuranceFileKey <> 0 Then
            Using cmdSubAgent As SiriusCommand = SiriusCommand.FromProcedure("spu_Select_SubAgents")
                cmdSubAgent.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetSubAgentsRequest.InsuranceFileKey)
                dsSubAgents = conSubAgent.ExecuteDataSet(cmdSubAgent, "Row")
            End Using
        End If
        'Populate the XML Document with the dsAgents information
        If dsSubAgents IsNot Nothing AndAlso (dsSubAgents.Tables.Count >= 1) Then
            If (dsSubAgents.Tables(0).Rows.Count >= 1) Then
                dsSubAgents.DataSetName = "BaseGetSubAgentsResponseTypeSubAgents"
                With dsSubAgents.Tables(0)
                    .TableName = "Row"
                    .Columns("party_cnt").ColumnName = "PartyKey"
                    .Columns("shortname").ColumnName = "Code"
                    .Columns("resolved_name").ColumnName = "Name"
                    .Columns(3).ColumnName = "Percentage"
                    .Columns(4).ColumnName = "Amount"
                End With

                Dim xmlDoc As New System.Xml.XmlDocument
                If oGetSubAgentsRequest.WCFSecurityToken = "" Then
                    xmlDoc.LoadXml(dsSubAgents.GetXml)
                    oGetSubAgentsResponse.SubAgentsDataset = xmlDoc.DocumentElement()
                End If
                oGetSubAgentsResponse.ResultData = dsSubAgents
            Else
                oGetSubAgentsResponse.ResultData = dsSubAgents
            End If
        End If

        Dim comReturnValue As Integer
        Dim listRisksBusiness As bSIRListRisks.Business = CreateAndInitialiseListRisksBusiness(conSubAgent, oGetSubAgentsRequest.BranchCode)
        Dim bIsValid As Boolean = False

        Try
            comReturnValue = listRisksBusiness.ValidateCertificateYear(bIsValid:=bIsValid, lNewInsuranceFileCnt:=oGetSubAgentsRequest.InsuranceFileKey)
            If bIsValid = False Then
                oErrors.AddBusinessRule(
                    SAMBusinessErrors.InvalidCertificateYears,
                    SAMBusinessErrors.InvalidCertificateYears.ToString())
                oErrors.CheckForErrors()
            End If
            If comReturnValue <> PMEReturnCode.PMTrue Then
                RaiseComMethodException("bSIRListRisks.Business.ValidateCertificateYear", comReturnValue)
            End If

        Catch ex As System.Exception
            Throw
        Finally
            If listRisksBusiness IsNot Nothing Then
                listRisksBusiness.Dispose()
                listRisksBusiness = Nothing
            End If
        End Try

        Return oGetSubAgentsResponse
    End Function

