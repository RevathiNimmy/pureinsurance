    Private Overloads Sub GetTaxes(ByVal con As SiriusConnection,
                                   ByVal insuranceFileKey As Integer,
                                   ByVal riskKey As Integer,
                                   ByVal branchCode As String,
                                   ByRef riskTax As Decimal,
                                   ByRef riskTaxes() As BaseTaxesType,
                                   ByRef policyTax As Decimal,
                                   ByRef policyTaxes() As BaseTaxesType)

        Const ACMethodName As String = "GetTaxes"

        Dim iRet As Integer = 0
        Dim insuranceFileTypeId As Integer
        Dim insuranceFileTypeCode As String
        Dim sProductCode As String = "NB"
        ' Now caluculate the Tax using the taxation business object
        Dim oSIRTax As bSIRRITax.Business = Nothing
        Try
            oSIRTax = New bSIRRITax.Business
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bSIRRITax.Business", ex.Message)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "Create bSIRRITax.Business Failed", True)
        End Try

        ' Initialise the business object
        Try
            SAMFunc.InitialiseSBOObject(Con:=con, oObject:=oSIRTax, SiriusUser:=_SiriusUser, sBranchCode:=branchCode, sObjectName:="bSIRRITax.Business")
        Catch ex As Exception
            If oSIRTax IsNot Nothing Then
                oSIRTax.Dispose()
                oSIRTax = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bSIRRITax.Business", ex.Message)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRRITax.Business.Initialise", True)
        End Try

        ' Set up the business object
        oSIRTax.InsuranceFileCnt = insuranceFileKey
        GetInsuranceFileType(con, insuranceFileKey, insuranceFileTypeId, insuranceFileTypeCode)

        Select Case insuranceFileTypeCode
            Case InsuranceFileType.LivePolicy, InsuranceFileType.Quote
                sProductCode = "NB"

            Case InsuranceFileType.MTAPermanentQuotation, InsuranceFileType.MTATemporaryQuotation,
                 InsuranceFileType.MTAPermanent, InsuranceFileType.MTATemporary,
                 InsuranceFileType.MTAQuotationReinstatement, InsuranceFileType.MTAReinstated, InsuranceFileType.MTAQuotationCancellation
                sProductCode = "MTA"

            Case InsuranceFileType.Renewal
                sProductCode = "REN"

            Case InsuranceFileType.MTACancellation
                sProductCode = "MTC"
        End Select

        ' Set the Task mode and Transaction type
        iRet = oSIRTax.SetProcessModes(vTask:=0, vTransactionType:=Cast.ToObjString(sProductCode))
        If (iRet <> 1) Then
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.BackofficeComponentFailed, "The call to bSIRRITax.Business.SetProcessModes failed.", iRet.ToString)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRRITax.Business.SetProcessModes failed.", True)
        End If

        If riskKey <> 0 Then
            Dim arrRiskTax As Object(,)
            Dim arrRiskTaxObject As Object = Nothing
            Dim sDescription As String = String.Empty

            oSIRTax.RiskCnt = riskKey

            ' Retrieve the tax details
            iRet = oSIRTax.GetRiskTax(arrRiskTaxObject, sDescription)

            If (iRet <> 1) Then
                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToRetrievePremiumDetails, "The call to bSIRRITax.Business.GetRiskTax failed.", iRet.ToString)
                STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRRITax.Business.GetRiskTax failed.", True)
            End If

            If IsArray(arrRiskTaxObject) = True Then
                arrRiskTax = DirectCast(arrRiskTaxObject, Object(,))

                Dim iLBnd As Integer = arrRiskTax.GetLowerBound(1)
                Dim iUBnd As Integer = arrRiskTax.GetUpperBound(1)

                riskTax = 0
                ReDim riskTaxes(iUBnd)

                For cnt As Integer = iLBnd To iUBnd
                    riskTaxes(cnt) = New BaseTaxesType
                    riskTaxes(cnt).Amount = Convert.ToDecimal(arrRiskTax.GetValue(InternalSAMConstants.ACRTaxValue, cnt))
                    riskTaxes(cnt).Description = Cast.ToString(arrRiskTax.GetValue(InternalSAMConstants.ACRDescription, cnt), "")
                    riskTax += riskTaxes(cnt).Amount
                Next
            End If
        End If

        Dim arrInsFileTax As Object(,)
        Dim arrInsFileTaxObject As Object = Nothing
        Dim description As String = String.Empty

        ' Retrieve the tax details
        iRet = oSIRTax.GetInsuranceFileTax(arrInsFileTaxObject, description)

        If (iRet <> 1) Then
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToRetrievePremiumDetails, "The call to bSIRRITax.Business.GetRiskTax failed.", iRet.ToString)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRRITax.Business.GetRiskTax failed.", True)
        End If

        ' If the policy level taxes have been calculated then total them up
        If IsArray(arrInsFileTaxObject) = True Then
            arrInsFileTax = DirectCast(arrInsFileTaxObject, Object(,))

            Dim iLBnd As Integer = arrInsFileTax.GetLowerBound(1)
            Dim iUBnd As Integer = arrInsFileTax.GetUpperBound(1)

            policyTax = 0
            ReDim policyTaxes(iUBnd)

            For cnt As Integer = iLBnd To iUBnd
                policyTaxes(cnt) = New BaseTaxesType
                policyTaxes(cnt).Amount = Convert.ToDecimal(arrInsFileTax.GetValue(InternalSAMConstants.ACRTaxValue, cnt).ToString())
                policyTaxes(cnt).Description = Cast.ToString(arrInsFileTax.GetValue(InternalSAMConstants.ACRDescription, cnt), "")
                policyTax += policyTaxes(cnt).Amount
            Next
        End If

        ' Kill off the com reference
        If oSIRTax IsNot Nothing Then
            oSIRTax.Dispose()
            oSIRTax = Nothing
        End If
    End Sub
    Public Overloads Function GetAndValidateSpecifiedTableCode(
       ByVal sTableName As String,
       ByVal sTableKeyNameToReturn As String,
       ByVal sFieldNameToValidate As String,
       ByVal sValueToValidate As String,
       ByVal oSAMErrorCollection As SAMErrorCollection,
       ByVal sRequestFieldName As String) As Integer

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                                    _SiriusUser.Username, _SiriusUser.SourceID,
                                                    _SiriusUser.LanguageID,
                                                    SiriusUserDefaults.AppName)
            Dim result As Integer = 0
            result = GetAndValidateSpecifiedTableCode(con,
                                       sTableName,
                                       sTableKeyNameToReturn,
                                       sFieldNameToValidate,
                                       sValueToValidate,
