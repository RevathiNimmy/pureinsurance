    Public Overloads Function UpdateCashDeposit(ByVal conCashDeposit As SiriusConnection, ByVal oUpdateCashDepositRequest As BaseUpdateCashDepositRequestType) As BaseUpdateCashDepositResponseType
        Dim oUpdateCashDepositResponse As New BaseUpdateCashDepositResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage

        If oUpdateCashDepositRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateCashDepositRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateCashDepositResponse = New SAMForInsuranceV2ImplementationTypes.UpdateCashDepositResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        If String.IsNullOrEmpty(oUpdateCashDepositRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        For Each CashDeposit As BaseCommonCashDepositItemType In oUpdateCashDepositRequest.CashDeposit
            'Do the business valiation 
            CashDeposit.Validate(CObj(oSAMErrorCollection))
        Next
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Data Validation
        '*******************************************************************************************

        oUpdateCashDepositRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
            PMLookupTable.Source, oUpdateCashDepositRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        For Each CashDeposit As BaseCommonCashDepositItemType In oUpdateCashDepositRequest.CashDeposit
            ValidateUpdateDataCashDepositItem(oSAMErrorCollection, oCoreBusiness, conCashDeposit, CashDeposit)
        Next
        oSAMErrorCollection.CheckForErrors()

        Using conCashDeposit
            conCashDeposit.BeginTransaction()
            Dim iCount As Integer = 0
            Dim sDescription As String = ""
            Dim sUserName As String = ""
            Dim dsCashDeposit As DataSet
            Dim sPartyName As String
            Dim sCashDepositRef As String
            Dim iUserId As Integer

            Try
                ' For each row in the request
                oUpdateCashDepositResponse.CashDeposit = New BaseUpdateCashDepositResponseTypeCashDeposit
                For Each CashDeposit As BaseCommonCashDepositItemType In oUpdateCashDepositRequest.CashDeposit

                    'Fetch the Cash Deposit details to update Event Log
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_CashDeposit_For_CD_Maintenance")
                        cmd.AddInParameter("@party_code", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(CashDeposit.PartyCode, "")
                        cmd.AddInParameter("@CashDeposit_Ref", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(CashDeposit.CashDepositRef, "")
                        dsCashDeposit = conCashDeposit.ExecuteDataSet(cmd, "Cash_Deposit")
                        sCashDepositRef = Cast.ToString(dsCashDeposit.Tables(0).Rows(0).Item("CashDeposit_Ref"), Nothing)
                        sPartyName = Cast.ToString(dsCashDeposit.Tables(0).Rows(0).Item("Party_Name"), Nothing)
                        sUserName = Cast.ToString(dsCashDeposit.Tables(0).Rows(0).Item("UserName"), "")

                        'sUserName = GetAndValidateDescriptionById(conCashDeposit, "PMUser", "UserName", "User_Id", iUserId.ToString)
                        sDescription = "Cash Deposit Details are Modified From:-:- " + Environment.NewLine + Environment.NewLine + "User Name: " & Trim(sUserName) & Environment.NewLine &
                                          "Party Name: " & sPartyName & Environment.NewLine & "CD Number: " & sCashDepositRef & Environment.NewLine & Environment.NewLine
                    End Using

                    oCoreBusiness.CheckSAMTSAndLock(Con:=conCashDeposit,
                   BranchCode:=oUpdateCashDepositRequest.BranchCode,
                   Lockname:=CoreBusiness.LockName.CashDepositKey,
                   LockValue:=CashDeposit.CashDepositKey,
                   TStamp:=CashDeposit.CDTimeStamp)

                    If (CashDeposit IsNot Nothing) Then
                        UpdateCashDepositItem(oSAMErrorCollection, oCoreBusiness, conCashDeposit,
                        CashDeposit)

                        sPartyName = GetAndValidateDescriptionById(conCashDeposit, "Party", "Resolved_Name", "shortname", CashDeposit.PartyCode)
                        sDescription = " To " + Environment.NewLine + Environment.NewLine + "User Name: " & Trim(CashDeposit.UserName) & Environment.NewLine &
                                          "Party Name: " & sPartyName & Environment.NewLine & "CD Number: " & CashDeposit.CashDepositRef & Environment.NewLine & Environment.NewLine

                        CreateEvent(conCashDeposit, CashDeposit.PartyKey, Nothing, Nothing, Nothing,
                               Nothing, Nothing, Nothing, Nothing, Nothing, Nothing,
                               Nothing, _SiriusUser.UserID, Now, sDescription, Nothing, Nothing, Nothing,
                               Nothing, Nothing, Nothing, Nothing, 0, Nothing, Nothing, CashDeposit.CashDepositKey)
                    End If
                    ReDim Preserve oUpdateCashDepositResponse.CashDeposit.Row(iCount)
                    oUpdateCashDepositResponse.CashDeposit.Row(iCount) = New BaseUpdateCashDepositResponseTypeCashDepositRow
                    oUpdateCashDepositResponse.CashDeposit.Row(iCount).CashDepositKey = CashDeposit.CashDepositKey
                    oUpdateCashDepositResponse.CashDeposit.Row(iCount).CashDepositRef = CashDeposit.CashDepositRef

                    DeleteCashDepositItemBranches(conCashDeposit, CashDeposit, oSAMErrorCollection)
                    DeleteCashDepositItemProducts(conCashDeposit, CashDeposit, oSAMErrorCollection)

                    If (CashDeposit.Products IsNot Nothing) Then
                        For Each products As BaseCommonCashDepositItemTypeProducts In CashDeposit.Products
                            AddCashDepositProducts(oSAMErrorCollection, conCashDeposit,
                           products, CashDeposit.CashDepositKey)
                        Next
                    End If
                    If (CashDeposit.Branches IsNot Nothing) Then
                        For Each Branches As BaseCommonCashDepositItemTypeBranches In CashDeposit.Branches
                            AddCashDepositBranches(oSAMErrorCollection, conCashDeposit,
                           Branches, CashDeposit.CashDepositKey)
                        Next
                    End If
                    iCount += 1
                Next

                For Each CashDeposit As BaseCommonCashDepositItemType In oUpdateCashDepositRequest.CashDeposit
                    oCoreBusiness.UnlockAndGetSAMTS(Con:=conCashDeposit,
                            BranchCode:=oUpdateCashDepositRequest.BranchCode,
                            Lockname:=CoreBusiness.LockName.CashDepositKey,
                            LockValue:=CashDeposit.CashDepositKey,
                            TStamp:=CashDeposit.CDTimeStamp)
                Next
                conCashDeposit.CommitTransaction()

            Catch ex As Exception

                conCashDeposit.RollbackTransaction()

                Throw

            End Try

        End Using

        Return oUpdateCashDepositResponse

    End Function

