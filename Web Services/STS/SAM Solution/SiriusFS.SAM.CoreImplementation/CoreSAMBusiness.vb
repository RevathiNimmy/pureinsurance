    Public Overloads Function GetRenewalAmountToFinance(ByVal conGetRenewalAmountToFinance As SiriusConnection, ByVal oGetRenewalAmountToFinanceRequest As BaseGetRenewalAmountToFinanceRequestType) As BaseGetRenewalAmountToFinanceResponseType

        Dim oGetRenewalAmountToFinanceResponse As New BaseGetRenewalAmountToFinanceResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim oPremiumFinanceBusiness As New bSIRPremiumFinance.Business
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetRenewalAmountToFinanceRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetRenewalAmountToFinanceRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetRenewalAmountToFinanceResponse = New SAMForInsuranceV2ImplementationTypes.GetRenewalAmountToFinanceResponseType
        End If
        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetRenewalAmountToFinanceRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If


        If oGetRenewalAmountToFinanceRequest.InsuranceFileKey = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If

        ' exit if there are any missing parameters
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Lookup and data Validation
        '*******************************************************************************************

        If Not String.IsNullOrEmpty(oGetRenewalAmountToFinanceRequest.BranchCode) Then
            oGetRenewalAmountToFinanceRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oGetRenewalAmountToFinanceRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If


        oSAMErrorCollection.CheckForErrors()




        SAMFunc.InitialiseSBOObject(oPremiumFinanceBusiness, _SiriusUser, oGetRenewalAmountToFinanceRequest.BranchCode)
        Dim nComReturnValue As Integer = 0


        If oGetRenewalAmountToFinanceRequest.InsuranceFileKey > 0 Then
            'Fetch renewal amount including any previous MTA amount to put on

            Dim vAmountToFinance(,) As Object = Nothing
            vAmountToFinance = CType(vAmountToFinance, Object(,))
            nComReturnValue = oPremiumFinanceBusiness.GetRenewalAmountToFinance(v_lInsuranceFileCnt:=oGetRenewalAmountToFinanceRequest.InsuranceFileKey, r_vResults:=vAmountToFinance)
            If nComReturnValue <> PMEReturnCode.PMTrue Then
                RaiseComMethodException("bSIRPremiumFinance.Business.IsSinglePlanAgent", nComReturnValue)
            End If

            If (Not vAmountToFinance Is Nothing) Then
                oGetRenewalAmountToFinanceResponse.RenewalAmount = gPMFunctions.ToSafeCurrency(gPMFunctions.ToSafeString(vAmountToFinance(0, 0)), 0)
            End If

        End If
        Return oGetRenewalAmountToFinanceResponse
    End Function
