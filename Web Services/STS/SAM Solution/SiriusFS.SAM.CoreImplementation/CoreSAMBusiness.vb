    ''' <summary>
    ''' This  method is to Update FinancePlan Details
    '''<param name="conFP" type="SiriusConnection"></param>
    '''<param name="oUpdateFinancePlanDetailsRequest" type="BaseUpdateFinancePlanDetailsRequestType"></param>
    '''<returns>BaseUpdateFinancePlanDetailsResponseType</returns>
    '''</summary>
    '''<remarks></remarks>
    Public Overloads Function UpdateFinancePlanDetails(ByVal conFP As SiriusConnection, ByVal oUpdateFinancePlanDetailsRequest As BaseUpdateFinancePlanDetailsRequestType) As BaseUpdateFinancePlanDetailsResponseType
        Dim oUpdateFinancePlanDetailsResponse As New BaseUpdateFinancePlanDetailsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim STSError As New STSErrorPublisher
        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage
        Const ACMethodName As String = "UpdateFinancePlanDetails"
        Dim oPremiumFinance As New bSIRPremiumFinance.Business
        Dim comReturnValue As Integer
        Dim vPFPremiumFinance As Object(,) = Nothing
        Dim oPFArray As Object(,)
        Dim mediatype As Integer
        Dim oCreditCard As New BaseCreditCardType
        Dim lPremiumFinanceCntObject As Object = Nothing
        Dim lPremiumFinanceVerObject As Object = Nothing
        Dim iInsuranceFileCnt As Integer
        Dim iClientId As Integer

        If oUpdateFinancePlanDetailsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateFinancePlanDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oUpdateFinancePlanDetailsResponse = New SAMForInsuranceV2ImplementationTypes.UpdateFinancePlanDetailsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        oUpdateFinancePlanDetailsRequest.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        'structure validation
        If oUpdateFinancePlanDetailsRequest.CreditCard IsNot Nothing Then
            oCreditCard.NameOnCreditCard = oUpdateFinancePlanDetailsRequest.CreditCard.NameOnCreditCard
            oCreditCard.Number = oUpdateFinancePlanDetailsRequest.CreditCard.Number
            oCreditCard.ExpiryDate = oUpdateFinancePlanDetailsRequest.CreditCard.ExpiryDate
            oCreditCard.Validate(CType(oErrors, Object))
            oErrors.CheckForErrors()
        End If

        If Not String.IsNullOrEmpty(oUpdateFinancePlanDetailsRequest.BranchCode) Then
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oUpdateFinancePlanDetailsRequest.BranchCode, "BranchCode", oErrors)
        End If

        oErrors.CheckForErrors()

        Try
            Using cmdscheme As SiriusCommand = SiriusCommand.FromProcedure("spu_PFPremiumFinance_scheme_sel")
                cmdscheme.AddInParameter("@financeplancnt", SqlDbType.Int).Value = oUpdateFinancePlanDetailsRequest.FinancePlanKey
                cmdscheme.AddInParameter("@financeplanversion", SqlDbType.Int).Value = oUpdateFinancePlanDetailsRequest.FinancePlanVersion
                cmdscheme.AddOutParameter("@mediatype", SqlDbType.Int)
                conFP.ExecuteNonQuery(cmdscheme)
                mediatype = Cast.ToInt32(cmdscheme.Parameters.Item("@mediatype").Value, 0)
            End Using

            If mediatype <> 9 Then 'If the media type is not creditcard reject the request
                oErrors.AddBusinessRule(SAMBusinessErrors.Invalidmediatype,
                SAMBusinessErrors.Invalidmediatype.ToString,
                "Can not update FinancePlan Details whose media type is not creditcard")
                oErrors.CheckForErrors()
            Else
                'Check partybankkey is provided with paymentitems. If yes, validate the partybankkey
                'Since the request does not have a party key, we can not validate the party bank key with party key
                'To Do: Get party key from the database for the given finance plan and validate the party key with party bank id. Also validate teh credit card details .
                If oUpdateFinancePlanDetailsRequest.CreditCard IsNot Nothing AndAlso oUpdateFinancePlanDetailsRequest.CreditCard.PartyBankKey > 0 Then

                    Dim sReturnValue As String = String.Empty
                    sReturnValue = GetAndValidateDescriptionById(conFP, "Party_Bank", "Party_Bank_Id", "Party_Bank_Id", oUpdateFinancePlanDetailsRequest.CreditCard.PartyBankKey.ToString())
                    Try
                        If (String.IsNullOrEmpty(sReturnValue) OrElse Convert.ToInt32(sReturnValue) = 0) Then
                            oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                                                    SAMInvalidData.InvalidLookupListValue.ToString,
                                                                    "PartyBankKey",
                                                                   oUpdateFinancePlanDetailsRequest.CreditCard.PartyBankKey.ToString())
                        End If
                    Catch
                        oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                                                    SAMInvalidData.InvalidLookupListValue.ToString,
                                                                    "PartyBankKey",
                                                                   oUpdateFinancePlanDetailsRequest.CreditCard.PartyBankKey.ToString())
                    End Try
                    oErrors.CheckForErrors()
                End If
            End If

            InitialiseSBOObject(conFP, oPremiumFinance, _SiriusUser, "bSIRPremiumFinance.BusinessClass")
            comReturnValue = oPremiumFinance.GetSingleFinancePlan(v_lFinanceCount:=oUpdateFinancePlanDetailsRequest.FinancePlanKey, v_lFinanceVersion:=oUpdateFinancePlanDetailsRequest.FinancePlanVersion, r_vPFPremiumFinance:=vPFPremiumFinance)
            If comReturnValue <> PMEReturnCode.PMTrue AndAlso comReturnValue <> PMEReturnCode.PMNotFound Then
                RaiseComMethodException("bSIRPremiumFinance.BusinessClass.GetSingleFinancePlan", comReturnValue)
            End If

            oPFArray = DirectCast(vPFPremiumFinance, Object(,))
            If (comReturnValue <> PMEReturnCode.PMTrue) Then
                If oPremiumFinance IsNot Nothing Then
                    oPremiumFinance.Dispose()
                    oPremiumFinance = Nothing
                End If
                STSError = New STSErrorPublisher(BackOfficeReturnValue:=comReturnValue, Description:="The call to PremiumFinance.GetSingleFinancePlan failed.  See the Sirius backoffice log for further details")
                STSError.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRPremiumFinance.Business", True)
            ElseIf IsArray(oPFArray) = False Then
                If oPremiumFinance IsNot Nothing Then
                    oPremiumFinance.Dispose()
                    oPremiumFinance = Nothing
                End If
                STSError = New STSErrorPublisher(comReturnValue, "PremiumFinance.GetSingleFinancePlan failed to retrieve the Finance Plane for Premium Finance record - " & oUpdateFinancePlanDetailsRequest.FinancePlanKey)
                STSError.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRPremiumFinance.Business", True)
            End If

            'Update credit card details
            If oUpdateFinancePlanDetailsRequest.CreditCard IsNot Nothing Then

                oPFArray(k_PFPlanBankAccountName, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.NameOnCreditCard
                oPFArray(k_PFPlanCCNumber, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.Number
                oPFArray(k_PFPlanCCExpiryDate, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.ExpiryDate
                oPFArray(k_PFPlanCCStartDate, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.StartDate
                oPFArray(k_PFPlanCCIssue, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.Issue
                oPFArray(k_PFPlanCCPin, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.Pin
                oPFArray(k_PFPlanCardType, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.TypeCode
                oPremiumFinance.DepositCCTrackingNumber = oUpdateFinancePlanDetailsRequest.CreditCard.TrackingNumber
                oPFArray(k_PFPlanPartyBankIdSel, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.PartyBankKey

                If oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder IsNot Nothing Then
                    oPFArray(k_PfPlanCardholderName, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.Name
                    oPFArray(k_PfPlanCardholderAddress1, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.AddressLine1
                    oPFArray(k_PfPlanCardholderAddress2, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.AddressLine2
                    oPFArray(k_PfPlanCardholderAddress3, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.AddressLine3
                    oPFArray(k_PfPlanCardholderAddress4, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.AddressLine4
                    oPFArray(k_PfPlanCardholderPostcode, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.PostCode
                    oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.CountryKey = oCoreBusiness.GetListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Country, oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.CountryCode)
                    oPFArray(k_PFPlanClientCountry_ID, 0) = oUpdateFinancePlanDetailsRequest.CreditCard.CardHolder.CountryKey

                End If
            End If

            lPremiumFinanceCntObject = oUpdateFinancePlanDetailsRequest.FinancePlanKey
            lPremiumFinanceVerObject = oUpdateFinancePlanDetailsRequest.FinancePlanVersion
            vPFPremiumFinance = oPFArray

            comReturnValue = oPremiumFinance.UpdateExistingRecord(
                CType(CObj(vPFPremiumFinance), System.Object(,)),
                lPremiumFinanceCntObject,
                lPremiumFinanceVerObject)

            If (comReturnValue <> PMEReturnCode.PMTrue) Then
                If oPremiumFinance IsNot Nothing Then
                    oPremiumFinance.Dispose()
                    oPremiumFinance = Nothing
                End If
                STSError = New STSErrorPublisher(BackOfficeReturnValue:=comReturnValue, Description:="The call to PremiumFinance.UpdateExistingRecord failed.  See the Sirius backoffice log for further details")
                STSError.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRPremiumFinance.Business", True)
            End If

            comReturnValue = oPremiumFinance.SaveInstalmentsPlanMediaTypeDetails(
                   v_lPfPremFinanceCnt:=oUpdateFinancePlanDetailsRequest.FinancePlanKey,
                   v_lPfPremFinanceVersion:=oUpdateFinancePlanDetailsRequest.FinancePlanVersion,
                   v_sActionCode:=InstalmentHistoryActionType.Amendment)

            If (comReturnValue <> PMEReturnCode.PMTrue) Then
                If oPremiumFinance IsNot Nothing Then
                    oPremiumFinance.Dispose()
                    oPremiumFinance = Nothing
                End If
                STSError = New STSErrorPublisher(BackOfficeReturnValue:=comReturnValue, Description:="The call to PremiumFinance.SaveInstalmentsPlanMediaTypeDetails failed. See the Sirius backoffice log for further details")
                STSError.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRPremiumFinance.Business", True)
            End If

            iInsuranceFileCnt = Convert.ToInt32(oPFArray(k_PFPlanInsuranceFileCnt, 0))
            iClientId = Convert.ToInt32(oPFArray(k_PFPlanClientId, 0))
            comReturnValue = oPremiumFinance.CreateEvent(v_lMode:="PMEdit", v_lInsuranceFileCnt:=iInsuranceFileCnt, v_lPartyCnt:=iClientId)

            If (comReturnValue <> PMEReturnCode.PMTrue) Then
                If oPremiumFinance IsNot Nothing Then
                    oPremiumFinance.Dispose()
                    oPremiumFinance = Nothing
                End If
                STSError = New STSErrorPublisher(BackOfficeReturnValue:=comReturnValue, Description:="The call to PremiumFinance.CreateEvent failed. See the Sirius backoffice log for further details")
                STSError.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bSIRPremiumFinance.Business", True)
            End If

        Finally
            If oPremiumFinance IsNot Nothing Then
                oPremiumFinance.Dispose()
                oPremiumFinance = Nothing
            End If
        End Try

        Return oUpdateFinancePlanDetailsResponse
    End Function

