#Region "Private Method - ProcessAddressDetails"

    '''<param name="oRequest" type="BaseFindAddressRequestType"></param>    
    '''<param name="oResponse" type="BaseFindAddressResponseType"></param>   
    '''<param name="obAddressBusiness" type="bPMAddressControl.Business"></param> 
    '''<remarks></remarks>
    Private Function ProcessAddressDetails(ByRef oRequest As BaseFindAddressRequestType,
    ByRef oResponse As BaseFindAddressResponseType) As BaseFindAddressResponseType

        Dim oAddressBusiness As bPMAddressControl.Business

        Try
            'This variable is used to get the result and it says that whether the method is executed without error or not
            Dim lComReturnValue As Integer = 0
            Dim oResultSet As Object = Nothing
            Dim oResultSetPickList As Object = Nothing
            Dim lPMAddressCnt As Integer = 0

            oAddressBusiness = New bPMAddressControl.Business

            'This portion will call the com method to initialize
            lComReturnValue = CInt(oAddressBusiness.Initialise(
                                  _SiriusUser.Username,
                                  _SiriusUser.Password,
                                  _SiriusUser.UserID,
                                  _SiriusUser.SourceID,
                                  _SiriusUser.LanguageID,
                                  _SiriusUser.CurrencyID,
                                  1,
                                  SiriusUserDefaults.AppName))

            'This com function will fetch the Case detials
            'Get the Address from the business object
            lComReturnValue = CInt(oAddressBusiness.FindAddress(r_vAddressArray:=oResultSet,
                                r_vPickList:=oResultSetPickList,
                                r_sPostCode:=oRequest.PostCode,
                                r_sAddressLine1:=oRequest.AddressLine1,
                                r_sAddressLine2:=oRequest.AddressLine2,
                                r_sAddressLine3:=oRequest.AddressLine3,
                                r_sAddressLine4:=oRequest.AddressLine4,
                                r_lPMAddressCnt:=lPMAddressCnt,
                                r_iCountryId:=Convert.ToInt16(oRequest.CountryCodeID)))


            If (lComReturnValue <> PMReturnCode.PMTrue) Then
                RaiseComMethodException("obAddressBusiness.FindAddress",
                lComReturnValue)
            End If

            Dim dsAddressDetails As New DataSet
            Dim dsResultAddressDetails As New DataSet

            If (oResultSet IsNot Nothing) AndAlso TypeOf (oResultSet) Is System.Array Then
                'Convert the object into the DataSet
                dsAddressDetails = Utilities.ArrayToDataSet(oResultSet)

                If dsAddressDetails.Tables.Count >= 1 Then
                    If (dsAddressDetails.Tables(0).Rows.Count >= 1) Then
                        dsResultAddressDetails.Tables.Add()

                        dsResultAddressDetails.Tables(0).Columns.Add("AddressLine1", GetType(System.String))
                        dsResultAddressDetails.Tables(0).Columns.Add("AddressLine2", GetType(System.String))
                        dsResultAddressDetails.Tables(0).Columns.Add("AddressLine3", GetType(System.String))
                        dsResultAddressDetails.Tables(0).Columns.Add("AddressLine4", GetType(System.String))
                        dsResultAddressDetails.Tables(0).Columns.Add("CountryCode", GetType(System.String))
                        dsResultAddressDetails.Tables(0).Columns.Add("PostCode", GetType(System.String))
                    End If
                End If

                Dim iCount As Integer = 0
                For iCount = 0 To dsAddressDetails.Tables(0).Columns.Count - 1
                    'Data are extracted from the DataSet and put it into corresponding objects
                    With dsAddressDetails.Tables(0).Columns(iCount)
                        'Note:Ideally we should fetch the data using column names 
                        'but as we havenot got the column names we are using the column index.
                        dsResultAddressDetails.Tables(0).Rows.Add()
                        dsResultAddressDetails.Tables(0).Rows(iCount)("AddressLine1") = dsAddressDetails.Tables(0).Rows(0)(iCount).ToString()
                        dsResultAddressDetails.Tables(0).Rows(iCount)("AddressLine2") = dsAddressDetails.Tables(0).Rows(1)(iCount).ToString()
                        dsResultAddressDetails.Tables(0).Rows(iCount)("AddressLine3") = dsAddressDetails.Tables(0).Rows(2)(iCount).ToString()
                        dsResultAddressDetails.Tables(0).Rows(iCount)("AddressLine4") = dsAddressDetails.Tables(0).Rows(3)(iCount).ToString()
                        dsResultAddressDetails.Tables(0).Rows(iCount)("PostCode") = dsAddressDetails.Tables(0).Rows(4)(iCount).ToString()
                        dsResultAddressDetails.Tables(0).Rows(iCount)("CountryCode") = dsAddressDetails.Tables(0).Rows(5)(iCount).ToString()

                    End With
                Next

                Dim xmlDoc As New System.Xml.XmlDocument
                dsResultAddressDetails.DataSetName = "BaseFindAddressResponseTypeAddressLookup"
                dsResultAddressDetails.Tables(0).TableName = "FindAddress"

                If oRequest.WCFSecurityToken = "" Then
                    xmlDoc.LoadXml(dsResultAddressDetails.GetXml)
                    If (dsAddressDetails.Tables.Count >= 1) Then
                        oResponse.ResultDataset = xmlDoc.DocumentElement()
                    End If
                End If

                If (dsAddressDetails.Tables.Count >= 1) Then
                    oResponse.ResultData = dsResultAddressDetails
                End If
            End If
        Catch ex As Exception
            Throw

        Finally
            If oAddressBusiness IsNot Nothing Then
                oAddressBusiness.Dispose()
                oAddressBusiness = Nothing
            End If
        End Try

        Return oResponse

    End Function
