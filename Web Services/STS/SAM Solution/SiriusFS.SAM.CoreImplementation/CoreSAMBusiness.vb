        End If
        If oUpdateWmTaskRequest.TaskStatusKey < 0 And oUpdateWmTaskRequest.TaskStatusKey > 4 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "TaskStatus")
        End If
        oSAMErrorCollection.CheckForErrors()

        ' Check that the timestamp matches and lock the task instance
        Dim AnyError As STSErrorType
        AnyError = oCorebusiness.CheckTSAndLock(con,
            BranchCode:=oUpdateWmTaskRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.TaskInstanceCnt,
            LockValue:=oUpdateWmTaskRequest.TaskInstanceKey,
            TStamp:=oUpdateWmTaskRequest.TaskTimeStamp)
        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
