                                                As BaseUpdateFeeResponseType


        Dim oUpdateFeeResponse As New BaseUpdateFeeResponseType
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage
        If oUpdateFeeRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateFeeRequestType) Then

            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateFeeResponse = New SAMForInsuranceV2ImplementationTypes.UpdateFeeResponseType

