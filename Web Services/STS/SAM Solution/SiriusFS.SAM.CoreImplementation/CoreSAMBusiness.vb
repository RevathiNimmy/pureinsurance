    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function GetBilledPremiumForRisk(ByVal con As SiriusConnection, ByVal nRiskCnt As Integer) As Decimal

        Dim dt As DataTable = Nothing
        Dim dBilledPremium As Decimal
        ' get the account details for the specified party
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Risks_Billed_Premium")
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = nRiskCnt
