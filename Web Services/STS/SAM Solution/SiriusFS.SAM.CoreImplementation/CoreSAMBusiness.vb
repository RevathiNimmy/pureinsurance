#Region "Private Method - ProcessRiskIndexBaseCaseDetails"
    ''' <summary>
    '''This function will get the case list from COM funciton "FindCase" if the index is empty
    '''</summary>
    '''<param name="oRequest" type="BaseFindCaseRequestType"></param>    
    '''<param name="oResponse" type="BaseFindCaseResponseType"></param>   
    '''<param name="obCLMCaseBusiness" type="bCLMCase.Business"></param> 
    '''<param name="oBackOfficeLinkBusiness" type="bCLMCase.Business"></param> 
    '''<remarks></remarks>
    Private Function ProcessRiskIndexBaseCaseDetails(ByVal oBackOfficeLinkBusiness As bBackOfficeLink.bBOLink,
    ByVal obCLMCaseBusiness As bCLMCase.Business,
    ByRef oRequest As BaseFindCaseRequestType,
    ByRef oResponse As BaseFindCaseResponseType) As BaseFindCaseResponseType

        Try
            Dim oSAMErrorCollection As New SAMErrorCollection
            'Declare the variable to make sure the initialization 
            Dim lReturn As Integer
            Dim sSQL As String = String.Empty

            'Create the object to get the output of the com function "FindLikeIndex" and it will be used as a 
            Dim oGISSearchDataArray(,) As Object = Nothing
            Dim oResultSet As Object = Nothing
            'This variable is used to get the result and it says that whether the method is executed without error or not
            Dim lComReturnValue As Integer

            'This object is used to stored the Case details.
            Dim oCaseData As Object(,) = Nothing

            oResponse.ResultDataset = Nothing

            'This portion will call the com method to initialize
            lReturn = CInt(oBackOfficeLinkBusiness.Initialise(
                                  _SiriusUser.Username,
                                  _SiriusUser.Password,
                                  _SiriusUser.UserID,
                                  _SiriusUser.SourceID,
                                  _SiriusUser.LanguageID,
                                  _SiriusUser.CurrencyID,
                                  1,
                                  SiriusUserDefaults.AppName))

            'This funciton is used to  collect the details related to the RiskIndex
            With oRequest
                lComReturnValue = oBackOfficeLinkBusiness.FindLikeIndex(sIndex:= .RiskIndex,
                        lNumberOfRecords:=500, vResultArray:=oGISSearchDataArray, sDataModelType:="CASE")
            End With

            'If the above function(FindLikeIndex) is not executed properly then  the exeception 
            'will be raised as follows
            If (lComReturnValue <> PMReturnCode.PMTrue) Then
                RaiseComMethodException("oBackOfficeLinkBusiness.FindLikeIndex", lComReturnValue)
            End If

            'This com function will fetch the case detials

            lComReturnValue = obCLMCaseBusiness.GetPolicyCase(CType(oGISSearchDataArray, Object(,)),
            oCaseData, oBackOfficeLinkBusiness.Sirius_Product, oRequest.ClaimNumber,
            v_vRegNumber:=oRequest.RiskIndex)

            'If the above function(GetPolicyCase) is not executed properly then  
            'the exeception will be raised as follows
            If (lComReturnValue <> PMReturnCode.PMTrue) AndAlso (lComReturnValue <> PMReturnCode.PMNotFound) Then
                RaiseComMethodException("obCLMCaseBusiness.GetPolicyCase", lComReturnValue)
            End If
            Dim iCounter1 As Integer = 0
            Dim iNumClaims As Integer = 0
            If oCaseData IsNot Nothing AndAlso (TypeOf (oCaseData) Is System.Array) Then
                Dim vSearchData As Object(,)
                Dim vCaseData As Object(,)
                vCaseData = CType(oCaseData, Object(,))
                For iCounter1 = Microsoft.VisualBasic.LBound(vCaseData, 2) To Microsoft.VisualBasic.UBound(vCaseData, 2)

                    lComReturnValue = obCLMCaseBusiness.GenerateSQL(v_sClaimNumber:=Cast.ToString(vCaseData(3, iCounter1), String.Empty),
                                v_sCaseNumber:="",
                                v_lRiskTypeID:=0,
                                v_lProgressStatusID:=0,
                                v_vCaseOpenDate:="",
                                r_sSQL:=sSQL)

                    ' Get the Case details from the business object.
                    Dim oResultSet1(,) As Object = CType(oResultSet, Object(,))
                    lComReturnValue = obCLMCaseBusiness.FindCase(v_sSQL:=sSQL,
                                            r_vResultArray:=oResultSet1, v_lNumberRecords:=oRequest.MaxRowsToFetch)
                    oResultSet = CType(oResultSet1, Object)
                    If TypeOf (oResultSet) Is System.Array Then
                        If oResultSet IsNot Nothing Then
                            Dim vResultData As Object(,)
                            Dim iFromRow As Integer = 0
                            Dim iMaxRow As Integer = 0
                            Dim iCounter2 As Integer = 0
                            Dim iCounter3 As Integer = 0
                            vResultData = CType(oResultSet, Object(,))
                            ' Get the no of fields selected
                            iNumClaims = Microsoft.VisualBasic.UBound(vResultData, 1)

                            If IsArray(vSearchData) = False Then
                                vSearchData = vResultData
                            Else
                                ' We alreay have some data and we have to merge it with new data
                                iFromRow = Microsoft.VisualBasic.UBound(vSearchData, 2)
                                iMaxRow = Microsoft.VisualBasic.UBound(vSearchData, 2) + Microsoft.VisualBasic.UBound(vResultData, 2) + 1
                                ReDim Preserve vSearchData(iNumClaims, iMaxRow)

                                For iCounter2 = Microsoft.VisualBasic.LBound(vResultData, 2) To Microsoft.VisualBasic.UBound(vResultData, 2)
                                    iFromRow = iFromRow + 1
                                    For iCounter3 = 0 To iNumClaims
                                        vSearchData(iCounter3, iFromRow) = vResultData(iCounter3, iCounter2)
                                    Next iCounter3
                                Next iCounter2
                            End If
                        End If
                    End If
                Next iCounter1
                oResultSet = CObj(vSearchData)
            End If

            If (lComReturnValue = PMReturnCode.PMNotFound) Then
                Return oResponse
            ElseIf (lComReturnValue <> PMReturnCode.PMTrue) Then
                RaiseComMethodException("obCLMCaseBusiness.FindCase", lComReturnValue)
            End If

            Dim dsCaseDetails As New DataSet
            Dim dsResultCaseDetails As New DataSet
            If (oResultSet IsNot Nothing) AndAlso TypeOf (oResultSet) Is System.Array Then
                'Convert the object into the DataSet
                dsCaseDetails = Utilities.ArrayToDataSet(oResultSet)

                If dsCaseDetails.Tables.Count >= 1 Then
                    If (dsCaseDetails.Tables(0).Rows.Count >= 1) Then
                        dsResultCaseDetails.Tables.Add()
                        dsResultCaseDetails.Tables(0).Columns.Add("CaseKey", GetType(System.Int32))
                        dsResultCaseDetails.Tables(0).Columns.Add("CaseNumber", GetType(System.String))
                        dsResultCaseDetails.Tables(0).Columns.Add("CaseOpenDate", GetType(System.DateTime))
                        dsResultCaseDetails.Tables(0).Columns.Add("Analyst", GetType(System.String))
                        dsResultCaseDetails.Tables(0).Columns.Add("Assistant", GetType(System.String))
                        dsResultCaseDetails.Tables(0).Columns.Add("CaseProgressDescription", GetType(System.String))
                        dsResultCaseDetails.Tables(0).Columns.Add("TotalIndemnity", GetType(System.Decimal))
                        dsResultCaseDetails.Tables(0).Columns.Add("TotalExpense", GetType(System.Decimal))
                        dsResultCaseDetails.Tables(0).Columns.Add("TotalExcess", GetType(System.Decimal))
                        dsResultCaseDetails.Tables(0).Columns.Add("BaseCaseKey", GetType(System.Int32))
                        dsResultCaseDetails.Tables(0).Columns.Add("CurrencyCode", GetType(System.String))

                        Dim iCount As Integer = 0
                        For iCount = 0 To dsCaseDetails.Tables(0).Rows.Count - 1
                            'Data are extracted from the DataSet and put it into corresponding objects
                            With dsCaseDetails.Tables(0).Rows(iCount)
                                'Note:Ideally we should fetch the data using column names 
                                'but as we havenot got the column names we are using the column index.
                                dsResultCaseDetails.Tables(0).Rows.Add()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("CaseKey") = CInt(dsCaseDetails.Tables(0).Rows(iCount)(0))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("CaseNumber") = dsCaseDetails.Tables(0).Rows(iCount)(1).ToString()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("Analyst") = dsCaseDetails.Tables(0).Rows(iCount)(3).ToString()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("Assistant") = dsCaseDetails.Tables(0).Rows(iCount)(4).ToString()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("CaseProgressDescription") = dsCaseDetails.Tables(0).Rows(iCount)(5).ToString()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("TotalIndemnity") = CDbl(dsCaseDetails.Tables(0).Rows(iCount)(6))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("TotalExpense") = CDbl(dsCaseDetails.Tables(0).Rows(iCount)(7))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("TotalExcess") = CDbl(dsCaseDetails.Tables(0).Rows(iCount)(8))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("BaseCaseKey") = CInt(dsCaseDetails.Tables(0).Rows(iCount)(9))
                                If (CDate(dsCaseDetails.Tables(0).Rows(iCount)(2)) > Date.MinValue) Then
                                    dsResultCaseDetails.Tables(0).Rows(iCount)("CaseOpenDate") = CDate(.Item(2))
                                End If
                                If CInt(dsCaseDetails.Tables(0).Rows(iCount)(9)) > 0 Then
                                    dsResultCaseDetails.Tables(0).Rows(iCount)("CurrencyCode") = Convert.ToString(GetCurrencyCodeForCase(CInt(dsCaseDetails.Tables(0).Rows(iCount)(9))))
                                Else
                                    dsResultCaseDetails.Tables(0).Rows(iCount)("CurrencyCode") = String.Empty
                                End If
                            End With
                        Next
                    End If

                    Dim xmlDoc As New System.Xml.XmlDocument
                    dsResultCaseDetails.DataSetName = "BaseFindCaseResponseTypeCaseDetails"
                    dsResultCaseDetails.Tables(0).TableName = "Row"

                    If (dsCaseDetails.Tables.Count >= 1) Then
                        If oRequest.WCFSecurityToken = "" Then
                            xmlDoc.LoadXml(dsResultCaseDetails.GetXml)
                            oResponse.ResultDataset = xmlDoc.DocumentElement()
                        End If
                        oResponse.ResultData = dsResultCaseDetails
                    Else
                        oResponse.ResultDataset = Nothing
                        oResponse.ResultData = Nothing
                    End If
                End If
            End If
        Catch ex As Exception
            Throw

        Finally
            If obCLMCaseBusiness IsNot Nothing Then
                obCLMCaseBusiness.Dispose()
                obCLMCaseBusiness = Nothing
            End If
            If oBackOfficeLinkBusiness IsNot Nothing Then
                oBackOfficeLinkBusiness.Dispose()
                oBackOfficeLinkBusiness = Nothing
            End If
        End Try

        Return oResponse
    End Function
    'End (Sandeep Kumar)-(Tech Spec-WPR28 FindCase)
#End Region
