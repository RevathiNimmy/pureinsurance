    Public Overloads Function GetEventNoteType(ByVal con As SiriusConnection, ByVal oGetEventNoteTypeRequest As BaseGetEventNoteTypeRequestType) As BaseGetEventNoteTypeResponseType
        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oCoreBusiness As New CoreBusiness
        Dim oResponse As BaseImplementationTypes.BaseGetEventNoteTypeResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oEvent As New bSIREvent.Business
        Dim iComReturnValue As Integer
        Dim vResultArray As Object(,)
        Dim iDefault As Short
        Dim oArrColHeaders(,) As Object = {{"EventTypeKey",
                                                          "EventTypeCode",
                                                          "EventTypeDescription"},
                                                          {System.Type.GetType("System.Int32"),
                                                          System.Type.GetType("System.String"),
                                                          System.Type.GetType("System.String")}}

        ' determine the type of package and thus the type of response
        If oGetEventNoteTypeRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetEventNoteTypeRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetEventNoteTypeResponseType
        Else
            oResponse = New BaseImplementationTypes.BaseGetEventNoteTypeResponseType
        End If

        '*********************
        ' STRUCTURE VALIDATION 
        '*********************

        ' validate the mandatory structure data
        oGetEventNoteTypeRequest.Validate(CType(oSAMErrorCollection, Object))

        ' if there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()
        Try
            oEvent = New bSIREvent.Business
            InitialiseSBOObject(con, oEvent, _SiriusUser, "bSIREvent.Business")

            iComReturnValue = oEvent.GetNoteEventType(r_vNoteEventTypeArray:=vResultArray,
                                                    r_iListIndex:=CShort(iDefault),
                                                    v_vInsuranceFileCnt:=CByte(oGetEventNoteTypeRequest.InsuranceFileKey),
                                                    v_vClaimCnt:=CByte(oGetEventNoteTypeRequest.ClaimKey),
                                                    v_vAccountKey:=CByte(oGetEventNoteTypeRequest.AccountKey),
                                                    v_vCaseID:=CByte(oGetEventNoteTypeRequest.CaseKey))

            If iComReturnValue <> PMEReturnCode.PMTrue _
                            AndAlso iComReturnValue <> PMEReturnCode.PMNotFound Then ' missing in tech spec
                RaiseComMethodException("bSIREvent.Business.GetNoteEventType", iComReturnValue)
            End If

            Dim oXMLDoc As New System.Xml.XmlDocument
