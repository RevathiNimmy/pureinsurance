    ''' <summary>  
    ''' Updates Selected Risk
    ''' </summary>  
    ''' <param name="BaseUpdateRiskSelectionRequestType">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseUpdateRiskSelectionRequestType</param>  
    Public Overloads Function UpdateRiskSelection(ByVal con As SiriusConnection,
                                            ByVal oUpdateRiskSelectionRequest As BaseUpdateRiskSelectionRequestType) _
                                            As BaseUpdateRiskSelectionResponseType

        '' The Transaction part was not mentioned in the tech spec and we have used SamErrorCollection instead of STSError as told by Rahul and Gaurav.
        ''These are deviation from the Tech Spec.
        Dim oUpdateRiskSelectionResponse As New BaseUpdateRiskSelectionResponseType
        Dim oErrors As New SAMErrorCollection
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)

        ''Deviation from the tech spec
        Dim nTypeOfPackage As enumTypeOfPackage
        If oUpdateRiskSelectionRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateRiskSelectionRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateRiskSelectionResponse = New SAMForInsuranceV2ImplementationTypes.UpdateRiskSelectionResponseType
        End If

        ''Request structure validation
        oUpdateRiskSelectionRequest.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        ' Check that the timestamp matches and lock the Quote
        Try

            con.BeginTransaction()
            Dim oAnyError As STSErrorType
            oAnyError = oCoreBusiness.CheckTSAndLock(
                BranchCode:=oUpdateRiskSelectionRequest.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=oUpdateRiskSelectionRequest.InsuranceFolderKey,
                TStamp:=oUpdateRiskSelectionRequest.TimeStamp)

            ' Check for Errors
            If oAnyError Is Nothing = False Then
                ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
                oUpdateRiskSelectionResponse.STSError = oAnyError
                Return oUpdateRiskSelectionResponse
            End If

            'call the stored procedure spu_SIR_Risk_Selection_Status_Update.
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Risk_Selection_Status_Update")
                cmd.Parameters.Clear()
                cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = oUpdateRiskSelectionRequest.RiskKey
                cmd.AddInParameter("@is_risk_selected", SqlDbType.Int).Value = Cast.NullIfDefault(oUpdateRiskSelectionRequest.IsSelected)
                con.ExecuteNonQuery(cmd)
            End Using


            Dim oGIS As bGIS.Application = Nothing
            Dim iRet As Integer

            Try
                oGIS = New bGIS.Application

                Dim oDatabase As dPMDAO.Database = Nothing
                Dim oDatabaseObject As Object = oDatabase

                InitialiseSBOObject(con, oGIS, _SiriusUser, "bGIS.Application")
                iRet = oGIS.SetProcessModes(SAMComponentAction.PMEdit, 0, 0, Cast.ToObjString(oUpdateRiskSelectionRequest.TransactionType), Now)

                iRet = oGIS.Recalculate(v_lInsuranceFileCnt:=oUpdateRiskSelectionRequest.InsuranceFileKey,
                                v_lRiskCnt:=oUpdateRiskSelectionRequest.RiskKey, sTransactionType:=oUpdateRiskSelectionRequest.TransactionType,
                                v_lInsuranceFolderCnt:=oUpdateRiskSelectionRequest.InsuranceFolderKey, v_bViaSAM:=True)

                If (iRet <> PMReturnCode.PMTrue) Then
                    RaiseComMethodException("oGIS.Recalculate", iRet)
                End If

                If oGIS IsNot Nothing Then
                    oGIS.Dispose()
                    oGIS = Nothing
                End If
            Catch ex As Exception

                oErrors.AddFatal(ex)

            End Try

            If oUpdateRiskSelectionRequest.RiskKey > 0 And oUpdateRiskSelectionRequest.InsuranceFileKey > 0 Then
                Dim sRiskDescription As String = String.Empty
                Dim nVariationNumber As Int32 = 0
                Dim nRiskCnt As Int32 = 0
                Dim dsResult As DataSet = Nothing
                Dim nCommandReturn As Int32
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Mandatory_Risk")
                    cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = oUpdateRiskSelectionRequest.RiskKey
                    cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oUpdateRiskSelectionRequest.InsuranceFileKey
                    dsResult = con.ExecuteDataSet(cmd, "GetMandatoryRisk")
                End Using
                If dsResult IsNot Nothing Then
                    If dsResult.Tables.Count > 0 Then
                        If dsResult.Tables(0).Rows.Count > 0 Then
                            nRiskCnt = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("risk_cnt"), 0)
                            sRiskDescription = Cast.ToString(dsResult.Tables(0).Rows(0).Item("description"), "")
                            nVariationNumber = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("variation_number"), 0)
                        End If
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Mandatory_Risk_Details")
                            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = nRiskCnt
                            cmd.AddInParameter("@risk_status_id", SqlDbType.Int).Value = 4 ' For Status to Unquote Risk
                            cmd.AddInParameter("@description", SqlDbType.Text).Value = sRiskDescription
                            cmd.AddInParameter("@variation_number", SqlDbType.Int).Value = nVariationNumber
                            nCommandReturn = con.ExecuteNonQuery(cmd)
                        End Using
                    End If
                End If

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Unquote_Risk_Forard")
                    cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = oUpdateRiskSelectionRequest.RiskKey
                    nCommandReturn = con.ExecuteNonQuery(cmd)
                End Using
            End If
            'end

            'Populate the response with any error code, as well as the used timestamp for locking
            oAnyError = oCoreBusiness.UnlockAndGetTS(
                              BranchCode:=oUpdateRiskSelectionRequest.BranchCode,
                              Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                              LockValue:=oUpdateRiskSelectionRequest.InsuranceFolderKey,
                              TStamp:=oUpdateRiskSelectionResponse.TimeStamp)

            ' Check for Errors
            If oAnyError Is Nothing = False Then
                ' Unable to unlock, return the error.
                oUpdateRiskSelectionResponse.STSError = oAnyError
                con.RollbackTransaction()
                Return oUpdateRiskSelectionResponse
            End If
            oErrors.CheckForErrors()
            con.CommitTransaction()
            Return oUpdateRiskSelectionResponse
        Catch
            con.RollbackTransaction()
            Return oUpdateRiskSelectionResponse
        End Try
    End Function

