    '''<summary>
    ''' This method is used to  Calculate Tax for Claims
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>   
    '''<param name="oCalculateTaxForClaimsRequestType" type="BaseCalculateTaxForClaimsRequestType"></param>   
    '''<returns>BaseCalculateTaxForClaimsResponseType</returns>
    '''<remarks>
    Public Overloads Function CalculateTaxforClaims(ByVal con As SiriusConnection, ByVal oCalculateTaxForClaimsRequestType As BaseCalculateTaxForClaimsRequestType) As BaseCalculateTaxForClaimsResponseType

        Dim oCalculateTaxForClaimsResponseType As New BaseCalculateTaxForClaimsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim dsTransTypeCode As DataSet = Nothing
        Dim sTransTypeCode As String = ""
        sTransTypeCode = oCalculateTaxForClaimsRequestType.TransactionTypeCode
        If sTransTypeCode = TransactionTypeCode.SalvageRecovery Then
            sTransTypeCode = kTaxTransTypeClaimSalvageReceipt
        ElseIf sTransTypeCode = TransactionTypeCode.ThirdPartyRecovery Then
            sTransTypeCode = kTaxTransTypeClaimThirdPartyRecoveryReceipt
        Else
            sTransTypeCode = "TTCP"
        End If

        'Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oCalculateTaxForClaimsRequestType.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.CalculateTaxForClaimsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oCalculateTaxForClaimsResponseType = New SAMForInsuranceV2ImplementationTypes.CalculateTaxForClaimsResponseType
        End If

        'Mandatory validations
        oCalculateTaxForClaimsRequestType.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        CalculateTaxForClaimsValidateDataStandardLookup(oCoreBusiness, oCalculateTaxForClaimsRequestType, oErrors)
        oErrors.CheckForErrors()

        Dim advancedTaxScript As String
        GetAdvancedTaxScript(con:=con, taxGroupId:=Cast.ToInt32(oCalculateTaxForClaimsRequestType.TaxGroupKey, 0), advancedTaxScript:=advancedTaxScript)

        If oCalculateTaxForClaimsRequestType.AdvancedTaxDetails IsNot Nothing AndAlso oCalculateTaxForClaimsRequestType.AdvancedTaxDetails.AdvancedTaxScriptOptionOn AndAlso Not String.IsNullOrEmpty(advancedTaxScript) Then

            '' If ATS is on
            Dim r_dLossTaxAmount As Decimal
            Dim r_dBaseTaxAmount As Decimal
            Dim r_dCurrencyTaxAmount As Decimal

            CalculateTax(con, oCalculateTaxForClaimsRequestType, r_dCurrencyTaxAmount, r_dLossTaxAmount, r_dBaseTaxAmount, oCalculateTaxForClaimsResponseType, oErrors)

            oErrors.CheckForErrors()
            oCalculateTaxForClaimsResponseType.TaxCurrencyAmount = Convert.ToDouble(r_dCurrencyTaxAmount)
            oCalculateTaxForClaimsResponseType.TaxLossAmount = Convert.ToDouble(r_dLossTaxAmount)
            oCalculateTaxForClaimsResponseType.TaxBaseAmount = Convert.ToDouble(r_dBaseTaxAmount)


        ElseIf oCalculateTaxForClaimsRequestType.ReceiptAdvancedTaxDetails IsNot Nothing AndAlso Not String.IsNullOrEmpty(advancedTaxScript) Then 'AndAlso oCalculateTaxForClaimsRequestType.ReceiptAdvancedTaxDetails.AdvancedTaxScriptOptionOn Then

            Dim r_dLossTaxAmount As Decimal
            Dim r_dBaseTaxAmount As Decimal
            Dim r_dCurrencyTaxAmount As Decimal

            CalculateReceiptTax(con, oCalculateTaxForClaimsRequestType, r_dCurrencyTaxAmount, r_dLossTaxAmount, r_dBaseTaxAmount, oErrors, oCalculateTaxForClaimsResponseType)
            oCalculateTaxForClaimsResponseType.TaxCurrencyAmount = Convert.ToDouble(r_dCurrencyTaxAmount)
            oCalculateTaxForClaimsResponseType.TaxLossAmount = Convert.ToDouble(r_dLossTaxAmount)
            oCalculateTaxForClaimsResponseType.TaxBaseAmount = Convert.ToDouble(r_dBaseTaxAmount)

        Else
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Calculate_tax_Amounts")
                cmd.AddInParameter("@company_id", SqlDbType.Int).Value = oCalculateTaxForClaimsRequestType.CompanyKey
                cmd.AddInParameter("@tax_group_id", SqlDbType.Int).Value = oCalculateTaxForClaimsRequestType.TaxGroupKey
                cmd.AddInParameter("@transtype", SqlDbType.VarChar, 20).Value = sTransTypeCode
                cmd.AddInParameter("@currency_id", SqlDbType.Int).Value = oCalculateTaxForClaimsRequestType.CurrencyKey
                cmd.AddInParameter("@loss_currency_id", SqlDbType.Int).Value = oCalculateTaxForClaimsRequestType.LossCurrencyKey
                cmd.AddInParameter("@amount", SqlDbType.Money).Value = oCalculateTaxForClaimsRequestType.Amount
                cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oCalculateTaxForClaimsRequestType.PerilId
                If sTransTypeCode = kTaxTransTypeClaimSalvageReceipt OrElse sTransTypeCode = kTaxTransTypeClaimThirdPartyRecoveryReceipt Then
                    cmd.AddInParameter("@claim_receipt_id", SqlDbType.Int).Value = 1
                Else
                    cmd.AddInParameter("@claim_receipt_id", SqlDbType.Int).Value = 0
                End If
                cmd.AddInParameter("@claim_payment_item_id", SqlDbType.Int).Value = 1
                cmd.AddInParameter("@calculate_only", SqlDbType.TinyInt).Value = 1
                cmd.AddOutParameter("@tax_currency_amount", SqlDbType.Money)
                cmd.AddOutParameter("@tax_loss_amount", SqlDbType.Money)
                cmd.AddOutParameter("@tax_base_amount", SqlDbType.Money)
                con.ExecuteNonQuery(cmd)

                oCalculateTaxForClaimsResponseType.TaxBaseAmount = Math.Round(Cast.ToDouble(cmd.Parameters.Item("@tax_base_amount").Value, 0.0), 2)
                oCalculateTaxForClaimsResponseType.TaxCurrencyAmount = Math.Round(Cast.ToDouble(cmd.Parameters.Item("@tax_currency_amount").Value, 0.0), 2)
                oCalculateTaxForClaimsResponseType.TaxLossAmount = Math.Round(Cast.ToDouble(cmd.Parameters.Item("@tax_loss_amount").Value, 0.0), 2)
            End Using
        End If
        Return oCalculateTaxForClaimsResponseType
    End Function

    Private Sub CalculateTaxForClaimsValidateDataStandardLookup(
       ByVal oBusiness As CoreBusiness,
       ByRef oRequest As BaseCalculateTaxForClaimsRequestType,
       ByRef oSAMErrorCollection As SAMErrorCollection)

        If String.IsNullOrEmpty(oRequest.CompanyCode) = False Then
            oRequest.CompanyKey = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.CompanyCode, "Code", oSAMErrorCollection)
        End If
        If String.IsNullOrEmpty(oRequest.CurrencyCode) = False Then
            oRequest.CurrencyKey = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, oRequest.CurrencyCode, "Code", oSAMErrorCollection)
        End If
        If String.IsNullOrEmpty(oRequest.LossCurrencyCode) = False Then
            oRequest.LossCurrencyKey = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, oRequest.LossCurrencyCode, "Code", oSAMErrorCollection)
        End If
        If String.IsNullOrEmpty(oRequest.TaxGroupCode) = False Then
            oRequest.TaxGroupKey = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.TaxGroup, oRequest.TaxGroupCode, "Code", oSAMErrorCollection)
        End If
        If String.IsNullOrEmpty(oRequest.PaymentTo) = False Then
            If oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.ClaimPaymentTo, oRequest.PaymentTo, "Code", oSAMErrorCollection) < 1 Then
                '' Nothing to do
            End If
        End If
    End Sub

