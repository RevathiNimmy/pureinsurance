    ''' <summary>
    '''This private method will be an common method and it can be used to get the insurancefile details
    '''</summary>
    '''<param name="conGetPolicyBankGuarantee">An object of a class SiriusConnection</param>
    '''<param name="iInsuranceFileKey">An integer variable</param>
    '''<param name="iPolicyBranchId">An integer variable</param>
    '''<param name="iPolicyProductId">An string variable</param>
    '''<param name="iPartyKey">An integer variable</param>
    '''<param name="iLeadAgentKey">An integer variable</param>
    '''<param name="sLeadAgentTypeCode">An string variable</param>
    '''<param name="dtCoverFrom">An DateTime Variable </param>
    '''<remarks></remarks>    
    Private Function GetCompleteInsuranceFileDetails(ByVal conGetPolicyBankGuarantee As SiriusConnection,
    ByVal iInsuranceFileKey As Integer, ByRef iPolicyBranchId As Integer, ByRef iPolicyProductId As Integer,
    ByRef iBusinessTypeCode As String, ByRef iPartyKey As Integer, ByRef iLeadAgentKey As Integer,
    ByRef sLeadAgentTypeCode As String, ByRef dtCoverFrom As DateTime, ByRef iCurrencyId As Integer) As Boolean
        Dim dsResult As DataSet = Nothing
        Dim bFlag As Boolean = False
        Dim iInsurance_file_cnt As Integer
        Using cmdGetPolicyBankGuarantee As SiriusCommand = SiriusCommand.FromProcedure("spe_Insurance_File_sel")
            cmdGetPolicyBankGuarantee.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = iInsuranceFileKey
            dsResult = conGetPolicyBankGuarantee.ExecuteDataSet(cmdGetPolicyBankGuarantee, "policyBankGuarantee")
            If (dsResult.Tables(0).Rows.Count >= 1) Then
                dtCoverFrom = Cast.ToDateTime(dsResult.Tables(0).Rows(0).Item("cover_start_date"), Date.MinValue)
                iPartyKey = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("insured_cnt"), 0)
                iLeadAgentKey = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("lead_agent_cnt"), 0)
                iPolicyProductId = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("product_id"), 0)
                iInsurance_file_cnt = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("insurance_file_cnt"), 0)
                iPolicyBranchId = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("Source_id"), 0)
                sLeadAgentTypeCode = Cast.ToString(dsResult.Tables(0).Rows(0).Item("Party_agent_Type_code"), Nothing)
                iBusinessTypeCode = Cast.ToString(dsResult.Tables(0).Rows(0).Item("business_type_code"), Nothing)
                iCurrencyId = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("currency_id"), 0)
                If (iInsurance_file_cnt = iInsuranceFileKey) Then
                    bFlag = True
                End If
            End If
        End Using
        Return bFlag
    End Function

    ''' <summary>
    ''' This method is used to do the Data Validation
    '''</summary>
    '''<param name="oSAMErrorCollection">An object of a class SAMErrorCollection</param>
    '''<param name="oCoreBusiness">An object of  a CoreBusiness</param>
    '''<param name="conBankGuarantee">An object of  a SiriusConnection</param>
    '''<param name="oBankGuarantee">An object of a class BaseBankGuaranteeItemType</param>
    '''<remarks></remarks> 
    Private Sub ValidateDataBankGuaranteeItem(ByRef oSAMErrorCollection As SAMErrorCollection, ByVal oCoreBusiness As CoreBusiness, ByVal conBankGuarantee As SiriusConnection, ByVal oBankGuarantee As BaseBankGuaranteeItemType)

        oBankGuarantee.BankNameKey = GetAndValidateSpecifiedTableCode(conBankGuarantee,
        PMLookupTable.Bank, "Bank_id", "Bank_id", oBankGuarantee.BankNameKey.ToString(), oSAMErrorCollection, "BankNameKey")

        oBankGuarantee.BGCurrencyKey = GetAndValidateSpecifiedTableCode(conBankGuarantee,
        PMLookupTable.Currency, "Currency_id", "code", oBankGuarantee.BGCurrencyCode, oSAMErrorCollection, "BGCurrencyCode")

        oBankGuarantee.CustodyBranchKey = GetAndValidateSpecifiedTableCode(conBankGuarantee,
               PMLookupTable.Source, "Source_Id", "code", oBankGuarantee.CustodyBranchCode, oSAMErrorCollection, "CustodyBranchCode")

        oBankGuarantee.PartyKey = GetAndValidateSpecifiedTableCode(conBankGuarantee,
        PMLookupTable.Party, "party_cnt", "party_cnt", oBankGuarantee.PartyKey.ToString(), oSAMErrorCollection, "PartyKey")

        Dim Bg_id As Integer = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
              PMLookupTable.BG_Status, oBankGuarantee.BGStatusCode, "BGStatusCode", oSAMErrorCollection)

        For Each oBranch As BaseBankGuaranteeItemTypeBranches In oBankGuarantee.Branches
            oBranch.SourceKey = GetAndValidateSpecifiedTableCode(conBankGuarantee,
            PMLookupTable.Source, "Source_id", "code", oBranch.BranchCode, oSAMErrorCollection, "BranchCode")
        Next

        For Each oProduct As BaseBankGuaranteeItemTypeProducts In oBankGuarantee.Products
            oProduct.ProductKey = GetAndValidateSpecifiedTableCode(conBankGuarantee,
            PMLookupTable.Product, "Product_id", "code", oProduct.ProductCode, oSAMErrorCollection, "ProductCode")
        Next

    End Sub

