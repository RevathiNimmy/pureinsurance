        For Each drRowObject In dtResult.Rows
            sString = "//" & UCase(drRowObject.Item("OBJECT_NAME").ToString) & "/@" & UCase(drRowObject.Item("PROPERTY_NAME").ToString & "CODE")
            'there is a possibility, if the user has selected more than one instance of a child screen,
            'that there could be more than one copy of an element. Here, we'll traverse through
            'them and make sure we do the necessary on each & every one.
            xnlstNodelist = xDoc.SelectNodes(sString)
            Dim xnElement As XmlNode
            Dim lookupListType As Integer = 0
            lookupListType = CInt(drRowObject.Item("SPECIALS_TYPE"))
            For Each xnElement In xnlstNodelist
                If xnElement.InnerText.Trim <> "" Then
                    Dim sSql As String = String.Empty
                    Select Case lookupListType
                        Case 2 'STSListType.UserDefinedTable 'SGConstants.LookupListType.UDL
                            sSql = "SELECT " & drRowObject.Item("SPECIALS_TYPE_REFERENCE").ToString().Trim() & "_id FROM " & drRowObject.Item("SPECIALS_TYPE_REFERENCE").ToString & " WHERE code = " & xnElement.InnerText
                        Case 6 'SGConstants.LookupListType.UML
                            sSql = "SELECT gis_user_def_detail_id FROM gis_user_def_detail WHERE code = '" & xnElement.InnerText & "' AND gis_user_def_header_id = " & drRowObject.Item("SPECIALS_TYPE_REFERENCE").ToString().Trim()
                    End Select
                    Using cmdSiriusCommand As SiriusCommand = SiriusCommand.FromText(sSql)
                        Using conSiriusConnection As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

                            Dim dtResults As DataTable = conSiriusConnection.ExecuteDataTable(cmdSiriusCommand)

                            Dim xeSelectedElement As XmlElement
                            xeSelectedElement = CType(xnElement.SelectSingleNode(".."), XmlElement)

                            If dtResults.Rows.Count > 0 Then
                                Select Case lookupListType
                                    Case 2 'STSListType.UserDefinedTable 'SGConstants.LookupListType.UDL
                                        If dtResults.Rows(0).Item(drRowObject.Item("SPECIALS_TYPE_REFERENCE").ToString().Trim() & "_id") IsNot Nothing AndAlso dtResults.Rows(0).Item(drRowObject.Item("SPECIALS_TYPE_REFERENCE").ToString().Trim() & "_id").ToString.Trim <> "" Then
                                            xeSelectedElement.SetAttribute(Mid(xnElement.Name, 1, Len(xnElement.Name) - 4), dtResults.Rows(0).Item("gis_user_def_detail_id").ToString)
                                        End If
                                    Case 6 'SGConstants.LookupListType.UML
                                        If dtResults.Rows(0).Item("gis_user_def_detail_id") IsNot Nothing AndAlso dtResults.Rows(0).Item("gis_user_def_detail_id").ToString.Trim <> "" Then
                                            xeSelectedElement.SetAttribute(Mid(xnElement.Name, 1, Len(xnElement.Name) - 4), dtResults.Rows(0).Item("gis_user_def_detail_id").ToString)
                                        End If
                                End Select
                            End If
                        End Using
                    End Using
                End If
            Next
        Next

        r_sXmlDataset = xDoc.OuterXml

        Return True

    End Function

    ''' <summary>
    ''' this method will update the US = 1 for all nodes in xml to make ready for addrisk function to save xml in DB
    ''' </summary>
    ''' <param name="r_sXmlDataset"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function MakeXMLForAddRisk(ByRef r_sXmlDataset As String) As Boolean
        Dim xdoc As New XmlDocument
        xdoc.LoadXml(r_sXmlDataset)
        Dim xnlstNodes As XmlNodeList
        xnlstNodes = xdoc.SelectNodes("//node()[@US]")
        For Each xnNode As XmlNode In xnlstNodes
            If xnNode.Attributes("US") IsNot Nothing Then
                xnNode.Attributes("US").Value = "1"
            End If
        Next
        r_sXmlDataset = xdoc.OuterXml
        Return True
    End Function

#Region "FindPolicyTransactionGrouped"
    ''' <summary>
    '''This method sends the request to the function 
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="FindPolicyTransactionGroupedRequest" type="BaseFindPolicyTransactionGroupedRequestType"></param>
    '''<remarks></remarks>
    Public Function FindPolicyTransactionGrouped(ByVal FindPolicyTransactionGroupedRequest As BaseFindPolicyTransactionGroupedRequestType) _
                                                                 As BaseFindPolicyTransactionGroupedResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseFindPolicyTransactionGroupedResponseType
        Dim sDisableWildcardSearchOption As String = String.Empty
        Dim sEnablePartialWildcardSearchOption As String = String.Empty
        Dim bDisableWildcardSearchOption As Boolean = False
        Dim bEnablePartialWildcardSearchOption As Boolean = False
        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection

        ' Checking the Type of package we are receiving in form of request
        Dim nTypeOfPackage As CoreSAMBusiness.enumTypeOfPackage
        If FindPolicyTransactionGroupedRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindPolicyTransactionGroupedRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.FindPolicyTransactionGroupedResponseType
        End If

        oBusiness.GetSystemOption(FindPolicyTransactionGroupedRequest.BranchCode, SystemOption.DisableWildcardSearch, sDisableWildcardSearchOption)

        oBusiness.GetSystemOption(FindPolicyTransactionGroupedRequest.BranchCode, SystemOption.EnablePartialWildcardSearch, sEnablePartialWildcardSearchOption)

        If (Trim(sDisableWildcardSearchOption) = "1") Then
            bDisableWildcardSearchOption = True
        Else
            bDisableWildcardSearchOption = False
        End If

        If (Trim(sEnablePartialWildcardSearchOption) = "1") Then
            bEnablePartialWildcardSearchOption = True
        Else
            bEnablePartialWildcardSearchOption = False
        End If

        If Not oBusiness.ValidWildcardSearch(
          bDisableWildcardSearchOption,
          bEnablePartialWildcardSearchOption,
          FindPolicyTransactionGroupedRequest.PolicyReference) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     SAMInvalidData.InvalidWildcardSearch.ToString,
                                     "PolicyReference")
        End If
        oSAMErrorCollection.CheckForErrors()

        If Not oBusiness.ValidWildcardSearch(
        bDisableWildcardSearchOption,
        bEnablePartialWildcardSearchOption,
        FindPolicyTransactionGroupedRequest.ClientCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     SAMInvalidData.InvalidWildcardSearch.ToString,
                                     "ClientCode")
        End If

        oSAMErrorCollection.CheckForErrors()

        If Not oBusiness.ValidWildcardSearch(
          bDisableWildcardSearchOption,
          bEnablePartialWildcardSearchOption,
          FindPolicyTransactionGroupedRequest.AgentCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     SAMInvalidData.InvalidWildcardSearch.ToString,
                                     "AgentCode")
        End If
        oSAMErrorCollection.CheckForErrors()

        Dim iSourceId As Integer = 0
        Try
            iSourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, FindPolicyTransactionGroupedRequest.BranchCode, "BranchCode")
        Catch ex As Exception
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                    SAMInvalidData.InvalidLookupListValue.ToString,
                                    "BranchCode",
                                    FindPolicyTransactionGroupedRequest.BranchCode)
        End Try

        If FindPolicyTransactionGroupedRequest.EffectiveFromDateSpecified And FindPolicyTransactionGroupedRequest.EffectiveToDateSpecified Then
            If FindPolicyTransactionGroupedRequest.EffectiveFromDate > FindPolicyTransactionGroupedRequest.EffectiveToDate Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                        SAMInvalidData.ValidationRulesFailed.ToString,
                                          "EffectiveFromDate",
                                          "EffectiveFromDate (" & FindPolicyTransactionGroupedRequest.EffectiveFromDate & ") should be <= EffectiveToDate  (" & FindPolicyTransactionGroupedRequest.EffectiveToDate & ")")
            End If
        End If

        Dim dsPolicies As DataSet = Nothing
        Dim oPolicies As New BaseFindPolicyTransactionGroupedResponseTypePolicies
        Dim dsPoliciesFees As DataSet = Nothing

        Using conPolicies As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_FindPolicyTransactionGroupedPolicies")

                cmd.AddInParameter("@SourceID", SqlDbType.Int).Value = iSourceId
                If FindPolicyTransactionGroupedRequest.AgentCodeSpecified Then
                    cmd.AddInParameter("@AgentCode", SqlDbType.VarChar, 30).Value = FindPolicyTransactionGroupedRequest.AgentCode
                Else
                    cmd.AddInParameter("@AgentCode", SqlDbType.VarChar, 30).Value = SqlString.Null
                End If
                If FindPolicyTransactionGroupedRequest.ClientCodeSpecified Then
                    cmd.AddInParameter("@ClientCode", SqlDbType.VarChar, 30).Value = FindPolicyTransactionGroupedRequest.ClientCode
                Else
                    cmd.AddInParameter("@ClientCode", SqlDbType.VarChar, 30).Value = SqlString.Null
                End If
                If FindPolicyTransactionGroupedRequest.DueDateSpecified Then
                    cmd.AddInParameter("@DueDate", SqlDbType.Date).Value = FindPolicyTransactionGroupedRequest.DueDate
                Else
                    cmd.AddInParameter("@DueDate", SqlDbType.Date).Value = SqlDateTime.Null
                End If
                If FindPolicyTransactionGroupedRequest.EffectiveFromDateSpecified Then
                    cmd.AddInParameter("@EffectiveFromDate", SqlDbType.Date).Value = FindPolicyTransactionGroupedRequest.EffectiveFromDate
                Else
                    cmd.AddInParameter("@EffectiveFromDate", SqlDbType.Date).Value = SqlDateTime.Null
                End If
                If FindPolicyTransactionGroupedRequest.EffectiveToDateSpecified Then
                    cmd.AddInParameter("@EffectiveToDate", SqlDbType.Date).Value = FindPolicyTransactionGroupedRequest.EffectiveToDate
                Else
                    cmd.AddInParameter("@EffectiveToDate", SqlDbType.Date).Value = SqlDateTime.Null
                End If
                If FindPolicyTransactionGroupedRequest.PolicyReferenceSpecified Then
                    cmd.AddInParameter("@PolicyReference", SqlDbType.VarChar, 30).Value = FindPolicyTransactionGroupedRequest.PolicyReference
                Else
                    cmd.AddInParameter("@PolicyReference", SqlDbType.VarChar, 30).Value = SqlString.Null
                End If
                If FindPolicyTransactionGroupedRequest.OnlyOutstanding Then
                    cmd.AddInParameter("@OnlyOutstanding", SqlDbType.Int).Value = 1
                Else
                    cmd.AddInParameter("@OnlyOutstanding", SqlDbType.Int).Value = 0
                End If

                dsPolicies = conPolicies.ExecuteDataSet(cmd, "Policies")
            End Using
        End Using

        Dim iCnt As Integer = 0
        Dim iPolicies As Integer = 0
        Dim dr As DataRow = Nothing
        Dim iTransactions As Integer = 0
        Dim iCurrentInsuranceFolderId As Integer = 0
        Dim sCurrentFeeType As String = ""
        Dim iFees As Integer
        Dim iCurrentFeeInsuranceFolderId As Integer = 0

        Dim oFindPolicyTransactionGroupedPolicies(0) As BaseFindPolicyTransactionGroupedResponseTypePolicies
        Dim oFindPolicyTransactionGroupedPoliciesFees(0) As BaseFindPolicyTransactionGroupedResponseTypePoliciesFees
        If dsPolicies IsNot Nothing AndAlso dsPolicies.Tables IsNot Nothing AndAlso dsPolicies.Tables.Count > 0 AndAlso dsPolicies.Tables(0).Rows IsNot Nothing AndAlso dsPolicies.Tables(0).Rows.Count > 0 Then
            If dsPolicies.Tables(0).Rows.Count > 0 Then
                For iCnt = 0 To dsPolicies.Tables(0).Rows.Count - 1

                    If iCurrentInsuranceFolderId <> Convert.ToInt32(dsPolicies.Tables(0).Rows(iCnt).Item("PolicyFolderId")) Then
                        iCurrentInsuranceFolderId = Convert.ToInt32(dsPolicies.Tables(0).Rows(iCnt).Item("PolicyFolderId"))
                        ReDim Preserve oFindPolicyTransactionGroupedPolicies(iPolicies)
                        oFindPolicyTransactionGroupedPolicies(iPolicies) = New BaseFindPolicyTransactionGroupedResponseTypePolicies
                        iPolicies = iPolicies + 1
                    End If

                    dr = dsPolicies.Tables(0).Rows(iCnt)
                    With oFindPolicyTransactionGroupedPolicies(iPolicies - 1)
                        .ClientCode = Cast.ToStringTrim(dr.Item("ClientCode"))
                        .ClientName = Cast.ToStringTrim(dr.Item("ClientName"))
                        .PolicyCurrency = Cast.ToStringTrim(dr.Item("PolicyCurrency"))
                        .PolicyFolderId = Cast.ToInt32(dr.Item("PolicyFolderId"), 0)
                        .PolicyNumber = Cast.ToStringTrim(dr.Item("PolicyNumber"))

                        If Cast.ToStringTrim(dr.Item("Transdetail_Type_Code")).ToUpper = "COMM" Then
                            .Commission = Cast.ToDouble(dr.Item("currency_amount"), 0)
                            .CommissionOS = Cast.ToDouble(dr.Item("outstanding_currency_amount"), 0)
                        ElseIf Cast.ToStringTrim(dr.Item("Transdetail_Type_Code")).ToUpper = "COMMTAX" Then
                            .CommissionTax = Cast.ToDouble(dr.Item("currency_amount"), 0)
                            .CommissionTaxOS = Cast.ToDouble(dr.Item("outstanding_currency_amount"), 0)
                        ElseIf Cast.ToStringTrim(dr.Item("Transdetail_Type_Code")).ToUpper = "GROSS" Then
                            .Premium = Cast.ToDouble(dr.Item("currency_amount"), 0)
                            .PremiumOS = Cast.ToDouble(dr.Item("outstanding_currency_amount"), 0)
                        ElseIf Cast.ToStringTrim(dr.Item("Transdetail_Type_Code")).ToUpper = "TAX" Then
                            .PremiumTax = Cast.ToDouble(dr.Item("currency_amount"), 0)
                            .PremiumTaxOS = Cast.ToDouble(dr.Item("outstanding_currency_amount"), 0)
                        End If
                    End With

                    If iCurrentFeeInsuranceFolderId <> iCurrentInsuranceFolderId Then
                        iCurrentFeeInsuranceFolderId = iCurrentInsuranceFolderId
                        Dim dataViewFEE As DataView = New DataView
                        With dataViewFEE
                            .Table = dsPolicies.Tables(0)
                            .RowFilter = "PolicyFolderId =" + Convert.ToString(iCurrentInsuranceFolderId) + " AND  FEE_TYPE IS NOT NULL"
                        End With

                        With dataViewFEE.ToTable
                            For FeesCount As Integer = 0 To dataViewFEE.ToTable.Rows.Count - 1
                                If sCurrentFeeType <> Cast.ToStringTrim(dataViewFEE.ToTable.Rows(FeesCount).Item("Fee_Type")) Then
                                    sCurrentFeeType = Cast.ToStringTrim(dataViewFEE.ToTable.Rows(FeesCount).Item("Fee_Type"))
                                    ReDim Preserve oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees(iFees)
                                    oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees(iFees) = New BaseFindPolicyTransactionGroupedResponseTypePoliciesFees
                                    iFees = iFees + 1
                                End If

                                If Cast.ToStringTrim(dataViewFEE.ToTable.Rows(FeesCount).Item("Transdetail_Type_Code")).ToUpper = "FEE" Then
                                    oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees(iFees - 1).FeeAmount = Cast.ToDouble(dataViewFEE.ToTable.Rows(FeesCount).Item("currency_amount"), 0)
                                    oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees(iFees - 1).FeeAmountOS = Cast.ToDouble(dataViewFEE.ToTable.Rows(FeesCount).Item("outstanding_currency_amount"), 0)
                                ElseIf Cast.ToStringTrim(dataViewFEE.ToTable.Rows(FeesCount).Item("Transdetail_Type_Code")).ToUpper = "FEETAX" Then
                                    oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees(iFees - 1).FeeTaxAmount = Cast.ToDouble(dataViewFEE.ToTable.Rows(FeesCount).Item("currency_amount"), 0)
                                    oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees(iFees - 1).FeeTaxAmountOS = Cast.ToDouble(dataViewFEE.ToTable.Rows(FeesCount).Item("outstanding_currency_amount"), 0)
                                End If
                                oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees(iFees - 1).FeeType = Cast.ToStringTrim(dataViewFEE.ToTable.Rows(FeesCount).Item("Fee_Type"))
                            Next
                            oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees = oFindPolicyTransactionGroupedPolicies(iPolicies - 1).Fees
                        End With
                    End If
                    iTransactions = iTransactions + 1
                    iFees = 0
                Next
                oResponse.Policies = oFindPolicyTransactionGroupedPolicies
            End If
        End If

        Return oResponse
    End Function
#End Region

#Region "GetPolicyTransactionDetails"
    ''' <summary>  
