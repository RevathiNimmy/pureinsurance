    '''<param name="con" type="SiriusConnection"></param> 
    '''<returns>BaseFindCashListReceiptsResponseType</returns>
    '''<remarks></remarks>   
    Public Function FindCashListReceipts(ByVal con As SiriusConnection,
     ByVal oRequest As BaseFindCashListReceiptsRequestType) As BaseFindCashListReceiptsResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseFindCashListReceiptsResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iBankAccountId As Int32
        Dim iBranchId As Int32
        Dim iBankId As Int32
        Dim iMediaStatusId As Int32

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindCashListReceiptsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.FindCashListReceiptsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        '*******************
        ' DATA VALIDATION
        '*******************

        ValidateFindCashListReceiptsLookup(con, oBusiness, oSAMErrorCollection, oRequest, iBankAccountId, iBranchId, iBankId, iMediaStatusId)

        ' throw any data related errors
        oSAMErrorCollection.CheckForErrors()

        Dim dsCashListItems As DataSet = Nothing
        Dim dsFilter As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Find_Receipt")
            If iBankAccountId <> 0 Then
                cmd.AddInParameter("@BankAccount_Id", SqlDbType.Int).Value = iBankAccountId
            End If
            If iBranchId <> 0 Then
                cmd.AddInParameter("@Branch_Id", SqlDbType.Int).Value = iBranchId
            End If
            If oRequest.CollectionDateFromSpecified = True Then
                cmd.AddInParameter("@CollectionDate_From", SqlDbType.DateTime).Value = oRequest.CollectionDateFrom
            End If
            If oRequest.CollectionDateToSpecified = True Then
                cmd.AddInParameter("@CollectionDate_To", SqlDbType.DateTime).Value = oRequest.CollectionDateTo
            End If
            If Not String.IsNullOrEmpty(oRequest.DocumentRef) Then
                cmd.AddInParameter("@Document_Ref", SqlDbType.VarChar, 25).Value = oRequest.DocumentRef
            End If
            If Not String.IsNullOrEmpty(oRequest.MediaReference) Then
                cmd.AddInParameter("@MediaReference", SqlDbType.VarChar, 30).Value = oRequest.MediaReference
            End If
            If iBankId <> 0 Then
                cmd.AddInParameter("@DrawnBank_Id", SqlDbType.Int).Value = iBankId
            End If
            If Not String.IsNullOrEmpty(oRequest.InsuranceRef) Then
                cmd.AddInParameter("@Insurance_Ref", SqlDbType.VarChar, 30).Value = oRequest.InsuranceRef
            End If

            If oRequest.PartyKeySpecified = True Then
                cmd.AddInParameter("@Party_Cnt", SqlDbType.Int).Value = oRequest.PartyKey
            End If

            If oRequest.MaxRowsToFetchSpecified = True Then
                cmd.AddInParameter("@MaxRowsToFetch", SqlDbType.Int).Value = oRequest.MaxRowsToFetch
            End If
            If _SiriusUser.UserID <> 0 Then
                cmd.AddInParameter("@User_Id", SqlDbType.SmallInt).Value = _SiriusUser.UserID
            End If
            If iMediaStatusId <> 0 Then
                cmd.AddInParameter("@MediaTypeStatus_Id", SqlDbType.Int).Value = iMediaStatusId
            End If

            dsCashListItems = con.ExecuteDataSet(cmd, "Row")
        End Using
        If dsCashListItems IsNot Nothing AndAlso dsCashListItems.Tables.Count > 0 AndAlso dsCashListItems.Tables(0).Rows.Count > 0 Then

            dsFilter = New DataSet
            With dsCashListItems.Tables(0)
                dsFilter.Tables.Add()
                dsFilter.Tables(0).Columns.Add("CashListItemKey", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("InsuranceFileKey", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("MediaTypeKey", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("MediaTypeDescription", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("MediaTypeStatusKey", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("MediaTypeStatusDescription", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("DocumentRef", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("BranchDescription", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("ClientCode", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("ClientName", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("PolicyNumber", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("DrawnBankName", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("MediaReference", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("MediaTypeCode", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("MediaTypeStatusCode", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("CurrentStatus", GetType(System.String))

                Dim iCount As Integer
                For iCount = 0 To dsCashListItems.Tables(0).Rows.Count - 1
                    dsFilter.Tables(0).Rows.Add()
                    dsFilter.Tables(0).Rows(iCount)("CashListItemKey") = Cast.ToInt32(dsCashListItems.Tables(0).Rows(iCount).Item("cashlistitem_id"), 0)
                    dsFilter.Tables(0).Rows(iCount)("InsuranceFileKey") = Cast.ToInt32(dsCashListItems.Tables(0).Rows(iCount).Item("Insurance_File_Cnt"), 0)
                    dsFilter.Tables(0).Rows(iCount)("MediaTypeKey") = Cast.ToInt32(dsCashListItems.Tables(0).Rows(iCount).Item("MediaType_Id"), 0)
                    dsFilter.Tables(0).Rows(iCount)("MediaTypeDescription") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("MediaType"), "")
                    dsFilter.Tables(0).Rows(iCount)("MediaTypeStatusKey") = Cast.ToInt32(dsCashListItems.Tables(0).Rows(iCount).Item("MediaType_Status_Id"), 0)
                    dsFilter.Tables(0).Rows(iCount)("MediaTypeStatusDescription") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("MediaTypeStatus"), "")
                    dsFilter.Tables(0).Rows(iCount)("DocumentRef") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("document_ref"), "")
                    dsFilter.Tables(0).Rows(iCount)("BranchDescription") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("Branch"), "")
                    dsFilter.Tables(0).Rows(iCount)("ClientCode") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("ClientCode"), "")
                    dsFilter.Tables(0).Rows(iCount)("ClientName") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("ClientName"), "")
                    dsFilter.Tables(0).Rows(iCount)("PolicyNumber") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("PolicyNumber"), "")
                    dsFilter.Tables(0).Rows(iCount)("DrawnBankName") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("DrawnBankName"), "")
                    dsFilter.Tables(0).Rows(iCount)("MediaReference") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("MediaReference"), "")
                    dsFilter.Tables(0).Rows(iCount)("MediaTypeCode") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("MediaTypeCode"), "")
                    dsFilter.Tables(0).Rows(iCount)("MediaTypeStatusCode") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("MediaType_Status_Code"), "")
                    dsFilter.Tables(0).Rows(iCount)("CurrentStatus") = Cast.ToString(dsCashListItems.Tables(0).Rows(iCount).Item("CurrentStatus"), "NULL")
                Next
            End With

            Dim xmlDoc As New System.Xml.XmlDocument
            dsFilter.DataSetName = "BaseFindCashListReceiptsResponseTypeCashListItems"
            dsFilter.Tables(0).TableName = "Row"

            If oRequest.WCFSecurityToken = "" Then
                xmlDoc.LoadXml(dsFilter.GetXml)
                If (dsFilter.Tables.Count >= 1) Then
                    oResponse.ResultDataSet = xmlDoc.DocumentElement()
                End If
            End If

            If (dsFilter.Tables.Count >= 1) Then
                oResponse.ResultData = dsFilter
            End If
        End If

        Return oResponse
    End Function

