    Public Overloads Function GetWmTaskLog(ByVal con As SiriusConnection, ByVal GetWmTaskLogRequest As BaseGetWmTaskLogRequestType) As BaseGetWmTaskLogResponseType
        Const ACMethodName As String = "GetWmTaskLog"
        Dim oGetWmTaskLogResponse As New BaseGetWmTaskLogResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If GetWmTaskLogRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetWmTaskLogRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetWmTaskLogResponse = New SAMForInsuranceV2ImplementationTypes.GetWmTaskLogResponseType
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(GetWmTaskLogRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        ' Check mandatory fields
        If GetWmTaskLogRequest.TaskInstanceKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "TaskInstanceKey")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsWmTaskLogs As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_PMWrk_Task_Inst_Log_sad ")
            cmd.AddInParameter("@pmwrk_task_instance_cnt", SqlDbType.Int).Value = GetWmTaskLogRequest.TaskInstanceKey

            Try
                dsWmTaskLogs = con.ExecuteDataSet(cmd, "Row")

                If dsWmTaskLogs.Tables.Count > 0 Then
                    For Each dataTable As DataTable In dsWmTaskLogs.Tables
                        If dataTable.Rows.Count > 0 Then
                            dataTable.Columns("pmwrk_task_instance_cnt").ColumnName = "TaskInstanceKey"
                            dataTable.Columns("date_created").ColumnName = "DateCreated"
                            dataTable.Columns("text").ColumnName = "LogText"
                            dataTable.Columns("created_by_id").ColumnName = "CreatedByKey"
                            dataTable.Columns("username").ColumnName = "UserName"
                        End If
                    Next
                End If
            Catch ex As Exception
                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "Failed To convert xml", ex.Message)
                STSErrorEx.SetContext(oGetWmTaskLogResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
                Return oGetWmTaskLogResponse

            End Try
        End Using

        Dim DocWmTaskLogs As New System.Xml.XmlDocument
        dsWmTaskLogs.DataSetName = "BaseGetWmTaskLogResponseTypeTaskLog"

        If GetWmTaskLogRequest.WCFSecurityToken = "" Then
            DocWmTaskLogs.LoadXml(dsWmTaskLogs.GetXml)
            oGetWmTaskLogResponse.ResultDataset = DocWmTaskLogs.DocumentElement()
        End If

        oGetWmTaskLogResponse.ResultData = dsWmTaskLogs
        Return oGetWmTaskLogResponse
    End Function

