                cmd.AddInParameter("@fee_percentage", SqlDbType.Money).Value = 0D
                cmd.AddInParameter("@FeeTypePercent", SqlDbType.Bit).Value = 0
            End If

            con.ExecuteNonQuery(cmd)

        End Using

        Return oUpdateFeeResponse


