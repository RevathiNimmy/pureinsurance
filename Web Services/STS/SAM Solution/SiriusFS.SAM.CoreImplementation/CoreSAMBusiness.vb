                .BIC = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("business_identifier_code"), String.Empty)
                .IBAN = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("international_bank_account_number"), String.Empty)
                .DayOfWeekOrMonth = Cast.ToInt32(dsfinancePlandetails.Tables(0).Rows(0).Item("DayOfWeekOrMonth"), 0)

                .PlanReference = dsfinancePlandetails.Tables(0).Rows(0).Item("AutoGeneratedPlanRef").ToString()
                Dim creditCardFound As Boolean = False
                Dim partyBankId As Integer = Cast.ToInt32(dsfinancePlandetails.Tables(0).Rows(0).Item("Party_bank_id"), 0)
                ' Attempt to use the Party Bank details
                If partyBankId <> 0 Then

                    Dim getPartyBankDetailsRequest As New BaseGetPartyBankDetailsRequestType
                    Dim getPartyBankDetailsResponse() As BasePartyBankType

                    getPartyBankDetailsRequest.PartyBankKey = partyBankId
                    getPartyBankDetailsRequest.IncludeHistory = False

                    ' Call Get Party Bank Details to get the Credit Card details
                    getPartyBankDetailsResponse = GetPartyBankDetailsByPartyBankKey(con,
                                                        New CoreBusiness(_SiriusUser),
                                                        getPartyBankDetailsRequest)

                    If IsArray(getPartyBankDetailsResponse) Then
                        oGetFinancePlanDetailsResponse.BankAccountType = getPartyBankDetailsResponse(0).AccountType
                        If getPartyBankDetailsResponse(0).Bank IsNot Nothing Then
                            oGetFinancePlanDetailsResponse.BankBranchCode = getPartyBankDetailsResponse(0).Bank.BranchCode
                        End If

                        If (getPartyBankDetailsResponse(0).CreditCard Is Nothing) = False Then
                            '.CreditCard = getPartyBankDetailsResponse(0).CreditCard
                            '.CreditCard.AccountType = getPartyBankDetailsResponse(0).AccountType
                            '.CreditCard.TypeCode = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("card_type"), String.Empty)
                            creditCardFound = True
                        End If
                    End If

                End If

                ' If no Party Bank details are found then use the credit card details on the Instalment Plan.
                If creditCardFound Then

                    Dim oCreditcard As New BaseImplementationTypes.BaseCreditCardType
                    Dim oCardTypeCardHolder As New BaseImplementationTypes.BaseCreditCardTypeCardHolder
                    oCardTypeCardHolder.AddressLine1 = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cardholder_address1"), String.Empty)
                    oCardTypeCardHolder.AddressLine2 = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cardholder_address2"), String.Empty)
                    oCardTypeCardHolder.AddressLine3 = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cardholder_address3"), String.Empty)
                    oCardTypeCardHolder.AddressLine4 = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cardholder_address4"), String.Empty)

                    oCardTypeCardHolder.CountryKey = Cast.ToInt32(dsfinancePlandetails.Tables(0).Rows(0).Item("client_country"), 0)
                    If oCardTypeCardHolder.CountryKey > 0 Then
                        oCardTypeCardHolder.CountryCode = oCoreBusiness.GetListItemFromID(Core.STSListType.PMLookup, PMLookupTable.Country, oCardTypeCardHolder.CountryKey).ToString()
                    End If
                    oCardTypeCardHolder.Name = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cardholder_name"), String.Empty)
                    oCardTypeCardHolder.PostCode = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cardholder_postcode"), String.Empty)
                    oCreditcard.ExpiryDate = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cc_expiry_date"), String.Empty)
                    oCreditcard.Issue = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cc_issue"), String.Empty)
                    oCreditcard.NameOnCreditCard = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cardholder_name"), String.Empty)
                    oCreditcard.Number = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cc_number"), String.Empty)
                    oCreditcard.Pin = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cc_pin"), String.Empty)
                    oCreditcard.StartDate = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("cc_start_date"), String.Empty)
                    oCreditcard.TypeCode = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("card_type"), String.Empty)
                    oCreditcard.AuthCode = Cast.ToString(dsfinancePlandetails.Tables(0).Rows(0).Item("auth_code"), String.Empty)
                    oCreditcard.PartyBankKey = Cast.ToInt32(dsfinancePlandetails.Tables(0).Rows(0).Item("Party_bank_id"), 0)

                    oCreditcard.CardHolder = oCardTypeCardHolder
                    .CreditCard = oCreditcard
                End If
            End With
        End If

        If (dsInstalments IsNot Nothing) Then
            If (dsInstalments.Tables.Count >= 1) Then
                If (dsInstalments.Tables(0).Rows.Count >= 1) Then
                    oGetFinancePlanDetailsResponse.Instalments = New BaseGetFinancePlanDetailsResponseTypeInstalments
                    For iCount As Integer = 0 To dsInstalments.Tables(0).Rows.Count - 1
                        ReDim Preserve oGetFinancePlanDetailsResponse.Instalments.Row(iCount)
                        oGetFinancePlanDetailsResponse.Instalments.Row(iCount) = New BaseGetFinancePlanDetailsResponseTypeInstalmentsRow
                        With oGetFinancePlanDetailsResponse.Instalments.Row(iCount)
                            .Amount = Cast.ToDouble(dsInstalments.Tables(0).Rows(iCount).Item("Amount"), 0)
                            .DueDate = Cast.ToDateTime(dsInstalments.Tables(0).Rows(iCount).Item("DueDate"), Date.MinValue)
                            .InstalmentNumber = Cast.ToInt32(dsInstalments.Tables(0).Rows(iCount).Item("InstalmentNumber"), 0)
                            .PaymentDate = Cast.ToDateTime(dsInstalments.Tables(0).Rows(iCount).Item("PostedDate"), Date.MinValue)
                            If .PaymentDate <> DateTime.MinValue Then
                                .PaymentDateSpecified = True
                            Else
                                .PaymentDateSpecified = False
                            End If
                            .Status = Cast.ToString(dsInstalments.Tables(0).Rows(iCount).Item("status_description"), Nothing)
                            .Reason = Cast.ToString(dsInstalments.Tables(0).Rows(iCount).Item("description"), Nothing)
                        End With
                    Next

                End If
            End If
        End If

        Return oGetFinancePlanDetailsResponse
    End Function

