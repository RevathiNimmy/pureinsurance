    ''' <summary>
    ''' This  method is to Get the Agent Commission Details
    '''<param name="oUpdateAgentCommissionRequestType" type="BaseUpdateAgentCommissionRequestType"></param>
    '''<param name="con" type="SiriusConnection"></param> 
    '''<returns>BaseUpdateAgentCommissionResponseType</returns>
    '''<remarks></remarks>   
    Public Overloads Function UpdateAgentCommission(ByVal con As SiriusConnection, ByVal oUpdateAgentCommissionRequestType As BaseUpdateAgentCommissionRequestType) As BaseUpdateAgentCommissionResponseType

        Dim oUpdateAgentCommissionResponse As New BaseUpdateAgentCommissionResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim iSourceId As Integer
        Dim iRiskTypeId As Integer
        Dim iCommissionBankId As Integer
        Dim iTaxGroupId As Integer
        Dim iPartyId As Int32
        Dim nTypeOfPackage As enumTypeOfPackage

        If oUpdateAgentCommissionRequestType.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateAgentCommissionRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oUpdateAgentCommissionResponse = New SAMForInsuranceV2ImplementationTypes.UpdateAgentCommissionResponseType
        ElseIf oUpdateAgentCommissionRequestType.GetType Is GetType(BaseImplementationTypes.BaseUpdateAgentCommissionRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.MessagingPackage
            oUpdateAgentCommissionResponse = New BaseImplementationTypes.BaseUpdateAgentCommissionResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If
        oUpdateAgentCommissionRequestType.Validate(CType(oErrors, Object))

        oErrors.CheckForErrors()

        If Not String.IsNullOrEmpty(oUpdateAgentCommissionRequestType.BranchCode) Then
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oUpdateAgentCommissionRequestType.BranchCode, "BranchCode", oErrors)
        End If

        oErrors.CheckForErrors()

        If oUpdateAgentCommissionRequestType.AgentCommission IsNot Nothing AndAlso oUpdateAgentCommissionRequestType.AgentCommission.Row IsNot Nothing Then
            For iCount As Integer = 0 To oUpdateAgentCommissionRequestType.AgentCommission.Row.Length - 1
                If String.IsNullOrEmpty(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).Agent) Then
                    oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "Agent")
                End If
                If String.IsNullOrEmpty(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).RiskType) Then
                    oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "RiskType")
                End If
                If String.IsNullOrEmpty(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CommissionBand) Then
                    oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "CommissionBand")
                End If
                If oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CommissionRate > 0 AndAlso oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).MaximumRate > 0 Then
                    If oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).MaximumRate < oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CommissionRate Then
                        oErrors.AddBusinessRule(SAMBusinessErrors.InvalidCommissionRate,
                                         SAMBusinessErrors.InvalidCommissionRate.ToString,
                                         "The Commission  Rate cannot be Greater than Maximum Rate configured against the commission arrangement")
                    End If
                End If
            Next
        End If

        oErrors.CheckForErrors()

        Try
            con.BeginTransaction()

            If oUpdateAgentCommissionRequestType.AgentCommission IsNot Nothing AndAlso oUpdateAgentCommissionRequestType.AgentCommission.Row IsNot Nothing Then
                For iCount As Integer = 0 To oUpdateAgentCommissionRequestType.AgentCommission.Row.Length - 1
                    If oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).IsAmended = True Then
                        Using cmdUpdateAgentCommission As SiriusCommand = SiriusCommand.FromProcedure("spu_sam_agent_commission_upd")


                            cmdUpdateAgentCommission.Parameters.Clear()
                            cmdUpdateAgentCommission.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oUpdateAgentCommissionRequestType.InsuranceFileKey
                            cmdUpdateAgentCommission.AddInParameter("@is_lead_agent", SqlDbType.TinyInt).Value = Cast.ToInt16(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).IsLeadAgent, 0)
                            cmdUpdateAgentCommission.AddInParameter("@premium", SqlDbType.Decimal, 19, 4).Value = oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).Premium
                            cmdUpdateAgentCommission.AddInParameter("@Commission_percentage", SqlDbType.Decimal, 19, 10).Value = oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CommissionRate
                            cmdUpdateAgentCommission.AddInParameter("@commission_value", SqlDbType.Decimal, 19, 4).Value = oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CommissionValue
                            cmdUpdateAgentCommission.AddInParameter("@is_amended", SqlDbType.TinyInt).Value = Cast.ToInt16(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).IsAmended, 0)
                            cmdUpdateAgentCommission.AddInParameter("@override_reason", SqlDbType.VarChar, 255).Value = Cast.ToString(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).OverRideReason)
                            If oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CalculatedCommissionValueSpecified Then
                                cmdUpdateAgentCommission.AddInParameter("@calculated_commission_value", SqlDbType.Money).Value = oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CalculatedCommissionValue
                            Else
                                cmdUpdateAgentCommission.AddInParameter("@calculated_commission_value", SqlDbType.Money).Value = Cast.ToDouble(0)
                            End If
                            cmdUpdateAgentCommission.AddInParameter("@is_value", SqlDbType.TinyInt).Value = Cast.ToInt16(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).IsValue, 0)
                            cmdUpdateAgentCommission.AddInParameter("@maximum_rate", SqlDbType.Decimal, 19, 4).Value = oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).MaximumRate
                            If Not String.IsNullOrEmpty(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).RiskType) Then
                                iRiskTypeId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.RiskType, oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).RiskType, "RiskType", oErrors)
                            End If
                            If Not String.IsNullOrEmpty(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CommissionBand) Then
                                iCommissionBankId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.CommissionBand, oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).CommissionBand, "CommissionBand", oErrors)
                            End If
                            If Not String.IsNullOrEmpty(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).TaxGroupCode) Then
                                iTaxGroupId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.TaxGroup, oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).TaxGroupCode, "TaxGroupCode", oErrors)
                            End If
                            If Not String.IsNullOrEmpty(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).Agent) Then
                                iPartyId = Cast.ToInt32(GetAndValidateSpecifiedTableCode(con, "party", "party_cnt", "shortname", oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).Agent, oErrors, "Agent"), 0)
                            End If

                            oErrors.CheckForErrors()

                            cmdUpdateAgentCommission.AddInParameter("@risk_type_id", SqlDbType.Int).Value = iRiskTypeId
                            cmdUpdateAgentCommission.AddInParameter("@commission_band_id", SqlDbType.Int).Value = iCommissionBankId
                            If iTaxGroupId = 0 Then
                                cmdUpdateAgentCommission.AddInParameter("@tax_group_id", SqlDbType.Int).Value = Nothing
                            Else
                                cmdUpdateAgentCommission.AddInParameter("@tax_group_id", SqlDbType.Int).Value = iTaxGroupId
                            End If
                            cmdUpdateAgentCommission.AddInParameter("@party_cnt", SqlDbType.Int).Value = iPartyId

                            If Cast.ToInt16(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).IsTaxAmended, 0) = 1 Then
                                cmdUpdateAgentCommission.AddInParameter("@is_tax_amended", SqlDbType.TinyInt).Value = 1
                                cmdUpdateAgentCommission.AddInParameter("@amended_tax_value", SqlDbType.Money).Value = Cast.DefaultIfNull(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).AmendedTaxValue, 0)
                            Else
                                cmdUpdateAgentCommission.AddInParameter("@is_tax_amended", SqlDbType.TinyInt).Value = 0
                                cmdUpdateAgentCommission.AddInParameter("@amended_tax_value", SqlDbType.Money).Value = Cast.ToDouble(0)
                            End If
                            cmdUpdateAgentCommission.AddInParameter("@peril_type_id", SqlDbType.Int).Value = Cast.ToInt32(oUpdateAgentCommissionRequestType.AgentCommission.Row(iCount).PerilType, 0)
                            con.ExecuteNonQuery(cmdUpdateAgentCommission)
                        End Using
                    End If
                Next
            End If

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_sir_lead_commission_upd")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oUpdateAgentCommissionRequestType.InsuranceFileKey
                con.ExecuteNonQuery(cmd)
            End Using

            con.CommitTransaction()
        Catch ex As Exception
            con.RollbackTransaction()
        End Try
        ' Dataset that will hold the returned results		
        Dim dsAgentCommissions As DataSet = Nothing
        Dim dsHeader As DataSet = Nothing

        If oUpdateAgentCommissionRequestType.InsuranceFileKey <> 0 Then

            Dim dTotalCommissionLeadAgent As Double = 0.0
            Dim dTotalTaxLeadAgent As Double = 0.0
            Dim dTotalNetPremiumLeadAgent As Double = 0.0
            Dim dTotalCommissionSubAgent As Double = 0.0
            Dim dTotalTaxSubAgent As Double = 0.0
            Dim dTotalNetPremiumSubAgent As Double = 0.0
            Using cmdCommissionsel As SiriusCommand = SiriusCommand.FromProcedure("spu_sir_agent_commission_sel")

                cmdCommissionsel.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oUpdateAgentCommissionRequestType.InsuranceFileKey)
                dsAgentCommissions = con.ExecuteDataSet(cmdCommissionsel, "Row")
                If (dsAgentCommissions.Tables.Count > 0) Then

                    If (dsAgentCommissions.Tables(0).Rows.Count > 0) Then
                        oUpdateAgentCommissionResponse.AgentCommission = New BaseAgentCommissionResponseTypeAgentCommission
                        For icount As Integer = 0 To dsAgentCommissions.Tables(0).Rows.Count - 1
                            ReDim Preserve oUpdateAgentCommissionResponse.AgentCommission.Row(icount)
                            oUpdateAgentCommissionResponse.AgentCommission.Row(icount) = New BaseAgentCommissionResponseTypeAgentCommissionRow
                            If Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item(7), False) Then
                                dTotalCommissionLeadAgent = dTotalCommissionLeadAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(6), 0.0)
                                dTotalTaxLeadAgent = dTotalTaxLeadAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(16), 0.0)
                            Else
                                dTotalCommissionSubAgent = dTotalCommissionSubAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(6), 0.0)
                                dTotalTaxSubAgent = dTotalTaxSubAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(16), 0.0)
                            End If
                            With oUpdateAgentCommissionResponse.AgentCommission.Row(icount)
                                .Agent = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item("shortname"), Nothing)
                                .AgentType = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item("Description"), Nothing)
                                .CommissionBand = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item(3), Nothing)

                                .IsLeadAgent = Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("is_lead_agent"), False)
                                .IsValue = Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("Is_Value"), False)
                                .MaximumRate = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("maximum_rate"), 0)
                                .Premium = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("premium"), 0)
                                .RiskType = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item(2), Nothing)
                                If Cast.ToInt32(dsAgentCommissions.Tables(0).Rows(icount).Item("tax_group_id"), 0) <> 0 Then
                                    .TaxGroup = GetAndValidateDescriptionById(con, "Tax_Group", "code", "tax_group_id", Cast.ToInt32(dsAgentCommissions.Tables(0).Rows(icount).Item("tax_group_id"), 0).ToString())
                                    .TaxGroupDescription = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item("Description2"), Nothing)
                                Else
                                    .TaxGroup = Nothing
                                End If
                                .TaxValue = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("tax_amount"), 0)
                                If Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("Is_Value"), False) = True Then
                                    .CommissionValue = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_value"), 0)
                                    If Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage"), 0) = 0 Or Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("premium"), 0) = 0 Then
                                        .CommissionRate = 0
                                    Else
                                        .CommissionRate = Cast.ToDouble(((Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_value"), 0) / Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("Premium"), 0)) * 100), 0)
                                    End If
                                Else
                                    .CommissionRate = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage"), 0)
                                    .CommissionValue = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_value"), 0)
                                End If
                                .IsAmended = Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("is_amended"), False)
                                .OverRideReason = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item("override_reason"), Nothing)
                                .PerilType = Cast.ToInt32(dsAgentCommissions.Tables(0).Rows(icount).Item("peril_type_id"), 0)
                            End With
                        Next
                        dTotalNetPremiumLeadAgent = dTotalCommissionLeadAgent + dTotalTaxLeadAgent
                        dTotalNetPremiumSubAgent = dTotalCommissionSubAgent + dTotalTaxSubAgent
                    End If
                End If
            End Using
            With oUpdateAgentCommissionResponse
                .LeadAgentNet = dTotalNetPremiumLeadAgent
                .LeadAgentTotalCommission = dTotalCommissionLeadAgent
                .LeadAgentTotalTax = dTotalTaxLeadAgent
                .SubAgentNet = dTotalNetPremiumSubAgent
                .SubAgentTotalCommission = dTotalCommissionSubAgent
                .SubAgentTotalTax = dTotalTaxSubAgent
            End With
        End If
        Return oUpdateAgentCommissionResponse
    End Function

    Public Function GenerateDocumentsForEvent(ByVal GenerateDocumentsForEventRequest As BaseGenerateDocumentsForEventRequestType) As BaseGenerateDocumentsForEventResponseType

        '************************************************************************************************************
        'Const declaration
        '************************************************************************************************************
        Const ACMethodName As String = "GenerateDocumentsForEvent"
        '************************************************************************************************************
        Dim oResponse As BaseGenerateDocumentsForEventResponseType = Nothing
        Dim oGenerateClaimsDocuments As New BaseImplementationTypes.BaseGenerateDocumentsForEventResponseType
        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCoreBusiness As New CoreBusiness
        Dim oDocLink As New bPMBDocLink.Business
        Dim oGetDocument As New bSIRGetDocument.Business

        Using con As SiriusConnection = New SiriusConnectionPMDAO(_SiriusUser.Username, _SiriusUser.SourceID, _SiriusUser.LanguageID, "test")
            oResponse = New SAMForInsuranceV2ImplementationTypes.GenerateDocumentsForEventResponseType

            '*********************
            ' STRUCTURE VALIDATION 
            '*********************
            ' validate the mandatory structure data
            GenerateDocumentsForEventRequest.Validate(CType(oSAMErrorCollection, Object))
            ' if there were any errors throw an exception
            oSAMErrorCollection.CheckForErrors()
            '*********************
            ' DATA VALIDATION 
            '*********************

            Dim iSourceID As Int32
            iSourceID% = 1

            If Not String.IsNullOrEmpty(GenerateDocumentsForEventRequest.BranchCode) Then
                iSourceID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, GenerateDocumentsForEventRequest.BranchCode, "BranchCode", oSAMErrorCollection)
            End If

            If Not oCoreBusiness.CheckInsuranceFile(GenerateDocumentsForEventRequest.InsuranceFileKey) Then
                oSAMErrorCollection.AddInvalidData(
                                                     SAMConstants.SAMInvalidData.InvalidInsuranceFile,
                                                     SAMConstants.SAMInvalidData.InvalidInsuranceFile.ToString,
                                                     "Invalid InsuranceFileKey Specified")
                oSAMErrorCollection.CheckForErrors()
            End If

            Select Case GenerateDocumentsForEventRequest.ProcessTypeCode
                Case "NB", "AP", "RP", "ZP", "RI"
                Case Else
                    oSAMErrorCollection.AddInvalidData(
                                       SAMConstants.SAMInvalidData.ValueOutOfAcceptableRange,
                                       SAMConstants.SAMInvalidData.ValueOutOfAcceptableRange.ToString,
                                       "Only NB, AP, RP, ZP, RI are supported as process type")
            End Select
            oSAMErrorCollection.CheckForErrors()

            Try
                Dim sResult As String = ""
                Dim sInsuranceFileStatusCode As String = ""

                InitialiseSBOObject(con, oDocLink, _SiriusUser, "bPMBDocLink.Business")

                InitialiseSBOObject(con, oGetDocument, _SiriusUser, "bSIRGetDocument.Business")

                Dim ds As DataSet
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_GetInsuranceFileStatus")
                    cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = GenerateDocumentsForEventRequest.InsuranceFileKey
                    ds = con.ExecuteDataSet(cmd, "InsuranceFileDetails")
                    Dim dr As DataRow

                    If ds.Tables("InsuranceFileDetails").Rows.Count > 0 Then
                        dr = ds.Tables("InsuranceFileDetails").Rows(0)
                        sInsuranceFileStatusCode = dr.Item(0).ToString().Trim().ToUpper()
                    End If
                End Using

                If sInsuranceFileStatusCode = "CAN" Then
                    'Cancellation Notice
                    GenerateDocumentForProcess(con, GenerateDocumentsForEventRequest, oResponse, oDocLink, oGetDocument, 10)
                Else
                    'Schedule
                    GenerateDocumentForProcess(con, GenerateDocumentsForEventRequest, oResponse, oDocLink, oGetDocument, 4)
                    'Certificate
                    GenerateDocumentForProcess(con, GenerateDocumentsForEventRequest, oResponse, oDocLink, oGetDocument, 5)
                    'Debit Note
                    GenerateDocumentForProcess(con, GenerateDocumentsForEventRequest, oResponse, oDocLink, oGetDocument, 3)
                End If
            Catch ex As Exception
                Throw
            Finally
                If oDocLink IsNot Nothing Then
                    oDocLink.Dispose()
                    oDocLink = Nothing
                End If
                If oGetDocument IsNot Nothing Then
                    oGetDocument.Dispose()
                    oGetDocument = Nothing
                End If
            End Try

        End Using

        Return oResponse
    End Function

    Private Sub GenerateDocumentForProcess(ByVal con As SiriusConnection,
                                            ByVal GenerateDocumentsForEventRequest As BaseGenerateDocumentsForEventRequestType,
                                            ByVal GenerateDocumentsForEventResponse As BaseGenerateDocumentsForEventResponseType,
                                            ByVal oDocLink As bPMBDocLink.Business,
                                            ByVal oGetDocument As bSIRGetDocument.Business,
                                            ByVal ProcessTypeDocumentId As Integer)

        Const ACMethodName As String = "GenerateDocumentForProcess"

        Dim bSuppressed As Boolean
        Dim iReturn As Integer
        Dim iRow As Integer
        Dim iUBound As Integer
        Dim iFuntionalArea As Short = 1
        Dim vResultArray(,) As Object = Nothing
        Dim iInsuranceFolderCnt As Integer = 0
        Dim iPartyCnt As Integer = 0

        Dim oGIS As bGIS.STS = Nothing
        Dim oDatabase As Object = Nothing
        Dim iRet As Integer
        Dim sZipFilePath As String = String.Empty
        Dim sMergedFilePath As String = ""
        Dim ds As DataSet
        Try

            iReturn = oGetDocument.CheckIfSuppressed(ProcessTypeDocumentId, GenerateDocumentsForEventRequest.InsuranceFileKey, bSuppressed)
            If bSuppressed Then Exit Sub
            iReturn = oDocLink.GetSFIDocumentTemplatesForProcessType(iFuntionalArea, GenerateDocumentsForEventRequest.InsuranceFileKey, ProcessTypeDocumentId, GenerateDocumentsForEventRequest.ProcessTypeCode, Now, vResultArray, True)
            If Not IsArray(vResultArray) Then
                Exit Sub
            End If
            Dim oResponseArray As System.Array
            Try
                oResponseArray = CType(vResultArray, System.Array)
            Catch
                oResponseArray = Nothing
            End Try

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Insurance_File_Details")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = GenerateDocumentsForEventRequest.InsuranceFileKey

                ds = con.ExecuteDataSet(cmd, "InsuranceFileDetails")

                Dim dr As DataRow

                If ds.Tables("InsuranceFileDetails").Rows.Count > 0 Then

                    dr = ds.Tables("InsuranceFileDetails").Rows(0)

                    iPartyCnt = Cast.ToInt32(dr.Item("insurance_holder_cnt"), 0)
                    iInsuranceFolderCnt = Cast.ToInt32(dr.Item("insurance_folder_cnt"), 0)
                End If
            End Using
            If GenerateDocumentsForEventRequest.GenerateDocuments Then
                Try
                    oGIS = New bGIS.STS
                Catch ex As Exception
                    Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bGIS.Application", ex.Message)
                    STSErrorEx.SetContext(GenerateDocumentsForEventResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "CreatebGISSTS", True)
                    Exit Sub
                End Try

                'Following line is being added by rk as part of SAM Interop conversions and as per internal and SSP discussion in place of LOC next to it (now commented somewhere below saying oDatabase = con.PMDAODatabase)
                'con = SiriusConnection.FromAny(connectionString:=ConnectionString)
                'oDatabase = con.SqlConnection.Database
                'oDatabase = con.PMDAODatabase

                If Not con Is Nothing Then
                    oDatabase = con.PMDAODatabase
                End If

                Try
                    iRet = oGIS.Initialise(sUserName:=_SiriusUser.Username,
                                           sPassword:=_SiriusUser.Password,
                                           iUserID:=CInt(_SiriusUser.UserID),
                                           iSourceID:=CInt(_SiriusUser.SourceID),
                                           iLanguageID:=CInt(_SiriusUser.LanguageID),
                                           iCurrencyID:=CInt(_SiriusUser.CurrencyID),
                                           iLogLevel:=SiriusUserDefaults.LogLevel,
                                           sCallingAppName:=ACMethodName,
                                           vDatabase:=oDatabase)
                Catch ex As Exception
                    If oGIS IsNot Nothing Then
                        oGIS.Dispose()
                        oGIS = Nothing
                    End If
                    Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bGIS.Application", ex.Message)
                    STSErrorEx.SetContext(GenerateDocumentsForEventResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "oGIS.Initialise", True)
                    Exit Sub
                End Try

                If (iRet <> 1) Then
                    If oGIS IsNot Nothing Then
                        oGIS.Dispose()
                        oGIS = Nothing
                    End If
                    Dim STSError2 As New STSErrorPublisher(iRet, "Failed to initialise GIS")
                    STSError2.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GISInitialise", True)
                End If
            End If

            If oResponseArray IsNot Nothing Then
                With oResponseArray
                    Dim lRowCnt As Integer = .GetUpperBound(1)
                    If GenerateDocumentsForEventResponse.Documents Is Nothing Then
                        ReDim GenerateDocumentsForEventResponse.Documents(lRowCnt)
                        iUBound = -1
                    Else
                        iUBound = GenerateDocumentsForEventResponse.Documents.GetUpperBound(1)
                        ReDim Preserve GenerateDocumentsForEventResponse.Documents(iUBound + lRowCnt + 1)
                    End If

                    Dim i As Integer = 0
                    For i = 0 To lRowCnt
                        Dim oDocRow As New BaseGenerateDocumentsForEventResponseDocument
                        oDocRow.DocumentTemplateCode = Cast.NullIfDefault(.GetValue(11, i), Nothing).ToString
                        oDocRow.DocumentTemplateDescription = Cast.NullIfDefault(.GetValue(7, i), Nothing).ToString
                        GenerateDocumentsForEventResponse.Documents(iUBound + i + 1) = oDocRow

                        If GenerateDocumentsForEventRequest.GenerateDocuments Then

                            sZipFilePath = String.Empty
                            'Document Generation
                            Dim lDocCount As Integer = 0
                            'Dim count As Integer

                            Dim oMergedFilePath As Object = sMergedFilePath
                            Dim oZipFilePath As Object = sZipFilePath

                            iRet = oGIS.GenerateDocument(
                                                   v_sDocumentTemplateCode:=oDocRow.DocumentTemplateCode,
                                                   v_lMode:=4,
                                                   v_lPartyCnt:=iPartyCnt,
                                                   v_lInsuranceFolderCnt:=iInsuranceFolderCnt,
                                                   v_lInsuranceFileCnt:=GenerateDocumentsForEventRequest.InsuranceFileKey,
                                                   v_bOutputAsHTML:=False,
                                                   r_sMergedFilePath:=CStr(oMergedFilePath),
                                                   r_sSpooledFilePath:=CStr(oZipFilePath),
                                                   v_bOutputAsPDF:=True)

                            If iRet <> 1 Then
                                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "bGis.Application.GeneratePolicyDocument returned an ErrorCode", "")
                                STSErrorEx.SetContext(GenerateDocumentsForEventResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
                                Exit Sub
                            End If
                        End If
                    Next
                End With
            End If

        Catch ex As Exception
            Throw
        Finally
            If GenerateDocumentsForEventRequest.GenerateDocuments Then
                If oGIS IsNot Nothing Then
                    oGIS.Dispose()
                    oGIS = Nothing
                End If
            End If
        End Try
    End Sub

