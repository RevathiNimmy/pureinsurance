                        oTransRow.DocumentGroupCode = Cast.NullIfDefault(.GetValue(63, i), Nothing).ToString
                        oTransRow.CurrencyCode = Cast.NullIfDefault(.GetValue(64, i), Nothing).ToString
                        oTransRow.AccountCurrencyCode = Cast.NullIfDefault(.GetValue(65, i), Nothing).ToString
                        oTransRow.BaseCurrencyCode = Cast.NullIfDefault(.GetValue(66, i), Nothing).ToString ' Sankar - PN 61185
                        oTransRow.BalanceType = Cast.NullIfDefault(.GetValue(55, i), Nothing).ToString
                        oTransRow.BGRef = Cast.NullIfDefault(.GetValue(61, i), Nothing).ToString
                        oTransRow.DocTypeDescription = Cast.NullIfDefault(.GetValue(62, i), Nothing).ToString
                        oTransRow.DocumentComment = Cast.NullIfDefault(.GetValue(36, i), Nothing).ToString
                        oTransRow.InstalmentCollection = (Convert.ToInt32(Cast.NullIfDefault(.GetValue(67, i), "0")) = 1)
                        oTransRow.DueDate = Convert.ToDateTime(Cast.NullIfDefault(.GetValue(71, i), ""))
                        'Split Reverse Allocation
                        oTransRow.CashListKey = Convert.ToInt32(Cast.NullIfDefault(.GetValue(68, i), ""))
                        If .GetValue(69, i) IsNot Nothing AndAlso Not String.IsNullOrEmpty(.GetValue(69, i).ToString) Then
                            oTransRow.IsSplitReceipt = Convert.ToBoolean(Cast.NullIfDefault(CInt(.GetValue(69, i)), "0"))
                        Else
