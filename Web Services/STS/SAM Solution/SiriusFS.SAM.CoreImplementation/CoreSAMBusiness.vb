    ''' <summary>  
    '''  This method is used to update bank guarantee.
    ''' </summary>  
    ''' <param name="sBranchCode">Branch Code which is String type</param>  
    ''' <param name="sCoverNoteBranchCode">Its Input parameter for which the corresponding ID is to be obtained</param>  
    ''' <param name="sCoverNotestatusCode">Its Input parameter for which the corresponding ID is to be obtained</param>  
    ''' <param name="oSAMErrorCollection">An object of type Sirius.Architecture.ExceptionHandling.SAMErrorCollection</param>  
    ''' <param name="oCoreBusiness">An object of type CoreBusiness</param>  
    ''' <param name="lCoverNoteBranchId">Output parameter which is retured back for corresponding sCoverNoteBranchCode</param>  
    ''' <param name="lCoverNotestatusId">CoverNotestatusId, which is retured back for corresponding sCoverNotestatusCode</param>  
    ''' <returns />
    Private Sub ValidateDataFindCoverNoteBooks(ByVal sBranchCode As String, ByVal sCoverNoteBranchCode As String,
            ByVal sCoverNotestatusCode As String, ByVal oSAMErrorCollection As SAMErrorCollection,
            ByVal oCoreBusiness As CoreBusiness, ByRef lCoverNoteBranchId As Int32, ByRef lCoverNotestatusId As Int32)

        oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                                                    PMLookupTable.Source, sBranchCode,
                                                    "BranchCode", oSAMErrorCollection)
        If Not String.IsNullOrEmpty(sCoverNoteBranchCode) Then
            lCoverNoteBranchId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                                            PMLookupTable.Source, sCoverNoteBranchCode,
                                            "CoverNoteBranchCode", oSAMErrorCollection)
        End If
        If Not String.IsNullOrEmpty(sCoverNotestatusCode) Then
