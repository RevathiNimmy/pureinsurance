    Public Overloads Function GetDocumentDefaults(ByVal conGetDocumentDefaults As SiriusConnection, ByVal oGetDocumentDefaultsRequest As BaseGetDocumentDefaultsRequestType) As BaseGetDocumentDefaultsResponseType

        Dim oGetDocumentDefaultsResponse As BaseGetDocumentDefaultsResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection

        oGetDocumentDefaultsResponse = New SAMForInsuranceV2ImplementationTypes.GetDocumentDefaultsResponseType
        If oGetDocumentDefaultsRequest.DocumentTemplateKeys IsNot Nothing AndAlso Not String.IsNullOrEmpty(oGetDocumentDefaultsRequest.DocumentTemplateKeys) Then
            If oGetDocumentDefaultsRequest.DocumentTemplateKeys.Split(CChar(",")).Length > 0 Then

                Dim Documents(oGetDocumentDefaultsRequest.DocumentTemplateKeys.Split(CChar(",")).Length - 1) As BaseGetDocumentDefaultsResponseTypeDocumentTemplates
                Dim keys() As String = oGetDocumentDefaultsRequest.DocumentTemplateKeys.Split(CChar(","))
                Dim iRow As Integer

                If IsArray(Documents) Then
                    Dim DS As DataTable

                    For iRow = 0 To Documents.GetUpperBound(0)
                        Using cmdGetDocumentDefaults As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Document_Template_Defaults_ForKey")
                            cmdGetDocumentDefaults.AddInParameter("@document_template_id", SqlDbType.VarChar).Value = keys(iRow)
                            DS = conGetDocumentDefaults.ExecuteDataTable(cmdGetDocumentDefaults)

                            If DS.Rows.Count > 0 Then
                                Documents(iRow) = New BaseGetDocumentDefaultsResponseTypeDocumentTemplates
                                Documents(iRow).DocumentTemplateID = CInt(DS.Rows(0).Item("document_template_id"))
                                Documents(iRow).DocumentTemplateCode = Cast.ToStringTrim(DS.Rows(0).Item("document_template_code"), "")
                                Documents(iRow).DocumentTemplateDescription = Cast.ToStringTrim(DS.Rows(0).Item("document_template_description"), "")
                                Documents(iRow).DocumentGroupID = Cast.ToInt32(DS.Rows(0).Item("document_template_group_id"), 0)
                                Documents(iRow).DocumentGroupCode = Cast.ToStringTrim(DS.Rows(0).Item("document_template_group_code"), "")
                                Documents(iRow).DocumentGroupDescription = Cast.ToStringTrim(DS.Rows(0).Item("document_template_group_description"), "")
                                Documents(iRow).DocumentSubGroupID = Cast.ToInt32(DS.Rows(0).Item("document_template_sub_group_id"), 0)
                                Documents(iRow).DocumentSubGroupCode = Cast.ToStringTrim(DS.Rows(0).Item("document_template_sub_group_code"), "")
                                Documents(iRow).DocumentSubGroupDescription = Cast.ToStringTrim(DS.Rows(0).Item("document_template_sub_group_description"), "")
                                Documents(iRow).SelectedByDefault = CBool(Cast.ToInt32(DS.Rows(0).Item("is_portal_selected_by_default"), 0) = 1)
                                Documents(iRow).InternalOnly = CBool(Cast.ToInt32(DS.Rows(0).Item("is_portal_internal_only"), 0) = 1)
                                Documents(iRow).EmailDocumentSubjectCode = Cast.ToStringTrim(DS.Rows(0).Item("email_sub_template_code"), "")
                                Documents(iRow).EmailDocumentAttachmentCode = Cast.ToStringTrim(DS.Rows(0).Item("email_attachment_template_code"), "")
                            End If
                        End Using
                    Next iRow

                    oGetDocumentDefaultsResponse.DocumentTemplates = Documents
                End If
            End If
        Else
            If oGetDocumentDefaultsRequest.DocumentTemplateCodes.Split(CChar(",")).Length > 0 Then

                Dim Documents(oGetDocumentDefaultsRequest.DocumentTemplateCodes.Split(CChar(",")).Length - 1) As BaseGetDocumentDefaultsResponseTypeDocumentTemplates
                Dim Codes() As String = oGetDocumentDefaultsRequest.DocumentTemplateCodes.Split(CChar(","))
                Dim iRow As Integer

                If IsArray(Documents) Then
                    Dim DS As DataTable

                    For iRow = 0 To Documents.GetUpperBound(0)
                        Using cmdGetDocumentDefaults As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Document_Template_Defaults_ForCode")
                            cmdGetDocumentDefaults.AddInParameter("document_template_code", SqlDbType.VarChar).Value = Codes(iRow)
                            DS = conGetDocumentDefaults.ExecuteDataTable(cmdGetDocumentDefaults)

                            If DS.Rows.Count > 0 Then
                                Documents(iRow) = New BaseGetDocumentDefaultsResponseTypeDocumentTemplates
                                Documents(iRow).DocumentTemplateID = CInt(DS.Rows(0).Item("document_template_id"))
                                Documents(iRow).DocumentTemplateCode = Cast.ToStringTrim(DS.Rows(0).Item("document_template_code"), "")
                                Documents(iRow).DocumentTemplateDescription = Cast.ToStringTrim(DS.Rows(0).Item("document_template_description"), "")
                                Documents(iRow).DocumentGroupID = Cast.ToInt32(DS.Rows(0).Item("document_template_group_id"), 0)
                                Documents(iRow).DocumentGroupCode = Cast.ToStringTrim(DS.Rows(0).Item("document_template_group_code"), "")
                                Documents(iRow).DocumentGroupDescription = Cast.ToStringTrim(DS.Rows(0).Item("document_template_group_description"), "")
                                Documents(iRow).DocumentSubGroupID = Cast.ToInt32(DS.Rows(0).Item("document_template_sub_group_id"), 0)
                                Documents(iRow).DocumentSubGroupCode = Cast.ToStringTrim(DS.Rows(0).Item("document_template_sub_group_code"), "")
                                Documents(iRow).DocumentSubGroupDescription = Cast.ToStringTrim(DS.Rows(0).Item("document_template_sub_group_description"), "")
                                Documents(iRow).SelectedByDefault = CBool(Cast.ToInt32(DS.Rows(0).Item("is_portal_selected_by_default"), 0) = 1)
                                Documents(iRow).InternalOnly = CBool(Cast.ToInt32(DS.Rows(0).Item("is_portal_internal_only"), 0) = 1)
                                Documents(iRow).EmailDocumentSubjectCode = Cast.ToStringTrim(DS.Rows(0).Item("email_sub_template_code"), "")
                                Documents(iRow).EmailDocumentAttachmentCode = Cast.ToStringTrim(DS.Rows(0).Item("email_attachment_template_code"), "")
                            End If
                        End Using
                    Next iRow

                    oGetDocumentDefaultsResponse.DocumentTemplates = Documents
