                    Docxml.LoadXml(dsGetRatingSectionTypes.GetXml)
                    oGetRatingSectionTypesResponse.ResultDataset = Docxml.DocumentElement()
                End If
            End If
            oGetRatingSectionTypesResponse.ResultDataset = Docxml.DocumentElement()
        End If

        If (dsGetRatingSectionTypes.Tables.Count >= 1) Then
