    ''' <summary>  
    '''  This method updates allocation of cash cheque payment. 
    ''' </summary>  
    ''' <param name="oUpdateAllocationRequest">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseUpdateAllocationRequestType</param>  
    ''' <returns>An object of type SiriusFS.SAM.BaseImplementationTypes.BaseUpdateAllocationResponseType</returns>  
    Public Overloads Function UpdateAllocation(ByVal con As SiriusConnection, ByVal oUpdateAllocationRequest As BaseUpdateAllocationRequestType) As BaseUpdateAllocationResponseType

        Dim oResponse As BaseUpdateAllocationResponseType

        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCorebusiness As New CoreBusiness

        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim oAllocation As BaseUpdateAllocationRequestTypeAllocation

        If oUpdateAllocationRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateAllocationRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateAllocationResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        'Check Mandatory Fields
        If String.IsNullOrEmpty(oUpdateAllocationRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
            SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode")
        End If
        If (oUpdateAllocationRequest.AccountKey <= 0) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
            SAMInvalidData.MandatoryInputMissing.ToString, "AccountKey")
        End If
        If (oUpdateAllocationRequest.TransdetailKey <= 0) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
            SAMInvalidData.MandatoryInputMissing.ToString, "TransdetailKey")
        End If

        If (oUpdateAllocationRequest.Allocation Is Nothing) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                           SAMInvalidData.MandatoryInputMissing.ToString, "Allocation")
        End If
        oSAMErrorCollection.CheckForErrors()

        Dim iSourceId As Integer
        iSourceId = oCorebusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oUpdateAllocationRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        GetAndValidateSpecifiedTableCode(con, "Account", "account_id", "account_id",
        oUpdateAllocationRequest.AccountKey.ToString, oSAMErrorCollection, "AccountKey")

        GetAndValidateSpecifiedTableCode(con, "transdetail", "transdetail_id", "transdetail_id",
        oUpdateAllocationRequest.TransdetailKey.ToString, oSAMErrorCollection, "TransdetailKey")

        ' Check for valid Cash List Item Key only if it supplied
        If (oUpdateAllocationRequest.CashListItemKey > 0) Then
            GetAndValidateSpecifiedTableCode(con, "cashlistitem", "cashlistitem_id", "cashlistitem_id",
            oUpdateAllocationRequest.CashListItemKey.ToString(), oSAMErrorCollection, "CashListItemKey")
        End If

        For Each oAllocation In oUpdateAllocationRequest.Allocation
            GetAndValidateSpecifiedTableCode(con, "transdetail", "transdetail_id", "transdetail_id",
                        oAllocation.AllocationTransdetailKey.ToString, oSAMErrorCollection, "AllocationTransdetailKey")
        Next
        oSAMErrorCollection.CheckForErrors()

        Dim oAllocationManual As bACTAllocationManual.Business = Nothing
        Dim allocationTransdetailKeys As New ArrayList
        Try
            con.BeginTransaction()

            For Each oAllocation In oUpdateAllocationRequest.Allocation
                If allocationTransdetailKeys.Contains(oAllocation.AllocationTransdetailKey) = False Then
                    allocationTransdetailKeys.Add(oAllocation.AllocationTransdetailKey)
                End If
            Next

            For Each oAllocation In oUpdateAllocationRequest.Allocation
                If allocationTransdetailKeys.Contains(oAllocation.AllocationTransdetailKey) = True Then
                    oCorebusiness.CheckSAMTSAndLock(con, BranchCode:=oUpdateAllocationRequest.BranchCode,
                        Lockname:=CoreBusiness.LockName.TransDetailKey,
                        LockValue:=oAllocation.AllocationTransdetailKey,
                        TStamp:=oAllocation.AllocationTimeStamp)
                    allocationTransdetailKeys.Remove(oAllocation.AllocationTransdetailKey)
                End If
            Next

            Dim vKeys(0 To 1, 7) As Object

            With oUpdateAllocationRequest

                vKeys(0, 0) = "account_id"
                vKeys(1, 0) = .AccountKey

                'TransdetailKey
                vKeys(0, 1) = "trans_detail_id"
                vKeys(1, 1) = .TransdetailKey & "|" & .Amount

                ' AllocationTransdetailKeys
                vKeys(0, 2) = "trans_detail_ids"

                Dim iCounter As Integer
                Dim oAllocationDetails() As Object = Nothing
                ReDim oAllocationDetails(oUpdateAllocationRequest.Allocation.GetUpperBound(0))
                For Each oAllocation In oUpdateAllocationRequest.Allocation
                    If .Allocation(iCounter).AllocationTransdetailExKeySpecified Or .Allocation(iCounter).WriteOffAmount <> 0 Then
                        oAllocationDetails(iCounter) = .Allocation(iCounter).AllocationTransdetailKey.ToString & "|" & .Allocation(iCounter).AllocationAmount.ToString & "|" & .Allocation(iCounter).AllocationTransdetailExKey & "|" & .WriteOffReason & "|" & .Allocation(iCounter).WriteOffAmount
                    Else
                        oAllocationDetails(iCounter) = .Allocation(iCounter).AllocationTransdetailKey.ToString & "|" & .Allocation(iCounter).AllocationAmount.ToString
                    End If
                    iCounter = iCounter + 1
                Next
                vKeys(1, 2) = oAllocationDetails

                vKeys(0, 3) = "writeoff_reason_id"
                vKeys(1, 3) = .WriteOffReason

                vKeys(0, 4) = "writeoff_amount"
                vKeys(1, 4) = Math.Round(.WriteOffAmount, 2)

                vKeys(0, 5) = "currency_difference"
                vKeys(1, 5) = .CurrencyDiff

                vKeys(0, 6) = "cashlistitem_id"
                vKeys(1, 6) = .CashListItemKey

                'TransdetailExKey
                vKeys(0, 7) = "trans_detail_ex_id"
                vKeys(1, 7) = .TransdetailExKey
            End With

            oAllocationManual = New bACTAllocationManual.Business
            InitialiseSBOObject(con, oAllocationManual, _SiriusUser, "bACTAllocationManual.Business")

            Dim ncomReturnValue As Integer
            ncomReturnValue = oAllocationManual.SetProcessModes(vTask:=2)
            If ncomReturnValue <> PMEReturnCode.PMTrue AndAlso ncomReturnValue <> PMReturnCode.PMNotFound Then
                RaiseComMethodException("bACTAllocationManual.Business.SetProcessModes", ncomReturnValue)
            End If

            ' Set the keys
            'icomReturnValue = oAllocationManual.SetKeys(vKeyArray:=CType(vKeys, Object))
            ncomReturnValue = oAllocationManual.SetKeys(vKeyArray:=DirectCast(vKeys, Object(,)))
            If ncomReturnValue <> PMEReturnCode.PMTrue AndAlso ncomReturnValue <> PMReturnCode.PMNotFound Then
                RaiseComMethodException("bACTAllocationManual.Business.SetKeys", ncomReturnValue)
            End If

            oAllocationManual.CompanyId = iSourceId

            ncomReturnValue = oAllocationManual.Start()
            If ncomReturnValue <> PMEReturnCode.PMTrue AndAlso ncomReturnValue <> PMReturnCode.PMNotFound Then
                RaiseComMethodException("bACTAllocationManual.Business.Start", ncomReturnValue)
            End If

            Dim oResultKeysObject(,) As Object = Nothing
            Dim nAllocationId As Integer = 0
            ncomReturnValue = oAllocationManual.GetKeys(oResultKeysObject)
            If ncomReturnValue <> PMEReturnCode.PMTrue AndAlso ncomReturnValue <> PMReturnCode.PMNotFound Then
                RaiseComMethodException("bACTAllocationManual.Business.Start", ncomReturnValue)
            End If

            If oResultKeysObject Is Nothing OrElse Not IsArray(oResultKeysObject) Then
                RaiseComMethodException("bACTAllocationManual.Business.Start", ncomReturnValue)
            End If

            'Dim oResultKeys As Object(,) = CType(oResultKeysObject, Object(,))


            nAllocationId = Cast.ToInt32(oResultKeysObject(1, 0), 0)
            oResponse.AllocationId = nAllocationId
            oResponse.AllocationBatchId = Cast.ToInt32(oResultKeysObject(1, 1), 0)

            oResponse.WriteOffAllocationId = Cast.ToInt32(oResultKeysObject(1, 2), 0)
            oResponse.WriteOffTransdetailId = Cast.ToInt32(oResultKeysObject(1, 3), 0)
            If oResponse.WriteOffTransdetailId > 0 Then
                oResponse.IsWrittenOff = True
            End If




            If oAllocationManual IsNot Nothing Then
                oAllocationManual.Dispose()
                oAllocationManual = Nothing
            End If


            For Each oAllocation In oUpdateAllocationRequest.Allocation
                If allocationTransdetailKeys.Contains(oAllocation.AllocationTransdetailKey) = False Then
                    allocationTransdetailKeys.Add(oAllocation.AllocationTransdetailKey)
                End If
            Next

            For Each oAllocation In oUpdateAllocationRequest.Allocation
                If allocationTransdetailKeys.Contains(oAllocation.AllocationTransdetailKey) = True Then
                    oCorebusiness.UnlockAndGetSAMTS(con, BranchCode:=oUpdateAllocationRequest.BranchCode,
                                Lockname:=CoreBusiness.LockName.TransDetailKey,
                                LockValue:=oAllocation.AllocationTransdetailKey,
                                TStamp:=oAllocation.AllocationTimeStamp)
                    allocationTransdetailKeys.Remove(oAllocation.AllocationTransdetailKey)
                End If
            Next

            con.CommitTransaction()
            oResponse.AllocationStatus = True

        Catch ex As Exception
            con.RollbackTransaction()
            Throw
        Finally
            If oAllocationManual IsNot Nothing Then
                oAllocationManual.Dispose()
                oAllocationManual = Nothing
            End If
        End Try

        Return oResponse

    End Function

