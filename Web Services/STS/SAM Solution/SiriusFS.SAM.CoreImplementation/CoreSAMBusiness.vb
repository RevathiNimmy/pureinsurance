    Public Overloads Function AddDocumentToDocumaster(ByVal con As SiriusConnection,
                                    ByVal oAddDocumentToDocumasterRequest As BaseAddDocumentToDocumasterRequestType) _
                                    As BaseAddDocumentToDocumasterResponseType


        Dim oAddDocumentToDocumasterResponse As New BaseAddDocumentToDocumasterResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim iBranchId As New Integer
        Dim o_sOptionValue As String = String.Empty
        Const sACMethodName As String = "AddDocumentToDocumaster"
        Dim oDatabase As dPMDAO.Database = Nothing
        Dim oDatabaseObject As Object = oDatabase
        Dim iRet As New Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oAddDocumentToDocumasterRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AddDocumentToDocumasterRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oAddDocumentToDocumasterResponse = New SAMForInsuranceV2ImplementationTypes.AddDocumentToDocumasterResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing

        End If

        'Mandatory validations
        oAddDocumentToDocumasterRequest.Validate(CObj(oSAMErrorCollection))
        oSAMErrorCollection.CheckForErrors()

        Dim sFilePath As String = ""
        Dim iReturn As Integer
        '''Get temp filepath from registry SOFTWARE\PM\SiriusSolutions\Client\DocZipPMDir
        iReturn = SAMFunc.GetPMRegSetting(PMERegSettingRoot.pmeRSRLocalMachine, PMEProductFamily.pmePFSiriusSolutions, PMERegSettingLevel.pmeRSLClient, "DocZipPMDir", sFilePath)
        If iReturn <> PMEReturnCode.PMTrue Then
            Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.DatasetPathRegistrySettingNotFound, "SAMFunc.GetPMRegSetting failed", "The registry setting for path SOFTWARE\PM\SiriusSolutions\Client\DocZipPMDir does not exist")
            STSErrorEX.SetContext(oAddDocumentToDocumasterResponse.STSError, HttpContext.Current.Request.Url.ToString(), sACMethodName, "GetPMRegSetting", True)
            Return oAddDocumentToDocumasterResponse
        End If

        sFilePath = Path.Combine(sFilePath, _SiriusUser.Username)
        If System.IO.Directory.Exists(sFilePath) = False Then
            System.IO.Directory.CreateDirectory(sFilePath)
        End If
        sFilePath = Path.Combine(sFilePath, oAddDocumentToDocumasterRequest.FileName)

        Dim oFileStream As System.IO.FileStream
        Dim btDocumentArray() As Byte
        btDocumentArray = oAddDocumentToDocumasterRequest.Document
        oFileStream = New System.IO.FileStream(sFilePath, FileMode.Create)
        oFileStream.Write(btDocumentArray, 0, btDocumentArray.Length)
        oFileStream.Close()

        Dim sInsuranceRef As String = ""
        Dim sPartyCode As String = ""
        Dim sClaimRef As String = ""

        If oAddDocumentToDocumasterRequest.PartyKey <> 0 Then
            sPartyCode = GetAndValidateDescriptionById(con, "Party",
                    "ShortName", "Party_Cnt", oAddDocumentToDocumasterRequest.PartyKey.ToString())
        End If

        If oAddDocumentToDocumasterRequest.InsuranceFolderKey <> 0 Then
            sInsuranceRef = GetAndValidateDescriptionById(con, "Insurance_File",
                    "Insurance_Ref", "Insurance_Folder_Cnt", oAddDocumentToDocumasterRequest.InsuranceFolderKey.ToString())
        End If

        Dim strFileExtension As String = System.IO.Path.GetExtension(sFilePath)
        Dim sDocType As String = ""
        Dim iDocNum As Integer
        Dim sKeyWords() As String
        Dim sPageType As String = ""
        If strFileExtension.Length > 0 Then
            sPageType = strFileExtension.Substring(1).ToUpper()
        End If
        Select Case strFileExtension.ToUpper()
            Case ".TIF", ".TIFF"
                sDocType = kDocFileTypeTIF
            Case ".TXT"
                sDocType = kDocFileTypeTXT
            Case ".RTF"
                sDocType = kDocFileTypeRTF
            Case ".DOC"
                sDocType = kDocFileTypeWRD
            Case ".DOCX"
                sDocType = kDocFileTypeWRD
            Case ".XLS"
                sDocType = kDocFileTypeEXL
            Case ".XLSX"
                sDocType = kDocFileTypeEXL
            Case ".PPT"
                sDocType = kDocFileTypePWP
            Case ".PPS"
                sDocType = kDocFileTypePWP
            Case ".MDB"
                sDocType = kDocFileTypeACC
            Case ".HTML"
                sDocType = kDocFileTypeHTM
            Case ".HTM"
                sDocType = kDocFileTypeHTM
            Case ".GIF"
                sDocType = kDocFileTypeGIF
            Case ".JPEG", ".JPG"
                sDocType = kDocFileTypeJPG
            Case ".EML"
                sDocType = kDocFileTypeEML
            Case ".PDF"
                sDocType = kDocFileTypePDF
            Case ".HLP"
                sDocType = kDocFileTypeHLP
            Case ".ZIP"
                sDocType = kDocFileTypeZIP
            Case ".MSG"
                sDocType = kDocFileTypeMSG
            Case Else
                sDocType = kDocFileTypeUnknown
        End Select

        Dim oDocAPI As bSIRDOCAPI.Form = Nothing

        Try
            oDocAPI = New bSIRDOCAPI.Form
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bSIRDOCAPI ", ex.Message)
            STSErrorEx.SetContext(oAddDocumentToDocumasterResponse.STSError, HttpContext.Current.Request.Url.ToString(), sACMethodName, "CreatebSIRDOCAPISFU", True)
            Return oAddDocumentToDocumasterResponse
        End Try
        Try
            oDocAPI.Initialise(sUsername:=_SiriusUser.Username, sPassword:=_SiriusUser.Password, iUserID:=_SiriusUser.UserID, iSourceID:=_SiriusUser.SourceID, iLanguageID:=_SiriusUser.LanguageID, iCurrencyID:=_SiriusUser.CurrencyID, iLogLevel:=SiriusUserDefaults.LogLevel, sCallingAppName:=sACMethodName, vDatabase:=oDatabaseObject)
        Catch ex As Exception
            If oDocAPI IsNot Nothing Then
                oDocAPI.Dispose()
                oDocAPI = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bSIRDOCAPI", ex.Message)
            STSErrorEx.SetContext(oAddDocumentToDocumasterResponse.STSError, HttpContext.Current.Request.Url.ToString(), sACMethodName, "bSIRDOCAPI.Initialise", True)
            Return oAddDocumentToDocumasterResponse
        End Try

        Try
            Dim sErrorCode As String = ""
            Dim dsKeys As DataSet
            If oAddDocumentToDocumasterRequest.FolderNum > 0 Then
                iRet = oDocAPI.AddDocumentDirect(lFolderNum:=oAddDocumentToDocumasterRequest.FolderNum,
                   sDocType:=sDocType, sPageType:=sPageType,
                            sFilename:=sFilePath,
                            sDocName:=oAddDocumentToDocumasterRequest.Description,
                            lDocNumber:=iDocNum,
                            bVisibleFromWeb:=oAddDocumentToDocumasterRequest.VisibleFromWeb)

                ' Retrive Relevant Keys
                dsKeys = RetrieveDMEKeys(con:=con,
                                    oFolderNum:=oAddDocumentToDocumasterRequest.FolderNum,
                                    sErrorCode:=sErrorCode)

                ' Create an Event
                Dim sEventTypeCode As String
                If (dsKeys IsNot Nothing) AndAlso (dsKeys.Tables.Count >= 1) AndAlso (dsKeys.Tables(0).Rows.Count >= 1) AndAlso sErrorCode = "" Then
                    sEventTypeCode = EventTypeCode.ProductionOfDocument

                    CreateEvent(con, Cast.ToInt32(dsKeys.Tables(0).Rows(0).Item("party_cnt"), 0),
                                        Cast.NullIfDefault(Cast.ToInt32(dsKeys.Tables(0).Rows(0).Item("insurance_folder_cnt"), 0)),
                                        Cast.NullIfDefault(Cast.ToInt32(dsKeys.Tables(0).Rows(0).Item("insurance_file_cnt"), 0)),
                                        Cast.NullIfDefault(Cast.ToInt32(dsKeys.Tables(0).Rows(0).Item("claim_cnt"), 0)),
                                        Nothing, Nothing, Nothing, Nothing, Nothing, Nothing,
                                        Nothing, _SiriusUser.UserID, Now, "Raised Document", Nothing, Nothing, sEventTypeCode,
                                        Nothing, Nothing, Nothing, Nothing, 0, Nothing, Nothing, Nothing)
                End If

            Else

                iRet = oDocAPI.AddDocument(lPartyId:=oAddDocumentToDocumasterRequest.PartyKey,
                                sPartyName:=sPartyCode,
                                lInsuranceFolderId:=oAddDocumentToDocumasterRequest.InsuranceFolderKey,
                                sInsuranceFileRef:=sInsuranceRef, lClaimId:=oAddDocumentToDocumasterRequest.ClaimKey,
                                sClaimRef:=sClaimRef, sDocType:=sDocType,
                                sFilename:=sFilePath,
                                sDocName:=oAddDocumentToDocumasterRequest.Description,
                                lDocNumber:=iDocNum, sKeywords:=sKeyWords,
                                lFSAComplaintFolderCnt:=0, sFSAComplaintReference:="",
                                sPageType:=sPageType, sAnnotation:="",
                                bVisibleFromWeb:=oAddDocumentToDocumasterRequest.VisibleFromWeb, bArchiveAsText:=True)
            End If
            oAddDocumentToDocumasterResponse.DocNum = iDocNum
        Catch ex As Exception
            If oDocAPI IsNot Nothing Then
                oDocAPI.Dispose()
                oDocAPI = Nothing
            End If
            RaiseComMethodException("bSIRDOCAPI.Form.AddDocument Failed", iRet)
        Finally
            Dim oFSO As System.IO.FileInfo
            oFSO = New System.IO.FileInfo(sFilePath)
            If oFSO.Exists() Then
                oFSO.Delete()
            End If

            If (iRet <> PMEReturnCode.PMTrue) Then
                If oDocAPI IsNot Nothing Then
                    oDocAPI.Dispose()
                    oDocAPI = Nothing
                End If
                RaiseComMethodException("bSIRDOCAPI.Form.AddDocument Failed", iRet)
            End If
        End Try

        Return oAddDocumentToDocumasterResponse

    End Function

    Private Function GetDMEFolderFromPath(ByVal con As SiriusConnection, ByVal sFolderPath As String) As Integer

        Dim sChildFolder As String
        Dim iFolderNum As Integer = 0
        Dim stringSeparators() As String = {"|"}
        Dim sParentFolder As String = String.Empty

        If sFolderPath.Contains("|") Then
            Dim sFolders As String()
            sFolders = sFolderPath.Split(stringSeparators, StringSplitOptions.None)
            sChildFolder = sFolders(sFolders.Length - 1)
            sParentFolder = sFolders(sFolders.Length - 2)
        Else
            sChildFolder = sFolderPath
        End If
        If (sChildFolder.Length >= 1000) Then
            sChildFolder = sChildFolder.Substring(0, 285)
        End If
        Dim dsFolder As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_ResolveDMEPath")
            cmd.AddInParameter("@folder_name", SqlDbType.VarChar, 285).Value = sChildFolder
            If Not String.IsNullOrEmpty(sParentFolder) Then
                cmd.AddInParameter("@sParentFolder", SqlDbType.VarChar, 255).Value = sParentFolder
            End If
            dsFolder = con.ExecuteDataSet(cmd, "Row")
        End Using

        If (dsFolder.Tables.Count > 0) Then
            If (dsFolder.Tables(0).Rows.Count > 0) Then
                For icount As Integer = 0 To dsFolder.Tables(0).Rows.Count - 1
                    If sFolderPath.ToUpper.Trim() = dsFolder.Tables(0).Rows(icount).Item("FolderPath").ToString.ToUpper.Trim() Then
                        iFolderNum = Cast.ToInt32(dsFolder.Tables(0).Rows(icount).Item("folder_num"), 0)
                        Exit For
                    End If
                Next
            End If
        End If

        Return iFolderNum


    End Function


    Private Function CheckUserFolderAccess(ByVal con As SiriusConnection, ByVal iFolderNum As Integer, ByVal iUserId As Integer) As Boolean
        Dim sFolderBranch As String = ""
        Dim dsBranch As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetDMEFolderBranch")
            cmd.AddInParameter("@folder_num", SqlDbType.Int).Value = iFolderNum
            dsBranch = con.ExecuteDataSet(cmd, "Row")
        End Using

        If (dsBranch.Tables.Count > 0) Then
            If (dsBranch.Tables(0).Rows.Count > 0) Then
                sFolderBranch = dsBranch.Tables(0).Rows(0).Item("ex_code").ToString
            End If
        End If

        Dim bValidBranch As Boolean
        Dim dt As DataTable
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_pm_get_user_sources")
            cmd.AddInParameter("@UserID", SqlDbType.Int).Value = iUserId
            dt = con.ExecuteDataTable(cmd)
        End Using

        'if the user has available sources 
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            ' for each source
            For Each dr As DataRow In dt.Rows
                If dr.Item("source_id").ToString() = sFolderBranch Or String.IsNullOrEmpty(sFolderBranch) Then
                    bValidBranch = True
                    Exit For
                End If
            Next
        End If


        Return bValidBranch
    End Function

    Private Function GetDMEDocTypeFromCode(ByVal docType As String) As DMEDocType
        Select Case docType
            Case "I" 'TIF
                Return DMEDocType.Tif
            Case "T" 'TXT
                Return DMEDocType.PlainText
            Case "W" 'RTF
                Return DMEDocType.RTF
            Case "D" 'Ms Word
                Return DMEDocType.Word
            Case "X" 'Excel
                Return DMEDocType.Excel
            Case "P" 'PowerPoint
                Return DMEDocType.PowerPoint
            Case "A" 'Access
                Return DMEDocType.Access
            Case "H" 'HTML
                Return DMEDocType.HTML
            Case "G" 'GIF
                Return DMEDocType.GIF
            Case "J" 'JPEG
                Return DMEDocType.JPEG
            Case "M" 'EML Email Doc
                Return DMEDocType.Email
            Case "F" 'PDF
                Return DMEDocType.PDF
            Case "E" 'Help Files
                Return DMEDocType.HelpFile
            Case "Z" 'Zip Files
                Return DMEDocType.ZIP
            Case "M"
                Return DMEDocType.MSG
            Case Else
                Return DMEDocType.Unknown
        End Select
    End Function

