    Public Overloads Function GetAgentDetailsForPolicy(ByVal con As SiriusConnection, ByVal oGetAgentDetailsForPolicyRequest As BaseGetAgentDetailsForPolicyRequestType) As BaseGetAgentDetailsForPolicyResponseType

        Dim oGetAgentDetailsForPolicyResponse As New BaseGetAgentDetailsForPolicyResponseType
        Dim oErrors As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        If oGetAgentDetailsForPolicyRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetAgentDetailsForPolicyRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetAgentDetailsForPolicyResponse = New SAMForInsuranceV2ImplementationTypes.GetAgentDetailsForPolicyResponseType
        End If

        oGetAgentDetailsForPolicyRequest.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        Dim sIsAgentAvailable As String = String.Empty
        If oGetAgentDetailsForPolicyRequest.InsuranceFileKey <> 0 Then
            GetAndValidateSpecifiedTableCode(con, PMLookupTable.Insurance_file, "Insurance_file_cnt", "Insurance_file_cnt", oGetAgentDetailsForPolicyRequest.InsuranceFileKey.ToString(), oErrors, "Insurance_file_cnt")
            oErrors.CheckForErrors()
            sIsAgentAvailable = GetAndValidateDescriptionById(con, PMLookupTable.Insurance_file, "lead_agent_cnt", "Insurance_file_cnt", oGetAgentDetailsForPolicyRequest.InsuranceFileKey.ToString())
        End If
        If sIsAgentAvailable <> String.Empty Or sIsAgentAvailable <> "" Then
            Dim dsAgentDetails As DataSet = Nothing
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_insurer_details")
                cmd.AddInParameter("@pol_id", SqlDbType.Int).Value = oGetAgentDetailsForPolicyRequest.InsuranceFileKey
                cmd.AddInParameter("@TransactionMode", SqlDbType.Int).Value = 1
                dsAgentDetails = con.ExecuteDataSet(cmd, "Row")
                If dsAgentDetails IsNot Nothing AndAlso dsAgentDetails.Tables.Count > 0 AndAlso dsAgentDetails.Tables("Row").Rows.Count > 0 Then
                    oGetAgentDetailsForPolicyResponse.Address1 = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Address1").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.Address2 = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Address2").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.Address3 = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Address3").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.Address4 = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Address4").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.AddressKey = Cast.ToInt32(dsAgentDetails.Tables("Row").Rows(0)("Address_cnt"), 0)
                    oGetAgentDetailsForPolicyResponse.AddressUsageTypeKey = Cast.ToInt32(dsAgentDetails.Tables("Row").Rows(0)("Address_usage_type_id"), 0)
                    oGetAgentDetailsForPolicyResponse.AreaCode = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Area_Code").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.Code = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Code").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.ContactTypeKey = Cast.ToInt32(dsAgentDetails.Tables("Row").Rows(0)("Contact_Type_id"), 0)
                    oGetAgentDetailsForPolicyResponse.CountryKey = Cast.ToInt32(dsAgentDetails.Tables("Row").Rows(0)("Country_id"), 0)
                    oGetAgentDetailsForPolicyResponse.Description = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Description").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.Extension = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Extension"), String.Empty)
                    oGetAgentDetailsForPolicyResponse.Name = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Name").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.Number = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Number").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.PostalCode = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Postal_Code").ToString(), String.Empty)
                    oGetAgentDetailsForPolicyResponse.Shortname = Cast.ToString(dsAgentDetails.Tables("Row").Rows(0)("Shortname").ToString(), String.Empty)
                End If
            End Using
        End If
        Dim dr As DataSet = Nothing
        Dim sPartyType As String = String.Empty

        Dim arParams(0) As SqlParameter

        ReDim arParams(2)
        arParams(0) = New SqlParameter("@Party_Cnt", 0)
        arParams(1) = New SqlParameter("@insurance_file_Cnt", oGetAgentDetailsForPolicyRequest.InsuranceFileKey)
        arParams(2) = New SqlParameter("@TransactionMode", 1)

        dr = SqlHelper.ExecuteDataset(SAMFunc.ConnectionString.ToString,
            CommandType.StoredProcedure,
            "spu_get_addresses_for_party",
            arParams)

        With dr.Tables(0)
            Dim oAddressResponse As New BaseGetAddressResponseType
            Dim oAddressRequest As New BaseGetAddressRequestType
            Dim oAddressType As AddressTypeType
            ReDim oGetAgentDetailsForPolicyResponse.Addresses(.Rows.Count - 1)
            For iCnt As Integer = 0 To .Rows.Count - 1
                oAddressResponse = New BaseGetAddressResponseType
                oAddressType = SAMFunc.GetAddressTypeCode(GetListCodeFromID(Core.STSListType.PMLookup, "Address_usage_type", Cast.ToInt32(.Rows(iCnt).Item("address_usage_type_id"), 0)))

                oAddressRequest.AddressKey = Cast.ToInt32(.Rows(iCnt).Item("address_cnt"), 0)
                oAddressRequest.BranchCode = oGetAgentDetailsForPolicyRequest.BranchCode
                oAddressResponse = GetAddress(oAddressRequest)
                oAddressResponse.Address.AddressTypeCode = oAddressType

                oGetAgentDetailsForPolicyResponse.Addresses(iCnt) = oAddressResponse.Address
            Next
        End With

        ReDim arParams(2)
        arParams(0) = New SqlParameter("@Party_Cnt", 0)
        arParams(1) = New SqlParameter("@insurance_file_Cnt", oGetAgentDetailsForPolicyRequest.InsuranceFileKey)
        arParams(2) = New SqlParameter("@TransactionMode", 1)

        dr = SqlHelper.ExecuteDataset(SAMFunc.ConnectionString,
            CommandType.StoredProcedure,
            "spu_get_contacts_for_party",
            arParams)

        'Modification For PN 42880 To Filter out Main Contact Type
        Dim dataViewPC As DataView = New DataView
        With dataViewPC
            .Table = dr.Tables(0)
            .RowFilter = "contacttypecode <> 'MAIN'"
        End With
        With dataViewPC.ToTable
            ReDim oGetAgentDetailsForPolicyResponse.Contacts(.Rows.Count - 1)
            Dim oContact As BaseContactDetailType
            For iCnt As Integer = 0 To .Rows.Count - 1
                oContact = New BaseContactDetailType

                oGetAgentDetailsForPolicyResponse.Contacts(iCnt) = New BaseContactType
                oGetAgentDetailsForPolicyResponse.Contacts(iCnt).AreaCode = .Rows(iCnt).Item("Area_Code").ToString
                oContact.Item = .Rows(iCnt).Item("number").ToString
                oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactDetail = oContact
                oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeId = Cast.ToInt32(.Rows(iCnt).Item("Contact_Type_id"), 0) ' Vivek: 20080704 - added the missing item to fix bug in existing system (Amend Client)
                oGetAgentDetailsForPolicyResponse.Contacts(iCnt).Description = Cast.ToString(.Rows(iCnt).Item("description")) ' Vivek: 20080704 - added the missing item to fix bug in existing system (Amend Client)
                Select Case Trim(.Rows(iCnt).Item("ContactTypeCode").ToString)
                    Case "E-MAIL"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.EMAIL
                    Case "HOMEPHONE"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.HOMEPHONE
                    Case "MOBILE"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.MOBILE
                    Case "FAX"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.FAX
                    Case "WEB"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.WEB
                    Case "MAIN"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.MAIN
                    Case "TELEPHONE"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.TELEPHONE
                    Case "MEMAIL"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.MAINEMAILCONTACT
                    Case "LETTER"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.LETTER
                    Case "OTHER"
                        oGetAgentDetailsForPolicyResponse.Contacts(iCnt).ContactTypeCode = ContactTypeType.OTHER
                End Select
                oGetAgentDetailsForPolicyResponse.Contacts(iCnt).Extension = Cast.ToString(.Rows(iCnt).Item("extension"))
            Next
        End With
        Return oGetAgentDetailsForPolicyResponse
    End Function

