#Region "CreateCaseVersion"
    ''' <summary>  
    ''' CreateCaseVersion
    ''' </summary>  
    Public Function CreateCaseVersion(ByRef con As SiriusConnection,
    ByVal oRequest As BaseCaseItemsRequestType,
        ByRef oResponse As BaseSaveCaseResponseType) As BaseSaveCaseResponseType

        ' Dim oResponse As New BaseSaveCaseResponseType
        Dim obCLMCaseBusiness As bCLMCase.Business
        obCLMCaseBusiness = New bCLMCase.Business
        Dim iCopyCaseKey As Integer = 0
        Dim iReturn As Integer = 0

        Try

            iReturn = obCLMCaseBusiness.ProcessCopyCase(oRequest.CaseKey, iCopyCaseKey, _SiriusUser.UserID)
            'handle ireturn
            If iReturn <> PMEReturnCode.PMTrue Then
                RaiseComMethodException("bCLMCase.Business.ProcessCopyCase Failed", iReturn)
            End If

            Try
                Dim dsGetCase As DataSet
                Dim dsGetCaseClaimLink As DataSet = Nothing
                Dim xmlDoc As New XmlDocument
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Case_Select")
                    cmd.AddInParameter("@case_id", SqlDbType.Int).Value = iCopyCaseKey
                    dsGetCase = con.ExecuteDataSet(cmd, "CaseDetails")
                End Using

                If (dsGetCase IsNot Nothing) Then
                    If (dsGetCase.Tables(0).Rows.Count >= 1) Then
                        With oResponse
                            .CaseKey = CInt(dsGetCase.Tables(0).Rows(0).Item("case_id"))
                            .CaseNumber = CStr(dsGetCase.Tables(0).Rows(0).Item("case_number"))
                            .BaseCaseKey = CInt(dsGetCase.Tables(0).Rows(0).Item("Base_case_id"))
                        End With
                    End If
                End If

