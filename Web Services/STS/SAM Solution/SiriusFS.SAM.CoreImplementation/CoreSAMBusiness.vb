    Public Sub ValidateCoverNoteSheetBussiness(ByVal con As SiriusConnection, ByRef oErrorCollection As Object, ByVal oAddCoverNoteSheetRequest As BaseAddCoverNoteSheetRequestType)
        Dim oCoreBusiness As New CoreBusiness
