    Public Sub SetDefaultValuesinBranch(ByRef vResult As Object, ByVal sBranchDescription As String, ByVal vDefaultValues As Object)

        Dim iCount As Integer = 0
        Dim jCount As Integer = 0
        Dim vCustomArrayMerge As Object(,) = Nothing
        Dim vCustomDefaultArrayMerge As Object(,) = Nothing

        Try

            vCustomArrayMerge = CType(vResult, Object(,))
            For iCount = 0 To Microsoft.VisualBasic.UBound(vCustomArrayMerge)
                If Not vCustomArrayMerge(iCount, 0) Is Nothing Then
                    If UCase(Trim(vCustomArrayMerge(iCount, 0).ToString)) = "BRANCH" Then
                        vCustomDefaultArrayMerge = CType(vDefaultValues, Object(,))
                        For jCount = 0 To Microsoft.VisualBasic.UBound(vCustomDefaultArrayMerge, 2)
                            If Trim(vCustomDefaultArrayMerge(iCount, jCount).ToString.ToUpper) = UCase(Trim(sBranchDescription)) Then
                                vCustomArrayMerge(iCount, 1) = Trim(sBranchDescription)
                                vCustomArrayMerge(iCount, 4) = jCount.ToString
                                Exit For
                            End If
                        Next jCount
                    End If
                End If
            Next iCount
            vResult = CObj(vCustomArrayMerge)

        Catch ex As Exception
            Throw
        End Try
    End Sub
