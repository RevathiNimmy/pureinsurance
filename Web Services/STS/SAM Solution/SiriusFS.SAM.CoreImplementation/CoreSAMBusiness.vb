            With dsAgentBranches.Tables(0)
                dsFilter.Tables.Add()
                dsFilter.Tables(0).Columns.Add("SourceID", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("SourceCode", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("Description", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("CountryID", GetType(System.Int32))

                Dim nCount As Integer

                For nCount = 0 To .Rows.Count - 1
                    dsFilter.Tables(0).Rows.Add()
                    dsFilter.Tables(0).Rows(nCount)("SourceID") = Cast.ToInt32(.Rows(nCount).Item("source_id"), 0)
                    dsFilter.Tables(0).Rows(nCount)("SourceCode") = Cast.ToString(.Rows(nCount).Item("code"), String.Empty)
                    dsFilter.Tables(0).Rows(nCount)("Description") = Cast.ToString(.Rows(nCount).Item("description"), String.Empty)
                    dsFilter.Tables(0).Rows(nCount)("CountryID") = Cast.ToInt32(.Rows(nCount).Item("country_id"), 0)
                Next
            End With
            Dim xmlDoc As New System.Xml.XmlDocument

            dsFilter.DataSetName = "BaseGetAgentSettingsResponseTypeBranches"
            dsFilter.Tables(0).TableName = "Row"
            xmlDoc.LoadXml(dsFilter.GetXml)
            oGetAgentSettingsResponse.ResultDataSet = xmlDoc.DocumentElement()

        Else
            oGetAgentSettingsResponse.ResultDataSet = Nothing
        End If

        Return oGetAgentSettingsResponse
    End Function

