        End Using
    End Function
    Public Overloads Function CallNamedStoredProcedure(ByVal oCon As SiriusConnection, ByVal oCallNamedStoredProcedureRequest As BaseCallNamedStoredProcedureRequestType) As BaseCallNamedStoredProcedureResponseType

        Dim oCoreBusiness As New CoreBusiness
        Dim iReturn As Integer = 0
        Dim oErrors As New SAMErrorCollection
        Dim oResponse As New BaseCallNamedStoredProcedureResponseType
        Dim nTypeofPackage As enumTypeOfPackage
        Dim sResult As String = String.Empty

        With oCallNamedStoredProcedureRequest
            If .GetType Is GetType(SAMForInsuranceV2ImplementationTypes.CallNamedStoredProcedureRequestType) Then
                nTypeofPackage = enumTypeOfPackage.SAMForInsuranceV2Package
                oResponse = New SAMForInsuranceV2ImplementationTypes.CallNamedStoredProcedureResponseType
            Else
                nTypeofPackage = enumTypeOfPackage.UnknownPackage
                Return oResponse
            End If
            Try
                Dim dsResult As New DataSet
                Dim dt As New DataTable("ReportData")
                If oCallNamedStoredProcedureRequest.IsReportDataset Then
                    oResponse.ReportDataset = New List(Of Dictionary(Of String, Object))
                    Using connection As SqlConnection = New SqlConnection(SAMFunc.ConnectionString)
                        Using command As Data.SqlClient.SqlCommand = New Data.SqlClient.SqlCommand(oCallNamedStoredProcedureRequest.ProcedureName, connection)
                            command.CommandType = CommandType.StoredProcedure
                            If oCallNamedStoredProcedureRequest.Parameters IsNot Nothing AndAlso oCallNamedStoredProcedureRequest.Parameters.Length > 0 Then
                                For Each oParam As BaseParameterType In oCallNamedStoredProcedureRequest.Parameters
                                    Dim name = oParam.ParamName.Replace("@", "").Trim()
                                    Dim value As Object = oParam.ParamValue.Replace("<", "").Replace(">", "")
                                    If name.ToLower() = "branch_id" Then
                                        value = oParam.ParamValue.Replace("ALL", "0").Replace("<", "").Replace(">", "")
                                    End If
                                    'reportDataSet1.ReportQueryParameters.Add(name, value);
                                    command.Parameters.Add(New Data.SqlClient.SqlParameter(name, value))

                                Next
                            End If
                            ' Dim reportAdapter As Data.SqlClient.SqlDataAdapter = New Data.SqlClient.SqlDataAdapter(command)
                            'reportAdapter.Fill(dt)
                            connection.Open()
                            Using reader As SqlDataReader = command.ExecuteReader()
                                Dim schemaTable As DataTable = reader.GetSchemaTable()

                                While reader.Read()
                                    Dim dic = New Dictionary(Of String, Object)()

                                    For i As Integer = 0 To reader.FieldCount - 1
                                        Dim colName As String = reader.GetName(i)
                                        Dim value As Object = If(Not reader.IsDBNull(i), reader.GetValue(i), Nothing)
                                        dic(colName) = value
                                    Next
                                    oResponse.ReportDataset.Add(dic)
                                End While
                            End Using

                        End Using
                    End Using
                    Return oResponse
                Else
                    Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure(oCallNamedStoredProcedureRequest.ProcedureName)
                            If oCallNamedStoredProcedureRequest.Parameters IsNot Nothing AndAlso oCallNamedStoredProcedureRequest.Parameters.GetUpperBound(0) >= 0 Then
                                For Each oParam As BaseParameterType In oCallNamedStoredProcedureRequest.Parameters
                                    If oParam.ParamName.ToLower.StartsWith("l") Then
                                        cmd.AddInParameter(oParam.ParamName, SqlDbType.Int).Value = Convert.ToInt32(oParam.ParamValue)
                                    ElseIf oParam.ParamName.ToLower.StartsWith("s") Then
                                        cmd.AddInParameter(oParam.ParamName, SqlDbType.Text, 255).Value = oParam.ParamValue
                                    ElseIf oParam.ParamName.ToLower.StartsWith("b") Then
                                        cmd.AddInParameter(oParam.ParamName, SqlDbType.TinyInt).Value = Convert.ToBoolean(oParam.ParamValue)
                                    ElseIf oParam.ParamName.ToLower.StartsWith("d") Then
                                        cmd.AddInParameter(oParam.ParamName, SqlDbType.DateTime).Value = Convert.ToDateTime(oParam.ParamValue)
                                    ElseIf oParam.ParamName.ToLower.StartsWith("f") Then
                                        cmd.AddInParameter(oParam.ParamName, SqlDbType.Float).Value = Convert.ToDouble(oParam.ParamValue)
                                    Else 'consider all other as text type parameters
                                        cmd.AddInParameter(oParam.ParamName, SqlDbType.Text, 255).Value = oParam.ParamValue
                                    End If
                                Next
                            End If
                            dsResult = con.ExecuteDataSet(cmd, "Row")
                            sResult = dsResult.GetXml
                        End Using
                    End Using
                    oResponse.Results = sResult
                End If
            Catch ex As Exception
                Throw ex
            End Try
        End With
        Return oResponse


    End Function
#End Region

    ''' <summary>  
    ''' Find the Policy
    ''' </summary>  
    ''' <param name="oImportLookupRequest">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseProcessListResponseType</param>  
    Public Overloads Function ProcessList(ByVal oImportLookupRequest As BaseProcessListRequestType) As BaseProcessListResponseType
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
