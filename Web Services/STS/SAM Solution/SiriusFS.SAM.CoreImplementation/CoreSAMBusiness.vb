    ''''<param name="lUserId" type="Integer"></param>   
    ''''<param name="oSAMErrorCollection" type="SAMErrorCollection"></param>  
    ''''</summary>
    ''''<remarks></remarks> 
    Private Sub ValidateWorkManagerLookup(ByVal con As SiriusConnection, ByVal CreateWmTaskRequest As BaseCreateWmTaskRequestType,
           ByRef lTaskGroupId As Integer,
           ByRef lTaskId As Integer,
           ByRef lUserGroupId As Integer,
               ByRef lUserId As Integer, Optional ByVal oSAMErrorCollection As SAMErrorCollection = Nothing)

        Dim oCorebusiness As New CoreBusiness

        'Get TaskGroupId
        lTaskGroupId = oCorebusiness.GetAndValidateListItemFromCode(CType(STSListType.PMLookup, Core.STSListType), "PMWrk_Task_Group", CreateWmTaskRequest.TaskGroup, "TaskGroup", oSAMErrorCollection)

        'Get TaskId
        lTaskId = oCorebusiness.GetAndValidateListItemFromCode(CType(STSListType.PMLookup, Core.STSListType), "PMWrk_Task", CreateWmTaskRequest.Task, "Task", oSAMErrorCollection)

        'Get UserGroupId
        lUserGroupId = oCorebusiness.GetAndValidateListItemFromCode(CType(STSListType.PMLookup, Core.STSListType), "pmuser_group", CreateWmTaskRequest.AllocationUserGroup, "AllocationUserGroup", oSAMErrorCollection)

        'Get UserId
        If Not String.IsNullOrEmpty(CreateWmTaskRequest.AllocationUser) Then
            lUserId = GetUserId(con, CreateWmTaskRequest.AllocationUser)
            If lUserId < 0 Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.UserDoesNotExist, SAMInvalidData.UserDoesNotExist.ToString, "AllocationUser")
            End If
        End If

    End Sub


    '''' <summary>
    '''' This is the private method which is used for Business validation.
    ''''<param name="oSAMErrorCollection" type="SAMErrorCollection"></param>   
    ''''<param name="CreateWmTaskRequest" type="BaseCreateWmTaskRequestType"></param>   
    ''''</summary>
    ''''<remarks></remarks>
    Private Sub ValidateWorkManagerBusinessRule(ByVal CreateWmTaskRequest As BaseCreateWmTaskRequestType,
           Optional ByVal oSAMErrorCollection As SAMErrorCollection = Nothing)
        If CreateWmTaskRequest.DueDateTime < Date.Today Then
            oSAMErrorCollection.AddInvalidData(SAMBusinessErrors.InvalidDueDate,
                                      SAMBusinessErrors.InvalidDueDate.ToString,
                                      "DueDateTime")
        End If
    End Sub


    ' ***************************************************************** '
    ' Name: FindControlSearch
    '
    ' Description: 
    '
    ' ***************************************************************** '
    Public Function FindControlSearch(ByVal FindControlSearchRequest As BaseFindControlSearchRequestType) As BaseFindControlSearchResponseType

        Dim oResponse As BaseFindControlSearchResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iRet As Int32
        Dim utils As New Utilities
        Dim vMappings As Object(,)
        Dim vResultsArray As Object(,) = Nothing

        'Start (Girija chokkalingam) - (Tech Spec - NEM - Wild Card Search.doc) - (6.3.1)

        Dim sDisableWildcardSearchOption As String
        Dim sEnablePartialWildcardSearchOption As String
        sDisableWildcardSearchOption = ""
        sEnablePartialWildcardSearchOption = ""
        Dim bDisableWildcardSearchOption As Boolean
        Dim bEnablePartialWildcardSearchOption As Boolean
        Dim oErrors As New SAMErrorCollection


        Dim oAgentRequest As AgentImplementationTypes.FindControlSearchRequestType

        Const ACMethodName As String = "FindControlSearch"

        Dim STSError As New STSErrorPublisher

        If FindControlSearchRequest.GetType Is GetType(AgentImplementationTypes.FindControlSearchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AgentsPackage
            oResponse = New AgentImplementationTypes.FindControlSearchResponseType
            oAgentRequest = DirectCast(FindControlSearchRequest, AgentImplementationTypes.FindControlSearchRequestType)
        ElseIf FindControlSearchRequest.GetType Is GetType(AnonymousImplementationTypes.FindControlSearchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AnonymousPackage
            oResponse = New AnonymousImplementationTypes.FindControlSearchResponseType
        ElseIf FindControlSearchRequest.GetType Is GetType(CustomerImplementationTypes.FindControlSearchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.CustomersPackage
            oResponse = New CustomerImplementationTypes.FindControlSearchResponseType
        ElseIf FindControlSearchRequest.GetType Is GetType(SAMForBrokingImplementationTypes.FindControlSearchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oResponse = New SAMForBrokingImplementationTypes.FindControlSearchResponseType
        ElseIf FindControlSearchRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.FindControlSearchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.FindControlSearchResponseType
        ElseIf FindControlSearchRequest.GetType Is GetType(BaseImplementationTypes.BaseFindControlSearchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            oResponse = New BaseImplementationTypes.BaseFindControlSearchResponseType
        ElseIf FindControlSearchRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindControlSearchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.FindControlSearchResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        'Check Mandatory Fields
        If FindControlSearchRequest.BranchCode = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        End If

        If FindControlSearchRequest.FindControlKey = 0 Then
            STSError.AddInvalidField("FindControlKey", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "FindControlKey"), "")
        End If

        ' Check for any errors
        If STSError.HasErrors Then
            ' Set the context
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "InputValidation", True)
            ' Return the errors
            Return oResponse
        End If

        'Start (Girija chokkalingam) - (Tech Spec - NEM - Wild Card Search.doc) - (6.3.1)

        oCoreBusiness.GetSystemOption(FindControlSearchRequest.BranchCode, SystemOption.DisableWildcardSearch, sDisableWildcardSearchOption)
        oCoreBusiness.GetSystemOption(FindControlSearchRequest.BranchCode, SystemOption.EnablePartialWildcardSearch, sEnablePartialWildcardSearchOption)
        If (Trim(sDisableWildcardSearchOption) = "1") Then
            bDisableWildcardSearchOption = True
        Else
            bDisableWildcardSearchOption = False
        End If
        If (Trim(sEnablePartialWildcardSearchOption) = "1") Then
            bEnablePartialWildcardSearchOption = True
        Else
            bEnablePartialWildcardSearchOption = False
        End If

        If FindControlSearchRequest.SearchCriteria IsNot Nothing Then
            For Each SearchItem As BaseSearchCriteriaType In FindControlSearchRequest.SearchCriteria
                If Not oCoreBusiness.ValidWildcardSearch(
                          bDisableWildcardSearchOption,
                          bEnablePartialWildcardSearchOption,
                          SearchItem.Value) Then
                    oErrors.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                             SAMInvalidData.InvalidWildcardSearch.ToString,
                                             SearchItem.PropertyName)
                End If
                oErrors.CheckForErrors()
            Next
        End If


        Dim oFindControl As bPBFindControl.Business
        Try
            oFindControl = New bPBFindControl.Business
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bGIS.Application", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "CreatebGISSTS", True)
            Return oResponse
        End Try

        Try
            iRet = CInt(oFindControl.Initialise(sUsername:=_SiriusUser.Username,
                                   sPassword:=_SiriusUser.Password,
                                   iUserID:=_SiriusUser.UserID,
                                   iSourceID:=_SiriusUser.SourceID,
                                   iLanguageID:=_SiriusUser.LanguageID,
                                   iCurrencyID:=_SiriusUser.CurrencyID,
                                   iLogLevel:=SiriusUserDefaults.LogLevel,
                                   sCallingAppName:=ACMethodName))
        Catch ex As Exception
            If oFindControl IsNot Nothing Then
                oFindControl.Dispose()
                oFindControl = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bPBFindControl.Business", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "bPBFindControl.Business.Initialise", True)
            Return oResponse
        End Try

        If (iRet <> 1) Then
            If oFindControl IsNot Nothing Then
                oFindControl.Dispose()
                oFindControl = Nothing
            End If
            Dim STSError2 As New STSErrorPublisher(iRet, "Failed to initialise bPBFindControl.Business")
            STSError2.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bPBFindControl.Business.Initialise", True)
        End If

        Dim vMappingsObject As Object(,) = Nothing

        Try
            iRet = oFindControl.GetMappings(
                                        v_lFindControlID:=FindControlSearchRequest.FindControlKey,
                                        v_vResultsArray:=vMappingsObject)

            vMappings = DirectCast(vMappingsObject, Object(,))

        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "Failed to run bPBFindControl.Business.GetMappings", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End Try

        If iRet = PMEReturnCode.PMNotFound Or IsArray(vMappings) = False Then
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.RecordNotFound, "No records found for FindCrontrol - " & FindControlSearchRequest.FindControlKey, "")
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        ElseIf iRet <> PMEReturnCode.PMTrue Then
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "bPBFindControl.Business.GetMappings failed to retrieve list of mappings for FindCrontrol - " & FindControlSearchRequest.FindControlKey, "")
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End If

        ' Use the system array variable
        Dim arrMappings As Object(,) = vMappings

        Const CNMappingSearchValue As Integer = 6
        Const CNMappingObjectName As Integer = 10
        Const CNMappingPropertyName As Integer = 11

        Dim ColArray(1, arrMappings.GetUpperBound(1)) As Object

        Dim lCntMapping As Integer
        Dim lLBndMapping As Integer = arrMappings.GetLowerBound(1)
        Dim lUBndMapping As Integer = arrMappings.GetUpperBound(1)

        Dim lCntSearch As Integer
        Dim lLBndSearch As Integer = FindControlSearchRequest.SearchCriteria.GetLowerBound(0)
        Dim lUBndSearch As Integer = FindControlSearchRequest.SearchCriteria.GetUpperBound(0)

        For lCntMapping = lLBndMapping To lUBndMapping

            ColArray(0, lCntMapping) = RTrim(Cast.ToString(arrMappings(CNMappingObjectName, lCntMapping), String.Empty)) & "__" & RTrim(Cast.ToString(arrMappings(CNMappingPropertyName, lCntMapping), String.Empty))
            ColArray(1, lCntMapping) = System.Type.GetType("System.String")

            For lCntSearch = lLBndSearch To lUBndSearch
                If ([String].Compare(FindControlSearchRequest.SearchCriteria(lCntSearch).ObjectName.ToString, Cast.ToString(arrMappings(CNMappingObjectName, lCntMapping), String.Empty), True) = 0) And
                   ([String].Compare(FindControlSearchRequest.SearchCriteria(lCntSearch).PropertyName.ToString, Cast.ToString(arrMappings(CNMappingPropertyName, lCntMapping), String.Empty), True) = 0) Then
                    arrMappings(CNMappingSearchValue, lCntMapping) = FindControlSearchRequest.SearchCriteria(lCntSearch).Value
                    Exit For
                End If
            Next lCntSearch

        Next lCntMapping

        Try

            Dim arrMappingsObject As Object = arrMappings

            iRet = oFindControl.FindData(
                                        v_vSearchArray:=CType(CObj(arrMappingsObject), Object(,)),
                                        v_vResultsArray:=vResultsArray)

            arrMappings = DirectCast(arrMappingsObject, Object(,))

        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "Failed to run bPBFindControl.Business.FindData", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End Try

        If IsArray(vResultsArray) = False Then
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.RecordNotFound, "No records found", "")
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End If

        Dim oXMLDoc As New System.Xml.XmlDocument

        Try
            oXMLDoc.LoadXml(Utilities.ArrayToDataSet(vResultsArray, ColArray, "FindData").GetXml)
        Catch ex As Exception
            Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.XMLDocumentBadlyFormed, "Unable to load SQL output as XML", ex.Message)
            STSErrorEX.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End Try

        oResponse.Matches = oXMLDoc.DocumentElement

        Try
            If oFindControl IsNot Nothing Then
                oFindControl.Dispose()
                oFindControl = Nothing
            End If
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to terminate business", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "Terminate", True)
        End Try

        If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            Dim oResponseAgent As New AgentImplementationTypes.FindControlSearchResponseType
            oResponseAgent = DirectCast(oResponse, AgentImplementationTypes.FindControlSearchResponseType)
            oResponse = oResponseAgent
        ElseIf nTypeOfPackage = enumTypeOfPackage.AnonymousPackage Then
            Dim oResponseAnonymous As New AnonymousImplementationTypes.FindControlSearchResponseType
            oResponseAnonymous = DirectCast(oResponse, AnonymousImplementationTypes.FindControlSearchResponseType)
            oResponse = oResponseAnonymous
        ElseIf nTypeOfPackage = enumTypeOfPackage.CustomersPackage Then
            Dim oResponseCustomer As New CustomerImplementationTypes.FindControlSearchResponseType
            oResponseCustomer = DirectCast(oResponse, CustomerImplementationTypes.FindControlSearchResponseType)
            oResponse = oResponseCustomer
        ElseIf nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            Dim oResponseSamForBroking As New SAMForBrokingImplementationTypes.FindControlSearchResponseType
            oResponseSamForBroking = DirectCast(oResponse, SAMForBrokingImplementationTypes.FindControlSearchResponseType)
            oResponse = oResponseSamForBroking
        ElseIf nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage Then
            Dim oResponseSamForInsurance As New SAMForInsuranceImplementationTypes.FindControlSearchResponseType
            oResponseSamForInsurance = DirectCast(oResponse, SAMForInsuranceImplementationTypes.FindControlSearchResponseType)
            oResponse = oResponseSamForInsurance
        ElseIf nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package Then
            Dim oResponseSamForInsuranceV2 As New SAMForInsuranceV2ImplementationTypes.FindControlSearchResponseType
            oResponseSamForInsuranceV2 = DirectCast(oResponse, SAMForInsuranceV2ImplementationTypes.FindControlSearchResponseType)
            oResponse = oResponseSamForInsuranceV2
        End If

        Return oResponse
    End Function

    Public Function GetDocumentList(ByVal GetDocumentListRequest As BaseGetDocumentListRequestType) As BaseGetDocumentListResponseType

        Dim oGetDocumentListResponse As BaseGetDocumentListResponseType = Nothing
        Dim oCoreBusiness As New CoreBusiness
        Dim typeOfPackage As enumTypeOfPackage

        Dim oSAMErrorCollection As New SAMErrorCollection

        If GetDocumentListRequest.GetType Is GetType(BaseImplementationTypes.BaseGetDocumentListRequestType) Then
            typeOfPackage = enumTypeOfPackage.UnknownPackage
            oGetDocumentListResponse = New BaseImplementationTypes.BaseGetDocumentListResponseType
        ElseIf GetDocumentListRequest.GetType Is GetType(SAMForBrokingImplementationTypes.GetDocumentListRequestType) Then
            typeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oGetDocumentListResponse = New SAMForBrokingImplementationTypes.GetDocumentListResponseType
        ElseIf GetDocumentListRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetDocumentListRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetDocumentListResponse = New SAMForInsuranceImplementationTypes.GetDocumentListResponseType
        ElseIf GetDocumentListRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetDocumentListRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetDocumentListResponse = New SAMForInsuranceV2ImplementationTypes.GetDocumentListResponseType
        Else
            typeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        If GetDocumentListRequest.InsuranceFolderKey = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "InsuranceFolderKey")
        End If

        oSAMErrorCollection.CheckForErrors()

        Dim documentData As DataSet = Nothing

        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_DOC_document_list_sel")
                cmd.AddInParameter("@insurance_folder_cnt", SqlDbType.Int).Value = GetDocumentListRequest.InsuranceFolderKey
                documentData = con.ExecuteDataSet(cmd, "Row")
            End Using
        End Using

        If documentData IsNot Nothing AndAlso documentData.Tables(0) IsNot Nothing AndAlso documentData.Tables(0).Rows.Count > 0 Then

            With documentData.Tables(0)
                Dim oBaseDocument As BaseDocumentType
                ReDim oGetDocumentListResponse.Documents(.Rows.Count - 1)

                For iLoop As Integer = 0 To .Rows.Count - 1
                    oBaseDocument = New BaseDocumentType

                    oBaseDocument.DocNum = Cast.ToInt32(.Rows(iLoop).Item("doc_num"), 0)
                    oBaseDocument.DocDescription = Cast.ToString(.Rows(iLoop).Item("doc_name"), String.Empty)

                    oBaseDocument.CreateDate = Cast.ToDateTime(.Rows(iLoop).Item("create_date"), DateTime.MinValue)

                    oGetDocumentListResponse.Documents(iLoop) = oBaseDocument
                Next

            End With
        End If

        Return oGetDocumentListResponse

    End Function

    ' ***************************************************************** '
    ' Name: GenerateDocument
    '
    ' Description: 
    '
    ' ***************************************************************** '
    Public Function GenerateDocument(ByVal GenerateDocumentRequest As BaseGenerateDocumentRequestType, Optional ByRef con As SiriusConnection = Nothing) As BaseGenerateDocumentResponseType
        Dim oResponse As BaseGenerateDocumentResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iRet As Int32
        Dim arrInsuranceFile As Object = Nothing
        Dim utils As New Utilities
        Dim sZipFilePath As String = String.Empty


        Dim btByteArray() As Byte

        Dim oAgentRequest As AgentImplementationTypes.GenerateDocumentRequestType = Nothing
        Dim samForBrokingRequest As SAMForBrokingImplementationTypes.GenerateDocumentRequestType = Nothing

        Const ACMethodName As String = "GenerateDocument"

        Dim STSError As New STSErrorPublisher

        If GenerateDocumentRequest.GetType Is GetType(AgentImplementationTypes.GenerateDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AgentsPackage
            oResponse = New AgentImplementationTypes.GenerateDocumentResponseType
            oAgentRequest = DirectCast(GenerateDocumentRequest, AgentImplementationTypes.GenerateDocumentRequestType)
        ElseIf GenerateDocumentRequest.GetType Is GetType(BaseImplementationTypes.BaseGenerateDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            oResponse = New BaseImplementationTypes.BaseGenerateDocumentResponseType
        ElseIf GenerateDocumentRequest.GetType Is GetType(CustomerImplementationTypes.GenerateDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.CustomersPackage
            oResponse = New CustomerImplementationTypes.GenerateDocumentResponseType
        ElseIf GenerateDocumentRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GenerateDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GenerateDocumentResponseType
        ElseIf GenerateDocumentRequest.GetType Is GetType(SAMForBrokingImplementationTypes.GenerateDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oResponse = New SAMForBrokingImplementationTypes.GenerateDocumentResponseType
            samForBrokingRequest = DirectCast(GenerateDocumentRequest, SAMForBrokingImplementationTypes.GenerateDocumentRequestType)
        ElseIf GenerateDocumentRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GenerateDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GenerateDocumentResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        If nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            If CoreBusiness.PartyIsAgent(samForBrokingRequest.UserPartyType) Then
                If oCoreBusiness.CheckAgentKey(samForBrokingRequest.UserPartyKey) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.AgentRecordNotFound, "Agent Key validation failed", "The Agent record does not exist for key: " & samForBrokingRequest.UserPartyKey)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Key Validation", True)
                    Return oResponse
                End If

                If oCoreBusiness.AgentSecurityCheck(samForBrokingRequest.UserName, samForBrokingRequest.PartyKey, PMEEntityType.Party) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security Check Failed", samForBrokingRequest.UserName & " does not have permission to access party " & samForBrokingRequest.UserPartyKey)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "AddAddress", True)
                    Return oResponse
                End If
            End If
        End If

        'Check Mandatory Fields
        If GenerateDocumentRequest.BranchCode = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        End If

        If GenerateDocumentRequest.DocumentTemplateCode = "" Then
            STSError.AddInvalidField("DocumentTemplateCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "DocumentTemplateCode"), "")
        End If

        GenerateDocumentRequest.InsuranceFileKey = ToSafeInteger(GenerateDocumentRequest.InsuranceFileKey)

        GenerateDocumentRequest.InsuranceFolderKey = ToSafeInteger(GenerateDocumentRequest.InsuranceFolderKey)

        GenerateDocumentRequest.ClaimKey = ToSafeInteger(GenerateDocumentRequest.ClaimKey)


        ' Check for any errors
        If STSError.HasErrors Then
            ' Set the context
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "InputValidation", True)
            ' Return the errors
            Return oResponse
        End If

        Dim iSourceID As Int32
        iSourceID% = 1
        ' Convert branch code to ID
        Try
            iSourceID% = oCoreBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "Source", GenerateDocumentRequest.BranchCode)
        Catch ex As Exception
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.BranchCodeInvalid), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "BranchCode"), GenerateDocumentRequest.BranchCode)
        End Try

        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Lookup field validation", True)
            Return oResponse
        End If

        ' Check the insurance folder cnt is valid
        If ToSafeInteger(GenerateDocumentRequest.InsuranceFileKey) > 0 Then
            If con Is Nothing Then
                If oCoreBusiness.CheckInsuranceFolder(GenerateDocumentRequest.InsuranceFolderKey) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.PolicyRecordNotFound, "Insurance Folder validation failed", "The Insurance Folder record does not exist for key: " & GenerateDocumentRequest.InsuranceFolderKey)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
                    Return oResponse
                End If
            Else
                If oCoreBusiness.CheckInsuranceFolder(con, GenerateDocumentRequest.InsuranceFolderKey) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.PolicyRecordNotFound, "Insurance Folder validation failed", "The Insurance Folder record does not exist for key: " & GenerateDocumentRequest.InsuranceFolderKey)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
                    Return oResponse
                End If
            End If

        End If

        ' Check the insurance file cnt is valid
        If ToSafeInteger(GenerateDocumentRequest.InsuranceFolderKey) > 0 Then
            Dim iFileFolderCnt As Integer
            If oCoreBusiness.CheckInsuranceFile(GenerateDocumentRequest.InsuranceFileKey, iFileFolderCnt) = False Then
                STSError = New STSErrorPublisher(STSErrorCodes.PolicyRecordNotFound, "Insurance File validation failed", "The Insurance File record does not exist for key: " & GenerateDocumentRequest.InsuranceFileKey)
                STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
                Return oResponse
            End If
            If iFileFolderCnt <> GenerateDocumentRequest.InsuranceFolderKey Then
                STSError = New STSErrorPublisher(STSErrorCodes.PolicyMismatch, "Insurance File validation failed", "The Insurance File's Folder does not match the passed InsuranceFolder")
                STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, ACMethodName, True)
                Return oResponse
            End If
        End If

        If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            If (oCoreBusiness.AgentSecurityCheck(oAgentRequest.UserName, oAgentRequest.PartyKey, PMEEntityType.Party) = False) Then
                STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security check failed", oAgentRequest.UserName & " does not have permission to access party " & oAgentRequest.PartyKey)
                STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "GenerateDocument", True)
                Return oResponse
            End If
        ElseIf nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            If (oCoreBusiness.AgentSecurityCheck(samForBrokingRequest.UserName, samForBrokingRequest.PartyKey, PMEEntityType.Party) = False) Then
                STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security check failed", samForBrokingRequest.UserName & " does not have permission to access party " & samForBrokingRequest.PartyKey)
                STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "GenerateDocument", True)
                Return oResponse
            End If
        End If

        Dim oGIS As bGIS.STS = Nothing
        Dim oDatabase As dPMDAO.Database = Nothing
        Dim oDatabaseObject As Object = oDatabase
        Try
            oGIS = New bGIS.STS
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bGIS.Application", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "CreatebGISSTS", True)
            Return oResponse
        End Try

        Try
            If con IsNot Nothing Then
                iRet = oGIS.Initialise(sUserName:=_SiriusUser.Username,
                                                      sPassword:=_SiriusUser.Password,
                                                      iUserID:=CInt(_SiriusUser.UserID),
                                                      iSourceID:=CInt(_SiriusUser.SourceID),
                                                      iLanguageID:=CInt(_SiriusUser.LanguageID),
                                                      iCurrencyID:=CInt(_SiriusUser.CurrencyID),
                                                      iLogLevel:=SiriusUserDefaults.LogLevel,
                                                      sCallingAppName:=ACMethodName,
                                                      vDatabase:=con.PMDAODatabase)

            Else
                iRet = CInt(oGIS.Initialise(sUserName:=_SiriusUser.Username,
                                       sPassword:=_SiriusUser.Password,
                                       iUserID:=CInt(_SiriusUser.UserID),
                                       iSourceID:=CInt(_SiriusUser.SourceID),
                                       iLanguageID:=CInt(_SiriusUser.LanguageID),
                                       iCurrencyID:=CInt(_SiriusUser.CurrencyID),
                                       iLogLevel:=SiriusUserDefaults.LogLevel,
                                       sCallingAppName:=ACMethodName,
                                       vDatabase:=oDatabaseObject))
            End If
        Catch ex As Exception
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bGIS.Application", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "oGIS.Initialise", True)
            Return oResponse
        End Try

        If (iRet <> 1) Then
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
            Dim STSError2 As New STSErrorPublisher(iRet, "Failed to initialise GIS")
            STSError2.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GISInitialise", True)
        End If
        If GenerateDocumentRequest.SpoolDocumentOnly Then
            GenerateDocumentRequest.Mode = gSIRLibrary.ACSpoolDocMode
        End If

        sZipFilePath = String.Empty
        'GENERATE DOCUMENTS HERE (bGis.Application.GeneratePolicyDocument)

        Dim mergeFilePathObject As String = oResponse.MergedFilePath
        Dim zipFilePathObject As String = sZipFilePath
        Dim iMode As Integer = 0
        Try
            iMode = GenerateDocumentRequest.Mode
            iRet = oGIS.GenerateDocument(
                                        v_sDocumentTemplateCode:=GenerateDocumentRequest.DocumentTemplateCode,
                                        v_lMode:=GenerateDocumentRequest.Mode,
                                        v_lPartyCnt:=GenerateDocumentRequest.PartyKey,
                                        v_lInsuranceFolderCnt:=GenerateDocumentRequest.InsuranceFolderKey,
                                        v_lInsuranceFileCnt:=GenerateDocumentRequest.InsuranceFileKey,
                                        v_sParameterXML:=GenerateDocumentRequest.ParameterXML,
                                        v_bOutputAsHTML:=GenerateDocumentRequest.OutputAsHTML,
                                        r_sMergedFilePath:=mergeFilePathObject,
                                        r_sSpooledFilePath:=zipFilePathObject,
                                        v_bOutputAsPDF:=GenerateDocumentRequest.OutputAsPDF,
                                        v_lClaimKey:=GenerateDocumentRequest.ClaimKey,
                                        v_sDocumentRef:=GenerateDocumentRequest.DocumentRef,
                                        sDestinationFilename:=GenerateDocumentRequest.DestinationFileName,
                                        sArchiveDocFileName:=GenerateDocumentRequest.ArchiveDocFileName,
                                        v_bOutputAsTXT:=GenerateDocumentRequest.OutputAsTXT,
                                        v_bSkipArchiveonEdit:=GenerateDocumentRequest.SkipArchiveOnEdit,
                                        bIsSuppressArchive:=GenerateDocumentRequest.IsSuppressArchive)

        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "Failed to run bGis.Application.GeneratePolicyDocument", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End Try
        If iRet <> 1 Then
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "bGis.Application.GeneratePolicyDocument returned an ErrorCode", "")
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End If

        oResponse.MergedFilePath = Cast.ToString(mergeFilePathObject, String.Empty)
        sZipFilePath = Cast.ToString(zipFilePathObject, String.Empty)

        Try
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to terminate business", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "Terminate", True)
        End Try

        If Not String.IsNullOrEmpty(oResponse.MergedFilePath) Then
            ' Convert the XML file to DOCX
            If iMode <> ACEmailMode Then
                If GenerateDocumentRequest.OutputAsPDF = False Then
                    SSP.Shared.bPMDocFunctions.ConvertDocumentUsingSiriusDocumentUtility(oResponse.MergedFilePath, oResponse.MergedFilePath.Replace(".xml", ".docx"))
                    oResponse.MergedFilePath = oResponse.MergedFilePath.Replace(".xml", ".docx")
                End If
            End If


            ' Try to read in the Spooled Zip file into a Filestream
            Try

                Using fsInputFile As FileStream = File.OpenRead(oResponse.MergedFilePath)

                    ReDim btByteArray(CInt(fsInputFile.Length - 1))

                    fsInputFile.Read(btByteArray, 0, CInt(fsInputFile.Length))
                    fsInputFile.Close()
                End Using

            Catch Ex As Exception
                Ex = New Exception("Failed to Read SpooledFilePath : " + sZipFilePath, Ex)
                ExceptionManager.Publish(Ex)
                Throw Ex
            Finally

            End Try

            oResponse.SpooledZipFile = btByteArray
            oResponse.MergedFilePath = IO.Path.GetFileName(oResponse.MergedFilePath)
            Dim sTmpDierectoryPath As String
            Dim oBusiness As New CoreBusiness
            Dim sIsSharepoinOnline As String
            oBusiness.GetSystemOption(GenerateDocumentRequest.BranchCode, SystemOption.IsSharepointOnline, sIsSharepoinOnline)
            sTmpDierectoryPath = IO.Path.GetDirectoryName(Cast.ToString(mergeFilePathObject, String.Empty))
            If IO.Directory.Exists(sTmpDierectoryPath) And Trim(sIsSharepoinOnline) <> "1" Then
                IO.Directory.Delete(sTmpDierectoryPath, True)
            End If
        End If

        If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            Dim oResponseAgent As New AgentImplementationTypes.GenerateDocumentResponseType
            oResponseAgent = DirectCast(oResponse, AgentImplementationTypes.GenerateDocumentResponseType)
            oResponse = oResponseAgent
        End If

        Return oResponse

    End Function

    Public Function GetCurrenciesByBranch(ByVal GetCurrenciesByBranchRequest As BaseGetCurrenciesByBranchRequestType) As BaseGetCurrenciesByBranchResponseType

        Const ACMethodName As String = "GetCurrenciesByBranch"

        'Dim iRet As Integer

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseGetCurrenciesByBranchResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oErrors As New SAMErrorCollection
        If GetCurrenciesByBranchRequest.GetType Is GetType(AgentImplementationTypes.GetCurrenciesByBranchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.AgentsPackage
            oResponse = New AgentImplementationTypes.GetCurrenciesByBranchResponseType
        ElseIf GetCurrenciesByBranchRequest.GetType Is GetType(BaseImplementationTypes.BaseGetCurrenciesByBranchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            oResponse = New BaseImplementationTypes.BaseGetCurrenciesByBranchResponseType
        ElseIf GetCurrenciesByBranchRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetCurrenciesByBranchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GetCurrenciesByBranchResponseType
        ElseIf GetCurrenciesByBranchRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetCurrenciesByBranchRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetCurrenciesByBranchResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim STSError As New STSErrorPublisher

        If SAMFunc.NothingToString(GetCurrenciesByBranchRequest.BranchCode) = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        End If

        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return oResponse
        End If

        Dim iSourceID As Int32
        iSourceID% = 1
        ' Convert branch code to ID      
        If (Not String.IsNullOrEmpty(GetCurrenciesByBranchRequest.BranchCode)) Then
            iSourceID% = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
            PMLookupTable.Source, GetCurrenciesByBranchRequest.BranchCode, "BranchCode", oErrors)
        End If

        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Lookup field validation", True)
            Return oResponse
        End If

        ' Call stored proc to get the Products
        Dim dr As DataSet = Nothing
        Dim arParams(0) As SqlParameter
        arParams(0) = New SqlParameter("@source_code", GetCurrenciesByBranchRequest.BranchCode)

        dr = SqlHelper.ExecuteDataset(SAMFunc.ConnectionString,
            CommandType.StoredProcedure,
            "spu_SAM_Get_Base_Currency_By_Source",
            arParams)

        'PN# 63333
        oResponse.BaseCurrencyCode = Trim(dr.Tables(0).Rows(0).Item("BaseCurrencyCode").ToString)
        oResponse.BaseCurrencyDescription = Trim(dr.Tables(0).Rows(0).Item("BaseCurrencyDescription").ToString)

        ' BSJ April 09 - SQL Mixed Mode Compliance
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Currencies_From_Source")
                cmd.AddInParameter("@source_code", SqlDbType.VarChar, 10).Value = GetCurrenciesByBranchRequest.BranchCode

                dr = con.ExecuteDataSet(cmd, "dr")
            End Using
        End Using

        ' Name the dataset, table and columns
        dr.DataSetName = "BaseGetCurrenciesByBranchResponseTypeCurrencies"
        dr.Tables(0).TableName = "Row"

        Dim oXMLDoc As New System.Xml.XmlDocument

        Try
            If GetCurrenciesByBranchRequest.WCFSecurityToken = "" Then
                Try
                    oXMLDoc.LoadXml(dr.GetXml)
                Catch ex As Exception
                    Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.XMLDocumentBadlyFormed, "Unable to load SQL output as XML", ex.Message)
                    STSErrorEX.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
                    Return oResponse
                End Try
                oResponse.Currencies = oXMLDoc.DocumentElement
            End If

            oResponse.ResultData = dr


        Catch ex As Exception
            Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.XMLDocumentBadlyFormed, "Unable to pass Document Element", ex.Message)
            STSErrorEX.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End Try

        If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            Dim oResponseAgent As New AgentImplementationTypes.GetCurrenciesByBranchResponseType
            oResponseAgent = DirectCast(oResponse, AgentImplementationTypes.GetCurrenciesByBranchResponseType)
            oResponse = oResponseAgent
        End If

        Return oResponse

    End Function

    Public Function GetDatasetDefinition(ByVal GetDatasetDefinitionInput As BaseGetDatasetDefinitionRequestType) As BaseGetDatasetDefinitionResponseType

        Const ACMethodName As String = "GetDatasetDefinition"

        Dim oResponse As New BaseImplementationTypes.BaseGetDatasetDefinitionResponseType
        Dim oBusiness As New CoreBusiness
        Dim sXMLFilename As String = String.Empty
        Dim sDatasetsPath As String = String.Empty
        Dim sXMLDatasetDefinition As String = String.Empty
        Dim CacheKey As String = String.Empty
        Dim iDataModelId As Integer
        Dim iSourceId As Integer
        Dim STSError As New STSErrorPublisher
        Dim samForBrokingRequest As SAMForBrokingImplementationTypes.GetDatasetDefinitionRequestType = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage

        If GetDatasetDefinitionInput.GetType Is GetType(SAMForBrokingImplementationTypes.GetAllPolicyVersionsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oResponse = New SAMForBrokingImplementationTypes.GetDatasetDefinitionResponseType
            samForBrokingRequest = DirectCast(GetDatasetDefinitionInput, SAMForBrokingImplementationTypes.GetDatasetDefinitionRequestType)
        End If

        ' Check if the branch code was passed in
        If SAMFunc.NothingToString(GetDatasetDefinitionInput.DataModelCode) = "" Then
            STSError.AddInvalidField("DataModelCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "DataModelCode"), "")
        End If

        ' Check if the branch code was passed in
        If SAMFunc.NothingToString(GetDatasetDefinitionInput.BranchCode) = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(MandatoryInputMissing, "BranchCode"), "")
        End If

        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return oResponse
        End If

        GetDatasetDefinitionInput.DataModelCode = GetDatasetDefinitionInput.DataModelCode.TrimEnd

        ' DataModelCode
        Try
            iDataModelId% = oBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "GIS_Data_Model", GetDatasetDefinitionInput.DataModelCode)
        Catch ex As Exception
            ' not set
            STSError.AddInvalidField("DataModelCode", CStr(STSErrorCodes.InvalidLookupListValue), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "DataModelCode"), GetDatasetDefinitionInput.DataModelCode)
        End Try

        iSourceId% = 1
        ' Convert branch code to ID
        Try
            iSourceId% = GetListIDFromCode(Core.STSListType.PMLookup, "source", GetDatasetDefinitionInput.BranchCode)
        Catch ex As Exception
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.BranchCodeInvalid), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "BranchCode"), GetDatasetDefinitionInput.BranchCode)
        End Try

        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Input validation", True)
            Return oResponse
        End If

        If nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            If CoreBusiness.PartyIsAgent(samForBrokingRequest.UserPartyType) Then
                If oBusiness.CheckAgentKey(samForBrokingRequest.UserPartyKey) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.AgentRecordNotFound, "Agent Key validation failed", "The Agent record does not exist for key: " & samForBrokingRequest.UserPartyKey)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Key Validation", True)
                    Return oResponse
                End If

                If oBusiness.AgentSecurityCheck(samForBrokingRequest.UserName, iSourceId, PMEEntityType.Source) = False Then
                    STSError = New STSErrorPublisher(STSErrorCodes.SecurityCheckFailed, "Security Check Failed", samForBrokingRequest.UserName & " does not have permission to access source " & iSourceId)
                    STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetDatasetDefinition", True)
                    Return oResponse
                End If
            End If
        End If

        'TODO - GetDatasetDefinition - Handle the BranchCode properly
        'TODO - GetDatasetDefinition - Fix the creation of the Dataset, so it uses correct InsFile, InsFolder, Risk cnt

        ' Get a reference to the cache object
        _oCache = HttpRuntime.Cache()

        ' Append Screen Code because we will have seperate datasets for each type of screen.
        CacheKey = DefaultDatasetKey & GetDatasetDefinitionInput.DataModelCode

        oResponse.XMLDatasetDefinition = CType(_oCache(CacheKey), String)

        If (oResponse.XMLDatasetDefinition = "") Or (oResponse.XMLDatasetDefinition Is Nothing) Then

            sDatasetsPath = DefaultDatasetPath

            sDatasetsPath = Cast.ToString(IIf(Right$(sDatasetsPath, 1) = "\", sDatasetsPath, sDatasetsPath & "\"), String.Empty)

            sXMLFilename = sDatasetsPath & GetDatasetDefinitionInput.DataModelCode & DatasetDefinitionSuffix & XMLFileExtension

            If Dir(sXMLFilename) <> "" Then

                Try
                    ' Create an instance of StreamReader to read from a file.
                    Using sr As StreamReader = New StreamReader(path:=sXMLFilename)
                        ' Read from the file until the end 
                        ' of the file is reached.
                        sXMLDatasetDefinition = sr.ReadToEnd
                        sr.Close()
                    End Using
                Catch Ex As Exception
                    ' TODO - GetDatasetDefinition - Raise proper exception.
                    STSError = New STSErrorPublisher("Failed to create StreamReader with file: " & sXMLFilename, Ex)
                    STSError.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "StreamReader", True)
                End Try

                If (Not sXMLDatasetDefinition Is Nothing) Then

                    ' Create a new depency
                    Dim dependency As New CacheDependency(sXMLFilename, Now())

                    ' Add the dataset into the cache
                    _oCache.Insert(CacheKey, sXMLDatasetDefinition, dependency)

                    oResponse.XMLDatasetDefinition = sXMLDatasetDefinition

                End If

            End If

        End If

        Return oResponse

    End Function

