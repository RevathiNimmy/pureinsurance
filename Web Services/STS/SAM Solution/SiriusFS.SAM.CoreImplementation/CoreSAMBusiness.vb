    ''' <summary>
    ''' This  method is to Get the Agent Commission Details
    '''<param name="oGetAgentCommissionRequestType" type="BaseGetAgentCommissionRequestType"></param>
    '''<param name="con" type="SiriusConnection"></param> 
    '''<returns>BaseGetAgentCommissionResponseType</returns>
    '''<remarks></remarks>   
    Public Overloads Function GetAgentCommission(ByVal con As SiriusConnection, ByVal oGetAgentCommissionRequestType As BaseGetAgentCommissionRequestType) As BaseGetAgentCommissionResponseType

        Dim oGetAgentCommissionResponse As New BaseGetAgentCommissionResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetAgentCommissionRequestType.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetAgentCommissionRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetAgentCommissionResponse = New SAMForInsuranceV2ImplementationTypes.GetAgentCommissionResponseType
        ElseIf oGetAgentCommissionRequestType.GetType Is GetType(BaseImplementationTypes.BaseGetAgentCommissionRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.MessagingPackage
            oGetAgentCommissionResponse = New BaseImplementationTypes.BaseGetAgentCommissionResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        oGetAgentCommissionRequestType.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        If Not String.IsNullOrEmpty(oGetAgentCommissionRequestType.BranchCode) Then
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oGetAgentCommissionRequestType.BranchCode, "BranchCode", oErrors)
        End If

        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsAgentCommissions As DataSet = Nothing
        Dim dsHeader As DataSet = Nothing

        If oGetAgentCommissionRequestType.InsuranceFileKey <> 0 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_upd_commission_max_rate")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetAgentCommissionRequestType.InsuranceFileKey)
                cmd.AddInParameter("@risk_type", SqlDbType.VarChar).Value = Cast.NullIfDefault(oGetAgentCommissionRequestType.RiskType)
                cmd.AddInParameter("@commission_band", SqlDbType.VarChar).Value = Cast.NullIfDefault(oGetAgentCommissionRequestType.CommissionBand)
                con.ExecuteNonQuery(cmd)
            End Using
            Dim dTotalCommissionLeadAgent As Double = 0.0
            Dim dTotalTaxLeadAgent As Double = 0.0
            Dim dTotalNetPremiumLeadAgent As Double = 0.0
            Dim dTotalCommissionSubAgent As Double = 0.0
            Dim dTotalTaxSubAgent As Double = 0.0
            Dim dTotalNetPremiumSubAgent As Double = 0.0
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_sir_agent_commission_sel")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetAgentCommissionRequestType.InsuranceFileKey)
                dsAgentCommissions = con.ExecuteDataSet(cmd, "Row")
                If (dsAgentCommissions.Tables.Count > 0) Then
                    If (dsAgentCommissions.Tables(0).Rows.Count > 0) Then
                        oGetAgentCommissionResponse.AgentCommission = New BaseAgentCommissionResponseTypeAgentCommission
                        For icount As Integer = 0 To dsAgentCommissions.Tables(0).Rows.Count - 1
                            ReDim Preserve oGetAgentCommissionResponse.AgentCommission.Row(icount)
                            oGetAgentCommissionResponse.AgentCommission.Row(icount) = New BaseAgentCommissionResponseTypeAgentCommissionRow
                            If Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item(7), False) Then
                                dTotalCommissionLeadAgent = dTotalCommissionLeadAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(6), 0.0)
                                dTotalTaxLeadAgent = dTotalTaxLeadAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(16), 0.0)
                            Else
                                dTotalCommissionSubAgent = dTotalCommissionSubAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(6), 0.0)
                                dTotalTaxSubAgent = dTotalTaxSubAgent + Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item(16), 0.0)
                            End If
                            With oGetAgentCommissionResponse.AgentCommission.Row(icount)
                                .Agent = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item("shortname"), Nothing)
                                .AgentType = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item("Description"), Nothing)
                                .CommissionBand = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item(3), Nothing)

                                .IsLeadAgent = Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("is_lead_agent"), False)
                                .IsValue = Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("Is_Value"), False)
                                .MaximumRate = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("maximum_rate"), 0)
                                .Premium = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("premium"), 0)
                                .RiskType = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item(2), Nothing)
                                If Cast.ToInt32(dsAgentCommissions.Tables(0).Rows(icount).Item("tax_group_id"), 0) <> 0 Then
                                    .TaxGroup = GetAndValidateDescriptionById(con, "Tax_Group", "code", "tax_group_id", Cast.ToInt32(dsAgentCommissions.Tables(0).Rows(icount).Item("tax_group_id"), 0).ToString())
                                    .TaxGroupDescription = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item("Description2"), Nothing)
                                Else
                                    .TaxGroup = Nothing
                                End If
                                .TaxValue = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("tax_amount"), 0)
                                If Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("Is_Value"), False) = True Then
                                    .CommissionValue = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_value"), 0)
                                    If Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage"), 0) = 0 Or Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("premium"), 0) = 0 Then
                                        .CommissionRate = 0
                                    Else
                                        .CommissionRate = Cast.ToDouble(((Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_value"), 0) / Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("Premium"), 0)) * 100), 0)
                                    End If
                                Else
                                    .CommissionRate = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_percentage"), 0)
                                    .CommissionValue = Cast.ToDouble(dsAgentCommissions.Tables(0).Rows(icount).Item("commission_value"), 0)
                                End If
                                .IsAmended = Cast.ToBoolean(dsAgentCommissions.Tables(0).Rows(icount).Item("is_amended"), False)
                                .OverRideReason = Cast.ToString(dsAgentCommissions.Tables(0).Rows(icount).Item("override_reason"), Nothing)
                                .PerilType = Cast.ToInt32(dsAgentCommissions.Tables(0).Rows(icount).Item("peril_type_id"), 0)
                            End With
                        Next
                        dTotalNetPremiumLeadAgent = dTotalCommissionLeadAgent + dTotalTaxLeadAgent
                        dTotalNetPremiumSubAgent = dTotalCommissionSubAgent + dTotalTaxSubAgent
                    End If
                End If
            End Using
            With oGetAgentCommissionResponse
                .LeadAgentNet = dTotalNetPremiumLeadAgent
                .LeadAgentTotalCommission = dTotalCommissionLeadAgent
                .LeadAgentTotalTax = dTotalTaxLeadAgent
                .SubAgentNet = dTotalNetPremiumSubAgent
                .SubAgentTotalCommission = dTotalCommissionSubAgent
                .SubAgentTotalTax = dTotalTaxSubAgent
            End With
        End If
        Return oGetAgentCommissionResponse
    End Function

