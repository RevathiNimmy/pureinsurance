    Private Function TransferPolicy(ByVal Con As SiriusConnection, ByVal request As BaseRunPortfolioTransferRequestType) As Integer

        Dim nReturn As Integer
        Dim oSIRRIPortfolioTransfer As bsirriportfoliotransfer.Business = Nothing
        Dim bSuccess As Boolean = False
        Dim sMessage As String

        Try

            oSIRRIPortfolioTransfer = New bsirriportfoliotransfer.Business

            InitialiseSBOObject(Con, oSIRRIPortfolioTransfer, _SiriusUser, request.BranchCode, "bSIRRIPortfolioTransfer.Business")

            nReturn = oSIRRIPortfolioTransfer.ProcessSinglePolicy(nInsuranceFileCnt:=request.InsuranceFileKey,
                                           dtTransferDate:=request.TransferDate,
                                           dtStartDate:=request.StartDate,
                                           dtEndDate:=request.EndDate,
                                           dtInceptionDate:=request.InceptionDate,
                                           nProductId:=request.ProductKey,
                                           sInsuranceFileType:=request.InsuranceFileType,
                                           bSkipPosting:=request.SkipPostings,
                                           r_sMessage:=sMessage)

            If nReturn <> PMEReturnCode.PMTrue Then

                If Not (request.InsuranceFileType = "QUOTE" OrElse request.InsuranceFileType = "RENEWAL" OrElse request.InsuranceFileType = "MTAQUOTE" _
                        OrElse request.InsuranceFileType = "MTAQTETEMP" OrElse request.InsuranceFileType = "MTAQREINS") Then
                    nReturn = CInt(oSIRRIPortfolioTransfer.InsertInsFilePTRIUsage(v_lInsFileCnt:=request.InsuranceFileKey, v_dtTransferDate:=request.TransferDate))
                    Return PMEReturnCode.PMFalse
                End If

            End If

        Finally
            If oSIRRIPortfolioTransfer IsNot Nothing Then
                oSIRRIPortfolioTransfer.Dispose()
                oSIRRIPortfolioTransfer = Nothing
            End If
        End Try

        Return nReturn

