    ''' <summary>
    ''' This method is used to get the details from a given table with given id
    ''' </summary>
    ''' <param name="con" type="SiriusConnection">the DB connection</param>
    ''' <param name="sTableName" type="String">the table name to be checked</param>
    ''' <param name="sIdFieldName" type="String">the name of the ID column</param>
    ''' <param name="sIdValue" type="String">the actual value of the id</param>
    ''' <param name="o_dsReturnRecord" type="DataSet">output param that will hold the details for the given id</param>
    ''' <returns>true if the id is valid, false otherwise</returns>
    ''' <remarks>Added by Vivek</remarks>
    Friend Overloads Function GetDetailsFromId(ByVal con As SiriusConnection, ByVal sTableName As String, ByVal sIdFieldName As String, ByVal sIdValue As String, Optional ByRef o_dsReturnRecord As DataSet = Nothing) As Boolean

        Dim ds As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetDetailsFromId")

            cmd.AddInParameter("@table_name", SqlDbType.VarChar, 255).Value = sTableName
            cmd.AddInParameter("@id_field", SqlDbType.VarChar, 255).Value = sIdFieldName
            cmd.AddInParameter("@id_value", SqlDbType.VarChar, 25).Value = sIdValue

            ds = con.ExecuteDataSet(cmd, "Details")

            If ds.Tables("Details").Rows.Count = 0 Then
                Return False
            Else
                If o_dsReturnRecord IsNot Nothing Then
                    Dim dv As New DataView(ds.Tables("Details"))
                    o_dsReturnRecord.Tables.Add(dv.ToTable(sTableName))
                End If

                Return True
            End If

        End Using

    End Function


    Friend Sub GetSourceDetails(ByVal sBranchCode As String,
    ByRef lSourceId As Integer,
    ByRef lCurrencyId As Integer)

        Dim GetListOutput As Core.GetListOutput
        Dim CacheKey As String = String.Empty

        GetListOutput = New Core.GetListOutput

        _oCache = HttpRuntime.Cache()

        ' Generate a Cache Key using the ListCode appended with the List Type
        ' as we may have two lists with the same name (but differing types)
        ' TO DO: Convert this to string builder
        CacheKey = "CUSTOMLISTUSERSOURCE"

        ' Try to get the Full List from the Cache
        GetListOutput.ListItems = CType(_oCache(CacheKey), DataSet)

        ' Get the Dataset if we don't already have it
        If GetListOutput.ListItems Is Nothing Then
            Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
                Using Cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_User_Source_Details")
                    GetListOutput.ListItems = con.ExecuteDataSet(Cmd, "UserSourceDetails")
                End Using
            End Using
        End If

        If (Not GetListOutput.ListItems Is Nothing) Then
            GetListOutput.ListItems.Tables(0).DefaultView.AllowEdit = False
            ' Add the dataset into the cache
            _oCache.Insert(CacheKey, GetListOutput.ListItems)

        End If

        Dim ds As DataSet = Nothing
        Dim bFoundSource As Boolean = False

        ds = GetListOutput.ListItems

        ' for each table ( there will be only one )
        For Each dt As DataTable In ds.Tables

            ' for each row 
            For Each dr As DataRow In dt.Rows

                ' attempt to find the branch we are looking for
                If Cast.ToStringTrim(dr.Item("code")).ToUpper.Trim() = sBranchCode.ToUpper.Trim() Then

                    ' get the source id and currency id
                    lSourceId = Cast.ToInt32(dr.Item("source_id"), 0)
                    lCurrencyId = Cast.ToInt32(dr.Item("base_currency_id"), 0)

                    ' indicate that we have found the record and 
                    ' so can safely exit the for loop
                    bFoundSource = True
                    Exit For
                End If

            Next

            If bFoundSource Then
                Exit For
            End If
        Next

    End Sub

