    ''' <summary>
    '''This method sends the request object values to the Stored Procedure and gets the Event Note detail
    '''</summary>
    '''<param name="oGetEventNoteRequest" type="BaseGetEventNoteRequestType"></param>
    ''' <returns>An object of type SiriusFS.SAM.SFI.BaseImplementationTypes.BaseGetEventNoteResponseType</returns>
    '''<remarks></remarks>
    Public Overloads Function GetEventNote(ByVal oGetEventNoteRequest As BaseGetEventNoteRequestType) As BaseGetEventNoteResponseType

        Dim oGetEventNoteResponse As New BaseGetEventNoteResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetEventNoteRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetEventNoteRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetEventNoteResponse = New SAMForInsuranceV2ImplementationTypes.GetEventNoteResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetEventNoteRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If oGetEventNoteRequest.EventKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "EventKey")
        End If
        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsEventNote As DataSet = Nothing
        Dim dtEventNote As New DataTable
        Dim icount As Integer

        Using conEventNote As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmdEventNote As SiriusCommand = SiriusCommand.FromProcedure("spe_Event_Public_Text_saa")
                cmdEventNote.AddInParameter("@event_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetEventNoteRequest.EventKey)
                dsEventNote = conEventNote.ExecuteDataSet(cmdEventNote, "Row")
            End Using
        End Using

        If dsEventNote IsNot Nothing AndAlso (dsEventNote.Tables.Count >= 1) Then

            icount = dsEventNote.Tables(0).Rows.Count - 1

            dtEventNote.TableName = "Row"
            dtEventNote.Columns.Add("event_cnt", System.Type.GetType("System.Int32"))
            dtEventNote.Columns.Add("event_public_text_id", System.Type.GetType("System.Int32"))
            dtEventNote.Columns.Add("text_line", System.Type.GetType("System.String"))

            While icount > 0

                dtEventNote.ImportRow(dsEventNote.Tables(0).Rows(icount - 1))
                dtEventNote.ImportRow(dsEventNote.Tables(0).Rows(icount))
                icount -= 2
            End While
        End If

        'Populate the XML Document here with the dsEventNote information
        If dsEventNote IsNot Nothing AndAlso (dsEventNote.Tables.Count >= 1) Then
            If (dsEventNote.Tables(0).Rows.Count >= 1) Then

                dsEventNote.DataSetName = "BaseGetEventNoteResponseTypeEventNotes"
                dsEventNote.Tables.RemoveAt(0)
                dsEventNote.Tables.Add(dtEventNote)
                With dsEventNote.Tables(0)
                    .TableName = "Row"
                    .Columns("event_cnt").ColumnName = "EventKey"
                    .Columns("event_public_text_id").ColumnName = "EventPublicTextKey"
                    .Columns("text_line").ColumnName = "EventText"
                End With

                Dim xmlDoc As New System.Xml.XmlDocument
                If oGetEventNoteRequest.WCFSecurityToken = "" Then
                    xmlDoc.LoadXml(dsEventNote.GetXml)
                    oGetEventNoteResponse.EventNotesDataset = xmlDoc.DocumentElement()
                End If

                oGetEventNoteResponse.ResultData = dsEventNote

            End If
        End If

        Return oGetEventNoteResponse
    End Function

