    Private Overloads Sub ReplacePartyContact(ByVal request As BaseReplacePartyContactRequestType, ByVal con As SiriusConnection)
        Try
            Dim baseContact As BaseContactType
            con.BeginTransaction()
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Del_Party_Contact")
                cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = request.PartyKey
                con.ExecuteNonQuery(cmd)
            End Using
            For Each baseContact In request.Contacts
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Add_Party_Contact")
                    cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = request.PartyKey
                    cmd.AddInParameter("@source_id", SqlDbType.Int).Value = request.SourceId
                    cmd.AddInParameter("@created_by_id", SqlDbType.Int).Value = request.UserId
                    If baseContact.ContactTypeCode = ContactTypeType.OTHER Then
                        cmd.AddInParameter("@contact_type_id", SqlDbType.Int).Value = GetcontactTypeID(baseContact.ContactTypeCode, baseContact.OtherContactTypeCode)
                    Else
                        cmd.AddInParameter("@contact_type_id", SqlDbType.Int).Value = GetcontactTypeID(baseContact.ContactTypeCode)
                    End If
                    cmd.AddInParameter("@area_code", SqlDbType.VarChar).Value = baseContact.AreaCode
                    cmd.AddInParameter("@number", SqlDbType.VarChar).Value = baseContact.ContactDetail.Item
                    cmd.AddInParameter("@description", SqlDbType.VarChar).Value = baseContact.Description
                    con.ExecuteNonQuery(cmd)
                End Using
            Next
            con.CommitTransaction()
        Catch ex As Exception
            con.RollbackTransaction()
            Throw
        End Try
    End Sub

