    ''' <summary>
    '''This method sends the request to the function 
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="oGetTransactionDetailsRequest" type="BaseGetTransactionDetailsRequestType"></param>
    '''<remarks></remarks>
    Public Overloads Function GetTransactionDetails(ByVal con As SiriusConnection, ByVal oGetTransactionDetailsRequest As BaseGetTransactionDetailsRequestType, Optional ByRef dsTransactionDetailsResponse As DataSet = Nothing) As BaseGetTransactionDetailsResponseType

        Dim oGetTransactionDetailsResponse As New BaseGetTransactionDetailsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim iSourceId As Integer
        Dim oFindTransaction As bACTFindTransaction.Business = Nothing
        Dim icomReturnValue As Integer
        Dim vResultArray As Object(,) = Nothing
        Dim iRecordCount As Integer
        Dim iAccountKey As Integer
        Dim sAllocationtransdetail As String = String.Empty
        Dim sXML As String = String.Empty
        Dim DocoXML As System.Xml.XmlDocument
        Const sACMethodName As String = "GetTransactionDetails"

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetTransactionDetailsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetTransactionDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetTransactionDetailsResponse = New SAMForInsuranceV2ImplementationTypes.GetTransactionDetailsResponseType
        End If
        'Mandatory validations
        oGetTransactionDetailsRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        If oGetTransactionDetailsRequest.Allocation IsNot Nothing AndAlso oGetTransactionDetailsRequest.Allocation.Row IsNot Nothing Then
            'Mandatory validations
            For iCount As Integer = 0 To oGetTransactionDetailsRequest.Allocation.Row.Length - 1

                If oGetTransactionDetailsRequest.Allocation.Row(iCount).AllocationTransDetailKey = 0 Then
                    oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "AllocationTransDetailKey")
                End If
            Next
            oErrors.CheckForErrors()
        End If
        'Data validations
        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                     PMLookupTable.Source, oGetTransactionDetailsRequest.BranchCode, "Source", oErrors)

        If oGetTransactionDetailsRequest.AccountKeySpecified = True Then
            iAccountKey = GetAndValidateSpecifiedTableCode(con, "account",
                                "account_id", "account_id", oGetTransactionDetailsRequest.AccountKey.ToString(), oErrors, "account_id")
            oGetTransactionDetailsRequest.AccountKey = iAccountKey
            oErrors.CheckForErrors()
        ElseIf Trim(oGetTransactionDetailsRequest.ShortCode) <> String.Empty Then
            iAccountKey = GetAndValidateSpecifiedTableCode(con, "account",
                               "account_id", "short_code", oGetTransactionDetailsRequest.ShortCode, oErrors, "account_id")

            'If we get InsuranceRef from NewPlan screen, by now iAccountKey = client account key, ovewrite it if we get an agent account key
            If oGetTransactionDetailsRequest.InsuranceRef <> String.Empty AndAlso oGetTransactionDetailsRequest.AccountKeySpecified = False _
                            AndAlso oGetTransactionDetailsRequest.AccountKey = 0 Then

                Dim dtTable As DataTable = Nothing
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_GetLeadAgentForPolicy")
                    cmd.AddInParameter("@InsuranceRef", SqlDbType.VarChar, 30).Value = CStr(oGetTransactionDetailsRequest.InsuranceRef)
                    dtTable = con.ExecuteDataTable(cmd)
                End Using

                Dim nPartyCnt As Integer = 0
                If dtTable IsNot Nothing AndAlso
                    dtTable.Rows IsNot Nothing AndAlso
                    dtTable.Rows.Count > 0 AndAlso Not (Cast.ToString(dtTable.Rows(0).Item("code"), "").Trim() = "Comm Acc" OrElse (Cast.ToString(dtTable.Rows(0).Item("code"), "").ToUpper().Trim() = "INTERMED") AndAlso Convert.ToBoolean(dtTable.Rows(0).Item("IsTransactOnAgent")) = False) Then 'commission agent so debt is on the client
                    nPartyCnt = Cast.ToInt32(dtTable.Rows(0).Item("lead_agent_cnt"), 0)

                End If
                dtTable = Nothing

                If nPartyCnt > 0 Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Select_AccountKey")
                        cmd.AddInParameter("@account_key", SqlDbType.Int).Value = CInt(nPartyCnt)
                        dtTable = con.ExecuteDataTable(cmd)
                    End Using

                    If dtTable IsNot Nothing AndAlso
                        dtTable.Rows IsNot Nothing AndAlso
                        dtTable.Rows.Count > 0 Then

                        iAccountKey = Cast.ToInt32(dtTable.Rows(0).Item("account_id"), 0)
                        dtTable = Nothing
                    End If
                End If

            End If
            oGetTransactionDetailsRequest.AccountKey = iAccountKey
            oErrors.CheckForErrors()
        Else
            iAccountKey = Nothing
        End If
        'This is For Lookup Validations
        If oGetTransactionDetailsRequest.Allocation IsNot Nothing AndAlso oGetTransactionDetailsRequest.Allocation.Row IsNot Nothing Then
            For iCount As Integer = 0 To oGetTransactionDetailsRequest.Allocation.Row.Length - 1
                GetAndValidateSpecifiedTableCode(con, "transdetail",
                     "transdetail_id", "transdetail_id", oGetTransactionDetailsRequest.Allocation.Row(iCount).AllocationTransDetailKey.ToString(), oErrors, "transdetail_id")

            Next
            oErrors.CheckForErrors()
        End If
        Dim sRollUp As String
        Dim bRollUp As Boolean
        Dim iCount1 As Integer
        Dim vTransIds(,) As Object

        oCoreBusiness.GetSystemOption(oGetTransactionDetailsRequest.BranchCode, 1031, sRollUp)
        If sRollUp <> "1" Then
            bRollUp = False
        Else
            bRollUp = True
        End If
        oFindTransaction = New bACTFindTransaction.Business
        InitialiseSBOObject(con, oFindTransaction, _SiriusUser, "bACTFindTransaction.Business")
        If oGetTransactionDetailsRequest.Allocation IsNot Nothing AndAlso oGetTransactionDetailsRequest.Allocation.Row IsNot Nothing Then
            If bRollUp = False Then
                If oGetTransactionDetailsRequest.Allocation.Row.Length = 1 Then
                    sAllocationtransdetail = oGetTransactionDetailsRequest.Allocation.Row(0).AllocationTransDetailKey.ToString()
                Else
                    For iCount As Integer = 0 To oGetTransactionDetailsRequest.Allocation.Row.Length - 1
                        If iCount = 0 Then
                            sAllocationtransdetail = oGetTransactionDetailsRequest.Allocation.Row(iCount).AllocationTransDetailKey.ToString()
                        Else
                            sAllocationtransdetail = sAllocationtransdetail & "," & oGetTransactionDetailsRequest.Allocation.Row(iCount).AllocationTransDetailKey.ToString()
                        End If
                    Next
                End If
            Else
                For iCount As Integer = 0 To oGetTransactionDetailsRequest.Allocation.Row.Length - 1
                    icomReturnValue = oFindTransaction.GetAllTransdetails(v_lTransDetailId:=oGetTransactionDetailsRequest.Allocation.Row(iCount).AllocationTransDetailKey,
                                                                               r_vTransdetails:=vResultArray)

                    If icomReturnValue <> PMEReturnCode.PMTrue AndAlso icomReturnValue <> PMReturnCode.PMNotFound Then
                        RaiseComMethodException("bACTFindTransaction.Business.GetAllTransdetails", icomReturnValue)
                    End If
                    vTransIds = CType(vResultArray, Object(,))
                    For iCount1 = 0 To vTransIds.GetUpperBound(1)
                        If sAllocationtransdetail = "" Then
                            sAllocationtransdetail = vTransIds(0, iCount1).ToString
                        Else
                            sAllocationtransdetail = sAllocationtransdetail & "," & vTransIds(0, iCount1).ToString
                        End If
                    Next
                Next
            End If
        End If

        With oGetTransactionDetailsRequest
            If (oGetTransactionDetailsRequest.AccountKeySpecified = True) OrElse Trim(oGetTransactionDetailsRequest.ShortCode) <> String.Empty Then
                iAccountKey = oGetTransactionDetailsRequest.AccountKey
            Else
                iAccountKey = Nothing
            End If
            icomReturnValue = oFindTransaction.SelectTransQuery(r_vResultArray:=vResultArray,
                                                            r_lNumberOfRecords:=iRecordCount,
                                                            v_iCompanyID:=CType(iSourceId, Short),
                                                             v_vAccountID:=iAccountKey,
                                                            v_vTransDetailIDs:=sAllocationtransdetail,
                                                            v_bIncludeReversedTrans:=oGetTransactionDetailsRequest.IncludeReversedTran,
                                                            v_vDateTo:=oGetTransactionDetailsRequest.AccountingDate,
                                                            v_vInsuranceRef:=oGetTransactionDetailsRequest.InsuranceRef,
                                                            v_vIsNewPF:=IIf(oGetTransactionDetailsRequest.IsNewPF = False, 0, 1),
                                                            v_vOutstandingOnly:=IIf(oGetTransactionDetailsRequest.IsOutstandingOnly = False, 0, 1)
                                                            )
        End With

        If icomReturnValue <> PMEReturnCode.PMTrue AndAlso icomReturnValue <> PMReturnCode.PMNotFound Then
            RaiseComMethodException("bACTFindTransaction.Business.SelectTransQuery", icomReturnValue)
        End If

        sXML = String.Empty
        DocoXML = New System.Xml.XmlDocument

        If vResultArray IsNot Nothing Then
            Try
                Dim dsTransaction As DataSet = Nothing
                Dim dsResultantTransaction As New DataSet
                dsTransaction = Utilities.ArrayToDataSet(vResultArray, " BaseGetTransactionDetailsResponseTypeTransactions")

                If dsTransaction IsNot Nothing AndAlso dsTransaction.Tables.Count > 0 AndAlso dsTransaction.Tables(0).Rows.Count > 0 Then
                    With dsTransaction.Tables(0)
                        dsResultantTransaction.Tables.Add()
                        dsResultantTransaction.Tables(0).Columns.Add("TransDetailKey", GetType(System.Int32))
                        dsResultantTransaction.Tables(0).Columns.Add("DocRef", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("AltRef", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("EffectiveDate", GetType(System.DateTime))
                        dsResultantTransaction.Tables(0).Columns.Add("TransDate", GetType(System.DateTime))
                        dsResultantTransaction.Tables(0).Columns.Add("MediaType", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("Amount", GetType(System.Decimal))
                        dsResultantTransaction.Tables(0).Columns.Add("OutstandingAmount", GetType(System.Decimal))
                        dsResultantTransaction.Tables(0).Columns.Add("MediaRef", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("Accountkey", GetType(System.Int32))
                        dsResultantTransaction.Tables(0).Columns.Add("AccountCode", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("Currency", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("CurrencyCode", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("TaxBand", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("TransactionCurrenciesAmount", GetType(System.Decimal))
                        dsResultantTransaction.Tables(0).Columns.Add("TransactionCurrency", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("CurrencyDiff", GetType(System.Decimal))
                        dsResultantTransaction.Tables(0).Columns.Add("AllocationTimeStamp", GetType(System.Byte()))
                        dsResultantTransaction.Tables(0).Columns.Add("DueDate", GetType(System.DateTime))
                        dsResultantTransaction.Tables(0).Columns.Add("SourceID", GetType(System.Int32))
                        dsResultantTransaction.Tables(0).Columns.Add("PeriodName", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("DocType", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("DoctypeGroup", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("PrimarySettled", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("InsuranceRef", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("Spare", GetType(System.String))
                        dsResultantTransaction.Tables(0).Columns.Add("DocTypeID", GetType(System.Int32))
                        dsResultantTransaction.Tables(0).Columns.Add("InsuranceFileCnt", GetType(System.Int32))
                        dsResultantTransaction.Tables(0).Columns.Add("TransactionCurrencyCode", GetType(System.String))
                        Dim nRowCount As Integer = 0
                        For icount As Integer = 0 To .Rows.Count - 1
                            Dim bExcludeCommissionEntry As Boolean = False
                            If dsTransaction.Tables(0).Rows(icount).Item(13).ToString() = "COMM" AndAlso dsTransaction.Tables(0).Rows(icount).Item(85).ToString() = "1" Then
                                bExcludeCommissionEntry = True
                            End If

                            If Not bExcludeCommissionEntry Then
                                dsResultantTransaction.Tables(0).Rows.Add()
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("TransDetailKey") = .Rows(icount).Item(17)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("DocRef") = .Rows(icount).Item(0)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("AltRef") = .Rows(icount).Item(34)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("EffectiveDate") = .Rows(icount).Item(1)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("TransDate") = .Rows(icount).Item(20)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("MediaType") = .Rows(icount).Item(39)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("Amount") = .Rows(icount).Item(18)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("OutstandingAmount") = .Rows(icount).Item(45)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("MediaRef") = .Rows(icount).Item(13)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("Accountkey") = .Rows(icount).Item(15)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("AccountCode") = .Rows(icount).Item(14)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("Currency") = .Rows(icount).Item(41)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("CurrencyCode") = GetListCodeFromID(Core.STSListType.PMLookup, "Currency", Convert.ToInt32(dsTransaction.Tables(0).Rows(icount).Item(42)))
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("TaxBand") = .Rows(icount).Item(50)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("TransactionCurrenciesAmount") = .Rows(icount).Item(3)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("TransactionCurrency") = .Rows(icount).Item(40)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("CurrencyDiff") = 0
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("SourceID") = .Rows(icount).Item(21)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("PeriodName") = .Rows(icount).Item(2)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("DocType") = .Rows(icount).Item(62)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("DoctypeGroup") = .Rows(icount).Item(63)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("InsuranceRef") = .Rows(icount).Item(8)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("Spare") = CStr(.Rows(icount).Item(13))
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("DocTypeID") = Val(.Rows(icount).Item(6).ToString)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("InsuranceFileCnt") = Val(.Rows(icount).Item(28).ToString)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("TransactionCurrencyCode") = .Rows(icount).Item(81)
                                If IsDate(.Rows(icount).Item(68)) Then
                                    dsResultantTransaction.Tables(0).Rows(nRowCount)("DueDate") = .Rows(icount).Item(68)
                                End If

                                If .Rows(icount).Item(4) IsNot String.Empty Then
                                    If Not CType(.Rows(icount).Item(4), Boolean) Then
                                        dsResultantTransaction.Tables(0).Rows(icount)("PrimarySettled") = "N"
                                    Else
                                        dsResultantTransaction.Tables(0).Rows(icount)("PrimarySettled") = "Y"
                                    End If
                                Else
                                    dsResultantTransaction.Tables(0).Rows(icount)("PrimarySettled") = "N"
                                End If

                                Dim itranskey As Integer
                                itranskey = Convert.ToInt32(dsTransaction.Tables(0).Rows(icount).Item(17))

                                ' Get the Timestamp
                                Dim AnyError As STSErrorType
                                Dim bIsLocked As Boolean

                                AnyError = oCoreBusiness.GetTimestamp(con,
                                                oGetTransactionDetailsRequest.BranchCode,
                                                CoreBusiness.LockName.TransDetailKey,
                                                itranskey,
                                                 oGetTransactionDetailsResponse.AllocationTimeStamp,
                                                bIsLocked)
                                dsResultantTransaction.Tables(0).Rows(nRowCount)("AllocationTimeStamp") = oGetTransactionDetailsResponse.AllocationTimeStamp
                                ' Return AnyErrors
                                If AnyError Is Nothing = False Then
                                    oGetTransactionDetailsResponse.STSError = AnyError
                                End If
                                nRowCount = nRowCount + 1
                            End If
                        Next

                    End With

                End If
                dsResultantTransaction.DataSetName = "BaseGetTransactionDetailsResponseTypeTransactions"
                dsResultantTransaction.Tables(0).TableName = "Row"
                dsTransactionDetailsResponse = dsResultantTransaction

                If oGetTransactionDetailsRequest.WCFSecurityToken = "" Then
                    sXML = dsResultantTransaction.GetXml()
                    DocoXML.LoadXml(sXML)
                    oGetTransactionDetailsResponse.ResultDataset = DocoXML.DocumentElement
                End If

                oGetTransactionDetailsResponse.ResultData = dsResultantTransaction

            Catch ex As Exception
                Dim STSErrorEx As New STSErrorPublisher("Failed to convert XML (ResultArray).", ex)
                STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), sACMethodName, "GetTransactionDetails", True)
                Throw
            Finally
                If oFindTransaction IsNot Nothing Then
                    oFindTransaction.Dispose()
                    oFindTransaction = Nothing
                End If
            End Try
        End If
        Return oGetTransactionDetailsResponse
    End Function

