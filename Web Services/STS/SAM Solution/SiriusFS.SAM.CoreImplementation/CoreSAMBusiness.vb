    ''' <summary>
    ''' To update RI Arrangement line - disabled RI2007
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oUpdateArrangementLinesRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function UpdateArrangementLines(ByVal con As SiriusConnection, ByVal oUpdateArrangementLinesRequest As BaseUpdateArrangementLinesRequestType) As BaseUpdateArrangementLinesResponseType

        Dim oUpdateArrangementLinesResponse As New BaseUpdateArrangementLinesResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim iInsuranceFileCnt As Integer
        Dim iRiskCnt As Integer
        Dim oReinsurance As BaseRiskRIArrangementLineType

        Dim nTypeOfPackage As enumTypeOfPackage

        If oUpdateArrangementLinesRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateArrangementLinesRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateArrangementLinesResponse = New SAMForInsuranceV2ImplementationTypes.UpdateArrangementLinesResponseType
        Else
            Return Nothing
        End If


        ' Check mandatory fields. Madatory keys depends upon the type of action that we are performing row. Place all the mandatory checks in below function only
        oUpdateArrangementLinesRequest.Validate(CObj(oSAMErrorCollection))

        oSAMErrorCollection.CheckForErrors()

        For Each oReinsurance In oUpdateArrangementLinesRequest.RIArrangementLines
            If Not (String.IsNullOrEmpty(oReinsurance.TreatyCode)) Then
                oReinsurance.TreatyID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, "treaty", oReinsurance.TreatyCode, "treaty_id", oSAMErrorCollection)
            End If
        Next
        oSAMErrorCollection.CheckForErrors()


        Dim dsRIDetails As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetRiskFromRIArrangement")
            cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = Cast.ToInt32(oUpdateArrangementLinesRequest.RIArrangementLines(0).RIArrangementKey)
            dsRIDetails = con.ExecuteDataSet(cmd, "row")
            If (dsRIDetails.Tables.Count > 0) Then
                If (dsRIDetails.Tables(0).Rows.Count > 0) Then
                    iInsuranceFileCnt = Cast.ToInt32(dsRIDetails.Tables(0).Rows(0).Item("Insurance_file_cnt"), 0)
                    iRiskCnt = Cast.ToInt32(dsRIDetails.Tables(0).Rows(0).Item("Risk_cnt"), 0)
                End If
            End If
        End Using

        'Delete all partial tax calculations entries
        DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.TREATYPREMIUMTAXTYPE, TaxType.TREATYCOMMISSIONTAXTYPE)
        DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.FACPREMIUMTAXTYPE, TaxType.FACCOMMISSIONTAXTYPE)
        Dim nReasonId As Integer
        nReasonId = Convert.ToInt32(oUpdateArrangementLinesRequest.RIArrangementLines(0).RiOverrideReasonId)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_upd")
            cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = Cast.ToInt32(oUpdateArrangementLinesRequest.RIArrangementLines(0).RIArrangementKey)
            cmd.AddInParameter("@is_modified", SqlDbType.Int).Value = IIf(nReasonId <> 0, 1, 0)
            cmd.AddInParameter("@ri_override_reason_id", SqlDbType.Int).Value = Convert.ToInt32(oUpdateArrangementLinesRequest.RIArrangementLines(0).RiOverrideReasonId)
            con.ExecuteNonQuery(cmd)
        End Using

        For Each oReinsurance In oUpdateArrangementLinesRequest.RIArrangementLines

            'Delete all partial tax calculations entries
            DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.TREATYPREMIUMTAXTYPE, TaxType.TREATYCOMMISSIONTAXTYPE, oReinsurance.RIArrangementLineKey)
            DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.FACPREMIUMTAXTYPE, TaxType.FACCOMMISSIONTAXTYPE, oReinsurance.RIArrangementLineKey)

            If oReinsurance.ActionType = RowAction.EditRow Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_upd")
                    cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                    cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = oReinsurance.ThisSharePercent
                    cmd.AddInParameter("@premium_percent", SqlDbType.Float).Value = oReinsurance.PremiumPercent
                    cmd.AddInParameter("@commission_percent", SqlDbType.Float).Value = oReinsurance.CommissionPercent
                    cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.AgreementCode
                    cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.SumInsured
                    cmd.AddInParameter("@premium_value", SqlDbType.Money).Value = oReinsurance.PremiumValue
                    cmd.AddInParameter("@commission_value", SqlDbType.Money).Value = oReinsurance.CommissionValue
                    cmd.AddInParameter("@premium_tax", SqlDbType.Money).Value = oReinsurance.PremiumTax
                    cmd.AddInParameter("@commission_tax", SqlDbType.Money).Value = oReinsurance.CommissionTax
                    cmd.AddInParameter("@is_commission_modified", SqlDbType.Int).Value = IIf(oReinsurance.IsCommissionModified, 1, 0)
                    con.ExecuteNonQuery(cmd)
                End Using
            ElseIf oReinsurance.ActionType = RowAction.AddRow Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_add")
                    cmd.AddOutParameter("@ri_arrangement_line_id", SqlDbType.Int)
                    cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oReinsurance.RIArrangementKey
                    cmd.AddInParameter("@type", SqlDbType.VarChar, 3).Value = oReinsurance.Type
                    cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = IIf(oReinsurance.TreatyID = 0, Nothing, oReinsurance.TreatyID)
                    cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = IIf(oReinsurance.PartyKey = 0, Nothing, oReinsurance.PartyKey)
                    cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = oReinsurance.DefaultSharePercent
                    cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = oReinsurance.ThisSharePercent
                    cmd.AddInParameter("@premium_percent", SqlDbType.Float).Value = oReinsurance.PremiumPercent
                    cmd.AddInParameter("@commission_percent", SqlDbType.Float).Value = oReinsurance.CommissionPercent
                    cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.AgreementCode
                    cmd.AddInParameter("@priority", SqlDbType.Int).Value = oReinsurance.Priority
                    cmd.AddInParameter("@number_of_lines", SqlDbType.Int).Value = oReinsurance.NumberOfLines
                    cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                    cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.SumInsured
                    cmd.AddInParameter("@premium_value", SqlDbType.Money).Value = oReinsurance.PremiumValue
                    cmd.AddInParameter("@commission_value", SqlDbType.Money).Value = oReinsurance.CommissionValue
                    cmd.AddInParameter("@premium_tax", SqlDbType.Money).Value = oReinsurance.PremiumTax
                    cmd.AddInParameter("@commission_tax", SqlDbType.Money).Value = oReinsurance.CommissionTax
                    cmd.AddInParameter("@is_commission_modified", SqlDbType.Int).Value = IIf(oReinsurance.IsCommissionModified, 1, 0)
                    con.ExecuteNonQuery(cmd)

                    oReinsurance.RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)
                End Using

            ElseIf oReinsurance.ActionType = RowAction.DeleteRow Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_del")
                    cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                    con.ExecuteNonQuery(cmd)
                End Using
            End If
            If oReinsurance.ActionType <> RowAction.DeleteRow Then
                If oReinsurance.Type = "F" Then
                    If oReinsurance.ActionType = RowAction.EditRow Then
                        DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.TREATYPREMIUMTAXTYPE, TaxType.TREATYCOMMISSIONTAXTYPE, oReinsurance.RIArrangementLineKey)
                        DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.FACPREMIUMTAXTYPE, TaxType.FACCOMMISSIONTAXTYPE, oReinsurance.RIArrangementLineKey)
                    End If
                    CalculateFACTax(con, iRiskCnt, iInsuranceFileCnt, oReinsurance)

                Else
                    If oReinsurance.ActionType = RowAction.EditRow Then
                        DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.TREATYPREMIUMTAXTYPE, TaxType.TREATYCOMMISSIONTAXTYPE, oReinsurance.RIArrangementLineKey)
                    End If
                    CalculateTreatyTax(con, iRiskCnt, iInsuranceFileCnt, oReinsurance)
                End If
            End If
        Next
        UpdatePremiumPercent(con, oUpdateArrangementLinesRequest)
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_UpdateRiskStatus")
            cmd.AddInParameter("@riskCnt", SqlDbType.Int).Value = iRiskCnt
            con.ExecuteNonQuery(cmd)
        End Using


        Return oUpdateArrangementLinesResponse

    End Function

