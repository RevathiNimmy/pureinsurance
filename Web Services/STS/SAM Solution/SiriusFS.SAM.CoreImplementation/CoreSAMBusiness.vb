    ''' <summary>  
    ''' Find the Policy
    ''' </summary>  
    ''' <param name="oRequest">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseFindPolicyRequestType</param>  
    ''' <param name="con">An object of type SiriusConnection</param>  
#Region "ProcessList"
    Public Overloads Function ProcessList(ByRef con As SiriusConnection, ByVal oRequest As BaseProcessListRequestType) As BaseProcessListResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseProcessListResponseType
        Dim nTypeOfPackage As enumTypeOfPackage

        Dim sResponse As String = ""
        Try
            If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ProcessListRequestType) Then
                nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
                oResponse = New SAMForInsuranceV2ImplementationTypes.ProcessListResponseType
            Else
                nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            End If

            Dim oSAMErrorCollection As New SAMErrorCollection

            '*******************
            ' STRUCTURE VALIDATION
            '*******************
            oRequest.Validate(CType(oSAMErrorCollection, Object))

            oSAMErrorCollection.CheckForErrors()

            '*******************
            ' DATA VALIDATION
            '*******************
            ' Validate inputs
            If String.IsNullOrEmpty(oRequest.TableName) Then
                sResponse = "Tablename is Mandatory"
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ListTypeNotFound, sResponse, sResponse)
            End If

            If String.IsNullOrEmpty(oRequest.TableData) Then
                sResponse = "TableData is Mandatory"
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ListTypeNotFound, sResponse, "TableData is Mandatory")
            End If
            ' validate the branch code
            If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
                oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
            End If
            oSAMErrorCollection.CheckForErrors()

            Dim dsLookup As DataSet = New DataSet
            'Validate Table name and Get the Existing Data
            Try
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetLookupData")
                    cmd.AddInParameter("@Table_Name", SqlDbType.VarChar).Value = oRequest.TableName
                    dsLookup = con.ExecuteDataSet(cmd, "lookup")
                End Using
            Catch ex As Exception
                sResponse = "Lookup table not found."
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "Lookup")
            End Try
            oSAMErrorCollection.CheckForErrors()

            'Load the XML in DataSet
            Dim dsInput As New DataSet()
            Dim dsFK As New DataSet()
            Dim ReferencedTableName As String = ""
            Dim sErrorresponse As String = ""

            dsInput.ReadXml(XmlReader.Create(New StringReader(oRequest.TableData)))
            'Remove the Empry Data
            RemoveEmptyRows(dsInput)

            ''Iterate the columns to check that the input columns are valid and exists in table
            For Each cols As DataColumn In dsInput.Tables(0).Columns
                If IsFKColumn(cols.ColumnName) Then 'Column is the FK

                    'Get FK column Name 
                    If Not dsLookup.Tables("lookup").Columns.Contains(FKColumnName(cols.ColumnName)) Then
                        sResponse = "Invalid Column " & cols.ColumnName
                    End If
                Else
                    If Not dsLookup.Tables("lookup").Columns.Contains(cols.ColumnName) Then
                        sResponse = "Invalid Column " & cols.ColumnName
                    End If
                End If
            Next


            Dim dv As DataView = New DataView(dsInput.Tables(0))
            Dim dtLookupCodes As DataTable = dv.ToTable(True, "Code")

            'Generate/Get the CaptionId for the Code
            Dim dtCaptions As DataTable
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_CaptionId")
                Dim tvpParam As SqlParameter = cmd.Parameters.AddWithValue("@CodeTVP", dtLookupCodes)
                tvpParam.SqlDbType = SqlDbType.Structured
                'tvpParam.TypeName = "dbo.CategoryTableType"
                dtCaptions = con.ExecuteDataTable(cmd)
            End Using
            'Add the Primary key to datatable.
            dtCaptions.PrimaryKey = New DataColumn() {dtCaptions.Columns("Code")}

            'Create the SQL Statement
            Dim sqlList As List(Of String) = CreateSql(dsInput, dsLookup, dtCaptions, oRequest.TableName, con)

            'Execute the SQLs
            Dim noofAffectedRows As Integer = 0
            For Each sql As String In sqlList
                Using cmd As SiriusCommand = SiriusCommand.FromText(sql)
                    noofAffectedRows += con.ExecuteNonQuery(cmd)
                End Using
            Next

            sResponse = "No of Effected Rows " + noofAffectedRows.ToString
            oResponse.Status = True
            oResponse.ResponseMessage = sResponse
        Catch ex As Exception
            oResponse.Status = False
            oResponse.ResponseMessage = ex.Message
            Return oResponse
        Finally

        End Try

        Return oResponse
    End Function
    ''' <summary>
    ''' Prepares the List of SQL Statement
    ''' </summary>
    ''' <param name="dsInput">Input Data</param>
    ''' <param name="dsLookup">Lookup Data</param>
    ''' <param name="dtCaptions"></param>
    ''' <param name="TableName"></param>
    ''' <param name="con"></param>
    ''' <returns></returns>
    Private Function CreateSql(dsInput As DataSet, dsLookup As DataSet, dtCaptions As DataTable, TableName As String, con As SiriusConnection) As List(Of String)
        Dim sqlList As New List(Of String)

        Dim sqlUpdate As StringBuilder
        Dim sqlInsert As StringBuilder = New StringBuilder("INSERT INTO " & TableName)
        Dim ColumnList As StringBuilder = New StringBuilder("")
        Dim hasFKColumn As Boolean = False
        Dim errorMessage As String = "", foreignkeyColumnName As String = "", referencedTableName As String = "", referencedColumnName As String = ""
        Dim dsFK As New DataSet
        Dim bIdentityExistsOnTable As Boolean = IdentityExistsonTable(con, TableName)

        Dim maxIdValue As Integer = 0

        'Create the ColumnList
        For Each column As DataColumn In dsInput.Tables(0).Columns
            If Not IsFKColumn(column.ColumnName) Then
                ColumnList.Append(column.ColumnName + ",")
            Else
                hasFKColumn = True
                'Get the Data from Referenced Tables. This data is Required to create the Insert SQL Statement
                Dim dtFK As DataTable = GetFKData(con, column.ColumnName, foreignkeyColumnName, referencedColumnName, referencedTableName, errorMessage)

                If (errorMessage = "") Then
                    If dsFK.Tables.Contains(referencedTableName) = False Then
                        dsFK.Tables.Add(dtFK)
                    End If
                    ColumnList.Append(foreignkeyColumnName + ",")
                End If
            End If
        Next
        ColumnList.Append("Caption_id, is_deleted")

        'If Identity does not exists on table 
        If bIdentityExistsOnTable = False Then
            ColumnList.Append(", " & TableName.Trim & "_id")
            maxIdValue = Convert.ToInt32(dsLookup.Tables(0).Select(TableName & "_id =max(" & TableName & "_id)")(0)(0))
        End If

        sqlInsert = sqlInsert.Append("(" + ColumnList.ToString + ") VALUES ")

        Dim insertStatementExists As Boolean = False

        For Each row As DataRow In dsInput.Tables(0).Rows
            If Not IsDBNull(row("Code")) Then

                If dsLookup.Tables(0).Select("Code = '" + row("Code").ToString + "'").Length > 0 Then
                    'Data Already exists in table. So, Create the Update statement
                    sqlUpdate = New StringBuilder("Update " & TableName & " SET ")

                    For Each col As DataColumn In dsInput.Tables(0).Columns
                        If IsFKColumn(col.ColumnName) = False Then
                            sqlUpdate.Append(col.ColumnName + "='" + row.Item(col.ColumnName).ToString.Trim + "',")
                        Else
                            GetForeignKeyDetails(col.ColumnName, foreignkeyColumnName, referencedColumnName, referencedTableName)
                            Dim rows() As DataRow = dsFK.Tables(referencedTableName).Select(referencedColumnName & " = '" & row.Item(col.ColumnName).ToString & "'")
                            If rows.Length = 0 Then
                                sqlUpdate.Append(foreignkeyColumnName + "= NULL,")
                            Else
                                sqlUpdate.Append(foreignkeyColumnName + "='" + rows(0).Item(referencedTableName & "_id").ToString + "',")
                            End If

                        End If
                    Next
                    sqlUpdate.Replace(",", "", sqlUpdate.Length - 1, 1)
                    sqlUpdate.Append(" WHERE Code = '" + row("Code").ToString + "'")
                    sqlList.Add(sqlUpdate.ToString)
                Else
                    insertStatementExists = True
                    Dim sqlValues As StringBuilder = New StringBuilder("(")
                    For Each col As DataColumn In dsInput.Tables(0).Columns
                        'If the Column is a Foreign Key Column, then get the value from the referenced table based on the FK Column
                        If IsFKColumn(col.ColumnName) Then
                            'Get the Data for Foreign Key
                            GetForeignKeyDetails(col.ColumnName, foreignkeyColumnName, referencedColumnName, referencedTableName)
                            Dim rows() As DataRow = dsFK.Tables(referencedTableName).Select(referencedColumnName & " = '" & row.Item(col.ColumnName).ToString & "'")
                            If rows.Length = 0 Then
                                sqlValues.Append("NULL" + ",")
                            Else
                                sqlValues.Append(rows(0).Item(referencedTableName & "_id").ToString + ",")
                            End If
                        Else
                            sqlValues.Append("'" & row.Item(col.ColumnName).ToString.Trim + "',")
                        End If

                    Next
                    'get the CaptionId
                    Dim rowCaption() As DataRow = dtCaptions.Select("Code = '" + row("Code").ToString + "'")
                    sqlValues.Append(rowCaption(0).Item("Caption_id").ToString)
                    sqlValues.Append("," & 0)  '0 for is_deleted
                    If bIdentityExistsOnTable = False Then
                        maxIdValue += 1
                        sqlValues.Append("," & maxIdValue)
                    End If

                    sqlValues.Append(")")
                    sqlInsert.Append(sqlValues.ToString + ",")

                End If
            End If
        Next

        If insertStatementExists Then
            sqlList.Add(sqlInsert.ToString.Substring(0, sqlInsert.Length - 1))
        End If

        Return sqlList
    End Function
    Private Function GetFKData(con As SiriusConnection, ColumnName As String, ByRef fkColumnName As String, ByRef referencedColumnName As String, ByRef referencedTableName As String, ByRef ErrorResponse As String) As DataTable
        'Get the FK table Data
        Dim arrfk() As String = Split(ColumnName, "__")
        If arrfk.Length < 4 Then
            ErrorResponse = "Invalid details for FK Constraint :" & ColumnName
            Return Nothing
        End If
        referencedColumnName = arrfk(3)
        referencedTableName = arrfk(2)
        fkColumnName = arrfk(0)
        Return GetlookUpData(con:=con, TableName:=referencedTableName)

    End Function
    Private Function GetlookUpData(con As SiriusConnection, TableName As String) As DataTable
        Dim dtLookup As DataTable

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetLookupData")
            cmd.AddInParameter("@Table_Name", SqlDbType.VarChar).Value = TableName
            dtLookup = con.ExecuteDataTable(cmd)
            dtLookup.TableName = TableName
        End Using
        Return dtLookup
    End Function
    ''' <summary>
    ''' Determines that the Column is a Foreign Key Column
    ''' </summary>
    ''' <param name="ColumnName"></param>
    ''' <returns></returns>
    Private Function IsFKColumn(ColumnName As String) As Boolean
        Dim output As Boolean
        If ColumnName Like "*__FK__*" Then
            output = True
        Else
            output = False
        End If
        Return output
    End Function
    ''' <summary>
    ''' Foreign Key Naming Convention
    ''' Primary_Cause_id__FK__Primary_cause__Code
    ''' Column_name__FK__ReferencedTableName_Referenced_column
    ''' </summary>
    ''' <param name="ColumnName"></param>
    ''' <param name="FKColumnName"></param>
    ''' <param name="ReferencedTableColumnName"></param>
    ''' <param name="tableName"></param>

    Private Sub GetForeignKeyDetails(ColumnName As String, ByRef FKColumnName As String, ByRef ReferencedTableColumnName As String, ByRef tableName As String)
        Dim arrfk() As String = Split(ColumnName, "__")
        If arrfk.Length < 4 Then
            FKColumnName = ""
            ReferencedTableColumnName = ""
        Else
            FKColumnName = arrfk(0)
            tableName = arrfk(2)
            ReferencedTableColumnName = arrfk(3)
        End If
    End Sub
    Private Function FKColumnName(ColumnName As String) As String
        Dim arrfk() As String = Split(ColumnName, "__")
        If arrfk.Length < 4 Then
            Return ""
        Else
            Return arrfk(0)
        End If
    End Function
    Private Function IdentityExistsonTable(con As SiriusConnection, tableName As String) As Boolean
        Dim result As DataTable
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CheckIdentityExists")
            cmd.AddInParameter("@tablename", SqlDbType.VarChar).Value = tableName
            result = con.ExecuteDataTable(cmd)
        End Using
        If result.Rows(0).Item(0).ToString = "1" Then
            Return True
        Else
            Return False
        End If
    End Function
    Private Sub RemoveEmptyRows(dsInput As DataSet)
        For i As Integer = 0 To dsInput.Tables(0).Rows.Count - 1
            If dsInput.Tables(0).Rows(i).Item(0).Equals(DBNull.Value) Then
                dsInput.Tables(0).Rows(i).Delete()
                dsInput.Tables(0).AcceptChanges()
            End If
        Next
    End Sub
#End Region

End Class

