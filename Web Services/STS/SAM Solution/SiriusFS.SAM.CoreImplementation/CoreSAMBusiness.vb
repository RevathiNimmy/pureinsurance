        End If

        ' Check mandatory fields
        oGetDMEFolderRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()

        If String.IsNullOrEmpty(oGetDMEFolderRequest.FolderPath) = False Then
            oGetDMEFolderRequest.FolderNum = GetDMEFolderFromPath(con, oGetDMEFolderRequest.FolderPath)
            If oGetDMEFolderRequest.FolderNum = 0 Then
                Return oGetDMEFolderResponse
            End If
        End If

        If oGetDMEFolderRequest.FolderNum > 0 Then
            If CheckUserFolderAccess(con, oGetDMEFolderRequest.FolderNum, _SiriusUser.UserID) = False Then
                oSAMErrorCollection.AddInvalidData(
                                   SAMConstants.SAMInvalidData.UserNotAuthorisedToActOnData,
                                           "User doesn't have access to the folder",
                                                "FolderNum")
                oSAMErrorCollection.CheckForErrors()

            End If
        End If

        Dim dsFolder As DataSet
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetDMESubFolders")
            cmd.AddInParameter("@folder_num", SqlDbType.Int).Value = oGetDMEFolderRequest.FolderNum
            dsFolder = con.ExecuteDataSet(cmd, "Row")
        End Using

        Dim sources As New ArrayList
        Dim dt As DataTable
        Dim validBranch As Boolean
        Dim iLength As Integer
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_pm_get_user_sources")
            cmd.AddInParameter("@UserID", SqlDbType.Int).Value = _SiriusUser.UserID
            dt = con.ExecuteDataTable(cmd)
        End Using
        If (dt.Rows.Count > 0) Then
            For icount As Integer = 0 To dt.Rows.Count - 1
                sources.Add(dt.Rows(icount).Item(0).ToString)
            Next
        End If
        iLength = 0
        If (dsFolder.Tables.Count > 0) Then
            If (dsFolder.Tables(0).Rows.Count > 0) Then
                For icount As Integer = 0 To dsFolder.Tables(0).Rows.Count - 1
                    validBranch = True
                    If Cast.ToInt32(dsFolder.Tables(0).Rows(icount).Item("parent_num"), 0) = 0 And String.IsNullOrEmpty(dsFolder.Tables(0).Rows(icount).Item("ex_code").ToString) = False Then
                        If sources.Contains(dsFolder.Tables(0).Rows(icount).Item("ex_code")) = False Then
                            validBranch = False
                        End If
                    End If
                    If validBranch Then
                        ReDim Preserve oGetDMEFolderResponse.SubFolders(iLength)
                        oGetDMEFolderResponse.SubFolders(iLength) = New BaseDMEFolderType
                        oGetDMEFolderResponse.SubFolders(iLength).FolderNum = Cast.ToInt32(dsFolder.Tables(0).Rows(icount).Item("folder_num"), 0)
                        oGetDMEFolderResponse.SubFolders(iLength).Name = dsFolder.Tables(0).Rows(icount).Item("folder_name").ToString
                        oGetDMEFolderResponse.SubFolders(iLength).ParentNum = Cast.ToInt32(dsFolder.Tables(0).Rows(icount).Item("parent_num"), 0)
                        oGetDMEFolderResponse.SubFolders(iLength).FolderLevel = Cast.ToInt32(dsFolder.Tables(0).Rows(icount).Item("folder_level"), 0)
                        oGetDMEFolderResponse.SubFolders(iLength).ExternalCode = dsFolder.Tables(0).Rows(icount).Item("ex_code").ToString
                        oGetDMEFolderResponse.SubFolders(iLength).CreateDate = Cast.ToDateTime(dsFolder.Tables(0).Rows(icount).Item("create_date"), Date.MinValue)
                        iLength = iLength + 1
                    End If
                Next
            End If
        End If

        If oGetDMEFolderRequest.IncludeFiles Then
            Dim dsDocuments As DataSet
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetDMEFolderDocuments")
                cmd.AddInParameter("@folder_num", SqlDbType.Int).Value = oGetDMEFolderRequest.FolderNum
                dsDocuments = con.ExecuteDataSet(cmd, "Row")
            End Using
            If (dsDocuments.Tables.Count > 0) Then
                If (dsDocuments.Tables(0).Rows.Count > 0) Then
                    For icount As Integer = 0 To dsDocuments.Tables(0).Rows.Count - 1
                        ReDim Preserve oGetDMEFolderResponse.Documents(icount)
                        oGetDMEFolderResponse.Documents(icount) = New BaseDocumentType
                        oGetDMEFolderResponse.Documents(icount).DocNum = Cast.ToInt32(dsDocuments.Tables(0).Rows(icount).Item("doc_num"), 0)
                        oGetDMEFolderResponse.Documents(icount).DocDescription = dsDocuments.Tables(0).Rows(icount).Item("doc_name").ToString
                        oGetDMEFolderResponse.Documents(icount).CreateDate = Cast.ToDateTime(dsDocuments.Tables(0).Rows(icount).Item("create_date"), Date.MinValue)
                        oGetDMEFolderResponse.Documents(icount).FolderNum = oGetDMEFolderRequest.FolderNum
                        oGetDMEFolderResponse.Documents(icount).FolderPath = dsDocuments.Tables(0).Rows(icount).Item("FolderPath").ToString
                        oGetDMEFolderResponse.Documents(icount).DocumentType = GetDMEDocTypeFromCode(dsDocuments.Tables(0).Rows(icount).Item("doc_type").ToString)
                    Next
                End If
            End If
        End If

        Dim dsParentFolder As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetDMEParentFolder")
            cmd.AddInParameter("@folder_num", SqlDbType.Int).Value = oGetDMEFolderRequest.FolderNum
            dsParentFolder = con.ExecuteDataSet(cmd, "Row")
        End Using

        If (dsParentFolder.Tables.Count > 0) Then
            If (dsParentFolder.Tables(0).Rows.Count > 0) Then
                oGetDMEFolderResponse.ParentNum = Cast.ToInt32(dsParentFolder.Tables(0).Rows(0).Item("parent_num"), 0)
            End If
        End If


        Return oGetDMEFolderResponse


    End Function
