    '''<summary>
    ''' This method is used to create postings of reinsurance during portfolio and clone amend process
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="oCreatePostingsForReinsuranceRequestType" type="BaseCreatePostingsForReinsuranceRequestType"></param>    
    '''<returns>BaseCreatePostingsForReinsuranceResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function CreatePostingsForReinsurance(ByVal con As SiriusConnection, ByVal oCreatePostingsForReinsuranceRequestType As BaseCreatePostingsForReinsuranceRequestType) As BaseCreatePostingsForReinsuranceResponseType
        Dim oResponse As New BaseCreatePostingsForReinsuranceResponseType
        Dim nInsuranceFileCnt As Integer
        Dim nReturn As Integer
        Dim sMessage As String
        Dim nInsFilePTRIUsageID As Integer
        Dim dtTransferDate As Date

        dtTransferDate = oCreatePostingsForReinsuranceRequestType.TransactionDate
        nInsuranceFileCnt = oCreatePostingsForReinsuranceRequestType.insuranceFileKey

        If oCreatePostingsForReinsuranceRequestType.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.CreatePostingsForReinsuranceRequestType) Then
            oResponse = New SAMForInsuranceV2ImplementationTypes.CreatePostingsForReinsuranceResponseType
        End If

        If oCreatePostingsForReinsuranceRequestType.ProcessType.ToUpper = "PORTFOLIOTRANSFER" Then

            Dim obSIRPortfolioTransfer As New bsirriportfoliotransfer.Business
            nReturn = CInt(obSIRPortfolioTransfer.Initialise(
                                         _SiriusUser.Username,
                                   _SiriusUser.Password,
                                   CInt(_SiriusUser.UserID),
                                   CInt(_SiriusUser.SourceID),
                                   CInt(_SiriusUser.LanguageID),
                                   CInt(_SiriusUser.CurrencyID),
                                         1,
                                         SiriusUserDefaults.AppName))

            Try
                nReturn = obSIRPortfolioTransfer.CreateAndPostStats(nInsuranceFileCnt:=nInsuranceFileCnt, sTransactionType:="PT", nPTInsuranceFileCnt:=nInsuranceFileCnt, bReversePT:=False, dtTransferDate:=dtTransferDate, r_sMessage:=sMessage)
                If nReturn <> PMEReturnCode.PMTrue Then
                    RaiseComMethodException("bSIRRIPortfolioTransfer.Business Failed", nReturn)
                End If
                Dim dsResult As DataSet

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Ins_File_PT_RI_Usage_sel_amend")
                    cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = nInsuranceFileCnt
                    dsResult = con.ExecuteDataSet(cmd, "GetPTRIUsage")
                End Using

                If dsResult IsNot Nothing AndAlso dsResult.Tables.Count > 0 AndAlso dsResult.Tables(0).Rows.Count > 0 Then
                    nInsFilePTRIUsageID = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("ins_file_PT_RI_usage_id"), 0)
                End If
                nReturn = CInt(obSIRPortfolioTransfer.DeleteInsFilePTRIUsage(v_lInsFilePTRIUsageID:=nInsFilePTRIUsageID))

                If nReturn <> PMEReturnCode.PMTrue Then
                    RaiseComMethodException("bSIRRIPortfolioTransfer.Business Failed", nReturn)
                End If

            Catch ex As Exception
                RaiseComMethodException("bSIRRIPortfolioTransfer Failed", nReturn)
            Finally
                If obSIRPortfolioTransfer IsNot Nothing Then
                    obSIRPortfolioTransfer.Dispose()
                    obSIRPortfolioTransfer = Nothing
                End If
            End Try
        ElseIf oCreatePostingsForReinsuranceRequestType.ProcessType.ToUpper = "CLONETRANSFER" Then

            Dim obSIRCloneRIBatchProcess As New bSIRCloneRIBatchProcess.Business

            nReturn = CInt(obSIRCloneRIBatchProcess.Initialise(
                                         _SiriusUser.Username,
                                         _SiriusUser.Password,
                                         _SiriusUser.UserID,
                                         _SiriusUser.SourceID,
                                         _SiriusUser.LanguageID,
                                         _SiriusUser.CurrencyID,
                                         1,
                                         SiriusUserDefaults.AppName))

            Try
                nReturn = obSIRCloneRIBatchProcess.CreateAndPostStats(nInsuranceFileCnt:=nInsuranceFileCnt, nClonedInsuranceFileCnt:=nInsuranceFileCnt, bReverseCloned:=True, sTransactionType:="DRI")
                nReturn = obSIRCloneRIBatchProcess.UpdateRIArrangementClonedStatus(v_lRisk_cnt:=0, v_iCloned:=2,
                                                                            v_lInsuranceFileCnt:=nInsuranceFileCnt)

                nReturn = obSIRCloneRIBatchProcess.DeleteInsFileClonedRIUsage(
                        nInsuranceFileCnt:=nInsuranceFileCnt)
            Catch ex As Exception
                RaiseComMethodException("bSIRCloneRIBatchProcess Failed", nReturn)
            Finally
                If obSIRCloneRIBatchProcess IsNot Nothing Then
                    obSIRCloneRIBatchProcess.Dispose()
                    obSIRCloneRIBatchProcess = Nothing
                End If
            End Try

        End If
        Return oResponse

    End Function
