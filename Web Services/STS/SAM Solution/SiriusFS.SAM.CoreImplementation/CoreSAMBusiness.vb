    '''<summary>
    ''' This method is used to UpdateBankGuaranteeConditionally
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>   
    '''<param name="oUpdateBankGuaranteeConditionallyRequest" type="BaseUpdateBankGuaranteeConditionallyRequestType"></param>   
    '''<returns>"oResponse" type ="BaseUpdateBankGuaranteeConditionallyResponseType"</returns>
    '''<remarks>
    Public Overloads Function UpdateBankGuaranteeConditionally(ByVal con As SiriusConnection, ByVal oUpdateBankGuaranteeConditionallyRequest As BaseUpdateBankGuaranteeConditionallyRequestType) As BaseUpdateBankGuaranteeConditionallyResponseType

        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim oResponse As New BaseUpdateBankGuaranteeConditionallyResponseType
        Dim iStatusId As Integer
        Dim sStauscode As String
        Dim nTypeOfPackage As enumTypeOfPackage

        If oUpdateBankGuaranteeConditionallyRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateBankGuaranteeConditionallyRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateBankGuaranteeConditionallyResponseType
        End If

        oUpdateBankGuaranteeConditionallyRequest.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        For Each oRequest As BaseUpdateBankGuaranteeConditionallyRequestTypeItem In oUpdateBankGuaranteeConditionallyRequest.Item
            Try
                oRequest.BGKey = GetAndValidateSpecifiedTableCode(con, PMLookupTable.BankGuarantee, "BG_id", "BG_id", oRequest.BGKey.ToString(), oErrors, "BGKey")

            Catch ex As Exception
                oErrors.AddInvalidData(SAMConstants.SAMBusinessErrors.BankGuaranteeNonIssued, "invalid bank guarantee reference " & oRequest.BGRef, "BGKey")
            End Try

            iStatusId = GetAndValidateSpecifiedTableCode(con, PMLookupTable.BankGuarantee, "BG_status_id", "BG_id", oRequest.BGKey.ToString(), oErrors, "bg_status_id")

            If oRequest.ActionType = BGUCActionType.Invoked AndAlso iStatusId <> oCoreBusiness.BGStatus.Issued Then

                oErrors.AddInvalidData(SAMConstants.SAMBusinessErrors.BankGuaranteeNonIssued,
                                                "BG with BG_ref " & oRequest.BGRef & " can not be invoked,since it is either expired, Deleted or not used against any Policy",
                                               "IsDeleted")
            End If

            If (oRequest.ActionType = BGUCActionType.DelUnDel And oRequest.IsDeleted = 1) AndAlso (iStatusId = oCoreBusiness.BGStatus.Issued Or iStatusId = oCoreBusiness.BGStatus.Invoked) Then
                oErrors.AddInvalidData(SAMConstants.SAMBusinessErrors.BankGuaranteeNotToDelete,
                                                            "BG with BG_ref  " & oRequest.BGRef & "can not be deleted,since it is in use or Invoked",
                                                            "IsDeleted")
            End If
        Next
        oErrors.CheckForErrors()

        Using con
            con.BeginTransaction()
            Try
                If oUpdateBankGuaranteeConditionallyRequest IsNot Nothing AndAlso oUpdateBankGuaranteeConditionallyRequest.Item IsNot Nothing Then
                    For Each oRequest As BaseUpdateBankGuaranteeConditionallyRequestTypeItem In oUpdateBankGuaranteeConditionallyRequest.Item

                        If oRequest.IsDeletedSpecified = True AndAlso oRequest.ActionType = BGUCActionType.DelUnDel Then
                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_BankGuarantee_Details_DelUndel")
                                Try
                                    cmd.AddInParameter("@bg_id", SqlDbType.Int).Value = oRequest.BGKey
                                    cmd.AddInParameter("@delete", SqlDbType.Int).Value = oRequest.IsDeleted
                                    con.ExecuteNonQuery(cmd)
                                Catch ex As Exception
                                    Throw
                                End Try
                            End Using                '

                        Else
                            'invoke functionality
                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Update_BG_Status")
                                If oRequest.InvokedDateSpecified = True Then
                                    Try
                                        cmd.AddInParameter("@bg_id", SqlDbType.Int).Value = oRequest.BGKey
                                        cmd.AddInParameter("@status_id", SqlDbType.Int).Value = oCoreBusiness.BGStatus.Invoked
                                        cmd.AddInParameter("@status_date", SqlDbType.DateTime).Value = oRequest.InvokedDate
                                        con.ExecuteNonQuery(cmd)
                                    Catch ex As Exception
                                        Throw
                                    End Try
                                End If
                            End Using
                        End If
                    Next
                End If
            Catch ex As Exception
                con.RollbackTransaction()
                Throw
            End Try
            con.CommitTransaction()
        End Using

        Return oResponse

    End Function

