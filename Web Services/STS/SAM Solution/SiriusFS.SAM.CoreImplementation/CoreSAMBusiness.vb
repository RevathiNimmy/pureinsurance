#Region "ExclusiveLock"

    ''' <summary>
    ''' Adds an exclusive lock
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oLockName"></param>
    ''' <param name="nLockValue"></param>
    ''' <param name="nLock2Value"></param>
    ''' <param name="sLock3Value"></param>
    ''' <param name="nUserID"></param>
    ''' <returns></returns>
    ''' <remarks>Will throuw a business rule error if the lock already exist on a record.</remarks>
    Private Sub AddExlusiveLock(ByRef con As SiriusConnection,
                                ByVal oBusiness As CoreBusiness,
                                ByVal oLockName As CoreBusiness.LockName,
                                ByVal nLockValue As Integer,
                                ByVal nLock2Value As Integer,
                                ByVal sLock3Value As String,
                                ByVal nUserID As Integer,
                                ByVal sBranchCode As String)

        'Add an Exclusive Lock
        'This should be only called if an explicit ExclusiveLock = True has come in the request
        Dim sOptionValue As String = String.Empty

        oBusiness.GetSystemOption(sBranchCode,
                                  SystemOption.EnableExclusiveLocking,
                                  sOptionValue)
        If sOptionValue = "1" Then
            Const sMode As String = "ADD"
            Dim oLockDetails As Object(,)

            ReDim Preserve oLockDetails(4, 0)

            oLockDetails(0, 0) = oBusiness.LockNameString(oLockName)
            oLockDetails(1, 0) = nLockValue
            oLockDetails(2, 0) = nLock2Value
            oLockDetails(3, 0) = sLock3Value
            oLockDetails(4, 0) = nUserID

            AddDeleteLocks(con, sMode, oLockDetails)
        End If
    End Sub

    ''' <summary>
    ''' Delete an exclusive lock
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oLockName"></param>
    ''' <param name="nLockValue"></param>
    ''' <returns></returns>
    ''' <remarks>Deletes an exclusive lock</remarks>
    Private Sub DeleteExlusiveLock(ByRef con As SiriusConnection,
                                   ByVal oBusiness As CoreBusiness,
                                   ByVal oLockName As CoreBusiness.LockName,
                                   ByVal nLockValue As Integer,
                                   ByVal sBranchCode As String)

        Dim sMode As String = "DELETE_EXCLUSIVE_LOCK"
        Dim oLockDetails As Object(,)
        Dim sOptionValue As String = String.Empty
        'Try and Delete only when system optin is on
        oBusiness.GetSystemOption(sBranchCode,
                                  SystemOption.EnableExclusiveLocking,
                                  sOptionValue)
        If sOptionValue = "1" Then
            ReDim Preserve oLockDetails(4, 0)

            oLockDetails(0, 0) = oBusiness.LockNameString(oLockName)
            oLockDetails(1, 0) = nLockValue
            AddDeleteLocks(con, sMode, oLockDetails)
        End If
    End Sub
#End Region

