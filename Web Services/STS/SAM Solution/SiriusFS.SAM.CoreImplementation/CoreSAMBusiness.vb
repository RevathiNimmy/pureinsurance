    Private Overloads Sub GetMandatoryAddons(ByVal con As SiriusConnection,
                          ByVal XMLDataSet As String,
                          ByVal DataModelCode As String,
                          ByVal TransactionType As enumTransactionTypeAddons,
                          ByVal RiskGroupId As Int32,
                          ByRef AddOnsXml As String,
                          Optional ByVal rootElementName As String = "",
                          Optional ByVal elementTypeName As String = "")

        Dim AddOns() As BaseAddOnType = Nothing
        Dim utils As New Utilities
        Dim addOn As BaseAddOnType
        Dim iCnt As Int32
        Dim oDomDocRisk As New System.Xml.XmlDocument ' MSXML2.DOMDocument
        Dim oDomNodeRisk As System.Xml.XmlNode ' MSXML2.IXMLDOMNode
        Dim oDomNodeRiskList As System.Xml.XmlNodeList
        Dim sXpath As String = String.Empty

        Const ACMethodName As String = "GetMandatoryAddons"

        'Get Mandatory Addons Linked to Risk Group.
        Dim dsAddOnArray As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetMandatoryRiskExtras")

            cmd.AddInParameter("@risk_group_id", SqlDbType.Int).Value = CInt(RiskGroupId)
            cmd.AddInParameter("@transaction_type", SqlDbType.VarChar).Value = Cast.ToString(TransactionType.ToString, "")

            dsAddOnArray = con.ExecuteDataSet(cmd, "AddOnArray")

            If dsAddOnArray.Tables("AddOnArray") IsNot Nothing AndAlso dsAddOnArray.Tables("AddOnArray").Rows.Count > 0 Then
                ReDim AddOns(dsAddOnArray.Tables("AddOnArray").Rows.Count)
                iCnt = 0
                For Each dr As DataRow In dsAddOnArray.Tables("AddOnArray").Rows
                    addOn = New BaseAddOnType
                    addOn.ExtraPercentage = Cast.ToDecimal(dr.Item("fee_percentage"), 0)
                    addOn.ExtraAmount = Cast.ToDecimal(dr.Item("fee_amount"), 0)
                    addOn.PartyShortCode = Cast.ToString(dr.Item("shortname"), "")
                    addOn.ResolvedName = Cast.ToString(dr.Item("resolved_name"), "")
                    AddOns(iCnt) = addOn
                    iCnt = iCnt + 1
                Next
            End If
        End Using

        'Get Addons from XmlDataset.
        Try
            oDomDocRisk.LoadXml(XMLDataSet)
        Catch ex As Exception
            ' Exception handling
        End Try

        sXpath = [String].Format("/DATA_SET/RISK_OBJECTS/{0}_POLICY_BINDER/{0}_OUTPUT/{0}_OUTPUT_FEES", DataModelCode.ToUpper)

        oDomNodeRiskList = oDomDocRisk.SelectNodes(sXpath)

        If (oDomNodeRiskList Is Nothing) = False Then
            For Each oDomNodeRisk In oDomNodeRiskList
                addOn = New BaseAddOnType
                addOn.ExtraPercentage = Cast.ToDecimal(oDomNodeRisk.Attributes.GetNamedItem("FEE_PERCENTAGE").Value, 0)
                addOn.ExtraAmount = Cast.ToDecimal(oDomNodeRisk.Attributes.GetNamedItem("FEE_AMOUNT").Value, 0)
                addOn.PartyShortCode = Cast.ToString(oDomNodeRisk.Attributes.GetNamedItem("SHORT_NAME").Value, "")

                Dim ds As DataSet = Nothing
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetResolvedNamefromShortname")
                    cmd.AddInParameter("@shortname", SqlDbType.Char).Value = Cast.ToString(addOn.PartyShortCode, "")
                    ds = con.ExecuteDataSet(cmd, "ResolvedName")

                    If ds.Tables("ResolvedName").Rows.Count >= 0 Then
                        Try
                            addOn.ResolvedName = ds.Tables(0).Rows(0).Item(0).ToString
                        Catch ex As Exception
                            Dim STSErrorEx As New STSErrorPublisher("Failed to Get resolvedname for party.", ex)
                            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetMandatoryAddons", True)
                        End Try
                    End If
                End Using

                'Add Another Node
                If IsArray(AddOns) Then
                    ReDim Preserve AddOns(AddOns.GetUpperBound(1) + 1)
                Else
                    ReDim AddOns(0)
                End If
                AddOns(AddOns.GetUpperBound(1)) = addOn
            Next
        End If

        Dim oXMLSerializer As Serialization.XmlSerializer
        If Len(rootElementName) > 0 Or Len(elementTypeName) > 0 Then
            Dim xmlAttrs As New XmlAttributes()
            Dim xmlRoot As New XmlRootAttribute
            xmlRoot.ElementName = rootElementName
            xmlRoot.IsNullable = False

            xmlAttrs.XmlRoot = xmlRoot

            Dim xmlType As New XmlTypeAttribute
            xmlType.TypeName = elementTypeName
            xmlAttrs.XmlType = xmlType
            xmlAttrs.Xmlns = False
            xmlAttrs.XmlIgnore = True

            Dim xmloverride As New XmlAttributeOverrides
            xmloverride.Add(GetType(BaseAddOnType), xmlAttrs)
            xmloverride.Add(GetType(BaseAddOnType()), xmlAttrs)

            oXMLSerializer = New Serialization.XmlSerializer(GetType(BaseAddOnType()), xmloverride)
        Else
            oXMLSerializer = New Serialization.XmlSerializer(GetType(BaseAddOnType()))
        End If

        Dim s As New StringBuilder
        Dim Output As New StringWriter(s)
        Try
            oXMLSerializer.Serialize(Output, AddOns)
            AddOnsXml = Output.ToString()
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to serialize Addons.", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetMandatoryAddons", True)
        End Try
    End Sub

