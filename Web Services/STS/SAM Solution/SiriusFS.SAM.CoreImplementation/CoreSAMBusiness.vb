        End Using
    End Function
    Public Overloads Function FindDMEDocuments(ByVal con As SiriusConnection, ByVal oFindDMEDocumentsRequest As BaseFindDMEDocumentsRequestType) As BaseFindDMEDocumentsResponseType

        Dim oFindDMEDocumentsResponse As New BaseFindDMEDocumentsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage
        Dim exCodeList As New List(Of String)
        Dim iFolderLevel As Integer
        Dim sSql As String
        Dim folderList As New List(Of Integer)
        Dim parentfolderList As New List(Of Integer)

        If oFindDMEDocumentsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindDMEDocumentsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oFindDMEDocumentsResponse = New SAMForInsuranceV2ImplementationTypes.FindDMEDocumentsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        oFindDMEDocumentsRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()


        If oFindDMEDocumentsRequest.ClaimNumber <> "" Then
            'Claim Search
            iFolderLevel = 2

            Dim oFindClaimRequest As New BaseFindClaimRequestType
            Dim oFindClaimResponse As New BaseFindClaimResponseType

            oFindClaimRequest.BranchCode = oFindDMEDocumentsRequest.BranchCode
            oFindClaimRequest.ClaimNumber = oFindDMEDocumentsRequest.ClaimNumber
            oFindClaimRequest.ClientShortName = oFindDMEDocumentsRequest.PartyCode
            oFindClaimRequest.InsuranceFileRef = oFindDMEDocumentsRequest.PolicyNumber
            oFindClaimRequest.IncludeClosedClaim = True
            oFindClaimRequest.AgentKey = oFindDMEDocumentsRequest.AgentKey

            oFindClaimResponse = FindClaim(oFindClaimRequest)
            If Not oFindClaimResponse.ResultDataset Is Nothing Then
                Dim xNodes As XmlNodeList
                xNodes = oFindClaimResponse.ResultDataset.SelectNodes("/BaseFindClaimResponseTypeClaims/Row")

                If xNodes.Count > 0 Then
                    For Each xNode As XmlNode In xNodes
                        Dim sDMEClaimNum As String
                        'Correctly format reference as DME does
                        sDMEClaimNum = String.Format("C{0:000000000}",
                         Convert.ToInt32(xNode.Item("ClaimKey").InnerText))
                        exCodeList.Add(sDMEClaimNum)
                    Next
                End If
            End If
        ElseIf (oFindDMEDocumentsRequest.PolicyNumber <> "" Or oFindDMEDocumentsRequest.RiskIndex <> "") Then
            'Policy Level Search
            iFolderLevel = 2

            Dim oFindPolicyRequest As New BaseFindPolicyRequestType
            Dim oFindPolicyResponse As BaseFindPolicyResponseType

            oFindPolicyRequest.BranchCode = oFindDMEDocumentsRequest.BranchCode
            oFindPolicyRequest.ClientShortName = oFindDMEDocumentsRequest.PartyCode
            oFindPolicyRequest.InsuranceRef = oFindDMEDocumentsRequest.PolicyNumber
            oFindPolicyRequest.RiskIndex = oFindDMEDocumentsRequest.RiskIndex
            oFindPolicyRequest.AgentKey = oFindDMEDocumentsRequest.AgentKey

            oFindPolicyResponse = FindPolicy(con, oFindPolicyRequest)
            If Not oFindPolicyResponse.ResultDataset Is Nothing Then
                Dim xNodes As XmlNodeList
                xNodes = oFindPolicyResponse.ResultDataset.SelectNodes("/BaseFindPolicyResponseTypeInsuranceFileDetails/Row")

                If xNodes.Count > 0 Then
                    For Each xNode As XmlNode In xNodes
                        exCodeList.Add(xNode.Item("InsuranceFolderKey").InnerText)
                    Next
                End If
            End If
        ElseIf (oFindDMEDocumentsRequest.PartyCode <> "" Or oFindDMEDocumentsRequest.PartyName <> "" Or oFindDMEDocumentsRequest.PostCode <> "" Or oFindDMEDocumentsRequest.AgentKey > 0) Then

            iFolderLevel = 1
            Dim oFindPartyRequest As New BaseFindPartyRequestType
            Dim oFindPartyResponse As BaseFindPartyResponseType

            'PC Party Search
            Using connection As SiriusConnection = New SiriusConnectionPMDAO(
                                           _SiriusUser.Username, _SiriusUser.SourceID,
                                           _SiriusUser.LanguageID,
                                           SiriusUserDefaults.AppName)

                oFindPartyRequest.BranchCode = oFindDMEDocumentsRequest.BranchCode
                oFindPartyRequest.Shortname = oFindDMEDocumentsRequest.PartyCode
                oFindPartyRequest.Name = oFindDMEDocumentsRequest.PartyName
                oFindPartyRequest.PostCode = oFindDMEDocumentsRequest.PostCode
                oFindPartyRequest.PartyType = "PC"
                oFindPartyRequest.Status = "ANY"
                oFindPartyRequest.AgentKey = oFindDMEDocumentsRequest.AgentKey

                oFindPartyResponse = FindPartyVersion2(connection, oFindPartyRequest)
                If Not oFindPartyResponse.ResultDataset Is Nothing Then
                    Dim xNodes As XmlNodeList
                    xNodes = oFindPartyResponse.ResultDataset.SelectNodes("/BaseFindPartyResponseTypeParties/Row")

                    If xNodes.Count > 0 Then
                        For Each xNode As XmlNode In xNodes
                            exCodeList.Add(xNode.Item("PartyKey").InnerText)
                        Next
                    End If
                End If
            End Using
            'CC Party Search
            Using connection As SiriusConnection = New SiriusConnectionPMDAO(
                                          _SiriusUser.Username, _SiriusUser.SourceID,
                                          _SiriusUser.LanguageID,
                                         SiriusUserDefaults.AppName)

                oFindPartyRequest.BranchCode = oFindDMEDocumentsRequest.BranchCode
                oFindPartyRequest.Shortname = oFindDMEDocumentsRequest.PartyCode
                oFindPartyRequest.Name = oFindDMEDocumentsRequest.PartyName
                oFindPartyRequest.PostCode = oFindDMEDocumentsRequest.PostCode
                oFindPartyRequest.PartyType = "CC"
                oFindPartyRequest.Status = "ANY"
                oFindPartyRequest.AgentKey = oFindDMEDocumentsRequest.AgentKey

                oFindPartyResponse = FindPartyVersion2(connection, oFindPartyRequest)
                If Not oFindPartyResponse.ResultDataset Is Nothing Then
                    Dim xNodes As XmlNodeList
                    xNodes = oFindPartyResponse.ResultDataset.SelectNodes("/BaseFindPartyResponseTypeParties/Row")

                    If xNodes.Count > 0 Then
                        For Each xNode As XmlNode In xNodes
                            exCodeList.Add(xNode.Item("PartyKey").InnerText)
                        Next
                    End If
                End If
            End Using
        End If


        If exCodeList.Count > 0 Then
            'Get all folders for from ex_codes
            sSql = " SELECT folder_num FROM DOC_folder WITH(NOLOCK) WHERE folder_level = " & iFolderLevel &
                " AND ex_code IN ("
            For Each exCode As String In exCodeList
                sSql = sSql & String.Format("'{0}',", exCode)
            Next
            'Remove the last comma
            sSql = sSql.Substring(0, sSql.Length - 1) & ")"

            Dim dtFolder As DataTable
            Using cmd As SiriusCommand = SiriusCommand.FromText(sSql)
                dtFolder = con.ExecuteDataTable(cmd)
            End Using
            If dtFolder IsNot Nothing AndAlso dtFolder.Rows.Count > 0 Then
                For Each dr As DataRow In dtFolder.Rows
                    folderList.Add(Cast.ToInt32(dr.Item("folder_num"), 0))
                Next
            End If


            If folderList.Count > 0 Then
                'Get the folders

                sSql = "SELECT folder_num, parent_num, folder_name, ex_code, folder_level, create_date" &
                    " FROM DOC_folder WITH(NOLOCK) WHERE folder_num IN ("
                For Each folderNum As Integer In folderList
                    sSql = sSql & String.Format("{0},", folderNum)
                Next
                parentfolderList = folderList
                sSql = sSql.Substring(0, sSql.Length - 1) & ")"

                If oFindDMEDocumentsRequest.FolderName <> "" Then
                    sSql = sSql & " and folder_name like '%" & oFindDMEDocumentsRequest.FolderName & "%' "
                End If

                If (oFindDMEDocumentsRequest.ParentNum > 0) Then
                    sSql = sSql & " and parent_num = " & oFindDMEDocumentsRequest.ParentNum
                End If
                sSql = sSql & "  order by folder_name "

                Dim dsFolder As DataSet
                Using cmd As SiriusCommand = SiriusCommand.FromText(sSql)
                    dsFolder = con.ExecuteDataSet(cmd, "Row")
                End Using

                If (dsFolder.Tables.Count > 0) Then
                    If (dsFolder.Tables(0).Rows.Count > 0) Then
                        For icount As Integer = 0 To dsFolder.Tables(0).Rows.Count - 1
                            ReDim Preserve oFindDMEDocumentsResponse.Folders(icount)
                            oFindDMEDocumentsResponse.Folders(icount) = New BaseDMEFolderType
                            oFindDMEDocumentsResponse.Folders(icount).FolderNum = Cast.ToInt32(dsFolder.Tables(0).Rows(icount).Item("folder_num"), 0)
                            oFindDMEDocumentsResponse.Folders(icount).Name = dsFolder.Tables(0).Rows(icount).Item("folder_name").ToString
                            oFindDMEDocumentsResponse.Folders(icount).ParentNum = Cast.ToInt32(dsFolder.Tables(0).Rows(icount).Item("parent_num"), 0)
                            oFindDMEDocumentsResponse.Folders(icount).FolderLevel = Cast.ToInt32(dsFolder.Tables(0).Rows(icount).Item("folder_level"), 0)
                            oFindDMEDocumentsResponse.Folders(icount).ExternalCode = dsFolder.Tables(0).Rows(icount).Item("ex_code").ToString
                            oFindDMEDocumentsResponse.Folders(icount).CreateDate = Cast.ToDateTime(dsFolder.Tables(0).Rows(icount).Item("create_date"), Date.MinValue)
                        Next
                    End If
                End If
            End If




            If iFolderLevel = 1 And folderList.Count > 0 And oFindDMEDocumentsRequest.IncludeFiles Then
                'Get folders at sub_level also
                sSql = "SELECT folder_num FROM DOC_folder WITH(NOLOCK) WHERE parent_num IN ("

                For Each folderNum As Integer In folderList
                    sSql = sSql & String.Format("'{0}',", folderNum.ToString)
                Next
                'Remove the last comma
                sSql = sSql.Substring(0, sSql.Length - 1) & ")"
                parentfolderList = folderList

                If oFindDMEDocumentsRequest.AgentKey > 0 Then
                    sSql = sSql & " AND EX_CODE  in ( SELECT CONVERT(varchar(20), insurance_folder_cnt) from  insurance_file where lead_agent_cnt =" & oFindDMEDocumentsRequest.AgentKey
                    sSql = sSql & " UNION SELECT 'GENERAL'"
                    sSql = sSql & " UNION SELECT CONCAT('C', RIGHT(CONCAT('000000000', C.CLAIM_ID),9)) from claim C INNER JOIN Insurance_File IFI on C.Policy_id = IFI.insurance_file_cnt "
                    sSql = sSql & " WHERE IFI.lead_agent_cnt =" & oFindDMEDocumentsRequest.AgentKey
                    sSql = sSql & " )"
                End If

                Using cmd As SiriusCommand = SiriusCommand.FromText(sSql)
                    dtFolder = con.ExecuteDataTable(cmd)
                End Using
                folderList = Nothing
                folderList = New List(Of Integer)
                If dtFolder IsNot Nothing AndAlso dtFolder.Rows.Count > 0 Then
                    For Each dr As DataRow In dtFolder.Rows
                        folderList.Add(Cast.ToInt32(dr.Item("folder_num"), 0))
                    Next
                End If

            End If
        ElseIf oFindDMEDocumentsRequest.FolderName <> "" Then
            sSql = "SELECT folder_num, parent_num, folder_name, ex_code, folder_level, create_date FROM DOC_folder WITH(NOLOCK) WHERE folder_name like '" & oFindDMEDocumentsRequest.FolderName & "%' and parent_num = " & oFindDMEDocumentsRequest.ParentNum & " order by folder_name"
            Dim dsfolder As DataSet
            Using cmd As SiriusCommand = SiriusCommand.FromText(sSql)
                dsfolder = con.ExecuteDataSet(cmd, "row")
            End Using
            If (dsfolder.Tables.Count > 0) Then
                If (dsfolder.Tables(0).Rows.Count > 0) Then
                    For icount As Integer = 0 To dsfolder.Tables(0).Rows.Count - 1
                        ReDim Preserve oFindDMEDocumentsResponse.Folders(icount)
                        oFindDMEDocumentsResponse.Folders(icount) = New BaseDMEFolderType
                        oFindDMEDocumentsResponse.Folders(icount).FolderNum = Cast.ToInt32(dsfolder.Tables(0).Rows(icount).Item("folder_num"), 0)
                        oFindDMEDocumentsResponse.Folders(icount).Name = dsfolder.Tables(0).Rows(icount).Item("folder_name").ToString
                        oFindDMEDocumentsResponse.Folders(icount).ParentNum = Cast.ToInt32(dsfolder.Tables(0).Rows(icount).Item("parent_num"), 0)
                        oFindDMEDocumentsResponse.Folders(icount).FolderLevel = Cast.ToInt32(dsfolder.Tables(0).Rows(icount).Item("folder_level"), 0)
                        oFindDMEDocumentsResponse.Folders(icount).ExternalCode = dsfolder.Tables(0).Rows(icount).Item("ex_code").ToString
                        oFindDMEDocumentsResponse.Folders(icount).CreateDate = Cast.ToDateTime(dsfolder.Tables(0).Rows(icount).Item("create_date"), Date.MinValue)
                    Next
                End If
            End If

        End If

        'No folders and no description search so return nothing
        If folderList.Count = 0 And (oFindDMEDocumentsRequest.DocumentDescription = "" Or iFolderLevel > 0) Then
            Return oFindDMEDocumentsResponse
        End If

        If oFindDMEDocumentsRequest.IncludeFiles Then
            'Now get the documents
            sSql = "SELECT folder_num,doc_num, doc_name, doc_type, create_date, dbo.GetDMEPath(folder_num) as FolderPath" &
            " FROM DOC_document WITH(NOLOCK) WHERE "

            If folderList.Count > 0 Then
                sSql = sSql & " folder_num IN ("

                For Each folderNum As Integer In folderList
                    sSql = sSql & String.Format("'{0}',", folderNum.ToString)
                Next
                For Each folderNum As Integer In parentfolderList
                    sSql = sSql & String.Format("'{0}',", folderNum.ToString)
                Next

                'Remove the last comma
                sSql = sSql.Substring(0, sSql.Length - 1) & ")"
            End If

            If oFindDMEDocumentsRequest.DocumentDescription <> "" Then
                If folderList.Count > 0 Then
                    sSql = sSql & " AND "
                End If
                sSql = sSql & " doc_name like '" & oFindDMEDocumentsRequest.DocumentDescription.Replace("'", "''") & "'"
            End If
            sSql = sSql & " ORDER BY create_date DESC"

            Dim dsDocuments As DataSet
            Using cmd As SiriusCommand = SiriusCommand.FromText(sSql)
                dsDocuments = con.ExecuteDataSet(cmd, "Row")
            End Using
            If (dsDocuments.Tables.Count > 0) Then
                If (dsDocuments.Tables(0).Rows.Count > 0) Then
                    For icount As Integer = 0 To dsDocuments.Tables(0).Rows.Count - 1
                        ReDim Preserve oFindDMEDocumentsResponse.Documents(icount)
                        oFindDMEDocumentsResponse.Documents(icount) = New BaseDocumentType
                        oFindDMEDocumentsResponse.Documents(icount).DocNum = Cast.ToInt32(dsDocuments.Tables(0).Rows(icount).Item("doc_num"), 0)
                        oFindDMEDocumentsResponse.Documents(icount).DocDescription = dsDocuments.Tables(0).Rows(icount).Item("doc_name").ToString
                        oFindDMEDocumentsResponse.Documents(icount).CreateDate = Cast.ToDateTime(dsDocuments.Tables(0).Rows(icount).Item("create_date"), Date.MinValue)
                        oFindDMEDocumentsResponse.Documents(icount).FolderNum = Cast.ToInt32(dsDocuments.Tables(0).Rows(icount).Item("folder_num"), 0)
                        oFindDMEDocumentsResponse.Documents(icount).FolderPath = dsDocuments.Tables(0).Rows(icount).Item("FolderPath").ToString
                        oFindDMEDocumentsResponse.Documents(icount).DocumentType = GetDMEDocTypeFromCode(dsDocuments.Tables(0).Rows(icount).Item("doc_type").ToString)
                    Next
                End If
            End If
        End If
        Return oFindDMEDocumentsResponse
    End Function
