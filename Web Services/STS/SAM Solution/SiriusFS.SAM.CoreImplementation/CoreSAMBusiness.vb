    '''<remarks></remarks>
    Public Overloads Function GetWmTask(ByVal con As SiriusConnection, ByVal oGetWmTaskRequest As BaseGetWmTaskRequestType) As BaseGetWmTaskResponseType
        Dim oGetWmTaskResponse As New BaseGetWmTaskResponseType
