    Private Sub ValidateUpdateDataCashDepositItem(ByRef oSAMErrorCollection As SAMErrorCollection, ByVal oCoreBusiness As CoreBusiness, ByVal conCashDeposit As SiriusConnection, ByVal oCashDeposit As BaseCommonCashDepositItemType)

        oCashDeposit.PartyKey = GetAndValidateSpecifiedTableCode(conCashDeposit,
