    ''' <summary>
    '''  This method is used to get Account Details
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oGetAccountDetailsRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function GetAccountDetails(ByVal con As SiriusConnection, ByVal oGetAccountDetailsRequest As BaseGetAccountDetailsRequestType) As BaseGetAccountDetailsResponseType

        Dim oGetAccountDetailsResponse As New BaseGetAccountDetailsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetAccountDetailsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetAccountDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetAccountDetailsResponse = New SAMForInsuranceV2ImplementationTypes.GetAccountDetailsResponseType
        End If

        ' validate the request structure against the specified business rules
        oGetAccountDetailsRequest.Validate(CObj(oErrors))

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        'Rk modifies as part of SAM SFI Interop conversions.

        Dim oFindTransaction As bACTFindTransaction.Business = Nothing
        Dim oAccount As bACTAccount.Form = Nothing
        Dim iComReturnValue As Integer
        Dim vResultArray As Object(,) = Nothing
        Dim iRecordCount As Integer
        Dim iAccountId As Integer
        Dim iCurrencykey As Integer
        Dim iDocTypeGroupkey As Integer
        Dim iDocumentTypeKey As Integer
        Dim oAccountBalance As Object
        Dim iDocumentId As Integer

        Try

            Dim iBranchId As Integer = oCoreBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "Source", oGetAccountDetailsRequest.BranchCode)

            'PN# 63288
            If oGetAccountDetailsRequest.CurrencyCode IsNot Nothing Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_CurrencyId_From_CurrencyCode")

                    cmd.AddInParameter("@currencyCode", SqlDbType.VarChar).Value = Cast.ToString(oGetAccountDetailsRequest.CurrencyCode, String.Empty)
                    cmd.AddOutParameter("@currencyID", SqlDbType.Int)
                    con.ExecuteNonQuery(cmd)

                    iCurrencykey = Cast.ToInt32(cmd.Parameters.Item("@currencyID").Value, 0)
                End Using
            End If

            If Not String.IsNullOrEmpty(oGetAccountDetailsRequest.DocumentTypeCode) Then
                iDocumentTypeKey = GetAndValidateSpecifiedTableCode(con, "documenttype", "documenttype_id", "code", oGetAccountDetailsRequest.DocumentTypeCode, oErrors, "DocumentTypeCode")
                oErrors.CheckForErrors()
            End If

            If Not String.IsNullOrEmpty(oGetAccountDetailsRequest.DocTypeGroupCode) Then
                iDocTypeGroupkey = GetAndValidateSpecifiedTableCode(con, "DocTypeGroup", "doctypegroup_id", "code", oGetAccountDetailsRequest.DocTypeGroupCode, oErrors, "DocTypeGroupCode")
                oErrors.CheckForErrors()
            End If

            If Not String.IsNullOrEmpty(oGetAccountDetailsRequest.DocumentRef) Then
                iDocumentId = GetAndValidateSpecifiedTableCode(con, "Document", "document_id", "document_ref", oGetAccountDetailsRequest.DocumentRef, oErrors, "DocumentId")
                If oGetAccountDetailsRequest.DocumentKeySpecified = False Then
                    oGetAccountDetailsRequest.DocumentKey = Cast.ToInt32(iDocumentId, 0)
                    oGetAccountDetailsRequest.DocumentKeySpecified = True
                End If
            End If
            If oGetAccountDetailsRequest.PartyCntSpecified = True AndAlso oGetAccountDetailsRequest.AccountKeySpecified = False Then

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Get_AccountID_From_partyCnt")

                    cmd.AddInParameter("@companyid", SqlDbType.Int).Value = iBranchId
                    cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oGetAccountDetailsRequest.PartyCnt
                    cmd.AddOutParameter("@AccountID", SqlDbType.Int)
                    cmd.AddOutParameter("@SubBranchID", SqlDbType.Int)
                    con.ExecuteNonQuery(cmd)

                    iAccountId = Cast.ToInt32(cmd.Parameters.Item("@AccountID").Value, 0)
                End Using

            Else
                If oGetAccountDetailsRequest.AccountKeySpecified = True Then
                    iAccountId = oGetAccountDetailsRequest.AccountKey
                Else
                    iAccountId = Nothing
                End If

            End If

            If oGetAccountDetailsRequest.PartyCntSpecified = False AndAlso oGetAccountDetailsRequest.AccountKeySpecified = False Then
                iAccountId = Nothing
            End If

            If iAccountId > 0 Then
                oAccount = New bACTAccount.Form
                InitialiseSBOObject(con, oAccount, _SiriusUser, "bACTAccount.Form")

                iComReturnValue = oAccount.GetAccountDetails(
                                        r_lAccountID:=iAccountId,
                                        sAccountName:=oGetAccountDetailsResponse.AccountName,
                                        sContactName:=oGetAccountDetailsResponse.ContactName,
