    Public Overloads Function DeleteWmTask(ByVal con As SiriusConnection, ByVal oDeleteWmTaskRequest As BaseDeleteWmTaskRequestType) As BaseDeleteWmTaskResponseType

        Dim oDeleteWmTaskResponse As New BaseDeleteWmTaskResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        'Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oDeleteWmTaskRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.DeleteWmTaskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oDeleteWmTaskResponse = New SAMForInsuranceV2ImplementationTypes.DeleteWmTaskResponseType
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oDeleteWmTaskRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode")
        End If

        ' Check mandatory fields
        If oDeleteWmTaskRequest.TaskInstanceKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString, "TaskInstanceKey")
        End If
        oErrors.CheckForErrors()

        ' Check that the timestamp matches and lock the task instance
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.CheckTSAndLock(con,
            BranchCode:=oDeleteWmTaskRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.TaskInstanceCnt,
            LockValue:=oDeleteWmTaskRequest.TaskInstanceKey,
            TStamp:=oDeleteWmTaskRequest.TaskTimeStamp)
        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oDeleteWmTaskResponse.STSError = AnyError
            Return oDeleteWmTaskResponse
        End If

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_pmwrk_task_inst_del")
            cmd.AddInParameter("@pmwrk_task_instance_cnt", SqlDbType.Int).Value = oDeleteWmTaskRequest.TaskInstanceKey
            con.ExecuteNonQuery(cmd)
        End Using

        ' Unlock and return the new timestamp
        AnyError = oCoreBusiness.UnlockAndGetTS(con,
            BranchCode:=oDeleteWmTaskRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.TaskInstanceCnt,
            LockValue:=oDeleteWmTaskRequest.TaskInstanceKey,
            TStamp:=oDeleteWmTaskResponse.TaskTimeStamp)

        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oDeleteWmTaskResponse.STSError = AnyError
            Return oDeleteWmTaskResponse
        End If

        Return oDeleteWmTaskResponse

    End Function

