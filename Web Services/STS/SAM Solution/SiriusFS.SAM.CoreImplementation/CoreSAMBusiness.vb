    ''' <summary>
    '''This web method  will perform the business
    '''</summary>
    '''<param name="conBankGuarantee">An object of the class SiriusConnection</param>
    '''<param name="oRequest">An object of the class GetBankGuaranteeRequestType</param>
    '''<remarks></remarks> 
    Public Overloads Function GetBankGuarantee(ByVal conBankGuarantee As SiriusConnection, ByVal oGetBankGuaranteeRequest As BaseGetBankGuaranteeRequestType) As BaseGetBankGuaranteeResponseType

        Dim oGetBankGuaranteeResponse As New BaseGetBankGuaranteeResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetBankGuaranteeRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetBankGuaranteeRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetBankGuaranteeResponse = New SAMForInsuranceV2ImplementationTypes.GetBankGuaranteeResponseType
        End If
        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetBankGuaranteeRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        ' Check mandatory fields
        If oGetBankGuaranteeRequest.BGKey = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BGKey")
        End If

        ' exit if there are any missing parameters
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Lookup and data Validation
        '*******************************************************************************************
        If (Not String.IsNullOrEmpty(oGetBankGuaranteeRequest.BranchCode)) Then
            oGetBankGuaranteeRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oGetBankGuaranteeRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        If oGetBankGuaranteeRequest.BGKey <> 0 Then
            oGetBankGuaranteeRequest.BGKey = GetAndValidateSpecifiedTableCode(conBankGuarantee,
                 PMLookupTable.Bank_Guarantee, "Bg_id", "Bg_Id", oGetBankGuaranteeRequest.BGKey.ToString, oSAMErrorCollection, "BGKey")
        End If

        Dim dsBankGuarantee As DataSet = Nothing
        Dim dsBankGuaranteeProducts As DataSet = Nothing
        Dim dsBankGuaranteeBranches As DataSet = Nothing

        oGetBankGuaranteeResponse.BankGuarantee = New BaseBankGuaranteeItemType
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_PartyBG_Details_Sel")
            cmd.AddInParameter("@bg_id", SqlDbType.Int).Value = Cast.NullIfDefault(oGetBankGuaranteeRequest.BGKey, 0)
            dsBankGuarantee = conBankGuarantee.ExecuteDataSet(cmd, "Bank_Guarantee")
            If (dsBankGuarantee IsNot Nothing) Then
                If (dsBankGuarantee.Tables.Count >= 1) Then
                    If (dsBankGuarantee.Tables(0).Rows.Count >= 1) Then

                        With oGetBankGuaranteeResponse

                            .BankGuarantee.BankBranch = Cast.ToString(dsBankGuarantee.Tables(0).Rows(0).Item("bank_branch"), Nothing)
                            .BankGuarantee.BankGuaranteeRef = Cast.ToString(dsBankGuarantee.Tables(0).Rows(0).Item("BG_Ref"), Nothing)
                            .BankGuarantee.BGKey = Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("bg_id"), 0)
                            .BankGuarantee.BankNameKey = Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("bank_name_id"), 0)
                            .BankGuarantee.BankNameDesc = GetAndValidateDescriptionById(conBankGuarantee, "Bank", "bank_name", "bank_id", Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("bank_name_id"), 0).ToString())
                            .BankGuarantee.BGLimit = Cast.ToDecimal(dsBankGuarantee.Tables(0).Rows(0).Item("bg_Limit"), 0)
                            .BankGuarantee.BGCurrencyKey = Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("BG_currency_id"), 0)
                            .BankGuarantee.BGCurrencyCode = GetAndValidateDescriptionById(conBankGuarantee, "Currency", "code", "Currency_Id", .BankGuarantee.BGCurrencyKey.ToString())
                            .BankGuarantee.ExpiryDate = Cast.ToDateTime(dsBankGuarantee.Tables(0).Rows(0).Item("Expiry_Date"), Nothing)
                            .BankGuarantee.IsPolicyLock = Cast.ToBoolean(dsBankGuarantee.Tables(0).Rows(0).Item("Is_Policy_Lock"), False)
                            .BankGuarantee.IsDeleted = Cast.ToBoolean(dsBankGuarantee.Tables(0).Rows(0).Item("Is_Deleted"), False)
                            .BankGuarantee.PartyKey = Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("Party_cnt"), 0)
                            .BankGuarantee.LimitAvailable = Cast.ToDecimal(dsBankGuarantee.Tables(0).Rows(0).Item("available_bal"), 0)
                            .BankGuarantee.BGStatusCode = GetAndValidateDescriptionById(conBankGuarantee, "BG_Status", "code", "bg_status_id", Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("bg_status_id"), 0).ToString())
                            .BankGuarantee.CustodyBranchKey = Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("custody_branch_id"), 0)
                            .BankGuarantee.CustodyBranchCode = GetAndValidateDescriptionById(conBankGuarantee, "Source", "code", "Source_id", .BankGuarantee.CustodyBranchKey.ToString())
                            .BankGuarantee.IssueDate = Cast.ToDateTime(dsBankGuarantee.Tables(0).Rows(0).Item("issue_date"), Nothing)
                        End With
                    End If
                End If
            End If
        End Using

        Dim uBound As Integer = 0
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_BankGuarantee_PLLProduct")
            cmd.AddInParameter("@bg_id", SqlDbType.Int).Value = Cast.NullIfDefault(oGetBankGuaranteeRequest.BGKey, 0)
            dsBankGuaranteeProducts = conBankGuarantee.ExecuteDataSet(cmd, "BankGuaranteeItemProducts")
            If (dsBankGuaranteeProducts IsNot Nothing) Then
                If (dsBankGuaranteeProducts.Tables.Count >= 1) Then
                    If (dsBankGuaranteeProducts.Tables(0).Rows.Count >= 1) Then

                        For iCount As Integer = 0 To dsBankGuaranteeProducts.Tables(0).Rows.Count - 1
                            ReDim Preserve oGetBankGuaranteeResponse.BankGuarantee.Products(iCount)
                            oGetBankGuaranteeResponse.BankGuarantee.Products(iCount) = New BaseBankGuaranteeItemTypeProducts
                            With oGetBankGuaranteeResponse.BankGuarantee.Products(iCount)
                                .Description = Cast.ToString(dsBankGuaranteeProducts.Tables(0).Rows(iCount).Item("description"), Nothing)
                                .ProductKey = Cast.ToInt32(dsBankGuaranteeProducts.Tables(0).Rows(iCount).Item("Product_id"), 0)
                                .ProductCode = GetAndValidateDescriptionById(conBankGuarantee, "Product", "code", "Product_id", .ProductKey.ToString())
                            End With
                        Next

                    End If
                End If
            End If

        End Using

        uBound = 0
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_BankGuarantee_PLLSource")

            cmd.AddInParameter("@bg_id", SqlDbType.Int).Value = Cast.NullIfDefault(oGetBankGuaranteeRequest.BGKey, 0)

            dsBankGuaranteeBranches = conBankGuarantee.ExecuteDataSet(cmd, "BankGuaranteeItemBranches")

            If (dsBankGuaranteeBranches IsNot Nothing) Then
                If (dsBankGuaranteeBranches.Tables.Count >= 1) Then
                    If (dsBankGuaranteeBranches.Tables(0).Rows.Count >= 1) Then
                        ReDim oGetBankGuaranteeResponse.BankGuarantee.Branches(dsBankGuaranteeBranches.Tables(0).Rows.Count - 1)
                        For iCount As Integer = 0 To dsBankGuaranteeBranches.Tables(0).Rows.Count - 1
                            oGetBankGuaranteeResponse.BankGuarantee.Branches(iCount) = New BaseBankGuaranteeItemTypeBranches
                            With oGetBankGuaranteeResponse.BankGuarantee.Branches(iCount)
                                .Description = Cast.ToString(dsBankGuaranteeBranches.Tables(0).Rows(iCount).Item("description"), Nothing)
                                .SourceKey = Cast.ToInt32(dsBankGuaranteeBranches.Tables(0).Rows(iCount).Item("Source_id"), 0)
                                .BranchCode = GetAndValidateDescriptionById(conBankGuarantee, "Source", "code", "Source_id", .SourceKey.ToString())
                            End With

                        Next
                    End If
                End If
            End If
        End Using

        ' Get the Timestamp
        Dim bIsLocked As Boolean
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.GetTimestamp(
                            oGetBankGuaranteeRequest.BranchCode,
                            CoreBusiness.LockName.BGId,
                            oGetBankGuaranteeRequest.BGKey,
                            oGetBankGuaranteeResponse.BankGuarantee.BGTimeStamp,
                            bIsLocked)
        ' Return AnyErrors
        If AnyError Is Nothing = False Then
            oGetBankGuaranteeResponse.STSError = AnyError
        End If
        Return oGetBankGuaranteeResponse
    End Function

