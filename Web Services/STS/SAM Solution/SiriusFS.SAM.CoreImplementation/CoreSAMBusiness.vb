    ''' <summary>  
    ''' Find the Policy
    ''' </summary>  
    ''' <param name="oRequest">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseFindPolicyRequestType</param>  
    ''' <param name="con">An object of type SiriusConnection</param>  
    Public Overloads Function FindPolicy(ByRef con As SiriusConnection,
    ByVal oRequest As BaseFindPolicyRequestType) As BaseFindPolicyResponseType

        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseFindPolicyResponseType
        Dim nTypeOfPackage As enumTypeOfPackage

        Dim sDisableWildcardSearchOption As String = ""
        Dim sEnablePartialWildcardSearchOption As String = ""
        Dim bDisableWildcardSearchOption As Boolean
        Dim bEnablePartialWildcardSearchOption As Boolean
        Dim sErrorMessage As String = ""

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindPolicyRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.FindPolicyResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        '*******************
        ' STRUCTURE VALIDATION
        '*******************
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' DATA VALIDATION
        '*******************

        oBusiness.GetSystemOption(oRequest.BranchCode, SystemOption.DisableWildcardSearch, sDisableWildcardSearchOption)
        oBusiness.GetSystemOption(oRequest.BranchCode, SystemOption.EnablePartialWildcardSearch, sEnablePartialWildcardSearchOption)
        If (Trim(sDisableWildcardSearchOption) = "1") Then
            bDisableWildcardSearchOption = True
        Else
            bDisableWildcardSearchOption = False
        End If
        If (Trim(sEnablePartialWildcardSearchOption) = "1") Then
            bEnablePartialWildcardSearchOption = True
        Else
            bEnablePartialWildcardSearchOption = False
        End If

        If Not oBusiness.ValidWildcardSearch(
               bDisableWildcardSearchOption,
               bEnablePartialWildcardSearchOption,
               oRequest.InsuranceRef,
               sErrorMessage) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     sErrorMessage,
                                     "Shortname")
        End If
        oSAMErrorCollection.CheckForErrors()
        If Not oBusiness.ValidWildcardSearch(
                      bDisableWildcardSearchOption,
                      bEnablePartialWildcardSearchOption,
                      oRequest.ClientShortName,
                      sErrorMessage) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     sErrorMessage,
                                     "Name")
        End If
        oSAMErrorCollection.CheckForErrors()

        If Not oBusiness.ValidWildcardSearch(
              bDisableWildcardSearchOption,
              bEnablePartialWildcardSearchOption,
              oRequest.RiskIndex,
              sErrorMessage) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     sErrorMessage,
                                     "FileCode")
        End If
        oSAMErrorCollection.CheckForErrors()

        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        ' validate the policy number 
        oSAMErrorCollection.CheckForErrors()

        'Get Agent Group Details if AgentKey is provided
        With oRequest
            If (oRequest.AgentKey <> 0) Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Agent_Group_From_Agent_Key")
                    cmd.AddOutParameter("@agent_group_cnt", SqlDbType.Int)
                    cmd.AddInParameter("@agent_cnt", SqlDbType.Int).Value = .AgentKey

                    con.ExecuteNonQuery(cmd)
                    .AgentGroupKey = Cast.ToInt32(cmd.Parameters("@agent_group_cnt").Value, 0)
                End Using
            End If
        End With

        'Create the object to the component to get the InsuranceFile Details
        Dim oSIRFindInsurance As bSIRFindInsurance.Form

        'Create the object to the component  bSIRFindInsurance.Form
        oSIRFindInsurance = New bSIRFindInsurance.Form
        Try
            'Check the RisIndex for its Null value. If the RiskIndex is null then it will call  the function 
            'ProcessRiskIndexBaseInsuranceFileSearchForClaims otherwise it will call the funciton "ProcessRInsuranceFileSearchForClaims"
            If Not String.IsNullOrEmpty(oRequest.RiskIndex) Then
                oResponse = ProcessRiskIndexBasedPolicySearch _
                (oSIRFindInsurance, oRequest, oResponse)
            Else
                oResponse = ProcessPolicySearch(oSIRFindInsurance, oRequest, oResponse)
            End If
        Catch ex As Exception

        Finally
            If oSIRFindInsurance IsNot Nothing Then
                oSIRFindInsurance.Dispose()
                oSIRFindInsurance = Nothing
            End If
        End Try

        Return oResponse
    End Function

    ''' <summary>  
    ''' Find the Policy on basis of risk index
    ''' </summary>  
    ''' <param name="oSIRFindInsurance">An object of type bSIRFindInsurance.Form</param>  
    ''' <param name="oRequest">An object of type BaseFindPolicyRequestType</param>  
    Private Function ProcessRiskIndexBasedPolicySearch(ByVal _
        oSIRFindInsurance As bSIRFindInsurance.Form,
        ByRef oRequest As BaseFindPolicyRequestType, ByRef oResponse As BaseFindPolicyResponseType) _
        As BaseFindPolicyResponseType

        Dim oSAMErrorCollection As New SAMErrorCollection
        'Declare the variable to make sure the initialization 
        Dim lReturn As Integer

        Dim lComReturnValue As Integer
        Dim sEnableAgentProductLink As String = "0"
        Dim oBusiness As New CoreBusiness(_SiriusUser)
        Dim STSError As New STSErrorPublisher
        Dim bEnableAgentProductLink As Boolean = False

        Try
            oBusiness.GetSystemOption(oRequest.BranchCode, SystemOption.EnableAgentProductLink, sEnableAgentProductLink)
            If sEnableAgentProductLink = "1" And oRequest.AgentKey > 0 Then   '74552
                bEnableAgentProductLink = True
            End If
        Catch ex As Exception
            STSError.AddInvalidField("EnableAgentProductLink", CStr(STSErrorCodes.EnableAgentProductLinkFieldInvalid), [String].Format(STSErrorPublisher.InValidField, "EnableAgentProductLink"), oRequest.BranchCode)
        End Try

        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), "ProcessRiskIndexBasedPolicySearch", "System Options field validation", True)
            Return oResponse
        End If

        Dim vResultArray As Object = Nothing

        lReturn = CInt(oSIRFindInsurance.Initialise(
                              _SiriusUser.Username,
                              _SiriusUser.Password,
                              _SiriusUser.UserID,
                              _SiriusUser.SourceID,
                              _SiriusUser.LanguageID,
                              _SiriusUser.CurrencyID,
                              1,
                              SiriusUserDefaults.AppName))

        Dim vResultArray1(,) As Object = CType(vResultArray, Object(,))
        lComReturnValue = oSIRFindInsurance.FindLikeIndex(sIndex:=oRequest.RiskIndex,
        lNumberOfRecords:=oRequest.MaxRowsToFetch, vResultArray:=vResultArray1, v_vAgentGroupCnt:=oRequest.AgentGroupKey)
        vResultArray = CType(vResultArray1, Object)
        'lNumberOfRecords:=oRequest.MaxRowsToFetch, vResultArray:=CType(vResultArray, Object(,)), v_vAgentGroupCnt:=oRequest.AgentGroupKey)

        If (lComReturnValue <> PMReturnCode.PMTrue) Then
            RaiseComMethodException("oSIRFindInsurance.FindLikeIndex", lComReturnValue)
        End If

        Dim strXML As String = String.Empty
        Dim oXMLDoc As System.Xml.XmlDocument
        Dim oResultArrayOut As Object = Nothing
        Dim oResultArrayCopy(,) As Object = Nothing
        Dim oFilterCol() As Object = {0, 1, 4, 9, 11, 13, 16, 17, 20, 21, 22, 23, 24, 25, 26} 'These are the column needs to be filter from object array 

        Dim typeOfPackage As enumTypeOfPackage

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindPolicyRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.FindPolicyResponseType
        End If

        strXML = String.Empty
        oXMLDoc = New System.Xml.XmlDocument
        Dim dsResult As New DataSet

        If vResultArray.ToString <> "" Then
            Try
                Dim arrColHeaders(,) As Object = {{"InsuranceFileKey",
                            "InsuranceRef",
                            "InsuranceFileType",
                            "ClientName", "ClientShortName", "PartyKey", "LastModifiedDate", "InsuranceFolderKey", "ProductCode", "ProductDescription", "RiskIndex", "Value", "Status"},
                        {System.Type.GetType("System.Int32"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.Int32"),
                        System.Type.GetType("System.DateTime"),
                        System.Type.GetType("System.Int32"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String")}}

                oResultArrayOut = CopyArrayWithFilters(CType(vResultArray, Object(,)), oResultArrayCopy, oFilterCol)
                dsResult = Utilities.ArrayToDataSet(oResultArrayOut, arrColHeaders, "BaseFindPolicyResponseTypeInsuranceFileDetails")

                If dsResult.Tables.Count > 0 Then
                    If dsResult.Tables(0).Rows.Count > 0 Then
                        dsResult.Tables(0).TableName = "Row"
                        dsResult.Tables(0).Columns(0).ColumnName = "InsuranceFileKey"
                        dsResult.Tables(0).Columns(1).ColumnName = "InsuranceRef"
                        dsResult.Tables(0).Columns(2).ColumnName = "InsuranceFileType"
                        dsResult.Tables(0).Columns(3).ColumnName = "ClientName"
                        dsResult.Tables(0).Columns(4).ColumnName = "ClientShortName"
                        dsResult.Tables(0).Columns(5).ColumnName = "PartyKey"
                        dsResult.Tables(0).Columns(6).ColumnName = "LastModifiedDate"
                        dsResult.Tables(0).Columns(7).ColumnName = "InsuranceFolderKey"
                        dsResult.Tables(0).Columns(8).ColumnName = "ProductCode"
                        dsResult.Tables(0).Columns(9).ColumnName = "ProductDescription"
                        dsResult.Tables(0).Columns(10).ColumnName = "RiskIndex"
                        dsResult.Tables(0).Columns(11).ColumnName = "Value"
                        dsResult.Tables(0).Columns(12).ColumnName = "Status"
                    End If
                End If

                If oRequest.WCFSecurityToken = "" Then
                    strXML = dsResult.GetXml()
                    oXMLDoc.LoadXml(strXML)
                    oResponse.ResultDataset = oXMLDoc.DocumentElement
                End If
                oResponse.ResultData = dsResult
            Catch ex As Exception
                oSAMErrorCollection.AddFatal(ex)
                oSAMErrorCollection.CheckForErrors()
            Finally
                If oSIRFindInsurance IsNot Nothing Then
                    oSIRFindInsurance.Dispose()
                    oSIRFindInsurance = Nothing
                End If
            End Try
        End If

        Return oResponse
    End Function

    ''' <summary>  
    ''' Find the Policy on basis of other search criteria
    ''' </summary>  
    ''' <param name="oSIRFindInsurance">An object of type bSIRFindInsurance.Form</param>  
    ''' <param name="oRequest">An object of type BaseFindPolicyRequestType</param>  
    Private Function ProcessPolicySearch(ByVal oSIRFindInsurance As _
  bSIRFindInsurance.Form, ByRef oRequest As BaseFindPolicyRequestType,
   ByRef oResponse As BaseFindPolicyResponseType) As BaseFindPolicyResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        'Declare the variable to make sure the initialization 
        Dim lReturn As Integer

        Dim lComReturnValue As Integer

        Dim vResultArray As Object(,) = Nothing

        Dim sEnableAgentProductLink As String = "0"
        Dim oBusiness As New CoreBusiness(_SiriusUser)
        Dim STSError As New STSErrorPublisher
        Dim bEnableAgentProductLink As Boolean = False

        Try
            oBusiness.GetSystemOption(oRequest.BranchCode, SystemOption.EnableAgentProductLink, sEnableAgentProductLink)
            If sEnableAgentProductLink = "1" And oRequest.AgentKey > 0 Then  'PN 74552
                bEnableAgentProductLink = True
            End If
        Catch ex As Exception
            STSError.AddInvalidField("EnableAgentProductLink", CStr(STSErrorCodes.EnableAgentProductLinkFieldInvalid), [String].Format(STSErrorPublisher.InValidField, "EnableAgentProductLink"), oRequest.BranchCode)
        End Try

        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), "ProcessPolicySearch", "System Options field validation", True)
            Return oResponse
        End If


        lReturn = CInt(oSIRFindInsurance.Initialise(
                             _SiriusUser.Username,
                             _SiriusUser.Password,
                             _SiriusUser.UserID,
                             _SiriusUser.SourceID,
                             _SiriusUser.LanguageID,
                             _SiriusUser.CurrencyID,
                             1,
                             SiriusUserDefaults.AppName))
        oSIRFindInsurance.FindMode = 1
        With oRequest
            oSIRFindInsurance.FindMode = 1
            lComReturnValue = oSIRFindInsurance.SearchByQuery(r_vResultArray:=vResultArray, v_vInsuranceRef:= .InsuranceRef,
                                        v_vInsFileType:=IIf(.QuoteTypeSpecified, .QuoteType, Nothing), v_vShortName:= .ClientShortName,
                                        v_bShowLapsedOnly:= .ShowLapsedOnlySpecified, v_vAgentGroupCnt:= .AgentGroupKey, v_bLimitResults:=True, v_bShowCurrentPolicyOnly:=True, v_lNumberOfRecords:=oRequest.MaxRowsToFetch, v_bShowCancelledForEvents:= .ShowCancelledForEvents,
                                        bRetrieveAssociated:= .RetrieveAssociates, v_vAgentKey:= .AgentKey)
        End With

        If (lComReturnValue <> PMReturnCode.PMTrue) Then
            RaiseComMethodException("oSIRFindInsurance.SearchByQuery", lComReturnValue)
        End If

        Dim strXML As String = String.Empty
        Dim oXMLDoc As System.Xml.XmlDocument
        Dim oResultArrayOut As Object = Nothing
        Dim oResultArrayCopy(,) As Object = Nothing
        Dim oFilterCol() As Object = {0, 1, 4, 9, 11, 13, 16, 19, 20, 21, 22} 'These are the column needs to be filter from object array 

        Dim typeOfPackage As enumTypeOfPackage

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindPolicyRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.FindPolicyResponseType
        End If

        strXML = String.Empty
        oXMLDoc = New System.Xml.XmlDocument
        Dim dsResult As New DataSet

        If vResultArray.ToString <> "" Then
            Try
                Dim arrColHeaders(,) As Object = {{"InsuranceFileKey",
                           "InsuranceRef",
                           "InsuranceFileType",
                           "ClientName", "ClientShortName", "PartyKey", "LastModifiedDate", "InsuranceFolderKey", "ProductCode", "ProductDescription", "CreatedDate", "Status", "IsMarketPlacePolicy", "AssociatedClients"},
                       {System.Type.GetType("System.Int32"),
                       System.Type.GetType("System.String"),
                       System.Type.GetType("System.String"),
                       System.Type.GetType("System.String"),
                       System.Type.GetType("System.String"),
                       System.Type.GetType("System.Int32"),
                       System.Type.GetType("System.DateTime"),
                       System.Type.GetType("System.Int32"),
                       System.Type.GetType("System.String"),
                       System.Type.GetType("System.String"),
                       System.Type.GetType("System.DateTime"),
                       System.Type.GetType("System.String"),
                       System.Type.GetType("System.Int32"),
                       System.Type.GetType("System.String")}}
                oResultArrayOut = CopyArrayWithFilters(CType(vResultArray, Object(,)), oResultArrayCopy, oFilterCol)
                dsResult = Utilities.ArrayToDataSet(oResultArrayOut, arrColHeaders, "BaseFindPolicyResponseTypeInsuranceFileDetails")

                If dsResult.Tables.Count > 0 Then
                    If dsResult.Tables(0).Rows.Count > 0 Then
                        dsResult.Tables(0).TableName = "Row"
                        dsResult.Tables(0).Columns(0).ColumnName = "InsuranceFileKey"
                        dsResult.Tables(0).Columns(1).ColumnName = "InsuranceRef"
                        dsResult.Tables(0).Columns(2).ColumnName = "InsuranceFileType"
                        dsResult.Tables(0).Columns(3).ColumnName = "ClientName"
                        dsResult.Tables(0).Columns(4).ColumnName = "ClientShortName"
                        dsResult.Tables(0).Columns(5).ColumnName = "PartyKey"
                        dsResult.Tables(0).Columns(6).ColumnName = "LastModifiedDate"
                        dsResult.Tables(0).Columns(7).ColumnName = "InsuranceFolderKey"
                        dsResult.Tables(0).Columns(8).ColumnName = "ProductCode"
                        dsResult.Tables(0).Columns(9).ColumnName = "ProductDescription"
                        dsResult.Tables(0).Columns(10).ColumnName = "CreatedDate"
                        dsResult.Tables(0).Columns(11).ColumnName = "Status"
                        dsResult.Tables(0).Columns(12).ColumnName = "IsMarketPlacePolicy"
                        dsResult.Tables(0).Columns(13).ColumnName = "AssociatedClients"

                    End If
                End If
                If oRequest.RetrieveAssociates = True Then
                    dsResult.Tables(0).Columns(13).ReadOnly = False
                    AddExtraXMLElementForPolicyAssociate(dsResult, "AssociatedClients")
                End If
                If oRequest.WCFSecurityToken = "" Then
                    strXML = dsResult.GetXml()
                    oXMLDoc.LoadXml(strXML)
                    oResponse.ResultDataset = oXMLDoc.DocumentElement
                End If

                oResponse.ResultData = dsResult

            Catch ex As Exception
                oSAMErrorCollection.AddFatal(ex)
                oSAMErrorCollection.CheckForErrors()

            Finally
                If oSIRFindInsurance IsNot Nothing Then
                    oSIRFindInsurance.Dispose()
                    oSIRFindInsurance = Nothing
                End If
            End Try
        End If

        Return oResponse
    End Function

