    Private Overloads Function LapseRenewal(ByVal con As SiriusConnection, ByVal request As BaseLapseRenewalRequestType) As BaseLapseRenewalResponseType

        Dim samError As SAMErrorCollection = New SAMErrorCollection
        Dim coreBusiness As New CoreBusiness(_SiriusUser)

        ' validate the mandatory structure data
        request.Validate(CType(samError, Object))

        ' if there were any errors throw an exception
        samError.CheckForErrors()

        ' Check Item is in renewal
        'ValidatePolicyIsInRenewal(con, request.InsuranceFileKey)

        ' Validate and get Lapsed reason Id From Lapsed reason Code.
        Dim lapsedReasonDesc As String = ""
        Dim lapsedReasonId As Integer = coreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.LapsedReason,
                                                                                    request.LapseReasonCode, "Code", samError, lapsedReasonDesc)

        Dim response As New BaseImplementationTypes.BaseLapseRenewalResponseType
        Dim typeOfPackage As enumTypeOfPackage

        If request.GetType Is GetType(SAMForInsuranceImplementationTypes.LapseRenewalRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            response = New SAMForInsuranceImplementationTypes.LapseRenewalResponseType
        ElseIf request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.LapseRenewalRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            response = New SAMForInsuranceV2ImplementationTypes.LapseRenewalResponseType
        End If

        Dim insuranceFolderKey As Integer
        Dim partyKey As Integer
        Dim renewalStatuskey As Integer
        Dim originalInsuranceFileKey As Integer
        Dim lapseRenewalData As DataTable
        Dim sInsuranceRef As String
        ' Get details for Lapse Renewal passing the renewal insurance file key
        lapseRenewalData = GetDetailsForLapseRenewal(con, request.InsuranceFileKey)
        If lapseRenewalData Is Nothing Or lapseRenewalData.Rows.Count = 0 Then
            samError.AddBusinessRule(SAMBusinessErrors.InsuranceFileDetailsNotFound,
                                                SAMBusinessErrors.InsuranceFileDetailsNotFound.ToString)
            samError.CheckForErrors()
        Else
            renewalStatuskey = Cast.ToInt32(lapseRenewalData.Rows(0)("renewal_status_cnt"), 0)
            partyKey = Cast.ToInt32(lapseRenewalData.Rows(0)("party_cnt"), 0)
            insuranceFolderKey = Cast.ToInt32(lapseRenewalData.Rows(0)("insurance_folder_cnt"), 0)
            originalInsuranceFileKey = Cast.ToInt32(lapseRenewalData.Rows(0)("Original_insurance_file_cnt"), 0)
            sInsuranceRef = lapseRenewalData.Rows(0)("insurance_ref").ToString()
        End If

        ' Check that the timestamp matches and lock the Quote
        coreBusiness.CheckSAMTSAndLock(Con:=con,
                           BranchCode:=request.BranchCode,
                           Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                           LockValue:=insuranceFolderKey,
                           TStamp:=request.QuoteTimeStamp)

        ' Call the bsirRenewalProcess.LapseRenewal process,
        LapseRenewal(con, request, insuranceFolderKey, partyKey, renewalStatuskey, originalInsuranceFileKey, lapsedReasonId, lapsedReasonDesc, sInsuranceRef)



        ' Unlock and return the new timestamp
        coreBusiness.UnlockAndGetSAMTS(Con:=con,
                     BranchCode:=request.BranchCode,
                     Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                     LockValue:=insuranceFolderKey,
                     TStamp:=response.QuoteTimeStamp)

        Return response

    End Function

    Private Overloads Sub LapseRenewal(ByVal con As SiriusConnection, ByVal request As BaseLapseRenewalRequestType,
                                       ByVal insuranceFolderKey As Integer, ByVal partyKey As Integer, ByVal renewalStatuskey As Integer,
                                       ByVal originalInsuranceFileKey As Integer, ByVal lapsedReasonId As Integer,
                                       ByVal lapsedReasonDesc As String, Optional ByVal v_sInsuranceRef As String = "")

        Dim comReturnValue As Integer
        Dim failureMessage As String = ""
        Dim renewalProcess As bSIRRenewalProcess.Business = Nothing

        Try
            renewalProcess = CreateAndInitialiseRenewalProcess(con, request.BranchCode)
            comReturnValue = CType(renewalProcess.LapseRenewal(
                                 v_lRenewalInsuranceFileCnt:=request.InsuranceFileKey,
                                    v_lInsuranceFileCnt:=originalInsuranceFileKey,
                                    v_lRenewalStatusCnt:=renewalStatuskey,
                                    v_lLapseReasonID:=lapsedReasonId,
                                    v_sLapseReasonDesc:=lapsedReasonDesc,
                                    v_lPartyCnt:=partyKey,
                                    v_lInsuranceFolderCnt:=insuranceFolderKey,
                                    r_sFailureMessage:=failureMessage), Integer)

            If comReturnValue <> PMEReturnCode.PMTrue Then
                RaiseComMethodException("bsirRenewalProcess.LapseRenewal Failed. Failure Message:" + failureMessage)
            Else
                Dim lTaskInstanceCnt As Integer
                Dim CoreBusiness As New CoreBusiness
                Dim sDescription As String

