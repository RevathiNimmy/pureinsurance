                            ReDim oGetPolicyTransactionDetailsTransactionsExtended(0)
                            nBuckets = 0
                            dtCurrentDueDate = Date.MinValue
                            dtCurrentFeeDueDate = Date.MinValue

                            For iCntLevel2 = 0 To dataViewtrans.ToTable.Rows.Count - 1
                                If dtCurrentDueDate <> Convert.ToDateTime((dataViewtrans.ToTable.Rows(iCntLevel2).Item("EffectiveDate"))) Then
                                    ReDim Preserve oGetPolicyTransactionDetailsTransactionsExtended(nBuckets)
                                    oGetPolicyTransactionDetailsTransactionsExtended(nBuckets) = New BaseGetPolicyTransactionDetailsResponseTypeTransactionsExtended
                                    dtCurrentDueDate = Convert.ToDateTime((dataViewtrans.ToTable.Rows(iCntLevel2).Item("EffectiveDate")))
                                    nBuckets = nBuckets + 1
                                End If

                                oGetPolicyTransactionDetailsTransactionsExtended(nBuckets - 1).DueDate = Convert.ToDateTime((dataViewtrans.ToTable.Rows(iCntLevel2).Item("EffectiveDate")))
                                If Cast.ToStringTrim(dataViewtrans.ToTable.Rows(iCntLevel2).Item("Transdetail_Type_Code")).ToUpper = "GROSS" Then
