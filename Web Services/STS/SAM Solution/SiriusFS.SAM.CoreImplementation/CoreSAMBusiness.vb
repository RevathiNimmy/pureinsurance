    ''' <summary>
    ''' Change password through WCF
    ''' </summary>
    ''' <param name="oRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function ChangePassword(ByVal con As SiriusConnection, ByVal oRequest As BaseChangePasswordRequestType) As BaseChangePasswordResponseType
        Dim iRet As Int32
        Dim oPMUserBusiness As Bpmuser.Business = Nothing
        Dim oBusiness As New CoreBusiness
        Dim iUserId As Integer

        Dim nTypeOfPackage As enumTypeOfPackage

        Dim oResponse As New BaseImplementationTypes.BaseChangePasswordResponseType

        Dim STSError As New STSErrorPublisher

        Const ACMethodName As String = "ChangePassword"

        ' Check the Package type that is requesting logoff
        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ChangePasswordRequestType) Then
            oResponse = New SAMForInsuranceV2ImplementationTypes.ChangePasswordResponseType
            nTypeOfPackage = enumTypeOfPackage.AgentsPackage
        Else
            nTypeOfPackage = enumTypeOfPackage.OtherPackage
        End If


        If oRequest.BranchCode = "" Then
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "BranchCode"), "")
        End If

        If oRequest.UserName = "" Then
            STSError.AddInvalidField("UserName", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "UserName"), "")
        End If

        If oRequest.NewPasswordHashed = "" Then
            STSError.AddInvalidField("NewPasswordHashed", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "NewPasswordHashed"), "")
        End If
        If oRequest.NewEncryptedPassword = "" Then '  Can password be blank????
            STSError.AddInvalidField("NewEncryptedPassword", CStr(STSErrorCodes.MandatoryInputMissing), [String].Format(STSErrorPublisher.MandatoryInputMissing, "NewEncryptedPassword"), "")
        End If
        ' exit if there are any missing parameters
        If STSError.HasErrors Then
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Mandatory field validation", True)
            Return DirectCast(oResponse, BaseChangePasswordResponseType)
        End If

        ' Branch Code
        Try
            Dim iSourceId As Integer = oBusiness.GetListItemFromCode(Core.STSListType.PMLookup, "Source", oRequest.BranchCode)
        Catch ex As Exception
            ' not set
            STSError.AddInvalidField("BranchCode", CStr(STSErrorCodes.BranchCodeInvalid), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "BranchCode"), oRequest.BranchCode)
        End Try

        Try
            iUserId = GetUserId(con, oRequest.UserName)
        Catch ex As Exception
            ' not set
            STSError.AddInvalidField("UserName", CStr(STSErrorCodes.BranchCodeInvalid), [String].Format(STSErrorPublisher.MandatoryInputInvalid, "UserName"), oRequest.UserName)
        End Try

        ' Check for any errors
        If STSError.HasErrors Then
            ' Set the context
            STSError.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "Input Validation", True)
            ' Return the errors
            Return DirectCast(oResponse, BaseChangePasswordResponseType)
        End If

        ' Create an instance of bPMUser.Business
        Try
            oPMUserBusiness = New Bpmuser.Business
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bPMUser.Business", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return DirectCast(oResponse, BaseChangePasswordResponseType)
        Finally
        End Try

        Dim SiriusUser As New SIRIUSUSER
        SiriusUser.UserID = CShort(iUserId)
        SiriusUser.Username = oRequest.UserName
        ' Initialise the bPMUser.Business
        Try
            SAMFunc.InitialiseSBOObject(oPMUserBusiness, SiriusUser)
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to intialise bPMUser.Business", ex.Message)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "Init bPMUser", True)
        End Try

        ' Call the Method
        Try
            iRet = oPMUserBusiness.GetDetails(vUserId:=CObj(iUserId))
            If iRet <> gPMConstants.PMEReturnCode.PMTrue Then
                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "oPMUserBusiness.GetDetails returned an error. Return Value = " + iRet.ToString, "")
                STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            End If
        Catch ex As Exception
            If oPMUserBusiness IsNot Nothing Then
                oPMUserBusiness.Dispose()
                oPMUserBusiness = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "Failed to call oPMUserBusiness.GetDetails", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return DirectCast(oResponse, BaseChangePasswordResponseType)
        End Try

        Try
            'sOldPassword field Replace Encrypted password into password column in pmuser with old Encryption logic 
            iRet = oPMUserBusiness.EditUpdate(lRow:=1, vUserId:=CObj(iUserId), vUsername:=CObj(oRequest.UserName), vPassword:=CObj(oRequest.NewPasswordHashed), vPasswordChangeDate:=DateTime.Now, vIsTempPassword:=False, sOldPassword:=oRequest.NewEncryptedPassword)
            If iRet <> gPMConstants.PMEReturnCode.PMTrue Then
                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "oPMUserBusiness.EditUpdate returned an error. Return Value = " + iRet.ToString, "")
                STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            End If
        Catch ex As Exception
            If oPMUserBusiness IsNot Nothing Then
                oPMUserBusiness.Dispose()
                oPMUserBusiness = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "Failed to call oPMUserBusiness.EditUpdate", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return DirectCast(oResponse, BaseChangePasswordResponseType)
        End Try

        Try
            iRet = oPMUserBusiness.Update
            If iRet <> gPMConstants.PMEReturnCode.PMTrue Then
                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "oPMUserBusiness.Update returned an error. Return Value = " + iRet.ToString, "")
                STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            End If
        Catch ex As Exception
            If oPMUserBusiness IsNot Nothing Then
                oPMUserBusiness.Dispose()
                oPMUserBusiness = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "Failed to call bPMUser.Update", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return DirectCast(oResponse, BaseChangePasswordResponseType)
        End Try

        Try
            iRet = oPMUserBusiness.UpdatePasswordHistory(iUser_Id:=iUserId)
            If iRet <> gPMConstants.PMEReturnCode.PMTrue Then
                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "oPMUserBusiness.UpdatePasswordHistory returned an error. Return Value = " + iRet.ToString, "")
                STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            End If
        Catch ex As Exception
            If oPMUserBusiness IsNot Nothing Then
                oPMUserBusiness.Dispose()
                oPMUserBusiness = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "Failed to call oPMUserBusiness.UpdatePasswordHistory", ex.Message)
            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return DirectCast(oResponse, BaseChangePasswordResponseType)
        End Try
        Dim dt As DataTable = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_User_Details")

            cmd.AddInParameter("@UserID", SqlDbType.Int).Value = iUserId

            dt = con.ExecuteDataTable(cmd)

        End Using

        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

            Dim oSources As BaseBranchType() = Nothing

            ' resize array
            Array.Resize(oSources, dt.Rows.Count)

            Dim iSource As Integer = 0

            ' for each source
            Dim dr As DataRow = dt.Rows(0)

            oResponse.FullUserName = Cast.ToString(dr.Item("FullUsername"), String.Empty)

            oResponse.EmailAddress = Cast.ToString(dr.Item("EmailAddress"), String.Empty)

        End If
        If oPMUserBusiness IsNot Nothing Then
            oPMUserBusiness.Dispose()
            oPMUserBusiness = Nothing
        End If

        Return oResponse
    End Function


