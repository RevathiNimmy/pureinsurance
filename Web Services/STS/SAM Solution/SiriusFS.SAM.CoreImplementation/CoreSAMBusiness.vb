    Public Overloads Function DeleteCoverNoteSheet(ByVal conDeleteCoverNoteSheet As SiriusConnection, ByVal oDeleteCoverNoteSheetRequest As BaseDeleteCoverNoteSheetRequestType) As BaseDeleteCoverNoteSheetResponseType

        Dim oDeleteCoverNoteSheetResponse As New BaseDeleteCoverNoteSheetResponseType
