        ''Request structure validation
        oUpdateFeeRequest.Validate(CType(oErrors, Object))
        'oUpdateFeeRequest.
        oErrors.CheckForErrors()


        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Policy_Fee")
            cmd.Parameters.Clear()
            cmd.AddInParameter("@policy_fee_u_id", SqlDbType.Int).Value = oUpdateFeeRequest.FeeKey
            If Not oUpdateFeeRequest.IsValue Then
                cmd.AddInParameter("@fee_amount", SqlDbType.Money).Value = 0D
                cmd.AddInParameter("@fee_percentage", SqlDbType.Money).Value = oUpdateFeeRequest.Rate
                cmd.AddInParameter("@FeeTypePercent", SqlDbType.Bit).Value = 1
