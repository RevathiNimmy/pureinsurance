                        oTransRow.FinancePlanKey = ToSafeInteger(Cast.NullIfDefault(.GetValue(82, i), 0))
                        oTransRow.FinancePlanVersion = ToSafeInteger(Cast.NullIfDefault(.GetValue(83, i), 0))
                        oTransRow.FinancePlanStatus = ToSafeString(Cast.NullIfDefault(.GetValue(84, i), "")).Trim()
                        If (.GetValue(28, i) IsNot Nothing AndAlso Not String.IsNullOrEmpty(.GetValue(28, i).ToString)) Then
                            oTransRow.Insurance_file_cnt = ToSafeInteger(Cast.NullIfDefault(.GetValue(28, i), 0))
                        End If
                        Dim party_agent_cnt As Integer = 0
                        Dim agent_cnt As Integer = 0
                        Dim party_cnt As Integer = 0
                        party_agent_cnt = ToSafeInteger(Cast.NullIfDefault(.GetValue(80, i), 0))
                        If (lColCnt > 85) Then
                            If (.GetValue(86, i) IsNot Nothing AndAlso Not String.IsNullOrEmpty(.GetValue(86, i).ToString)) Then
                                party_cnt = ToSafeInteger(Cast.NullIfDefault(.GetValue(86, i), 0))
                            End If
                        End If
                        If (lColCnt > 86) Then
                            If (.GetValue(87, i) IsNot Nothing AndAlso Not String.IsNullOrEmpty(.GetValue(87, i).ToString)) Then
