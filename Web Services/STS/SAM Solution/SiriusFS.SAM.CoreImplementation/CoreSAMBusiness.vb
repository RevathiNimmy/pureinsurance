                    IsFeeTypePercent = CBool(Cast.ToBoolean(dsFees.Tables(0).Rows(iCount).Item("FeeTypePercent"), False))

                    If Not (IsFeeTypePercent) Then
                        dsFilter.Tables(0).Rows(iCount)("Rate") = Cast.ToDouble(dsFees.Tables(0).Rows(iCount).Item("fee_rate_amount"), 0.0)
