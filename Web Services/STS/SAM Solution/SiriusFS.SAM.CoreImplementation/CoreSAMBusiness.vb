    Private Sub ClearRiskOutput(ByVal sDataModelCode As String,
                                      ByRef XMLDataset As String,
                                      Optional ByVal bSkipSaveToDB As Boolean = False)

        Dim document As New XmlDocument
        document.LoadXml(XMLDataset)
        Dim sXPath As String
        Dim navigator As XPathNavigator
        Dim nodes As XPathNodeIterator
        Dim sNamespace As String
        Dim iCnt As Integer

        For iCnt = 0 To CountReferAndDecline(XMLDataset, sDataModelCode)
            sXPath = "/DATA_SET/RISK_OBJECTS/" & sDataModelCode.ToString & "_POLICY_BINDER/" & sDataModelCode.ToString & "_OUTPUT"

            navigator = document.CreateNavigator()
            nodes = navigator.Select(sXPath)

            sNamespace = navigator.LookupNamespace(navigator.Prefix)

            While nodes.MoveNext

                If nodes.Current.MoveToAttribute("US", sNamespace) Then
                    If nodes.Current.Value = "1" Or bSkipSaveToDB = True Then
                        nodes.Current.MoveToParent()
                        nodes.Current.DeleteSelf()
                    Else
                        nodes.Current.SetValue("3")
                    End If

                End If

            End While

            navigator.MoveToRoot()
        Next

        'NB: The below syntax is best guess - it was navigator.UnderlyingObject.outerxml.ToString
        ' which does resolve with option strict on 
        Dim myXMLNode As XmlNode = DirectCast(navigator.UnderlyingObject, XmlNode)

        XMLDataset = myXMLNode.OuterXml.ToString

    End Sub

