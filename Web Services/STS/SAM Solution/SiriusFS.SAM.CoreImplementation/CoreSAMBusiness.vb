                    lComReturnValue = obCLMCaseBusiness.GenerateSQL(r_sSQL:=sSQL, v_sClaimNumber:=Cast.ToString(.ClaimNumber, String.Empty),
                    v_sCaseNumber:=Cast.ToString(.CaseNumber, String.Empty),
                    v_lRiskTypeID:=Cast.ToInt32(.RiskTypeID, 0),
                    v_lProgressStatusID:=Cast.ToInt32(.ProgressStatusCodeID, 0))
                Else
                    lComReturnValue = obCLMCaseBusiness.GenerateSQL(r_sSQL:=sSQL, v_sClaimNumber:=Cast.ToString(.ClaimNumber, String.Empty),
                   v_sCaseNumber:=Cast.ToString(.CaseNumber, String.Empty),
                   v_lRiskTypeID:=Cast.ToInt32(.RiskTypeID, 0),
                   v_lProgressStatusID:=Cast.ToInt32(.ProgressStatusCodeID, 0),
                   v_vCaseOpenDate:=CDate(.CaseOpenDate.ToShortDateString))
                End If

            End With

            'Get the case details from the business object
            Dim oResultSet1(,) As Object = CType(oResultSet, Object(,))
            lComReturnValue = CInt(obCLMCaseBusiness.FindCase(v_sSQL:=sSQL, r_vResultArray:=oResultSet1, v_lNumberRecords:=oRequest.MaxRowsToFetch))
            oResultSet = CType(oResultSet1, Object)
            If (lComReturnValue <> PMReturnCode.PMTrue) Then
                RaiseComMethodException("obCLMCaseBusiness.FindCase",
                lComReturnValue)
            End If

            Dim dsCaseDetails As New DataSet
            Dim dsResultCaseDetails As New DataSet
            If (oResultSet IsNot Nothing) AndAlso TypeOf (oResultSet) Is System.Array Then
                'Convert the object into the DataSet
                dsCaseDetails = Utilities.ArrayToDataSet(oResultSet)

                If dsCaseDetails.Tables.Count >= 1 Then
                    If (dsCaseDetails.Tables(0).Rows.Count >= 1) Then
                        dsResultCaseDetails.Tables.Add()
                        dsResultCaseDetails.Tables(0).Columns.Add("CaseKey", GetType(System.Int32))
                        dsResultCaseDetails.Tables(0).Columns.Add("CaseNumber", GetType(System.String))
                        dsResultCaseDetails.Tables(0).Columns.Add("Analyst", GetType(System.String))
                        dsResultCaseDetails.Tables(0).Columns.Add("Assistant", GetType(System.String))
                        dsResultCaseDetails.Tables(0).Columns.Add("CaseProgressDescription", GetType(System.String))
                        dsResultCaseDetails.Tables(0).Columns.Add("TotalIndemnity", GetType(System.Decimal))
                        dsResultCaseDetails.Tables(0).Columns.Add("TotalExpense", GetType(System.Decimal))
                        dsResultCaseDetails.Tables(0).Columns.Add("TotalExcess", GetType(System.Decimal))
                        dsResultCaseDetails.Tables(0).Columns.Add("BaseCaseKey", GetType(System.Int32))
                        dsResultCaseDetails.Tables(0).Columns.Add("CaseOpenDate", GetType(System.DateTime))
                        dsResultCaseDetails.Tables(0).Columns.Add("CurrencyCode", GetType(System.String))

                        Dim iCount As Integer = 0
                        For iCount = 0 To dsCaseDetails.Tables(0).Rows.Count - 1
                            'Data are extracted from the DataSet and put it into corresponding objects
                            With dsCaseDetails.Tables(0).Rows(iCount)
                                'Note:Ideally we should fetch the data using column names 
                                'but as we havenot got the column names we are using the column index.
                                dsResultCaseDetails.Tables(0).Rows.Add()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("CaseKey") = CInt(dsCaseDetails.Tables(0).Rows(iCount)(0))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("CaseNumber") = dsCaseDetails.Tables(0).Rows(iCount)(1).ToString()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("Analyst") = dsCaseDetails.Tables(0).Rows(iCount)(3).ToString()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("Assistant") = dsCaseDetails.Tables(0).Rows(iCount)(4).ToString()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("CaseProgressDescription") = dsCaseDetails.Tables(0).Rows(iCount)(5).ToString()
                                dsResultCaseDetails.Tables(0).Rows(iCount)("TotalIndemnity") = CDbl(dsCaseDetails.Tables(0).Rows(iCount)(6))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("TotalExpense") = CDbl(dsCaseDetails.Tables(0).Rows(iCount)(7))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("TotalExcess") = CDbl(dsCaseDetails.Tables(0).Rows(iCount)(8))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("BaseCaseKey") = CInt(dsCaseDetails.Tables(0).Rows(iCount)(9))
                                dsResultCaseDetails.Tables(0).Rows(iCount)("CurrencyCode") = Convert.ToString(GetCurrencyCodeForCase(CInt(dsCaseDetails.Tables(0).Rows(iCount)(9))))
                                If (CDate(dsCaseDetails.Tables(0).Rows(iCount)(2)) > Date.MinValue) Then
                                    dsResultCaseDetails.Tables(0).Rows(iCount)("CaseOpenDate") = CDate(.Item(2))
                                End If
                                If CInt(dsCaseDetails.Tables(0).Rows(iCount)(9)) > 0 Then
                                    dsResultCaseDetails.Tables(0).Rows(iCount)("CurrencyCode") = Convert.ToString(GetCurrencyCodeForCase(CInt(dsCaseDetails.Tables(0).Rows(iCount)(9))))
                                Else
                                    dsResultCaseDetails.Tables(0).Rows(iCount)("CurrencyCode") = String.Empty
                                End If
                            End With
                        Next
                    End If
                End If
                Dim xmlDoc As New System.Xml.XmlDocument
                dsResultCaseDetails.DataSetName = "BaseFindCaseResponseTypeCaseDetails"
                dsResultCaseDetails.Tables(0).TableName = "Row"

                If oRequest.WCFSecurityToken = "" Then
                    xmlDoc.LoadXml(dsResultCaseDetails.GetXml)
                    If (dsCaseDetails.Tables.Count >= 1) Then
                        oResponse.ResultDataset = xmlDoc.DocumentElement()

                    End If
                End If

                If (dsCaseDetails.Tables.Count >= 1) Then
                    oResponse.ResultData = dsResultCaseDetails
                End If
            End If
        Catch ex As Exception
            Throw

        Finally
            If obCLMCaseBusiness IsNot Nothing Then
                obCLMCaseBusiness.Dispose()
                obCLMCaseBusiness = Nothing
            End If
        End Try

        Return oResponse

    End Function
    Private Function GetCurrencyCodeForCase(ByVal iBaseCaseKey As Integer) As String

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetCurrencyCodeForCase")
                cmd.AddInParameter("@base_case_id", SqlDbType.Int).Value = iBaseCaseKey
                cmd.AddOutParameter("@CurrencyCode", SqlDbType.VarChar, 30)
                con.ExecuteNonQuery(cmd)
                If Not IsDBNull(cmd.Parameters("@currencyCode").Value) Then
                    Return Convert.ToString(cmd.Parameters("@currencyCode").Value)
                Else
                    Return String.Empty
                End If
            End Using

        End Using
    End Function
