    '''<param name="BaseGetCoinsuranceValuesRequest" type="BaseGetCoinsuranceValuesRequestType"></param>   
    '''<returns>BaseGetCoinsuranceValuesResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function GetCoinsuranceValues(ByVal con As SiriusConnection, ByVal GetCoinsuranceValuesRequest As BaseGetCoinsuranceValuesRequestType) As BaseGetCoinsuranceValuesResponseType

        Dim oGetCoinsuranceValuesResponse As New BaseGetCoinsuranceValuesResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        'Dim iSourceId As Integer ' unused
        Dim nTypeOfPackage As enumTypeOfPackage

        If GetCoinsuranceValuesRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetCoinsuranceValuesRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetCoinsuranceValuesResponse = New SAMForInsuranceV2ImplementationTypes.GetCoinsuranceValuesResponseType
        End If

        GetCoinsuranceValuesRequest.Validate(CObj(oErrors))

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results
        Dim dsValues As DataSet = Nothing
        Dim dsArrangement As DataSet = Nothing

        ' NOTE: do we need this condition? we have already checked for mandatory field
        If GetCoinsuranceValuesRequest.InsuranceFileKey <> 0 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Coi_Value_saa")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetCoinsuranceValuesRequest.InsuranceFileKey)
                dsValues = con.ExecuteDataSet(cmd, "Row")

            End Using

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_Coi_Arrangement_sel")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetCoinsuranceValuesRequest.InsuranceFileKey)
                dsArrangement = con.ExecuteDataSet(cmd, "Row")

            End Using
        End If

        If dsArrangement IsNot Nothing AndAlso dsArrangement.Tables.Count > 0 Then
            If (dsArrangement.Tables(0).Rows.Count > 0) Then
                With dsArrangement.Tables(0).Rows(0)
                    oGetCoinsuranceValuesResponse.IsRecovered = Cast.ToBoolean(.Item("is_recovered"), False)
                    oGetCoinsuranceValuesResponse.IsSurcharged = Cast.ToBoolean(.Item("is_surcharged"), False)
                    oGetCoinsuranceValuesResponse.DefaultId = Cast.ToInt32(.Item("coi_default_id"), 0)
                End With
            End If
        End If

        If dsValues IsNot Nothing AndAlso dsValues.Tables.Count > 0 Then

            dsValues.DataSetName = "BaseGetCoinsuranceValuesResponseTypeCoInsurers"
            With dsValues.Tables(0)
                .TableName = "Row"
                .Columns("party_cnt").ColumnName = "CoInsurerKey"
                .Columns("name").ColumnName = "CoInsurer"
                .Columns("arrangement_ref").ColumnName = "ArrangementRef"
                .Columns("share_percent").ColumnName = "SharePerc"
                .Columns("commission_percent").ColumnName = "CommissionPerc"
            End With

            Dim xmlDoc As New System.Xml.XmlDocument
            If GetCoinsuranceValuesRequest.WCFSecurityToken = "" Then
                xmlDoc.LoadXml(dsValues.GetXml)
                oGetCoinsuranceValuesResponse.ResultDataset = xmlDoc.DocumentElement()
            End If

            oGetCoinsuranceValuesResponse.ResultData = dsValues

        End If

        Return oGetCoinsuranceValuesResponse

    End Function

