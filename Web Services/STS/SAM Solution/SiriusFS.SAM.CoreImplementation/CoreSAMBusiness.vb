        End If

        ' validate the mandatory structure data
        oGetProductRiskEventsRequest.Validate(CType(oSAMErrorCollection, Object))

        ' if there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        'Prakash: look up validation for product code if provided
        If Not String.IsNullOrEmpty(oGetProductRiskEventsRequest.ProductCode) Then
            oGetProductRiskEventsRequest.ProductKey = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Product, oGetProductRiskEventsRequest.ProductCode, "ProductCode", oSAMErrorCollection)
            oSAMErrorCollection.CheckForErrors()
        End If
        '*********************
        ' Get Required Information 
        '*********************
        Dim ds As DataSet = GetEventsDataset(con, oGetProductRiskEventsRequest)

        ds.DataSetName = "BaseGetProductRiskEventsResponseTypeEvents"

        Dim xmlDoc As New System.Xml.XmlDocument
        If oGetProductRiskEventsRequest.WCFSecurityToken = "" Then
            xmlDoc.LoadXml(ds.GetXml)
            oResponse.Events = xmlDoc.DocumentElement
        End If

        oResponse.ResultData = ds
        Return oResponse
    End Function

    Private Function GetEventsDataset(ByVal con As SiriusConnection,
                                  ByVal oRequest As BaseGetProductRiskEventsRequestType
                                  ) As DataSet

        Dim ds As DataSet = Nothing

        'If Direct buiness needs to be retrieved, then AgentKey should not be provided
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Product_Events")
            If oRequest.ProductKey <> 0 Then
                cmd.AddInParameter("@product_id", SqlDbType.Int).Value = oRequest.ProductKey
            End If
            If oRequest.InsuranceFileKey <> 0 Then
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oRequest.InsuranceFileKey
            End If
            If oRequest.EventType = ProductEventActionType.ClaimEvent Then
                cmd.AddInParameter("@type", SqlDbType.VarChar, 10).Value = "CLAIM"
            Else
                cmd.AddInParameter("@type", SqlDbType.VarChar, 10).Value = "MTA"
            End If
            ds = con.ExecuteDataSet(cmd, "Row")
        End Using

        Return ds
    End Function

