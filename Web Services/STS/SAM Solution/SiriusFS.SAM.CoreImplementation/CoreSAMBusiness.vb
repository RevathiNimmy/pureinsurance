        ValidateCoverNoteSheetData(CObj(oSAMErrorCollection), UpdateCoverNoteSheetRequest)
        oSAMErrorCollection.CheckForErrors()

        'Business Rule Validation        
        dsCoverNoteBookDetails = GetCoverNoteBookDetails(con, UpdateCoverNoteSheetRequest.CoverNoteBookKey)
