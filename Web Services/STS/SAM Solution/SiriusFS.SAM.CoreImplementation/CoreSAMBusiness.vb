    '''<summary>
    ''' This method is used to update the risk status of a policy
    '''</summary>
    '''<param name="conUpdateRiskStatus" type="SiriusConnection"></param>
    '''<param name="oUpdateRiskStatusRequest" type="BaseUpdateRiskStatusRequestType"></param>    
    '''<returns>BaseUpdateRiskStatusResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function UpdateRiskStatus(ByVal conUpdateRiskStatus As SiriusConnection, ByVal oUpdateRiskStatusRequest As BaseUpdateRiskStatusRequestType) As BaseUpdateRiskStatusResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim iReturn As Integer = 0
        Dim oErrors As New SAMErrorCollection
        Dim oResponse As New BaseUpdateRiskStatusResponseType
        Dim r_lInsuranceFolderKey As Integer
        Dim nTypeofPackage As enumTypeOfPackage

        With oUpdateRiskStatusRequest
            If .GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateRiskStatusRequestType) Then
                nTypeofPackage = enumTypeOfPackage.SAMForInsuranceV2Package
                oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateRiskStatusResponseType
            Else
                nTypeofPackage = enumTypeOfPackage.UnknownPackage
                Return oResponse
            End If

            ' Check Mandatory Field
            .Validate(CObj(oErrors))
            oErrors.CheckForErrors()

            ' Look up validation
            Dim iSourceId As Integer
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, .BranchCode, "BranchCode", oErrors)
            oErrors.CheckForErrors()

            'Check insurance file key for validity
            If Not .InsuranceFileKey = Nothing Then
                If Not oCoreBusiness.CheckInsuranceFile(conUpdateRiskStatus, .InsuranceFileKey, r_lInsuranceFolderKey) Then
                    oErrors.AddInvalidData(SAMConstants.SAMInvalidData.InvalidLookupListValue,
                                    SAMConstants.SAMInvalidData.InvalidLookupListValue.ToString,
                                         "InsuranceFileKey")
                    oErrors.CheckForErrors()
                End If
            End If

            'Check risk key for validity
            If Not .RiskKey = Nothing Then
                If Not oCoreBusiness.CheckRisk(conUpdateRiskStatus, .RiskKey) Then
                    oErrors.AddInvalidData(SAMConstants.SAMInvalidData.InvalidLookupListValue,
                                    SAMConstants.SAMInvalidData.InvalidLookupListValue.ToString,
                                         "RiskKey")
                    oErrors.CheckForErrors()
                End If
            End If

            Try

                If .RiskKey = Nothing And .InsuranceFileKey = Nothing Then
                    oErrors.AddBusinessRule(SAMBusinessErrors.CanNotUpdateLivePolicyDetails,
                                                                "Both Risk and Insurance file key are null")
                    oErrors.CheckForErrors()
                End If

                'EM 20120807 Copy Risk Change
                'If the status is unqouted then call risks have to be copied
                If (.RiskStatusCode = RiskStatusCode.Unquoted) AndAlso (.RiskKey <> Nothing AndAlso .InsuranceFileKey <> Nothing AndAlso (.RiskKey > 0 And .InsuranceFileKey > 0)) Then

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_update_risk_status_unquoted")
                        cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = .InsuranceFileKey
                        conUpdateRiskStatus.ExecuteNonQuery(cmd)
                    End Using
                Else
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Risk_Status")
                        cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = .RiskKey
                        cmd.AddInParameter("@risk_status_code", SqlDbType.VarChar, 20).Value = .RiskStatusCode
                        cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = .InsuranceFileKey
                        conUpdateRiskStatus.ExecuteNonQuery(cmd)
                    End Using
                End If

                If .RiskInceptionDateSpecified And .RiskKey > 0 Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Update_RiskDescription")
                        cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = .RiskKey
                        cmd.AddInParameter("@riskdescription", SqlDbType.VarChar, 20).Value = String.Empty
                        cmd.AddInParameter("@risk_inception_date", SqlDbType.DateTime).Value = .RiskInceptionDate
                        conUpdateRiskStatus.ExecuteNonQuery(cmd)
                    End Using
                End If
            Catch ex As Exception
                Throw
            End Try
        End With
        Return oResponse
    End Function

