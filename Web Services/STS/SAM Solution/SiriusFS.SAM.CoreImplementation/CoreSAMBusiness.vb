    Private Overloads Function GenerateInvite(ByVal con As SiriusConnection, ByVal request As BaseGenerateInviteRequestType) As BaseGenerateInviteResponseType

        Dim samError As SAMErrorCollection = New SAMErrorCollection
        Dim coreBusiness As New CoreBusiness(_SiriusUser)

        ' validate the mandatory structure data
        request.Validate(CType(samError, Object))

        ' if there were any errors throw an exception
        samError.CheckForErrors()

        'Check Item is in renewal
        ValidatePolicyIsInRenewal(con, request.InsuranceFileKey)

        'Get renewal status details
        Dim renewalsStatusDataTable As DataTable = GetRenewalStatus(con, request.InsuranceFileKey)
        If renewalsStatusDataTable IsNot Nothing AndAlso renewalsStatusDataTable.Rows.Count > 0 Then
            If Cast.ToInt32(renewalsStatusDataTable.Rows(0)("is_invite_printed"), 0) <> 0 Then
                samError.AddBusinessRule(
                                SAMBusinessErrors.RenwalInviteAlreadyPrinted,
                                SAMBusinessErrors.RenwalInviteAlreadyPrinted.ToString(),
                                "Renewal Invite already printed for insurance File " + request.InsuranceFileKey.ToString())
                samError.CheckForErrors()
            End If
            If Cast.ToString(renewalsStatusDataTable.Rows(0)("renewal_status_type_code"), String.Empty) <> RenewalStatusTypeCodes.AwaitingRenewalNoticePrint Then
                samError.AddBusinessRule(
                                SAMBusinessErrors.RenewalStatusTypeIsInvalidForThisAction,
                                SAMBusinessErrors.RenewalStatusTypeIsInvalidForThisAction.ToString(),
                                "Renewal status not in Awaiting Renewal Notice Print. Current Renewal Status is " + Cast.ToString(renewalsStatusDataTable.Rows(0)("renewal_status_type_code"), String.Empty))
                samError.CheckForErrors()
            End If
        Else
            samError.AddBusinessRule(
                SAMBusinessErrors.NoRenewalStatusRecordExistsForTheSpecifiedPolicy,
                SAMBusinessErrors.NoRenewalStatusRecordExistsForTheSpecifiedPolicy.ToString(),
                "No Renewal Status record exists for insurance file " + request.InsuranceFileKey.ToString())
            samError.CheckForErrors()
        End If

        Dim response As New BaseImplementationTypes.BaseGenerateInviteResponseType
        Dim typeOfPackage As enumTypeOfPackage
        Dim generateInviteData As DataTable = Nothing

        If request.GetType Is GetType(SAMForInsuranceImplementationTypes.GenerateInviteRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            response = New SAMForInsuranceImplementationTypes.GenerateInviteResponseType
        ElseIf request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GenerateInviteRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            response = New SAMForInsuranceV2ImplementationTypes.GenerateInviteResponseType
        End If

        Dim renewalStatusKey As Integer
        Dim partyKey As Integer
        Dim insuranceFolderKey As Integer
        'Get Invite Details By calling stored procedure spu_SAM_Generate_Invite
        generateInviteData = GenerateInvite(con, request.InsuranceFileKey)

        'If No rows are returned satisfying criteria for Generate Add Sam Business Rule
        If generateInviteData Is Nothing Or generateInviteData.Rows.Count = 0 Then
            samError.AddBusinessRule(SAMBusinessErrors.InsuranceFileDetailsIsNotValidToGenerateInvite,
                                                SAMBusinessErrors.InsuranceFileDetailsIsNotValidToGenerateInvite.ToString)
            samError.CheckForErrors()
        Else
            renewalStatusKey = Cast.ToInt32(generateInviteData.Rows(0)("renewal_status_cnt"), 0)
            partyKey = Cast.ToInt32(generateInviteData.Rows(0)("party_cnt"), 0)
            insuranceFolderKey = Cast.ToInt32(generateInviteData.Rows(0)("insurance_folder_cnt"), 0)
            ''Check Not True Monthly Policy unless anniversary date has reached for poicy to be valid to generate invite
            'If (BooleanDataConvert.ToBoolean(Cast.ToInt32(generateInviteData.Rows(0)("Is_True_Monthly_Policy"), 0)) = True _
            ' And BooleanDataConvert.ToBoolean(Cast.ToInt32(generateInviteData.Rows(0)("Anniversary_Copy"), 0)) = False) Then
            '    samError.AddBusinessRule( _
            '                        SAMBusinessErrors.PolicyNotValidTrueMonthlyPolicyUntilAnniversaryDateReachedtoGenerateInvite, _
            '                        SAMBusinessErrors.PolicyNotValidTrueMonthlyPolicyUntilAnniversaryDateReachedtoGenerateInvite.ToString(), _
            '                        "Not a valid true monthly policy unless policy has reached anniversary date to generate invite" + request.InsuranceFileKey.ToString())
            '    samError.CheckForErrors()
            'End If
        End If

        ' Check that the timestamp matches and lock the Quote
        coreBusiness.CheckSAMTSAndLock(Con:=con,
                           BranchCode:=request.BranchCode,
                           Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                           LockValue:=insuranceFolderKey,
                           TStamp:=request.QuoteTimeStamp)

        Dim docTypeID As Integer
        Dim docTemplateID As Integer
        Dim comReturnValue As Integer
        comReturnValue = GenerateCustomerRenewalEmail(con, partyKey, request.InsuranceFileKey, RenewalEmailType.Invite, request.BranchCode)
        'Generate the customer renewal mail calling the COm object class:bsirrenwal Method:GenerateCustomerRenewalEmail
        If (comReturnValue = PMEReturnCode.PMNotFound) Then
            'Check existance of a document calling the COM object class:bsirreninviteprint Method:ValidateRenewalInvite
            'If (PrintValidateRenwalInvite(con, request.InsuranceFileKey, docTypeID, request.BranchCode) = PMEReturnCode.PMTrue) Then
            'Call the GenerateDocument method to generate the document
            Dim documentTemplateCodeId As Integer = CInt(GetTemplateCodesForRenewal(request.InsuranceFileKey, SIRConst.SIRDocTypeRenewalNotice, "RNI"))
            If documentTemplateCodeId <> 0 Then
                GeneratePrintInviteDocument(con, request, documentTemplateCodeId, partyKey, insuranceFolderKey,
                                                response.Errors, response.MergedFilePath, response.SpooledZipFile, response.STSError)
            End If
            Try
                'check if any Errors were returned from GenerateDocument method
                SAMErrorCollection.CheckForErrorsFromSTS(response.STSError)
                'Update the renewal status set is_invite_printed = true and renewal_status_type = "Awaiting Update" calling COM object
                'Class:bsirreninviteprint Method:UpdateRenewalStatus
                If (PrintUpdateRenewalStatus(con, request.InsuranceFileKey, 0, "", request.BranchCode) = PMReturnCode.PMTrue) Then
                    'Add to Last_Print_Run table
                    AddLastPrintRun(con, renewalStatusKey, request.UserId)
                End If
            Catch ex As Exception
                'Update Renewal_Status Table renewal_status_type  to "Awaiting Renewal Notice Print" and invite printed to false
                PrintUpdateRenewalStatus(con, request.InsuranceFileKey, 4, "", request.BranchCode)
                Throw
            End Try
            'End If
        ElseIf comReturnValue = PMReturnCode.PMTrue Then
            'Update the renewal status set is_invite_printed = true and renewal_status_type = "Awaiting Update" calling COM object
            'Class:bsirreninviteprint Method:UpdateRenewalStatus
            If (PrintUpdateRenewalStatus(con, request.InsuranceFileKey, 0, "", request.BranchCode) = PMReturnCode.PMTrue) Then
                'Add to Last_Print_Run table
                AddLastPrintRun(con, renewalStatusKey, request.UserId)
            End If
        End If

        ' Unlock and return the new timestamp
        coreBusiness.UnlockAndGetSAMTS(Con:=con,
                     BranchCode:=request.BranchCode,
                     Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                     LockValue:=insuranceFolderKey,
                     TStamp:=response.QuoteTimeStamp)

        Return response

    End Function

    Private Sub GeneratePrintInviteDocument(ByVal con As SiriusConnection, ByVal oRequest As BaseGenerateInviteRequestType,
                                            ByVal docTypeID As Integer, ByVal partyKey As Integer, ByVal insuranceFolderKey As Integer,
                                            ByRef samError As SAMError(), ByRef mergedFilePath As String, ByRef spooledZipFile As Byte(),
                                            ByRef stsError As STSErrorType)

        Dim coreBusiness As New CoreBusiness

        Dim generateDocumentRequest As New BaseGenerateDocumentRequestType
        Dim generateDocumentResponse As New BaseGenerateDocumentResponseType
        Dim generateInviteResponse As New BaseGenerateInviteResponseType

        generateDocumentRequest.BranchCode = oRequest.BranchCode
        generateDocumentRequest.DocumentTemplateCode = GetTemplateCode(con, docTypeID)
        generateDocumentRequest.InsuranceFileKey = oRequest.InsuranceFileKey
        generateDocumentRequest.InsuranceFolderKey = insuranceFolderKey
        generateDocumentRequest.Mode = 4
        generateDocumentRequest.OutputAsHTML = oRequest.OutputAsHTML
        generateDocumentRequest.OutputAsPDF = oRequest.OutputAsPDF
        generateDocumentRequest.PartyKey = partyKey
        generateDocumentRequest.SourceId = oRequest.SourceId
        generateDocumentRequest.SpoolDocumentOnly = oRequest.SpoolDocumentOnly

        'Call the generatedocumentmethod here
        generateDocumentResponse = GenerateDocument(generateDocumentRequest)

        'Set response back to generate invite
        samError = generateDocumentResponse.Errors
        mergedFilePath = generateDocumentResponse.MergedFilePath
        spooledZipFile = generateDocumentResponse.SpooledZipFile
        stsError = generateDocumentResponse.STSError

    End Sub

    Private Function PrintUpdateRenewalStatus(ByVal con As SiriusConnection, ByVal insuranceFileKey As Integer,
                                              ByVal renewalExceptionReasonID As Integer, ByVal renewalExceptionNote As String,
                                              ByVal branchCode As String) As Integer
        Dim comReturnValue As Integer
        Dim renewalInvitePrint As bsirreninviteprint.Business = Nothing

        Try
            renewalInvitePrint = CreateAndInitialiseRenewalInvitePrint(con, branchCode)
            comReturnValue = CType(renewalInvitePrint.UpdateRenewalStatus(
                                  v_lInsuranceFileCnt:=insuranceFileKey,
                                  v_lRenewalExceptionReasonID:=renewalExceptionReasonID,
                                  v_sRenewalExceptionNote:=renewalExceptionNote), Integer)

            If comReturnValue <> PMEReturnCode.PMTrue Then
                RaiseComMethodException("bSIRRenInvitePrint.UpdateRenewalStatus Failed")
            End If

            Return comReturnValue

        Finally
            If renewalInvitePrint IsNot Nothing Then
                renewalInvitePrint.Dispose()
                renewalInvitePrint = Nothing
            End If
        End Try

    End Function

    Private Function PrintValidateRenwalInvite(ByVal con As SiriusConnection, ByVal insuranceFileKey As Integer,
                                               ByRef docTypeID As Integer, ByVal branchCode As String) As Integer
        Dim comReturnValue As Integer
        Dim renewalInvitePrint As bsirreninviteprint.Business = Nothing
        Dim docTemplateID As Integer

        Try
            renewalInvitePrint = CreateAndInitialiseRenewalInvitePrint(con, branchCode)
            comReturnValue = CType(renewalInvitePrint.ValidateRenewalInvite(
                                  v_lInsuranceFileCnt:=insuranceFileKey,
                                  r_lDocumentTemplateId:=docTemplateID,
                                  r_lDocumentTypeId:=docTypeID), Integer)

            If comReturnValue <> PMEReturnCode.PMTrue Then
                'Update Renewal_Status Table renewal_status_type  to "Awaiting Renewal Notice Print" and invite printed to false
                PrintUpdateRenewalStatus(con, insuranceFileKey, 4, "", branchCode)
                RaiseComMethodException("bSirRenInvitePrint.PrintValidateRenwalInvite Failed")
            End If

            If docTemplateID = 0 Or docTypeID = 0 Then
                comReturnValue = PMReturnCode.PMFalse
            End If

            Return comReturnValue

        Finally
            If renewalInvitePrint IsNot Nothing Then
                renewalInvitePrint.Dispose()
                renewalInvitePrint = Nothing
            End If
        End Try

    End Function

