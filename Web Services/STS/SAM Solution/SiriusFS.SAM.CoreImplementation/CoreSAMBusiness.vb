    '''<summary>
    ''' This method is used to filter the columns got from database
    '''</summary>
    '''<param name="dsPolciesForRenewalSelection" type="DataSet"></param>   
    '''<returns>DataSet</returns>
    '''<remarks></remarks> 
    Private Function FilterPoliciesForRenewalSelection(ByVal dsPolciesForRenewalSelection As DataSet) As DataSet
        Dim dsPoliciesForRenewalSelectionFiltered As New DataSet
        dsPoliciesForRenewalSelectionFiltered.Tables.Add("Row")
        With dsPoliciesForRenewalSelectionFiltered.Tables(0)
            .Columns.Add("InsuranceFileKey", GetType(System.Int32))
            .Columns.Add("InsuranceFolderKey", GetType(System.Int32))
            .Columns.Add("PartyKey", GetType(System.Int32))
            .Columns.Add("ProductKey", GetType(System.Int32))
            .Columns.Add("LeadAgentKey", GetType(System.Int32))
            .Columns.Add("InsuranceFileRef", GetType(System.String))
            .Columns.Add("CoverStartDate", GetType(Date))
            .Columns.Add("CoverEndDate", GetType(Date))
            .Columns.Add("ClientCode", GetType(System.String))
            .Columns.Add("Client", GetType(System.String))
            .Columns.Add("LeadAgent", GetType(System.String))
            .Columns.Add("IsAutoRenewable", GetType(System.Boolean))
            .Columns.Add("ProductDescription", GetType(System.String))
            .Columns.Add("RrenewalDate", GetType(Date))
            .Columns.Add("IsClosed", GetType(System.Boolean))
            .Columns.Add("IsInTransferMode", GetType(System.Boolean))
            .Columns.Add("IsTrueMonthlyPolicy", GetType(System.Boolean))
            .Columns.Add("AnniversaryCopy", GetType(System.Boolean))
            .Columns.Add("RrenewalCount", GetType(System.Int32))

            Dim drTemp As DataRow
            If (dsPolciesForRenewalSelection IsNot Nothing AndAlso dsPolciesForRenewalSelection.Tables.Count > 0) Then
                For Each dr As DataRow In dsPolciesForRenewalSelection.Tables(0).Rows
                    drTemp = .NewRow()
                    drTemp("InsuranceFileKey") = Cast.ToInt32(dr("insurance_file_cnt"), 0)
                    drTemp("PartyKey") = Cast.ToInt32(dr("insurance_holder_cnt"), 0)
                    drTemp("ProductKey") = Cast.ToInt32(dr("product_id"), 0)
                    drTemp("LeadAgentKey") = Cast.ToInt32(dr("lead_agent_cnt"), 0)
                    drTemp("InsuranceFileRef") = Cast.ToString(dr("Insurance_ref"), String.Empty)
                    drTemp("CoverStartDate") = Cast.ToDateTime(dr("cover_start_date"), Date.MinValue)
                    drTemp("CoverEndDate") = Cast.ToDateTime(dr("expiry_date"), Date.MinValue)
                    drTemp("Client") = Cast.ToString(dr("client_name"), String.Empty)
                    drTemp("LeadAgent") = Cast.ToString(dr("agent_name"), String.Empty)
                    drTemp("IsAutoRenewable") = Cast.ToInt32(dr("is_auto_renewable"), 0) = 1
                    drTemp("ProductDescription") = Cast.ToString(dr("Product_description"), String.Empty)
                    drTemp("InsuranceFolderKey") = Cast.ToInt32(dr("insurance_folder_cnt"), 0)
                    drTemp("RrenewalDate") = Cast.ToDateTime(dr("renewal_date"), Date.MinValue)
                    drTemp("ClientCode") = Cast.ToString(dr("client_code"), String.Empty)
                    drTemp("IsClosed") = Cast.ToInt32(dr("is_deleted"), 0) = 1
                    drTemp("IsInTransferMode") = Cast.ToInt32(dr("is_in_transfer_mode"), 0) = 1
                    drTemp("IsTrueMonthlyPolicy") = Cast.ToInt32(dr("is_true_monthly_policy"), 0) = 1
                    drTemp("AnniversaryCopy") = Cast.ToInt32(dr("anniversary_copy"), 0) = 1
                    drTemp("RrenewalCount") = Cast.ToInt32(dr("renewal_count"), 0)
                    .Rows.Add(drTemp)
                    drTemp = Nothing
                Next
            End If
        End With

        Return dsPoliciesForRenewalSelectionFiltered
    End Function

