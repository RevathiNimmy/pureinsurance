    ''' <summary>
    ''' Process the mandatory risk on this insurance file, if it is defined. 
    ''' The mandatory risk should be unquoted if any other risk changes and should always be a copy 
    ''' </summary>
    ''' <param name="con">Database Connection</param>
    ''' <param name="branchCode">Processing Branch</param>
    ''' <param name="insuranceFileKey">Insurance File being processed</param>
    ''' <param name="riskCnt">The risk that has changed, if it is the mandatory risk then this code will do nothing</param>
    ''' <param name="TransactionType">The type of transaction being processed</param>
    ''' <remarks> EM - 20120806 - Created</remarks>
    Private Sub ProcessMandatoryRisk(ByVal con As SiriusConnection,
                                     ByVal branchCode As String,
                                     ByVal insuranceFileKey As Integer,
                                     ByVal riskCnt As Integer,
                                     ByVal TransactionType As TransactionType)

        Dim sRiskDescription As String = String.Empty
        Dim nVariationNumber As Integer = 0
        Dim nRiskCnt As Integer = 0
        Dim sRiskLinkStatusFlag As String = String.Empty
        Dim dsResult As DataSet
        Dim nCommandReturn As Integer = 0

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Mandatory_Risk")
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = riskCnt
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = insuranceFileKey
            dsResult = con.ExecuteDataSet(cmd, "GetMandatoryRisk")
        End Using

        If dsResult IsNot Nothing Then
            If dsResult.Tables.Count > 0 Then
                If dsResult.Tables(0).Rows.Count > 0 Then
                    nRiskCnt = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("risk_cnt"), 0)
                    sRiskDescription = Cast.ToString(dsResult.Tables(0).Rows(0).Item("description"), "")
                    nVariationNumber = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("variation_number"), 0)
                    sRiskLinkStatusFlag = Cast.ToString(dsResult.Tables(0).Rows(0).Item("status_flag"), RiskLinkStatusType.Changed)
                    If sRiskLinkStatusFlag = RiskLinkStatusType.Unchanged Then
                        Dim lOriginalMandatoryRiskCnt As Integer = nRiskCnt
                        ProcessCopyMTARisk(con, branchCode, insuranceFileKey, lOriginalMandatoryRiskCnt, nRiskCnt, TransactionType)
                        If sRiskLinkStatusFlag = RiskLinkStatusType.Renewed Then
                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_DeleteTaxDetailsForBatchRenewals")
                                cmd.AddInParameter("@InsuranceFileCnt", SqlDbType.Int).Value = insuranceFileKey
                                cmd.AddInParameter("@RiskCnt", SqlDbType.Int).Value = lOriginalMandatoryRiskCnt
                                con.ExecuteNonQuery(cmd)
                            End Using
                        End If
                    End If
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Update_Mandatory_Risk_Details")
                        cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = nRiskCnt
                        cmd.AddInParameter("@risk_status_id", SqlDbType.Int).Value = 4 ' For Status to Unquote Risk
                        cmd.AddInParameter("@description", SqlDbType.Text).Value = sRiskDescription
                        cmd.AddInParameter("@variation_number", SqlDbType.Int).Value = nVariationNumber
                        nCommandReturn = con.ExecuteNonQuery(cmd)
                    End Using
                End If
            End If
        End If
    End Sub
