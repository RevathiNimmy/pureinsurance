        End If
        ' Check mandatory fields
        If String.IsNullOrEmpty(GetHeaderAndRisksByKeyRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode")
        End If
        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsRisks As DataSet = Nothing
        Dim dsHeader As DataSet = Nothing
        Dim dsAmountDetails As DataSet = Nothing
        Dim dTotalRiskSumInsured As Double = 0.0 ' Sum of all the SumInsured of all the risk


        If GetHeaderAndRisksByKeyRequest.InsuranceFileKey <> 0 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_GetPolicyRisks")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndRisksByKeyRequest.InsuranceFileKey)
                cmd.AddInParameter("@isviaSAM", SqlDbType.Int).Value = 1
                dsRisks = con.ExecuteDataSet(cmd, "Row")
            End Using
            If dsRisks.Tables(0).Rows.Count > 0 Then
                dsRisks.Tables(0).Columns("risk_cnt").ColumnName = "RiskKey"
                dsRisks.Tables(0).Columns("risk_folder_cnt").ColumnName = "RiskFolderKey"
                dsRisks.Tables(0).Columns("risk_type_code").ColumnName = "RiskTypeCode"
                dsRisks.Tables(0).Columns("description").ColumnName = "Description"
                dsRisks.Tables(0).Columns("riskdescription").ColumnName = "RiskTypeDescription"
                dsRisks.Tables(0).Columns("total_sum_insured").ColumnName = "TotalSumInsured"
                dsRisks.Tables(0).Columns("total_this_premium").ColumnName = "Premium"
                dsRisks.Tables(0).Columns("risk_status_code").ColumnName = "StatusCode"
                dsRisks.Tables(0).Columns("is_risk_selected").ColumnName = "IsRisk"
                dsRisks.Tables(0).Columns("risk_number").ColumnName = "RiskNumber"
                dsRisks.Tables(0).Columns("is_discounted").ColumnName = "Discounted"
                dsRisks.Tables(0).Columns("variation_number").ColumnName = "Variation"
                dsRisks.Tables(0).Columns("statusdescription").ColumnName = "StatusDescription"
                dsRisks.Tables(0).Columns("coverage").ColumnName = "Coverage"
                dsRisks.Tables(0).Columns("insured_item").ColumnName = "InsuredItem"
                dsRisks.Tables(0).Columns("extensions").ColumnName = "Extensions"
                dsRisks.Tables(0).Columns("fee_tax").ColumnName = "FeeTax"
                dsRisks.Tables(0).Columns("fee_premium").ColumnName = "FeePremium"
                dsRisks.Tables(0).Columns("cover_start_date").ColumnName = "StartDate"
                dsRisks.Tables(0).Columns("expiry_date").ColumnName = "EndDate"
                dsRisks.Tables(0).Columns("risk_tax").ColumnName = "RiskTax"

                dsRisks.Tables(0).Columns("Cover_Note_Ref").ColumnName = "CoverNoteNumber"
                dsRisks.Tables(0).Columns("Cover_Note_From").ColumnName = "CoverNoteFrom"
                dsRisks.Tables(0).Columns("Cover_Note_To").ColumnName = "CoverNoteTo"
                dsRisks.Tables(0).Columns("totalstampinsurer").ColumnName = "StampDutyInsurer"
                dsRisks.Tables(0).Columns("totalstampinsured").ColumnName = "StampDutyInsured"
                dsRisks.Tables(0).Columns("Original_Risk_cnt").ColumnName = "OriginalRiskKey"
                'Wpr53
                dsRisks.Tables(0).Columns("Is_Mandatory_Risk").ColumnName = "IsMandatoryRisk"
                dsRisks.Tables(0).Columns("risk_link_status_flag").ColumnName = "RiskLinkStatusFlag"
                dsRisks.Tables(0).Columns("risk_link_change_date").ColumnName = "RiskLinkChangeDate"
                dsRisks.Tables(0).Columns("Is_Auto_Rated").ColumnName = "Is_Auto_Rated"
            End If
            If dsRisks.Tables.Count > 0 AndAlso dsRisks.Tables(0).Rows.Count > 0 Then
                oGetHeaderAndRisksByKeyResponse.Risks = New BaseGetHeaderAndRisksByKeyResponseTypeRisks
                For iCount As Integer = 0 To dsRisks.Tables(0).Rows.Count - 1
                    ReDim Preserve oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount)
                    Dim riskStatus As String = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("RiskLinkStatusFlag"), "C")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount) = New BaseGetHeaderAndRisksByKeyResponseTypeRisksRow
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).RiskKey = Cast.ToInt32(dsRisks.Tables(0).Rows(iCount)("RiskKey"), 0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).RiskFolderKey = Cast.ToInt32(dsRisks.Tables(0).Rows(iCount)("RiskFolderKey"), 0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).RiskTypeCode = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("RiskTypeCode"), "")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).Description = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("Description"), "")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).TotalSumInsured = Cast.ToDouble(dsRisks.Tables(0).Rows(iCount)("TotalSumInsured"), 0.0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).Premium = Cast.ToDouble(dsRisks.Tables(0).Rows(iCount)("Premium"), 0.0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).StatusCode = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("StatusCode"), "UNQUOTED")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).IsRisk = Cast.ToBoolean(dsRisks.Tables(0).Rows(iCount)("IsRisk"), False)

                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).RiskNumber = Cast.ToInt32(dsRisks.Tables(0).Rows(iCount)("RiskNumber"), 0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).Discounted = Cast.ToBoolean(dsRisks.Tables(0).Rows(iCount)("Discounted"), False)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).Variation = Cast.ToInt32(dsRisks.Tables(0).Rows(iCount)("Variation"), 0)

                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).StatusDescription = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("StatusDescription"), "")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).Coverage = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("Coverage"), "")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).InsuredItem = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("InsuredItem"), "")

                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).Extensions = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("Extensions"), "")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).FeeTax = Cast.ToDouble(dsRisks.Tables(0).Rows(iCount)("FeeTax"), 0.0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).FeePremium = Cast.ToDouble(dsRisks.Tables(0).Rows(iCount)("FeePremium"), 0.0)

                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).StartDate = Cast.ToDateTime(dsRisks.Tables(0).Rows(iCount)("StartDate"), Date.MinValue)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).EndDate = Cast.ToDateTime(dsRisks.Tables(0).Rows(iCount)("EndDate"), Date.MinValue)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).RiskTax = Cast.ToDouble(dsRisks.Tables(0).Rows(iCount)("RiskTax"), 0.0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).RiskTypeDescription = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("RiskTypeDescription"), "")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).StampDutyInsurer = Cast.ToDouble(dsRisks.Tables(0).Rows(iCount)("StampDutyInsurer"), 0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).StampDutyInsured = Cast.ToDouble(dsRisks.Tables(0).Rows(iCount)("StampDutyInsured"), 0)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).OriginalRiskKey = Cast.ToInt32(dsRisks.Tables(0).Rows(iCount)("OriginalRiskKey"), 0)
                    ' Sasria                    
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).IsMandatoryRisk = Cast.ToBoolean(dsRisks.Tables(0).Rows(iCount)("IsMandatoryRisk"), False)
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).riskLinkStatusFlag = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("RiskLinkStatusFlag"), "")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).riskLinkChangeDate = Cast.ToDateTime(dsRisks.Tables(0).Rows(iCount)("RiskLinkChangeDate"), New DateTime())
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).Is_Auto_Rated = Cast.ToBoolean(dsRisks.Tables(0).Rows(iCount)("Is_Auto_Rated"), False)
                    If riskStatus = "U" OrElse riskStatus = "R" Then
                        oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).RiskTax = 0
                        oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).FeeTax = 0
                        oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).FeePremium = 0
                        oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).Premium = 0
                    End If
                    Dim oCoverNote As New BaseCoverNoteRiskItemType

                    oCoverNote.RiskKey = Cast.ToInt32(dsRisks.Tables(0).Rows(iCount)("RiskKey"), 0)
                    oCoverNote.CoverNoteNumber = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("CoverNoteNumber"), "")
                    If Cast.ToDateTime(dsRisks.Tables(0).Rows(iCount)("CoverNoteFrom"), Date.MinValue) = Date.MinValue Then
                        oCoverNote.CoverNoteFromSpecified = False
                        oCoverNote.CoverNoteFrom = Nothing
                    Else
                        oCoverNote.CoverNoteFromSpecified = True
                        oCoverNote.CoverNoteFrom = Cast.ToDateTime(dsRisks.Tables(0).Rows(iCount)("CoverNoteFrom"), Date.MinValue)
                    End If
                    If Cast.ToDateTime(dsRisks.Tables(0).Rows(iCount)("CoverNoteFrom"), Date.MinValue) = Date.MinValue Then
                        oCoverNote.CoverNoteToSpecified = False
                        oCoverNote.CoverNoteTo = Nothing
                    Else
                        oCoverNote.CoverNoteToSpecified = True
                        oCoverNote.CoverNoteTo = Cast.ToDateTime(dsRisks.Tables(0).Rows(iCount)("CoverNoteTo"), Date.MinValue)

                    End If

                    oCoverNote.RiskDesc = Cast.ToString(dsRisks.Tables(0).Rows(iCount)("RiskTypeDescription"), "")
                    oGetHeaderAndRisksByKeyResponse.Risks.Row(iCount).CoverNote = oCoverNote
                    dTotalRiskSumInsured = dTotalRiskSumInsured + Cast.ToDouble(dsRisks.Tables(0).Rows(iCount)("TotalSumInsured"), 0.0)
                Next
            End If
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Insurance_File_Details")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndRisksByKeyRequest.InsuranceFileKey)
                dsHeader = con.ExecuteDataSet(cmd, "Row")
            End Using

            If dsHeader.Tables(0).Rows.Count > 0 Then
                With oGetHeaderAndRisksByKeyResponse
                    .InsuranceFileKey = GetHeaderAndRisksByKeyRequest.InsuranceFileKey
                    .ClientCode = dsHeader.Tables(0).Rows(0)("shortname").ToString()
                    .InsuranceFileRef = dsHeader.Tables(0).Rows(0)("insurance_ref").ToString()
                    .Agent = dsHeader.Tables(0).Rows(0)(9).ToString()
                    If (IsDate(dsHeader.Tables(0).Rows(0)("inception_date"))) Then
                        .InceptionDate = CDate(dsHeader.Tables(0).Rows(0)("inception_date"))
                    End If
                    If (IsDate(dsHeader.Tables(0).Rows(0)("cover_start_date"))) Then
                        .CoverStartDate = CDate(dsHeader.Tables(0).Rows(0)(2))
                    End If
                    If (IsDate(dsHeader.Tables(0).Rows(0)("expiry_date"))) Then
                        .ExpiryDate = CDate(dsHeader.Tables(0).Rows(0)("expiry_date"))
                    End If
                    .Currency = dsHeader.Tables(0).Rows(0)("description").ToString()
                    Dim iCorrespondenceTypeID As Integer = Cast.ToInt32(dsHeader.Tables(0).Rows(0)("Correspondence_Type"), 0)
                    If iCorrespondenceTypeID <> 0 Then
                        .CorrespondenceType = oCoreBusiness.GetListItemFromID(Core.STSListType.PMLookup, PMLookupTable.CorrespondenceType, iCorrespondenceTypeID)
                    End If

                    Dim iDefaultPreferredCorrespondenceID As Integer = Cast.ToInt32(dsHeader.Tables(0).Rows(0)("Default_Preferred_Correspondence"), 0)
                    If iDefaultPreferredCorrespondenceID <> 0 Then
                        .DefaultPreferredCorrespondence = oCoreBusiness.GetListItemFromID(Core.STSListType.PMLookup, PMLookupTable.ContactType, iDefaultPreferredCorrespondenceID)
                    End If

                    .IsAgentReceiveCorrespondence = Cast.ToBoolean(dsHeader.Tables(0).Rows(0)("Is_Agent_Correspondence"), False)

                    Dim sMailContacts As String = String.Empty
                    Dim dsContacts As New DataSet()

                    If .IsAgentReceiveCorrespondence Then
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Party_Contacts")
                            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = ToSafeInteger(dsHeader.Tables(0).Rows(0)("lead_agent_cnt"))
                            dsContacts = con.ExecuteDataSet(cmd, "Row")
                        End Using
                        For Each row As DataRow In dsContacts.Tables(0).Rows
                            If ToSafeString(.DefaultPreferredCorrespondence).Trim() = ToSafeString(row("Contact_Type_Code")).Trim() AndAlso ToSafeString(row("Contact_Type_Code")).Trim().ToUpper() = "MEMAIL" Then
                                If sMailContacts = String.Empty Then
                                    sMailContacts = ToSafeString(row("number")).Trim()
                                Else
                                    sMailContacts &= "," & ToSafeString(row("number")).Trim()
                                End If
                            End If
                        Next
                    Else
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Party_Contacts")
                            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = ToSafeInteger(dsHeader.Tables(0).Rows(0)("party_cnt"))
                            dsContacts = con.ExecuteDataSet(cmd, "Row")
                        End Using
                        For Each row As DataRow In dsContacts.Tables(0).Rows
                            If ToSafeString(.DefaultPreferredCorrespondence).Trim() = ToSafeString(row("Contact_Type_Code")).Trim() AndAlso ToSafeString(row("Contact_Type_Code")).Trim().ToUpper() = "MEMAIL" Then
                                If sMailContacts = String.Empty Then
                                    sMailContacts = ToSafeString(row("number")).Trim()
                                Else
                                    sMailContacts &= "," & ToSafeString(row("number")).Trim()
                                End If
                            End If
                        Next
                    End If

                    .MailContacts = sMailContacts
                End With

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Policy_Amount_Details")
                    cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndRisksByKeyRequest.InsuranceFileKey)
                    dsAmountDetails = con.ExecuteDataSet(cmd, "Row")
                End Using

                If (dsAmountDetails.Tables(0).Rows.Count > 0) Then
                    oGetHeaderAndRisksByKeyResponse.NetTotal = Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("this_premium"), 0)

                    oGetHeaderAndRisksByKeyResponse.TaxTotal = Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("insurance_file_tax"), 0) + Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("risk_tax"), 0) +
                                                            Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("fee_tax"), 0) + Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("risk_fee_tax"), 0)

                    oGetHeaderAndRisksByKeyResponse.FeeTotal = Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("policy_fee_amount"), 0) + Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("risk_fee_amount"), 0)
                    oGetHeaderAndRisksByKeyResponse.GrossTotal = Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("total_premium_amount"), 0)
                    oGetHeaderAndRisksByKeyResponse.TotalSumInsured = dTotalRiskSumInsured
                    'oGetHeaderAndRisksByKeyResponse.TaxRateUnRounded = Cast.ToDouble(dsAmountDetails.Tables(0).Rows(0)("tax_rate_UR"), 0)
                End If

            End If
        End If
        Return oGetHeaderAndRisksByKeyResponse
    End Function

