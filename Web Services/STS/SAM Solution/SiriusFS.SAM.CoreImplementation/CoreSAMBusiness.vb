    Public Overloads Sub RunRenewalSelection(ByVal Con As SiriusConnection, ByVal RunRenewalSelectionRequest As BaseRunRenewalSelectionRequestType)
        Dim oCoreBusiness As New CoreBusiness
        Dim iReturn As Integer = 0
        Dim oErrors As SAMErrorCollection = New SAMErrorCollection

        Dim nTypeofPackage As enumTypeOfPackage

        If RunRenewalSelectionRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.RunRenewalSelectionRequestType) Then
            nTypeofPackage = enumTypeOfPackage.SAMForInsurancePackage
        ElseIf RunRenewalSelectionRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.RunRenewalSelectionRequestType) Then
            nTypeofPackage = enumTypeOfPackage.SAMForInsuranceV2Package
        End If

        'Check Mandatory Field
        If String.IsNullOrEmpty(RunRenewalSelectionRequest.InsuranceFileKey.ToString) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                   SAMInvalidData.MandatoryInputMissing.ToString,
                                   "InsuranceFileKey")
            Exit Sub
        End If

        ' if there were any errors throw an exception
        oErrors.CheckForErrors()

        Dim obSIRRenewalSelection As bSIRRenSelection.Business = Nothing
        Try
            SyncLock m_Sellock
                obSIRRenewalSelection = CType(CreateAndInitialiseRenewalSelection(Con,
                                              RunRenewalSelectionRequest.BranchCode), bSIRRenSelection.Business)

                'Pass the task_id because need to Copy the Risk as logic defined in SP "spu_Risk_Tax_Select" which gets called from bSIRRITax
                obSIRRenewalSelection.SetProcessModes(2)

                iReturn = obSIRRenewalSelection.ProcessRenewalSelection(v_lInsuranceFileCnt:=RunRenewalSelectionRequest.InsuranceFileKey,
                            v_lBatchRenewalJobID:=RunRenewalSelectionRequest.BatchRenewalJobKey,
                            v_lRecordsCount:=RunRenewalSelectionRequest.RecordsCount,
                            v_sGUID:=RunRenewalSelectionRequest.GUID,
                v_bDoNotCreateTMPAnniversaryVersion:=RunRenewalSelectionRequest.bDoNotCreateTMPAnniversaryVersion)

                If iReturn <> PMEReturnCode.PMTrue Then
                    RaiseComMethodException("bSIRRenSelection.Business.ProcessRenewalSelection Failed", iReturn)
                End If
            End SyncLock
        Finally
            If obSIRRenewalSelection IsNot Nothing Then
                obSIRRenewalSelection.Dispose()
                obSIRRenewalSelection = Nothing
            End If
        End Try

    End Sub

