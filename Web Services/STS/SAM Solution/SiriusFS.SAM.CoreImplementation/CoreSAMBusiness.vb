            If dsTransactions.Tables(0).Rows.Count > 0 Then
                dsTransactions.Locale = System.Globalization.CultureInfo.CurrentCulture
                For iCnt = 0 To dsTransactions.Tables(0).Rows.Count - 1

                    If iCurrentDocumentDetailId <> Convert.ToInt32(dsTransactions.Tables(0).Rows(iCnt).Item("document_id")) Then

                        iCurrentDocumentDetailId = Convert.ToInt32(dsTransactions.Tables(0).Rows(iCnt).Item("document_id"))
