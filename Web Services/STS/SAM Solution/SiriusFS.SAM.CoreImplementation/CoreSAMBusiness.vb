    ''' <summary>
    '''This method sends the request to the function 
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="oGetCurrencyExchangeRatesRequest" type="BaseGetCurrencyExchangeRatesRequestType"></param>
    '''<remarks></remarks>
    Public Overloads Function GetCurrencyExchangeRates(ByVal con As SiriusConnection, ByVal oGetCurrencyExchangeRatesRequest As BaseGetCurrencyExchangeRatesRequestType) As BaseGetCurrencyExchangeRatesResponseType

        Dim oGetCurrencyExchangeRatesResponse As New BaseGetCurrencyExchangeRatesResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim iSourceId As Integer
        Dim iAccountID As Integer
        Dim iTransactionTypeID As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetCurrencyExchangeRatesRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetCurrencyExchangeRatesRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetCurrencyExchangeRatesResponse = New SAMForInsuranceV2ImplementationTypes.GetCurrencyExchangeRatesResponseType
        End If

        'Mandatory validations
        oGetCurrencyExchangeRatesRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        'Data validations

        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oGetCurrencyExchangeRatesRequest.BranchCode, "Source", oErrors)

        If Not String.IsNullOrEmpty(oGetCurrencyExchangeRatesRequest.AccountCode) Then
            iAccountID = GetAndValidateSpecifiedTableCode(con, "account",
                         "account_id", "Short_Code", oGetCurrencyExchangeRatesRequest.AccountCode.ToString(), oErrors, "short_code")
        End If

        iTransactionTypeID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                       PMLookupTable.Currency, oGetCurrencyExchangeRatesRequest.TransactionCurrencyCode, "currency_id", oErrors)

        Dim iBaseCurrencyID As Integer
        Dim dBaseAmount As Decimal
        Dim iAccountCurrencyID As Integer
        Dim dAccountAmount As Decimal
        Dim iSystemCurrencyID As Integer
        Dim dSystemAmount As Decimal
        Dim dCurrencyBaseXrate As Decimal
        Dim dtCurrencyBaseDate As Date
        Dim dAccountBaseXrate As Decimal
        Dim dtAccountBaseDate As Date
        Dim dSystemBaseXrate As Decimal
        Dim dtSystemBaseDate As Date
        Dim dAccountAmountUnrounded As Decimal
        Dim dBaseAmountUnrounded As Decimal
        Dim dSystemAmountUnrounded As Decimal
        Dim dRate As Decimal

        GetCurrencyExchangeRatesForAll(con, Date.Today.Date, iAccountID, iSourceId, iTransactionTypeID, oGetCurrencyExchangeRatesRequest.CurrencyAmountUnRounded,
            iBaseCurrencyID,
            dBaseAmount,
            iAccountCurrencyID,
            dAccountAmount,
            iSystemCurrencyID,
            dSystemAmount,
            dCurrencyBaseXrate,
            dtCurrencyBaseDate,
            dAccountBaseXrate,
            dtAccountBaseDate,
            dSystemBaseXrate,
            dtSystemBaseDate,
            dAccountAmountUnrounded,
            dBaseAmountUnrounded,
            dSystemAmountUnrounded)
        With oGetCurrencyExchangeRatesResponse
            .AccountAmount = dAccountAmount
            .AccountAmountUnrounded = dAccountAmountUnrounded
            .BaseAmount = dBaseAmount
            .BaseAmountUnrounded = dBaseAmountUnrounded
            .SystemAmount = dSystemAmount
            .SystemAmountUnrounded = dSystemAmountUnrounded
            .CurrencyRates = New BaseCoreCurrencyExchangeRatesType
            If dAccountBaseXrate = 0 Then
                .CurrencyRates.AccountCurrencyRateSpecified = False
            Else
                .CurrencyRates.AccountCurrencyRateSpecified = True
                .CurrencyRates.AccountCurrencyRate = dAccountBaseXrate
            End If
            If dCurrencyBaseXrate = 0 Then
                .CurrencyRates.BaseCurrencyRateSpecified = False
            Else
                .CurrencyRates.BaseCurrencyRateSpecified = True
                .CurrencyRates.BaseCurrencyRate = dCurrencyBaseXrate
            End If
            If dAccountBaseXrate = 0 Then
                .CurrencyRates.SystemCurrrencyRateSpecified = False
            Else
                oGetCurrencyExchangeRatesResponse.CurrencyRates.SystemCurrrencyRateSpecified = True
                oGetCurrencyExchangeRatesResponse.CurrencyRates.SystemCurrrencyRate = dSystemBaseXrate
            End If
            If dSystemBaseXrate = 0 Then
                oGetCurrencyExchangeRatesResponse.CurrencyRates.SystemCurrrencyRateSpecified = False
            Else
                oGetCurrencyExchangeRatesResponse.CurrencyRates.SystemCurrrencyRateSpecified = True
                oGetCurrencyExchangeRatesResponse.CurrencyRates.SystemCurrrencyRate = dSystemBaseXrate
            End If

            oGetCurrencyExchangeRatesResponse.CurrencyRates.ExchangeRateOverrideReasonKeySpecified = False

            Dim sTransactionDesc As String

            Dim dsTransactionDesc As New DataSet
            If GetDetailsFromId(con, "Currency", "currency_id", iTransactionTypeID.ToString(), dsTransactionDesc) Then
                If dsTransactionDesc.Tables(0).Rows.Count > 0 AndAlso (dsTransactionDesc.Tables(0).Rows.Count >= 1) Then
                    sTransactionDesc = Cast.ToString(dsTransactionDesc.Tables(0).Rows(0).Item("description"), "")
                Else
                    sTransactionDesc = ""
                End If
            Else
                sTransactionDesc = ""

            End If

            Dim sAccountCurrencyDesc As String
            Dim dsAccountCurrencyDesc As New DataSet
            If GetDetailsFromId(con, "Currency", "currency_id", iAccountCurrencyID.ToString(), dsAccountCurrencyDesc) Then
                If dsAccountCurrencyDesc.Tables(0).Rows.Count > 0 AndAlso (dsAccountCurrencyDesc.Tables(0).Rows.Count >= 1) Then
                    sAccountCurrencyDesc = Cast.ToString(dsAccountCurrencyDesc.Tables(0).Rows(0).Item("description"), "")
                Else
                    sAccountCurrencyDesc = ""
                End If
            Else
                sAccountCurrencyDesc = ""

            End If
            Dim sBaseCurrencyDesc As String
            Dim dsBaseCurrencyDesc As New DataSet
            If GetDetailsFromId(con, "Currency", "currency_id", iBaseCurrencyID.ToString(), dsBaseCurrencyDesc) Then
                If dsBaseCurrencyDesc.Tables(0).Rows.Count > 0 AndAlso (dsBaseCurrencyDesc.Tables(0).Rows.Count >= 1) Then
                    sBaseCurrencyDesc = Cast.ToString(dsBaseCurrencyDesc.Tables(0).Rows(0).Item("description"), "")
                Else
                    sBaseCurrencyDesc = ""
                End If
            Else
                sBaseCurrencyDesc = ""

            End If

            .CurrencyRates.SystemCurrencyDate = dtSystemBaseDate
            .CurrencyRates.AccountCurrencyDate = dtAccountBaseDate
            .CurrencyRates.BaseCurrencyDate = dtCurrencyBaseDate
            .CurrencyRates.TransactionCurrencyKey = iTransactionTypeID
            .CurrencyRates.TransactionCurrencyDesc = sTransactionDesc
            .CurrencyRates.AccountCurrencyKey = iAccountCurrencyID
            .CurrencyRates.AccountCurrencyDesc = sAccountCurrencyDesc
            .CurrencyRates.BaseCurrencyKey = iBaseCurrencyID
            .CurrencyRates.BaseCurrencyDesc = sBaseCurrencyDesc
            .CurrencyRates.SystemCurrencyKey = iSystemCurrencyID
            GetCurrencyRate(con, Date.Today.Date, iSourceId, iSystemCurrencyID, iTransactionTypeID, dRate, oGetCurrencyExchangeRatesRequest.ClaimKey, oGetCurrencyExchangeRatesRequest.IsManualJournal)
            .CurrencyRates.TransactionCurrrencyRate = dRate
            .CurrencyRates.TransactionCurrrencyRateSpecified = True
        End With
        Return oGetCurrencyExchangeRatesResponse
    End Function

    ''' <summary>
    '''This method sends the request to the function 
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="EffectiveTransactionDate" type="Date"></param>
    '''<param name="AccountID" type="Integer"></param>
    '''<param name="CompanyId" type="Integer"></param>
    '''<param name="CurrencyID" type="Integer"></param>
    '''<param name="CurrencyAmountUnrounded" type="Decimal"></param>
    '''<param name="BaseCurrencyID" type="Integer"></param>
    '''<param name="BaseAmount" type="Decimal"></param>
    '''<param name="AccountCurrencyID" type="Integer"></param>
    '''<param name="AccountAmount" type="Decimal"></param>
    '''<param name="SystemCurrencyID" type="Integer"></param>
    '''<param name="SystemAmount" type="Date"></param>
    '''<param name="CurrencyBaseXrate" type="Decimal"></param>
    '''<param name="CurrencyBaseDate" type="Date"></param>
    '''<param name="AccountBaseXrate" type="Decimal"></param>
    '''<param name="AccountBaseDate" type="Date"></param>
    '''<param name="SystemBaseXrate" type="Decimal"></param>
    '''<param name="SystemBaseDate" type="Date"></param>
    '''<param name="AccountAmountUnrounded" type="Decimal"></param>
    '''<param name="BaseAmountUnrounded" type="Decimal"></param>
    '''<param name="SystemAmountUnrounded" type="Decimal"></param>
    '''<param name="sMode" type="String"></param>
    '''<remarks></remarks>
    Private Sub GetCurrencyExchangeRatesForAll(
     ByVal con As SiriusConnection,
     ByVal EffectiveTransactionDate As Date,
     ByVal AccountID As Integer,
     ByVal CompanyId As Integer,
     ByVal CurrencyID As Integer,
     ByVal CurrencyAmountUnrounded As Decimal,
     ByRef BaseCurrencyID As Integer,
     ByRef BaseAmount As Decimal,
     ByRef AccountCurrencyID As Integer,
     ByRef AccountAmount As Decimal,
     ByRef SystemCurrencyID As Integer,
     ByRef SystemAmount As Decimal,
     ByRef CurrencyBaseXrate As Decimal,
     ByRef CurrencyBaseDate As Date,
     ByRef AccountBaseXrate As Decimal,
     ByRef AccountBaseDate As Date,
     ByRef SystemBaseXrate As Decimal,
     ByRef SystemBaseDate As Date,
     Optional ByRef AccountAmountUnrounded As Decimal = 0,
     Optional ByRef BaseAmountUnrounded As Decimal = 0,
     Optional ByRef SystemAmountUnrounded As Decimal = 0,
     Optional ByVal sMode As String = "ALL")

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Do_Currency_Conversion")

            cmd.AddInParameter("@account_id", SqlDbType.Int).Value = AccountID
            cmd.AddInParameter("@company_id", SqlDbType.Int).Value = CompanyId
            cmd.AddInParameter("@currency_id", SqlDbType.Int).Value = CurrencyID
            cmd.AddInParameter("@currency_amount_unrounded", SqlDbType.Money).Value = CurrencyAmountUnrounded
            cmd.AddInParameter("@mode", SqlDbType.VarChar, 10).Value = sMode

            cmd.AddOutParameter("@base_currency_id", SqlDbType.Int)
            cmd.AddOutParameter("@base_currency_code", SqlDbType.VarChar, 20)
            cmd.AddOutParameter("@base_amount", SqlDbType.Money)
            cmd.AddOutParameter("@base_amount_unrounded", SqlDbType.Money)
            cmd.AddOutParameter("@account_currency_id", SqlDbType.Int)
            cmd.AddOutParameter("@account_amount", SqlDbType.Money)
            cmd.AddOutParameter("@account_amount_unrounded", SqlDbType.Money)
            cmd.AddOutParameter("@system_currency_id", SqlDbType.Int)
            cmd.AddOutParameter("@system_amount", SqlDbType.Money)
            cmd.AddOutParameter("@system_amount_unrounded", SqlDbType.Money)
            cmd.AddOutParameter("@currency_base_xrate", SqlDbType.Float)
            cmd.AddOutParameter("@currency_base_date", SqlDbType.DateTime)
            cmd.AddOutParameter("@account_base_xrate", SqlDbType.Float)
            cmd.AddOutParameter("@account_base_date", SqlDbType.DateTime)
            cmd.AddOutParameter("@system_base_xrate", SqlDbType.Float)
            cmd.AddOutParameter("@system_base_date", SqlDbType.DateTime)
            cmd.AddOutParameter("@return_status", SqlDbType.Int)
            con.ExecuteNonQuery(cmd)

            BaseCurrencyID = Cast.ToInt32(cmd.Parameters("@base_currency_id").Value, 0)
            BaseAmount = Cast.ToDecimal(cmd.Parameters("@base_amount").Value, 0)
            AccountCurrencyID = Cast.ToInt32(cmd.Parameters("@account_currency_id").Value, 0)
            AccountAmount = Cast.ToDecimal(cmd.Parameters("@account_amount").Value, 0)
            SystemCurrencyID = Cast.ToInt32(cmd.Parameters("@system_currency_id").Value, 0)
            SystemAmount = Cast.ToDecimal(cmd.Parameters("@system_amount").Value, 0)
            CurrencyBaseXrate = CDec(Cast.ToDouble(cmd.Parameters("@currency_base_xrate").Value, 0))
            CurrencyBaseDate = Cast.ToDateTime(cmd.Parameters("@currency_base_date").Value, Date.MinValue)
            AccountBaseXrate = CDec(Cast.ToDouble(cmd.Parameters("@account_base_xrate").Value, 0))
            AccountBaseDate = Cast.ToDateTime(cmd.Parameters("@account_base_date").Value, Date.MinValue)
            SystemBaseXrate = CDec(Cast.ToDouble(cmd.Parameters("@system_base_xrate").Value, 0))
            SystemBaseDate = Cast.ToDateTime(cmd.Parameters("@system_base_date").Value, Date.MinValue)

            'BaseCurrencyCode = cmd.Parameters("@base_currency_code").Value.ToString()
            BaseAmountUnrounded = CDec(Cast.ToDouble(cmd.Parameters("@base_amount_unrounded").Value, 0))
            AccountAmountUnrounded = CDec(Cast.ToDouble(cmd.Parameters("@account_amount_unrounded").Value, 0))
            SystemAmountUnrounded = CDec(Cast.ToDouble(cmd.Parameters("@system_amount_unrounded").Value, 0))

            Dim ReturnStatus As Integer

            ReturnStatus = Cast.ToInt32(cmd.Parameters("@return_status").Value, 0)

            If ReturnStatus <> 1 Then

                Dim oSAMErrorCollection As New SAMErrorCollection
                Dim iErrorCode As Integer
                Dim sErrorCode As String = String.Empty
                Dim sDescription As String = String.Empty

                Select Case ReturnStatus
                    Case -1
                        ' raise an error  - no system currency set up 
                        iErrorCode = SAMBusinessErrors.NoSystemCurrenyHasBeenDefined
                        sErrorCode = SAMBusinessErrors.NoSystemCurrenyHasBeenDefined.ToString

                    Case -2
                        ' raise an error - no account currency set up
                        iErrorCode = SAMBusinessErrors.NoAccountCurrencyHasBeenDefined
                        sErrorCode = SAMBusinessErrors.NoAccountCurrencyHasBeenDefined.ToString
                        sDescription = "No currency value has been set for account - account id = " & AccountID.ToString
                    Case -3
                        ' raise an error - no account currency conversion rates set up
                        iErrorCode = SAMBusinessErrors.NoAccountCurrencyConversionRatesHaveBeenDefined
                        sErrorCode = SAMBusinessErrors.NoAccountCurrencyConversionRatesHaveBeenDefined.ToString
                        sDescription = "No currency conversion rates have been defined for the currency on account  - account id =" & AccountID.ToString
                    Case -4
                        ' raise an error - no system currency converison rates set up
                        iErrorCode = SAMBusinessErrors.NoSystemCurrencyConversionRatesHaveBeenDefined
                        sErrorCode = SAMBusinessErrors.NoSystemCurrencyConversionRatesHaveBeenDefined.ToString
                    Case Else
                        iErrorCode = SAMBusinessErrors.DoCurrencyConversionReturnedInvalidStatus
                        sErrorCode = SAMBusinessErrors.DoCurrencyConversionReturnedInvalidStatus.ToString
                End Select

                oSAMErrorCollection.AddBusinessRule(iErrorCode, sErrorCode, sDescription)
                oSAMErrorCollection.CheckForErrors()

            End If

        End Using

    End Sub

    Private Sub GetCurrencyRate(
     ByVal con As SiriusConnection,
     ByVal EffectiveTransactionDate As Date,
     ByVal CompanyId As Integer,
     ByVal LossCurrencyID As Integer,
     ByVal PaymentCurrencyID As Integer,
     ByRef Rate As Decimal,
 Optional ByVal iClaimKey As Integer = 0,
  Optional ByVal bIsManualJournal As Boolean = False)

        If iClaimKey <> 0 Then
            Dim ds As DataSet
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Claim_Currency")

                cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = iClaimKey
                ds = con.ExecuteDataSet(cmd, "Table")

                If ds IsNot Nothing AndAlso ds.Tables IsNot Nothing AndAlso ds.Tables.Count > 0 AndAlso ds.Tables(0).Rows IsNot Nothing AndAlso ds.Tables(0).Rows.Count > 0 Then
                    LossCurrencyID = Convert.ToInt32(ds.Tables(0).Rows(0).Item(0))
                End If

            End Using
        End If


        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Currency_Rate")
            If bIsManualJournal Then
                cmd.AddInParameter("@losscurrency_id", SqlDbType.Int).Value = 0
            Else
                cmd.AddInParameter("@losscurrency_id", SqlDbType.Int).Value = LossCurrencyID
            End If
            cmd.AddInParameter("@paymentcurrency_id", SqlDbType.Int).Value = PaymentCurrencyID
            cmd.AddInParameter("@company_id", SqlDbType.Int).Value = CompanyId
            cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = EffectiveTransactionDate

            cmd.AddOutParameter("@rate", SqlDbType.Float)
            con.ExecuteNonQuery(cmd)

            Rate = CDec(Cast.ToDouble(cmd.Parameters("@rate").Value, 0))

        End Using

    End Sub
