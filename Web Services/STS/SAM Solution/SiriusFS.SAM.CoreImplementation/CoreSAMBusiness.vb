                                       sRequestFieldName)
            Return result
        End Using

    End Function
    Public Overloads Function GetAndValidateSpecifiedTableCode(
                                            ByVal con As SiriusConnection,
                                            ByVal sTableName As String,
                                            ByVal sTableKeyNameToReturn As String,
                                            ByVal sFieldNameToValidate As String,
                                            ByVal sValueToValidate As String,
                                            ByVal oSAMErrorCollection As SAMErrorCollection,
                                            ByVal sRequestFieldName As String) As Integer

        Dim dt As DataTable = Nothing
        Dim lReturn As Integer
        Dim sCacheKey As String = String.Empty
        Dim sCacheReturnValue As String = String.Empty


        If sTableName.ToLower() = "party_type" Then 'Implement caching for specific table name
            _oCache = HttpRuntime.Cache()
            sCacheKey = sTableName.ToLower() + "_" + sTableKeyNameToReturn.ToLower() + "_" + sFieldNameToValidate.ToLower() + "_" + sValueToValidate.ToLower()
            sCacheReturnValue = CType(_oCache(sCacheKey), String)
        End If


        If sCacheReturnValue = String.Empty OrElse sCacheReturnValue Is Nothing Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_And_Validate_Field")

                cmd.AddInParameter("@table_name", SqlDbType.VarChar, 255).Value = sTableName
                cmd.AddInParameter("@field_to_return_name", SqlDbType.VarChar, 255).Value = sTableKeyNameToReturn
                cmd.AddInParameter("@field_to_validate_name", SqlDbType.VarChar, 255).Value = sFieldNameToValidate
                cmd.AddInParameter("@field_to_validate_value", SqlDbType.VarChar, 255).Value = sValueToValidate

                dt = con.ExecuteDataTable(cmd)

            End Using
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
                ' there should be only 1
                For Each dr As DataRow In dt.Rows
                    lReturn = Cast.ToInt32(dr.Item(0), 0)
                Next
            Else
                lReturn = 0
            End If
            If sTableName.ToLower() = "party_type" Then 'Implement caching for specific table name
                _oCache.Insert(sCacheKey, lReturn.ToString())
            End If
        Else
            lReturn = ToSafeInteger(sCacheReturnValue)
        End If

        ' if a key value was not returned
        If lReturn = 0 Then
            ' add an error to the SAMErrorCollection
            oSAMErrorCollection.AddInvalidData(
                              SAMInvalidData.InvalidLookupListValue,
                              SAMInvalidData.InvalidLookupListValue.ToString,
                              sRequestFieldName,
                              sValueToValidate)
        End If

        Return lReturn

    End Function

