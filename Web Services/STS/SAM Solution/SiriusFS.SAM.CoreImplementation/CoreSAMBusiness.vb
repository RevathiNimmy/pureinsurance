                    If (dsfinancePlans.Tables(0).Rows.Count >= 1) Then
                        oGetFinancePlansResponse.FinancePlans = New BaseGetFinancePlansResponseTypeFinancePlans
                        For iCount As Integer = 0 To dsfinancePlans.Tables(0).Rows.Count - 1

                            ReDim Preserve oGetFinancePlansResponse.FinancePlans.Row(iCount)
                            oGetFinancePlansResponse.FinancePlans.Row(iCount) = New BaseGetFinancePlansResponseTypeFinancePlansRow
                            With oGetFinancePlansResponse.FinancePlans.Row(iCount)
                                .FinancePlanKey = Cast.ToInt32(dsfinancePlans.Tables(0).Rows(iCount).Item("pfPrem_finance_cnt"), 0)
                                .FinancePlanVersion = Cast.ToInt32(dsfinancePlans.Tables(0).Rows(iCount).Item("pfPrem_finance_version"), 0)
