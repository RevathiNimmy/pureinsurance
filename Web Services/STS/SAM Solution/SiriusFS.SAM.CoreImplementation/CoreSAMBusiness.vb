    ''' <summary>
    '''This function will pass the request object to the stored proceudre and returns the reponse object
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>  
    '''<param name="oDettachCoverNoteRequest" type="BaseAttachCoverNoteRequestType"></param>  
    '''<returns> object of type BaseAttachCoverNoteResponseType </returns>
    '''<remarks></remarks>
    Public Function DettachCoverNote(ByVal con As SiriusConnection, ByVal oDettachCoverNoteRequest As BaseAttachCoverNoteRequestType) As BaseAttachCoverNoteResponseType

        Dim oDettachCoverNoteResponse As New BaseAttachCoverNoteResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oDettachCoverNoteRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.AttachCoverNoteRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oDettachCoverNoteResponse = New SAMForInsuranceImplementationTypes.AttachCoverNoteResponseType
        ElseIf oDettachCoverNoteRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AttachCoverNoteRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oDettachCoverNoteResponse = New SAMForInsuranceV2ImplementationTypes.AttachCoverNoteResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oDettachCoverNoteRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        ' Place a lock using TimeStamp

        ' Check mandatory fields
        If oDettachCoverNoteRequest.CoverNote.RiskKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "RiskId")
        End If
        If oDettachCoverNoteRequest.CoverNote.TImeStamp Is Nothing Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "TImeStamp")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()
        GetAndValidateSpecifiedTableCode(con, "Risk",
                               "risk_cnt", "risk_cnt", oDettachCoverNoteRequest.CoverNote.RiskKey.ToString(), oErrors, "risk_cnt")
        oErrors.CheckForErrors()

        Dim oAnyError As STSErrorType
        'As said by Gaurav(lock based on InsuranceFolderKey)
        oAnyError = oCoreBusiness.CheckTSAndLock(
            BranchCode:=oDettachCoverNoteRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.RiskKey,
            LockValue:=oDettachCoverNoteRequest.CoverNote.RiskKey,
            TStamp:=oDettachCoverNoteRequest.CoverNote.TImeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oDettachCoverNoteResponse.STSError = oAnyError
            Return oDettachCoverNoteResponse
        End If
        Try

            con.BeginTransaction()
            'Make a call to following SP to insert the values 
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Detach_Cover_Notes")
                cmd.AddInParameter("@Risk_Id", SqlDbType.Int).Value = oDettachCoverNoteRequest.CoverNote.RiskKey
                con.ExecuteNonQuery(cmd)
            End Using
            con.CommitTransaction()
        Catch ex As Exception
            con.RollbackTransaction()
        End Try

        oAnyError = oCoreBusiness.UnlockAndGetTS(
     BranchCode:=oDettachCoverNoteRequest.BranchCode,
     Lockname:=CoreBusiness.LockName.RiskKey,
     LockValue:=oDettachCoverNoteRequest.CoverNote.RiskKey,
     TStamp:=oDettachCoverNoteRequest.CoverNote.TImeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Unable to unlock, return the error.
            oDettachCoverNoteResponse.STSError = oAnyError
            Return oDettachCoverNoteResponse
        End If

        Return oDettachCoverNoteResponse

    End Function

