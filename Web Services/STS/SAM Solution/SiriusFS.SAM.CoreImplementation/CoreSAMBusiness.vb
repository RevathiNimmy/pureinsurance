    '''<summary>
    ''' This method is used to update the renewal status of a policy
    '''</summary>
    '''<param name="conUpdateRenewalStatus" type="SiriusConnection"></param>
    '''<param name="oUpdateRenewalStatusRequest" type="BaseUpdateRenewalStatusRequestType"></param>    
    '''<returns>BaseUpdateRenewalStatusResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function UpdateRenewalStatus(ByVal conUpdateRenewalStatus As SiriusConnection, ByVal oUpdateRenewalStatusRequest As BaseUpdateRenewalStatusRequestType) As BaseUpdateRenewalStatusResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim iReturn As Integer = 0
        Dim oErrors As New SAMErrorCollection
        Dim oResponse As New BaseUpdateRenewalStatusResponseType
        ' This variable is just a dummy variable while calling unlock timestamp method on RenewalStatusKey
        Dim o_aRetrunTimeStamp() As Byte = Nothing
        ' For getting timstamp on RenewalStatusKey, creating a timestamp variable
        Dim r_aRenewalTimeStamp() As Byte = Nothing
        'Deviation from Tech spec: instead of adding an insurance folder key in the request class in BaseImplementation type file, creating a local variable
        Dim r_lInsuranceFolderKey As Integer
        Dim nTypeofPackage As enumTypeOfPackage

        With oUpdateRenewalStatusRequest
            If .GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateRenewalStatusRequestType) Then
                nTypeofPackage = enumTypeOfPackage.SAMForInsuranceV2Package
                oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateRenewalStatusResponseType
            Else
                nTypeofPackage = enumTypeOfPackage.UnknownPackage
                Return oResponse
            End If

            ' Check Mandatory Field
            .Validate(CObj(oErrors))
            oErrors.CheckForErrors()

            ' Look up validation
            Dim iSourceId As Integer
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, .BranchCode, "BranchCode", oErrors)
            oErrors.CheckForErrors()

            'Check insurance file key for validity
            If Not oCoreBusiness.CheckInsuranceFile(conUpdateRenewalStatus, .InsuranceFileKey, r_lInsuranceFolderKey) Then
                oErrors.AddInvalidData(SAMConstants.SAMInvalidData.InvalidLookupListValue,
                                SAMConstants.SAMInvalidData.InvalidLookupListValue.ToString,
                                     "InsuranceFileKey")
                oErrors.CheckForErrors()
            End If

            ' Get renewal status information
            Dim tbRenewalStatusDetails As DataTable = Nothing

            tbRenewalStatusDetails = GetRenewalStatus(conUpdateRenewalStatus, .InsuranceFileKey)
            If tbRenewalStatusDetails IsNot Nothing AndAlso tbRenewalStatusDetails.Rows.Count > 0 Then
                .OldRenewalStatusTypeCode = Cast.ToString(tbRenewalStatusDetails.Rows(0)("renewal_status_type_code"), String.Empty)
                .RenewalStatusKey = Cast.ToInt32(tbRenewalStatusDetails.Rows(0)("renewal_status_cnt"), 0)
            Else
                'If table contains no result, we have to raise error and exit
                oErrors.AddBusinessRule(
                    SAMBusinessErrors.InvalidTransactionType,
                    SAMBusinessErrors.InvalidTransactionType.ToString,
                    "Attempted a renewals call on a policy that isnt in renewals")

                oErrors.CheckForErrors()
            End If

            If .RenewalStatusCode.Equals(.OldRenewalStatusTypeCode) Then

                ' If new status code and old status code are same, exit without error
                Return oResponse
            ElseIf .OldRenewalStatusTypeCode.Equals(RenewalStatusTypeCodes.AwaitingBrokerTransfer) Then

                ' If agent is in transfer mode, error and exit
                oErrors.AddBusinessRule(SAMBusinessErrors.RenewalStatusTypeIsInvalidForThisAction,
                                        "Can not renew this policy since the agent is in transfer mode.")
                oErrors.CheckForErrors()
            End If

            Try
                conUpdateRenewalStatus.BeginTransaction()

                ' Check that the timestamp matches and put lock on the given insurance folder key
                oCoreBusiness.CheckSAMTSAndLock(Con:=conUpdateRenewalStatus,
                                                BranchCode:= .BranchCode,
                                                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                                                LockValue:=r_lInsuranceFolderKey,
                                                TStamp:= .QuoteTimeStamp)

                ' Get a timestamp on RenewalStatusKey
                Dim o_bLocked As Boolean
                oCoreBusiness.GetSAMTimestamp(
                                                Con:=conUpdateRenewalStatus,
                                                BranchCode:= .BranchCode,
                                                Lockname:=CoreBusiness.LockName.RenewalProcess,
                                                LockValue:= .RenewalStatusKey,
                                                TStamp:=r_aRenewalTimeStamp,
                                                bCurrentlyLocked:=o_bLocked)

                ' Check the method call succeeded
                If o_bLocked Then

                    oErrors.AddBusinessRule(SAMBusinessErrors.RecordLockedByAnotherUser,
                                            "The renewal record for policy is already locked by another user.")
                    oErrors.CheckForErrors()
                End If

                ' Check that the timestamp matches and put lock on the given renewal status key
                oCoreBusiness.CheckSAMTSAndLock(Con:=conUpdateRenewalStatus,
                                                BranchCode:= .BranchCode,
                                                Lockname:=CoreBusiness.LockName.RenewalProcess,
                                                LockValue:= .RenewalStatusKey,
                                                TStamp:=r_aRenewalTimeStamp)

                UpdateRenewalStatus(oCoreBusiness, conUpdateRenewalStatus, .InsuranceFileKey, .RenewalStatusCode)

                If .OldRenewalStatusTypeCode.Equals(RenewalStatusTypeCodes.AwaitingUpdate) Then
                    ' If renewal is waiting for update check the system option 5001=1(Credit control enabled)
                    Dim o_sResult As String = String.Empty
                    oCoreBusiness.GetSystemOption(.BranchCode, 5001, o_sResult)
                    If Cast.ToInt32(o_sResult, 0) = 1 Then
                        ' If this system option is one then delete credit control item by 
                        ' passing Request.InsuranceFileKey to spu_ACT_Del_Credit_Control_Item_InsFile
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Del_Credit_Control_Item_InsFile")
                            cmd.AddInParameter(" @insurance_file_cnt", SqlDbType.Int).Value = .InsuranceFileKey
                            conUpdateRenewalStatus.ExecuteNonQuery(cmd)
                        End Using
                    End If
                End If

                ' Unlock the lock on renewal status key
                oCoreBusiness.UnlockAndGetSAMTS(
                                              Con:=conUpdateRenewalStatus,
                                              BranchCode:= .BranchCode,
                                              Lockname:=CoreBusiness.LockName.RenewalProcess,
                                              LockValue:= .RenewalStatusKey,
                                              TStamp:=o_aRetrunTimeStamp)

                ' Unlock the lock on insurance folder key
                oCoreBusiness.UnlockAndGetSAMTS(
                                                 Con:=conUpdateRenewalStatus,
                                                 BranchCode:= .BranchCode,
                                                 Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                                                 LockValue:=r_lInsuranceFolderKey,
                                                 TStamp:=oResponse.QuoteTimeStamp)

                conUpdateRenewalStatus.CommitTransaction()
            Catch ex As Exception
                conUpdateRenewalStatus.RollbackTransaction()
                Throw
            End Try
        End With
        Return oResponse
    End Function

