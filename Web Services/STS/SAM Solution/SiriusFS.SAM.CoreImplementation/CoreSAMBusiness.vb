    Public Overloads Function GetBalanceForCD(ByVal conCashDeposit As SiriusConnection, ByVal oGetBalanceForCDRequest As BaseGetBalanceForCDRequestType) As BaseGetBalanceForCDResponseType

        Dim oGetBalanceForCDResponse As New BaseGetBalanceForCDResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetBalanceForCDRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetBalanceForCDRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetBalanceForCDResponse = New SAMForInsuranceV2ImplementationTypes.GetBalanceForCDResponseType
        End If
        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetBalanceForCDRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        ' Check mandatory fields
        If oGetBalanceForCDRequest.InsuranceFileKey = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If

        If String.IsNullOrEmpty(oGetBalanceForCDRequest.CashDepositRef) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "CashDepositRef")
        End If

        ' exit if there are any missing parameters
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Lookup and data Validation
        '*******************************************************************************************

        oGetBalanceForCDRequest.CashDepositKey = GetAndValidateSpecifiedTableCode(conCashDeposit,
                "CashDeposit", "CashDeposit_ID", "CashDeposit_Ref", oGetBalanceForCDRequest.CashDepositRef, oSAMErrorCollection, "CashDepositRef")

        If Not String.IsNullOrEmpty(oGetBalanceForCDRequest.BranchCode) Then
            oGetBalanceForCDRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oGetBalanceForCDRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        oSAMErrorCollection.CheckForErrors()

        oGetBalanceForCDRequest.IsPrePayment = oCoreBusiness.GetProductOption(SIRHiddenOptions.SIROPTEnablePayNowOptions, oGetBalanceForCDRequest.SourceId) = "1"

        Using cmdCashDeposit As SiriusCommand = SiriusCommand.FromProcedure("spe_insurance_file_sel")
            Dim dsCashDeposit As DataSet
            cmdCashDeposit.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetBalanceForCDRequest.InsuranceFileKey)
            dsCashDeposit = conCashDeposit.ExecuteDataSet(cmdCashDeposit, "CashDeposit")
            If (dsCashDeposit IsNot Nothing) Then
                If (dsCashDeposit.Tables.Count >= 1) Then
                    If (dsCashDeposit.Tables(0).Rows.Count >= 1) Then
                        oGetBalanceForCDRequest.CoverStartDate = Cast.ToDateTime(dsCashDeposit.Tables(0).Rows(0).Item("cover_start_date"), Nothing)
                    End If
                End If
            End If
        End Using

        Using cmdCashDeposit As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Balance_For_CD")
            cmdCashDeposit.AddInParameter("@CashDeposit_ID", SqlDbType.Int).Value = Cast.NullIfDefault(oGetBalanceForCDRequest.CashDepositKey)
            If oGetBalanceForCDRequest.IsPrePayment Then
                cmdCashDeposit.AddInParameter("@Is_PrePayment", SqlDbType.TinyInt).Value = 1
            Else
                cmdCashDeposit.AddInParameter("@Is_PrePayment", SqlDbType.TinyInt).Value = 0
            End If
            cmdCashDeposit.AddInParameter("@Cover_Start_Date", SqlDbType.DateTime).Value = Cast.NullIfDefault(oGetBalanceForCDRequest.CoverStartDate)
            cmdCashDeposit.AddInParameter("@Policy_Issue_Date", SqlDbType.DateTime).Value = Date.Now
            cmdCashDeposit.AddOutParameter("@Available_Balance", SqlDbType.Money)
            cmdCashDeposit.AddOutParameter("@Running_Balance", SqlDbType.Money)

            conCashDeposit.ExecuteNonQuery(cmdCashDeposit)

            oGetBalanceForCDResponse.AvailableBalance = Cast.ToDecimal(cmdCashDeposit.Parameters.Item("@Available_Balance").Value, 0)
            oGetBalanceForCDResponse.RunningBalance = Cast.ToDecimal(cmdCashDeposit.Parameters.Item("@Running_Balance").Value, 0)

        End Using

        Return oGetBalanceForCDResponse
    End Function

    ''' <summary>  
    ''' Creates Manual Journal  
    ''' </summary>  
    ''' <param name="BaseAddJournalRequestType">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseAddJournalRequestType</param>  
    ''' <returns>An object of type SiriusFS.SAM.BaseImplementationTypes.BaseAddJournalResponseType</returns>  
