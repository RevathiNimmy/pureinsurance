                        End If
                        If .GetValue(70, i) IsNot Nothing AndAlso Not String.IsNullOrEmpty(.GetValue(70, i).ToString) Then
                            oTransRow.IsLead = Convert.ToBoolean(Cast.NullIfDefault(CInt(.GetValue(70, i)), "0"))
