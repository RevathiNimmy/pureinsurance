    Private Sub CalculateFACTax(ByVal con As SiriusConnection,
                                          ByVal iRiskCnt As Integer,
                                          ByVal iInsuranceFileCnt As Integer,
                                          ByVal oRILine As BaseRiskRIArrangementLineType)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Calculate_Treaty_Party_Tax_Amounts")
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.ToInt32(iInsuranceFileCnt)
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = Cast.ToInt32(iRiskCnt)
            cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oRILine.RIArrangementLineKey
            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oRILine.PartyKey
            cmd.AddInParameter("@premium", SqlDbType.Money).Value = oRILine.PremiumValue
            cmd.AddInParameter("@commission", SqlDbType.Money).Value = oRILine.CommissionValue
            cmd.AddInParameter("@premium_transtype", SqlDbType.VarChar, 20).Value = TaxType.FACPREMIUMTAXTYPE
            cmd.AddInParameter("@commission_transtype", SqlDbType.VarChar, 20).Value = TaxType.FACCOMMISSIONTAXTYPE
            cmd.AddOutParameter("@premium_tax", SqlDbType.Money)
            cmd.AddOutParameter("@commission_tax", SqlDbType.Money)

            con.ExecuteNonQuery(cmd)

        End Using

    End Sub

    Private Sub CalculateTreatyTax(ByVal con As SiriusConnection,
                                         ByVal iRiskCnt As Integer,
                                         ByVal iInsuranceFileCnt As Integer,
                                         ByVal oRILine As BaseRiskRIArrangementLineType)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Calculate_Treaty_Tax_Amounts")
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.ToInt32(iInsuranceFileCnt)
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = Cast.ToInt32(iRiskCnt)
            cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oRILine.RIArrangementLineKey
            cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = oRILine.TreatyID
            cmd.AddInParameter("@premium", SqlDbType.Money).Value = oRILine.PremiumValue
            cmd.AddInParameter("@commission", SqlDbType.Money).Value = oRILine.CommissionValue
            cmd.AddInParameter("@premium_transtype", SqlDbType.VarChar, 20).Value = TaxType.TREATYPREMIUMTAXTYPE
