    Public Overloads Function UpdateQuotePaymentMethod(ByVal con As SiriusConnection, ByVal oUpdateQuotePaymentMethodRequest As BaseUpdateQuotePaymentMethodRequestType) As BaseUpdateQuotePaymentMethodResponseType
        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oCoreBusiness As New CoreBusiness
        Dim oResponse As BaseImplementationTypes.BaseUpdateQuotePaymentMethodResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iComReturnValue As Integer
        Dim vResultArray As Object
        Dim iDefault As Short
        Dim oCreditCard As New BaseCreditCardType
        Dim iSourceId As Integer
        Dim oPremiumFinance As New bSIRPremiumFinance.Business
        Dim comReturnValue As Integer
        Dim arrQuoteArrayObject As Object = Nothing
        Dim arrQuoteArray As Object(,) = Nothing
        Dim arrValidPlans As Object

        Const k_PFQuotePFRF_ID As Integer = 32

        ' determine the type of package and thus the type of response
        If oUpdateQuotePaymentMethodRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateQuotePaymentMethodRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.UpdateQuotePaymentMethodResponseType
        Else
            oResponse = New BaseImplementationTypes.BaseUpdateQuotePaymentMethodResponseType
        End If

        '*********************
        ' STRUCTURE VALIDATION 
        '*********************

        ' STILL TO DO VALIDATIONS    
        ' validate the mandatory structure data
        oUpdateQuotePaymentMethodRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()

        If Not String.IsNullOrEmpty(oUpdateQuotePaymentMethodRequest.BranchCode) Then
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oUpdateQuotePaymentMethodRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        oSAMErrorCollection.CheckForErrors()

        ' Business Rule Validations
        ' Check that the Insurance file should be in quoted state
        ' Check to see whether PFRF_id belongs to that scheme or not

        ' Suggestion
        If oCoreBusiness.CheckInsuranceFile(oUpdateQuotePaymentMethodRequest.InsuranceFileKey, oUpdateQuotePaymentMethodRequest.InsuranceFolderKey) = False Then
            oSAMErrorCollection.AddBusinessRule(SAMConstants.
                    SAMInvalidData.InvalidInsuranceFileType,
                    "Invalid Insurance File Key Provided.")

        End If
        oSAMErrorCollection.CheckForErrors()

        Dim oAnyError As STSErrorType
        oAnyError = oCoreBusiness.CheckTSAndLock(
            BranchCode:=oUpdateQuotePaymentMethodRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=oUpdateQuotePaymentMethodRequest.InsuranceFolderKey,
            TStamp:=oUpdateQuotePaymentMethodRequest.QuoteTimeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oResponse.STSError = oAnyError
            Return oResponse
        End If

        UpdateQuotePaymentValidateBusiness(oSAMErrorCollection, con, oUpdateQuotePaymentMethodRequest)
        oSAMErrorCollection.CheckForErrors()

        Try
            con.BeginTransaction()
            If oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote IsNot Nothing Then
                ' Initialize business object
                InitialiseSBOObject(con, oPremiumFinance, _SiriusUser, "bSIRPremiumFinance.BusinessClass")

                ' Setting Process mode of bSIRPremiumFinance to PMEdit
                comReturnValue = oPremiumFinance.SetProcessModes(vProcessMode:=PMEComponentAction.PMEdit)
                If comReturnValue <> PMEReturnCode.PMTrue Then
                    RaiseComMethodException("bSIRPremiumFinance.BusinessClass.SetProcessModes Failed", comReturnValue)
                End If

                Dim dtPremFinance As DataTable
                GetPlanDetailsOnStatus(oSAMErrorCollection, con, oUpdateQuotePaymentMethodRequest, "011", dtPremFinance)

                For iCount As Integer = 0 To dtPremFinance.Rows.Count - 1
                    ' Delete the plans that are already existing on the quote
                    comReturnValue = oPremiumFinance.DeletePlan(
                                    Cast.ToInt32(dtPremFinance.Rows(iCount)("PFPrem_Finance_Cnt"), 0),
                                    Cast.ToInt32(dtPremFinance.Rows(iCount)("PFPrem_Finance_Version"), 0),
                                    Cast.ToString(dtPremFinance.Rows(iCount)("StatusInd"), ""))

                    If (comReturnValue <> PMEReturnCode.PMTrue) Then
                        If oPremiumFinance IsNot Nothing Then
                            oPremiumFinance.Dispose()
                            oPremiumFinance = Nothing
                        End If
                        RaiseComMethodException("bSIRPremiumFinance.BusinessClass.DeletePlan Failed", comReturnValue)
                    End If
                Next

                Try
                    ' Grab a new quote

                    oPremiumFinance.UseTransCurrency = 0

                    If oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.IsUseTransactionCurrency Then
                        oPremiumFinance.UseTransCurrency = 1
                    End If

                    comReturnValue = oPremiumFinance.Calculate_Quotes(
                        v_lSourceID:=iSourceId%,
                        v_sProductCode:=InternalSAMConstants.CNBusinessTypeREN,
                        v_dtQuoteDate:=Date.MinValue,
                        v_dtStartDate:=Date.MinValue,
                        v_dtEndDate:=Date.MinValue,
                        v_dtPreferredDate:=oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.PreferredDate,
                        v_iDayInMonth:=CShort(oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.MonthDay),
                        v_iDayInWeek:=CShort(oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.WeekDay),
                        v_crAmountToFinance:=CDec(oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.AmountToFinance),
                        v_bPaymentProtection:=oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.PaymentProtection,
                        v_dInterestOverrideRate:=oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.OverrideInterestRate,
                        v_bOverrideCommission:=False,
                        v_lPartyCnt:=0,
                        r_vQuoteArray:=arrQuoteArrayObject,
                        v_lInsuranceFileCnt:=oUpdateQuotePaymentMethodRequest.InsuranceFileKey)

                    arrQuoteArray = DirectCast(arrQuoteArrayObject, Object(,))

                Catch ex As Exception
                    If oPremiumFinance IsNot Nothing Then
                        oPremiumFinance.Dispose()
                        oPremiumFinance = Nothing
                    End If
                    RaiseComMethodException("bSIRPremiumFinance.BusinessClass.Calculate_Quotes Failed", comReturnValue)
                Finally
                    If (comReturnValue <> PMEReturnCode.PMTrue) Then
                        If oPremiumFinance IsNot Nothing Then
                            oPremiumFinance.Dispose()
                            oPremiumFinance = Nothing
                        End If
                        RaiseComMethodException("bSIRPremiumFinance.BusinessClass.Calculate_Quotes Failed", comReturnValue)
                    ElseIf IsArray(arrQuoteArray) = False Then
                        If oPremiumFinance IsNot Nothing Then
                            oPremiumFinance.Dispose()
                            oPremiumFinance = Nothing
                        End If
                        RaiseComMethodException("bSIRPremiumFinance.BusinessClass.Calculate_Quotes No Records Retrieved", comReturnValue)
                    End If
                End Try

                Dim lPremiumFinanceCnt As Integer = 0
                Dim lPremiumFinanceVer As Integer = 0
                Dim oPFArrayObject As Object(,) = Nothing
                Dim oPFArray As Object(,)
                Dim iCnt As Integer = 0
                Dim blSchemeFound As Boolean = False
                Dim iUbnd As Integer = arrQuoteArray.GetUpperBound(1)
                Dim iLbnd As Integer = arrQuoteArray.GetLowerBound(1)

                For iCnt = iLbnd To iUbnd

                    If Cast.ToInt32(arrQuoteArray(k_PFQuotePFRF_ID, iCnt), 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.PFRF_ID Then
                        blSchemeFound = True
                        Exit For
                    End If

                Next

                If blSchemeFound = True Then

                    comReturnValue = oPremiumFinance.InsertOrUpdatePremiumFinance(
                        arrQuoteArray,
                        iCnt,
                        Nothing,
                        lPremiumFinanceCnt,
                        lPremiumFinanceVer)

                    If (comReturnValue <> PMEReturnCode.PMTrue) Then
                        If oPremiumFinance IsNot Nothing Then
                            oPremiumFinance.Dispose()
                            oPremiumFinance = Nothing
                        End If
                        RaiseComMethodException("bSIRPremiumFinance.BusinessClass.InsertOrUpdatePremiumFinance Failed", comReturnValue)
                    End If

                    comReturnValue = oPremiumFinance.GetSingleFinancePlan(
                        lPremiumFinanceCnt,
                        lPremiumFinanceVer,
                        oPFArrayObject)

                    oPFArray = DirectCast(oPFArrayObject, Object(,))
                    If (comReturnValue <> PMEReturnCode.PMTrue) Then
                        If oPremiumFinance IsNot Nothing Then
                            oPremiumFinance.Dispose()
                            oPremiumFinance = Nothing
                        End If
                        RaiseComMethodException("bSIRPremiumFinance.BusinessClass.GetSingleFinancePlan Failed", comReturnValue)
                    ElseIf IsArray(oPFArray) = False Then
                        If oPremiumFinance IsNot Nothing Then
                            oPremiumFinance.Dispose()
                            oPremiumFinance = Nothing
                        End If
                        RaiseComMethodException("bSIRPremiumFinance.BusinessClass.GetSingleFinancePlan No Records Retrieved", comReturnValue)
                    End If

                    'Update to bank details etc.
                    oPFArray(k_PFPlanBankName, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankName
                    oPFArray(k_PFPlanBankSortCode, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankSortCode
                    oPFArray(k_PFPlanBankAccountNo, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAccountNo
                    oPFArray(k_PFPlanBankAccountName, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAccountName
                    oPFArray(k_PFPlanBankBranch, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankBranch
                    oPFArray(bSIRPremFinConst.kBIC, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BIC
                    oPFArray(bSIRPremFinConst.kIBAN, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.IBAN

                    If oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAddress Is Nothing = False Then
                        oPFArray(k_PFPlanBankAddress1, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAddress.AddressLine1
                        oPFArray(k_PFPlanBankAddress2, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAddress.AddressLine2
                        oPFArray(k_PFPlanBankAddress3, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAddress.AddressLine3
                        oPFArray(k_PFPlanBankAddress4, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAddress.AddressLine4
                        oPFArray(k_PFPlanBankPostcode, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAddress.PostCode
                        oPFArray(k_PFPlanBankCountry, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAddress.CountryCode
                    End If

                    oPFArray(k_PFPlanBankAreaCode, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankAreaCode
                    oPFArray(k_PFPlanBankPhone, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankPhone
                    oPFArray(k_PFPlanBankExtn, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankExtn
                    oPFArray(k_PFPlanBankFaxCode, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankFaxCode
                    oPFArray(k_PFPlanBankFax, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.BankFax

                    ' populate the credit card details into the array 
                    ' if they are present in the request
                    If oUpdateQuotePaymentMethodRequest.PaymentMethod = PaymentMethodType.CreditCard Then

                        If oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard IsNot Nothing Then

                            oPFArray(k_PFPlanBankAccountName, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.NameOnCreditCard
                            oPFArray(k_PFPlanCCNumber, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.Number
                            oPFArray(k_PFPlanCCExpiryDate, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.ExpiryDate
                            oPFArray(k_PFPlanCCStartDate, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.StartDate
                            oPFArray(k_PFPlanCCIssue, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.Issue
                            oPFArray(k_PFPlanCCPin, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.Pin
                            oPFArray(k_PFPlanCardType, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.TypeCode
                            oPFArray(k_PFPlanPartyBankIdSel, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.PartyBankKey

                            oPFArray(k_PFPlanIsCardholder, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.CardHolder Is Nothing

                            If oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.CardHolder IsNot Nothing Then

                                oPFArray(k_PfPlanCardholderName, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.CardHolder.Name
                                oPFArray(k_PfPlanCardholderAddress1, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.CardHolder.AddressLine1
                                oPFArray(k_PfPlanCardholderAddress2, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.CardHolder.AddressLine2
                                oPFArray(k_PfPlanCardholderAddress3, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.CardHolder.AddressLine3
                                oPFArray(k_PfPlanCardholderAddress4, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.CardHolder.AddressLine4
                                oPFArray(k_PfPlanCardholderPostcode, 0) = oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote.CreditCard.CardHolder.PostCode
                            End If

                        End If

                    End If

                    Dim lPremiumFinanceCntObject As Object = lPremiumFinanceCnt
                    Dim lPremiumFinanceVerObject As Object = lPremiumFinanceVer
                    oPFArrayObject = oPFArray

                    comReturnValue = oPremiumFinance.UpdateExistingRecord(
                        CType(CObj(oPFArrayObject), System.Array(,)),
                        lPremiumFinanceCntObject,
                        lPremiumFinanceVerObject)

                    If (comReturnValue <> PMEReturnCode.PMTrue) Then
                        If oPremiumFinance IsNot Nothing Then
                            oPremiumFinance.Dispose()
                            oPremiumFinance = Nothing
                        End If
                        RaiseComMethodException("bSIRPremiumFinance.BusinessClass.UpdateExistingRecord Failed", comReturnValue)
                    End If

                End If

            End If

            Dim listRisksBusiness As bSIRListRisks.Business = CreateAndInitialiseListRisksBusiness(con, oUpdateQuotePaymentMethodRequest.BranchCode)

            UpdatePolicyPaymentDetails(listRisksBusiness, oUpdateQuotePaymentMethodRequest.InsuranceFileKey, oUpdateQuotePaymentMethodRequest.PaymentMethod.ToString, False)
            If (comReturnValue <> PMEReturnCode.PMTrue) Then
                If listRisksBusiness IsNot Nothing Then
                    listRisksBusiness.Dispose()
                    listRisksBusiness = Nothing
                End If
            End If

            oCoreBusiness.UnlockAndGetSAMTS(Con:=con,
                BranchCode:=oUpdateQuotePaymentMethodRequest.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=oUpdateQuotePaymentMethodRequest.InsuranceFolderKey,
                TStamp:=oUpdateQuotePaymentMethodRequest.QuoteTimeStamp)

            ' Check for Errors
            If oAnyError Is Nothing = False Then
                ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
                oResponse.STSError = oAnyError
                Return oResponse
            End If
            con.CommitTransaction()
            oResponse.QuoteTimeStamp = oUpdateQuotePaymentMethodRequest.QuoteTimeStamp

        Catch
            con.RollbackTransaction()
            Throw
        Finally
            If oPremiumFinance IsNot Nothing Then
                oPremiumFinance.Dispose()
                oPremiumFinance = Nothing
            End If
        End Try

        Return oResponse
    End Function

    Private Sub UpdateQuotePaymentValidateBusiness(ByRef oSAMErrorCollection As SAMErrorCollection,
                                                        ByVal con As SiriusConnection,
                                                        ByVal oUpdateQuotePaymentMethodRequest As BaseUpdateQuotePaymentMethodRequestType)
        Dim InsuranceFileTypeKey As Integer
        Dim InsuranceFileTypeCode As String
        Dim oCoreBusiness As New CoreBusiness
        GetInsuranceFileType(con, oUpdateQuotePaymentMethodRequest.InsuranceFileKey,
                                InsuranceFileTypeKey, InsuranceFileTypeCode)

        If LCase(InsuranceFileTypeCode) <> "renewal" Then
            oSAMErrorCollection.AddBusinessRule(SAMConstants.
                     SAMInvalidData.InvalidInsuranceFileType,
                     "Only Policy Under Renewal is supported for this method.")
        End If

        ' Validate the Installment Quote is provided
        If oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote IsNot Nothing Then
            With oUpdateQuotePaymentMethodRequest.SelectedInstalmentQuote
                ' scheme no / scheme version / pfrf_id
                If Not IsValidScheme(con, .SelectedSchemeNo, .SelectedSchemeVersion, .PFRF_ID) Then
                    oSAMErrorCollection.AddInvalidData(
                    SAMConstants.SAMInvalidData.SelectedInstalmentQuoteDataIsInvalid,
                    SAMConstants.SAMInvalidData.SelectedInstalmentQuoteDataIsInvalid.ToString,
                    "SelectedSchemeNo/SelectedSchemeVersion/PFRF_ID")
                End If

                ' week day
                If .WeekDay > 7 OrElse .WeekDay < 0 Then
                    oSAMErrorCollection.AddInvalidData(
                               SAMConstants.SAMInvalidData.ValueOutOfAcceptableRange,
                               SAMConstants.SAMInvalidData.ValueOutOfAcceptableRange.ToString,
                               "WeekDay:AcceptableRange:1-7", .WeekDay.ToString)
                End If

                ' month day
                If .MonthDay > 31 OrElse .MonthDay < 0 Then
                    oSAMErrorCollection.AddInvalidData(
                               SAMConstants.SAMInvalidData.ValueOutOfAcceptableRange,
                               SAMConstants.SAMInvalidData.ValueOutOfAcceptableRange.ToString,
                               "MonthDay:AcceptableRange:1-31", .MonthDay.ToString)
                End If

                ' override interest rate
                If .OverrideInterestRate > 100 OrElse .OverrideInterestRate < -1 Then
                    oSAMErrorCollection.AddInvalidData(
                               SAMConstants.SAMInvalidData.ValueOutOfAcceptableRange,
                               SAMConstants.SAMInvalidData.ValueOutOfAcceptableRange.ToString,
                               "OverrideInterestRate:AcceptableRanges:(0-100=OverrideRates)(-1=NoOverride)", .OverrideInterestRate.ToString)
                End If

                ' credit card
                If .CreditCard IsNot Nothing Then
                    ValidateBaseCreditCardTypeData(con, .CreditCard, oSAMErrorCollection)
                End If

                ' bank address 
                If .BankAddress IsNot Nothing Then
                    ValidateBaseAddressTypeData(con, oCoreBusiness, .BankAddress, oSAMErrorCollection)
                End If
            End With
        End If
    End Sub

