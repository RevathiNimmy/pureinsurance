    '''This Generic  method validates lookup validations
    '''</summary>
    '''<param name="oErrorCollection" type="Object"></param>
    '''<param name="iCoverNoteStatusKey" type="Integer"></param>
    '''<param name="BranchCode" type="String"></param>
    '''<param name="CoverNoteStatusCode" type="String"></param>
    '''<remarks></remarks>
    Public Sub ValidateCoverNoteBookLookup(ByRef oErrorCollection As Object, ByRef iCoverNoteStatusKey As Integer, ByVal BranchCode As String, ByVal CoverNoteStatusCode As String)
