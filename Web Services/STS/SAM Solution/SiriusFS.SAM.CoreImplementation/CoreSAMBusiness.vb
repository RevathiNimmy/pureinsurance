        If UpdateRatingDetailsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateRatingDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oUpdateRatingDetailsResponse = New SAMForInsuranceV2ImplementationTypes.UpdateRatingDetailsResponseType
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(UpdateRatingDetailsRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If UpdateRatingDetailsRequest.InsuranceFileKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If
        If UpdateRatingDetailsRequest.RiskKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "RiskKey")
        End If

        If UpdateRatingDetailsRequest.TimeStamp Is Nothing Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "TimeStamp")
        End If

        oErrors.CheckForErrors()

        If UpdateRatingDetailsRequest.RatingDetails IsNot Nothing Then
            If UpdateRatingDetailsRequest.RatingDetails.Row IsNot Nothing Then
                'This is for Mandatory Validaation
                For iCount As Integer = 0 To UpdateRatingDetailsRequest.RatingDetails.Row.Length - 1
                    If String.IsNullOrEmpty(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).RatingSectionTypeCode) Then
                        oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                    SAMInvalidData.MandatoryInputMissing.ToString,
                                                    "RatingSectionTypeCode")
                    End If
                    If String.IsNullOrEmpty(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).EarningPatternCode) Then
                        oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                    SAMInvalidData.MandatoryInputMissing.ToString,
                                                    "EarningPatternCode")
                    End If
                    If String.IsNullOrEmpty(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).RateTypeCode) Then
                        oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                    SAMInvalidData.MandatoryInputMissing.ToString,
                                                    "RateTypeCode")
                    End If

                    oErrors.CheckForErrors()
                Next

                'This is For Lookup Validations
                For iCount As Integer = 0 To UpdateRatingDetailsRequest.RatingDetails.Row.Length - 1

                    iRatingSectionTypeId = GetAndValidateSpecifiedTableCode(con, "rating_section_type", "Rating_Section_Type_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).RatingSectionTypeCode, oErrors, "RatingSectionTypeCode")
                    iEarningPatternId = GetAndValidateSpecifiedTableCode(con, "Earning_Pattern", "Earning_Pattern_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).EarningPatternCode, oErrors, "EarningPatternCode")
                    iRateTypeId = GetAndValidateSpecifiedTableCode(con, "rate_type", "Rate_Type_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).RateTypeCode, oErrors, "RateTypeCode")

                    If Not String.IsNullOrEmpty(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).CountryCode) Then
                        iCountryId = GetAndValidateSpecifiedTableCode(con, "Country", "Country_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).CountryCode, oErrors, "CountryCode")

                    End If
                    If Not String.IsNullOrEmpty(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).StateCode) Then
                        iStateId = GetAndValidateSpecifiedTableCode(con, "State", "State_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).StateCode, oErrors, "StateCode")

                    End If
                    oErrors.CheckForErrors()
                Next
            End If
        End If


        Dim r_lInsFolderCnt As Integer = 0
        Dim r_lSourceId As Integer = 0
        oCoreBusiness.CheckInsuranceFile(con, UpdateRatingDetailsRequest.InsuranceFileKey, r_lInsFolderCnt, r_lSourceId)

        ' Check that the timestamp matches and lock the Quote
        Dim oAnyError As STSErrorType
        oAnyError = oCoreBusiness.CheckTSAndLock(
            BranchCode:=UpdateRatingDetailsRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=r_lInsFolderCnt,
            TStamp:=UpdateRatingDetailsRequest.TimeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oUpdateRatingDetailsResponse.STSError = oAnyError
            Return oUpdateRatingDetailsResponse
        End If
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_sir_peril_del")
            cmd.Parameters.Clear()
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(UpdateRatingDetailsRequest.InsuranceFileKey)
            cmd.AddInParameter("@risk_id", SqlDbType.Int).Value = Cast.NullIfDefault(UpdateRatingDetailsRequest.RiskKey)
            con.ExecuteNonQuery(cmd)
        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_sir_rating_section_del")
            cmd.Parameters.Clear()
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(UpdateRatingDetailsRequest.InsuranceFileKey)
            cmd.AddInParameter("@risk_id", SqlDbType.Int).Value = Cast.NullIfDefault(UpdateRatingDetailsRequest.RiskKey)
            con.ExecuteNonQuery(cmd)
        End Using

        If UpdateRatingDetailsRequest.RatingDetails IsNot Nothing Then
            If UpdateRatingDetailsRequest.RatingDetails.Row IsNot Nothing Then
                For iCount As Integer = 0 To UpdateRatingDetailsRequest.RatingDetails.Row.Length - 1
                    iCountryId = 0
                    iStateId = 0
                    iCurrencyID = 0
                    iRatingSectionTypeId = GetAndValidateSpecifiedTableCode(con, "rating_section_type", "Rating_Section_Type_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).RatingSectionTypeCode, oErrors, "RatingSectionTypeCode")
                    iEarningPatternId = GetAndValidateSpecifiedTableCode(con, "Earning_Pattern", "Earning_Pattern_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).EarningPatternCode, oErrors, "EarningPatternCode")
                    iRateTypeId = GetAndValidateSpecifiedTableCode(con, "rate_type", "Rate_Type_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).RateTypeCode, oErrors, "RateTypeCode")

                    If Not String.IsNullOrEmpty(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).CountryCode) Then
                        iCountryId = GetAndValidateSpecifiedTableCode(con, "Country", "Country_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).CountryCode, oErrors, "CountryCode")
                    End If
                    If Not String.IsNullOrEmpty(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).StateCode) Then
                        iStateId = GetAndValidateSpecifiedTableCode(con, "State", "State_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).StateCode, oErrors, "StateCode")
                    End If
                    If Not String.IsNullOrEmpty(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).CurrencyCode) Then
                        iCurrencyID = GetAndValidateSpecifiedTableCode(con, "Currency", "Currency_Id", "code", UpdateRatingDetailsRequest.RatingDetails.Row(iCount).CurrencyCode, oErrors, "CurrencyCode")
                    End If
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_sir_peril_allocation")
                        cmd.Parameters.Clear()
                        cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = UpdateRatingDetailsRequest.InsuranceFileKey
                        cmd.AddInParameter("@risk_id", SqlDbType.Int).Value = UpdateRatingDetailsRequest.RiskKey
                        cmd.AddInParameter("@rating_section_type_id", SqlDbType.Int).Value = iRatingSectionTypeId
                        cmd.AddInParameter("@policy_section_type_id", SqlDbType.Int).Value = DBNull.Value
                        cmd.AddInParameter("@earning_pattern_id", SqlDbType.Int).Value = iEarningPatternId
                        cmd.AddInParameter("@rate_type_id", SqlDbType.Int).Value = iRateTypeId
                        cmd.AddInParameter("@insurance_file_no_of_dp", SqlDbType.SmallInt).Value = DBNull.Value
                        cmd.AddInParameter("@original_flag", SqlDbType.Int).Value = UpdateRatingDetailsRequest.RatingDetails.Row(iCount).OriginalFlag
                        cmd.AddInParameter("@currency_id", SqlDbType.SmallInt).Value = IIf(iCurrencyID = 0, DBNull.Value, iCurrencyID)
                        cmd.AddInParameter("@annual_rate", SqlDbType.Decimal).Value = UpdateRatingDetailsRequest.RatingDetails.Row(iCount).AnnualRate
                        cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = UpdateRatingDetailsRequest.RatingDetails.Row(iCount).SumInsured
                        cmd.AddInParameter("@annual_premium", SqlDbType.Money).Value = Cast.ToDouble(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).AnnualPremium, 0.0)
                        cmd.AddInParameter("@this_premium", SqlDbType.Money).Value = UpdateRatingDetailsRequest.RatingDetails.Row(iCount).ThisPremium
                        cmd.AddInParameter("@country_id", SqlDbType.SmallInt).Value = IIf(iCountryId = 0, DBNull.Value, iCountryId)
                        cmd.AddInParameter("@state_id", SqlDbType.SmallInt).Value = IIf(iStateId = 0, DBNull.Value, iStateId)
                        cmd.AddInParameter("@is_amended", SqlDbType.SmallInt).Value = UpdateRatingDetailsRequest.RatingDetails.Row(iCount).IsAmended
                        cmd.AddInParameter("@calculated_premium", SqlDbType.Money).Value = UpdateRatingDetailsRequest.RatingDetails.Row(iCount).CalculatedPremium
                        cmd.AddInParameter("@override_reason", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(UpdateRatingDetailsRequest.RatingDetails.Row(iCount).OverrideReason)
                        cmd.AddInParameter("@Auto_calculated", SqlDbType.TinyInt).Value = 1
                        con.ExecuteNonQuery(cmd)
                    End Using
                Next
            End If
        End If

        Dim ACMethodName As String
        Dim iRet As Integer
        Dim oGIS As bGIS.Application = Nothing
        Try
            oGIS = New bGIS.Application
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed To create bGIS.Application", ex.Message)
            STSErrorEx.SetContext(oUpdateRatingDetailsResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "CreatebGISSTS", True)
            Return oUpdateRatingDetailsResponse
        End Try

        Try
            SAMFunc.InitialiseGIS(Con:=con, oGIS:=oGIS, SiriusUser:=_SiriusUser, sBranchCode:=UpdateRatingDetailsRequest.BranchCode)
        Catch ex As Exception
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed To initialise bGIS.Application", ex.Message)
            STSErrorEx.SetContext(oUpdateRatingDetailsResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "oGIS.Initialise", True)
            Return oUpdateRatingDetailsResponse
        End Try

        iRet = oGIS.SetProcessModes(SAMComponentAction.PMEdit, 0, 0, Cast.ToObjString("NB"), Now)
        If UpdateRatingDetailsRequest.TransactionType <> "" Then
            sTransactionType = UpdateRatingDetailsRequest.TransactionType
        Else
            sTransactionType = "NB"
        End If
        Try
            iRet = oGIS.UpdateRiskAfter(
                            v_lInsuranceFileCnt:=UpdateRatingDetailsRequest.InsuranceFileKey,
                            v_lInsuranceFolderCnt:=r_lInsFolderCnt,
                            v_lRiskCnt:=UpdateRatingDetailsRequest.RiskKey,
                            sTransactionType:=sTransactionType)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Recalculate_Policy_Fees")
                cmd.AddInParameter("@Transaction_type_id", SqlDbType.Int).Value = -1
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = UpdateRatingDetailsRequest.InsuranceFileKey
                cmd.AddInParameter("@product_id", SqlDbType.Int).Value = -1
                cmd.AddInParameter("@sTransactionType", SqlDbType.VarChar).Value = UpdateRatingDetailsRequest.TransactionType
                cmd.AddInParameter("@nViaSAM", SqlDbType.Int).Value = 1
                con.ExecuteNonQuery(cmd)
            End Using

        Catch ex As Exception
            Dim STSError3 As New STSErrorPublisher("bGis.Application.GetPremiumData failed", ex)
            STSError3.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GetPremiumDataReturn", True)
        End Try

        Try
            If oGIS IsNot Nothing Then
                oGIS.Dispose()
                oGIS = Nothing
            End If
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed To terminate business", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "Terminate", True)
        End Try

        oAnyError = oCoreBusiness.UnlockAndGetTS(
                  BranchCode:=UpdateRatingDetailsRequest.BranchCode,
                  Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                  LockValue:=r_lInsFolderCnt,
                  TStamp:=oUpdateRatingDetailsResponse.TimeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Unable to unlock, return the error.
            oUpdateRatingDetailsResponse.STSError = oAnyError
            Return oUpdateRatingDetailsResponse
        End If

        Return oUpdateRatingDetailsResponse
    End Function

