    Public Overloads Function GetCashDepositsForPolicy(ByVal conGetCashDepositsForPolicy As SiriusConnection, ByVal oGetCashDepositsForPolicyRequest As BaseGetCashDepositsForPolicyRequestType) As BaseGetCashDepositsForPolicyResponseType

        '**********************************************************************************************
        'Declarations
        '**********************************************************************************************
        Dim oGetCashDepositsForPolicyResponse As New BaseGetCashDepositsForPolicyResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCoreBusiness As New CoreBusiness
        Dim iPolicyBranchId As Integer = 0
        Dim iPolicyProductId As Integer = 0
        Dim sBusinessTypeCode As String = Nothing
        Dim iPartyKey As Integer = 0
        Dim iLeadAgentKey As Integer = 0
        Dim sLeadAgentTypeCode As String = Nothing
        Dim dtCoverFromDate As DateTime = Nothing
        Dim bFlag As Boolean = False
        Dim iCurrencyId As Integer
        Dim sOptionValue As String
        Dim iWarningCount As Integer = 0
        Dim dsCashDepositDetails As DataSet = Nothing
        Dim bIsLocked As Boolean
        Dim AnyError As STSErrorType

        If oGetCashDepositsForPolicyRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetCashDepositsForPolicyRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetCashDepositsForPolicyResponse = New SAMForInsuranceV2ImplementationTypes.GetCashDepositsForPolicyResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        '**********************************************************************************************
        ''Structure Validation(Mandatory Checking)
        '**********************************************************************************************
        oGetCashDepositsForPolicyRequest.Validate(CObj(oSAMErrorCollection))

        oSAMErrorCollection.CheckForErrors()

        '**********************************************************************************************
        'Data Validation
        '**********************************************************************************************
        oGetCashDepositsForPolicyRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
          PMLookupTable.Source, oGetCashDepositsForPolicyRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        oGetCashDepositsForPolicyRequest.InsuranceFileKey = GetAndValidateSpecifiedTableCode(conGetCashDepositsForPolicy,
            PMLookupTable.Insurance_file, "insurance_file_cnt", "insurance_file_cnt", oGetCashDepositsForPolicyRequest.InsuranceFileKey.ToString(), oSAMErrorCollection, "InsuranceFileKey")

        oGetCashDepositsForPolicyRequest.InsuranceFolderKey = GetAndValidateSpecifiedTableCode(conGetCashDepositsForPolicy,
         PMLookupTable.Insurance_file, "insurance_folder_cnt", "insurance_file_cnt", oGetCashDepositsForPolicyRequest.InsuranceFileKey.ToString(), oSAMErrorCollection, "InsuranceFileKey")

        oSAMErrorCollection.CheckForErrors()

        bFlag = GetCompleteInsuranceFileDetails(conGetCashDepositsForPolicy, oGetCashDepositsForPolicyRequest.InsuranceFileKey,
        iPolicyBranchId, iPolicyProductId, sBusinessTypeCode, iPartyKey, iLeadAgentKey, sLeadAgentTypeCode,
        dtCoverFromDate, iCurrencyId)

        If (bFlag = False) Then
            oSAMErrorCollection.AddBusinessRule(SAMConstants.SAMBusinessErrors.InValidInsuranceFileCnt, "Invalid InsuranceFileKey")
        End If
        oSAMErrorCollection.CheckForErrors()

        sOptionValue = oCoreBusiness.GetProductOption(SIRHiddenOptions.SIROPTEnablePayNowOptions, iPolicyBranchId)
        If Trim(sOptionValue) <> "" And Trim(sOptionValue).Length > 0 Then
            oGetCashDepositsForPolicyRequest.isPrePayment = True
        Else
            oGetCashDepositsForPolicyRequest.isPrePayment = False
        End If

        If sBusinessTypeCode.Trim() = InternalSAMConstants.kBusinessTypeDIRECT Then
            If oGetCashDepositsForPolicyRequest.GetCDsOf = CDPartyType.Agent Then
                AddWarning(oGetCashDepositsForPolicyResponse.Warnings,
                SAMBusinessWarnings.InCaseOfDirectBusinessNoAgentWillBeavailable,
                "In case of direct business no Agent will be available")
            End If
            oGetCashDepositsForPolicyRequest.PartyKey = iPartyKey
        ElseIf sBusinessTypeCode.Trim() = InternalSAMConstants.kBusinessTypeAGENCY Then
            If sLeadAgentTypeCode IsNot Nothing Then
                If (sLeadAgentTypeCode.Trim() = InternalSAMConstants.sBroker) Then
                    If (oGetCashDepositsForPolicyRequest.GetCDsOf = CDPartyType.Client) Then
                        AddWarning(oGetCashDepositsForPolicyResponse.Warnings,
                        SAMBusinessWarnings.InCaseIfAgentIsABrokerThenOnlyAgentCDsShouldbeRetrieved,
                        "In case if agent is a broker then only Agent CDs should be retrieved")
                    End If
                    oGetCashDepositsForPolicyRequest.PartyKey = iLeadAgentKey
                ElseIf (sLeadAgentTypeCode.Trim() = InternalSAMConstants.sCommissionAccount) Then
                    If (oGetCashDepositsForPolicyRequest.GetCDsOf = CDPartyType.Agent) Then
                        AddWarning(oGetCashDepositsForPolicyResponse.Warnings,
                        SAMBusinessWarnings.InCaseIfAgentIsACommAccThenOnlyClientCDSShouldBeRetrieved,
                        "In case if agent is a Comm Acc then only Client CDS should be retrieved")
                    End If
                    oGetCashDepositsForPolicyRequest.PartyKey = iPartyKey
                ElseIf (sLeadAgentTypeCode.Trim() = InternalSAMConstants.sIntermediary) Then
                    If (oGetCashDepositsForPolicyRequest.GetCDsOf = CDPartyType.Agent) Then
                        oGetCashDepositsForPolicyRequest.PartyKey = iLeadAgentKey
                    ElseIf (oGetCashDepositsForPolicyRequest.GetCDsOf = CDPartyType.Client) Then
                        oGetCashDepositsForPolicyRequest.PartyKey = iPartyKey
                    End If
                End If
            End If
        End If

        oGetCashDepositsForPolicyRequest.TotalPremium = GetTotalPremiumAmount(conGetCashDepositsForPolicy, oGetCashDepositsForPolicyRequest.InsuranceFileKey)

        If oGetCashDepositsForPolicyRequest.TotalPremium < 0 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Policy_CDPayment_History")
                cmd.AddInParameter("@Party_Cnt", SqlDbType.Int).Value = oGetCashDepositsForPolicyRequest.PartyKey
                cmd.AddInParameter("@Insurance_Folder_Cnt", SqlDbType.Int).Value = oGetCashDepositsForPolicyRequest.InsuranceFolderKey
                dsCashDepositDetails = conGetCashDepositsForPolicy.ExecuteDataSet(cmd, "PolicyCashDeposit")
            End Using
        ElseIf oGetCashDepositsForPolicyRequest.TotalPremium > 0 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_CashDeposit_For_Policy")
                cmd.AddInParameter("@Product_ID", SqlDbType.Int).Value = iPolicyProductId
                cmd.AddInParameter("@Branch_ID", SqlDbType.Int).Value = iPolicyBranchId
                cmd.AddInParameter("@Policy_ID", SqlDbType.Int).Value = oGetCashDepositsForPolicyRequest.InsuranceFileKey
                cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oGetCashDepositsForPolicyRequest.PartyKey
                cmd.AddInParameter("@Is_PrePayment", SqlDbType.TinyInt).Value = IIf(oGetCashDepositsForPolicyRequest.isPrePayment = True, 1, 0)
                cmd.AddInParameter("@Total_Premium", SqlDbType.Decimal).Value = oGetCashDepositsForPolicyRequest.TotalPremium
                cmd.AddInParameter("@Cover_Start_Date", SqlDbType.DateTime).Value = dtCoverFromDate
                cmd.AddInParameter("@Policy_Issue_Date", SqlDbType.DateTime).Value = Now
                dsCashDepositDetails = conGetCashDepositsForPolicy.ExecuteDataSet(cmd, "PolicyCashDeposit")
            End Using
        End If

        If (dsCashDepositDetails IsNot Nothing) Then
            If (dsCashDepositDetails.Tables.Count >= 1) Then
                dsCashDepositDetails.Tables(0).Columns("CashDeposit_ID").ColumnName = "CashDepositKey"
                dsCashDepositDetails.Tables(0).Columns("Account_ID").ColumnName = "AccountKey"
                dsCashDepositDetails.Tables(0).Columns("Party_ID").ColumnName = "PartyKey"
                dsCashDepositDetails.Tables(0).Columns("CashDeposit_Ref").ColumnName = "CashDepositRef"
                dsCashDepositDetails.Tables(0).Columns("Amount").ColumnName = "Amount"
                dsCashDepositDetails.Tables(0).Columns("available_balance").ColumnName = "AvailableBalance"
                dsCashDepositDetails.Tables(0).Columns("Date_Created").ColumnName = "DateCreated"
                Dim xmlDoc As New XmlDocument
                dsCashDepositDetails.DataSetName = "BaseGetCashDepositsForPolicyResponseTypeCashDepositPolicies"
                dsCashDepositDetails.Tables(0).TableName = "Row"
                If oGetCashDepositsForPolicyRequest.WCFSecurityToken = "" Then
                    xmlDoc.LoadXml(dsCashDepositDetails.GetXml())
                    oGetCashDepositsForPolicyResponse.ResultDataset = xmlDoc.DocumentElement
                End If

                oGetCashDepositsForPolicyResponse.ResultData = dsCashDepositDetails

            End If
        End If

        oGetCashDepositsForPolicyResponse.AgentType = sLeadAgentTypeCode

        AnyError = oCoreBusiness.GetTimestamp(
                                  oGetCashDepositsForPolicyRequest.BranchCode,
                                  CoreBusiness.LockName.PartyCnt,
                                  oGetCashDepositsForPolicyRequest.PartyKey,
                                  oGetCashDepositsForPolicyResponse.CDTimeStamp,
                                  bIsLocked)
        ' Return AnyErrors
        If AnyError Is Nothing = False Then
            oGetCashDepositsForPolicyResponse.STSError = AnyError
        End If

        Return oGetCashDepositsForPolicyResponse
    End Function

