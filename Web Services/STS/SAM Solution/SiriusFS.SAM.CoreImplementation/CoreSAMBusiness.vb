    Public Overloads Function GetAccountingPeriod(ByRef ConnIN As SiriusConnection,
                                                            ByVal oRequest As BaseGetAccountingPeriodRequestType) As BaseGetAccountingPeriodResponseType

        Dim oGetAccountingPeriodResponse As New BaseGetAccountingPeriodResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim iSourceId As Integer = 0
        Dim iSubBranchId As Integer = 0
        Dim dsResult As DataSet = Nothing

        Dim nTypeOfPackage As enumTypeOfPackage

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetAccountingPeriodRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetAccountingPeriodResponse = New SAMForInsuranceV2ImplementationTypes.GetAccountingPeriodResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        oRequest.Validate(CType(oErrors, SAMErrorCollection))
        oErrors.CheckForErrors()

        If Not String.IsNullOrEmpty(oRequest.BranchCode) Then
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oErrors)
        End If

        If oRequest.SubBranchCodeSpecified = True Then
            If Not String.IsNullOrEmpty(oRequest.SubBranchCode) Then
                iSubBranchId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.SubBranchCode, "BranchCode", oErrors)
            End If
        End If

        oErrors.CheckForErrors()

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Do_GetPeriodForDate")
            cmd.AddInParameter("@company_id", SqlDbType.TinyInt).Value = iSourceId
            cmd.AddInParameter("@date_in_period", SqlDbType.DateTime).Value = Cast.ToDateTime(oRequest.DateInPeriod)
            cmd.AddInParameter("@sub_branch_id", SqlDbType.TinyInt).Value = Cast.NullIfDefault(iSubBranchId)
            dsResult = ConnIN.ExecuteDataSet(cmd, "GetAccountindPeriod")
        End Using

        If dsResult IsNot Nothing Then
            If dsResult.Tables.Count > 0 Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_SelAll_Period")
                    cmd.AddInParameter("@company_id", SqlDbType.TinyInt).Value = iSourceId
                    If oRequest.SubBranchCode IsNot Nothing Then
                        cmd.AddInParameter("@sub_branch_id", SqlDbType.TinyInt).Value = Cast.NullIfDefault(iSubBranchId)
                    End If
                    cmd.AddInParameter("@year_name", SqlDbType.VarChar, 20).Value = Cast.ToString(dsResult.Tables("GetAccountindPeriod").Rows(0).Item("year_name").ToString)
                    dsResult = ConnIN.ExecuteDataSet(cmd, "GetDocuments")
                End Using
            End If
        Else
            ' Check mandatory fields
            oErrors.AddBusinessRule(SAMBusinessErrors.NoAccountingPeriodFound,
                                            SAMBusinessErrors.NoAccountingPeriodFound.ToString,
                                            "No Accounting Period Found")
            oErrors.CheckForErrors()
        End If

        If (dsResult.Tables.Count > 0) Then

            If (dsResult.Tables(0).Rows.Count > 0) Then

                Dim dsFilter As DataSet = Nothing
                dsFilter = New DataSet
                With dsFilter
                    .Tables.Add()
                    .Tables(0).Columns.Add("PeriodKey", GetType(System.Int16))
                    .Tables(0).Columns.Add("YearName", GetType(System.String))
                    .Tables(0).Columns.Add("PeriodName", GetType(System.String))
                    .Tables(0).Columns.Add("PeriodEndDate", GetType(System.DateTime))
                End With

                Dim iCount As Integer
                With dsFilter.Tables(0)
                    For iCount = 0 To dsResult.Tables(0).Rows.Count - 1
                        .Rows.Add()
                        .Rows(iCount)("PeriodKey") = Cast.ToInt16(dsResult.Tables(0).Rows(iCount).Item("period_id"), 0)
                        .Rows(iCount)("YearName") = dsResult.Tables(0).Rows(iCount).Item("year_name").ToString
                        .Rows(iCount)("PeriodName") = dsResult.Tables(0).Rows(iCount).Item("period_name").ToString
                        .Rows(iCount)("PeriodEndDate") = Cast.ToDateTime(dsResult.Tables(0).Rows(iCount).Item("period_end_date"))
                    Next
                End With

                'Reformat the data set the get only the elements needed
                Dim xmlDoc As New System.Xml.XmlDocument
                dsFilter.DataSetName = "BaseGetAccountingPeriodResponseTypePeriod"
                dsFilter.Tables(0).TableName = "Row"

                If oRequest.WCFSecurityToken = "" Then
                    xmlDoc.LoadXml(dsFilter.GetXml)
                    If (dsFilter.Tables.Count >= 1) Then
                        'Populate the XML Document here with the dsUserGroups information
                        oGetAccountingPeriodResponse.ResultDataSet = xmlDoc.DocumentElement()
                    End If
                End If

                If (dsFilter.Tables.Count >= 1) Then
                    oGetAccountingPeriodResponse.ResultData = dsFilter
                End If
            End If
        End If

        Return oGetAccountingPeriodResponse

    End Function

