        ' Call stored proc to get the Risks
        Dim dr As DataSet = Nothing

        ' BSJ April 09 - SQL Mixed Mode Compliance
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Risk_By_Product")
                cmd.AddInParameter("@ProductID", SqlDbType.Int).Value = iProductID

                dr = con.ExecuteDataSet(cmd, "dr")
            End Using
        End Using

        'Dim arParams(0) As SqlParameter
        'arParams(0) = New SqlParameter("@ProductID", iProductID)
        '
        'dr = SqlHelper.ExecuteDataset(oBusiness.ConnectionString.ToString, _
        '    CommandType.StoredProcedure, _
        '    "spu_SAM_Get_Risk_By_Product", _
        '    arParams)

        ' Name the dataset and table
        dr.DataSetName = "BaseGetRiskByProductResponseTypeRisks"
        dr.Tables(0).TableName = "Row"
        dr.Tables(0).Columns(0).ColumnName = "RiskTypeKey"
        dr.Tables(0).Columns(1).ColumnName = "RiskTypeCode"
        dr.Tables(0).Columns(2).ColumnName = "Description"
        dr.Tables(0).Columns(3).ColumnName = "ScreenKey"
        dr.Tables(0).Columns(4).ColumnName = "DataModelCode"
        dr.Tables(0).Columns(5).ColumnName = "ScreenCode"

        Dim oXMLDoc As New System.Xml.XmlDocument
        Try
            If GetRiskByProductRequest.WCFSecurityToken = "" Then
                Try
                    oXMLDoc.LoadXml(dr.GetXml)
                Catch ex As Exception
                    Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.XMLDocumentBadlyFormed, "Unable to load SQL output as XML", ex.Message)
                    STSErrorEX.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
                    Return oResponse
                End Try
                oResponse.Risks = oXMLDoc.DocumentElement
            End If

            oResponse.ResultData = dr

        Catch ex As Exception
            Dim STSErrorEX As New STSErrorPublisher(STSErrorCodes.XMLDocumentBadlyFormed, "Unable to pass Document Element", ex.Message)
            STSErrorEX.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
            Return oResponse
        End Try

        If nTypeOfPackage = enumTypeOfPackage.AgentsPackage Then
            Dim oResponseAgent As New AgentImplementationTypes.GetRiskByProductResponseType
            oResponseAgent = DirectCast(oResponse, AgentImplementationTypes.GetRiskByProductResponseType)
            oResponse = oResponseAgent
        End If

        Return oResponse

    End Function

    Public Function GetUserDetails(ByVal oRequest As BaseGetUserDetailsRequestType) As BaseGetUserDetailsResponseType

        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oBusiness As New CoreBusiness
        Dim oResponse As BaseGetUserDetailsResponseType = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage

        ' determine the type of package and thus the type of response
        If oRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetUserDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GetUserDetailsResponseType
        ElseIf oRequest.GetType Is GetType(SAMForBrokingImplementationTypes.GetUserDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oResponse = New SAMForBrokingImplementationTypes.GetUserDetailsResponseType
        ElseIf oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetUserDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetUserDetailsResponseType
        ElseIf oRequest.GetType Is GetType(BaseImplementationTypes.BaseGetUserDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetUserDetailsResponseType
        End If

        ' get the pmuser sources
        Using con As SiriusConnection = SiriusConnection.FromAny(SAMFunc.ConnectionString)

            Dim dt As DataTable = Nothing
            Dim dsUserGroups As DataSet = Nothing

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_User_Details")

                cmd.AddInParameter("@UserID", SqlDbType.Int).Value = oRequest.UserId

                dt = con.ExecuteDataTable(cmd)

            End Using

            ' if the user has available sources 
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                Dim oSources As BaseBranchType() = Nothing

                ' resize array
                Array.Resize(oSources, dt.Rows.Count)

                Dim iSource As Integer = 0

                ' for each source
                Dim dr As DataRow = dt.Rows(0)

                oResponse.FullUsername = Cast.ToString(dr.Item("FullUsername"), String.Empty)
                oResponse.PasswordChangeDate = Cast.ToDateTime(dr.Item("PasswordChangedDate"), Date.MinValue)
                oResponse.LastLogin = Cast.ToDateTime(dr.Item("LastLogin"), Date.MinValue)
                oResponse.EmailAddress = Cast.ToString(dr.Item("EmailAddress"), String.Empty)
                oResponse.PartyKey = Cast.ToInt32(dr.Item("PartyCnt"), 0)
                oResponse.PartyName = Cast.ToString(dr.Item("PartyResolvedName"), String.Empty)
                oResponse.PartyType = Cast.ToStringTrim(dr.Item("PartyTypeCode"), String.Empty)
                oResponse.PartyShortName = Cast.ToStringTrim(dr.Item("PartyShortName"), String.Empty)
                oResponse.ConsolidatedAgentCommission = (Cast.ToString(dr.Item("ConsolidatedAgentCommission")) = "1")
                oResponse.PureUsername = Cast.ToStringTrim(dr.Item("Username"), String.Empty)
            End If

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_pm_get_user_sources")

                cmd.AddInParameter("@UserID", SqlDbType.Int).Value = oRequest.UserId

                dt = con.ExecuteDataTable(cmd)

            End Using

            ' if the user has available sources 
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                Dim oSources As BaseBranchType() = Nothing

                ' resize array
                Array.Resize(oSources, dt.Rows.Count)

                Dim iSource As Integer = 0

                ' for each source
                For Each dr As DataRow In dt.Rows

                    Dim oSource As New BaseImplementationTypes.BaseBranchType

                    ' populate the response type
                    oSource.Description = Cast.ToStringTrim(dr.Item("description"), String.Empty)
                    oSource.BranchCode = Cast.ToStringTrim(dr.Item("code"), String.Empty)
                    oSource.BranchKey = Cast.ToInt32(dr.Item("source_id"), 0)
                    oSource.AgentCode = Cast.ToStringTrim(dr.Item("shortname"), String.Empty)
                    oSource.BusinessType = Cast.ToStringTrim(dr.Item("direct_business"), String.Empty)
                    oSource.AgentKey = Cast.ToInt32(dr.Item("agentkey"), 0)


                    oSources(iSource) = oSource

                    iSource += 1

                Next

                oResponse.SourceList = oSources

            End If

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Allow_Consolidated_Commission")

                cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oRequest.AgentKey

                dt = con.ExecuteDataTable(cmd)

            End Using

            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                ' See if the agent is allowed consilidated commission 
                oResponse.ConsolidatedAgentCommission = CBool(IIf(Cast.ToInt32(dt.Rows(0).Item(0), 0) = 1, True, False))

            End If

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_pmuser_group_info")

                cmd.AddInParameter("@user_id", SqlDbType.Int).Value = oRequest.UserId
                cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = DateTime.Now

                dsUserGroups = con.ExecuteDataSet(cmd, "Row")
                If dsUserGroups IsNot Nothing AndAlso dsUserGroups.Tables.Count > 0 Then
                    For Each dataTable As DataTable In dsUserGroups.Tables
                        If dataTable.Rows.Count > 0 Then
                            dataTable.Columns(0).ColumnName = "UserGroupKey"
                            dataTable.Columns(1).ColumnName = "Code"
                            dataTable.Columns(2).ColumnName = "Description"
                            dataTable.Columns(3).ColumnName = "IsAssociated"
                            dataTable.Columns(4).ColumnName = "IsSupervisor"
                            dataTable.Columns(5).ColumnName = "IsSystemAdmin"
                        End If
                    Next
                    Dim DocUserGroups As New System.Xml.XmlDocument
                    dsUserGroups.DataSetName = "BaseGetUserDetailsResponseTypeUserGroups"
                    dsUserGroups.Tables(0).TableName = "Row"

                    DocUserGroups.LoadXml(dsUserGroups.GetXml)
                    oResponse.UserGroups = DocUserGroups.DocumentElement()

                    oResponse.ResultData = dsUserGroups

                Else
                    oResponse.UserGroups = Nothing
                    oResponse.ResultData = Nothing

                End If

            End Using

        End Using

        Return oResponse

    End Function

