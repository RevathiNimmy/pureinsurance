        Dim lUserId As Integer

        'Get UserGroupId
        lUserGroupId = oCorebusiness.GetAndValidateListItemFromCode(CType(STSListType.PMLookup, Core.STSListType), "pmuser_group", oUpdateWmTaskRequest.UserGroupCode, "AllocationUserGroup", oSAMErrorCollection)

        'Get UserId
        If Not String.IsNullOrEmpty(oUpdateWmTaskRequest.UserCode) Then
            lUserId = GetUserId(con, oUpdateWmTaskRequest.UserCode)
            If lUserId <= 0 Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.UserDoesNotExist, SAMInvalidData.UserDoesNotExist.ToString, "AllocationUser")
            End If
        End If
        oSAMErrorCollection.CheckForErrors()

        Try
            con.BeginTransaction()

            With oUpdateWmTaskRequest
                UpdateTaskInstance(con, .TaskInstanceKey, .Client, .DueDate, lUserGroupId, lUserId,
                                    .Description, .TaskStatusKey, .Urgent, Now, _SiriusUser.UserID, 1, "")

                If (.KeyData IsNot Nothing) Then
                    If (.KeyData.Row IsNot Nothing) Then
                        If (.KeyData.Row.Length > 0) Then
                            Dim iCount As Integer
                            For iCount = 0 To oUpdateWmTaskRequest.KeyData.Row.Length - 1
                                UpdateTaskInstanceKey(con, .TaskInstanceKey, .KeyData.Row(iCount).KeyName, .KeyData.Row(iCount).KeyValue)
                            Next
                        End If
                    End If
                End If
            End With

            con.CommitTransaction()

        Catch ex As Exception
            con.RollbackTransaction()
            Throw
        End Try

        ' Unlock and return the new timestamp
        AnyError = oCorebusiness.UnlockAndGetTS(con,
            BranchCode:=oUpdateWmTaskRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.TaskInstanceCnt,
            LockValue:=oUpdateWmTaskRequest.TaskInstanceKey,
            TStamp:=oUpdateWmTaskResponse.TaskTimeStamp)

        ' Check for Errors
        If AnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oUpdateWmTaskResponse.STSError = AnyError
            Return oUpdateWmTaskResponse
        End If

        Return oUpdateWmTaskResponse

    End Function

