            Return Nothing
        End If

        oGetProductRiskOptionValueRequest.Validate(CObj(oSAMErrorCollection))
        oSAMErrorCollection.CheckForErrors()

        ValidateProductRiskLookup(oGetProductRiskOptionValueRequest, oSAMErrorCollection, iproductId, iriskTypeId)
        oSAMErrorCollection.CheckForErrors()

        ValidateProductRiskBusinessRule(oGetProductRiskOptionValueRequest, oSAMErrorCollection)
        oSAMErrorCollection.CheckForErrors()
        Dim sProductRiskMaintenance As String = String.Empty
        Dim sRiskTypeMaintenance As String = String.Empty

        If oGetProductRiskOptionValueRequest.ActionType = ProductConfigActionType.ProductRiskMaintenance Then
