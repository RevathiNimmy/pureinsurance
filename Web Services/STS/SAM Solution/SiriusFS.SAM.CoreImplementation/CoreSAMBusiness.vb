    Public Overloads Function UpdateSubAgents(ByVal conUpdate As SiriusConnection, ByVal oUpdateSubAgentsRequest As BaseUpdateSubAgentsRequestType) As BaseUpdateSubAgentsResponseType
        Dim insuranceFileTypeId As Integer = 0
        Dim insuranceFileTypeCode As String = String.Empty

        Dim oUpdateSubAgentsResponse As New BaseUpdateSubAgentsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oUpdateSubAgentsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateSubAgentsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateSubAgentsResponse = New SAMForInsuranceV2ImplementationTypes.UpdateSubAgentsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oUpdateSubAgentsRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If oUpdateSubAgentsRequest.InsuranceFileKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "InsuranceFileKey")
        End If

        oErrors.CheckForErrors()
        If oUpdateSubAgentsRequest.SubAgents IsNot Nothing AndAlso oUpdateSubAgentsRequest.SubAgents.Row IsNot Nothing Then

            For iCount As Integer = 0 To oUpdateSubAgentsRequest.SubAgents.Row.Length - 1

                If oUpdateSubAgentsRequest.SubAgents.Row(iCount).PartyKey = 0 Then
                    oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "PartyKey")
                End If
            Next
        End If
        oErrors.CheckForErrors()

        'Business rule validation
        GetInsuranceFileType(conUpdate, oUpdateSubAgentsRequest.InsuranceFileKey, insuranceFileTypeId, insuranceFileTypeCode)

        If insuranceFileTypeCode = InsuranceFileType.LivePolicy Then
            oErrors.AddBusinessRule(SAMBusinessErrors.CanNotUpdateLivePolicyDetails,
                SAMBusinessErrors.CanNotUpdateLivePolicyDetails.ToString,
                "Can not update SubAgents details for a live poilcy")
        End If

        oErrors.CheckForErrors()

        'As said by Gaurav to get the insurance folder key
        Dim r_lInsFolderCnt As Integer = 0
        Dim r_lSourceId As Integer = 0
        oCoreBusiness.CheckInsuranceFile(conUpdate, oUpdateSubAgentsRequest.InsuranceFileKey, r_lInsFolderCnt, r_lSourceId)

        'Use the time stamp for record locking purposes
        Dim oAnyError As STSErrorType
        'As said by Gaurav(lock based on InsuranceFolderKey)
        oAnyError = oCoreBusiness.CheckTSAndLock(
            BranchCode:=oUpdateSubAgentsRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
            LockValue:=r_lInsFolderCnt,
            TStamp:=oUpdateSubAgentsRequest.TimeStamp)
        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oUpdateSubAgentsResponse.STSError = oAnyError
            Return oUpdateSubAgentsResponse
        End If

        Try
            conUpdate.BeginTransaction()
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Del_SubAgents")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oUpdateSubAgentsRequest.InsuranceFileKey
                conUpdate.ExecuteNonQuery(cmd)
            End Using

            If oUpdateSubAgentsRequest.SubAgents IsNot Nothing AndAlso oUpdateSubAgentsRequest.SubAgents.Row IsNot Nothing Then
                For iCount As Integer = 0 To oUpdateSubAgentsRequest.SubAgents.Row.Length - 1
                    Using cmdUpdateSubAgents As SiriusCommand = SiriusCommand.FromProcedure("spu_Add_SubAgents")
                        cmdUpdateSubAgents.Parameters.Clear()
                        cmdUpdateSubAgents.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oUpdateSubAgentsRequest.InsuranceFileKey
                        cmdUpdateSubAgents.AddInParameter("@party_cnt", SqlDbType.Int).Value = oUpdateSubAgentsRequest.SubAgents.Row(iCount).PartyKey
                        cmdUpdateSubAgents.AddInParameter("@percentage", SqlDbType.Decimal, 7, 4).Value = oUpdateSubAgentsRequest.SubAgents.Row(iCount).Percentage
                        cmdUpdateSubAgents.AddInParameter("@amount", SqlDbType.Decimal, 19, 4).Value = oUpdateSubAgentsRequest.SubAgents.Row(iCount).Amount
                        conUpdate.ExecuteNonQuery(cmdUpdateSubAgents)
                    End Using
                Next
            End If

            conUpdate.CommitTransaction()
        Catch ex As Exception
            conUpdate.RollbackTransaction()
        End Try

        oAnyError = oCoreBusiness.UnlockAndGetTS(
       BranchCode:=oUpdateSubAgentsRequest.BranchCode,
       Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
       LockValue:=r_lInsFolderCnt,
       TStamp:=oUpdateSubAgentsResponse.TimeStamp)
        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Unable to unlock, return the error.
            oUpdateSubAgentsResponse.STSError = oAnyError
            Return oUpdateSubAgentsResponse
        End If
        Return oUpdateSubAgentsResponse
    End Function

