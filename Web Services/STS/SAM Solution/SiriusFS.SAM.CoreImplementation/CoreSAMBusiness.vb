    ''' <summary>
    ''' this will transform UDL values in response xml by adding two new attributes Code,Desc
    ''' </summary>
    ''' <param name="r_sXmlDataset"></param>
    ''' <param name="sDataModelCode"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function TransformResponseUDLValues(ByRef r_sXmlDataset As String, ByVal sDataModelCode As String) As Boolean

        Const kCreateQuoteSQL As String = "spu_SG_GetSGGISObjectAndPropertyFORUDL"

        Dim xDoc As XmlDocument
        Dim sString As String = String.Empty
        Dim xnlstNodelist As XmlNodeList

        If r_sXmlDataset.Trim = "" Then
            'raise exception and getout
            Return False
        End If

        xDoc = New XmlDocument
        xDoc.LoadXml(r_sXmlDataset)
        xDoc.XmlResolver = Nothing
        'So let's get the Element names ...
        'load all element and property in a datatable
        Dim dtResult As New DataTable

        'make a database call and load Object/ Property/ List 
        'pass the datamodel code as a parameter

        Using conDBConnection As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmdCommand As SiriusCommand = SiriusCommand.FromProcedure(kCreateQuoteSQL)
                cmdCommand.AddInParameter("@sdata_model_code", SqlDbType.VarChar).SqlValue = sDataModelCode
                dtResult = conDBConnection.ExecuteDataTable(cmdCommand)
            End Using
        End Using

        Dim drRowObject As DataRow
        For Each drRowObject In dtResult.Rows
            sString = "//" & UCase(drRowObject.Item("OBJECT_NAME").ToString) & "/@" & UCase(drRowObject.Item("PROPERTY_NAME").ToString)
            'there is a possibility, if the user has selected more than one instance of a child screen,
            'that there could be more than one copy of an element. Here, we'll traverse through
            'them and make sure we do the necessary on each & every one.
            xnlstNodelist = xDoc.SelectNodes(sString)
            Dim xnElement As XmlNode

            For Each xnElement In xnlstNodelist
                If xnElement.InnerText.Trim <> "" Then

                    Dim sSql As String = "SELECT code, description FROM " & drRowObject.Item("specials_type_reference").ToString & " WHERE " & drRowObject.Item("specials_type_reference").ToString & "_id =" & xnElement.InnerText
                    Using cmdSiriusCommand As SiriusCommand = SiriusCommand.FromText(sSql)
                        Using conSiriusConnection As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

                            Dim dtResults As DataTable = conSiriusConnection.ExecuteDataTable(cmdSiriusCommand)

                            Dim xeSelectedElement As XmlElement
                            xeSelectedElement = CType(xnElement.SelectSingleNode(".."), XmlElement)

                            If dtResults.Rows.Count > 0 Then
                                If dtResults.Rows(0).Item("code") IsNot Nothing AndAlso dtResults.Rows(0).Item("code").ToString.Trim <> "" Then
                                    xeSelectedElement.SetAttribute(xnElement.Name & "CODE", dtResults.Rows(0).Item("code").ToString)
                                    xeSelectedElement.SetAttribute(xnElement.Name & "DESC", dtResults.Rows(0).Item("description").ToString)
                                End If
                            End If
                        End Using
                    End Using
                End If
            Next
        Next

        r_sXmlDataset = xDoc.OuterXml

        Return True

    End Function


