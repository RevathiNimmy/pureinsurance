                oInsurerPayment = Nothing
            End If
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bACTInsurerPaymentSFU.Application", ex.Message)
            STSErrorEx.SetContext(oAddWriteOffResponse.STSError, HttpContext.Current.Request.Url.ToString(), sACMethodName, "bACTInsurerPaymentSFU.Initialise", True)
            Return oAddWriteOffResponse
        End Try
        Try
            iRet = oInsurerPayment.AddWriteOffTransaction(Docid:=oAddWriteOffRequest.DocumentKey,
                            Account_id:=oAddWriteOffRequest.AccountKey,
                            WriteOffAccID:=iWriteOffAccID,
                            WriteOffamt:=oAddWriteOffRequest.WriteOffAmount, m_lTransDetailID:=m_lTransDetailId)
            oAddWriteOffResponse.TransactionKey = m_lTransDetailId
        Catch ex As Exception
            Dim STSError3 As New STSErrorPublisher("oInsurerPayment.AddWriteOffTransaction failed", ex)
            STSError3.Raise(HttpContext.Current.Request.Url.ToString(), sACMethodName, " Recalculate", True)
        End Try
        Try
            If oInsurerPayment IsNot Nothing Then
                oInsurerPayment.Dispose()
                oInsurerPayment = Nothing
            End If
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to terminate business", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), sACMethodName, "Terminate", True)
        End Try
        Return oAddWriteOffResponse
    End Function

