    Public Overloads Function AddEvent(ByVal oAddEventRequest As BaseAddEventRequestType) As BaseAddEventResponseType
        Dim oAddEventResponse As New BaseAddEventResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oAddEventRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AddEventRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oAddEventResponse = New SAMForInsuranceV2ImplementationTypes.AddEventResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing

        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oAddEventRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If
        If oAddEventRequest.PartyKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "PartyKey")
        End If

        ' Check mandatory fields
        If oAddEventRequest.EventTypeKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "EventTypeKey")
        End If
        'If oAddEventRequest.EventLogSubjectKey = 0 Then
        '    oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing, _
        '                                SAMInvalidData.MandatoryInputMissing.ToString, _
        '                                "EventLogSubjectKey")
        'End If
        If String.IsNullOrEmpty(oAddEventRequest.UserName) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "UserName ")
        End If
        If String.IsNullOrEmpty(oAddEventRequest.RtfText) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "RtfText ")
        End If
        If oAddEventRequest.EventDate <= Date.MinValue OrElse oAddEventRequest.EventDate = Nothing Then
            oErrors.AddInvalidData(
            SAMConstants.SAMInvalidData.MandatoryInputMissing,
            SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
            "EventDate")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        'Dim dsAddevent As DataSet = Nothing
        Using conAddevent As SiriusConnection = SiriusConnection.FromAny(connectionString:=ConnectionString)
            Dim iuserid As Int32
            Dim sDescription As String
            sDescription = oAddEventRequest.RtfText
            iuserid = GetAndValidateSpecifiedTableCode(conAddevent, "PMUser", "user_id", "username", oAddEventRequest.UserName, oErrors, "username")
            Using cmdAddevent As SiriusCommand = SiriusCommand.FromProcedure("spe_event_log_add")
                cmdAddevent.AddOutParameter("@event_cnt", SqlDbType.Int)
                cmdAddevent.AddInParameter("@party_cnt", SqlDbType.Int).Value = oAddEventRequest.PartyKey
                cmdAddevent.AddInParameter("@insurance_folder_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oAddEventRequest.InsuranceFolderKey, 0)
                cmdAddevent.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oAddEventRequest.InsuranceFileKey, 0)
                cmdAddevent.AddInParameter("@claim_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oAddEventRequest.ClaimKey, 0)
                cmdAddevent.AddInParameter("@document_cnt", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@old_address_cnt", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@new_address_cnt", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@campaign_id", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@document_type_id", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@report_type_id", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@event_type_id", SqlDbType.Int).Value = oAddEventRequest.EventTypeKey
                cmdAddevent.AddInParameter("@user_id", SqlDbType.Int).Value = iuserid
                cmdAddevent.AddInParameter("@event_date", SqlDbType.DateTime).Value = oAddEventRequest.EventDate
                cmdAddevent.AddInParameter("@description", SqlDbType.VarChar, 8000).Value = sDescription
                cmdAddevent.AddInParameter("@old_party_type_id", SqlDbType.Int).Value = 0
                cmdAddevent.AddInParameter("@event_log_subject_id", SqlDbType.Int).Value = IIf(oAddEventRequest.EventLogSubjectKey = 0, SqlInt32.Null, oAddEventRequest.EventLogSubjectKey)
                cmdAddevent.AddInParameter("@event_type_code", SqlDbType.VarChar, 10).Value = System.DBNull.Value
                cmdAddevent.AddInParameter("@account_key", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@fsa_complaint_folder_cnt", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@short_description", SqlDbType.VarChar, 70).Value = System.DBNull.Value
                cmdAddevent.AddInParameter("@priority_code", SqlDbType.VarChar, 10).Value = oAddEventRequest.Priority
                cmdAddevent.AddInParameter("@is_completed", SqlDbType.SmallInt).Value = Convert.ToInt16(oAddEventRequest.StatusKey)
                cmdAddevent.AddInParameter("@peril_id", SqlDbType.Int).Value = SqlInt32.Null
                cmdAddevent.AddInParameter("@rtf_Text", SqlDbType.NText).Value = "{\rtf1\ansi\ansicpg1252\deff0\deflang1033{\fonttbl{\f0\fnil\fcharset0 Verdana;}}\viewkind4\uc1\pard\f0\fs17\par }"
                cmdAddevent.AddInParameter("@is_manual_description", SqlDbType.TinyInt).Value = IIf(oAddEventRequest.IsManualDescription = False, 0, 1)
                cmdAddevent.AddInParameter("@Document_Path", SqlDbType.VarChar, 255).Value = oAddEventRequest.Document_Path
                conAddevent.ExecuteNonQuery(cmdAddevent)
                oAddEventResponse.EventKey = Cast.ToInt32(cmdAddevent.Parameters.Item("@event_cnt").Value, 0)
            End Using

            Try
                conAddevent.BeginTransaction()
                Dim sUserDate As String
                sUserDate = "[" + oAddEventRequest.UserName + " " + "-" + " " + Convert.ToString(oAddEventRequest.EventDate) + "]"
                Using cmdPublicText As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Party_Public_Text_add")
                    cmdPublicText.AddInParameter("@party_cnt", SqlDbType.Int).Value = oAddEventRequest.PartyKey
                    cmdPublicText.AddInParameter("@text_line", SqlDbType.VarChar, 255).Value = sUserDate
                    cmdPublicText.AddOutParameter("party_public_text_id", SqlDbType.Int)
                    conAddevent.ExecuteNonQuery(cmdPublicText)
                End Using
                Using cmdPublicTextDesc As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Party_Public_Text_add")
                    cmdPublicTextDesc.AddInParameter("@party_cnt", SqlDbType.Int).Value = oAddEventRequest.PartyKey
                    cmdPublicTextDesc.AddInParameter("@text_line", SqlDbType.VarChar, 255).Value = oAddEventRequest.RtfText
                    cmdPublicTextDesc.AddOutParameter("party_public_text_id", SqlDbType.Int)
                    conAddevent.ExecuteNonQuery(cmdPublicTextDesc)
                End Using

                conAddevent.CommitTransaction()
            Catch ex As Exception
                conAddevent.RollbackTransaction()
            End Try
        End Using

        Return oAddEventResponse
    End Function

