        Dim STSError As New STSErrorPublisher
        Dim iProductID As Int32 = 0
        Dim dsFindCase As DataSet = Nothing
        Dim oGISSearchDataArray As Object = Nothing
        Dim oResultSet As Object = Nothing

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.CaseLinkUnLinkRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.CaseLinkUnLinkResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        Dim oSAMErrorCollection As New SAMErrorCollection

        '*******************
        ' STRUCTURE VALIDATION
        '*******************
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        oSAMErrorCollection.CheckForErrors()

        '*******************
        ' DATA VALIDATION
        '*******************
        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        Else
            oRequest.SourceId = 1
        End If

        oSAMErrorCollection.CheckForErrors()

        Try
            Dim dsGetCaseClaimLink As DataSet
            If oRequest.BaseCaseKey <> 0 AndAlso oRequest.ClaimKey <> 0 Then
                If oRequest.IsLinked Then
                    'Unlink the claim
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Case_Update_Claim_CaseLink")
                        cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
                        cmd.AddInParameter("@base_case_id", SqlDbType.Int).Value = System.DBNull.Value
                        con.ExecuteNonQuery(cmd)
                    End Using
                Else
                    'Check the claim whether it is attached to any other case or not
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Case_Claim_Details")
                        cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
                        dsGetCaseClaimLink = con.ExecuteDataSet(cmd, "LinkedClaims")
                    End Using
                    If dsGetCaseClaimLink IsNot Nothing Then
                        If dsGetCaseClaimLink.Tables(0).Rows.Count > 0 Then
                            If IsDBNull(dsGetCaseClaimLink.Tables(0).Rows(0).Item("base_case_id")) Then
                                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Case_Update_Claim_CaseLink")
                                    cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
                                    cmd.AddInParameter("@base_case_id", SqlDbType.Int).Value = oRequest.BaseCaseKey
                                    con.ExecuteNonQuery(cmd)
                                End Using
                            Else
                                AddWarning(oResponse.Warnings,
                                            SAMBusinessWarnings.ClaimIsAlreadyLinkedToOneCase,
                                            "The claim you have selected is already linked to Case Number:" & dsGetCaseClaimLink.Tables(0).Rows(0).Item("case_number").ToString & " A Claim can only be linked to one case")
                            End If
                        End If
                    End If
                End If
            End If

        Catch ex As Exception
            Throw
        Finally
            ''TODO : Dispose COM objects
        End Try

        Return oResponse

    End Function
