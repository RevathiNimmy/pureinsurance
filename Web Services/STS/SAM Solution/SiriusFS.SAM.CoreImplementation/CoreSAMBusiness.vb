    '''<summary>
    ''' This method is used to select a policy for renewal 
    '''</summary>
    '''<param name="conRenewalSelection" type="SiriusConnection"></param>
    '''<param name="oRunRenewalSelectionByPolicyRequest" type="BaseRunRenewalSelectionByPolicyRequestType"></param>   
    '''<returns>BaseRunRenewalSelectionByPolicyResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function RunRenewalSelectionByPolicy(ByVal conRenewalSelection As SiriusConnection, ByVal oRunRenewalSelectionByPolicyRequest As BaseRunRenewalSelectionByPolicyRequestType) As BaseRunRenewalSelectionByPolicyResponseType
        Dim oCoreBusiness As CoreBusiness
        Dim SiriusUser As New SIRIUSUSER
        SiriusUser.UserID = Convert.ToInt16(oRunRenewalSelectionByPolicyRequest.CreatedById)
        If oRunRenewalSelectionByPolicyRequest.CreatedById = 0 Then
            oCoreBusiness = New CoreBusiness
        Else
            oCoreBusiness = New CoreBusiness(SiriusUser)
        End If
        Dim iReturn As Integer = 0
        Dim oErrors As New SAMErrorCollection
        Dim oResponse As New BaseRunRenewalSelectionByPolicyResponseType
        Dim sFailureReason As String = ""

        'Deviation from Tech spec: creating a local timestamp vairable to set lock on InsuranceFolderKey. Rahul told that this is needed since the calling code 
        'may not be able to provide timestamp in the request.
        Dim r_aQuoteTimeStamp() As Byte = Nothing
        Dim r_lInsuranceFolderKey As Integer

        Dim nTypeofPackage As enumTypeOfPackage

        If oRunRenewalSelectionByPolicyRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.RunRenewalSelectionByPolicyRequestType) Then
            nTypeofPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.RunRenewalSelectionByPolicyResponseType
        Else
            nTypeofPackage = enumTypeOfPackage.UnknownPackage
            oResponse = New BaseRunRenewalSelectionByPolicyResponseType
        End If

        'Check Mandatory Field
        oRunRenewalSelectionByPolicyRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        'Look up validation
        Dim iSourceId As Integer
        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRunRenewalSelectionByPolicyRequest.BranchCode, "BranchCode", oErrors)
        oErrors.CheckForErrors()

        'Check insurance file key for validity
        If Not oCoreBusiness.CheckInsuranceFile(conRenewalSelection, oRunRenewalSelectionByPolicyRequest.InsuranceFileKey, r_lInsuranceFolderKey) Then
            oErrors.AddInvalidData(SAMConstants.SAMInvalidData.InvalidLookupListValue,
                            SAMConstants.SAMInvalidData.InvalidLookupListValue.ToString,
                                 "InsuranceFileKey")
        End If

        Dim obSIRRenewalSelection As bSIRRenSelection.BusinessNET = Nothing

        ' Get a timestamp on Insurance Folder Key
        Dim o_bLocked As Boolean
        oCoreBusiness.GetSAMTimestamp(
                                       Con:=conRenewalSelection,
                                       BranchCode:=oRunRenewalSelectionByPolicyRequest.BranchCode,
                                       Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                                       LockValue:=r_lInsuranceFolderKey,
                                       TStamp:=r_aQuoteTimeStamp,
                                       bCurrentlyLocked:=o_bLocked)

        ' Check the method call succeeded
        If o_bLocked Then

            oErrors.AddBusinessRule(SAMBusinessErrors.RecordLockedByAnotherUser,
                                    "The policy is already locked by another user.")
            oErrors.CheckForErrors()
        End If

        ' Check that the timestamp matches and put lock on the given InsuranceFolderKey
        oCoreBusiness.CheckSAMTSAndLock(Con:=conRenewalSelection,
                                        BranchCode:=oRunRenewalSelectionByPolicyRequest.BranchCode,
                                        Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                                        LockValue:=r_lInsuranceFolderKey,
                                        TStamp:=r_aQuoteTimeStamp)

        Try
            obSIRRenewalSelection = CType(CreateAndInitialiseRenewalSelectionNET(conRenewalSelection,
                                          oRunRenewalSelectionByPolicyRequest.BranchCode), bSIRRenSelection.BusinessNET)
            If Not oRunRenewalSelectionByPolicyRequest Is Nothing AndAlso oRunRenewalSelectionByPolicyRequest.SkipGenerateRenewalPolicyNumber Then
                obSIRRenewalSelection.SkipGenerateRenewalPolicyNumber = oRunRenewalSelectionByPolicyRequest.SkipGenerateRenewalPolicyNumber
            End If
            obSIRRenewalSelection.SetProcessModes(vTask:=SAMComponentAction.PMEdit)

            'Deviation from tech spec: obSIRRenewalSelection.ProcessRenewalSelection method's parameters have changed in latest version and the 
            'parameters specified in tech spec no longer exist.
            iReturn = obSIRRenewalSelection.ProcessRenewalSelection(v_lInsuranceFileCnt:=oRunRenewalSelectionByPolicyRequest.InsuranceFileKey,
                                                                    r_lNewInsuranceFileCnt:=oResponse.RenewalInsuranceFileKey, v_bIgnoreDate:=True,
                                                                    v_iDoNotCopyRisk:=oRunRenewalSelectionByPolicyRequest.DoNotCopyRiskAtRenSelection,
                                                                    r_sFailureReason:=sFailureReason)

            If iReturn <> PMEReturnCode.PMTrue Then
                RaiseComMethodException("bSIRRenSelection.Business.ProcessRenewalSelection Failed", iReturn)
            End If

            If Not (String.IsNullOrEmpty(sFailureReason)) Then
                oErrors.AddBusinessRule(SAMBusinessErrors.NoPolicyVersionFoundOrAlreadyRenewed,
                sFailureReason)
                oErrors.CheckForErrors()
            End If

            UpdateInsuranceFileSystem(conRenewalSelection, oRunRenewalSelectionByPolicyRequest.CreatedById, oResponse.RenewalInsuranceFileKey, "REN", True, oRunRenewalSelectionByPolicyRequest.Regarding)

            If oRunRenewalSelectionByPolicyRequest.SetRenewalInviteAsSent = True Then
                Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
                    Using Cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Renewal_Status_Invite_Printed_upd")
                        Cmd.AddInParameter("@renewal_insurance_file_cnt", SqlDbType.Int).Value = oResponse.RenewalInsuranceFileKey
                        con.ExecuteNonQuery(Cmd)
                    End Using
                End Using
            End If

            iReturn = obSIRRenewalSelection.GetRenewalQuoteRef(oResponse.RenewalInsuranceFileKey, oResponse.RenewalInsuranceQuoteRef)

            If iReturn <> PMEReturnCode.PMTrue Then
                RaiseComMethodException("bSIRRenSelection.Business.ProcessRenewalSelection Failed", iReturn)
            End If
        Finally
            If obSIRRenewalSelection IsNot Nothing Then
                obSIRRenewalSelection.Dispose()
                obSIRRenewalSelection = Nothing
            End If
            ' Unlock the lock on insurance folder key
            oCoreBusiness.UnlockAndGetSAMTS(
                                            Con:=conRenewalSelection,
                                            BranchCode:=oRunRenewalSelectionByPolicyRequest.BranchCode,
                                            Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                                            LockValue:=r_lInsuranceFolderKey,
                                            TStamp:=oResponse.QuoteTimeStamp)
        End Try

        Return oResponse
    End Function

