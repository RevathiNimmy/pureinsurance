            Dim oResponse As BaseGetWorkManagerScheduledTasksResponseType

            oResponse = GetWorkManagerScheduledTasks(con, oGetWorkManagerScheduledTasksRequest)

            Return oResponse

        End Using

    End Function

    Public Function GetDate(ByVal strDate As String) As DateTime
        Dim selectedDate As DateTime
        Select Case strDate
            Case "AllDates"
                selectedDate = Date.MinValue
            Case "Today"
                selectedDate = Date.Today
            Case "Tomorrow"
                selectedDate = Date.Today.AddDays(1)
            Case "Next2Days"
                selectedDate = Date.Today.AddDays(2)
            Case "Next3Days"
                selectedDate = Date.Today.AddDays(3)
            Case "Next4Days"
                selectedDate = Date.Today.AddDays(4)
            Case "Next5Days"
                selectedDate = Date.Today.AddDays(5)
            Case "Next6Days"
                selectedDate = Date.Today.AddDays(6)
            Case "Next7Days"
                selectedDate = Date.Today.AddDays(7)
            Case "Next14Days"
                selectedDate = Date.Today.AddDays(14)
            Case "Next28Days"
                selectedDate = Date.Today.AddDays(28)
        End Select
        Return selectedDate

    End Function
    Public Overloads Function GetWorkManagerScheduledTasks(ByVal con As SiriusConnection, ByVal oGetWorkManagerScheduledTasksRequest As BaseGetWorkManagerScheduledTasksRequestType) As BaseGetWorkManagerScheduledTasksResponseType
        Dim oGetWorkManagerScheduledTasksResponse As New BaseGetWorkManagerScheduledTasksResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim selectedDate As Date = GetDate(oGetWorkManagerScheduledTasksRequest.Date.ToString()) 'Dim oSAMErrorCollection As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage
        If oGetWorkManagerScheduledTasksRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetWorkManagerScheduledTasksRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetWorkManagerScheduledTasksResponse = New SAMForInsuranceV2ImplementationTypes.GetWorkManagerScheduledTasksResponseType
        End If

        ' Check mandatory fields

        If String.IsNullOrEmpty(oGetWorkManagerScheduledTasksRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If
        oErrors.CheckForErrors()

        Dim iShowSystemKey As Int32
        Dim dtDate As DateTime
        Dim iTaskStatusKey As Int32
        If (oGetWorkManagerScheduledTasksRequest.ShowSystemKEYSpecified = True) Then
            iShowSystemKey = oGetWorkManagerScheduledTasksRequest.ShowSystemKEY
        Else
            iShowSystemKey = ShowType.All
        End If

        If (oGetWorkManagerScheduledTasksRequest.DateSpecified = True) Then
            dtDate = selectedDate
        Else
            dtDate = Date.MinValue
        End If

        If (oGetWorkManagerScheduledTasksRequest.TaskStatusKeySpecified = True) Then
            iTaskStatusKey = oGetWorkManagerScheduledTasksRequest.TaskStatusKey
        Else
            iTaskStatusKey = TaskStatus.All
        End If

        Dim lUserGroupId As Integer
        Dim lUserId As Integer

        'Get UserGroupId
        If oGetWorkManagerScheduledTasksRequest.UserGroupCODE <> "(All Group)" Then
            lUserGroupId = oCoreBusiness.GetAndValidateListItemFromCode(CType(STSListType.PMLookup, Core.STSListType), "pmuser_group", oGetWorkManagerScheduledTasksRequest.UserGroupCODE, "AllocationUserGroup", oErrors)
        Else
            lUserGroupId = -1
        End If
        'Get UserId
        lUserId = GetUserId(con, oGetWorkManagerScheduledTasksRequest.UserCODE)

        If oGetWorkManagerScheduledTasksRequest.TaskStatusKey < 0 And oGetWorkManagerScheduledTasksRequest.TaskStatusKey > 4 Then
            oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "TaskStatus")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsAllGroups As DataSet = Nothing
        Dim dsGroupsByUser As DataSet = Nothing
        Dim dsGroups As New DataSet
        Dim sProcName As String

        If lUserId <= 0 Then
            If lUserGroupId <= 0 Then
                sProcName = "spu_pmuser_groups_all_sel"
            Else
                sProcName = "spu_pmuser_users_groups_sel"
            End If
        Else
            sProcName = "spu_pmuser_groups_all_sel"
        End If

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure(sProcName)
            If lUserId <= 0 AndAlso lUserGroupId >= 0 Then
                cmd.AddInParameter("@user_id", SqlDbType.Int).Value = _SiriusUser.UserID
            End If
            If Date.MinValue <> selectedDate Then
                cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = selectedDate
            Else
                cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = Date.Today
            End If

            cmd.AddInParameter("@language_id", SqlDbType.Int).Value = _SiriusUser.LanguageID
            dsAllGroups = con.ExecuteDataSet(cmd, "AllGroups")
        End Using

        If lUserId > -1 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_pmuser_users_groups_sel")
                cmd.AddInParameter("@user_id", SqlDbType.Int).Value = lUserId
                If Date.MinValue <> selectedDate Then
                    cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = selectedDate
                Else
                    cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = Date.Today
                End If
                'cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = selectedDate 'oGetWorkManagerScheduledTasksRequest.Date
                cmd.AddInParameter("@language_id", SqlDbType.Int).Value = _SiriusUser.LanguageID
                dsGroupsByUser = con.ExecuteDataSet(cmd, "GroupsByUser")
            End Using
        End If
        'This is  a loop and fill the dataset dsGroups with the groups who are matching in dsAllGroups and dsGroupsByUser and matching has to be done on GroupCODE
        If lUserId <> 0 Then

            If dsGroupsByUser Is Nothing Then

                Throw New Exception("User:" & oGetWorkManagerScheduledTasksRequest.UserCODE & "is not a Member of any Usergroup")
            Else
                Dim tbGroups As New DataTable
                Dim tc As DataColumn = New DataColumn()
                tc.DataType = System.Type.GetType("System.Int32")
                tc.ColumnName = "CODE"
                dsGroups.Tables.Add(tbGroups)
                dsGroups.Tables(0).Columns.Add(tc)
                For icntGroups As Integer = 0 To dsAllGroups.Tables(0).Rows.Count - 1
                    For icntUsers As Integer = 0 To dsGroupsByUser.Tables(0).Rows.Count - 1
                        If dsAllGroups.Tables(0).Rows(icntGroups)("CODE").ToString() = dsGroupsByUser.Tables(0).Rows(icntUsers)("CODE").ToString() Then
                            Dim tr As System.Data.DataRow
                            tr = dsGroups.Tables(0).NewRow()
                            tr(0) = dsAllGroups.Tables(0).Rows(icntGroups)(0)
                            dsGroups.Tables(0).Rows.Add(tr)
                            Exit For
                        End If
                    Next
                Next
            End If

        End If
        If dsGroups.Tables.Count <= 0 Then
            dsGroups.Merge(dsAllGroups, True)
        End If

        Dim dsTasks As New DataSet()
        Dim bCurrentOmitCompleted As Boolean = False
        If oGetWorkManagerScheduledTasksRequest.TaskStatusKey = TaskStatus.NotComplete Then
            bCurrentOmitCompleted = True

        End If

        If oGetWorkManagerScheduledTasksRequest.ReferenceNumber IsNot Nothing AndAlso oGetWorkManagerScheduledTasksRequest.ReferenceNumber.Trim.Length > 0 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Scheduled_Tasks")
                cmd.AddInParameter("@user_id", SqlDbType.BigInt).Value = _SiriusUser.UserID
                cmd.AddInParameter("@task_status", SqlDbType.BigInt).Value = DBNull.Value
                cmd.AddInParameter("@omit_task_status", SqlDbType.Bit).Value = DBNull.Value
                cmd.AddInParameter("@pmuser_group_id", SqlDbType.BigInt).Value = DBNull.Value
                cmd.AddInParameter("@selected_user_id", SqlDbType.BigInt).Value = DBNull.Value

                If oGetWorkManagerScheduledTasksRequest.DateSpecified And Date.MinValue <> selectedDate Then
                    cmd.AddInParameter("@task_due_date_limit", SqlDbType.DateTime).Value = selectedDate.AddHours(23).AddMinutes(59).AddSeconds(59)
                Else
                    cmd.AddInParameter("@task_due_date_limit", SqlDbType.DateTime).Value = DBNull.Value
                End If
                Dim sUsergroups As String
                sUsergroups = String.Empty
                ' for each table ( there will be only one )
                For Each dt As DataTable In dsGroups.Tables
                    ' for each row 
                    For Each dr As DataRow In dt.Rows
                        sUsergroups = sUsergroups & dr.Item(0).ToString() & "|"
                    Next
                Next
                If sUsergroups.Length > 0 Then
                    cmd.AddInParameter("@pmuser_group_string", SqlDbType.VarChar, 1000).Value = sUsergroups
                Else
                    cmd.AddInParameter("@pmuser_group_string", SqlDbType.VarChar, 1000).Value = DBNull.Value
                End If

                cmd.AddInParameter("@is_system_task", SqlDbType.Bit).Value = DBNull.Value
                cmd.AddInParameter("@source_id", SqlDbType.Int).Value = DBNull.Value
                cmd.AddInParameter("@RestrictTaskList", SqlDbType.Int).Value = DBNull.Value
                cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = DBNull.Value
                cmd.AddInParameter("@ReferenceNumber", SqlDbType.VarChar, 30).Value = oGetWorkManagerScheduledTasksRequest.ReferenceNumber

                con.ExecuteDataSet(cmd, dsTasks, "Tasks")
            End Using


        Else
            If oGetWorkManagerScheduledTasksRequest.ShowSystemKEY <> 1 Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Scheduled_Tasks")
                    cmd.AddInParameter("@user_id", SqlDbType.BigInt).Value = _SiriusUser.UserID

                    'For task staus New, Complete, InComplete and InProgress
                    If oGetWorkManagerScheduledTasksRequest.TaskStatusKey < TaskStatus.All Then
                        If oGetWorkManagerScheduledTasksRequest.TaskStatusKeySpecified Then
                            cmd.AddInParameter("@task_status", SqlDbType.BigInt).Value = oGetWorkManagerScheduledTasksRequest.TaskStatusKey
                        Else
                            cmd.AddInParameter("@task_status", SqlDbType.BigInt).Value = SqlInt64.Null
                        End If
                        cmd.AddInParameter("@omit_task_status", SqlDbType.Bit).Value = 0
                    Else
                        ' For Not Complete task status
                        If bCurrentOmitCompleted Then
                            cmd.AddInParameter("@task_status", SqlDbType.BigInt).Value = PMEWrkManTaskStatus.pmeWMTSComplete 'oGetWorkManagerScheduledTasksRequest.TaskStatusKey
                            cmd.AddInParameter("@omit_task_status", SqlDbType.Bit).Value = 1
                        Else
                            cmd.AddInParameter("@task_status", SqlDbType.BigInt).Value = DBNull.Value
                            cmd.AddInParameter("@omit_task_status", SqlDbType.Bit).Value = 0
                        End If
                    End If

                    If lUserGroupId > 0 Then
                        cmd.AddInParameter("@pmuser_group_id", SqlDbType.BigInt).Value = lUserGroupId
                    Else
                        cmd.AddInParameter("@pmuser_group_id", SqlDbType.BigInt).Value = DBNull.Value
                    End If

                    If lUserId > 0 Then
                        cmd.AddInParameter("@selected_user_id", SqlDbType.BigInt).Value = lUserId
                    Else
                        cmd.AddInParameter("@selected_user_id", SqlDbType.BigInt).Value = DBNull.Value
                    End If

                    If oGetWorkManagerScheduledTasksRequest.DateSpecified And Date.MinValue <> selectedDate Then
                        cmd.AddInParameter("@task_due_date_limit", SqlDbType.DateTime).Value = selectedDate.AddHours(23).AddMinutes(59).AddSeconds(59) 'oGetWorkManagerScheduledTasksRequest.Date
                    Else
                        cmd.AddInParameter("@task_due_date_limit", SqlDbType.DateTime).Value = DBNull.Value
                    End If

                    Dim sUsergroups As String
                    If oGetWorkManagerScheduledTasksRequest.ShowSystemKEY = 0 Or oGetWorkManagerScheduledTasksRequest.ShowSystemKEY = ShowType.All Then
                        sUsergroups = String.Empty
                        ' for each table ( there will be only one )
                        For Each dt As DataTable In dsGroups.Tables
                            ' for each row 
                            For Each dr As DataRow In dt.Rows
                                sUsergroups = sUsergroups & dr.Item(0).ToString() & "|"
                            Next
                        Next
                        cmd.AddInParameter("@pmuser_group_string", SqlDbType.VarChar, 1000).Value = sUsergroups

                    Else
                        cmd.AddInParameter("@pmuser_group_string", SqlDbType.VarChar, 1000).Value = DBNull.Value

                    End If
                    cmd.AddInParameter("@is_system_task", SqlDbType.Bit).Value = 0
                    If oGetWorkManagerScheduledTasksRequest.PartyKey > 0 Then
                        cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oGetWorkManagerScheduledTasksRequest.PartyKey
                    End If
                    If oGetWorkManagerScheduledTasksRequest.ReferenceNumber IsNot Nothing Then
                        cmd.AddInParameter("@ReferenceNumber", SqlDbType.VarChar, 30).Value = oGetWorkManagerScheduledTasksRequest.ReferenceNumber
                    End If
                    con.ExecuteDataSet(cmd, dsTasks, "Tasks")
                End Using
            End If

            If IsUserAdministrator(oGetWorkManagerScheduledTasksRequest, lUserId) Then

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Scheduled_Tasks")

                    cmd.AddInParameter("@user_id", SqlDbType.BigInt).Value = DBNull.Value
                    cmd.AddInParameter("@task_status", SqlDbType.BigInt).Value = DBNull.Value
                    cmd.AddInParameter("@omit_task_status", SqlDbType.Bit).Value = DBNull.Value
                    cmd.AddInParameter("@pmuser_group_id", SqlDbType.BigInt).Value = DBNull.Value
                    cmd.AddInParameter("@selected_user_id", SqlDbType.BigInt).Value = DBNull.Value

                    If oGetWorkManagerScheduledTasksRequest.DateSpecified And Date.MinValue <> selectedDate Then
                        cmd.AddInParameter("@task_due_date_limit", SqlDbType.DateTime).Value = selectedDate.AddHours(23).AddMinutes(59).AddSeconds(59)
                    Else
                        cmd.AddInParameter("@task_due_date_limit", SqlDbType.DateTime).Value = DBNull.Value
                    End If

                    cmd.AddInParameter("@pmuser_group_string", SqlDbType.VarChar, 1000).Value = DBNull.Value
                    cmd.AddInParameter("@is_system_task", SqlDbType.Bit).Value = 1
                    cmd.AddInParameter("@source_id", SqlDbType.Int).Value = DBNull.Value
                    cmd.AddInParameter("@RestrictTaskList", SqlDbType.Int).Value = DBNull.Value
                    If oGetWorkManagerScheduledTasksRequest.PartyKey > 0 Then
                        cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oGetWorkManagerScheduledTasksRequest.PartyKey
                    End If
                    If oGetWorkManagerScheduledTasksRequest.ReferenceNumber IsNot Nothing Then
                        cmd.AddInParameter("@ReferenceNumber", SqlDbType.VarChar, 30).Value = oGetWorkManagerScheduledTasksRequest.ReferenceNumber
                    End If
                    con.ExecuteDataSet(cmd, dsTasks, "Tasks")
                End Using
            End If

        End If
        If dsTasks.Tables IsNot Nothing AndAlso dsTasks.Tables.Count > 0 Then
            Dim dsFilter As DataSet = Nothing
            dsFilter = New DataSet
            With dsTasks.Tables(0)
                dsFilter.Tables.Add()
                dsFilter.Tables(0).Columns.Add("Urgent", GetType(System.Int16))
                dsFilter.Tables(0).Columns.Add("TaskStatusKey", GetType(System.Int16))
                dsFilter.Tables(0).Columns.Add("Type", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("DueDate", GetType(System.DateTime))
                dsFilter.Tables(0).Columns.Add("Customer", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("Branch", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("Description", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("UserGroupKey", GetType(System.Int16))
                dsFilter.Tables(0).Columns.Add("UserKey", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("TaskInstanceKey", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("UserCode", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("UserGroupDescription", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("UserGroupCode", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("TaskGroupKey", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("TaskKey", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("PartyCnt", GetType(System.Int32))
                dsFilter.Tables(0).Columns.Add("PartyName", GetType(System.String))
                dsFilter.Tables(0).Columns.Add("InsuranceFolderKey", GetType(System.Int32))
            End With
            Dim iCount As Integer
            For iCount = 0 To dsTasks.Tables(0).Rows.Count - 1
                dsFilter.Tables(0).Rows.Add()
                dsFilter.Tables(0).Rows(iCount)("Urgent") = Cast.ToInt16(dsTasks.Tables(0).Rows(iCount).Item("is_urgent"), 0)
                dsFilter.Tables(0).Rows(iCount)("TaskStatusKey") = Cast.ToInt16(dsTasks.Tables(0).Rows(iCount).Item("task_status"), 0)
                dsFilter.Tables(0).Rows(iCount)("Type") = dsTasks.Tables(0).Rows(iCount).Item("type_of_task").ToString
                dsFilter.Tables(0).Rows(iCount)("DueDate") = Cast.ToDateTime(dsTasks.Tables(0).Rows(iCount).Item("task_due_date"), Date.Now)
                dsFilter.Tables(0).Rows(iCount)("Customer") = Cast.ToString(dsTasks.Tables(0).Rows(iCount).Item("customer"), String.Empty)
                dsFilter.Tables(0).Rows(iCount)("Branch") = Cast.ToString(dsTasks.Tables(0).Rows(iCount).Item("Branch"), String.Empty)
                dsFilter.Tables(0).Rows(iCount)("Description") = Cast.ToString(dsTasks.Tables(0).Rows(iCount).Item("description"), String.Empty)
                dsFilter.Tables(0).Rows(iCount)("UserGroupKey") = Cast.ToInt16(dsTasks.Tables(0).Rows(iCount).Item("pmuser_group_id"), 0)
                dsFilter.Tables(0).Rows(iCount)("UserKey") = Cast.ToInt32(dsTasks.Tables(0).Rows(iCount).Item("user_id"), 0)
                dsFilter.Tables(0).Rows(iCount)("TaskInstanceKey") = Cast.ToInt32(dsTasks.Tables(0).Rows(iCount).Item("pmwrk_task_instance_cnt"), 0)
                dsFilter.Tables(0).Rows(iCount)("UserCode") = Cast.ToString(dsTasks.Tables(0).Rows(iCount).Item("UserDescription"), String.Empty)
                dsFilter.Tables(0).Rows(iCount)("UserGroupDescription") = Cast.ToString(dsTasks.Tables(0).Rows(iCount).Item("UserGroupDescription"), String.Empty)
                dsFilter.Tables(0).Rows(iCount)("UserGroupCode") = Cast.ToString(dsTasks.Tables(0).Rows(iCount).Item("UserGroupCode"), String.Empty)
                dsFilter.Tables(0).Rows(iCount)("TaskGroupKey") = Cast.ToInt32(dsTasks.Tables(0).Rows(iCount).Item("TaskGroupKey"), 0)
                dsFilter.Tables(0).Rows(iCount)("TaskKey") = Cast.ToInt32(dsTasks.Tables(0).Rows(iCount).Item("TaskKey"), 0)
                dsFilter.Tables(0).Rows(iCount)("PartyCnt") = Cast.ToInt32(dsTasks.Tables(0).Rows(iCount).Item("PartyCnt"), 0)
                dsFilter.Tables(0).Rows(iCount)("PartyName") = dsTasks.Tables(0).Rows(iCount).Item("PartyName").ToString()
                dsFilter.Tables(0).Rows(iCount)("InsuranceFolderKey") = Cast.ToInt32(dsTasks.Tables(0).Rows(iCount).Item("InsuranceFolderKey"), 0)
            Next
            If (dsFilter.Tables.Count > 0) Then

                If (dsFilter.Tables(0).Rows.Count > 0) Then

                    Dim xmlDoc As New System.Xml.XmlDocument

                    dsFilter.DataSetName = "BaseGetWorkManagerScheduledTasksResponseTypeTasks"
                    dsFilter.Tables(0).TableName = "Row"

                    If oGetWorkManagerScheduledTasksRequest.WCFSecurityToken = "" Then
                        xmlDoc.LoadXml(dsFilter.GetXml)
                        If (dsFilter.Tables.Count >= 1) Then
                            oGetWorkManagerScheduledTasksResponse.ResultDataset = xmlDoc.DocumentElement()
                        End If
                    End If

                    If (dsFilter.Tables.Count >= 1) Then
                        oGetWorkManagerScheduledTasksResponse.ResultData = dsFilter
                    End If
                End If
            End If
        End If
        Return oGetWorkManagerScheduledTasksResponse

    End Function

    ''' <summary>
    '''IsUserAdministrator is core sam method for Work manager Get Task
    '''</summary>
    '''<param name="GetWorkManagerScheduledTasksRequest" type="BaseGetWorkManagerScheduledTasksRequestType"></param>   
    '''<remarks></remarks>
    Public Function IsUserAdministrator(ByVal oGetWorkManagerScheduledTasksRequest As BaseGetWorkManagerScheduledTasksRequestType, ByVal lUserId As Integer) As Boolean
        Dim dsCount As DataSet = Nothing
        Dim iCount As Integer
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                                    _SiriusUser.Username, _SiriusUser.SourceID,
                                                    _SiriusUser.LanguageID,
                                                    SiriusUserDefaults.AppName)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_pmuser_is_sysadmin")
                cmd.AddInParameter("@user_id", SqlDbType.Int).Value = lUserId
                cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = Now

                dsCount = con.ExecuteDataSet(cmd, "Count")
                If dsCount.Tables("Count").Rows.Count > 0 Then
                    iCount = CInt(dsCount.Tables("Count").Rows(0)(0).ToString())
                End If

                If iCount > 0 Then
                    IsUserAdministrator = True
                Else
                    IsUserAdministrator = False
                End If

            End Using
        End Using
    End Function

