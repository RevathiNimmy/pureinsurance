    Private Function GetTemplateCodesForRenewal(ByVal v_lInsurance_FileCnt As Long,
                                                ByVal v_lProcessType_Docs_ID As Long,
                                                ByVal v_lprocess_Type_code As String,
                                                Optional ByRef con As SiriusConnection = Nothing) As String

        Dim ACMethodName As String = "GetTemplateCodesForRenewal"
        Dim iRet As Integer
        Dim obPMBDocLink As bPMBDocLink.Business = Nothing
        Dim oDatabase As dPMDAO.Database = Nothing
        Dim oDatabaseObject As Object = oDatabase
        Dim vResultArray(,) As Object = Nothing
        Dim vDocNameArray As Object(,)
        Dim sProcessTypeDoc As String = "RN"
        Try
            obPMBDocLink = New bPMBDocLink.Business
        Catch ex As Exception
            Dim STSError2 As New STSErrorPublisher(iRet, "Failed to initialise bPMBDocLink")
            STSError2.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bPMBDocLinkInitialise", True)
        End Try

        Try
            If con IsNot Nothing Then
                oDatabaseObject = con.PMDAODatabase
            End If
            iRet = CInt(obPMBDocLink.Initialise(sUsername:=_SiriusUser.Username,
                                   sPassword:=_SiriusUser.Password,
                                   iUserID:=_SiriusUser.UserID,
                                   iSourceID:=_SiriusUser.SourceID,
                                   iLanguageID:=_SiriusUser.LanguageID,
                                   iCurrencyID:=_SiriusUser.CurrencyID,
                                   iLogLevel:=SiriusUserDefaults.LogLevel,
                                   sCallingAppName:=ACMethodName,
                                   vDatabase:=oDatabaseObject))
        Catch ex As Exception
            If obPMBDocLink IsNot Nothing Then
                obPMBDocLink.Dispose()
                obPMBDocLink = Nothing
            End If
            Dim STSError2 As New STSErrorPublisher(iRet, "Failed to initialise bPMBDocLink")
            STSError2.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bPMBDocLinkInitialise", True)
        End Try

        If (iRet <> 1) Then
            If obPMBDocLink IsNot Nothing Then
                obPMBDocLink.Dispose()
                obPMBDocLink = Nothing
            End If
            Dim STSError2 As New STSErrorPublisher(iRet, "Failed to initialise bPMBDocLink")
            STSError2.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bPMBDocLinkInitialise", True)
        End If

        Try
            iRet = obPMBDocLink.GetSFIDocumentTemplatesForProcessType(1, Cast.ToInt32(v_lInsurance_FileCnt, 0), Cast.ToInt32(v_lProcessType_Docs_ID, 0), v_lprocess_Type_code, Now.Date, r_vResultarray:=vResultArray)

        Catch ex As Exception
            If obPMBDocLink IsNot Nothing Then
                obPMBDocLink.Dispose()
                obPMBDocLink = Nothing
            End If
            RaiseComMethodException("bPMBDocLink.Business Failed")
        End Try

        If (iRet <> 1) Then
            If obPMBDocLink IsNot Nothing Then
                obPMBDocLink.Dispose()
                obPMBDocLink = Nothing
            End If
            RaiseComMethodException("bPMBDocLink.Business Failed")
        End If

        Select Case v_lProcessType_Docs_ID
            Case 3
                sProcessTypeDoc = "Debit Note"
            Case 4
                sProcessTypeDoc = "Schedule"
            Case 5
                sProcessTypeDoc = "Certificate"
            Case 6
                sProcessTypeDoc = "Notice"
        End Select

        If IsArray(vResultArray) Then
            vDocNameArray = DirectCast(vResultArray, Object(,))
            GetTemplateCodesForRenewal = vDocNameArray.GetValue(0, 0).ToString
        Else
            ' PN64308 - If we can't find the template the we can still continue without the document.
            GetTemplateCodesForRenewal = "0"
        End If

        Try
            If obPMBDocLink IsNot Nothing Then
                obPMBDocLink.Dispose()
                obPMBDocLink = Nothing
            End If
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to terminate business", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "Terminate", True)
        End Try

    End Function

