    Public Overloads Function RecalculateRIForPortfolioTransfer(ByVal con As SiriusConnection, ByVal oRecalculateRIForPortfolioTransferRequestType As BaseRecalculateRIForPortfolioTransferRequestType) As BaseRecalculateRIForPortfolioTransferResponseType
        Dim nProductID As Integer
        Dim oResponse As New BaseRecalculateRIForPortfolioTransferResponseType

        Dim nReturn As Integer
        Dim dtInceptionDate As Date
        Dim dProRataRate As Double
        Dim nInsuranceFileCnt As Integer
        Dim nIsValid As Integer
        Dim oCoreBusiness As New CoreBusiness
        Dim bIsForAmend As Boolean
        nInsuranceFileCnt = oRecalculateRIForPortfolioTransferRequestType.InsuranceFileKey

        Dim obSIRRIPortfolioTransfer As New bsirriportfoliotransfer.Business

        nReturn = CInt(obSIRRIPortfolioTransfer.Initialise(
                             _SiriusUser.Username,
                             _SiriusUser.Password,
                             _SiriusUser.UserID,
                             _SiriusUser.SourceID,
                             _SiriusUser.LanguageID,
                             _SiriusUser.CurrencyID,
                             1,
                             SiriusUserDefaults.AppName))

        Try

            Dim dsResult As DataSet

            Dim nInsFolderCnt As Integer
            Dim nSourceId As Integer
            oCoreBusiness.CheckInsuranceFile(con, oRecalculateRIForPortfolioTransferRequestType.InsuranceFileKey, nInsFolderCnt, nSourceId)

            'Use the time stamp for record locking purposes
            Dim oAnyError As STSErrorType
            'lock based on InsuranceFolderKey
            oAnyError = oCoreBusiness.CheckTSAndLock(
                BranchCode:=oRecalculateRIForPortfolioTransferRequestType.BranchCode,
                Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                LockValue:=nInsFolderCnt,
                TStamp:=oRecalculateRIForPortfolioTransferRequestType.TimeStamp)

            ' Check for Errors
            If oAnyError Is Nothing = False Then
                ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
                oResponse.STSError = oAnyError
                Return oResponse
            End If

            If oRecalculateRIForPortfolioTransferRequestType.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.RecalculateRIForPortfolioTransferRequestType) Then
                oResponse = New SAMForInsuranceV2ImplementationTypes.RecalculateRIForPortfolioTransferResponseType
            End If

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Ins_File_PT_RI_Usage_sel_amend")
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = nInsuranceFileCnt
                dsResult = con.ExecuteDataSet(cmd, "GetPTRIUsage")
            End Using

            If dsResult IsNot Nothing AndAlso dsResult.Tables.Count > 0 AndAlso dsResult.Tables(0).Rows.Count > 0 Then
                Dim dtCoverStartDate As Date
                Dim dtCoverEndDate As Date
                Dim dtTransferDate As Date
                dtTransferDate = DateTime.Now()
                nProductID = Cast.ToInt32(dsResult.Tables(0).Rows(0).Item("product_id"), 0)
                dtCoverStartDate = Cast.ToDateTime(dsResult.Tables(0).Rows(0).Item("cover_start_date"), Date.MinValue)
                dtCoverEndDate = Cast.ToDateTime(dsResult.Tables(0).Rows(0).Item("expiry_date"), Date.MinValue)
                dtInceptionDate = Cast.ToDateTime(dsResult.Tables(0).Rows(0).Item("inception_date_tpi"), Date.MinValue)
                dtTransferDate = Cast.ToDateTime(dsResult.Tables(0).Rows(0).Item("TransferDate"), Date.MinValue)
                bIsForAmend = True

                nReturn = obSIRRIPortfolioTransfer.GetProRataRate(nProductID:=nProductID, dtOldStartDate:=dtCoverStartDate, dtOldEndDate:=dtCoverEndDate, dtStartDate:=dtTransferDate, dtEndDate:=dtCoverEndDate, o_dProRataRate:=dProRataRate, o_dtInceptionDate:=dtInceptionDate)
                If nReturn <> PMEReturnCode.PMTrue Then
                    RaiseComMethodException("bSIRRIPortfolioTransfer.Business Failed", nReturn)
                End If

                nReturn = obSIRRIPortfolioTransfer.RecalculateRI(nInsuranceFileCnt:=nInsuranceFileCnt, dtTransferDate:=dtTransferDate, dProRataRate:=dProRataRate, nIsPT:=1, r_nIsValid:=nIsValid, bIsForAmend:=bIsForAmend)
                If nReturn <> PMEReturnCode.PMTrue Then
                    RaiseComMethodException("bSIRRIPortfolioTransfer.Business Failed", nReturn)
                End If
            End If

            oAnyError = oCoreBusiness.UnlockAndGetTS(
                       BranchCode:=oRecalculateRIForPortfolioTransferRequestType.BranchCode,
                       Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                       LockValue:=nInsFolderCnt,
                       TStamp:=oResponse.TimeStamp)

            ' Check for Errors
            If oAnyError Is Nothing = False Then
                ' Unable to unlock, return the error.
                oResponse.STSError = oAnyError
                Return oResponse
            End If
        Catch ex As Exception
            RaiseComMethodException("bSIRRIPortfolioTransfer.Business Failed", nReturn)
        Finally
            If obSIRRIPortfolioTransfer IsNot Nothing Then
                obSIRRIPortfolioTransfer.Dispose()
                obSIRRIPortfolioTransfer = Nothing
            End If
        End Try

        Return oResponse

    End Function
