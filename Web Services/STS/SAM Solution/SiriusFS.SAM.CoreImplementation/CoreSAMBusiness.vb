    '''</summary>
    '''<remarks></remarks> 
    Public Overloads Function GetAccountBalanceByAccountCode(ByVal conFP As SiriusConnection, ByVal oGetAccountBalanceByAccountCodeInput As _
                                                                BaseGetAccountBalanceByAccountCodeRequestType) As BaseGetAccountBalanceByAccountCodeResponseType

        Dim oGetAccountBalanceByAccountCodeResponse As New BaseGetAccountBalanceByAccountCodeResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim iSourceId As Integer
        Dim iAccountId As Integer
        Dim dsResult As DataSet = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetAccountBalanceByAccountCodeInput.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetAccountBalanceByAccountCodeRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetAccountBalanceByAccountCodeResponse = New SAMForInsuranceV2ImplementationTypes.GetAccountBalanceByAccountCodeResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        oGetAccountBalanceByAccountCodeInput.Validate(CType(oErrors, Object))
        oErrors.CheckForErrors()

        If Not String.IsNullOrEmpty(oGetAccountBalanceByAccountCodeInput.BranchCode) Then
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oGetAccountBalanceByAccountCodeInput.BranchCode, "BranchCode", oErrors)
        End If

        If Not String.IsNullOrEmpty(oGetAccountBalanceByAccountCodeInput.AccountCode) Then
            iAccountId = GetAndValidateSpecifiedTableCode(conFP, "account",
                    "account_id", "Short_Code", oGetAccountBalanceByAccountCodeInput.AccountCode.ToString(), oErrors, "short_code")
        End If
        oErrors.CheckForErrors()

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Select_AccountBal")
            cmd.AddInParameter("@account_id", SqlDbType.Int).Value = iAccountId
            cmd.AddInParameter("@company_id", SqlDbType.Int).Value = iSourceId
            cmd.AddInParameter("@restrict_to_non_policy_transactions", SqlDbType.Bit).Value = Cast.ToBoolean(oGetAccountBalanceByAccountCodeInput.RestrictToNonPolicyTransactions, False)
            dsResult = conFP.ExecuteDataSet(cmd, "GetAccountBalanceByAccountCode")
        End Using
        If dsResult IsNot Nothing Then
            If dsResult.Tables.Count > 0 Then
                If dsResult.Tables(0).Rows.Count > 0 Then
                    oGetAccountBalanceByAccountCodeResponse.AccountBalance = Cast.ToDouble(dsResult.Tables(0).Rows(0).Item("sum_amount"), 0.0)
                End If
            End If
        End If
        Return oGetAccountBalanceByAccountCodeResponse
    End Function

