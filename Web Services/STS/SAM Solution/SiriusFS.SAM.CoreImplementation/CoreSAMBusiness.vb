            oUpdateArrangementLinesRI2007Response = New SAMForInsuranceV2ImplementationTypes.UpdateArrangementLinesRI2007ResponseType
        Else
            Return Nothing
        End If


        ' Check mandatory fields. Madatory keys depends upon the type of action that we are performing row. Place all the mandatory checks in below function only
        oUpdateArrangementLinesRI2007Request.Validate(CObj(oSAMErrorCollection))

        oSAMErrorCollection.CheckForErrors()

        For Each oReinsurance In oUpdateArrangementLinesRI2007Request.RIArrangementLines
