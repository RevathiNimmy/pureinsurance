    ''' <summary>
    '''This function will pass the request object to the stored proceudre and returns the reponse object
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>  
    '''<param name="o_CreateWmTaskRequest" type="BaseCreateWmTaskRequestType"></param>  
    '''<returns> object of type BaseAttachCoverNoteResponseType </returns>
    '''<remarks></remarks>
    Public Overloads Function CreateWmTask(ByVal con As SiriusConnection, ByVal oCreateWmTaskRequest As BaseCreateWmTaskRequestType) As BaseCreateWmTaskResponseType

        Dim oResponse As BaseCreateWmTaskResponseType

        Dim oSamForBrokingRequest As SAMForBrokingImplementationTypes.CreateWmTaskRequestType = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCorebusiness As New CoreBusiness
        Dim lSourceID As Integer
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim lCurrencyID As Integer
        If oCreateWmTaskRequest.GetType Is GetType(SAMForBrokingImplementationTypes.CreateWmTaskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oResponse = New SAMForBrokingImplementationTypes.CreateWmTaskResponseType
            oSamForBrokingRequest = DirectCast(oCreateWmTaskRequest, SAMForBrokingImplementationTypes.CreateWmTaskRequestType)
        ElseIf oCreateWmTaskRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.CreateWmTaskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.CreateWmTaskResponseType
        ElseIf oCreateWmTaskRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.CreateWmTaskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.CreateWmTaskResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        'Check Mandatory Validation

        oCreateWmTaskRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()


        Dim lTaskGroupId As Integer
        Dim lTaskId As Integer
        Dim lUserGroupId As Integer
        Dim lUserId As Integer
        Dim lTaskStatus As Integer
        Dim lCreatedById As Integer
        Dim lModifiedById As Integer

        ValidateWorkManagerLookup(con, oCreateWmTaskRequest, lTaskGroupId, lTaskId, lUserGroupId, lUserId, oSAMErrorCollection)
        ValidateWorkManagerBusinessRule(oCreateWmTaskRequest, oSAMErrorCollection)

        oSAMErrorCollection.CheckForErrors()

        If nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage Then
            lCreatedById = oSamForBrokingRequest.UserPartyKey
            lModifiedById = oSamForBrokingRequest.UserPartyKey
        ElseIf nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage Or nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package Then
            lCreatedById = oCreateWmTaskRequest.UserId
            lModifiedById = oCreateWmTaskRequest.UserId
        End If

        If oCreateWmTaskRequest.IsComplete Then
            lTaskStatus = PMEWrkManTaskStatus.pmeWMTSComplete
        Else
            lTaskStatus = PMEWrkManTaskStatus.pmeWMTSNew
        End If

        'Start (Vijayakumar Ramasamy) -(Tech Spec - UIIC WR33 - Work Manager - Create Task(Additional Changes).doc)- (7.1.4.5)
        ' load source from specified branch code
        GetSourceDetails(oCreateWmTaskRequest.BranchCode, lSourceID, lCurrencyID)


        'Added IsTaskReview  as a parameter
        Dim lTaskInstanceCnt As Integer
        Dim uExternaleTaskGuid As String = String.Empty
        Dim oa_KeyArray(,) As Object
        Const kKeyNameColPosition As Integer = 0
        Const kKeyValueColPosition As Integer = 1

        If oCreateWmTaskRequest.KeyData IsNot Nothing Then
            ReDim oa_KeyArray(1, oCreateWmTaskRequest.KeyData.Row.Length - 1)
            For iCount As Integer = 0 To oCreateWmTaskRequest.KeyData.Row.Length - 1

                If Not oCreateWmTaskRequest.KeyData.Row(iCount).KeyName Is Nothing _
                  AndAlso CStr(oCreateWmTaskRequest.KeyData.Row(iCount).KeyName) <> "" Then

                    oa_KeyArray(kKeyNameColPosition, iCount) = oCreateWmTaskRequest.KeyData.Row(iCount).KeyName
                    oa_KeyArray(kKeyValueColPosition, iCount) = oCreateWmTaskRequest.KeyData.Row(iCount).KeyValue
                Else
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "KeyName")
                    oSAMErrorCollection.CheckForErrors()
                End If
            Next
        End If

        uExternaleTaskGuid = Trim(oCreateWmTaskRequest.GuidPMExternalItem)

        CreateTaskInstance(con, lTaskInstanceCnt,
                             lTaskGroupId,
                             lTaskId,
                             oCreateWmTaskRequest.Client,
                             oCreateWmTaskRequest.DueDateTime,
                             lUserGroupId,
                             lUserId,
                             oCreateWmTaskRequest.Description,
                             lTaskStatus,
                             Cast.ToInt32(IIf(oCreateWmTaskRequest.IsUrgent, 1, 0), 0),
                             Now,
                             lCreatedById,
                             Now, lModifiedById,
                             1, "",
                             Cast.ToInt32(IIf(oCreateWmTaskRequest.IsTaskReview, 1, 0), 0),
                             lSourceID,
                             oa_KeyArray,
                             oCreateWmTaskRequest.IsExternalItem,
                             uExternaleTaskGuid,
                             oCreateWmTaskRequest.ParentTaskId,
                             oCreateWmTaskRequest.ExternalTaskCategoryCode,
                             oCreateWmTaskRequest.LockName,
                             oCreateWmTaskRequest.LockValue,
                             oCreateWmTaskRequest.ExternalTaskStatus,
                             oCreateWmTaskRequest.IsExternalChildTask)


        oResponse.GuidPMExternalItem = uExternaleTaskGuid
        oResponse.TaskInstanceKey = lTaskInstanceCnt

        Return oResponse

    End Function


