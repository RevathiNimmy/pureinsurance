#Region "Private Method - ProcessAddEditCase"
    ''' <summary>
    '''This function will get the case list from COM funciton "ProcessAddEditCase" if the index is empty
    '''</summary>
    '''<param name="oRequest" type="BaseCaseItemsRequestType"></param>    
    '''<param name="oResponse" type="BaseSaveCaseResponseType"></param>   
    '''<remarks></remarks>
    Private Function ProcessAddCase(ByVal Con As SiriusConnection,
    ByRef oRequest As BaseCaseItemsRequestType,
    ByRef oResponse As BaseSaveCaseResponseType,
    ByRef oBusiness As CoreBusiness,
    ByRef oSAMErrorCollection As SAMErrorCollection) As BaseSaveCaseResponseType

        Try
            'Declare the variable to make sure the initialization
            Dim oGetNumberingSchemeNoRequestType As New BaseGetNumberingSchemeNoRequestType
            Dim oGetNumberingSchemeNoResponseType As New BaseGetNumberingSchemeNoResponseType
            Dim sCaseNumberingSchemeCode As String = String.Empty
            Dim iCaseId As Int32 = 0
            Dim iProgressStatusCodeId As Integer = 0
            Dim iAnalystId As Int32 = 0
            Dim iAssistantId As Int32 = 0
            Dim bGetCaseNumber As Boolean = True
            Dim dsSaveCase As DataSet = Nothing
            Dim iBaseCaseID As Int32 = 0
            ' Convert  code to ID
            If (Not String.IsNullOrEmpty(oRequest.ProgressStatusCode)) Then
                iProgressStatusCodeId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                    PMLookupTable.CaseProgressStatusCode, oRequest.ProgressStatusCode, "ProgressStatusCode", oSAMErrorCollection)
            Else
                iProgressStatusCodeId = 0
            End If
            oSAMErrorCollection.CheckForErrors()

            If (Not String.IsNullOrEmpty(oRequest.Analyst)) Then
                iAnalystId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                    PMLookupTable.Handler, oRequest.Analyst, "Analyst", oSAMErrorCollection)
            Else
                iAnalystId = 0
            End If
            oSAMErrorCollection.CheckForErrors()

            If (Not String.IsNullOrEmpty(oRequest.Assistant)) Then
                iAssistantId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                    PMLookupTable.Handler, oRequest.Assistant, "Assistant", oSAMErrorCollection)
            Else
                iAssistantId = 0
            End If
            oSAMErrorCollection.CheckForErrors()

            With oGetNumberingSchemeNoRequestType
                .SchemeType = NumberingSchemeType.Case
                .SourceId = oRequest.SourceId
            End With

            oGetNumberingSchemeNoResponseType = GetNumberingSchemeNo(Con, oGetNumberingSchemeNoRequestType, True)

            With oGetNumberingSchemeNoResponseType
                If .Errors IsNot Nothing Or .STSError IsNot Nothing Then
                    oResponse.Errors = .Errors
                    oResponse.STSError = .STSError
                    Return oResponse
                End If

                sCaseNumberingSchemeCode = .GeneratedCode
            End With

            If (String.IsNullOrEmpty(sCaseNumberingSchemeCode)) AndAlso (String.IsNullOrEmpty(oRequest.CaseNumber)) Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "CaseNumber")
            End If
            oSAMErrorCollection.CheckForErrors()

            '' Add Case
            With oRequest
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Case_Add")
                    cmd.AddInParameter("@Case_ID", SqlDbType.Int).Value = oRequest.CaseKey
                    If (String.IsNullOrEmpty(oRequest.CaseNumber)) Then
                        cmd.AddInParameter("@case_number", SqlDbType.VarChar).Value = Cast.ToString(sCaseNumberingSchemeCode)
                    Else
                        cmd.AddInParameter("@case_number", SqlDbType.VarChar).Value = Cast.ToString(.CaseNumber)
                    End If
                    cmd.AddInParameter("@case_opened_date", SqlDbType.DateTime).Value = CDate(.CaseOpenDate.ToShortDateString)
                    cmd.AddInParameter("@case_version", SqlDbType.SmallInt).Value = 0
                    cmd.AddInParameter("@case_progress_id", SqlDbType.Int).Value = iProgressStatusCodeId
                    cmd.AddInParameter("@analyst_handler_id", SqlDbType.Int).Value = iAnalystId
                    cmd.AddInParameter("@admin_handler_id", SqlDbType.Int).Value = iAssistantId
                    cmd.AddInParameter("@base_case_id", SqlDbType.Int).Value = 0
                    cmd.AddInParameter("@user_id", SqlDbType.SmallInt).Value = _SiriusUser.UserID
                    dsSaveCase = Con.ExecuteDataSet(cmd, "SaveCase")

                    If dsSaveCase.Tables(0).Rows.Count > 0 Then
                        iCaseId = CInt(dsSaveCase.Tables(0).Rows(0).Item(0))
                        iBaseCaseID = Cast.ToInt32(dsSaveCase.Tables(0).Rows(0).Item(1), 0)
                    End If
                End Using
            End With

            If iCaseId <> 0 Then
                oRequest.CaseKey = iCaseId
                oResponse.CaseKey = iCaseId
                oResponse.BaseCaseKey = iBaseCaseID
                oResponse.CaseNumber = GetAndValidateDescriptionById(Con, "[Case]", "Case_Number", "case_id", iCaseId.ToString)
            End If

        Catch ex As Exception
            Throw
        End Try

        Return oResponse

    End Function

    Public Function CreateCaseEvent(ByVal con As SiriusConnection,
                                        ByVal lCaseId As Integer,
                                           ByVal lUserId As Integer,
                                            ByVal sEventDescription As String) As Integer

        Dim lEventCnt As Integer
        Dim sDescriptionToUse As String = String.Empty

        ' default event type

        Dim sEventTypeCode As String = EventTypeCode.NewCase

        ' override default claim event description is a value is passed
        If Not String.IsNullOrEmpty(sEventDescription) Then
            sDescriptionToUse = sEventDescription
        End If

        ' create default claim event
        CreateEvent(con,
                    Nothing,
                    Nothing,
                    Nothing,
                    Nothing,
                    Nothing, Nothing, Nothing, Nothing, Nothing, Nothing, 38,
                    lUserId,
                    Date.Now,
                    sDescriptionToUse,
                    Nothing, Nothing, sEventTypeCode, Nothing, Nothing, Nothing,
                    Nothing, Nothing, Nothing,
                    lEventCnt,
                    Nothing, , lCaseId)

        Return lEventCnt
    End Function

