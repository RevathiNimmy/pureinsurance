                        .BankGuarantee.BGCurrencyCode = GetAndValidateDescriptionById(con, "Currency", "code", "Currency_Id", .BankGuarantee.BGCurrencyKey.ToString())
                        .BankGuarantee.ExpiryDate = Cast.ToDateTime(dsBankGuarantee.Tables(0).Rows(0).Item("Expiry_Date"), Nothing)
                        .BankGuarantee.IsPolicyLock = Cast.ToBoolean(dsBankGuarantee.Tables(0).Rows(0).Item("Is_Policy_Lock"), False)
                        .BankGuarantee.IsDeleted = Cast.ToBoolean(dsBankGuarantee.Tables(0).Rows(0).Item("Is_Deleted"), False)
                        .BankGuarantee.PartyKey = Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("Party_cnt"), 0)
                        .BankGuarantee.LimitAvailable = Cast.ToDecimal(dsBankGuarantee.Tables(0).Rows(0).Item("available_bal"), 0)
                        .BankGuarantee.CustodyBranchKey = Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("custody_branch_id"), 0)
                        .BankGuarantee.CustodyBranchCode = GetAndValidateDescriptionById(con, "Source", "code", "Source_id", .BankGuarantee.CustodyBranchKey.ToString())
                        .BankGuarantee.IssueDate = Cast.ToDateTime(dsBankGuarantee.Tables(0).Rows(0).Item("issue_date"), Nothing)

                        sBGStatusDesc = GetAndValidateDescriptionById(con, PMLookupTable.BG_Status, "description", "BG_status_id", Cast.ToInt32(dsBankGuarantee.Tables(0).Rows(0).Item("bg_status_id"), 0).ToString)
                        sDescription = "Bank Guarantee Details Modified From:- " + Environment.NewLine + Environment.NewLine + "Bank Name: " & Trim(.BankGuarantee.BankNameDesc) & Environment.NewLine &
                        "Bank Branch: " & .BankGuarantee.BankBranch & Environment.NewLine & "BG Number: " & .BankGuarantee.BankGuaranteeRef & Environment.NewLine &
                        "BG Amount: " & .BankGuarantee.BGLimit.ToString & Environment.NewLine & "Date Expiry: " & .BankGuarantee.ExpiryDate & Environment.NewLine &
                        "Status: " & sBGStatusDesc & Environment.NewLine & Environment.NewLine
                    End With
                End Using

                oBankGuarantee.LimitAvailable = oBankGuarantee.BGLimit
                UpdateBankGuaranteeItem(con, oBankGuarantee, oSAMErrorCollection)
                DeleteBankGuaranteeItemProducts(con, oBankGuarantee, oSAMErrorCollection)
                DeleteBankGuaranteeItemBranches(con, oBankGuarantee, oSAMErrorCollection)
                AddBankGuaranteeProducts(con, oBankGuarantee, oSAMErrorCollection)
                AddBankGuaranteeBranches(con, oBankGuarantee, oSAMErrorCollection)

                sBankName = GetAndValidateDescriptionById(con, PMLookupTable.Bank, "bank_name", "bank_id", oBankGuarantee.BankNameKey.ToString)
                sDescription = sDescription & "To " & Environment.NewLine & Environment.NewLine + "Bank Name: " & Trim(sBankName) & Environment.NewLine & "Bank Branch: " & oBankGuarantee.BankBranch & Environment.NewLine &
                                "BG Number: " & oBankGuarantee.BankGuaranteeRef & Environment.NewLine & "BG Amount: " & oBankGuarantee.BGLimit.ToString & Environment.NewLine &
                                "Date Expiry: " & oBankGuarantee.ExpiryDate & Environment.NewLine & "Status: " & sBGStatusDesc

                CreateEvent(con, oBankGuarantee.PartyKey, Nothing, Nothing, Nothing,
                Nothing, Nothing, Nothing, Nothing, Nothing, Nothing,
                Nothing, _SiriusUser.UserID, Now, sDescription, Nothing, Nothing, Nothing,
                Nothing, Nothing, Nothing, Nothing, 0, Nothing, Nothing, oBankGuarantee.BGKey)
            Next

            oResponse.BankGuarantee = New BaseUpdateBankGuaranteeResponseTypeBankGuarantee
            ReDim Preserve oResponse.BankGuarantee.Row(oUpdateBankGuaranteeRequest.BankGuarantee.GetUpperBound(0))
            Dim iCounter As Integer = 0
            For Each oBankGuarantee In oUpdateBankGuaranteeRequest.BankGuarantee
                oCorebusiness.UnlockAndGetSAMTS(Con:=con,
                    BranchCode:=oUpdateBankGuaranteeRequest.BranchCode,
                    Lockname:=CoreBusiness.LockName.BGId,
                    LockValue:=oBankGuarantee.BGKey,
                    TStamp:=oBankGuarantee.BGTimeStamp)

                oResponse.BankGuarantee.Row(iCounter) = New BaseUpdateBankGuaranteeResponseTypeBankGuaranteeRow
                oResponse.BankGuarantee.Row(iCounter).BGKey = oBankGuarantee.BGKey
                oResponse.BankGuarantee.Row(iCounter).BGTimeStamp = oBankGuarantee.BGTimeStamp
                iCounter = iCounter + 1
            Next

            con.CommitTransaction()

        Catch ex As Exception
            con.RollbackTransaction()
            Throw
        End Try

        Return oResponse
    End Function

