        'Delete all partial tax calculations entries
        DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.TREATYPREMIUMTAXTYPE, TaxType.TREATYCOMMISSIONTAXTYPE)
        DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.FACPREMIUMTAXTYPE, TaxType.FACCOMMISSIONTAXTYPE)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_upd")
            cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = Cast.ToInt32(oUpdateArrangementLinesRI2007Request.RIArrangementLines(0).RIArrangementKey)
            cmd.AddInParameter("@is_modified", SqlDbType.Int).Value = 0
            con.ExecuteNonQuery(cmd)
        End Using
        If Not IsNothing(oReinsurance) AndAlso Cast.ToInt32(oReinsurance.RIArrangementLineKey, 0) <> 0 Then
            DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.TREATYPREMIUMTAXTYPE, TaxType.TREATYCOMMISSIONTAXTYPE, oReinsurance.RIArrangementLineKey)
        End If

        For Each oReinsurance In oUpdateArrangementLinesRI2007Request.RIArrangementLines

            'Delete all partial tax calculations entries
            DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.TREATYPREMIUMTAXTYPE, TaxType.TREATYCOMMISSIONTAXTYPE, oReinsurance.RIArrangementLineKey)
            DeleteTaxCalculationEntries(con, iRiskCnt, iInsuranceFileCnt, TaxType.FACPREMIUMTAXTYPE, TaxType.FACCOMMISSIONTAXTYPE, oReinsurance.RIArrangementLineKey)

            If oReinsurance.Type <> "FX" Then
                If oReinsurance.ActionType = RowAction.EditRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_upd_RI2007")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                        cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = oReinsurance.ThisSharePercent
                        cmd.AddInParameter("@premium_percent", SqlDbType.Float).Value = oReinsurance.PremiumPercent
                        cmd.AddInParameter("@commission_percent", SqlDbType.Float).Value = oReinsurance.CommissionPercent
                        cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.AgreementCode
                        cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.SumInsured
                        cmd.AddInParameter("@premium_value", SqlDbType.Money).Value = oReinsurance.PremiumValue
                        cmd.AddInParameter("@commission_value", SqlDbType.Money).Value = oReinsurance.CommissionValue
                        cmd.AddInParameter("@premium_tax", SqlDbType.Money).Value = oReinsurance.PremiumTax
                        cmd.AddInParameter("@commission_tax", SqlDbType.Money).Value = oReinsurance.CommissionTax
                        cmd.AddInParameter("@is_commission_modified", SqlDbType.Int).Value = IIf(oReinsurance.IsCommissionModified, 1, 0)
                        cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                        cmd.AddInParameter("@lower_limit", SqlDbType.Money).Value = oReinsurance.LowerLimit
                        cmd.AddInParameter("@retained_percentage", SqlDbType.Float).Value = oReinsurance.Retained
                        cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = oReinsurance.DefaultSharePercent
                        cmd.AddInParameter("@participation_percent", SqlDbType.Float).Value = oReinsurance.ParticipationPercent
                        con.ExecuteNonQuery(cmd)
                    End Using
                ElseIf oReinsurance.ActionType = RowAction.AddRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_add")
                        cmd.AddOutParameter("@ri_arrangement_line_id", SqlDbType.Int)
                        cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oReinsurance.RIArrangementKey
                        cmd.AddInParameter("@type", SqlDbType.VarChar, 3).Value = oReinsurance.Type
                        cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = IIf(oReinsurance.TreatyID = 0, Nothing, oReinsurance.TreatyID)
                        cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = IIf(oReinsurance.PartyKey = 0, Nothing, oReinsurance.PartyKey)
                        cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = oReinsurance.ThisSharePercent
                        cmd.AddInParameter("@premium_percent", SqlDbType.Float).Value = oReinsurance.PremiumPercent
                        cmd.AddInParameter("@commission_percent", SqlDbType.Float).Value = oReinsurance.CommissionPercent
                        cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.AgreementCode
                        cmd.AddInParameter("@priority", SqlDbType.Int).Value = oReinsurance.Priority
                        cmd.AddInParameter("@number_of_lines", SqlDbType.Int).Value = oReinsurance.NumberOfLines
                        cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.SumInsured
                        cmd.AddInParameter("@premium_value", SqlDbType.Money).Value = oReinsurance.PremiumValue
                        cmd.AddInParameter("@commission_value", SqlDbType.Money).Value = oReinsurance.CommissionValue
                        cmd.AddInParameter("@premium_tax", SqlDbType.Money).Value = oReinsurance.PremiumTax
                        cmd.AddInParameter("@commission_tax", SqlDbType.Money).Value = oReinsurance.CommissionTax
                        cmd.AddInParameter("@is_commission_modified", SqlDbType.Int).Value = IIf(oReinsurance.IsCommissionModified, 1, 0)
                        cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                        cmd.AddInParameter("@lower_limit", SqlDbType.Money).Value = oReinsurance.LowerLimit
                        cmd.AddInParameter("@retained_percentage", SqlDbType.Float).Value = oReinsurance.Retained
                        cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = oReinsurance.DefaultSharePercent
                        cmd.AddInParameter("@participation_percent", SqlDbType.Float).Value = oReinsurance.ParticipationPercent

                        con.ExecuteNonQuery(cmd)

                        oReinsurance.RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)
                    End Using

                ElseIf oReinsurance.ActionType = RowAction.DeleteRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_del_RI2007")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                        con.ExecuteNonQuery(cmd)
                    End Using
                End If
                If oReinsurance.ActionType <> RowAction.DeleteRow Then
                    If oReinsurance.Type = "F" Then
                        CalculateFACTax(con, iRiskCnt, iInsuranceFileCnt, oReinsurance)

                    Else
                        CalculateTreatyTax(con, iRiskCnt, iInsuranceFileCnt, oReinsurance)
                    End If
                    If oReinsurance.Type = "F" And oReinsurance.BrokerParticipants IsNot Nothing Then

                        For iCount As Integer = 0 To oReinsurance.BrokerParticipants.Length - 1
                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_AddBrokerParticipants")
                                cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                                cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oReinsurance.BrokerParticipants(iCount).PartyKey
                                cmd.AddInParameter("@Part_percent", SqlDbType.Float).Value = oReinsurance.BrokerParticipants(iCount).ParticpationPercentage
                                cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 1
                                con.ExecuteNonQuery(cmd)
                            End Using
                        Next
                    End If
                End If
            Else
                ProcessFAXRILines(con, iRiskCnt, iInsuranceFileCnt, oReinsurance)
            End If
        Next

        UpdatePremiumPercentRI2007(con, oUpdateArrangementLinesRI2007Request)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_UpdateRiskStatus")
            cmd.AddInParameter("@riskCnt", SqlDbType.Int).Value = iRiskCnt
            con.ExecuteNonQuery(cmd)
        End Using


        Return oUpdateArrangementLinesRI2007Response

    End Function

    Private Sub ProcessFAXRILines(ByVal con As SiriusConnection,
                            ByVal iRiskCnt As Integer,
                            ByVal iInsuranceFileCnt As Integer,
                            ByVal oReinsurance As BaseRiskRIArrangementLineType)
        Dim sRiIds As String
        If oReinsurance.ActionType = RowAction.AddRow Then
            For iCount As Integer = 0 To oReinsurance.FAXParticipants.Length - 1
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_add")
                    cmd.AddOutParameter("@ri_arrangement_line_id", SqlDbType.Int)
                    cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oReinsurance.RIArrangementKey
                    cmd.AddInParameter("@type", SqlDbType.VarChar, 3).Value = oReinsurance.Type
                    cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = Nothing
                    cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).PartyKey
                    cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = 0D
                    cmd.AddInParameter("@premium_percent", SqlDbType.Float).Value = 0D
                    cmd.AddInParameter("@commission_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).CommissionPercent
                    cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.FAXParticipants(iCount).AgreementCode
                    cmd.AddInParameter("@priority", SqlDbType.Int).Value = 1
                    cmd.AddInParameter("@number_of_lines", SqlDbType.Int).Value = 1
                    cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).SumInsured
                    cmd.AddInParameter("@premium_value", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).PremiumValue
                    cmd.AddInParameter("@commission_value", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).CommissionValue
                    cmd.AddInParameter("@premium_tax", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).PremiumTax
                    cmd.AddInParameter("@commission_tax", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).CommissionTax
                    cmd.AddInParameter("@is_commission_modified", SqlDbType.Int).Value = 0
                    cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                    cmd.AddInParameter("@lower_limit", SqlDbType.Money).Value = oReinsurance.LowerLimit
                    cmd.AddInParameter("@retained_percentage", SqlDbType.Float).Value = IIf(oReinsurance.FAXParticipants(iCount).AccountType = "Retained", 1D, 0D)
                    cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = 0D
                    cmd.AddInParameter("@participation_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).ParticpationPercentage
                    con.ExecuteNonQuery(cmd)

                    oReinsurance.FAXParticipants(iCount).RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)

                    If iCount = 0 Then
                        oReinsurance.RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)
                    End If

                    If iCount <> oReinsurance.FAXParticipants.Length - 1 Then
                        sRiIds = sRiIds & oReinsurance.FAXParticipants(iCount).RIArrangementLineKey.ToString & ","
                    Else
                        sRiIds = sRiIds & oReinsurance.FAXParticipants(iCount).RIArrangementLineKey.ToString
                    End If

                End Using


                If oReinsurance.FAXParticipants(iCount).BrokerParticipants IsNot Nothing Then

                    For iCount1 As Integer = 0 To oReinsurance.FAXParticipants(iCount).BrokerParticipants.Length - 1
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_AddBrokerParticipants")
                            cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                            cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).PartyKey
                            cmd.AddInParameter("@Part_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).ParticpationPercentage
                            cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 1
                            con.ExecuteNonQuery(cmd)
                        End Using
                    Next
                End If

                CalculateFACTax(con, iRiskCnt, iInsuranceFileCnt, oReinsurance)

            Next
            If sRiIds <> "" Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_Update_RiArrangementLine_Grouping")
                    cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                    cmd.AddInParameter("@sRiIds", SqlDbType.VarChar).Value = sRiIds
                    cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 1
                    con.ExecuteNonQuery(cmd)
                End Using
            End If

        ElseIf oReinsurance.ActionType = RowAction.EditRow Then
            Dim lNewRIArrangementLineId As Long

            For iCount As Integer = 0 To oReinsurance.FAXParticipants.Length - 1
                If oReinsurance.FAXParticipants(iCount).ActionType = RowAction.AddRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_add")
                        cmd.AddOutParameter("@ri_arrangement_line_id", SqlDbType.Int)
                        cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oReinsurance.RIArrangementKey
                        cmd.AddInParameter("@type", SqlDbType.VarChar, 3).Value = oReinsurance.Type
                        cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = Nothing
                        cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).PartyKey
                        cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@premium_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@commission_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).CommissionPercent
                        cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.FAXParticipants(iCount).AgreementCode
                        cmd.AddInParameter("@priority", SqlDbType.Int).Value = 1
                        cmd.AddInParameter("@number_of_lines", SqlDbType.Int).Value = 1
                        cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).SumInsured
                        cmd.AddInParameter("@premium_value", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).PremiumValue
                        cmd.AddInParameter("@commission_value", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).CommissionValue
                        cmd.AddInParameter("@premium_tax", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).PremiumTax
                        cmd.AddInParameter("@commission_tax", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).CommissionTax
                        cmd.AddInParameter("@is_commission_modified", SqlDbType.Int).Value = 0
                        cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                        cmd.AddInParameter("@lower_limit", SqlDbType.Money).Value = oReinsurance.LowerLimit
                        cmd.AddInParameter("@retained_percentage", SqlDbType.Float).Value = IIf(oReinsurance.FAXParticipants(iCount).AccountType = "Retained", 1D, 0D)
                        cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@participation_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).ParticpationPercentage
                        con.ExecuteNonQuery(cmd)
                        oReinsurance.FAXParticipants(iCount).RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)

                        If iCount = 0 Then
                            oReinsurance.RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)
                        End If

                    End Using
                ElseIf oReinsurance.FAXParticipants(iCount).ActionType = RowAction.EditRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_upd_RI2007")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                        cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@premium_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@commission_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).CommissionPercent
                        cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.FAXParticipants(iCount).AgreementCode
                        cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).SumInsured
                        cmd.AddInParameter("@premium_value", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).PremiumValue
                        cmd.AddInParameter("@commission_value", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).CommissionValue
                        cmd.AddInParameter("@premium_tax", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).PremiumTax
                        cmd.AddInParameter("@commission_tax", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).CommissionTax
                        cmd.AddInParameter("@is_commission_modified", SqlDbType.Int).Value = 0
                        cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                        cmd.AddInParameter("@lower_limit", SqlDbType.Money).Value = oReinsurance.LowerLimit
                        cmd.AddInParameter("@retained_percentage", SqlDbType.Float).Value = IIf(oReinsurance.FAXParticipants(iCount).AccountType = "Retained", 1D, 0D)
                        cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@participation_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).ParticpationPercentage
                        con.ExecuteNonQuery(cmd)
                    End Using
                ElseIf oReinsurance.FAXParticipants(iCount).ActionType = RowAction.DeleteRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_DelBrokerParticipants")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                        cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = 0
                        cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 1
                        con.ExecuteNonQuery(cmd)
                    End Using

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_Delete_RI2007ArrangementLines")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                        cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = 0
                        cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 1
                        cmd.AddOutParameter("@NewgroupingId", SqlDbType.Int)
                        con.ExecuteNonQuery(cmd)
                        oReinsurance.RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("NewgroupingId").Value, 0)
                    End Using

                End If

                If oReinsurance.FAXParticipants(iCount).ActionType = RowAction.AddRow Or
                   oReinsurance.FAXParticipants(iCount).ActionType = RowAction.EditRow Then
                    If iCount <> oReinsurance.FAXParticipants.Length - 1 Then
                        sRiIds = sRiIds & oReinsurance.FAXParticipants(iCount).RIArrangementLineKey.ToString & ","
                    Else
                        sRiIds = sRiIds & oReinsurance.FAXParticipants(iCount).RIArrangementLineKey.ToString
                    End If

                    If oReinsurance.FAXParticipants(iCount).BrokerParticipants IsNot Nothing Then
                        For iCount1 As Integer = 0 To oReinsurance.FAXParticipants(iCount).BrokerParticipants.Length - 1
                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_DelBrokerParticipants")
                                cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                                cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).PartyKey
                                cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 1
                                con.ExecuteNonQuery(cmd)
                            End Using

                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_AddBrokerParticipants")
                                cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                                cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).PartyKey
                                cmd.AddInParameter("@Part_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).ParticpationPercentage
                                cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 1
                                con.ExecuteNonQuery(cmd)
                            End Using
                        Next
                    End If

                    CalculateFACTax(con, iRiskCnt, iInsuranceFileCnt, oReinsurance)
                End If
            Next

            If Right(sRiIds, 1) = "," Then
                sRiIds = Left(sRiIds, Len(sRiIds) - 1)
            End If
            If sRiIds.Contains(",") Then
                lNewRIArrangementLineId = CLng(sRiIds.Substring(0, sRiIds.IndexOf(",")))
            End If

            If sRiIds <> "" Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_Update_RiArrangementLine_Grouping")
                    If lNewRIArrangementLineId <> 0 Then
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = lNewRIArrangementLineId
                    Else
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                    End If
                    cmd.AddInParameter("@sRiIds", SqlDbType.VarChar).Value = sRiIds
                    cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 1
                    con.ExecuteNonQuery(cmd)
                End Using
            End If

        ElseIf oReinsurance.ActionType = RowAction.DeleteRow Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_RI_Arrangement_Line_del_RI2007")
                cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                con.ExecuteNonQuery(cmd)
            End Using
        End If

    End Sub

    Private Sub DeleteTaxCalculationEntries(ByVal con As SiriusConnection,
                                       ByVal iRiskCnt As Integer,
                                       ByVal iInsuranceFileCnt As Integer,
                                       ByVal sTaxType As String,
                                       ByVal sCommType As String,
                                       Optional ByVal iRIArrangementLineId As Integer = 0)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Delete_Tax_Calculations")
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.ToInt32(iInsuranceFileCnt)
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = Cast.ToInt32(iRiskCnt)
