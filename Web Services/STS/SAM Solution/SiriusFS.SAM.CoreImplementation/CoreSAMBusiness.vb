                Next
            End With

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Insurance_File_Details")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(GetHeaderAndRiskFeesByKeyRequest.InsuranceFileKey)

                dsHeader = con.ExecuteDataSet(cmd, "Row")

            End Using

        End If

        If (dsHeader.Tables.Count >= 1) Then
            If (dsHeader.Tables(0).Rows.Count >= 1) Then

                With dsHeader.Tables(0)
                    oGetHeaderAndRiskFeesByKeyResponse.InsuranceFileKey = GetHeaderAndRiskFeesByKeyRequest.InsuranceFileKey
                    oGetHeaderAndRiskFeesByKeyResponse.ClientCode = .Rows(0).Item("shortname").ToString
                    oGetHeaderAndRiskFeesByKeyResponse.InsuranceFileRef = .Rows(0).Item("insurance_ref").ToString
                    oGetHeaderAndRiskFeesByKeyResponse.Currency = .Rows(0).Item("description").ToString
