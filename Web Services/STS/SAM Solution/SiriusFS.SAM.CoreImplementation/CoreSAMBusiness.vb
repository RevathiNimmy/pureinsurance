            .Columns("country_code").ColumnName = "CountryCode"
            .Columns("state_id").ColumnName = "StateId"
            .Columns("state_code").ColumnName = "StateCode"
            .Columns("Earning_Pattern_code").ColumnName = "EarningPatternCode"

        End With
        Dim Docxml As New System.Xml.XmlDocument

        If oGetRatingSectionTypesRequest.WCFSecurityToken = "" Then
