    ''' <summary>
    '''This generic method validates Businesss rules
    '''</summary>
    '''<param name="oErrorCollection" type="Object"></param>
    '''<param name="isourceId" type="Integer"></param>
    '''<param name="iProductKey" type="Integer"></param>
    '''<param name="oCoverNoteProducts" type="BaseCoverNoteBookType"></param>
    '''<param name="isourceId" type="Integer"></param>
    '''<param name="CoverNoteBranchCode" type="String"></param>
    '''<param name="AgentKeySpecified" type="Boolean"></param>
    '''<remarks></remarks>
    Public Sub ValidateCoverNoteBookBusinessRule(ByRef oErrorCollection As Object, ByRef isourceId As Nullable(Of Int32), ByRef iAgentKeyvalue As Nullable(Of Int32), ByRef iProductKey As Nullable(Of Int32), ByVal AgentKey As Integer, ByVal oCoverNoteProducts As BaseCoverNoteBookType, ByVal CoverNoteBranchCode As String, ByVal AgentKeySpecified As Boolean)
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim sMessage As String = Nothing
        Dim iAgentKey As Nullable(Of Int32)
        If AgentKeySpecified = True Then
            iAgentKey = AgentKey
        Else
            iAgentKey = Nothing
        End If

        If AgentKey > 0 Or Not String.IsNullOrEmpty(CoverNoteBranchCode) Or oCoverNoteProducts.CoverNoteProducts IsNot Nothing Then
            If (AgentKey <= 0) Then
                sMessage = "AgentKey "
            End If
            If String.IsNullOrEmpty(CoverNoteBranchCode) Then
                sMessage += "CoverNoteBranchCode"
            End If
            If oCoverNoteProducts.CoverNoteProducts Is Nothing AndAlso oCoverNoteProducts.CoverNoteProducts.Row Is Nothing Then
                sMessage += "CoverNoteProducts "
            End If

            If sMessage IsNot Nothing Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                          SAMInvalidData.MandatoryInputMissing.ToString,
                                          sMessage)
            Else
                iAgentKeyvalue = iAgentKey
                isourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
PMLookupTable.Source, CoverNoteBranchCode, "Source", oSAMErrorCollection)
            End If
        Else
            iAgentKeyvalue = Nothing
            isourceId = Nothing
            iProductKey = Nothing
        End If
    End Sub

    ''' <summary>
    '''This method validates Data validations
    '''</summary>
    '''<param name="oErrorCollection" type="Object"></param>
    '''<param name="oAddCoverNoteBookRequest" type="BaseAddCoverNoteBookRequestType"></param>
    '''<remarks></remarks>

    Private Sub ValidateCoverNoteBookData(ByRef oErrorCollection As Object, ByVal oAddCoverNoteBookRequest As BaseAddCoverNoteBookRequestType)
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        If oAddCoverNoteBookRequest.StartNumber <= 0 Then
            oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                               SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                               "StartNumber")
        End If
        If oAddCoverNoteBookRequest.StartNumber > oAddCoverNoteBookRequest.EndNumber Then
            oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                               SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                               "Start has to  be less than End number")
        End If

        If oAddCoverNoteBookRequest.EndNumber <= 0 Then
            oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                               SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                               "EndNumber")
        End If

        If oAddCoverNoteBookRequest.EffectiveDate <= Date.MinValue Then
            oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                               SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                               "EffectiveDate")
        End If
        If oAddCoverNoteBookRequest.AgentKeySpecified = True Then
            If oAddCoverNoteBookRequest.AgentKey <= 0 Then
                oSAMErrorCollection.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                                SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                                "EndNumber")
            End If
        End If
    End Sub

