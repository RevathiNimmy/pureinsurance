    ''' <summary>
    '''This function will call the stored procedure and will get the ProductRiskOptionValue 
    '''</summary>
    '''<param name="oGetNumberingSchemeNoRequest" type="BaseGetNumberingSchemeNoRequestType"></param>   
    '''<param name="con" type="SiriusConnection"></param>  
    '''<returns> object of type BaseGetNumberingSchemeNoResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function GetNumberingSchemeNo(ByVal con As SiriusConnection, ByVal oGetNumberingSchemeNoRequest As BaseGetNumberingSchemeNoRequestType, Optional ByVal bGetCaseNumber As Boolean = False) As BaseGetNumberingSchemeNoResponseType

        Dim oGetNumberingSchemeNoResponse As New BaseGetNumberingSchemeNoResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Const ACMethodName As String = "GetNumberingSchemeNo"
        Dim oPolicyNumMaint As New bSIRPolicyNumMaint.Business
        Dim sGeneratedCoverNoteCode As String = String.Empty
        Dim sFailureReason As String = String.Empty
        Dim comReturnValue As Integer

        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetNumberingSchemeNoRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetNumberingSchemeNoRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oGetNumberingSchemeNoResponse = New SAMForInsuranceImplementationTypes.GetNumberingSchemeNoResponseType
        ElseIf (oGetNumberingSchemeNoRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetNumberingSchemeNoRequestType)) Or bGetCaseNumber = True Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetNumberingSchemeNoResponse = New SAMForInsuranceV2ImplementationTypes.GetNumberingSchemeNoResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If
        If bGetCaseNumber = False Then
            ' Check mandatory fields
            If String.IsNullOrEmpty(oGetNumberingSchemeNoRequest.BranchCode) Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                            SAMInvalidData.MandatoryInputMissing.ToString,
                                            "BranchCode")
            End If

            ' Check mandatory fields
            If oGetNumberingSchemeNoRequest.ProductKey = 0 Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                            SAMInvalidData.MandatoryInputMissing.ToString,
                                            "ProductKey")
            End If

            If oGetNumberingSchemeNoRequest.AgentKey = 0 Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                            SAMInvalidData.MandatoryInputMissing.ToString,
                                            "AgentKey")
            End If

            oErrors.CheckForErrors()
            If Not String.IsNullOrEmpty(oGetNumberingSchemeNoRequest.BranchCode) Then
                iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oGetNumberingSchemeNoRequest.BranchCode, "BranchCode", oErrors)
            End If

            If oGetNumberingSchemeNoRequest.ProductKey <> 0 Then
                GetAndValidateSpecifiedTableCode(con, "product", "product_id", "product_id", oGetNumberingSchemeNoRequest.ProductKey.ToString(), oErrors, "ProductKey")

            End If
            oErrors.CheckForErrors()
        End If

        If oGetNumberingSchemeNoRequest.SchemeType = NumberingSchemeType.Quote Then
            Return Nothing
        ElseIf oGetNumberingSchemeNoRequest.SchemeType = NumberingSchemeType.Policy Then
            Return Nothing
        ElseIf oGetNumberingSchemeNoRequest.SchemeType = NumberingSchemeType.CoverNote Then
            Try

                InitialiseSBOObject(con, oPolicyNumMaint, _SiriusUser, "bSIRPolicyNumMaint.Business")

                comReturnValue = oPolicyNumMaint.GenerateCoverNoteNumber(
                      v_lSourceID:=iSourceId,
                      v_lProductId:=oGetNumberingSchemeNoRequest.ProductKey,
                      v_lAgentId:=oGetNumberingSchemeNoRequest.AgentKey,
                      r_sGeneratedCoverNoteCode:=sGeneratedCoverNoteCode,
                      r_sFailureReason:=sFailureReason)
                If comReturnValue <> PMEReturnCode.PMTrue AndAlso comReturnValue <> PMEReturnCode.PMNotFound Then
                    RaiseComMethodException("bSIRPolicyNumMaint.Business.GenerateCoverNoteNumber", comReturnValue)
                Else
                    oGetNumberingSchemeNoResponse.FailureReason = sFailureReason
                    oGetNumberingSchemeNoResponse.GeneratedCode = sGeneratedCoverNoteCode
                End If
            Catch ex As Exception
                Throw
            Finally
                If oPolicyNumMaint IsNot Nothing Then
                    oPolicyNumMaint.Dispose()
                    oPolicyNumMaint = Nothing
                End If

            End Try
        ElseIf oGetNumberingSchemeNoRequest.SchemeType = NumberingSchemeType.Case Then
            Try
                Dim sGeneratedCaseCode As String = String.Empty

                InitialiseSBOObject(con, oPolicyNumMaint, _SiriusUser, sObjectName:="bSIRPolicyNumMaint.Business")

                comReturnValue = oPolicyNumMaint.GenerateCaseCode(
                      v_iSourceID:=oGetNumberingSchemeNoRequest.SourceId,
                      r_sGeneratedCaseCode:=sGeneratedCaseCode,
                      r_sFailureReason:=sFailureReason,
                      v_iClaimId:=oGetNumberingSchemeNoRequest.ClaimKey)
                If comReturnValue <> PMEReturnCode.PMTrue AndAlso comReturnValue <> PMEReturnCode.PMNotFound Then
                    RaiseComMethodException("bSIRPolicyNumMaint.Business.GenerateCaseCode", comReturnValue)
                Else
                    oGetNumberingSchemeNoResponse.FailureReason = sFailureReason
                    oGetNumberingSchemeNoResponse.GeneratedCode = sGeneratedCaseCode
                End If
            Catch ex As Exception
                Throw
            Finally
                If oPolicyNumMaint IsNot Nothing Then
                    oPolicyNumMaint.Dispose()
                    oPolicyNumMaint = Nothing
                End If
            End Try

        End If

        Return oGetNumberingSchemeNoResponse

    End Function


    ''' <summary>
    '''This function will pass the request object along with connection object to the AttachCoverNote or  DettachCoverNote based on process type method
    '''</summary>
    '''<param name="oAttachCoverNoteRequest" type="BaseAttachCoverNoteRequestType"></param>  
    '''<returns> object of type BaseAttachCoverNoteResponseType </returns>
    '''<remarks></remarks>
    Public Overloads Function AttachCoverNote(ByVal oAttachCoverNoteRequest As BaseAttachCoverNoteRequestType) As BaseAttachCoverNoteResponseType

        ' validate the request structure against the specified business rules
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

            Dim oResponse As BaseAttachCoverNoteResponseType

            If oAttachCoverNoteRequest.ProcessType = CoverNoteProcessType.Attach Then
                oResponse = AttachCoverNote(con, oAttachCoverNoteRequest)
            ElseIf oAttachCoverNoteRequest.ProcessType = CoverNoteProcessType.Dettach Then
                oResponse = DettachCoverNote(con, oAttachCoverNoteRequest)
            End If

            Return oResponse

        End Using

    End Function


    ''' <summary>
    '''This function will pass the request object to the stored proceudre and returns the reponse object
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>  
    '''<param name="oAttachCoverNoteRequest" type="BaseAttachCoverNoteRequestType"></param>  
    '''<returns> object of type BaseAttachCoverNoteResponseType </returns>
    '''<remarks></remarks>
    Public Overloads Function AttachCoverNote(ByVal con As SiriusConnection, ByVal oAttachCoverNoteRequest As BaseAttachCoverNoteRequestType) As BaseAttachCoverNoteResponseType

        Dim oAttachCoverNoteResponse As New BaseAttachCoverNoteResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim dCoverNoteFrom As Date
        Dim dCoverNoteTo As Date
        Dim lproductId As Integer

        Dim nTypeOfPackage As enumTypeOfPackage

        If oAttachCoverNoteRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.AttachCoverNoteRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oAttachCoverNoteResponse = New SAMForInsuranceImplementationTypes.AttachCoverNoteResponseType
        ElseIf oAttachCoverNoteRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AttachCoverNoteRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oAttachCoverNoteResponse = New SAMForInsuranceV2ImplementationTypes.AttachCoverNoteResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oAttachCoverNoteRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If oAttachCoverNoteRequest.CoverNote.RiskKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "RiskId")
        End If

        If String.IsNullOrEmpty(oAttachCoverNoteRequest.CoverNote.CoverNoteNumber) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "CoverNoteNumber")
        End If

        If oAttachCoverNoteRequest.CoverNote.CoverNoteFrom = Date.MinValue Or oAttachCoverNoteRequest.CoverNote.CoverNoteFrom = Nothing Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "CoverNoteFrom")
        End If

        If oAttachCoverNoteRequest.CoverNote.CoverNoteTo = Date.MinValue Or oAttachCoverNoteRequest.CoverNote.CoverNoteTo = Nothing Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "CoverNoteTo")
        End If
        If oAttachCoverNoteRequest.CoverNote.TImeStamp Is Nothing Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "TImeStamp")
        End If

        oErrors.CheckForErrors()

        GetAndValidateSpecifiedTableCode(con, "Risk",
                                "risk_cnt", "risk_cnt", oAttachCoverNoteRequest.CoverNote.RiskKey.ToString(), oErrors, "risk_cnt")
        If oAttachCoverNoteRequest.CoverNote.CoverNoteFromSpecified = True Then
            If oAttachCoverNoteRequest.CoverNote.CoverNoteFrom < Date.Now Then
                oErrors.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                               SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                               "CoverNoteFrom Should be equal or greater than today’s date")

            Else
                dCoverNoteFrom = oAttachCoverNoteRequest.CoverNote.CoverNoteFrom
            End If
        Else
            dCoverNoteFrom = Nothing

        End If
        If oAttachCoverNoteRequest.CoverNote.CoverNoteToSpecified = True Then
            If oAttachCoverNoteRequest.CoverNote.CoverNoteTo < Date.Now Or oAttachCoverNoteRequest.CoverNote.CoverNoteTo < oAttachCoverNoteRequest.CoverNote.CoverNoteFrom Then
                oErrors.AddInvalidData(SAMConstants.SAMInvalidData.MandatoryInputMissing,
                                               SAMConstants.SAMInvalidData.MandatoryInputMissing.ToString,
                                               "CoverNoteTo should always be greater than or equal CoverNoteFrom date")

            Else
                dCoverNoteTo = oAttachCoverNoteRequest.CoverNote.CoverNoteTo
            End If
        Else
            dCoverNoteTo = Nothing
        End If
        oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                                  PMLookupTable.Source, oAttachCoverNoteRequest.BranchCode,
                                  "BranchCode", oErrors)

        oErrors.CheckForErrors()

        Dim oAnyError As STSErrorType
        oAnyError = oCoreBusiness.CheckTSAndLock(
            BranchCode:=oAttachCoverNoteRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.RiskKey,
            LockValue:=oAttachCoverNoteRequest.CoverNote.RiskKey,
            TStamp:=oAttachCoverNoteRequest.CoverNote.TImeStamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oAttachCoverNoteResponse.STSError = oAnyError
            Return oAttachCoverNoteResponse
        End If

        Try

            con.BeginTransaction()
            'Make a call to following SP to insert the values 
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Attach_Cover_Notes")
                cmd.AddOutParameter("@Risk_Cover_Note_Link_Id", SqlDbType.Int)
                cmd.AddInParameter("@Risk_Id", SqlDbType.Int).Value = oAttachCoverNoteRequest.CoverNote.RiskKey
                cmd.AddInParameter("@Cover_Note_Ref", SqlDbType.VarChar, 50).Value = oAttachCoverNoteRequest.CoverNote.CoverNoteNumber
                cmd.AddInParameter("@Cover_Note_From", SqlDbType.DateTime).Value = dCoverNoteFrom
                cmd.AddInParameter("@Cover_Note_To", SqlDbType.DateTime).Value = dCoverNoteTo
                con.ExecuteNonQuery(cmd)
                oAttachCoverNoteResponse.CoverNoteRiskId = Cast.ToInt32(cmd.Parameters.Item("@Risk_Cover_Note_Link_Id").Value, 0)
                oAttachCoverNoteResponse.RiskKey = oAttachCoverNoteRequest.CoverNote.RiskKey

            End Using

            If oAttachCoverNoteRequest.GenerateCoverNoteDocs = True Then
                Dim sDocumentCode As String = String.Empty
                Dim dsPolicydetails As DataSet = Nothing
                Dim lInsuranceFileCnt As Integer
                Dim lInsuranceFolderCnt As Integer
                Dim lAgentCnt As Integer
                Dim lDocumentId As Integer
                Dim oGetProductRiskOptionValueRequest As New BaseProductRiskOptionValueRequestType
                Dim oGenerateDocumentRequest As New BaseGenerateDocumentRequestType
                dsPolicydetails = GetPolicyDetailsOnRisk(con, oAttachCoverNoteRequest.CoverNote.RiskKey, lproductId)

                oGetProductRiskOptionValueRequest.ProducRiskOption = ProductRiskOptions.CoverNotedocTemplate
                lDocumentId = Convert.ToInt32(GetProductRiskOptions(con, lproductId, oGetProductRiskOptionValueRequest))
                sDocumentCode = GetAndValidateDescriptionById(con, "document_template", "code", "document_template_id", lDocumentId.ToString())

                If dsPolicydetails.Tables.Count > 0 AndAlso dsPolicydetails.Tables(0).Rows.Count > 0 Then
                    lInsuranceFileCnt = Convert.ToInt32(dsPolicydetails.Tables(0).Rows(0).Item("Insurance_File_Cnt"))
                    lInsuranceFolderCnt = Convert.ToInt32(dsPolicydetails.Tables(0).Rows(0).Item("Insurance_Folder_Cnt"))
                    lAgentCnt = Cast.ToInt32(dsPolicydetails.Tables(0).Rows(0).Item("Lead_Agent_Cnt"), 0)
                End If
                oGenerateDocumentRequest.BranchCode = oAttachCoverNoteRequest.BranchCode
                oGenerateDocumentRequest.DocumentTemplateCode = sDocumentCode
                oGenerateDocumentRequest.InsuranceFileKey = lInsuranceFileCnt
                oGenerateDocumentRequest.InsuranceFolderKey = lInsuranceFolderCnt
                oGenerateDocumentRequest.PartyKey = lAgentCnt

                GenerateDocument(oGenerateDocumentRequest)
            End If

            oAnyError = oCoreBusiness.UnlockAndGetTS(
          BranchCode:=oAttachCoverNoteRequest.BranchCode,
          Lockname:=CoreBusiness.LockName.RiskKey,
          LockValue:=oAttachCoverNoteRequest.CoverNote.RiskKey,
          TStamp:=oAttachCoverNoteResponse.TimeStamp)

            ' Check for Errors
            If oAnyError Is Nothing = False Then
                ' Unable to unlock, return the error.
                oAttachCoverNoteResponse.STSError = oAnyError
                Return oAttachCoverNoteResponse
            End If

            con.CommitTransaction()
        Catch ex As Exception
            con.RollbackTransaction()
        End Try

        Return oAttachCoverNoteResponse

    End Function


