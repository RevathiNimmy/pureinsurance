    ''' <summary>
    '''This method sends the request to the function 
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="oGetTransactionDetailsExRequest" type="BaseGetTransactionDetailsExRequestType"></param>
    '''<remarks></remarks>
    Public Overloads Function GetTransactionDetailsEx(ByVal con As SiriusConnection, ByVal oGetTransactionDetailsExRequest As BaseGetTransactionDetailsExRequestType) As BaseGetTransactionDetailsExResponseType

        Dim oResponse As New BaseGetTransactionDetailsExResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim ovResultArray As Object = Nothing
        Dim iSourceId As Integer
        Dim vResultArray As Object = Nothing
        Dim iAllocationTransDetailKey As Integer = Nothing
        Dim sAllocationtransdetail As String = String.Empty

        Dim nTypeOfPackage As enumTypeOfPackage

        If oGetTransactionDetailsExRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetTransactionDetailsExRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetTransactionDetailsExResponseType
        End If
        'Mandatory validations
        oGetTransactionDetailsExRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        If oGetTransactionDetailsExRequest.Allocation IsNot Nothing And oGetTransactionDetailsExRequest.Allocation.Row IsNot Nothing Then
            'Mandatory validations
            For iCount As Integer = 0 To oGetTransactionDetailsExRequest.Allocation.Row.Length - 1

                If oGetTransactionDetailsExRequest.Allocation.Row(iCount).AllocationTransDetailKey = 0 Then
                    oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                SAMInvalidData.MandatoryInputMissing.ToString,
                                                "AllocationTransDetailKey")
                End If
            Next
            oErrors.CheckForErrors()
        End If
        'Data validations
        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                     PMLookupTable.Source, oGetTransactionDetailsExRequest.BranchCode, "Source", oErrors)

        Dim iTransactions As Integer = 0
        Dim AnyError As STSErrorType
        Dim bTransLocked As Boolean = False
        Dim iLockedByUserID As Integer
        Dim slockedByUser As String

        If oGetTransactionDetailsExRequest.Allocation IsNot Nothing And oGetTransactionDetailsExRequest.Allocation.Row IsNot Nothing Then
            For iCount As Integer = 0 To oGetTransactionDetailsExRequest.Allocation.Row.Length - 1
                If iCount = 0 Then
                    sAllocationtransdetail = oGetTransactionDetailsExRequest.Allocation.Row(iCount).AllocationTransDetailKey.ToString()
                Else
                    sAllocationtransdetail = sAllocationtransdetail & "," & oGetTransactionDetailsExRequest.Allocation.Row(iCount).AllocationTransDetailKey.ToString()
                End If

            Next

            Dim dsTrans As DataSet = Nothing

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Get_ExtendedTransactions")
                cmd.AddInParameter("@transdetail_id", SqlDbType.VarChar).Value = sAllocationtransdetail
                dsTrans = con.ExecuteDataSet(cmd, "TransdetailEx")
            End Using

            If dsTrans IsNot Nothing AndAlso dsTrans.Tables IsNot Nothing _
                        AndAlso dsTrans.Tables.Count > 0 AndAlso dsTrans.Tables(0).Rows IsNot Nothing AndAlso dsTrans.Tables(0).Rows.Count > 0 Then

                Dim iCurrentTransDetailId As Integer = 0
                Dim iCnt As Integer = 0
                Dim dr As DataRow = Nothing
                Dim oGetTransactionDetailsEx(0) As BaseGetTransactionDetailsExResponseTypeTransactions
                Dim oGetTransactionDetailsExTrans(0) As BaseGetTransactionDetailsExResponseTypeTransactionsExtended

                For iCntOuter As Integer = 0 To dsTrans.Tables(0).Rows.Count - 1

                    If iCurrentTransDetailId <> Convert.ToInt32(dsTrans.Tables(0).Rows(iCntOuter).Item("transdetail_id")) Then
                        iCurrentTransDetailId = Convert.ToInt32(dsTrans.Tables(0).Rows(iCntOuter).Item("transdetail_id"))
                        ReDim Preserve oGetTransactionDetailsEx(iTransactions)
                        oGetTransactionDetailsEx(iTransactions) = New BaseGetTransactionDetailsExResponseTypeTransactions
                        dr = dsTrans.Tables(0).Rows(iCntOuter)
                        With oGetTransactionDetailsEx(iTransactions)
                            .AccountCode = Cast.ToStringTrim(dr.Item("short_code"))
                            .CurrencyCode = Cast.ToStringTrim(dr.Item("code"))
                            .DocumentReference = Cast.ToStringTrim(dr.Item("document_ref"))
                            .Amount = Cast.ToDecimal(dr.Item("amount"), 0)
                            .Outstanding_Amount = Cast.ToDecimal(dr.Item("os_amount"), 0)
                            .TransDetailKey = Cast.ToInt32(dr.Item("transdetail_id"), 0)

                            ' Get the Timestamp
                            AnyError = oCoreBusiness.GetTimestamp(
                                BranchCode:=oGetTransactionDetailsExRequest.BranchCode,
                                Lockname:=CoreBusiness.LockName.TransDetailKey,
                                LockValue:=tosafeinteger(.TransDetailKey, 0),
                                TStamp:= .AllocationTimeStamp,
                                bCurrentlyLocked:=bTransLocked)

                            ' Return AnyErrors
                            If AnyError Is Nothing = False Then
                                oResponse.STSError = AnyError
                            End If
                            Dim dataViewEx As DataView = New DataView
                            With dataViewEx
                                .Table = dsTrans.Tables(0)
                                .RowFilter = "transdetail_id =" + Convert.ToString(iCurrentTransDetailId)
                            End With

                            With dataViewEx.ToTable
                                For iCntInner As Integer = 0 To dataViewEx.ToTable.Rows.Count - 1
                                    ReDim Preserve oGetTransactionDetailsEx(iTransactions).Extended(iCntInner)
                                    oGetTransactionDetailsEx(iTransactions).Extended(iCntInner) = New BaseGetTransactionDetailsExResponseTypeTransactionsExtended
                                    oGetTransactionDetailsEx(iTransactions).Extended(iCntInner).DueAmount = Cast.ToDecimal(dataViewEx.ToTable.Rows(iCntInner).Item("currency_amount"), 0)
                                    oGetTransactionDetailsEx(iTransactions).Extended(iCntInner).DueDate = Convert.ToDateTime(dataViewEx.ToTable.Rows(iCntInner).Item("effective_date"))
                                    oGetTransactionDetailsEx(iTransactions).Extended(iCntInner).ExtendedId = Cast.ToInt32(dataViewEx.ToTable.Rows(iCntInner).Item("transdetailex_id"), 0)
                                    oGetTransactionDetailsEx(iTransactions).Extended(iCntInner).OutstandingAmount = Cast.ToDecimal(dataViewEx.ToTable.Rows(iCntInner).Item("outstanding_currency_amount"), 0)

                                Next ' Fees

                            End With

                        End With
                        iTransactions = iTransactions + 1

                    End If

                Next
                oResponse.Transactions = oGetTransactionDetailsEx
            End If

        End If
        Return oResponse

    End Function

