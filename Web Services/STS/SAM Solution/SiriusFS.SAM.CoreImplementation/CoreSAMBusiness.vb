    Public Overloads Function CallNamedStoredProcedure(ByVal oCallNamedStoredProcedureRequest As BaseCallNamedStoredProcedureRequestType) As BaseCallNamedStoredProcedureResponseType
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
