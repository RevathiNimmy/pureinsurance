            cmd.AddInParameter("@user_id", SqlDbType.Int).Value = _SiriusUser.UserID
            con.ExecuteNonQuery(cmd)
        End Using

        ' Unlock and return the new timestamp
        oAnyError = oCoreBusiness.UnlockAndGetTS(con,
            BranchCode:=UpdateCoverNoteSheetRequest.BranchCode,
            Lockname:=CoreBusiness.LockName.CoverNoteBookId,
            LockValue:=UpdateCoverNoteSheetRequest.CoverNoteBookKey,
            TStamp:=oUpdateCoverNoteSheetResponse.CoverNoteBookTimestamp)

        ' Check for Errors
        If oAnyError Is Nothing = False Then
            ' Either the timestamp didn't match or the record couldn't be locked for some reason, return the error.
            oUpdateCoverNoteSheetResponse.STSError = oAnyError
