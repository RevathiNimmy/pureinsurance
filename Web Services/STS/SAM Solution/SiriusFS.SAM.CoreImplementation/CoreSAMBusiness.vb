    Public Function GetDocument(ByVal GetDocumentRequest As BaseGetDocumentRequestType) As BaseGetDocumentResponseType

        Dim oResponse As BaseGetDocumentResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iRet As Int32
        Dim filePath As String = String.Empty
        Dim btByteArray() As Byte
        Dim btCompressedArray() As Byte
        Dim compressFile As Boolean
        Dim convertPdf As Boolean
        Dim sExtensionType As String = Nothing

        Dim samForBrokingRequest As SAMForBrokingImplementationTypes.GetDocumentRequestType = Nothing
        Dim errorCollection As New SAMErrorCollection

        compressFile = False
        convertPdf = True

        If GetDocumentRequest.GetType Is GetType(SAMForBrokingImplementationTypes.GetDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SamForBrokingPackage
            oResponse = New SAMForBrokingImplementationTypes.GetDocumentResponseType
            samForBrokingRequest = DirectCast(GetDocumentRequest, SAMForBrokingImplementationTypes.GetDocumentRequestType)
        ElseIf GetDocumentRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GetDocumentResponseType
            Dim samForInsuranceRequest As SAMForInsuranceImplementationTypes.GetDocumentRequestType = DirectCast(GetDocumentRequest, SAMForInsuranceImplementationTypes.GetDocumentRequestType)
            compressFile = samForInsuranceRequest.Compress
            convertPdf = samForInsuranceRequest.ConvertPdf
        ElseIf GetDocumentRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetDocumentRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetDocumentResponseType
            Dim samForInsuranceV2Request As SAMForInsuranceV2ImplementationTypes.GetDocumentRequestType = DirectCast(GetDocumentRequest, SAMForInsuranceV2ImplementationTypes.GetDocumentRequestType)
            compressFile = samForInsuranceV2Request.Compress
            sExtensionType = samForInsuranceV2Request.FileExtension
            convertPdf = samForInsuranceV2Request.ConvertPdf
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        'Check Mandatory Fields
        If GetDocumentRequest.DocNum = 0 Then
            errorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "DocNum")
            errorCollection.CheckForErrors()
        End If

        Dim oDoc As bSIRDOCAPI.Form = Nothing

        Try
            oDoc = New bSIRDOCAPI.Form


            Dim oDatabase As dPMDAO.Database = Nothing
            Dim oDatabaseObject As Object = oDatabase
            ' initialise the object
            iRet = CInt(oDoc.Initialise(
                                   _SiriusUser.Username,
                                   _SiriusUser.Password,
                                   CInt(_SiriusUser.UserID),
                                   CInt(_SiriusUser.SourceID),
                                   CInt(_SiriusUser.LanguageID),
                                   CInt(_SiriusUser.CurrencyID),
                                   1,
                                   SiriusUserDefaults.AppName,
                                   False, oDatabaseObject))
            If (iRet <> PMEReturnCode.PMTrue) Then
                errorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "Failed to initialise bSIRDOCAPI")
                errorCollection.CheckForErrors()
            End If
            iRet = oDoc.GetDocument(v_lDocNum:=CInt(GetDocumentRequest.DocNum),
                                        v_bOutputAsPdf:=convertPdf,
                                        r_sDocumentPath:=filePath)

            If (iRet <> PMEReturnCode.PMTrue) Then
                errorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bSIRDOCAPI.Form.GetDocument")
                errorCollection.CheckForErrors()
            End If

        Finally
            If oDoc IsNot Nothing Then
                oDoc.Dispose()
                oDoc = Nothing
            End If
        End Try

        If Not File.Exists(filePath) Then
            errorCollection.AddInvalidData(SAMInvalidData.FileNotFound, "File not found: " & filePath, String.Empty)
            errorCollection.CheckForErrors()
        End If

        ' Try to read in the file into a Filestream
        Try
            If Not String.IsNullOrEmpty(filePath) AndAlso filePath.Trim() <> "" Then
                oResponse.FileExtension = Path.GetExtension(filePath)
            End If
            Using fsInputFile As FileStream = File.OpenRead(filePath)
                ReDim btByteArray(CInt(fsInputFile.Length) - 1)
                fsInputFile.Read(btByteArray, 0, CInt(fsInputFile.Length))
                fsInputFile.Close()
            End Using
        Finally

        End Try

        If compressFile Then



            Try
                Using compressedStream As MemoryStream = New MemoryStream()
                    Using zipStream As GZipStream = New GZipStream(compressedStream, CompressionMode.Compress, True)

                        zipStream.Write(btByteArray, 0, btByteArray.Length)

                        ReDim btCompressedArray(CInt(compressedStream.Length) - 1)
                        compressedStream.Read(btCompressedArray, 0, btCompressedArray.Length)

                        oResponse.PdfDocument = btCompressedArray
                        zipStream.Close()
                        compressedStream.Close()
                    End Using
                End Using

            Finally

            End Try

        Else
            oResponse.PdfDocument = btByteArray

        End If

        Return oResponse

    End Function

