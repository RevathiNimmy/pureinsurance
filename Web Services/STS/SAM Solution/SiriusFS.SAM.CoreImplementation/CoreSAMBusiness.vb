    '''<summary>
    ''' This method is used to Copy Risk 
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>   
    '''<param name="oCopyRiskRequest" type="BaseCopyRiskRequestType"></param>   
    '''<returns>"oCopyRiskResponse" type ="BaseCopyRiskResponseType"</returns>
    '''<remarks>
    Public Overloads Function CopyRisk(ByVal con As SiriusConnection, ByVal oCopyRiskRequest As BaseCopyRiskRequestType) As BaseCopyRiskResponseType
        Dim oCopyRiskResponse As New BaseCopyRiskResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim obGIS As New bGIS.STS
        Dim lReturn As Integer
        Dim iRet As Integer
        Dim newRiskKey As Integer
        'con = SiriusConnection.FromAny(connectionString:=ConnectionString)
        Dim oDatabase As Object = Nothing
        If Not con Is Nothing Then
            oDatabase = con.PMDAODatabase
        End If

        Try
            If oCopyRiskRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.CopyRiskRequestType) Then
                nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
                oCopyRiskResponse = New SAMForInsuranceV2ImplementationTypes.CopyRiskResponseType
            End If

            ' validate the mandatory structure data 
            oCopyRiskRequest.Validate(CType(oSAMErrorCollection, Object))

            'if there were any errors throw an exception
            oSAMErrorCollection.CheckForErrors()

            ' Create an object of bGIS.STS and call ProcessCopyRisk passing appropriate parameter and get the new risk key and time stamp and pass it in the response structure.
            lReturn = obGIS.Initialise(
                                  _SiriusUser.Username,
                                  _SiriusUser.Password,
                                  CInt(_SiriusUser.UserID),
                                  CInt(_SiriusUser.SourceID),
                                  CInt(_SiriusUser.LanguageID),
                                  CInt(_SiriusUser.CurrencyID),
                                  1,
                                  SiriusUserDefaults.AppName,
                                  vDatabase:=oDatabase)

            iRet = obGIS.ProcessCopyRisk(newRiskKey, CShort(oCopyRiskRequest.CopyType), oCopyRiskRequest.InsuranceFileKey, oCopyRiskRequest.InsuranceFolderKey, oCopyRiskRequest.RiskKey, oCopyRiskRequest.RiskNumber, True)
            If (iRet <> PMEReturnCode.PMTrue) And (iRet <> PMReturnCode.PMNotFound) Then
                If obGIS IsNot Nothing Then
                    obGIS.Dispose()
                    obGIS = Nothing
                End If
                RaiseComMethodException("obGIS.ProcessCopyRisk", iRet)
            End If

            Dim AnyError As STSErrorType
            Dim bIsLocked As Boolean

            AnyError = oCoreBusiness.GetTimestamp(con,
                                oCopyRiskRequest.BranchCode,
                                CoreBusiness.LockName.InsuranceFolderCnt,
                                oCopyRiskRequest.InsuranceFolderKey,
                                oCopyRiskResponse.QuoteTimeStamp,
                                bIsLocked)

            ' Return AnyErrors
            If AnyError Is Nothing = False Then
                oCopyRiskResponse.STSError = AnyError
            End If

            oCopyRiskResponse.RiskKey = newRiskKey

        Catch ex As Exception
            Throw

        Finally
            If obGIS IsNot Nothing Then
                obGIS.Dispose()
                obGIS = Nothing
            End If
        End Try

        Return oCopyRiskResponse
    End Function

