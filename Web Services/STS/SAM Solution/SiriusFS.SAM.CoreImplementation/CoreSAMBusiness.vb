    '''<remarks></remarks> 
    Public Overloads Function FindDocumentTemplates(ByVal conFindDocument As SiriusConnection, ByVal oFindDocumentTemplatesRequest As BaseFindDocumentTemplatesRequestType) As BaseFindDocumentTemplatesResponseType

        Dim oFindDocumentTemplatesResponse As New BaseFindDocumentTemplatesResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage
        Dim ibranchId As Integer
        Dim iProductId As Integer = 0
        Dim iRiskTypeId As Integer = 0
        Dim bIncludeDeletedTemplates As Boolean
        Dim iGisObjectId As Integer = 0

        If oFindDocumentTemplatesRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindDocumentTemplatesRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oFindDocumentTemplatesResponse = New SAMForInsuranceV2ImplementationTypes.FindDocumentTemplatesResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oFindDocumentTemplatesRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If Not String.IsNullOrEmpty(oFindDocumentTemplatesRequest.BranchCode) Then
            ibranchId = Cast.ToInt32(oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oFindDocumentTemplatesRequest.BranchCode, "Code", oErrors), 0)
        End If

        If Not String.IsNullOrEmpty(oFindDocumentTemplatesRequest.ProductCode) Then
            iProductId = Cast.ToInt32(oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, "Product", oFindDocumentTemplatesRequest.ProductCode, "Code", oErrors), 0)
        End If

        If Not String.IsNullOrEmpty(oFindDocumentTemplatesRequest.RiskTypeCode) Then
            iRiskTypeId = Cast.ToInt32(oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, "Risk_type", oFindDocumentTemplatesRequest.RiskTypeCode, "Code", oErrors), 0)
        End If

        oErrors.CheckForErrors()
        If Not String.IsNullOrEmpty(oFindDocumentTemplatesRequest.ObjectName) Then
            If iRiskTypeId > 0 Then
                iGisObjectId = GetAndValidateSpecifiedTableCodeForRiskType(conFindDocument, "gis_object", "gis_object_id", "object_name", oFindDocumentTemplatesRequest.ObjectName, oErrors, "object_name", iRiskTypeId)
            Else
                iGisObjectId = GetAndValidateSpecifiedTableCode(conFindDocument, "gis_object", "gis_object_id", "object_name", oFindDocumentTemplatesRequest.ObjectName, oErrors, "object_name")
            End If
        End If
        oErrors.CheckForErrors()

        Dim ofindDocumentTemplate As New bSIRFindDocTemplate.Form
        Dim comReturnValue As Integer
        Dim vResultArray As Object(,) = Nothing

        InitialiseSBOObject(conFindDocument, ofindDocumentTemplate, _SiriusUser, "bSIRFindDocTemplate.Form")
        If (oCoreBusiness.GetProductOption(gPMConstants.SIRHiddenOptions.SIROOPTNoDeletedTempates, ibranchId) = "1") Then
            bIncludeDeletedTemplates = True
        Else
            bIncludeDeletedTemplates = False
        End If

        Dim sDocumentCode As String
        Dim iDocumentTypeId As Integer
        Dim dtEffectiveDate As New DateTime
        sDocumentCode = oFindDocumentTemplatesRequest.Code
        iDocumentTypeId = Cast.ToInt32(oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.DocumentType, oFindDocumentTemplatesRequest.TypeCode, "Code", oErrors), 0)
        oErrors.CheckForErrors()
        If oFindDocumentTemplatesRequest.EffectiveDateSpecified And oFindDocumentTemplatesRequest.EffectiveDate > Date.MinValue Then
            dtEffectiveDate = oFindDocumentTemplatesRequest.EffectiveDate
        Else
            dtEffectiveDate = ToSafeDate("01/01/1899")
        End If
        If (iProductId = 0) Then
            If (iRiskTypeId = 0) Then
                If oFindDocumentTemplatesRequest.ViaClientManager Then
                    Dim oSources As Object(,) = Nothing
                    GetValidSources(conFindDocument, oSources, False)
                    ofindDocumentTemplate.ViaClientManager = True
                    comReturnValue = ofindDocumentTemplate.SearchByQuery(r_vResultArray:=vResultArray, v_vDocumentCode:=sDocumentCode, v_vDocumentTypeId:=CStr(iDocumentTypeId), v_bIncludeDeleted:=bIncludeDeletedTemplates, v_lExcludeCopyTempalte:=1, v_dtEffectiveDate:=dtEffectiveDate, v_lNumberOfRecords:=oFindDocumentTemplatesRequest.MaxRowsToFetch, v_vValidSourceArray:=CType(oSources, Object))
                ElseIf oFindDocumentTemplatesRequest.TypeCode IsNot Nothing AndAlso oFindDocumentTemplatesRequest.TypeCode <> "" Then
                    comReturnValue = ofindDocumentTemplate.SearchByQuery(r_vResultArray:=vResultArray, v_vDocumentCode:=sDocumentCode, v_vDocumentTypeId:=CStr(iDocumentTypeId), v_bIncludeDeleted:=bIncludeDeletedTemplates, v_lExcludeCopyTempalte:=1, v_dtEffectiveDate:=dtEffectiveDate, v_lNumberOfRecords:=oFindDocumentTemplatesRequest.MaxRowsToFetch)
                Else
                    comReturnValue = ofindDocumentTemplate.SearchByQuery(r_vResultArray:=vResultArray, v_vDocumentCode:=sDocumentCode, v_vDocumentTypeId:=Nothing, v_bIncludeDeleted:=bIncludeDeletedTemplates, v_lExcludeCopyTempalte:=1, v_dtEffectiveDate:=dtEffectiveDate, v_lNumberOfRecords:=oFindDocumentTemplatesRequest.MaxRowsToFetch)
                End If
            Else
                Dim sColumnName As String = String.Empty
                If Not (String.IsNullOrEmpty(Convert.ToString(oFindDocumentTemplatesRequest.PropertyName))) Then
                    sColumnName = GetAndValidateDescriptionById(conFindDocument, "GIS_Property", "column_name", "property_name", Convert.ToString(oFindDocumentTemplatesRequest.PropertyName))
                End If
                comReturnValue = ofindDocumentTemplate.SearchByRiskType(
                   r_vResultArray:=vResultArray,
                   v_lRiskTypeId:=iRiskTypeId,
                   v_vDocumentCode:=sDocumentCode,
                   v_lBranchID:=ibranchId, v_sColumnName:=sColumnName,
                   v_dtEffectiveDate:=dtEffectiveDate, v_lNumberOfRecords:=oFindDocumentTemplatesRequest.MaxRowsToFetch, lGISObjectID:=iGisObjectId, v_sPropertyName:=oFindDocumentTemplatesRequest.PropertyName)
            End If
        Else
            comReturnValue = ofindDocumentTemplate.SearchByProduct(
                r_vResultArray:=vResultArray,
                v_lProductId:=iProductId,
                v_lBranchId:=ibranchId, v_lNumberOfRecords:=oFindDocumentTemplatesRequest.MaxRowsToFetch)
        End If

        If comReturnValue <> PMEReturnCode.PMTrue AndAlso comReturnValue <> PMEReturnCode.PMNotFound Then
            RaiseComMethodException("bSIRFindDocTemplate.Form.SearchByQuery", comReturnValue)
        End If

        Dim strXML As String = String.Empty
        Dim oXMLDoc As System.Xml.XmlDocument
        Dim oResultArrayOut As Object = Nothing
        Dim oResultArrayCopy(,) As Object = Nothing
        Dim oFilterCol() As Object = {3, 5, 6} 'These are the column needs to be filter from object array 

        Dim oBusiness As New CoreBusiness(_SiriusUser)
        Dim typeOfPackage As enumTypeOfPackage

        If oFindDocumentTemplatesRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindDocumentTemplatesRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oFindDocumentTemplatesResponse = New SAMForInsuranceV2ImplementationTypes.FindDocumentTemplatesResponseType
        End If

        strXML = String.Empty
        oXMLDoc = New System.Xml.XmlDocument
        Dim dsResult As New DataSet

        If CType(vResultArray, Object(,)) IsNot Nothing Then
            Try
                Dim arrColHeaders(,) As Object = {{" DocumentTemplateKey ",
                            "Code",
                            "Description",
                            "Type",
                            "EffectiveDate"},
                        {System.Type.GetType("System.Int32"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.String"),
                        System.Type.GetType("System.DateTime")}}

                oResultArrayOut = CopyArrayWithFilters(CType(vResultArray, Object(,)), oResultArrayCopy, oFilterCol)
                dsResult = Utilities.ArrayToDataSet(oResultArrayOut, arrColHeaders, "BaseFindDocumentTemplatesResponseTypeDocumentTemplates")

                If dsResult.Tables.Count > 0 Then
                    If dsResult.Tables(0).Rows.Count > 0 Then

                        dsResult.Tables(0).TableName = "Row"
                        dsResult.Tables(0).Columns(0).ColumnName = "DocumentTemplateKey"
                        dsResult.Tables(0).Columns(1).ColumnName = "Code"
                        dsResult.Tables(0).Columns(2).ColumnName = "Description"
                        dsResult.Tables(0).Columns(3).ColumnName = "Type" 'Using Code(document_type) that is returned from COM, as said by Gaurav
                        dsResult.Tables(0).Columns(4).ColumnName = "EffectiveDate"
                    End If
                End If

                If oFindDocumentTemplatesRequest.WCFSecurityToken = "" Then
                    strXML = dsResult.GetXml()
                    oXMLDoc.LoadXml(strXML)
                    oFindDocumentTemplatesResponse.DocumentTemplatesDataset = oXMLDoc.DocumentElement
                End If
                oFindDocumentTemplatesResponse.ResultData = dsResult

            Finally
                If ofindDocumentTemplate IsNot Nothing Then
                    ofindDocumentTemplate.Dispose()
                    ofindDocumentTemplate = Nothing
                End If
            End Try
        End If

        Return oFindDocumentTemplatesResponse
    End Function

