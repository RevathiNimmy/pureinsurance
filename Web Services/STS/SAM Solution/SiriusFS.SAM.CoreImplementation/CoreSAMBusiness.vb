    ''' <summary>
    '''This method sends the request object values to the Stored Procedure and gets the Bank Guarantee
    '''</summary>
    '''<param name="oFindBankGuaranteeRequest" type="BaseFindBankGuaranteeRequestType"></param>
    '''<param name="conBG" type="SiriusConnection"></param>
    ''' <returns>An object of type SiriusFS.SAM.SFI.BaseImplementationTypes.BaseFindBankGuaranteeResponseType</returns>
    '''<remarks></remarks>

    Public Overloads Function FindBankGuarantee(ByVal conBG As SiriusConnection, ByVal oFindBankGuaranteeRequest As BaseFindBankGuaranteeRequestType) As BaseFindBankGuaranteeResponseType

        Dim oFindBankGuaranteeResponse As BaseFindBankGuaranteeResponseType

        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim nTypeOfPackage As enumTypeOfPackage

        If oFindBankGuaranteeRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindBankGuaranteeRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oFindBankGuaranteeResponse = New SAMForInsuranceV2ImplementationTypes.FindBankGuaranteeResponseType
        Else
            Return Nothing
        End If
        Dim lBGstatusid As Integer
        oFindBankGuaranteeRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()
        'Check Mandatory Fields
        'Check if all request structure fields are not blank combinely.
        With oFindBankGuaranteeRequest
            If String.IsNullOrEmpty(.PartyCode) AndAlso String.IsNullOrEmpty(.AgentCode) AndAlso String.IsNullOrEmpty(.InsuranceRef) AndAlso String.IsNullOrEmpty(.BankGuaranteeRef) AndAlso String.IsNullOrEmpty(.BankNameCode) AndAlso String.IsNullOrEmpty(.BGStatusCode) Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                                   SAMInvalidData.MandatoryInputMissing.ToString,
                                                   "AllFields")
            End If
            oErrors.CheckForErrors()

            If Not String.IsNullOrEmpty(.BGStatusCode) Then
                lBGstatusid = GetAndValidateSpecifiedTableCode(conBG, "BG_Status", "Bg_Status_Id", "code", .BGStatusCode, oErrors, "BGStatusCode")
                oErrors.CheckForErrors()
            End If

            oErrors.CheckForErrors()
        End With
        ' Dataset that will hold the returned results		
        Dim dsBankGuaranteeDetails As DataSet = Nothing
        Using cmdBG As SiriusCommand = SiriusCommand.FromProcedure("Spu_bank_guarantee_sel")
            cmdBG.AddInParameter("@party_code", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(oFindBankGuaranteeRequest.PartyCode, Nothing)
            cmdBG.AddInParameter("@agent_code", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(oFindBankGuaranteeRequest.AgentCode, Nothing)
            cmdBG.AddInParameter("@insurance_ref", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(oFindBankGuaranteeRequest.InsuranceRef, Nothing)
            cmdBG.AddInParameter("@bank_guarantee_ref", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(oFindBankGuaranteeRequest.BankGuaranteeRef, Nothing)
            cmdBG.AddInParameter("@bank_name", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(oFindBankGuaranteeRequest.BankNameCode, Nothing)
            cmdBG.AddInParameter("@BG_status_id", SqlDbType.Int).Value = Cast.NullIfDefault(lBGstatusid, 0)
            If oFindBankGuaranteeRequest.MaxRowsToFetchSpecified = True Then
                cmdBG.AddInParameter("@MaxRowsToFetch", SqlDbType.Int).Value = oFindBankGuaranteeRequest.MaxRowsToFetch
            End If
            dsBankGuaranteeDetails = conBG.ExecuteDataSet(cmdBG, "BankGuarantee")
        End Using

        'Populate the XML Document here with the dsBankGuaranteeDetails information
        If dsBankGuaranteeDetails IsNot Nothing AndAlso (dsBankGuaranteeDetails.Tables.Count >= 1) Then
            dsBankGuaranteeDetails.DataSetName = "BaseFindBankGuaranteeResponseTypeBankGuarantee"
            If (dsBankGuaranteeDetails.Tables(0).Rows.Count >= 1) Then
                With dsBankGuaranteeDetails.Tables(0)
                    .TableName = "row"
                    .Columns.Remove("bank_branch")
                    .Columns.Remove("BG_currency_Id")
                    'As said Gaurav
                    '.Columns.Remove("Conversion_Rate")
                    '.Columns.Remove("Effective_Date")
                    .Columns.Remove("is_policy_lock")
                    .Columns.Remove("RowStatus")
                    .Columns.Remove("RowIndex")
                    .Columns.Remove("is_deleted")

                    .Columns("bg_id").ColumnName = "BGKey"
                    .Columns("bank_name_id").ColumnName = "BankNameKey"
                    .Columns("BankName").ColumnName = "BankName"
                    .Columns("BG_ref").ColumnName = "BankGuaranteeRef"
                    .Columns("BG_limit").ColumnName = "BGLimit"
                    .Columns("available_bal").ColumnName = "AvailableBalance"
                    .Columns("expiry_date").ColumnName = "ExpiryDate"
                    .Columns("Party_Cnt").ColumnName = "PartyKey"
                    .Columns("ResolvedName").ColumnName = "ClientResolvedName"
                    .Columns("ShortName").ColumnName = "ClientShortName"
                    .Columns("Branches").ColumnName = "Branches"
                    .Columns("Products").ColumnName = "Products"
                    .Columns("Description").ColumnName = "StatusDescription"
                End With

                Dim xmlDoc As New System.Xml.XmlDocument
                If oFindBankGuaranteeRequest.WCFSecurityToken = "" Then
                    xmlDoc.LoadXml(dsBankGuaranteeDetails.GetXml)
                    oFindBankGuaranteeResponse.BankGuaranteeDataset = xmlDoc.DocumentElement()
                End If
                oFindBankGuaranteeResponse.ResultData = dsBankGuaranteeDetails

            End If
        End If

        Return oFindBankGuaranteeResponse

    End Function

