    '''<summary>
    ''' This method check if policy is pending portfolio or clone transfer
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="oIsPendingTransferRequestType" type="BaseIsPendingTransferRequestType"></param>    
    '''<returns>BaseIsPendingTransferResponseType</returns>
    '''<remarks></remarks> 
    Public Overloads Function IsPendingTransfer(ByVal con As SiriusConnection, ByVal oIsPendingTransferRequestType As BaseIsPendingTransferRequestType) As BaseIsPendingTransferResponseType

        Dim oResponse As New BaseIsPendingTransferResponseType
        Dim oCoreBusiness As New CoreBusiness

        Try
            If oIsPendingTransferRequestType.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.IsPendingTransferRequestType) Then
                oResponse = New SAMForInsuranceV2ImplementationTypes.IsPendingTransferResponseType
            End If

            Dim oResultDataset As DataSet = Nothing
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_IsPending_PT")
                cmd.AddInParameter("@sPolicyNumber", SqlDbType.VarChar, 50).Value = Cast.ToString(oIsPendingTransferRequestType.PolicyNumber)
                cmd.AddInParameter("@nInsuranceFileCnt", SqlDbType.Int).Value = oIsPendingTransferRequestType.InsuranceFileKey
                oResultDataset = con.ExecuteDataSet(cmd, "Portfolio Transfer")
            End Using

            If oResultDataset IsNot Nothing AndAlso oResultDataset.Tables.Count > 0 AndAlso oResultDataset.Tables(0).Rows.Count > 0 Then
                oResponse.IsPendingPortfolioTransfer = True
            End If

            oResultDataset = Nothing
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_IsPending_CloneTransfer")
                cmd.AddInParameter("@sPolicyNumber", SqlDbType.VarChar, 50).Value = Cast.ToString(oIsPendingTransferRequestType.PolicyNumber)
                cmd.AddInParameter("@nInsuranceFileCnt", SqlDbType.Int).Value = oIsPendingTransferRequestType.InsuranceFileKey
                oResultDataset = con.ExecuteDataSet(cmd, "Clone Transfer")
            End Using
            If oResultDataset IsNot Nothing AndAlso oResultDataset.Tables.Count > 0 AndAlso oResultDataset.Tables(0).Rows.Count > 0 Then
                oResponse.IsPendingCloneTransfer = True
            End If
            oResultDataset = Nothing
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Ins_File_PT_RI_Usage_sel_amend")
                cmd.AddInParameter("@policy_number", SqlDbType.VarChar, 30).Value = Cast.ToString(oIsPendingTransferRequestType.PolicyNumber)
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oIsPendingTransferRequestType.InsuranceFileKey
                oResultDataset = con.ExecuteDataSet(cmd, "Portfolio Amend")
            End Using
            If oResultDataset IsNot Nothing AndAlso oResultDataset.Tables.Count > 0 AndAlso oResultDataset.Tables(0).Rows.Count > 0 Then
                oResponse.IsPendingPortfolioTransfer = True
            End If
            oResultDataset = Nothing
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Risks_Cloned_RI_Status_Sel_amend")
                cmd.AddInParameter("@spolicy_number", SqlDbType.VarChar, 50).Value = Cast.ToString(oIsPendingTransferRequestType.PolicyNumber)
                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oIsPendingTransferRequestType.InsuranceFileKey
                oResultDataset = con.ExecuteDataSet(cmd, "Clone Amend")
            End Using
            If oResultDataset IsNot Nothing AndAlso oResultDataset.Tables.Count > 0 AndAlso oResultDataset.Tables(0).Rows.Count > 0 Then
                oResponse.IsPendingCloneTransfer = True
            End If

            Dim sOptionValue As String
            sOptionValue = oCoreBusiness.GetProductOption(SIRHiddenOptions.SIROPTOverridePortfolioTransferValidations, 1)
            If Trim(sOptionValue) = "1" AndAlso Trim(sOptionValue).Length > 0 Then
                oResponse.IsPendingPortfolioTransfer = False
                oResponse.IsPendingCloneTransfer = False
            End If

        Catch ex As Exception
            Throw
        End Try

        Return oResponse

    End Function

