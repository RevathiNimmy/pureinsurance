    Public Overloads Function AddJournal(ByVal con As SiriusConnection, ByVal oAddJournalRequest As BaseAddJournalRequestType) As BaseAddJournalResponseType

        Dim oAddJournalResponse As New BaseAddJournalResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iManualJournalId As Integer = 0
        Dim sGroupCode As String = ""
        Dim sRangeCode As String = ""
        Dim sNumber As String = ""
        Dim iAuditSetId As Integer
        Dim iJournalTypeId As Integer
        Dim dtLastDate As DateTime
        Dim dtRecurringDate As DateTime
        Dim iOffset As Integer
        Dim iMonths As Integer
        Dim iNextType As Integer
        Dim iSourceId As Integer
        Dim sDocumentRef As String
        Dim lReturn As Integer
        Dim bReccurringDocument As Boolean
        Dim bReversingDocument As Boolean
        Dim iRowCounter As Integer
        Dim sTempCurrency As String
        Dim dTempAmount As Decimal
        Dim oTempCurrencyRate As Object = 0
        Dim oTransaction As BaseAddJournalTransaction
        Dim iTransdetailTypeId As Integer = 1 ' default to Trans

        Dim oTransArray(,) As Object = Nothing
        Dim lstDocumentRef As New List(Of String)
        Dim oDocument As New bACTDocument.Form
        Dim oAuditSet As New bACTAuditset.Form
        Dim oDocPost As New bACTDocumentPost.Form
        Dim oCurrencyConvert As New bACTCurrencyConvert.Form

        Dim oDatabase As Object = Nothing 'con.PMDAODatabase()
        Dim JournalBranchId As Integer
        Dim iSubBranchId As Integer = 0


        If oAddJournalRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AddJournalRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oAddJournalResponse = New SAMForInsuranceV2ImplementationTypes.AddJournalResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If
        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        oAddJournalRequest.Validate(CObj(oSAMErrorCollection))
        oSAMErrorCollection.CheckForErrors()

        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oAddJournalRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        iJournalTypeId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.DocumentTypes, oAddJournalRequest.JournalTypeCode, "JournalTypeCode", oSAMErrorCollection)

        oAddJournalRequest.SourceId = iSourceId
        oAddJournalRequest.JournalTypeId = iJournalTypeId

        If Not String.IsNullOrEmpty(oAddJournalRequest.JournalSubBranchCode) Then
            iSubBranchId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.SubBranch, oAddJournalRequest.JournalSubBranchCode, "SubBranchCode", oSAMErrorCollection)
        End If
        oSAMErrorCollection.CheckForErrors()

        If oAddJournalRequest.Comment.Length >= 256 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                        SAMInvalidData.ValidationRulesFailed.ToString,
                                        "Comment much not contain characters greater than 255")
        End If
        oSAMErrorCollection.CheckForErrors()

        sTempCurrency = oAddJournalRequest.Transactions(0).CurrencyCode
        For iRowCounter = 0 To oAddJournalRequest.Transactions.Length - 2
            If sTempCurrency <> oAddJournalRequest.Transactions(iRowCounter + 1).CurrencyCode Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                        SAMInvalidData.ValidationRulesFailed.ToString,
                                                        "Currency Code must be same")
            End If
        Next
        oSAMErrorCollection.CheckForErrors()

        For Each oTransaction In oAddJournalRequest.Transactions
            dTempAmount = dTempAmount + oTransaction.Amount
        Next
        If dTempAmount <> 0 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                    "The Sum of Amount must be zero")
        End If
        oSAMErrorCollection.CheckForErrors()
        If (oAddJournalRequest.JournalTypeCode = "RCJ" Or oAddJournalRequest.JournalTypeCode = "DPJ") Then
            If IsNothing(oAddJournalRequest.RecurringDetails) Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                    "RecurringDetails")
            End If
        End If
        If (oAddJournalRequest.JournalTypeCode = "ACC" Or oAddJournalRequest.JournalTypeCode = "RVJ" Or
            oAddJournalRequest.JournalTypeCode = "PPT") Then
            If IsNothing(oAddJournalRequest.ReversalDetails) Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                    "ReversalDetails")
            End If
        End If
        If Not IsNothing(oAddJournalRequest.RecurringDetails) Then
            If Not (oAddJournalRequest.JournalTypeCode = "RCJ" Or oAddJournalRequest.JournalTypeCode = "DPJ") Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                    "RecurringDetails")
            End If
        End If
        oSAMErrorCollection.CheckForErrors()

        If Not IsNothing(oAddJournalRequest.ReversalDetails) Then
            If Not (oAddJournalRequest.JournalTypeCode = "ACC" Or oAddJournalRequest.JournalTypeCode = "RVJ" Or
                oAddJournalRequest.JournalTypeCode = "PPT") Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                    "ReversalDetails")
            End If
        End If

        oSAMErrorCollection.CheckForErrors()

        If Not IsNothing(oAddJournalRequest.RecurringDetails) Then
            If oAddJournalRequest.RecurringDetails.Occurs <= 0 Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                                    "Occurs must be greater than Zero")
            End If
        End If
        oSAMErrorCollection.CheckForErrors()

        If Not IsNothing(oAddJournalRequest.RecurringDetails) Then
            With oAddJournalRequest.RecurringDetails
                If .PerPeriodOnDay <= 0 And .PerPeriodOnMonth <= 0 And .PerQuarterOnDay <= 0 Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                                        SAMInvalidData.ValidationRulesFailed.ToString,
                                                                                        "One of PerPeriodOnDay, PerPeriodOnMonth, PerQuarterOnDay must be > 0")
                End If

                If (.PerPeriodOnDay < 1 Or .PerPeriodOnDay > 366) And .PerPeriodOnDaySpecified Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                    "PerPeriodOnDay should be in between 1 and 366")

                End If
                If (.PerPeriodOnMonth < 1 Or .PerPeriodOnMonth > 31) And .PerPeriodOnMonthSpecified Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                    "PerPeriodOnMonth should be in between 1 and 31")
                End If
                If (.PerQuarterOnDay < 1 Or .PerQuarterOnDay > 31) And .PerQuarterOnDaySpecified Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                    SAMInvalidData.ValidationRulesFailed.ToString,
                                                                    "PerQuarterOnDay should be in between 1 and 31")
                End If
                If Not ((.PerPeriodOnDay > 0 And .PerPeriodOnMonth <= 0 And .PerQuarterOnDay <= 0) Or
                         (.PerPeriodOnMonth > 0 And .PerPeriodOnDay <= 0 And .PerQuarterOnDay <= 0) Or
                         (.PerQuarterOnDay > 0 And .PerPeriodOnDay <= 0 And .PerPeriodOnMonth <= 0)) Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                                                                        SAMInvalidData.ValidationRulesFailed.ToString,
                                                                                        "Only one of PerPeriodOnDay, PerPeriodOnMonth, PerQuarterOnDay can be > 0")
                End If
            End With
        End If
        oSAMErrorCollection.CheckForErrors()

        If Not IsNothing(oAddJournalRequest.ReversalDetails) Then
            If oAddJournalRequest.ReversalDetails.ReversesOn = Date.MinValue Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                            SAMInvalidData.MandatoryInputMissing.ToString,
                                            "ReversesOn")
            End If
        End If
        oSAMErrorCollection.CheckForErrors()

        iRowCounter = 0
        For iRowCounter = 0 To oAddJournalRequest.Transactions.Length - 1
            With oAddJournalRequest
                .Transactions(iRowCounter).AccountKey = GetAndValidateSpecifiedTableCode(con, "account", "account_id", "Short_Code", .Transactions(iRowCounter).AccountCode, oSAMErrorCollection, "short_code")

                .Transactions(iRowCounter).CurrencyKey = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, .Transactions(iRowCounter).CurrencyCode, "CurrencyCode", oSAMErrorCollection)
                If Not String.IsNullOrEmpty(.Transactions(iRowCounter).UnderwritingYear) Then
                    .Transactions(iRowCounter).UnderwritingYearKey = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.UnderwritingYear, .Transactions(iRowCounter).UnderwritingYear, "UnderwritingYear", oSAMErrorCollection)
                End If
                If Not String.IsNullOrEmpty(.Transactions(iRowCounter).CostCentreCode) Then
                    .Transactions(iRowCounter).CostCentreKey = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.CostCentre, .Transactions(iRowCounter).CostCentreCode, "CostCentreCode", oSAMErrorCollection)
                End If
            End With
        Next
        oSAMErrorCollection.CheckForErrors()

        Try

            lReturn = CInt(oCurrencyConvert.Initialise(sUsername:=_SiriusUser.Username,
                                    sPassword:=_SiriusUser.Password,
                                    iUserID:=_SiriusUser.UserID,
                                    iSourceID:=_SiriusUser.SourceID,
                                    iLanguageID:=_SiriusUser.LanguageID,
                                    iCurrencyID:=_SiriusUser.CurrencyID,
                                    iLogLevel:=1,
                                    sCallingAppName:=SiriusUserDefaults.AppName,
                                    vDatabase:=oDatabase))
            If (lReturn <> PMEReturnCode.PMTrue) Then
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bACTCurrencyConvert.Form.Initialise")
                oSAMErrorCollection.CheckForErrors()
            End If

            lReturn = CInt(oDocument.Initialise(sUsername:=_SiriusUser.Username,
                                    sPassword:=_SiriusUser.Password,
                                    iUserID:=_SiriusUser.UserID,
                                    iSourceID:=_SiriusUser.SourceID,
                                    iLanguageID:=_SiriusUser.LanguageID,
                                    iCurrencyID:=_SiriusUser.CurrencyID,
                                    iLogLevel:=1,
                                    sCallingAppName:=SiriusUserDefaults.AppName,
                                    vDatabase:=oDatabase))
            If (lReturn <> PMEReturnCode.PMTrue) Then
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bACTDocument.Form.Initialise")
                oSAMErrorCollection.CheckForErrors()
            End If

            lReturn = oAuditSet.Initialise(sUserName:=_SiriusUser.Username,
                                            sPassword:=_SiriusUser.Password,
                                            iUserID:=CInt(_SiriusUser.UserID),
                                            iSourceID:=CInt(_SiriusUser.SourceID),
                                            iLanguageID:=CInt(_SiriusUser.LanguageID),
                                            iCurrencyID:=CInt(_SiriusUser.CurrencyID),
                                            iLogLevel:=1,
                                            sCallingAppName:=SiriusUserDefaults.AppName,
                                            vDatabase:=oDatabase)
            If (lReturn <> PMEReturnCode.PMTrue) Then
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bACTAuditset.Form.Initialise")
                oSAMErrorCollection.CheckForErrors()
            End If

            lReturn = CInt(oDocPost.Initialise(sUsername:=_SiriusUser.Username,
                                                        sPassword:=_SiriusUser.Password,
                                                        iUserID:=_SiriusUser.UserID,
                                                        iSourceID:=_SiriusUser.SourceID,
                                                        iLanguageID:=_SiriusUser.LanguageID,
                                                        iCurrencyID:=_SiriusUser.CurrencyID,
                                                        iLogLevel:=1,
                                                        sCallingAppName:=SiriusUserDefaults.AppName,
                                                        vDatabase:=oDatabase))
            If (lReturn <> PMEReturnCode.PMTrue) Then
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                        SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                        "bACTDocumentPost.Form.Initialise")
                oSAMErrorCollection.CheckForErrors()
            End If

            Select Case oAddJournalRequest.JournalTypeCode
                Case "ACC"
                    bReversingDocument = True
                Case "RCJ"
                    bReccurringDocument = True
                Case "RVJ"
                    bReversingDocument = True
                Case "DPJ"
                    bReccurringDocument = True
                Case "PPT"
                    bReversingDocument = True
            End Select





            For iRowCounter = 0 To oAddJournalRequest.Transactions.Length - 1
                With oAddJournalRequest.Transactions(iRowCounter)
                    lReturn = oCurrencyConvert.GetCurrencyRate(v_lCurrencyID:= .CurrencyKey,
v_lCompanyId:=iSourceId,
v_dtConversionDate:=Now,
                                                                        r_vConversionRate:=oTempCurrencyRate)

                    If (lReturn <> PMEReturnCode.PMTrue) Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
SAMBusinessErrors.COMComponentMethodFailed.ToString,
"bACTCurrencyConvert.Form.GetCurrencyRate")
                        oSAMErrorCollection.CheckForErrors()
                    End If
                    .CurrencyRate = CDbl(oTempCurrencyRate)
                    .BaseAmount = ToSafeDecimal(.CurrencyRate * .Amount)
                End With
            Next
            If (oAddJournalRequest.Is_reffered = 0) Then
                lReturn = oDocument.GetAutoNumValues(v_iDocumentTypeID:=CShort(iJournalTypeId),
                                            r_sGroupCode:=sGroupCode,
                                            r_sRangeCode:=sRangeCode)
                If (lReturn <> PMEReturnCode.PMTrue) Then
                    oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                        SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                        "bACTDocument.Form.GetAutoNumValues")
                    oSAMErrorCollection.CheckForErrors()
                End If

                lReturn = oDocument.GenerateDocumentReferenceNumber(v_sGroupCode:=sGroupCode,
                                            v_sRangeCode:=sRangeCode,
                                            v_iUserID:=CInt(_SiriusUser.UserID),
                                            v_iCompanyID:=CShort(iSourceId),
                                            r_sDocumentRef:=sNumber)
                If (lReturn <> PMEReturnCode.PMTrue) Then
                    oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                        SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                        "bACTDocument.Form.GenerateDocumentReferenceNumber")
                    oSAMErrorCollection.CheckForErrors()
                End If

                ' sDocumentRef = String.Format("{0}{1:00000000}", sRangeCode, iNumber)
                sDocumentRef = sRangeCode + sNumber
                lstDocumentRef.Add(sDocumentRef)


                oSAMErrorCollection.CheckForErrors()


                If bReversingDocument Then
                    lReturn = oAuditSet.DirectAdd(vAuditsetID:=iAuditSetId,
                                vCompanyID:=CObj(iSourceId),
                                vUserID:=CObj(_SiriusUser.UserID),
                                vPostedDate:=DateTime.Now,
                                vComment:="Reversing Document")
                End If
                If (lReturn <> PMEReturnCode.PMTrue) Then
                    oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                        SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                        "bACTAuditset.Form.DirectAdd")
                    oSAMErrorCollection.CheckForErrors()
                End If

                If bReccurringDocument Then
                    lReturn = oAuditSet.DirectAdd(vAuditsetID:=iAuditSetId,
                                vCompanyID:=CObj(iSourceId),
                                vUserID:=CObj(_SiriusUser.UserID),
                                vPostedDate:=DateTime.Now,
                                vComment:="Recurring Document")
                    If (lReturn <> PMEReturnCode.PMTrue) Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                            SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                            "bACTAuditset.Form.DirectAdd")
                        oSAMErrorCollection.CheckForErrors()
                    End If
                End If

            End If
            If (oAddJournalRequest.ManualJournalId = 0) Then
                iManualJournalId = SaveManualJournal(con, oAddJournalRequest)
            Else
                iManualJournalId = oAddJournalRequest.ManualJournalId
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Update_ManualJournalStatus")
                    cmd.AddInParameter("@manualJournalId", SqlDbType.Int).Value = iManualJournalId
                    cmd.AddInParameter("@is_reffered", SqlDbType.Int).Value = oAddJournalRequest.Is_reffered
                    cmd.AddInParameter("@userId", SqlDbType.Int).Value = _SiriusUser.UserID
                    cmd.AddInParameter("@approved", SqlDbType.Int).Value = oAddJournalRequest.Approved
                    con.ExecuteNonQuery(cmd)
                End Using
            End If

            Dim iTempLength As Integer = oAddJournalRequest.Transactions.Length - 1
            ReDim Preserve oTransArray(iTempLength, 17)
            iRowCounter = 0
            For Each oTransaction In oAddJournalRequest.Transactions
                With oTransaction
                    oTransArray(iRowCounter, 0) = .AccountKey
                    oTransArray(iRowCounter, 1) = .AccountCode
                    oTransArray(iRowCounter, 2) = .CurrencyKey
                    oTransArray(iRowCounter, 3) = .CurrencyCode
                    oTransArray(iRowCounter, 4) = .Amount
                    oTransArray(iRowCounter, 5) = .CurrencyRate
                    oTransArray(iRowCounter, 6) = .BaseAmount
                    oTransArray(iRowCounter, 7) = .AltReference
                    oTransArray(iRowCounter, 8) = .Comment
                    oTransArray(iRowCounter, 9) = .UnderwritingYearKey
                    oTransArray(iRowCounter, 10) = .UnderwritingYear
                    oTransArray(iRowCounter, 11) = .CostCentreKey
                    oTransArray(iRowCounter, 12) = .CostCentreCode
                    oTransArray(iRowCounter, 13) = .InsuranceRef
                    oTransArray(iRowCounter, 14) = .PurchaseOrderNumber
                    oTransArray(iRowCounter, 15) = .PurchaseInvoiceNumber
                    oTransArray(iRowCounter, 16) = .ManualJournalDetailId
                    oTransArray(iRowCounter, 17) = iManualJournalId
                End With
                iRowCounter = iRowCounter + 1
            Next

            Dim iManualJournalDetailid As Integer = Convert.ToInt32(oTransArray(0, 16))

            If (iManualJournalDetailid = 0) Then
                lReturn = SaveManualJournalDetail(con, oTransArray:=oTransArray)
            End If

            Dim oDocumentId As Object = 0
            If (oAddJournalRequest.Is_reffered = 0) Then


                If (Not oAddJournalRequest.JournalBranchCode Is Nothing) AndAlso Trim(oAddJournalRequest.JournalBranchCode).Length > 0 Then
                    JournalBranchId = GetSourceId(oAddJournalRequest.JournalBranchCode)
                Else
                    JournalBranchId = iSourceId
                End If

                If Not bReccurringDocument Then
                    lReturn = oDocPost.AddDocumentTransactions(
                        r_vDocumentID:=oDocumentId,
                        v_lDocumentTypeId:=iJournalTypeId,
                        v_sBranchID:=iSourceId.ToString,
                        v_sComment:=oAddJournalRequest.Comment,
                        v_dtDocumentDate:=oAddJournalRequest.JournalDate,
                        v_vDocSourceID:=JournalBranchId,
                        v_sDocumentRef:=sDocumentRef,
                        v_vOperatorID:=_SiriusUser.UserID,
                        v_vTransArray:=oTransArray,
                        vTransdetailTypeID:=iTransdetailTypeId,
                        v_lSubBranchID:=iSubBranchId)
                    If (lReturn <> PMEReturnCode.PMTrue) Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                            SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                            "bACTDocumentPost.Form.AddDocumentTransactions")
                        oSAMErrorCollection.CheckForErrors()
                    End If

                Else
                    dtLastDate = oAddJournalRequest.JournalDate

                    If oAddJournalRequest.RecurringDetails.PerPeriodOnDay > 0 Then
                        iOffset = oAddJournalRequest.RecurringDetails.PerPeriodOnDay
                        iMonths = 0
                        iNextType = 1
                    ElseIf oAddJournalRequest.RecurringDetails.PerPeriodOnMonth > 0 Then
                        iOffset = oAddJournalRequest.RecurringDetails.PerPeriodOnMonth
                        GetJournalMonthsForward(dtNextDate:=dtLastDate,
                                         iOffset:=iOffset,
                                         iMonths:=iMonths)
                        iNextType = 2
                    ElseIf oAddJournalRequest.RecurringDetails.PerQuarterOnDay > 0 Then
                        iOffset = oAddJournalRequest.RecurringDetails.PerQuarterOnDay
                        GetJournalMonthsForward(dtNextDate:=dtLastDate,
                                                    iOffset:=iOffset,
                                                    iMonths:=iMonths)
                        iNextType = 3
                    End If

                    lReturn = oDocument.GetDatePlusXMonths(
                        v_vCurrentDate:=DateTime.Now(),
                        r_vNextDate:=CStr(dtLastDate),
                        v_vOffset:=iOffset,
                        v_vMonths:=iMonths)
                    If (lReturn <> PMEReturnCode.PMTrue) Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                            SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                            "bACTDocument.Form.GetDatePlusXMonths")
                        oSAMErrorCollection.CheckForErrors()
                    End If

                    lReturn = oDocPost.AddDocumentTransactions(
                               r_vDocumentID:=oDocumentId,
                               v_lDocumentTypeId:=iJournalTypeId,
                               v_sBranchID:=iSourceId.ToString,
                               v_sComment:=oAddJournalRequest.Comment,
                               v_dtDocumentDate:=dtLastDate,
                               v_vDocSourceID:=JournalBranchId,
                               v_sDocumentRef:=sDocumentRef,
                               v_vOperatorID:=_SiriusUser.UserID,
                               v_vTransArray:=oTransArray,
                               vTransdetailTypeID:=iTransdetailTypeId)
                    If (lReturn <> PMEReturnCode.PMTrue) Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                            SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                            "bACTDocumentPost.Form.AddDocumentTransactions")
                        oSAMErrorCollection.CheckForErrors()
                    End If

                    'Dim iRecLoop As Integer
                    'Now insert reoccuring transactions

                    For iRowCounter = 1 To oAddJournalRequest.RecurringDetails.Occurs - 1
                        'Create Document
                        lReturn = oDocument.GenerateDocumentReferenceNumber(
                                     v_sGroupCode:=sGroupCode,
                                     v_sRangeCode:=sRangeCode,
                                     v_iUserID:=CInt(_SiriusUser.UserID),
                                     v_iCompanyID:=CShort(iSourceId),
                                     r_sDocumentRef:=sNumber)
                        If (lReturn <> PMEReturnCode.PMTrue) Then
                            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                                SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                                "bACTDocument.Form.GenerateDocumentReferenceNumber")
                            oSAMErrorCollection.CheckForErrors()
                        End If

                        'sDocumentRef = String.Format("{0}{1:00000000}", sRangeCode, iNumber)

                        sDocumentRef = sRangeCode + sNumber
                        lstDocumentRef.Add(sDocumentRef)

                        lReturn = oDocument.GetDateNext(v_iNextType:=CShort(iNextType),
                                            v_vCurrentDate:=dtLastDate,
                                            v_vOffset:=iOffset,
                                            r_vNextDate:=CObj(dtRecurringDate))
                        If (lReturn <> PMEReturnCode.PMTrue) Then
                            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                                SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                                "bACTDocument.Form.GetDateNext")
                            oSAMErrorCollection.CheckForErrors()
                        End If

                        lReturn = oDocPost.AddDocumentTransactions(
                                r_vDocumentID:=oDocumentId,
                                v_lDocumentTypeId:=iJournalTypeId,
                                v_sBranchID:=iSourceId.ToString,
                                v_sComment:=oAddJournalRequest.Comment,
                                v_dtDocumentDate:=dtRecurringDate,
                                v_vDocSourceID:=JournalBranchId,
                                v_sDocumentRef:=sDocumentRef,
                                v_vOperatorID:=_SiriusUser.UserID,
                                v_vTransArray:=oTransArray,
                                vTransdetailTypeID:=iTransdetailTypeId)
                        If (lReturn <> PMEReturnCode.PMTrue) Then
                            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                                SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                                "bACTDocumentPost.Form.AddDocumentTransactions")
                            oSAMErrorCollection.CheckForErrors()
                        End If

                        dtLastDate = dtRecurringDate
                    Next
                End If

                If bReversingDocument Then
                    'Process reversal document
                    Dim sComment As String

                    sComment = String.Format("Reverses {0}", sDocumentRef)

                    'Reverse the transaction amounts
                    For iRowCounter = 0 To oTransArray.GetUpperBound(0)
                        oTransArray(iRowCounter, 4) = CDbl(oTransArray(iRowCounter, 4)) * -1
                        oTransArray(iRowCounter, 6) = CDbl(oTransArray(iRowCounter, 6)) * -1
                    Next

                    lReturn = oDocument.GenerateDocumentReferenceNumber(
                               v_sGroupCode:=sGroupCode,
                               v_sRangeCode:=sRangeCode,
                               v_iUserID:=CInt(_SiriusUser.UserID),
                               v_iCompanyID:=CShort(iSourceId),
                               r_sDocumentRef:=sNumber)
                    If (lReturn <> PMEReturnCode.PMTrue) Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                            SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                            "bACTDocument.Form.GenerateDocumentReferenceNumber")
                        oSAMErrorCollection.CheckForErrors()
                    End If

                    sDocumentRef = sRangeCode + sNumber
                    lstDocumentRef.Add(sDocumentRef)

                    lReturn = oDocPost.AddDocumentTransactions(
                               r_vDocumentID:=oDocumentId,
                               v_lDocumentTypeId:=iJournalTypeId,
                               v_sBranchID:=iSourceId.ToString,
                               v_sComment:=sComment,
                               v_dtDocumentDate:=oAddJournalRequest.ReversalDetails.ReversesOn,
                               v_vDocSourceID:=JournalBranchId,
                               v_sDocumentRef:=sDocumentRef,
                               v_vOperatorID:=_SiriusUser.UserID,
                               v_vTransArray:=oTransArray)
                    If (lReturn <> PMEReturnCode.PMTrue) Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                            SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                            "bACTDocumentPost.Form.AddDocumentTransactions")
                        oSAMErrorCollection.CheckForErrors()
                    End If
                End If

                If bReccurringDocument Or bReversingDocument Then
                    'POOL the document reference
                    lReturn = oDocument.PoolNumber(
                           v_sGroupCode:=sGroupCode,
                           v_sRangeCode:=sRangeCode,
                           v_iUserID:=CInt(_SiriusUser.UserID),
                           v_iCompanyID:=CShort(iSourceId),
                           r_lNumber:=CInt(sNumber))
                    If (lReturn <> PMEReturnCode.PMTrue) Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                            SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                            "bACTDocument.Form.PoolNumber")
                        oSAMErrorCollection.CheckForErrors()
                    End If
                End If
            Else

            End If
        Catch ex As Exception
            Throw
        Finally
            If oDocument IsNot Nothing Then
                oDocument.Dispose()
                oDocument = Nothing
            End If
            If oDocPost IsNot Nothing Then
                oDocPost.Dispose()
                oDocPost = Nothing
            End If
            If oCurrencyConvert IsNot Nothing Then
                oCurrencyConvert.Dispose()
                oCurrencyConvert = Nothing
            End If
            If oAuditSet IsNot Nothing Then
                oAuditSet.Dispose()
                oAuditSet = Nothing
            End If
        End Try

        oAddJournalResponse.DocumentRef = lstDocumentRef.ToArray
        oAddJournalResponse.ManualJournalId = iManualJournalId

        Return oAddJournalResponse

    End Function


    Private Function SaveManualJournal(ByVal con As SiriusConnection, ByVal oAddJournalRequest As BaseAddJournalRequestType) As Integer
        Dim lReturn As Integer = 0
        Dim iManualJournalId As Integer = 0
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ManualJournal_add")
            cmd.AddOutParameter("@ManualJournal_Id", SqlDbType.Int)
            cmd.AddInParameter("@CreatedDate", SqlDbType.DateTime).Value = oAddJournalRequest.JournalDate
            cmd.AddInParameter("@document_type_id", SqlDbType.Int).Value = oAddJournalRequest.JournalTypeId
            cmd.AddInParameter("@Source_id", SqlDbType.Int).Value = oAddJournalRequest.SourceId

            cmd.AddInParameter("@is_reffered", SqlDbType.Bit).Value = oAddJournalRequest.Is_reffered
            cmd.AddInParameter("@PMuser_id", SqlDbType.Int).Value = _SiriusUser.UserID
            cmd.AddInParameter("@Comment", SqlDbType.VarChar, 500).Value = oAddJournalRequest.Comment
            If (oAddJournalRequest.ReversalDetails IsNot Nothing) Then
                cmd.AddInParameter("@Reverse_on", SqlDbType.DateTime).Value = oAddJournalRequest.ReversalDetails.ReversesOn
            Else
                cmd.AddInParameter("@Reverse_on", SqlDbType.DateTime).Value = DateTime.Now
            End If
            If (oAddJournalRequest.RecurringDetails IsNot Nothing) Then
                cmd.AddInParameter("@Recurring_occurs", SqlDbType.Int).Value = 1

                cmd.AddInParameter("@PerPeriodOnDay", SqlDbType.Int).Value = oAddJournalRequest.RecurringDetails.PerPeriodOnDay
                cmd.AddInParameter("@PerMonthOnDay", SqlDbType.Int).Value = oAddJournalRequest.RecurringDetails.PerPeriodOnMonth
                cmd.AddInParameter("@PerQuarterOnDay", SqlDbType.Int).Value = oAddJournalRequest.RecurringDetails.PerQuarterOnDay

            Else
                cmd.AddInParameter("@Recurring_occurs", SqlDbType.Int).Value = 0

                cmd.AddInParameter("@PerPeriodOnDay", SqlDbType.Int).Value = 0
                cmd.AddInParameter("@PerMonthOnDay", SqlDbType.Int).Value = 0
                cmd.AddInParameter("@PerQuarterOnDay", SqlDbType.Int).Value = 0

            End If
            cmd.AddInParameter("@Authorisation_Comment", SqlDbType.VarChar, 500).Value = ""
            Try
                con.ExecuteNonQuery(cmd)

                iManualJournalId = Cast.ToInt32(cmd.Parameters.Item("@ManualJournal_Id").Value, 0)
                lReturn = iManualJournalId
            Catch ex As Exception
                lReturn = 0
            End Try

        End Using


        Return lReturn

    End Function

    Private Function SaveManualJournalDetail(ByVal con As SiriusConnection, ByRef oTransArray As Object(,)) As Integer
        Dim lReturn As Integer = 0
        Dim iManualJournalDetailId As Integer = 0
        For iRowCounter = 0 To oTransArray.GetUpperBound(0)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ManualJournalDetail_add")
                cmd.AddOutParameter("@ManualJournalDetail_Id", SqlDbType.Int)
                cmd.AddInParameter("@ManualJournal_id", SqlDbType.Int).Value = oTransArray(iRowCounter, 17)
                cmd.AddInParameter("@Account_id", SqlDbType.Int).Value = oTransArray(iRowCounter, 0)
                cmd.AddInParameter("@Amount", SqlDbType.Decimal, 19, 4).Value = oTransArray(iRowCounter, 4)
                cmd.AddInParameter("@Currency_id", SqlDbType.Int).Value = oTransArray(iRowCounter, 2)
                cmd.AddInParameter("@Currency_Rate", SqlDbType.Decimal, 19, 4).Value = oTransArray(iRowCounter, 5)
                cmd.AddInParameter("@Base_Amount", SqlDbType.Decimal, 19, 4).Value = oTransArray(iRowCounter, 6)
                cmd.AddInParameter("@Alternate_ref", SqlDbType.VarChar, 50).Value = oTransArray(iRowCounter, 7)
                cmd.AddInParameter("@Comment", SqlDbType.VarChar, 500).Value = oTransArray(iRowCounter, 8)
                cmd.AddInParameter("@UnderwritingYear_id", SqlDbType.Int).Value = oTransArray(iRowCounter, 9)
                cmd.AddInParameter("@CostCenterId", SqlDbType.Int).Value = oTransArray(iRowCounter, 11)
                cmd.AddInParameter("@Insurance_ref", SqlDbType.VarChar, 30).Value = oTransArray(iRowCounter, 13)
                cmd.AddInParameter("@Purchase_order_No", SqlDbType.VarChar, 40).Value = oTransArray(iRowCounter, 14)
                cmd.AddInParameter("@Purchase_Invoice_No", SqlDbType.VarChar, 40).Value = oTransArray(iRowCounter, 15)
                Try
                    con.ExecuteNonQuery(cmd)
                    iManualJournalDetailId = Cast.ToInt32(cmd.Parameters.Item("@ManualJournalDetail_Id").Value, 0)
                    oTransArray(iRowCounter, 16) = iManualJournalDetailId
                    lReturn = iManualJournalDetailId
                Catch ex As Exception
                    lReturn = 0
                End Try

            End Using
        Next
        Return lReturn

    End Function

    Private Sub GetJournalMonthsForward(ByRef dtNextDate As DateTime,
                ByVal iOffset As Integer,
                ByRef iMonths As Integer)

        Dim iYear As Integer
        Dim iMonth As Integer

        iYear = Year(dtNextDate) - Year(Now)
        iMonth = dtNextDate.Month - Now.Month

        If iMonth > -1 And iYear = 0 Then
            If Day(dtNextDate) > iOffset Then
                iMonths = iMonth + 1
            Else
                iMonths = iMonth
            End If
        Else
            If Day(dtNextDate) > iOffset Then
                iMonths = (iYear * 12) + iMonth + 1
            Else
                iMonths = (iYear * 12) + iMonth
            End If
        End If
    End Sub

    Public Function CountReferAndDecline(ByVal sXMLDataSet As String, ByVal DataModelCode As String) As Integer
        Dim Doc As New XmlDocument
        Dim iCounter As Integer = 0
        Using srDataset As New System.IO.StringReader(sXMLDataSet)
            Using xmlTR As New XmlTextReader(srDataset)

                Doc.Load(xmlTR)
                xmlTR.Close()
            End Using
            srDataset.Close()
        End Using

        Dim oNodes As XmlNodeList = Doc.SelectNodes("//" & DataModelCode & "_OUTPUT[@REFER_REASON]")

        Dim oNode As XmlNode

        For Each oNode In oNodes
            If oNode IsNot Nothing AndAlso oNode.Attributes("US").Value = "1" Then
                iCounter = iCounter + 1
            End If
        Next

        oNodes = Doc.SelectNodes("//" & DataModelCode & "_OUTPUT[@DECLINE_REASON]")
        For Each oNode In oNodes
            If oNode IsNot Nothing AndAlso oNode.Attributes("US").Value = "1" Then
                iCounter = iCounter + 1
            End If
        Next
        CountReferAndDecline = iCounter

    End Function
