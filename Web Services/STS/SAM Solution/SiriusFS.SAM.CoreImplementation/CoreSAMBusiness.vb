                xmlDoc.LoadXml(dsPoliciesForRenewalSelection.GetXml)
                oResponse.Policies = xmlDoc.DocumentElement
            End If

            oResponse.ResultData = dsPoliciesForRenewalSelection
        End Using
        Return oResponse
