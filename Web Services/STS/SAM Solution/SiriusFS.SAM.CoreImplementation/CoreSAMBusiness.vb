            oResponse = AddCashDeposit(conCashDeposit, oAddCashDepositRequest)

            Return oResponse

        End Using

    End Function

    Public Overloads Function AddCashDeposit(ByVal conCashDeposit As SiriusConnection, ByVal oAddCashDepositRequest As BaseAddCashDepositRequestType) As BaseAddCashDepositResponseType
        Dim oAddCashDepositResponse As New BaseAddCashDepositResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage

        If oAddCashDepositRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.AddCashDepositRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oAddCashDepositResponse = New SAMForInsuranceV2ImplementationTypes.AddCashDepositResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        If String.IsNullOrEmpty(oAddCashDepositRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        For Each CashDeposit As BaseCommonCashDepositItemType In oAddCashDepositRequest.CashDeposit
            'Do the business valiation 

            CashDeposit.Validate(CObj(oSAMErrorCollection))
        Next
        oSAMErrorCollection.CheckForErrors()

        '*******************************************************************************************
        'Data Validation
        '*******************************************************************************************

        oAddCashDepositRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
            PMLookupTable.Source, oAddCashDepositRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        For Each CashDeposit As BaseCommonCashDepositItemType In oAddCashDepositRequest.CashDeposit
            ValidateDataCashDepositItem(oSAMErrorCollection, oCoreBusiness, conCashDeposit, CashDeposit)
        Next
        oSAMErrorCollection.CheckForErrors()

        Using conCashDeposit
            conCashDeposit.BeginTransaction()
            Dim iCount As Integer = 0
            Dim bIsLocked As Boolean
            Try
                ' For each row in the request
                oAddCashDepositResponse.CashDeposit = New BaseAddCashDepositResponseTypeCashDeposit
                For Each CashDeposit As BaseCommonCashDepositItemType In oAddCashDepositRequest.CashDeposit

                    If (CashDeposit IsNot Nothing) Then
                        AddCashDepositItem(oSAMErrorCollection, oCoreBusiness, conCashDeposit,
                        CashDeposit)
                        AddCashDepositEvents(oSAMErrorCollection, conCashDeposit, CashDeposit)
                    End If

                    oCoreBusiness.GetSAMTimestamp(
                        oAddCashDepositRequest.BranchCode,
                        CoreBusiness.LockName.CashDepositKey,
                        CashDeposit.CashDepositKey,
                        CashDeposit.CDTimeStamp,
                         bIsLocked)

                    If bIsLocked Then

                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.RecordLockedByAnotherUser,
                                                "The Cash Deposit is already locked by another user.")
                        oSAMErrorCollection.CheckForErrors()
                    End If

                    ' Check that the timestamp matches and put lock on the given renewal status key
                    oCoreBusiness.CheckSAMTSAndLock(Con:=conCashDeposit,
                                                    BranchCode:=oAddCashDepositRequest.BranchCode,
                                                    Lockname:=CoreBusiness.LockName.CashDepositKey,
                                                    LockValue:=CashDeposit.CashDepositKey,
                                                    TStamp:=CashDeposit.CDTimeStamp)

                    ReDim Preserve oAddCashDepositResponse.CashDeposit.Row(iCount)
                    oAddCashDepositResponse.CashDeposit.Row(iCount) = New BaseAddCashDepositResponseTypeCashDepositRow
                    oAddCashDepositResponse.CashDeposit.Row(iCount).CashDepositKey = CashDeposit.CashDepositKey
                    oAddCashDepositResponse.CashDeposit.Row(iCount).CashDepositRef = CashDeposit.CashDepositRef

                    If (CashDeposit.Products IsNot Nothing) Then
                        For Each products As BaseCommonCashDepositItemTypeProducts In CashDeposit.Products
                            AddCashDepositProducts(oSAMErrorCollection, conCashDeposit,
                           products, CashDeposit.CashDepositKey)
                        Next
                    End If
                    If (CashDeposit.Branches IsNot Nothing) Then
                        For Each Branches As BaseCommonCashDepositItemTypeBranches In CashDeposit.Branches
                            AddCashDepositBranches(oSAMErrorCollection, conCashDeposit,
                           Branches, CashDeposit.CashDepositKey)
                        Next
                    End If
                    iCount += 1
                Next

                For Each CashDeposit As BaseCommonCashDepositItemType In oAddCashDepositRequest.CashDeposit
                    oCoreBusiness.UnlockAndGetSAMTS(Con:=conCashDeposit,
                                BranchCode:=oAddCashDepositRequest.BranchCode,
                                Lockname:=CoreBusiness.LockName.CashDepositKey,
                                LockValue:=CashDeposit.CashDepositKey,
                                TStamp:=CashDeposit.CDTimeStamp)
                Next
                conCashDeposit.CommitTransaction()
            Catch ex As Exception

                conCashDeposit.RollbackTransaction()

                Throw

            End Try

        End Using

        Return oAddCashDepositResponse

    End Function

    Private Sub ValidateDataCashDepositItem(ByRef oSAMErrorCollection As SAMErrorCollection, ByVal oCoreBusiness As CoreBusiness, ByVal conCashDeposit As SiriusConnection, ByVal oCashDeposit As BaseCommonCashDepositItemType)

        oCashDeposit.PartyKey = GetAndValidateSpecifiedTableCode(conCashDeposit,
        PMLookupTable.Party, "party_cnt", "shortname", oCashDeposit.PartyCode, oSAMErrorCollection, "PartyCode")

        For Each oBranch As BaseCommonCashDepositItemTypeBranches In oCashDeposit.Branches
            oBranch.BranchKey = GetAndValidateSpecifiedTableCode(conCashDeposit,
            PMLookupTable.Source, "Source_id", "code", oBranch.BranchCode, oSAMErrorCollection, "BranchCode")
        Next

        For Each oProduct As BaseCommonCashDepositItemTypeProducts In oCashDeposit.Products
            oProduct.ProductKey = GetAndValidateSpecifiedTableCode(conCashDeposit,
            PMLookupTable.Product, "Product_id", "code", oProduct.ProductCode, oSAMErrorCollection, "ProductCode")
        Next

    End Sub

