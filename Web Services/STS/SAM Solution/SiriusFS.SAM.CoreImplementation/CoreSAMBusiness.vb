        If oGetWmTaskRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetWmTaskRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetWmTaskResponse = New SAMForInsuranceV2ImplementationTypes.GetWmTaskResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing

        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(oGetWmTaskRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        ' Check mandatory fields
        If oGetWmTaskRequest.TaskInstanceKey = 0 Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "TaskInstanceKey")
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsWmTaskInstance As DataSet = Nothing
        Dim dsWmTask As DataSet = Nothing
        Dim dsTaskKeyResult As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_PMWrk_Task_Instance_sel")
            cmd.AddInParameter("@pmwrk_task_instance_cnt", SqlDbType.Int).Value = oGetWmTaskRequest.TaskInstanceKey
            dsWmTaskInstance = con.ExecuteDataSet(cmd, "TaskInstance")

        End Using

        dsTaskKeyResult = GetTaskInstanceKey(con, oGetWmTaskRequest.TaskInstanceKey)
        If dsTaskKeyResult IsNot Nothing AndAlso (dsTaskKeyResult.Tables(0).Rows.Count >= 1) Then
            Dim xmlDoc As New System.Xml.XmlDocument
            dsTaskKeyResult.DataSetName = "BaseGetWmTaskResponseTypeKeyData"
            With dsTaskKeyResult.Tables(0)
                .TableName = "Row"
                .Columns("name").ColumnName = "KeyName"
                .Columns("key_value").ColumnName = "KeyValue"
            End With
            If oGetWmTaskRequest.WCFSecurityToken = "" Then
                xmlDoc.LoadXml(dsTaskKeyResult.GetXml)
                oGetWmTaskResponse.ResultDataset = xmlDoc.DocumentElement()
            End If
            oGetWmTaskResponse.ResultData = dsTaskKeyResult

        End If
        Dim bIsLocked As Boolean
        Dim AnyError As STSErrorType
        AnyError = oCoreBusiness.GetTimestamp(
                            oGetWmTaskRequest.BranchCode,
                            CoreBusiness.LockName.TaskInstanceCnt,
                            oGetWmTaskRequest.TaskInstanceKey,
                            oGetWmTaskResponse.TaskTimestamp,
                            bIsLocked)
        ' Return AnyErrors
        If AnyError Is Nothing = False Then
            oGetWmTaskResponse.STSError = AnyError
        End If

        oGetWmTaskResponse.TaskInstanceKey = Cast.ToInt32(dsWmTaskInstance.Tables(0).Rows(0).Item("pmwrk_task_instance_cnt"), 0)
        oGetWmTaskResponse.TaskGroupKey = Cast.ToInt32(dsWmTaskInstance.Tables(0).Rows(0).Item("pmwrk_task_group_id"), 0)
        oGetWmTaskResponse.TaskGroupCode = Cast.ToString(dsWmTaskInstance.Tables(0).Rows(0).Item("TaskGroupCode"), "")
        oGetWmTaskResponse.TaskKey = Cast.ToInt32(dsWmTaskInstance.Tables(0).Rows(0).Item("pmwrk_task_id"), 0)
        oGetWmTaskResponse.TaskCode = Cast.ToString(dsWmTaskInstance.Tables(0).Rows(0).Item("TaskCode"), "")
        oGetWmTaskResponse.Customer = Cast.ToString(dsWmTaskInstance.Tables(0).Rows(0).Item("customer"), "")
        oGetWmTaskResponse.DueDate = Cast.ToDateTime(dsWmTaskInstance.Tables(0).Rows(0).Item("task_due_date"), Date.MinValue)
        oGetWmTaskResponse.UserGroupKey = Cast.ToInt32(dsWmTaskInstance.Tables(0).Rows(0).Item("pmuser_group_id"), 0)
        oGetWmTaskResponse.UserGroupCode = Cast.ToString(dsWmTaskInstance.Tables(0).Rows(0).Item("UserGroupCode"), "")
        oGetWmTaskResponse.UserKey = Cast.ToInt32(dsWmTaskInstance.Tables(0).Rows(0).Item("user_id"), 0)
        oGetWmTaskResponse.UserCode = Cast.ToString(dsWmTaskInstance.Tables(0).Rows(0).Item("UserCode"), "")
        oGetWmTaskResponse.Description = Cast.ToString(dsWmTaskInstance.Tables(0).Rows(0).Item("description"), "")
        oGetWmTaskResponse.CreatedByUser = Cast.ToString(dsWmTaskInstance.Tables(0).Rows(0).Item("CreatedByUser"), "")
        oGetWmTaskResponse.ModifiedByUser = Cast.ToString(dsWmTaskInstance.Tables(0).Rows(0).Item("ModifiedByUser"), "")

        If (Cast.ToInt32(dsWmTaskInstance.Tables(0).Rows(0).Item("task_status"), 0) = 0) Then
