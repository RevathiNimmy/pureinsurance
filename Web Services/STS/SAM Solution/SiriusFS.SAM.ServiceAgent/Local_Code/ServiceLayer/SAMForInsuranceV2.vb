                                            oCreditCard.Issue = .Issue

                                            oCreditCard.TrackingNumber = .TrackingNumber

                                            oCreditCard.PartyBankKey = .PartyBankKey

                                        End With
                                        oItem.CreditCard = oCreditCard
                                    End If
                                End With

                                oPaymentItem(cntItems) = oItem
