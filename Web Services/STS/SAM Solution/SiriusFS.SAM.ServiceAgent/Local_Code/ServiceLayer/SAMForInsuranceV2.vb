                oImpRequest.BranchCode = .BranchCode
                oImpRequest.InsuranceFileKey = .InsuranceFileKey
                oImpRequest.ProcessTypeCode = .ProcessTypeCode
                oImpRequest.GenerateDocuments = .GenerateDocuments
            End With

            Try
