    ''' <summary>
    ''' This method converts an error object of type SiriusFS.SAM.Structure.BaseImplementationTypes.SAMError to SiriusFS.
    ''' </summary>
    ''' <param name="oError">Error object of type SiriusFS.SAM.Structure.BaseImplementationTypes.SAMError</param>
    ''' <returns>Error object of type Sirius.Architecture.ExceptionHandling.SAMError</returns>
    ''' <remarks></remarks>
    Private Function ConvertToSFIV2SAMError(ByVal oError As SiriusFS.SAM.Structure.BaseImplementationTypes.SAMError) As SAMError

        Dim oReturnError As SAMError = Nothing

        Select Case oError.GetType.FullName
            Case GetType(SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorInvalidData).FullName
                Dim oSError As SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorInvalidData = DirectCast(oError, SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorInvalidData)
                Dim oDError As New SAMErrorInvalidData
                oDError.Code = oSError.Code
                oDError.Description = oSError.Description
                oDError.FieldName = oSError.FieldName
                oDError.SuppliedValue = oSError.SuppliedValue
                oReturnError = oDError
            Case GetType(SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorBusinessRule).FullName
                Dim oSError As SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorBusinessRule = DirectCast(oError, SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorBusinessRule)
                Dim oDError As New SAMErrorBusinessRule
                oDError.Code = oSError.Code
                oDError.Description = oSError.Description
                oDError.Detail = oSError.Detail
                oReturnError = oDError
            Case GetType(SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorFatal).FullName
                Dim osError As SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorFatal = DirectCast(oError, SiriusFS.SAM.Structure.BaseImplementationTypes.SAMErrorFatal)
                Dim oDError As New SAMErrorFatal
                oDError.Type = osError.Type
                oReturnError = oDError
        End Select

        Return oReturnError
    End Function

