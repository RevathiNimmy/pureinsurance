                                    .Branches(iBranchCount).BranchCode = oAddBankGuaranteeRequest.BankGuarantee(iCount).Branches(iBranchCount).BranchCode
                                    .Branches(iBranchCount).Description = oAddBankGuaranteeRequest.BankGuarantee(iCount).Branches(iBranchCount).Description
                                Next
                            End If
                        End With

                    Next
                End If
            End If

            Try

                ' Call the implementation method
                oImpResponse = oBusiness.AddBankGuarantee(oImpRequest)
                SAMErrorCollection.CheckForErrorsFromSTS(oImpResponse.STSError)

                oResponse.BankGuarantee = New BaseAddBankGuaranteeResponseTypeBankGuarantee

                For iResponseCount As Integer = 0 To oImpResponse.BankGuarantee.Row.Length - 1
                    ReDim Preserve oResponse.BankGuarantee.Row(iResponseCount)
                    oResponse.BankGuarantee.Row(iResponseCount) = New BaseAddBankGuaranteeResponseTypeBankGuaranteeRow
                    With oResponse.BankGuarantee.Row(iResponseCount)
                        .BGKey = oImpResponse.BankGuarantee.Row(iResponseCount).BGKey
                        .BGRef = oImpResponse.BankGuarantee.Row(iResponseCount).BGRef
                        .BGTimeStamp = oImpResponse.BankGuarantee.Row(iResponseCount).BGTimeStamp
                    End With
                Next

            Catch ex As Exception
                Handler.BusinessLayerBoundary(ex, oResponse)
            End Try

            Return oResponse

        Catch ex As Exception
            Handler.BusinessLayerLastResort(ex, Context)
            Return Nothing
        End Try

