    Private Sub ValidateBankAccDetails(ByVal con As SiriusConnection, ByVal mediaTypeCode As String,
                                                ByVal bankCode As String,
                                                ByVal bankName As String,
                                                ByVal bankNumber As String,
                                                ByRef samErrorCollection As SAMErrorCollection)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Check_media_type_Validation")
            cmd.AddInParameter("@Media_type_code", SqlDbType.VarChar, 50).Value = mediaTypeCode
            cmd.AddInParameter("@Media_validation_code", SqlDbType.VarChar, 50)

            con.ExecuteNonQuery(cmd)
            If Cast.ToString(cmd.Parameters.Item("@Media_validation_code")) = "Bank" Then
                If IsNothing(bankCode) Then
                    samErrorCollection.AddBusinessRule(
                                                SAMConstants.SAMBusinessErrors.MediaTypeMandatory,
                                                SAMConstants.SAMBusinessErrors.MediaTypeMandatory.ToString,
                                                "BankAccountCodeMandatory")

                End If

                If IsNothing(bankName) Then

                    samErrorCollection.AddBusinessRule(
                                                SAMConstants.SAMBusinessErrors.MediaTypeMandatory,
                                                SAMConstants.SAMBusinessErrors.MediaTypeMandatory.ToString,
                                                "BankNameMandatory")
                End If
                If IsNothing(bankNumber) Then

                    samErrorCollection.AddBusinessRule(
                                                SAMConstants.SAMBusinessErrors.MediaTypeMandatory,
                                                SAMConstants.SAMBusinessErrors.MediaTypeMandatory.ToString,
                                                "BankAccountNumberMandatory")
                End If

            End If
        End Using

    End Sub

