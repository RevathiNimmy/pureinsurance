    Public Overloads Function PayClaim(ByVal con As SiriusConnection, ByVal oRequest As BaseClaimPaymentRequestType) _
                                           As Object

        ' determine the type of package and thus the type of response
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oResponse As Object = Nothing
        Dim oBusiness As New CoreBusiness(_SiriusUser)
        Dim TimeStamp As Byte()
        '-----------------------------------------------------------------------
        ' Validation Block
        '-----------------------------------------------------------------------
        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection

        GetVersionId(oRequest.ClaimPayment.BaseClaimPerilKey,
                        oRequest.ClaimPayment.VersionId,
                        con)

        Dim sOptionValue As String = String.Empty
        'Create GetProductRiskOptions request
        Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType

        'Get the product id
        Dim dsProductId As DataSet = Nothing
        Dim iProductId As Integer
        'Getting the product id from insurance file count 
        GetInsFileCntProductId(con:=con,
                                lInsuranceFileCnt:=oRequest.ClaimPayment.InsuranceFileCNT,
                                dsProductId:=dsProductId,
                                lBaseClaimID:=oRequest.ClaimPayment.BaseClaimKey)
        If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
        AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso dsProductId.Tables(0).Rows(0).Item("product_id") IsNot Nothing AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
            iProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
        Else
            'Failed to get the product id from the given base claim key
            oSAMErrorCollection.AddInvalidData(
                                    SAMConstants.SAMInvalidData.GeneralFailure,
                                    "Failed to get product details for the given policy")

            oSAMErrorCollection.CheckForErrors()
        End If
        Dim SourceId As Integer

        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If
        If oRequest.ClaimPayment.CashList IsNot Nothing Then
            oRequest.ClaimPayment.CashList.SourceID = SourceId
        End If
        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsAdvancedTaxScriptEnabled

        sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If
        If oRequest.ClaimPayment.CashList IsNot Nothing Then
            If oRequest.ClaimPayment.CashList.CurrencyKey = 0 Then
                oRequest.ClaimPayment.CashList.CurrencyKey = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                    PMLookupTable.Currency, oRequest.ClaimPayment.CashList.CurrencyCode, "CurrencyCode", oSAMErrorCollection)
            End If
        End If
        oRequest.ClaimPayment.AdvanceScript = sOptionValue

        '************************
        ' Structure Validation
        '************************

        ' validate the mandatory data in the structure
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        ' if there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        '************************
        ' Data Validation
        '************************

        ' validate the data provided in the structure
        PayClaimValidateData(con, oBusiness, oRequest, oSAMErrorCollection)

        ' get the details for the last version of the specified claim so we can perform further validation
        ' of the request
        Dim oClaimDetails As New BaseAdditionalClaimRelatedDetails

        ' get details for the claim 
        GetClaimDetailsForPaymentOrReceipt(con,
                oRequest.ClaimPayment.ClaimId,
                oRequest.ClaimPayment.ClaimPerilId,
                oClaimDetails)

        ' further pay claim data validation
        FurtherClaimPaymentDataValidation(oRequest, oClaimDetails, oBusiness, oSAMErrorCollection)

        ' if there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        '************************
        ' Business Rule Validation
        '************************

        'validate the request structure against the specified business rules
        PayClaimValidateBusinessRules(con, oRequest.ClaimPayment, oClaimDetails, oSAMErrorCollection)

        'if there were any business rule errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        ' Retrieve the system options, Id's from codes
        oRequest.ClaimPayment.CurrencyId = oBusiness.GetListItemFromCode _
        (Core.STSListType.PMLookup, PMLookupTable.Currency, oRequest.ClaimPayment.CurrencyCode)

        ' Retrieve the system options, Id's from codes
        If oRequest.ClaimPayment.Payee IsNot Nothing Then
            If String.IsNullOrEmpty(oRequest.ClaimPayment.Payee.MediaTypeCode) = False Then
                oRequest.ClaimPayment.Payee.MediaTypeId = oBusiness.GetListItemFromCode _
                (Core.STSListType.PMLookup, PMLookupTable.MediaType, oRequest.ClaimPayment.Payee.MediaTypeCode)
            End If
        End If

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsGrossClaimPaymentAmount

        sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If

        oRequest.ClaimPayment.ClaimPaymentIsGross = sOptionValue

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.AllowNegativeReserve

        sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If

        oRequest.ClaimPayment.AllowNegativeReserve = sOptionValue
        oRequest.ClaimPayment.ClaimNumber = oClaimDetails.Claim.ClaimNumber

        ' Check the Type of Request and process it interface accordingly
        ' Their can be two kind of requests
        ' 1 - Complete Payment of claim Request
        ' 2 - Build the Taxes response and send it to the user and no transaction will be processed in this case

        If Not oRequest.IsDataTransferClaim Then
            If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.PayClaimRequestType) Or
            oRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.PayClaimRequestType) Or
            oRequest.GetType Is GetType(BaseImplementationTypes.BaseClaimPaymentRequestType) Then

                DeleteDirtyClaims(con, oRequest.ClaimPayment.BaseClaimKey)
                ' check timestamp and lock

                oBusiness.CheckSAMTSAndLock(con, oRequest.BranchCode,
                    CoreBusiness.LockName.ClaimId,
                    oRequest.ClaimPayment.BaseClaimKey,
                    oRequest.TimeStamp)
            End If
        End If


        If oRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.PayClaimRequestType) Or
            oRequest.GetType Is GetType(BaseImplementationTypes.BaseClaimPaymentRequestType) Then ' Process 1'st kind of Request

            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.PayClaimResponseType

            If Not oRequest.IsDataTransferClaim Then
                con.BeginTransaction()
            End If

            Try

                oResponse = ProcessPayClaim(con, oRequest, oSAMErrorCollection)
                oResponse = DirectCast(oResponse, SAMForInsuranceImplementationTypes.PayClaimResponseType)
                If Not oRequest.IsDataTransferClaim Then
                    con.CommitTransaction()
                End If

            Catch

                If Not oRequest.IsDataTransferClaim Then
                    con.RollbackTransaction()
                End If

                If Not oRequest.IsDataTransferClaim Then

                    ' unlock and get the new timestamp
                    oBusiness.UnlockAndGetSAMTS(
                        con,
                        oRequest.BranchCode,
                        CoreBusiness.LockName.ClaimId,
                        oRequest.ClaimPayment.BaseClaimKey,
                         TimeStamp)
                End If


                Throw

            End Try

        ElseIf oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.PayClaimRequestType) Then

            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package

            'Saurabh ------- Changrd SAMForInsuranceImplementationTypes to SAMForInsuranceV2ImplementationTypes
            oResponse = New SAMForInsuranceV2ImplementationTypes.PayClaimResponseType

            If Not oRequest.IsDataTransferClaim Then
                con.BeginTransaction()
            End If

            Try

                oResponse = ProcessPayClaim(con, oRequest, oSAMErrorCollection)

                If Not oRequest.IsDataTransferClaim Then
                    con.CommitTransaction()
                End If

            Catch

                If Not oRequest.IsDataTransferClaim Then
                    con.RollbackTransaction()
                End If

                If Not oRequest.IsDataTransferClaim Then

                    ' unlock and get the new timestamp
                    oBusiness.UnlockAndGetSAMTS(
                        con,
                        oRequest.BranchCode,
                        CoreBusiness.LockName.ClaimId,
                        oRequest.ClaimPayment.BaseClaimKey,
                         TimeStamp)
                End If

                Throw

            End Try

        Else ' Process 2'nd kind of request
            oResponse = New SAMForInsuranceImplementationTypes.GetClaimPaymentTaxesResponseType

            oResponse = ProcessGetTaxDetails(con, oRequest, oSAMErrorCollection)

        End If

        If Not oRequest.IsDataTransferClaim Then
            If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.PayClaimRequestType) Or
                oRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.PayClaimRequestType) Or
                oRequest.GetType Is GetType(BaseImplementationTypes.BaseClaimPaymentRequestType) Then
                ' unlock and get the new timestamp
                oBusiness.UnlockAndGetSAMTS(
                    con,
                    oRequest.BranchCode,
                    CoreBusiness.LockName.ClaimId,
                    oRequest.ClaimPayment.BaseClaimKey,
                     TimeStamp)
            End If
        End If

        If oRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.PayClaimRequestType) Or
          oRequest.GetType Is GetType(BaseImplementationTypes.BaseClaimPaymentRequestType) Then ' Process 1'st kind of Request
            CType(oResponse, SAMForInsuranceImplementationTypes.PayClaimResponseType).TimeStamp = TimeStamp
        ElseIf oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.PayClaimRequestType) Then
            CType(oResponse, SAMForInsuranceV2ImplementationTypes.PayClaimResponseType).TimeStamp = TimeStamp
        End If

        Return oResponse

    End Function

    ''' <summary>
    ''' Validates the claim payment request type
    ''' </summary>
    '''<param name="con">An object of SiriusConnection class</param>
