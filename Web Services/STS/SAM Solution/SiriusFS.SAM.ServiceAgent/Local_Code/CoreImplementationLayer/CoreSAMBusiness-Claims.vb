    ''' <summary>
    ''' GetClaimNumber - returns the claim number 
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <remarks></remarks>
    Private Sub GetClaimNumber(ByVal con As SiriusConnection,
                        ByVal OpenClaimRequest As BaseClaimOpenRequestType)

        Dim ds As DataSet = Nothing
        Dim sProductCode As String = String.Empty
        Dim lBusinessType As Integer
        Dim lNumberingSchemeId As Integer

        Const kProvisionalClaim As Integer = 3
        Const kLiveClaim As Integer = 4

        ' determine which numbering scheme we need to use
        If OpenClaimRequest.Claim.InfoOnly Then
            lBusinessType = kProvisionalClaim
        Else
            lBusinessType = kLiveClaim
        End If

        ' get the numbering schemes for the specified product 
        GetNumberingSchemeForProductAndBusinessType(
                                    con,
                                    OpenClaimRequest.Claim.ProductId,
                                    lBusinessType,
                                    lNumberingSchemeId,
                                    sProductCode)

        Dim bUseAutoGenerateNumber As Boolean
        Dim sMaskCode As String = String.Empty
        Dim sFixedCode As String = String.Empty
        Dim lNextNumber As Integer
        Dim bReuseAbandonedNumbers As Boolean
        Dim bIsResetNumber As Boolean
        Dim lPeriodID As Integer
        Dim sAcocuntingYear As String = String.Empty

        ' get the details of the selected numbering scheme
        GetNumberingScheme(con, lNumberingSchemeId, _SiriusUser.LanguageID, bUseAutoGenerateNumber,
                            sMaskCode, sFixedCode, lNextNumber, bReuseAbandonedNumbers, bIsResetNumber)

        Dim sNumberToAllocate As String = String.Empty

        If bUseAutoGenerateNumber Then
            sNumberToAllocate = sMaskCode
        Else
            ' at the moment we dont support auto generated number
            Dim oSAMErrorCollection As New SAMErrorCollection
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.AutoClaimNumberingDisabled,
                                                SAMBusinessErrors.AutoClaimNumberingDisabled.ToString)
            oSAMErrorCollection.CheckForErrors()
        End If

        ' include product code in generated number
        If InStr(sNumberToAllocate, "P") <> 0 Then
            InsertCodeIntoNumber(sMaskCode, sProductCode.ToUpper(), "P", sNumberToAllocate)
        End If

        ' include agent file code in generated number
        If (InStr(sMaskCode, "A") <> 0) Then
            Dim sAgentFileCode As String = String.Empty
            If OpenClaimRequest.Claim.AgentCnt <> 0 Then
            sAgentFileCode = GetAgentFileCode(con, OpenClaimRequest.Claim.AgentCnt)
            Else
                sAgentFileCode = ""
            End If
            InsertCodeIntoNumber(sMaskCode, sAgentFileCode.ToUpper(), "A", sNumberToAllocate)
        End If

        ' include claim date in generated number
        If (InStr(sMaskCode, "L") <> 0) Or (InStr(sMaskCode, "R") <> 0) Then

            Dim sCode As String = String.Empty
            Dim sClaimMask As String = String.Empty
            sCode = ""
            If (InStr(sMaskCode, "L") <> 0) Then
                sClaimMask = "L"
                sCode = OpenClaimRequest.Claim.LossFromDate.Year.ToString
            Else
                sClaimMask = "R"
                sCode = OpenClaimRequest.Claim.ReportedDate.Year.ToString
            End If

            InsertCodeIntoNumber(sMaskCode, sCode, sClaimMask, sNumberToAllocate)

        End If

        ' include branch code in generated number
        If (InStr(sMaskCode, "B") <> 0) Then
            InsertCodeIntoNumber(sMaskCode, OpenClaimRequest.BranchCode.ToUpper(), "B", sNumberToAllocate)
        End If

        ' include fixed code in generated number
        If InStr(sMaskCode, "X") <> 0 Then
            InsertCodeIntoNumber(sMaskCode, sFixedCode, "X", sNumberToAllocate)
        End If

        If InStr(sMaskCode, "Y") <> 0 Then
            InsertCodeIntoNumber(sMaskCode, Date.Today.ToString, "Y", sNumberToAllocate)
        End If

        If InStr(sMaskCode, "U") <> 0 Then
            'Get the accounting period year for the transaction date
            GetPeriodForDate(con, OpenClaimRequest.Claim.SourceId, Date.Now, lPeriodID, sAcocuntingYear)

            'If no period id returned, raise error
            If lPeriodID = 0 Then
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.NoAccountingPeriodDefinedForTheSelectedDate,
                                                    SAMBusinessErrors.NoAccountingPeriodDefinedForTheSelectedDate.ToString)
                oSAMErrorCollection.CheckForErrors()
            End If
            InsertCodeIntoNumber(sMaskCode, sAcocuntingYear, "U", sNumberToAllocate)

            If bIsResetNumber Then
                'Get the next number according to accounting period
                Dim iPeriodNextNumber As Integer
                GetPeriodNextNumber(con, lNumberingSchemeId, sAcocuntingYear, iPeriodNextNumber)

                If iPeriodNextNumber = 0 Then
                    'Failed to get the next number. Raise Error.
                    Dim oSAMErrorCollection As New SAMErrorCollection
                    oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.FailedToGetNextNumberForTheSelectedAccountingPeriod,
                                                        SAMBusinessErrors.FailedToGetNextNumberForTheSelectedAccountingPeriod.ToString)
                    oSAMErrorCollection.CheckForErrors()
                Else
                    lNextNumber = iPeriodNextNumber
                End If

                'Increment the next number for given accounting period in database
                IncrementPeriodNextNumber(con, lNumberingSchemeId, sAcocuntingYear)
            End If
        End If
        Dim sNumber As String = String.Empty
        sNumber = lNextNumber.ToString

        ' include the next number in generated number
        InsertCodeIntoNumber(sMaskCode, sNumber, "9", sNumberToAllocate)

        ' return the generated claim number
        OpenClaimRequest.Claim.ClaimNumber = sNumberToAllocate

    End Sub

