    ''' <summary>
    ''' sets default for values which are optional in the request and were not passed
    ''' from the previous version of the claim
    ''' </summary>
    ''' <param name="oClaim"></param>
    ''' <remarks></remarks>
    Private Sub SetupUpdateDefaults(ByVal oClaim As BaseClaimType)

        ' Update request to include defaults for values 
        ' not provided within the requests optional fields

        '**** MAY BE OVERRIDEN BY VALUES IN THE REQUEST ****

        ' default client contacts 
        '(NB: These values will be overriden by those in the request if there are values in the request)
        oClaim.ClientTelNo = oClaim.PreviousClientTelNo
        oClaim.ClientFaxNo = oClaim.PreviousClientFaxNo
        oClaim.ClientMobileNo = oClaim.PreviousClientMobileNo
        oClaim.ClientEmail = oClaim.PreviousClientEmail
        oClaim.ClientTelNoOff = oClaim.PreviousClientTelNoOff
        '***************************************************

        ' there is no agent on the policy so clear agent details
        If oClaim.AgentCnt = 0 Then

            oClaim.InsurerAddressId = 0
            oClaim.InsurerEmail = String.Empty
            oClaim.InsurerFaxNo = String.Empty
            oClaim.InsurerTelNo = String.Empty

            If oClaim.Insurer IsNot Nothing Then
                oClaim.Insurer.ContactName = String.Empty
                oClaim.Insurer.PartyClaimNumber = String.Empty
            End If

        Else

            '**** MAY BE OVERRIDEN BY VALUES IN THE REQUEST ****

            ' default insurer contacts
            '(NB: These values will be overriden by those in the request if there are values in the request)
            oClaim.InsurerEmail = oClaim.PreviousInsurerEmail
            oClaim.InsurerFaxNo = oClaim.PreviousInsurerFaxNo
            oClaim.InsurerTelNo = oClaim.PreviousInsurerTelNo

            '***************************************************

        End If

        ' if the following values are not specified in the request
        ' then use the previous results in the update statement
        If oClaim.UserDefFldACode Is Nothing Then
            oClaim.UserDefFldAId = oClaim.PreviousUserDefFldAId
        End If

        If oClaim.UserDefFldBCode Is Nothing Then
            oClaim.UserDefFldBId = oClaim.PreviousUserDefFldBId
        End If

        If oClaim.UserDefFldCCode Is Nothing Then
            oClaim.UserDefFldCId = oClaim.PreviousUserDefFldCId
        End If

        If oClaim.UserDefFldDCode Is Nothing Then
            oClaim.UserDefFldDId = oClaim.PreviousUserDefFldDId
        End If

        If oClaim.UserDefFldECode Is Nothing Then
            oClaim.UserDefFldEId = oClaim.PreviousUserDefFldEId
        End If

        If oClaim.SecondaryCauseCode Is Nothing Then
            oClaim.SecondaryCauseId = oClaim.PreviousSecondaryCauseId
        End If

        If oClaim.CatastropheCode Is Nothing Then
            oClaim.CatastropheId = oClaim.PreviousCatastropheCodeid
        End If

        If oClaim.Location Is Nothing Then
            oClaim.Location = oClaim.PreviousLocation
        End If

        If oClaim.TownCode Is Nothing Then
            oClaim.TownId = oClaim.PreviousTownId
        End If

        If oClaim.Comments Is Nothing Then
            oClaim.Comments = oClaim.PreviousComments
        End If

    End Sub

    Private Sub ProcessMaintainClaim(ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal oRequest As BaseClaimMaintainRequestType,
    ByVal oResponse As BaseClaimResponseType)

        ' get insurance file details from the original claim 
        GetInsuranceFileDetails(con, oRequest.Claim)

        ' setup the defaults for fields which havent been passed in the original request
        ' with values from the previous version of the claim
        SetupUpdateDefaults(oRequest.Claim)

        'If oRequest.Claim.Client IsNot Nothing Then
        '    ' get the client contacts from the request
        '    GetContactDetails(con, oBusiness, oRequest.Claim, oRequest.Claim.Client.Contact, False)
        'End If

        'If oRequest.Claim.Insurer IsNot Nothing AndAlso oRequest.Claim.AgentCnt <> 0 Then
        '    ' get the insurer contacts from the request
        '    GetContactDetails(con, oBusiness, oRequest.Claim, oRequest.Claim.Insurer.Contact, True)
        'End If

		'Delete all dirty claims
        DeleteDirtyClaims(con, oRequest.Claim.BaseClaimKey)

        If Not oRequest.IsDataTransferClaim Then
            ' check timestamp and lock
            oBusiness.CheckSAMTSAndLock(con, oRequest.BranchCode,
                CoreBusiness.LockName.ClaimId,
                oRequest.Claim.BaseClaimKey,
                oRequest.TimeStamp)
        End If


        
        If Not oRequest.IsDataTransferClaim Then
            con.BeginTransaction()
        End If

        Try

            ' default the claim version description is the data hasnt been provided
            If String.IsNullOrEmpty(oRequest.Claim.ClaimVersionDescription) Then
                If String.IsNullOrEmpty(oRequest.Claim.Description) Then
                    oRequest.Claim.ClaimVersionDescription = "Maintained Claim"
                Else
                    oRequest.Claim.ClaimVersionDescription = oRequest.Claim.Description
                End If
            Else
                oRequest.Claim.ClaimVersionDescription = oRequest.Claim.ClaimVersionDescription
            End If


            ' copy the claim and all related objects :- retrieve the claim id and version id
            ProcessCopyClaim(con, oRequest.Claim.BaseClaimKey, oRequest.Claim.SourceId,
                             TransactionTypeCode.MaintainClaim, _SiriusUser.UserID,
                              oRequest.Claim.ClaimId, oRequest.Claim.VersionId,
                               oRequest.IsDataTransferClaim, oRequest.DataTransferClaimHasClaimRiskDataSpecified, oRequest.DataTransferIsUsingFullClaimVersioning, oRequest)

            If oRequest.Claim.Client IsNot Nothing Then
                ' save the claims address
                UpdateClaimAddress(con, oBusiness, oRequest.BranchCode, oRequest.Claim.ClientAddressId, oRequest.Claim.Client.Address)
            End If

            If oRequest.Claim.Insurer IsNot Nothing Then
                ' only if there is an agent on the policy
                If oRequest.Claim.AgentCnt <> 0 Then
                    ' save the claims insurer address if it is any different
                    UpdateClaimAddress(con, oBusiness, oRequest.BranchCode, oRequest.Claim.InsurerAddressId, oRequest.Claim.Insurer.Address)
                End If
            End If

            ' update the claim details
            UpdateClaim(con, oBusiness, oRequest)

            Dim bBalanceAndCloseClaim As Boolean = False
            If oRequest.Claim.ReserveOnly = False Then
                bBalanceAndCloseClaim = GetBalanceAndCloseClaimStatus(con, oRequest.Claim)
            End If

            ' if the claim is info only then finish processing at this point
            If Not oRequest.Claim.InfoOnly Then

                ' balance and close the claim 
                If bBalanceAndCloseClaim Then

                    ' balance the claims reserves and recoveries
                    ProcessBalanceAndCloseClaim(con, oBusiness, oRequest)

                Else

                    ' preprocess the claim perils - adds any new claim perils that are needed
                    PreprocessClaimPerils(con, oBusiness, TransactionTypeCode.MaintainClaim,
                            oRequest.Claim, oRequest.Claim.ClaimPeril)

                    ' if this process is being called via the data transfer
                    ' create the sirius peril - samstaging peril links
                    If oRequest.IsDataTransferClaim Then
                        CreateDataTransferClaimPerilLinks(con, oRequest.Claim.ClaimPeril)
                    End If

                    ' update the claim peril details
                    If oRequest.Claim.ReserveOnly = True Then
                        UpdateClaimPerilDetails(con, oBusiness, TransactionTypeCode.MaintainClaim,
                            oRequest.Claim, oRequest.Claim.ClaimPeril, True)
                    Else
                        UpdateClaimPerilDetails(con, oBusiness, TransactionTypeCode.MaintainClaim,
                            oRequest.Claim, oRequest.Claim.ClaimPeril, oRequest.IsDataTransferClaim)
                    End If
                    ' just return the response
                    ' populate response object
                    PopulateMaintainClaimResponseObject(oBusiness, oRequest, oResponse)
                        'For maintain claim, transaction type code in database is C_CR
                        Const ksTransactionType As String = "C_CR"
                        ProcessClaimsCoinsurance(con, oBusiness, oRequest.Claim.ClaimId, ksTransactionType, oRequest.BranchCode)

                    Dim oGetProductRiskOptionValueRequest As New BaseProductRiskOptionValueRequestType
                    Dim oGetProductRiskOptionValueResponse As New BaseProductRiskOptionValueResponseType
                    oGetProductRiskOptionValueRequest.BranchCode = oRequest.BranchCode
                    oGetProductRiskOptionValueRequest.ProductCode = oRequest.Claim.ProductCode
                    oGetProductRiskOptionValueRequest.RiskTypeOption = RiskTypeOptions.IsAutoReinsured
                    oGetProductRiskOptionValueRequest.ActionType = ProductConfigActionType.RiskTypeMaintenance
                    Dim dtRiskType As DataTable

                    If oRequest.Claim.RiskKey > 0 Then
                        Using cmd As SiriusCommand = SiriusCommand.FromText("select rt.code from risk r join risk_type rt on r.risk_type_id=rt.risk_type_id where risk_cnt=" + Convert.ToString(oRequest.Claim.RiskKey))
                            dtRiskType = con.ExecuteDataTable(cmd)
                        End Using
                        oGetProductRiskOptionValueRequest.RiskTypeCode = Convert.ToString(dtRiskType.Rows.Item(0)(0)).Trim()
                        oGetProductRiskOptionValueRequest.RiskTypeOptionSpecified = True
                        oGetProductRiskOptionValueResponse = GetProductRiskOptionValue(oGetProductRiskOptionValueRequest)
                    End If
                    If Not oRequest.DataTransferClaimHasSpecifiedReinsurance And (oGetProductRiskOptionValueResponse IsNot Nothing AndAlso oGetProductRiskOptionValueResponse.ProductRiskOptionValue = "1") Then
                            ' process reinsurance
                            ProcessClaimsReinsurance(con, oRequest.Claim.ClaimId, 0)
                    ElseIf oGetProductRiskOptionValueResponse Is Nothing Then
                        ProcessClaimsReinsurance(con, oRequest.Claim.ClaimId, 0)
                        End If

                    End If

                If oRequest.Claim.ReserveOnly = False Then
                    ' if reserves and recoveries are not balanced ensure that the 
                    ' claim status is not set to "closed"
                    ValidateClaimStatus(con, oBusiness, oRequest.Claim)

                    ' finalise the claim details
                    FinaliseClaimDetails(con, oRequest.Claim.ClaimId, oRequest.Claim.ClaimVersionDescription)

                    ' create default claim event
                    CreateDefaultClaimEvent(con, oRequest.Claim.InsuranceHolderCnt,
                                                    oRequest.Claim.InsuranceFolderCnt,
                                                     oRequest.Claim.InsuranceFileKey,
                                                      oRequest.Claim.ClaimId,
                                                       TransactionTypeCode.MaintainClaim,
                                                        _SiriusUser.UserID,
                                                         oRequest.Claim.ClaimVersionDescription)

                    ' if the claim dates have changed between this version of the claim 
                    ' and the previous version
                    CreateEventClaimDatesHaveChanged(con, oRequest.Claim)

                    ' Create External Handler Task If Required
                    CreateTaskExternalClaimHandler(con, oBusiness, oRequest.BranchCode, oRequest)

                    ' Update Insurance File System
                    UpdateInsuranceFileSystem(con, _SiriusUser.UserID,
                                                oRequest.Claim.InsuranceFileKey,
                                                    TransactionTypeCode.OpenClaim)

                    ' do not process transactions if this is a data transfer claim
                    ' these are done by another data transfer process
                    If Not oRequest.IsDataTransferClaim Then
                        ' Raise the transactions
                        RaiseTransactions(con, oRequest.Claim.ClaimId, _
                                            oRequest.Claim.TransactionTypeId, _
                                              TransactionTypeCode.MaintainClaim, _
                                                oRequest.Claim.PaymentSuppressReserves, _
                                                 oRequest.Claim.CurrencyId)
                    End If

                    ' ensure that the maintained version of the claim is also on claims builder
                    ' if the original version is
                    SetupClaimGisDetails(con, oRequest.Claim.ClaimId, oRequest.Claim.BaseClaimKey)

                    oResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                        (con, oRequest.Claim.ClaimId, oRequest.Claim.CloseClaimOnZeroReserveRecoveryBalance)
                    ' Update Claim Is Dirty Flag 
                    UpdateClaimIsDirtyFlag(con, oRequest.Claim.ClaimId, InternalSAMConstants.kClaimProcessed)
                End If
                ' Populate response object
                PopulateMaintainClaimResponseObject(oBusiness, oRequest, oResponse)


            End If
            If oRequest.Claim.InfoOnly Then
                If bBalanceAndCloseClaim Then
                    ' balance the claims reserves and recoveries
                    ' set claim status to closed
                    Dim lClosedClaimStatusId As Integer = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.ClaimStatus, ClaimStatus.Closed, "ClaimStatusCode")
                    UpdateClaimStatus(con, oRequest.Claim.ClaimId, lClosedClaimStatusId)

                End If
                ' Update Claim Is Dirty Flag to indicate that the open claim process has completed
                UpdateClaimIsDirtyFlag(con, oRequest.Claim.ClaimId, InternalSAMConstants.kClaimProcessed)
                ' Populate response object
                PopulateMaintainClaimResponseObject(oBusiness, oRequest, oResponse)


            End If
            If Not oRequest.IsDataTransferClaim Then
                con.CommitTransaction()
            End If

            If Not oRequest.IsDataTransferClaim Then

                ' unlock and get the new timestamp
                oBusiness.UnlockAndGetSAMTS(
                    con,
                    oRequest.BranchCode,
                    CoreBusiness.LockName.ClaimId,
                    oRequest.Claim.BaseClaimKey,
                     oResponse.TimeStamp)
            End If


        Catch ex As Exception

            If Not oRequest.IsDataTransferClaim Then
                con.RollbackTransaction()
            End If

            If Not oRequest.IsDataTransferClaim Then

                ' unlock and get the new timestamp
                oBusiness.UnlockAndGetSAMTS(
                    con,
                    oRequest.BranchCode,
                    CoreBusiness.LockName.ClaimId,
                    oResponse.BaseClaimKey,
                     oResponse.TimeStamp)
            End If


            Throw
        End Try



    End Sub

    Private Sub SetupClaimGisDetails(ByVal con As SiriusConnection, ByVal ClaimId As Integer, ByVal BaseClaimId As Integer)
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_SetupClaimGisDetails")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = ClaimId
            cmd.AddInParameter("@base_claim_id", SqlDbType.Int).Value = BaseClaimId
            con.ExecuteNonQuery(cmd)
        End Using

    End Sub

