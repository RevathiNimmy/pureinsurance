    ''' <summary>
    '''This function will fetch the claim versions based on ClaimKey
    '''</summary>
    '''<param name="oRequest" type="BaseGetVersionsForClaimRequestType"></param>    
    '''<remarks></remarks>
    Public Function GetVersionsForClaim(ByVal oRequest As BaseGetVersionsForClaimRequestType) As BaseGetVersionsForClaimResponseType

        Dim oResponse As New BaseImplementationTypes.BaseGetVersionsForClaimResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim oSamErrorsCollection As New SAMErrorCollection
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Dim lClaimId As Integer
            Dim lSourceId As Integer
            Dim typeOfPackage As enumTypeOfPackage

            If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetVersionsForClaimRequestType) Then
                typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
                oResponse = New SAMForInsuranceV2ImplementationTypes.GetVersionsForClaimResponseType
            End If

            '*********************
            ' STRUCTURE VALIDATION
            '*********************
            'Check Mandatory Fields
            If oRequest.BranchCode = "" Then
                oSamErrorsCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, oRequest.BranchCode)
            End If

            oRequest.Validate(CObj(oSamErrorsCollection))

            oSamErrorsCollection.CheckForErrors()

            ' Lookup Codes to ensure they are valid
            If Not String.IsNullOrEmpty(oRequest.BranchCode) Then
                lSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSamErrorsCollection)
            End If
            If oRequest.BaseClaimKey = 0 Then
                'validate the ClaimNumber number 
                If Not String.IsNullOrEmpty(oRequest.ClaimKey) Then
                    lClaimId = GetAndValidateSpecifiedTableCode(con,
                    "claim", "claim_id", "claim_number",
                    oRequest.ClaimKey, oSamErrorsCollection, "ClaimKey")
                End If
            Else
                lClaimId = oRequest.BaseClaimKey
            End If
            oSamErrorsCollection.CheckForErrors()

            'Get Base/original Claim_id
            Dim nBaseClaimid As Integer = 0
            Dim bTimestamp() As Byte
            Dim bIscurrentlyLocked As Boolean
            nBaseClaimid = GetBaseClaimID(con, lClaimId)
            If nBaseClaimid = 0 Then nBaseClaimid = lClaimId

            'Get Timestamp of claim and check if claim is locked before
            oCoreBusiness.GetSAMTimestamp(oRequest.BranchCode, CoreBusiness.LockName.ClaimId, nBaseClaimid, bTimestamp, bIscurrentlyLocked)
            If bIscurrentlyLocked Then oResponse.IsPreviouslyLocked = True

            ' Dataset that will hold the returned results		
            Dim dsGetClaimDetails As DataSet = Nothing
            Using cmdGetClaimDetails As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Claim_Version_Details")

                cmdGetClaimDetails.AddInParameter("@claim_id", SqlDbType.Int).Value = lClaimId

                dsGetClaimDetails = con.ExecuteDataSet(cmdGetClaimDetails, "Row")

            End Using
            dsGetClaimDetails.DataSetName = "BaseGetVersionsForClaimResponseTypeVersions"

            If oRequest.WCFSecurityToken = "" Then
            Dim xmlDoc As New System.Xml.XmlDocument
            xmlDoc.LoadXml(dsGetClaimDetails.GetXml)
            oResponse.ResultDataset = xmlDoc.DocumentElement()
            End If
            oResponse.ResultData = dsGetClaimDetails
        End Using
        Return oResponse

    End Function

    Public Function FindInsuranceFileForClaimsVersion2(ByVal oRequest As BaseFindInsuranceFileRequestType) _
    As BaseFindInsuranceFileResponseType

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Return FindInsuranceFileForClaimsVersion2(con, oRequest)

        End Using

    End Function

    Public Function FindInsuranceFileForClaimsVersion2(ByRef con As SiriusConnection,
            ByVal oRequest As BaseFindInsuranceFileRequestType) As BaseFindInsuranceFileResponseType
        Dim oBusiness As New CoreBusiness
        Dim oResponse As New SAMForInsuranceV2ImplementationTypes.FindInsuranceFileForClaimsResponseType
        Dim nTypeOfPackage As enumTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
        Dim oSAMErrorCollection As New SAMErrorCollection

        ' STRUCTURE VALIDATION
        'Check Mandatory Fields
        If oRequest.BranchCode = "" Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, oRequest.BranchCode)
        End If

        If oRequest.LossDate <= Date.MinValue Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, oRequest.LossDate.ToString)
        End If
        oSAMErrorCollection.CheckForErrors()

        ' validate the branch code
        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        'Validate The Cover Note Sheet Number
        Dim bCheckForCoverNoteSheetNumber As Boolean
        If (oRequest.CoverNoteSheetNumberSpecified AndAlso oRequest.CoverNoteSheetNumber <> 0) Then
            bCheckForCoverNoteSheetNumber = CheckCoverNoteSheetNumber(oRequest.CoverNoteSheetNumber)
        End If
        oSAMErrorCollection.CheckForErrors()

        'Get Agent Group Details if AgentKey is provided
        With oRequest
            If (.AgentKey <> 0) Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Agent_Group_From_Agent_Key")
                    cmd.AddOutParameter("@agent_group_cnt", SqlDbType.Int)
                    cmd.AddInParameter("@agent_cnt", SqlDbType.Int).Value = .AgentKey

                    con.ExecuteNonQuery(cmd)
                    .AgentGroupKey = Cast.ToInt32(cmd.Parameters("@agent_group_cnt").Value, 0)
                End Using
            End If
        End With

        'Create the object to the component to get the InsuranceFile Details
        Dim oBackOfficeLinkBusiness As bBackOfficeLink.bBOLink
        'Create the object to the component  bBackOfficeLink.bBOLink
        oBackOfficeLinkBusiness = New bBackOfficeLink.bBOLink

        'Check the RisIndex for its Null value. If the RiskIndex is null then it will call  the function 
        'ProcessRiskIndexBaseInsuranceFileSearchForClaims otherwise it will call the funciton "ProcessRInsuranceFileSearchForClaims"
        If Not String.IsNullOrEmpty(oRequest.RiskIndex) Then
            oResponse = ProcessRiskIndexBaseInsuranceFileSearchForClaims _
            (oBackOfficeLinkBusiness, oRequest)
        Else
            oResponse = ProcessInsuranceFileSearchForClaims(oBackOfficeLinkBusiness, oRequest)
        End If

        'It will destroy the memory occupied by the com component
        If oBackOfficeLinkBusiness IsNot Nothing Then
            oBackOfficeLinkBusiness.Dispose()
            oBackOfficeLinkBusiness = Nothing
        End If

        Return oResponse
    End Function

    Private Function ProcessRiskIndexBaseInsuranceFileSearchForClaims(ByVal _
                                                                oBackOfficeLinkBusiness As bBackOfficeLink.bBOLink,
            ByRef oRequest As BaseFindInsuranceFileRequestType) _
            As SAMForInsuranceV2ImplementationTypes.FindInsuranceFileForClaimsResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim iReturn As Integer
        Dim oGISSearchDataArray As Object = Nothing
        Dim lComReturnValue As Integer
        Dim oComOutputData As Object(,) = Nothing
        Dim oResponse As New SAMForInsuranceV2ImplementationTypes.FindInsuranceFileForClaimsResponseType

        iReturn = CInt(oBackOfficeLinkBusiness.Initialise(
                              _SiriusUser.Username,
                              _SiriusUser.Password,
                              _SiriusUser.UserID,
                              _SiriusUser.SourceID,
                              _SiriusUser.LanguageID,
                              _SiriusUser.CurrencyID,
                              1,
                              SiriusUserDefaults.AppName))

        'This funciton is used to  collect the details related to the RiskIndex
        Dim oGISSearchDataArray1(,) As Object = CType(oGISSearchDataArray, Object(,))
        With oRequest
            lComReturnValue = oBackOfficeLinkBusiness.FindLikeIndex(sIndex:= .RiskIndex,
                    lNumberOfRecords:=500, vResultArray:=oGISSearchDataArray1, v_vAgentGroupCnt:=CByte(.AgentGroupKey))
        End With
        oGISSearchDataArray = CType(oGISSearchDataArray1, Object)
        If (lComReturnValue <> PMReturnCode.PMTrue) Then
            RaiseComMethodException("oBackOfficeLinkBusiness.FindLikeIndex", lComReturnValue)
        End If

        lComReturnValue = oBackOfficeLinkBusiness.GetUWPolicyByGISSearchIndex(oGISSearchDataArray,
                            oComOutputData, oRequest.InsuranceRef, oRequest.ClientShortName,
                           oRequest.PostCode, CStr(IIf((CBool(oRequest.InForceFromSpecified)) And oRequest.InForceFrom > Date.MinValue, oRequest.InForceFrom, Nothing)),
                           CStr(IIf((CBool(oRequest.InForceToSpecified)) And oRequest.InForceTo > Date.MinValue, oRequest.InForceTo, Nothing)), CStr(oRequest.LossDate), oRequest.CoverNoteSheetNumber, v_lNumbersOfRecords:=oRequest.MaxRowsToFetch, bRetrieveAssociates:=oRequest.RetrieveAssociates)
        If (lComReturnValue <> PMReturnCode.PMTrue) Then
            RaiseComMethodException("oBackOfficeLinkBusiness.GetUWPolicyByGISSearchIndex", lComReturnValue)
        End If

        Dim dsInsuranceFile As New DataSet
        'Convert the object into the DataSet
        dsInsuranceFile = Utilities.ArrayToDataSet(oComOutputData)
        Dim dsResultInsuranceFile As New DataSet
        If dsInsuranceFile IsNot Nothing Then
            If dsInsuranceFile.Tables.Count >= 1 Then
                If (dsInsuranceFile.Tables(0).Rows.Count >= 1) Then
                    dsResultInsuranceFile.Tables.Add()
                    dsResultInsuranceFile.Tables(0).Columns.Add("InsuranceFileKey", GetType(System.Int32))
                    dsResultInsuranceFile.Tables(0).Columns.Add("InsuranceRef", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("ProductCode", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("RenewalDate", GetType(System.DateTime))
                    dsResultInsuranceFile.Tables(0).Columns.Add("RiskIndex", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("ClientShortName", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("ClientName", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("ClientAddressLine1", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("ClientPostCode", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("LeadAgentKey", GetType(System.Int32))
                    dsResultInsuranceFile.Tables(0).Columns.Add("InsuranceFileStatusCode", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("CoverFrom", GetType(System.DateTime))
                    dsResultInsuranceFile.Tables(0).Columns.Add("CoverTo", GetType(System.DateTime))
                    dsResultInsuranceFile.Tables(0).Columns.Add("LeadAgentName", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("InceptionDate", GetType(System.DateTime))
                    dsResultInsuranceFile.Tables(0).Columns.Add("InsuranceFileTypeCode", GetType(System.String))
                    dsResultInsuranceFile.Tables(0).Columns.Add("LapseDate", GetType(System.DateTime))
                    dsResultInsuranceFile.Tables(0).Columns.Add("AllowedClosedBranchClaims", GetType(System.Int32))
                    dsResultInsuranceFile.Tables(0).Columns.Add("StatusId", GetType(System.Int32))
                    dsResultInsuranceFile.Tables(0).Columns.Add("IsSourceClosed", GetType(System.Int32))

                    dsResultInsuranceFile.Tables(0).Columns.Add("AssociatedClients", GetType(System.String))
                    If oRequest.RetrieveAssociates Then
                        dsResultInsuranceFile.Tables(0).Columns("AssociatedClients").ReadOnly = False
                        AddExtraXMLElementForPolicyAssociate(dsResultInsuranceFile, "AssociatedClients")
                    End If
                    Dim iCount As Integer
                    For iCount = 0 To dsInsuranceFile.Tables(0).Rows.Count - 1
                        'Data are extracted from the DataSet and put it into corresponding objects
                        With dsInsuranceFile.Tables(0).Rows(iCount)
                            'Note:Ideally we should fetch the data using column names 
                            'but as we havenot got the column names we are using the column index.
                            dsResultInsuranceFile.Tables(0).Rows.Add()
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("InsuranceFileKey") = StringDataConvert.ToInt32(dsInsuranceFile.Tables(0).Rows(iCount)(0), 0)
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("ClientShortName") = dsInsuranceFile.Tables(0).Rows(iCount)(1).ToString()
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("InsuranceRef") = dsInsuranceFile.Tables(0).Rows(iCount)(2).ToString()
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("RiskIndex") = dsInsuranceFile.Tables(0).Rows(iCount)(3).ToString()
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("ProductCode") = dsInsuranceFile.Tables(0).Rows(iCount)(4).ToString()
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("ClientPostCode") = dsInsuranceFile.Tables(0).Rows(iCount)(7).ToString()
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("ClientName") = dsInsuranceFile.Tables(0).Rows(iCount)(9).ToString()
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("ClientAddressLine1") = dsInsuranceFile.Tables(0).Rows(iCount)(8).ToString()
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("LeadAgentKey") = StringDataConvert.ToInt32(dsInsuranceFile.Tables(0).Rows(iCount)(13), 0)
                            If IsDBNull(dsInsuranceFile.Tables(0).Rows(iCount)(23)) Then
                                dsResultInsuranceFile.Tables(0).Rows(iCount)("AllowedClosedBranchClaims") = 0
                            Else
                                dsResultInsuranceFile.Tables(0).Rows(iCount)("AllowedClosedBranchClaims") = Convert.ToInt32(dsInsuranceFile.Tables(0).Rows(iCount)(23))
                            End If

                            If (StringDataConvert.ToDateTime(dsInsuranceFile.Tables(0).Rows(iCount)(10), Date.MinValue) > Date.MinValue) Then
                                dsResultInsuranceFile.Tables(0).Rows(iCount)("RenewalDate") =
                                StringDataConvert.ToDateTime(.Item(10), Nothing)
                            End If
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("InsuranceFileStatusCode") = dsInsuranceFile.Tables(0).Rows(iCount)(15).ToString
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("CoverFrom") = dsInsuranceFile.Tables(0).Rows(iCount)(16)
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("CoverTo") = dsInsuranceFile.Tables(0).Rows(iCount)(17)
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("LeadAgentName") = dsInsuranceFile.Tables(0).Rows(iCount)(18).ToString
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("StatusId") = IIf(Convert.ToString(dsInsuranceFile.Tables(0).Rows(iCount)(14)) = "", 0, dsInsuranceFile.Tables(0).Rows(iCount)(14))
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("IsSourceClosed") = IIf(Convert.ToString(dsInsuranceFile.Tables(0).Rows(iCount)(11)) = "", 0, dsInsuranceFile.Tables(0).Rows(iCount)(11))
                            dsResultInsuranceFile.Tables(0).Rows(iCount)("AssociatedClients") = Trim(dsInsuranceFile.Tables(0).Rows(iCount).Item(24).ToString)

                        End With
                    Next
                End If
            End If
            If oRequest.RetrieveAssociates Then
                dsResultInsuranceFile.Tables(0).Columns("AssociatedClients").ReadOnly = False
                AddExtraXMLElementForPolicyAssociate(dsResultInsuranceFile, "AssociatedClients")
            End If
            dsResultInsuranceFile.DataSetName = "BaseFindInsuranceFileResponseTypeInsuranceFileDetails"
            dsResultInsuranceFile.Tables(0).TableName = "Row"

            If oRequest.WCFSecurityToken = "" Then
                Dim xmlDoc As New System.Xml.XmlDocument
            xmlDoc.LoadXml(dsResultInsuranceFile.GetXml)
            If (dsInsuranceFile.Tables.Count >= 1) Then
                oResponse.ResultDataset = xmlDoc.DocumentElement()
            End If
            End If
            oResponse.ResultData = dsResultInsuranceFile
        Else
            oResponse.ResultDataset = Nothing
            oResponse.ResultData = Nothing
        End If
        Return oResponse
    End Function

