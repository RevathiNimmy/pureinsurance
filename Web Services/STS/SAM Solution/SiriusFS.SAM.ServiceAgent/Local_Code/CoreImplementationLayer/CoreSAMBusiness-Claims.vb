    Private Sub SaveReceiptToAccounts(
    ByVal con As SiriusConnection,
                                       ByVal Request As BaseClaimReceiptRequestType,
    Optional ByVal bExcludeTax As Boolean = False)

        Dim AccountId As Integer
        Dim ShortCode As String = String.Empty
        Dim PartyCnt As Integer
        Dim DocumentComment As String = String.Empty

        Dim ClaimReceipt As BaseClaimReceiptType = Request.ClaimReceipt
        Dim AdditionalDetails As BaseAdditionalClaimRelatedDetails = ClaimReceipt.AdditionalDetails

        Dim StatsFolderCnt As Integer
        Dim DocumentTypeID As Integer = ACTConst.ACTDocTypeClaimReceipt
        Dim ReceiptAmountGross As Decimal = 0
        Dim ReceiptAmountNet As Decimal = 0
        Dim ReceiptTaxAmount As Decimal = 0
        Dim transactionType As String = ClaimReceipt.TransactionTypeCode

        ' not sure why this is 28 at this point?
        ' but it is changed back to the correct transaction type id at the end
        ' of the process by a call to spu_CLM_Finalise_stats
        Dim TransactionTypeID As Integer = 28

        If transactionType = TransactionTypeCode.ThirdPartyRecovery Then
            DocumentComment = "TP Recovery for Claim Number :=" & AdditionalDetails.Claim.ClaimNumber
        ElseIf transactionType = TransactionTypeCode.SalvageRecovery Then
            DocumentComment = "Salvage for Claim Number :=" & AdditionalDetails.Claim.ClaimNumber
        End If

        ReceiptAmountGross = ClaimReceipt.TotalReceiptAmountGross
        ReceiptAmountNet = ClaimReceipt.TotalReceiptAmountNet
        ReceiptTaxAmount = ClaimReceipt.TotalReceiptTaxAmount

        PartyCnt = ClaimReceipt.PartyKey

        ' if there is a valid class of business code
        If Not String.IsNullOrEmpty(AdditionalDetails.ClaimPeril.ClassOfBusinessCode) Then
            Dim TaxAmountsByType As DataTable = GetTaxAmountsByTaxType(con, ClaimReceipt.ClaimReceiptId, 0)
            Dim iRecoveryPartyKey As Integer
            Dim TaxAmount As Decimal
            Dim TaxTypeCode As String = String.Empty
            Dim CreditAccountCode As String = String.Empty
            For Each receiptItem As BaseClaimReceiptItemType In Request.ClaimReceipt.ReceiptItem
                If bExcludeTax = True Then
                    ReceiptAmountGross = receiptItem.ReceiptAmount + receiptItem.TotalTaxAmount
                    ReceiptAmountNet = receiptItem.ReceiptAmount
                    ReceiptTaxAmount = receiptItem.TotalTaxAmount
                Else
                ReceiptAmountGross = receiptItem.ReceiptAmount
                ReceiptAmountNet = receiptItem.ReceiptAmount - receiptItem.TotalTaxAmount
                ReceiptTaxAmount = receiptItem.TotalTaxAmount
                End If

                Dim oSAMErrorCollection As New SAMErrorCollection
                If Not String.IsNullOrEmpty(receiptItem.RecoveryPartyCode) Then
                    ShortCode = receiptItem.RecoveryPartyCode
                    iRecoveryPartyKey = GetAndValidateSpecifiedTableCode(con, "Party", "party_cnt", "shortname",
                                receiptItem.RecoveryPartyCode, oSAMErrorCollection, "RecoveryPartycode")
                    oSAMErrorCollection.CheckForErrors()
                    AccountId = GetAccountID(con, iRecoveryPartyKey, ShortCode)

                Else
                    ShortCode = Request.ReceiptPartyShortCode
                    AccountId = Request.ReceiptPartyAccountId
                    iRecoveryPartyKey = GetAndValidateSpecifiedTableCode(con, "Party", "party_cnt", "shortname",
                                Request.ReceiptPartyShortCode, oSAMErrorCollection, "RecoveryPartycode")

                End If

                StatsFolderCnt = AddClaimsStatsFolder(
                                        con,
                                        AdditionalDetails.InsuranceFile.InsuranceFileKey,
                                        InternalSAMConstants.kCredit,
                                        DocumentComment,
                                        TransactionTypeID,
                                        transactionType,
                                        _SiriusUser.UserID,
                                        _SiriusUser.Username,
                                        ClaimReceipt.ClaimId,
                                        DocumentTypeID)

                Dim TransactionAmount As Decimal

                ' the amount to post depends on whether tax is to be posted seperately
                If AdditionalDetails.Risk.PostTaxEntriesSeparately Then
                    TransactionAmount = ReceiptAmountNet
                Else
                    TransactionAmount = ReceiptAmountGross
                End If

                AddClaimsStatsDetail(con:=con,
                                    lStatsFolderCnt:=StatsFolderCnt,
                                    lClaimId:=ClaimReceipt.ClaimId,
                                    lClaimPerilId:=ClaimReceipt.ClaimPerilId,
                                    sStatsDetailType:="GRS",
                                    lClassOfBusinessId:=AdditionalDetails.ClaimPeril.ClassOfBusinessId,
                                    sClassOfBusinessCode:=AdditionalDetails.ClaimPeril.ClassOfBusinessCode,
                                    lRIPartyCnt:=iRecoveryPartyKey,
                                    sRIShortname:=ShortCode,
                                    lRIPartyType:=0,
                                    dRISharePercent:=0,
                                    crTransactionAmount:=TransactionAmount,
                                    lDocumentTypeId:=DocumentTypeID)

                If ReceiptTaxAmount <> 0 AndAlso
                    AdditionalDetails.Risk.PostTaxEntriesSeparately AndAlso
                        TaxAmountsByType IsNot Nothing AndAlso
                            TaxAmountsByType.Rows.Count > 0 Then

                    AddClaimsStatsDetail(
                            con,
                            StatsFolderCnt,
                            ClaimReceipt.ClaimId,
                            ClaimReceipt.ClaimPerilId,
                            "TAG",
                            AdditionalDetails.ClaimPeril.ClassOfBusinessId,
                            AdditionalDetails.ClaimPeril.ClassOfBusinessCode,
                            iRecoveryPartyKey,
                            ShortCode,
                            0,
                            0,
                            ReceiptTaxAmount,
                            DocumentTypeID)
                    'Create a TAN Entry alongwith TAG otherwise stats folder count will miss out in the collection and 
                    'it will create tax amount in last stats folder count. 
                    ' get the tax type details
                    TaxTypeCode = receiptItem.TaxCalculationItem.Item(0).TaxBandCode
                    TaxAmount = receiptItem.TaxCalculationItem.Item(0).TaxValue

                    ' Insert stats details records for Tax (One gross line for each tax type)
                    If TaxAmount <> 0 Then

                        ' set tan / tag account code
                        CreditAccountCode = "NOTA" & TaxTypeCode & "IN"

                        AddClaimsStatsDetail(con:=con,
                                                    lStatsFolderCnt:=StatsFolderCnt,
                                                    lClaimId:=ClaimReceipt.ClaimId,
                                                    lClaimPerilId:=ClaimReceipt.ClaimPerilId,
                                                    sStatsDetailType:="TAN",
                                                    lClassOfBusinessId:=AdditionalDetails.ClaimPeril.ClassOfBusinessId,
                                                    sClassOfBusinessCode:=AdditionalDetails.ClaimPeril.ClassOfBusinessCode,
                                                    lRIPartyCnt:=0,
                                                    sRIShortname:=CreditAccountCode,
                                                    lRIPartyType:=0,
                                                    dRISharePercent:=0,
                                                    crTransactionAmount:=-TaxAmount,
                                                    lDocumentTypeId:=DocumentTypeID)

                    End If
                End If
            Next
        Else

            Dim oSAMErrorCollection As New SAMErrorCollection
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.PostingOfReceiptToAccountsFailedMissingClassOfBusinessCode,
                SAMBusinessErrors.PostingOfReceiptToAccountsFailedMissingClassOfBusinessCode.ToString(),
                "SaveReceiptsToAccounts Failed - No Class Of Business Code Available")
            oSAMErrorCollection.CheckForErrors()

        End If

    End Sub

