    ''' <summary>
    ''' creates the default claim event
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="lInsuranceHolderCnt"></param>
    ''' <param name="lInsuranceFolderCnt"></param>
    ''' <param name="lInsuranceFileCnt"></param>
    ''' <param name="lClaimId"></param>
    ''' <param name="sTransactionType"></param>
    ''' <param name="lUserId"></param>
    ''' <param name="sEventDescription"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function CreateDefaultClaimEvent(ByVal con As SiriusConnection,
                                   ByVal lInsuranceHolderCnt As Integer,
                                    ByVal lInsuranceFolderCnt As Integer,
                                      ByVal lInsuranceFileCnt As Integer,
                                        ByVal lClaimId As Integer,
                                         ByVal sTransactionType As String,
                                          ByVal lUserId As Integer,
                                    ByVal sEventDescription As String,
                                    Optional ByVal sClaimStatus As String = "") As Integer

        Dim lEventCnt As Integer
        Dim sDescriptionToUse As String = String.Empty

        ' default event type
        Dim sEventTypeCode As String = EventTypeCode.ClaimChanged

        Select Case sTransactionType
            Case TransactionTypeCode.OpenClaim
                sDescriptionToUse = "Opened Claim"
                ' override default event type only for open claim
                sEventTypeCode = EventTypeCode.NewClaim
            Case TransactionTypeCode.MaintainClaim
                sDescriptionToUse = "Maintained Claim"
            Case TransactionTypeCode.PayClaim
                sDescriptionToUse = "Payment Of Claim"
            Case TransactionTypeCode.ThirdPartyRecovery
                sDescriptionToUse = "Third Party Recovery"
        End Select

        Select Case sClaimStatus
            Case EventTypeCode.ClaimAuthorise
                sEventTypeCode = EventTypeCode.ClaimAuthorise
            Case EventTypeCode.ClaimDecline
                sEventTypeCode = EventTypeCode.ClaimDecline
            Case EventTypeCode.ClaimRecommend
                sEventTypeCode = EventTypeCode.ClaimRecommend
        End Select

        ' override default claim event description is a value is passed
        If Not String.IsNullOrEmpty(sEventDescription) Then
            sDescriptionToUse = sEventDescription
        End If

        ' create default claim event
        CreateEvent(con,
                    lInsuranceHolderCnt,
                    lInsuranceFolderCnt,
                    lInsuranceFileCnt,
                    lClaimId,
                    Nothing, Nothing, Nothing, Nothing, Nothing, Nothing, Nothing,
                    lUserId,
                    Date.Now,
                    sDescriptionToUse,
                    Nothing, Nothing, sEventTypeCode, Nothing, Nothing, Nothing,
                    Nothing, Nothing, Nothing,
                    lEventCnt)

        Return lEventCnt

    End Function
    ''' <summary>
    ''' Recalculate Tax Amounts on basis of currency,this Receipt , Tax group Change
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="lCompanyID"></param>
    ''' <param name="lTaxGroupId"></param>
    ''' <param name="sTranstype"></param>
    ''' <param name="lCurrencyId"></param>
    ''' <param name="lLossCurrencyId"></param>
    ''' <param name="crAmount"></param>
    ''' <param name="lClaimPerilId"></param>
    ''' <param name="lClaimId"></param>
    ''' <param name="lClaimPaymentId"></param>
    ''' <param name="lClaimReceiptId "></param>
    ''' <param name="lClaimPaymentItemId"></param>
    ''' <param name="lClaimReceiptItemId"></param>
    ''' <param name="lCalculateOnly"></param>
    ''' <param name="oTaxBandDetails"></param>
    ''' <param name="crTaxCurrencyAmount"></param>
    ''' <param name=" crTaxLossAmount"></param>
    ''' <param name="crTaxBaseAmount "></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Sub CalculateTaxAmounts(ByVal con As SiriusConnection,
                                ByVal lCompanyId As Integer,
                                ByVal lTaxGroupId As Integer,
                                ByVal sTranstype As String,
                                ByVal lCurrencyId As Integer,
                                ByVal lLossCurrencyId As Integer,
                                ByVal crAmount As Decimal,
                                ByRef crTaxCurrencyAmount As Decimal,
                                ByRef crTaxLossAmount As Decimal,
                                ByRef crTaxBaseAmount As Decimal,
                                ByVal lClaimPerilId As Integer,
                                ByVal lClaimPaymentId As Integer,
                                ByVal lClaimReceiptId As Integer,
                                ByVal lClaimPaymentItemId As Integer,
                                ByVal lClaimReceiptItemId As Integer,
                                ByVal lCalculateOnly As Integer,
                                ByRef oTaxBandDetails As DataSet,
                                Optional ByVal nGetSavedTaxOfPeril As Integer = 0)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Calculate_Tax_Amounts")

            If lClaimPaymentId <> 0 Then
                cmd.AddInParameter("@claim_payment_id", SqlDbType.Int).Value = lClaimPaymentId
            End If

