                                                ByVal iClaimPaymentDocumentKey As Integer)

        oPaymentItem.AllocationDetails = New BaseAllocationType
        oPaymentItem.AllocationDetails.AutoAllocate = True
        If oPaymentItem.AccountKey = 0 Then
            oPaymentItem.AccountKey = iClaimPaymentAccountKey
        End If
        GetTransForAllocationForDocument(con, oPaymentItem, iClaimPaymentAccountKey, iClaimPaymentDocumentKey)
    End Sub

