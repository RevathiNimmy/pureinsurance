    Private Sub ClaimReceiptValidateData(
    ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByRef ClaimReceiptRequest As BaseClaimReceiptRequestType,
    ByRef oSAMErrorCollection As SAMErrorCollection)

        '***************************
        ''' validate standard lookup data
        '***************************

        ClaimReceiptValidateDataStandardLookup(oBusiness, ClaimReceiptRequest, oSAMErrorCollection)

        '**************************
        ''' validate other data
        '**************************
        ClaimReceiptValidateDataOther(con, oBusiness, ClaimReceiptRequest, oSAMErrorCollection)

    End Sub

    Private Sub ClaimReceiptValidateDataStandardLookup(
    ByVal oBusiness As CoreBusiness,
    ByRef oRequest As BaseClaimReceiptRequestType,
    ByRef oSAMErrorCollection As SAMErrorCollection)

        '*********************
        'mandatory
        '*********************

        ' branch code
        oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        ' Currency Code
        oRequest.ClaimReceipt.CurrencyId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, oRequest.ClaimReceipt.CurrencyCode, "CurrencyCode", oSAMErrorCollection)

        '*********************
        ' optional
        '*********************

        ' Payee Media Type
        If (String.IsNullOrEmpty(oRequest.ClaimReceipt.Payee.MediaTypeCode) = False) Then
            oRequest.ClaimReceipt.Payee.MediaTypeId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.MediaType, oRequest.ClaimReceipt.Payee.MediaTypeCode, "MediaTypeCode", oSAMErrorCollection)
        End If

        ' Address Country Code
        If (oRequest.ClaimReceipt.Payee.Address IsNot Nothing AndAlso oRequest.ClaimReceipt.Payee.Address.CountryCode IsNot Nothing) Then
            oRequest.ClaimReceipt.Payee.Address.CountryId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Country, oRequest.ClaimReceipt.Payee.Address.CountryCode, "CountryCode", oSAMErrorCollection)
        End If

    End Sub

    Private Sub ClaimReceiptValidateDataOther(
    ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByRef Request As BaseClaimReceiptRequestType,
    ByRef oSAMErrorCollection As SAMErrorCollection)

        ' validate claim receipt keys

        ' validate specified recovery exists on specified peril which exists on specified claim
        ' NB This function also sets the claim id / claim peril id to those of the last version 
        ' of the claim to aid further validation
        ClaimReceiptValidateDataLinks(con, Request, oSAMErrorCollection)

        ' Tax Group Code
        For Each ClaimReceiptItem As BaseClaimReceiptItemType In Request.ClaimReceipt.ReceiptItem
            If Not String.IsNullOrEmpty(ClaimReceiptItem.TaxGroupCode) Then
                ClaimReceiptItem.TaxGroupId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.TaxGroup, ClaimReceiptItem.TaxGroupCode, "TaxGroupCode", oSAMErrorCollection)
            Else
                ClaimReceiptItem.TaxGroupId = Nothing
            End If
        Next

        ' validate that the selected tax group is appropriate
        ValidateClaimReceiptTaxGroup(Request, oSAMErrorCollection, Request.ClaimReceipt.TransactionTypeCode)

    End Sub

    Private Sub ClaimReceiptValidateBusinessRules(
                                ByVal oBusiness As CoreBusiness,
                                    ByRef ClaimReceiptRequest As BaseClaimReceiptRequestType,
                                    ByRef oSAMErrorCollection As SAMErrorCollection, ByVal con As SiriusConnection)

        '*************************************************************************
        'Check for Info Only Claim
        '*************************************************************************
        ValidateClaimReceiptInfoOnly(con, CInt(ClaimReceiptRequest.ClaimReceipt.BaseClaimKey), oSAMErrorCollection)

        '*************************************************************************
        'Check for Advanced Tax Scripting
        '*************************************************************************
        ValidateAdvScriptOn(ClaimReceiptRequest, oSAMErrorCollection)

    End Sub

    Private Sub ValidateAdvScriptOn(
    ByVal ClaimReceiptRequest As BaseClaimReceiptRequestType,
    ByRef oSAMErrorCollection As SAMErrorCollection)

        If ClaimReceiptRequest.ClaimReceipt.IsAdvancedTaxSystemOptionOn AndAlso ClaimReceiptRequest.ClaimReceipt.ReceiptItem(0).TaxGroupAdvancedTaxScript IsNot Nothing AndAlso ClaimReceiptRequest.ClaimReceipt.ReceiptItem(0).TaxGroupAdvancedTaxScript.Length > 0 Then

            If ClaimReceiptRequest.ClaimReceipt.AdvancedTaxDetails IsNot Nothing Then

                If ClaimReceiptRequest.ClaimReceipt.AdvancedTaxDetails.InsuredDomiciled = True Then

                    If Not ClaimReceiptRequest.ClaimReceipt.AdvancedTaxDetails.InsuredPercentageSpecified AndAlso
                         (ClaimReceiptRequest.ClaimReceipt.AdvancedTaxDetails.InsuredPercentage > 0) AndAlso
                         String.IsNullOrEmpty(ClaimReceiptRequest.ClaimReceipt.AdvancedTaxDetails.InsuredTaxNumber) Then

                        oSAMErrorCollection.AddBusinessRule(
                         SAMBusinessErrors.UseOfAdvancedTaxScriptRequiresMandatoryInsurerTaxNumber,
                         SAMBusinessErrors.UseOfAdvancedTaxScriptRequiresMandatoryInsurerTaxNumber.ToString,
                         "The Insured Tax Number is required when a tax percentage is supplied ( > 0) and the insured is domiciled")

                        oSAMErrorCollection.CheckForErrors()
                    End If
                End If
            End If

        End If

    End Sub

    Private Sub ValidateClaimPaymentInfoOnly(ByVal con As SiriusConnection, ByVal BaseClaimKey As Integer,
       ByVal oSAMErrorCollection As SAMErrorCollection)

        If IsInfoOnlyClaim(con, BaseClaimKey) Then

