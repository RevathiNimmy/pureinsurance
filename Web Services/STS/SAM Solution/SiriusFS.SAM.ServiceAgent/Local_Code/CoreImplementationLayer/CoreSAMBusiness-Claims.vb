    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function GetClaimDetails(ByVal con As SiriusConnection,
                                     ByVal oBusiness As CoreBusiness,
                                     ByVal oOpenClaimRequest As BaseClaimOpenRequestType) As Integer

        Dim bInfoOnly As Boolean

        ' returns the transaction type details 
        GetTransactionType(con, TransactionTypeCode.OpenClaim,
                                oOpenClaimRequest.Claim.TransactionTypeId,
                                 oOpenClaimRequest.Claim.TransactionTypeDescription)

        ' get insurance file details
        GetInsuranceFileDetails(con, oOpenClaimRequest.Claim)

        ' get the client details
        GetClientDetails(con, oBusiness, oOpenClaimRequest)

        ' only get insurer details if there is an agent specified on the policy
        If oOpenClaimRequest.Claim.AgentCnt <> 0 Then
            ' get the insurers details
            GetInsurerDetails(con, oBusiness, oOpenClaimRequest)
        End If

        bInfoOnly = oOpenClaimRequest.Claim.InfoOnly

        ' determine the claim status
        If bInfoOnly Then
            oOpenClaimRequest.Claim.ClaimStatusId = oBusiness.GetAndValidateListItemFromCode(
                                                        Core.STSListType.PMLookup,
                                                            PMLookupTable.ClaimStatus,
                                                                ClaimStatus.ProvisionalOpenClaim, "ClaimStatusCode")
        Else
            oOpenClaimRequest.Claim.ClaimStatusId = oBusiness.GetAndValidateListItemFromCode(
                                                        Core.STSListType.PMLookup,
                                                            PMLookupTable.ClaimStatus,
                                                                ClaimStatus.LiveOpenClaim, "ClaimStatusCode")
        End If

        If oOpenClaimRequest.IsDataTransferClaim Then
            If String.IsNullOrEmpty(oOpenClaimRequest.Claim.ClaimNumber) Then
                ' get a default claim number for the data transfer claim
                GetClaimNumber(con, oOpenClaimRequest)
            End If
        Else
            If String.IsNullOrEmpty(oOpenClaimRequest.Claim.ClaimNumber) Then
                GetClaimNumber(con, oOpenClaimRequest)
            Else
                'Claim Number is provided to SAM so check for valid Claim Number
                If oOpenClaimRequest.Claim.IgnoreClaimNumberValidation = False Then
                    CheckClaimNumber(con, oOpenClaimRequest)
                End If
            End If
        End If

    End Function

    ''' <summary>
    ''' Claim Number is provided to SAM so check for valid Claim Number
    ''' </summary>
    Private Sub CheckClaimNumber(ByVal con As SiriusConnection,
                        ByVal OpenClaimRequest As BaseClaimOpenRequestType)

        Const ACMethodName As String = "CheckClaimNumber"
        Const kLiveClaim As Integer = 4
        Dim bOpenClaim As bOpenClaim.Business = Nothing
        Dim sFailureReason As String = ""
        Dim iRet As System.Int32

        Try
            bOpenClaim = New bOpenClaim.Business
        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bOpenClaim.Business", ex.Message)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bOpenClaim", True)
        End Try

        SAMFunc.InitialiseSBOObject(con, bOpenClaim, _SiriusUser, "", "bOpenClaim.Business")

        Try
            iRet = bOpenClaim.ValidateClaimNumber(OpenClaimRequest.Claim.ClaimNumber, kLiveClaim, OpenClaimRequest.Claim.ProductId, sFailureReason)

            If (iRet <> PMEReturnCode.PMTrue) Then
                Dim STSErrorEX As New STSErrorPublisher(iRet, "bOpenClaim.Business.ValidateClaimNumber failed")
                STSErrorEX.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "ValidateClaimNumber", True)
            End If

            If Not String.IsNullOrEmpty(sFailureReason) Then
                RaiseComMethodException("bOpenClaim" & sFailureReason, iRet)
            End If

            If Not String.IsNullOrEmpty(sFailureReason) Then
                RaiseComMethodException("bOpenClaim" & sFailureReason, iRet)
            End If

        Catch ex As Exception

            Dim STSErrorEx As New STSErrorPublisher("An error occured calling bOpenClaim.Business.ValidateClaimNumber", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "ValidateClaimNumber", True)

        Finally
            ' Terminate the reference to the bOpenClaim
            If bOpenClaim IsNot Nothing Then
                bOpenClaim.Dispose()
            bOpenClaim = Nothing
            End If
        End Try

    End Sub

    ''' <summary>
    ''' Claim Number is provided to SAM so checking for uniqueness
    ''' </summary>
    Private Function CheckClaimNumberAlreadyExist(ByVal OpenClaimRequest As BaseClaimOpenRequestType) As Integer

        Const ACMethodName As String = "CheckClaimNumberAlreadyExist"
        Dim bOpenClaim As bOpenClaim.Business = Nothing
        Dim sFailureReason As String = ""
        Dim iRet, iClaimID As System.Int32

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                     _SiriusUser.Username, _SiriusUser.SourceID,
                                     _SiriusUser.LanguageID,
                                     SiriusUserDefaults.AppName)

            Try
                bOpenClaim = New bOpenClaim.Business
            Catch ex As Exception
                Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bOpenClaim.Business", ex.Message)
                STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "bOpenClaim", True)
            End Try

            SAMFunc.InitialiseSBOObject(con, bOpenClaim, _SiriusUser, "", "bOpenClaim.Business")

            Try
                iRet = bOpenClaim.CheckClaimNumber(OpenClaimRequest.Claim.ClaimNumber, iClaimID)

                If (iRet <> PMEReturnCode.PMTrue) Then
                    Dim STSErrorEX As New STSErrorPublisher(iRet, "bOpenClaim.Business.CheckClaimNumberAlreadyExist failed")
                    STSErrorEX.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "CheckClaimNumberAlreadyExist", True)
                End If

                If Not String.IsNullOrEmpty(sFailureReason) Then
                    RaiseComMethodException("bOpenClaim" & sFailureReason, iRet)
                End If

                If Not String.IsNullOrEmpty(sFailureReason) Then
                    RaiseComMethodException("bOpenClaim" & sFailureReason, iRet)
                End If

            Catch ex As Exception

                Dim STSErrorEx As New STSErrorPublisher("An error occured calling bOpenClaim.Business.CheckClaimNumber", ex)
                STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "CheckClaimNumber", True)

            Finally
                ' Terminate the reference to the bOpenClaim
                If bOpenClaim IsNot Nothing Then
                    bOpenClaim.Dispose()
                bOpenClaim = Nothing
                End If
            End Try
        End Using
        Return iClaimID

    End Function

    ''' <summary>
    ''' gets the insurance file details
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oBusiness"></param>
    ''' <param name="oClaim"></param>
    ''' <remarks></remarks>
    ''' <exception cref="SAMErrorException">InsuranceFileDetailsNotFound</exception>
    Private Sub GetInsuranceFileDetails(ByVal con As SiriusConnection,
                                        ByVal oClaim As BaseClaimType, Optional ByRef dInceptionDate As DateTime = Nothing)

        Dim ds As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Insurance_File_Details")

            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = oClaim.InsuranceFileKey

            ds = con.ExecuteDataSet(cmd, "InsuranceFileDetails")

            Dim dr As DataRow

            If ds.Tables("InsuranceFileDetails").Rows.Count > 0 Then

                dr = ds.Tables("InsuranceFileDetails").Rows(0)

                oClaim.ProductId = Cast.ToInt32(dr.Item("product_id")).GetValueOrDefault(0)
                oClaim.ProductCode = dr.Item("product_code").ToString
                oClaim.InsuranceRef = dr.Item("insurance_ref").ToString
                oClaim.AgentCnt = Cast.ToInt32(dr.Item("lead_agent_cnt"), 0)
                oClaim.InsuranceHolderCnt = Cast.ToInt32(dr.Item("insurance_holder_cnt"), 0)
                oClaim.InsuranceFolderCnt = Cast.ToInt32(dr.Item("insurance_folder_cnt"), 0)
                oClaim.SourceId = Cast.ToInt32(dr.Item("source_id"), 0)
                oClaim.InsuredCnt = Cast.ToInt32(dr.Item("insured_cnt"), 0)
                oClaim.SourceDescription = dr.Item("description").ToString
                oClaim.PaymentSuppressReserves = Cast.ToInt32(dr.Item("suppress_reserves"), 0)
                oClaim.PaymentSuppressPayments = Cast.ToInt32(dr.Item("suppress_payments"), 0)
                oClaim.PaymentSuppressRecoveries = Cast.ToInt32(dr.Item("suppress_recoveries"), 0)
                If oClaim.UnderwritingYearId = 0 Then
                    oClaim.UnderwritingYearId = Cast.ToInt32(dr.Item("underwriting_year_id"), 0)
                End If
                ' only override the currency with the value from the insurance file 
                ' if it was not specified in the request
                If String.IsNullOrEmpty(oClaim.CurrencyCode) Then
                    oClaim.CurrencyCode = dr.Item("currency_code").ToString
                    oClaim.CurrencyId = Cast.ToInt16(dr.Item("currency_id"), CShort(0))
                End If
                dInceptionDate = Convert.ToDateTime(dr.Item("inception_date"))
            Else
                ''' <exception>InsuranceFileDetailsNotFound</exception>
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(
                         SAMBusinessErrors.InsuranceFileDetailsNotFound,
                        SAMBusinessErrors.InsuranceFileDetailsNotFound.ToString,
                        "Insurance file details not found for insurance_file_cnt :" & oClaim.InsuranceFileKey)
                oSAMErrorCollection.CheckForErrors()

            End If

        End Using

    End Sub

    ''' <summary>
    ''' InsertCodeIntoNumber - ripped direct from vb 
    ''' </summary>
    ''' <param name="sMask"></param>
    ''' <param name="sCode"></param>
    ''' <param name="sChar"></param>
    ''' <param name="sResult"></param>
    ''' <remarks></remarks>
    Private Sub InsertCodeIntoNumber(ByVal sMask As String,
                                    ByVal sCode As String,
                                    ByVal sChar As String,
                                    ByRef sResult As String)

        Dim iCodeStart As Integer
        Dim iPos As Integer
        Dim iCodeLength As Integer
        Dim sLeft As String = String.Empty
        Dim sRight As String = String.Empty
        Dim sFormatStr As String = String.Empty

        iCodeStart = InStr(sMask, sChar)
        iPos = iCodeStart
        Do While InStr(iPos, sMask, sChar) <> 0
            iCodeLength = iCodeLength + 1
            iPos = iPos + 1
        Loop

        If iCodeLength <= Len(sCode) Then
            If sChar = "L" OrElse sChar = "R" OrElse sChar = "U" Then
                sCode = Right(sCode, iCodeLength)
            ElseIf sChar = "Y" Then
                sCode = Right(Today.Year.ToString(), iCodeLength)
            Else
                sCode = Left(sCode, iCodeLength)
            End If
        Else
            If sChar = "9" Then

                'Establish format of numeric section.
                For iPos = 1 To iCodeLength
                    sFormatStr = sFormatStr & "0"

                Next iPos

                sFormatStr = "{0:" & sFormatStr & "}"

                sCode = String.Format(sFormatStr, CInt(sCode))

            Else
                If (sChar <> "A") Then
                sCode = sCode & Space(iCodeLength - Len(sCode))
                End If
            End If
        End If

        sLeft = Left(sResult, iCodeStart - 1)
        sRight = Mid(sResult, iCodeStart + iCodeLength)
        sResult = sLeft & sCode & sRight

    End Sub

    ''' <summary>
    ''' returns the numbering scheme details for the specified product
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="lProductId"></param>
    ''' <param name="lBusinessType"></param>
    ''' <param name="o_lNumberingScheme"></param>
    ''' <param name="o_sProductCode"></param>
    ''' <remarks></remarks>
    ''' <exception>ProductNumberingShemesNotFound</exception>
    Private Sub GetNumberingSchemeForProductAndBusinessType(
                                ByVal con As SiriusConnection,
                                ByVal lProductId As Integer,
                                ByVal lBusinessType As Integer,
                                ByRef o_lNumberingScheme As Integer,
                                ByRef o_sProductCode As String)

        Dim ds As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_prod_auto_num_ids")

            cmd.AddInParameter("@product_id", SqlDbType.Int).Value = lProductId

            ds = con.ExecuteDataSet(cmd, "ProductNumberingSchemes")

            Dim dr As DataRow

            If ds.Tables.Count > 0 AndAlso ds.Tables("ProductNumberingSchemes").Rows.Count > 0 Then

                dr = ds.Tables("ProductNumberingSchemes").Rows(0)

                ' get the product string
                o_sProductCode = dr.Item(0).ToString

                ' get the numbering scheme id
                o_lNumberingScheme = Cast.ToInt32(dr.Item(lBusinessType)).GetValueOrDefault(0)

            Else
                ''' <exception>ProductNumberingShemesNotFound</exception>
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(
                    SAMBusinessErrors.ProductsNumberingSchemesNotFound,
                        SAMBusinessErrors.ProductsNumberingSchemesNotFound.ToString,
                            "Product Numbering Scheme Details Not Returned for Product ID :" & lProductId)
                oSAMErrorCollection.CheckForErrors()
            End If

        End Using
    End Sub

    ''' <summary>
    ''' returns the details for the specified numbering scheme 
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="lNumberingSchemeId"></param>
    ''' <param name="lLanguageId"></param>
    ''' <param name="o_Generate"></param>
    ''' <param name="o_MaskCode"></param>
    ''' <param name="o_FixedCode"></param>
    ''' <param name="o_NextNumber"></param>
    ''' <param name="o_ReuseAbandoned"></param>
    ''' <remarks></remarks>
    ''' <exception cref="SAMErrorException">NumberingSchemeNotFound</exception>
    Private Sub GetNumberingScheme(
                        ByVal con As SiriusConnection,
                        ByVal lNumberingSchemeId As Integer,
                        ByVal lLanguageId As Integer,
                        ByRef o_bGenerate As Boolean,
                        ByRef o_sMaskCode As String,
                        ByRef o_sFixedCode As String,
                        ByRef o_lNextNumber As Integer,
                        ByRef o_bReuseAbandoned As Boolean,
                        Optional ByRef o_bIsResetNumber As Boolean = False)
        Dim ds As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Numbering_Scheme")

            cmd.AddInParameter("@language_id", SqlDbType.Int).Value = lLanguageId
            cmd.AddInParameter("@numbering_scheme_id", SqlDbType.Int).Value = lNumberingSchemeId

            ds = con.ExecuteDataSet(cmd, "NumberScheme")

            Dim dr As DataRow

            If ds.Tables.Count > 0 AndAlso ds.Tables("NumberScheme").Rows.Count > 0 Then

                dr = ds.Tables("NumberScheme").Rows(0)

                o_bGenerate = BooleanDataConvert.ToBoolean(Cast.ToByte(dr.Item("is_generated"), CByte(1)))
                o_sMaskCode = dr.Item("mask_code").ToString
                o_sFixedCode = dr.Item("fixed_code").ToString
                o_lNextNumber = Cast.ToInt32(dr.Item("next_number"), 0)
                o_bReuseAbandoned = BooleanDataConvert.ToBoolean(Cast.ToByte(dr.Item("is_reuse_abandoned"), CByte(0)))
                o_bIsResetNumber = BooleanDataConvert.ToBoolean(Cast.ToByte(dr.Item("is_reset_number"), CByte(0)))
            Else
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(
                    SAMBusinessErrors.NumberingSchemeNotFound,
                        SAMBusinessErrors.NumberingSchemeNotFound.ToString,
                            "Numbering Scheme Details Not Returned for Language ID :" & lLanguageId & " Numbering Scheme Id : " & lNumberingSchemeId)
                oSAMErrorCollection.CheckForErrors()
            End If

        End Using
