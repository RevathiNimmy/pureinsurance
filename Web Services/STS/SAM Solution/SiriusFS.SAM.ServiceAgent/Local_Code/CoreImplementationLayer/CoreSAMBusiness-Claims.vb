    Private Sub SaveClaimReceiptDetails(
    ByVal con As SiriusConnection,
    ByVal ClaimReceipt As BaseClaimReceiptType,
    Optional ByVal bExcludeTax As Boolean = False)


        'Logic is used to bifercate the amount for tax and Net amount seprately
        Dim crClaim_ReceiptAmount As Decimal
        If ClaimReceipt.ReceiptItem IsNot Nothing Then
            For Each ClaimReceiptItem As BaseClaimReceiptItemType In ClaimReceipt.ReceiptItem
                If bExcludeTax Then
                    crClaim_ReceiptAmount += (ClaimReceiptItem.ReceiptAmount)
                Else
                    crClaim_ReceiptAmount += (ClaimReceiptItem.ReceiptAmount - ClaimReceiptItem.TotalTaxAmount)
                End If
            Next
        End If

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Claim_Receipt_Add")

            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = ClaimReceipt.ClaimId
            cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = ClaimReceipt.ClaimPerilId
            cmd.AddInParameter("@date_of_receipt", SqlDbType.DateTime).Value = IIf(ClaimReceipt.TransactionDate = New Date, Now, ClaimReceipt.TransactionDate)
            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = ClaimReceipt.PartyKey



            cmd.AddInParameter("@amount", SqlDbType.Money).Value = Math.Round(crClaim_ReceiptAmount, 2)

            cmd.AddInParameter("@tax_amount", SqlDbType.Money).Value = Math.Round(ClaimReceipt.TotalReceiptTaxAmount, 2)
            cmd.AddInParameter("@created_by", SqlDbType.SmallInt).Value = _SiriusUser.UserID
            cmd.AddInParameter("@currency_id", SqlDbType.SmallInt).Value = ClaimReceipt.CurrencyId
            cmd.AddInParameter("@comments", SqlDbType.VarChar, 40).Value = Nothing

            If ClaimReceipt.AdvancedTaxDetails IsNot Nothing Then
                cmd.AddInParameter("@insured_domiciled", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(ClaimReceipt.AdvancedTaxDetails.InsuredDomiciled)
                cmd.AddInParameter("@insured_percentage", SqlDbType.Float).Value = CDbl(ClaimReceipt.AdvancedTaxDetails.InsuredPercentage)
                cmd.AddInParameter("@insured_tax_number", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(ClaimReceipt.AdvancedTaxDetails.InsuredTaxNumber, String.Empty)
                cmd.AddInParameter("@receivable_tax_percentage", SqlDbType.Float).Value = CDbl(ClaimReceipt.AdvancedTaxDetails.ReceivableTaxPercentage)
                cmd.AddInParameter("@is_tax_exempt", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(ClaimReceipt.AdvancedTaxDetails.IsTaxExempt)
                cmd.AddInParameter("@is_settlement", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(ClaimReceipt.AdvancedTaxDetails.IsSettlement)
            Else
                cmd.AddInParameter("@insured_domiciled", SqlDbType.TinyInt).Value = Nothing
                cmd.AddInParameter("@insured_percentage", SqlDbType.Float).Value = Nothing
                cmd.AddInParameter("@insured_tax_number", SqlDbType.VarChar, 50).Value = Nothing
                cmd.AddInParameter("@receivable_tax_percentage", SqlDbType.Float).Value = Nothing
                cmd.AddInParameter("@is_tax_exempt", SqlDbType.TinyInt).Value = Nothing
                cmd.AddInParameter("@is_settlement", SqlDbType.TinyInt).Value = Nothing
            End If
            If (ClaimReceipt.Payee IsNot Nothing) Then
                cmd.AddInParameter("@PayeeMediaType", SqlDbType.Int).Value = Cast.NullIfDefault(ClaimReceipt.Payee.MediaTypeId, 0)
                cmd.AddInParameter("@PayeeName", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(ClaimReceipt.Payee.Name, String.Empty)
                cmd.AddInParameter("@PayeeBankName", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(ClaimReceipt.Payee.BankName, String.Empty)
                cmd.AddInParameter("@PayeeSortCode", SqlDbType.VarChar, 8).Value = Cast.NullIfDefault(ClaimReceipt.Payee.BankCode, String.Empty)
                cmd.AddInParameter("@PayeeAccountNo", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(ClaimReceipt.Payee.BankNumber, String.Empty)
                cmd.AddInParameter("@PayeeComments", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(ClaimReceipt.Payee.Comments, String.Empty)
                cmd.AddInParameter("@PayeeMediaRef", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(ClaimReceipt.Payee.MediaReference, String.Empty)
                cmd.AddInParameter("@document_id", SqlDbType.Int).Value = Nothing

                If (ClaimReceipt.ReceiptPartyType <> ClaimReceiptPartyTypeType.CLMRECEIVABLE) AndAlso (ClaimReceipt.Payee.Address IsNot Nothing) Then
                    cmd.AddInParameter("@Address1", SqlDbType.VarChar, 60).Value = Cast.NullIfDefault(ClaimReceipt.Payee.Address.AddressLine1, String.Empty)
                    cmd.AddInParameter("@Address2", SqlDbType.VarChar, 60).Value = Cast.NullIfDefault(ClaimReceipt.Payee.Address.AddressLine2, String.Empty)
                    cmd.AddInParameter("@Address3", SqlDbType.VarChar, 60).Value = Cast.NullIfDefault(ClaimReceipt.Payee.Address.AddressLine3, String.Empty)
                    cmd.AddInParameter("@Address4", SqlDbType.VarChar, 60).Value = Cast.NullIfDefault(ClaimReceipt.Payee.Address.AddressLine4, String.Empty)
                    cmd.AddInParameter("@PostalCode", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(ClaimReceipt.Payee.Address.PostCode, String.Empty)
                    cmd.AddInParameter("@PayeeCountry", SqlDbType.Int).Value = Cast.NullIfDefault(ClaimReceipt.Payee.Address.CountryId, 0)
                Else
                    cmd.AddInParameter("@Address1", SqlDbType.VarChar, 60).Value = Nothing
                    cmd.AddInParameter("@Address2", SqlDbType.VarChar, 60).Value = Nothing
                    cmd.AddInParameter("@Address3", SqlDbType.VarChar, 60).Value = Nothing
                    cmd.AddInParameter("@Address4", SqlDbType.VarChar, 60).Value = Nothing
                    cmd.AddInParameter("@PostalCode", SqlDbType.VarChar, 20).Value = Nothing
                    cmd.AddInParameter("@PayeeCountry", SqlDbType.Int).Value = Nothing
                End If
            Else
                cmd.AddInParameter("@PayeeMediaType", SqlDbType.Int).Value = Nothing
                cmd.AddInParameter("@PayeeName", SqlDbType.VarChar, 255).Value = Nothing
                cmd.AddInParameter("@PayeeBankName", SqlDbType.VarChar, 255).Value = Nothing
                cmd.AddInParameter("@PayeeSortCode", SqlDbType.VarChar, 8).Value = Nothing
                cmd.AddInParameter("@PayeeAccountNo", SqlDbType.VarChar, 30).Value = Nothing
                cmd.AddInParameter("@PayeeComments", SqlDbType.VarChar, 255).Value = Nothing
                cmd.AddInParameter("@PayeeMediaRef", SqlDbType.VarChar, 30).Value = Nothing
                cmd.AddInParameter("@document_id", SqlDbType.Int).Value = Nothing
                'cmd.AddInParameter("@TheirRef", SqlDbType.VarChar, 30).Value = Nothing
            End If

            cmd.AddInParameter("@TheirRef", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(ClaimReceipt.Payee.TheirReference, String.Empty)
            cmd.AddOutParameter("@claim_receipt_id", SqlDbType.Int)

            con.ExecuteNonQuery(cmd)

            ClaimReceipt.ClaimReceiptId = Cast.ToInt32(cmd.Parameters("@claim_receipt_id").Value, 0)

            ' if we dont get any failures but the item isnt added?
            If ClaimReceipt.ClaimReceiptId = 0 Then
                ' raise an error if we didnt successfully add the tax calculation item
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.FailedToAddClaimReceipt,
                    SAMBusinessErrors.FailedToAddClaimReceipt.ToString)
                oSAMErrorCollection.CheckForErrors()
            End If

        End Using

    End Sub

    Private Sub SaveClaimReceiptItem(
    ByVal con As SiriusConnection,
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal ClaimReceiptItem As BaseClaimReceiptItemType,
    Optional ByVal bExcludeTax As Boolean = False)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Claim_Receipt_Item_Add")

            cmd.AddOutParameter("@claim_receipt_Item_id", SqlDbType.Int)
            cmd.AddInParameter("@claim_receipt_id", SqlDbType.Int).Value = ClaimReceipt.ClaimReceiptId
            cmd.AddInParameter("@reserve_id", SqlDbType.Int).Value = Nothing
            cmd.AddInParameter("@recovery_id", SqlDbType.Int).Value = ClaimReceiptItem.RecoveryId
            cmd.AddInParameter("@recovery_type_id", SqlDbType.Int).Value = ClaimReceiptItem.RecoveryTypeId
            cmd.AddInParameter("@recovery_type_code", SqlDbType.Text).Value = ClaimReceiptItem.RecoveryTypeCode
            cmd.AddInParameter("@currency_id", SqlDbType.SmallInt).Value = ClaimReceipt.CurrencyId
            cmd.AddInParameter("@tax_group_id", SqlDbType.Int).Value = Cast.NullIfDefault(ClaimReceiptItem.TaxGroupId, 0)

            cmd.AddInParameter("@this_receipt", SqlDbType.Money).Value = ClaimReceiptItem.ReceiptAmount

            cmd.AddInParameter("@tax_amount", SqlDbType.Money).Value = ClaimReceiptItem.TotalTaxAmount
            cmd.AddInParameter("@exchange_rate_override_reason_id", SqlDbType.Int).Value = Nothing
            cmd.AddInParameter("@currency_base_xrate", SqlDbType.Float).Value = CDbl(ClaimReceipt.CurrencyToBaseXRate)
            cmd.AddInParameter("@currency_base_date", SqlDbType.DateTime).Value = ClaimReceipt.CurrencyToBaseDate
            cmd.AddInParameter("@account_base_xrate", SqlDbType.Float).Value = CDbl(ClaimReceipt.AccountToBaseXRate)
            cmd.AddInParameter("@account_base_date", SqlDbType.DateTime).Value = ClaimReceipt.AccountToBaseDate
            cmd.AddInParameter("@system_base_xrate", SqlDbType.Float).Value = CDbl(ClaimReceipt.SystemToBaseXRate)
            cmd.AddInParameter("@system_base_date", SqlDbType.DateTime).Value = ClaimReceipt.SystemToBaseDate
            cmd.AddInParameter("@receipt_loss_xrate", SqlDbType.Float).Value = CDbl(ClaimReceipt.ReceiptToLossXRate)

            con.ExecuteNonQuery(cmd)

            ClaimReceiptItem.ClaimReceiptItemId = Cast.ToInt32(cmd.Parameters("@claim_receipt_item_id").Value, 0)

            ' if we dont get any failures but the item isnt added?
            If ClaimReceiptItem.ClaimReceiptItemId = 0 Then
                ' raise an error if we didnt successfully add the tax calculation item
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.FailedToAddClaimReceiptItem,
                    SAMBusinessErrors.FailedToAddClaimReceiptItem.ToString)
                oSAMErrorCollection.CheckForErrors()
            End If

        End Using
    End Sub

    ''' <summary>
    ''' Save all the claim receipt item records and data that relates to them to the database
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="Request"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function SaveClaimReceiptItems(
    ByVal con As SiriusConnection,
    ByVal Request As BaseClaimReceiptRequestType,
    Optional ByVal bExcludeTax As Boolean = False) As Integer

        Dim ClaimReceipt As BaseClaimReceiptType = Request.ClaimReceipt

        For Each ClaimReceiptItem As BaseClaimReceiptItemType In Request.ClaimReceipt.ReceiptItem

            ' save claim receipt item to database
            SaveClaimReceiptItem(con, ClaimReceipt, ClaimReceiptItem, bExcludeTax)

            ' save the tax entries for the claim receipt item 
            If ClaimReceiptItem.TaxGroupId.HasValue Then
                SaveTaxCalculationsItems(con, ClaimReceipt, ClaimReceiptItem)
            End If

            ' update the associated reserve with the payment details
            UpdateRecovery(con, ClaimReceipt, ClaimReceiptItem, bExcludeTax)

            ' save any associated coinsurer / reinsurer payments
            SaveCoinsurerReinsurerPayments(con, Request, ClaimReceipt, ClaimReceiptItem)

        Next

    End Function

