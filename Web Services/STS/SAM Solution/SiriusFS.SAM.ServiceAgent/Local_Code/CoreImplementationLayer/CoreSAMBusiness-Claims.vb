    ByVal oRequest As BaseClaimReceiptRequestType,
    ByVal oBusiness As CoreBusiness,
        ByVal oSAMErrorCollection As SAMErrorCollection)

            ' validates the payment party information - and sets the correct default value if a value is not provided by the request
        ValidateClaimReceiptPayeeInformation(oRequest.ClaimReceipt.AdditionalDetails, oRequest.ClaimReceipt.PartyKey,
                        oRequest.ClaimReceipt.ReceiptPartyType, oSAMErrorCollection)

        End Sub

    Private Sub ValidateAgentDetailsForClaim(
    ByVal AdditionalDetails As BaseAdditionalClaimRelatedDetails,
    ByVal oSAMErrorCollection As SAMErrorCollection,
        ByRef PartyKey As Integer)

            Dim bSpecifiedAgentIsValid As Boolean = False

            ' if there is no agent present on this claim then
            If AdditionalDetails.Agent Is Nothing Then

                ' add invalid data error - invalid party type "agent" specified
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidPartyTypeKeySpecifiedNoAgentDetailsFoundForClaim,
                                               SAMInvalidData.InvalidPartyTypeKeySpecifiedNoAgentDetailsFoundForClaim.ToString,
                                                    "PartyType")

            Else

                ' if its an agent the party cnt doesnt have to have been provided as 
                ' this can be determined from the insurance file 
                If PartyKey <> 0 Then

                    ' add invalid data error  - invalid agent specified
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.SpecifiedPartyTypeShouldHaveAPartyKeyofZero,
                                                   SAMInvalidData.SpecifiedPartyTypeShouldHaveAPartyKeyofZero.ToString,
                                                        "PartyKey")

                Else

                    ' if the agent is in transfer mode use the details of the transfer agent
                If AdditionalDetails.Agent.IsInTransferMode AndAlso
                    AdditionalDetails.Agent.TransferToBusinessTypeCode <> InternalSAMConstants.kBusinessTypeDIRECT AndAlso
                            AdditionalDetails.TransferAgent IsNot Nothing Then

                        PartyKey = AdditionalDetails.TransferAgent.PartyKey

                    Else

                        ' otherwise use the details of the agent
                        PartyKey = AdditionalDetails.Agent.PartyKey

                    End If

                End If

            End If

        End Sub

        ''' <summary>
        ''' Validates that the passed data is correct and returns the correct client key
        ''' </summary>
        ''' <param name="oClaimDetails"></param>
        ''' <param name="oSAMErrorCollection"></param>
        ''' <param name="PartyKey"></param>
        ''' <remarks></remarks>
    Private Sub ValidateClientDetailsForClaim(ByVal oClaimDetails As BaseAdditionalClaimRelatedDetails,
    ByVal oSAMErrorCollection As SAMErrorCollection,
        ByRef PartyKey As Integer)

            ' if its a client the party cnt shouldnt have been provided as 
            ' this can be determined from the insurance file 
            If PartyKey <> 0 Then

                ' add invalid data error  - invalid agent specified
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.SpecifiedPartyTypeShouldHaveAPartyKeyofZero,
                                               SAMInvalidData.SpecifiedPartyTypeShouldHaveAPartyKeyofZero.ToString,
                                                    "PartyKey")

            Else

                PartyKey = oClaimDetails.Client.PartyKey

            End If

        End Sub

    Private Sub ValidateOtherPartyDetailsForClaim(
    ByVal oClaimDetails As BaseAdditionalClaimRelatedDetails,
    ByVal oSAMErrorCollection As SAMErrorCollection,
        ByRef PartyKey As Integer)

            ' default to calling existing function which determines if the specified party key
            ' belongs to a record which matches up with the relevant party type
            ' which is all that needs to be validated here. 

            ' NB : although this is specifically passing payment party type it does exactly the 
            ' same job for claims receipts.
            ValidatePaymentPartyType(PartyKey, ClaimPaymentPartyTypeType.PARTY, oSAMErrorCollection)

        End Sub

    Private Sub ValidateClaimReceiptPayeeInformation(
    ByVal AdditionalDetails As BaseAdditionalClaimRelatedDetails,
    ByRef PartyKey As Integer,
    ByVal PartyType As ClaimReceiptPartyTypeType,
        ByVal oSAMErrorCollection As SAMErrorCollection)

            Select Case PartyType
                Case ClaimReceiptPartyTypeType.AGENT

                    ValidateAgentDetailsForClaim(AdditionalDetails, oSAMErrorCollection, PartyKey)

                Case ClaimReceiptPartyTypeType.CLIENT

                    ValidateClientDetailsForClaim(AdditionalDetails, oSAMErrorCollection, PartyKey)

                Case ClaimReceiptPartyTypeType.CLMRECEIVABLE

                    If PartyKey <> 0 Then
                        ' add invalid data error  - invalid client specified
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ReceiptPartyTypeCLMRECEIVABLESpecifiedPartyKeyShouldBeZero,
                                                       SAMInvalidData.ReceiptPartyTypeCLMRECEIVABLESpecifiedPartyKeyShouldBeZero.ToString,
                                                           "PartyKey", PartyKey.ToString())
                    End If

                Case ClaimReceiptPartyTypeType.PARTY

                    ValidateOtherPartyDetailsForClaim(AdditionalDetails, oSAMErrorCollection, PartyKey)

            End Select

        End Sub

    Private Sub ValidateClaimPaymentPayeeInformation(ByVal oClaimDetails As BaseAdditionalClaimRelatedDetails,
    ByRef PartyKey As Integer,
    ByVal PartyType As ClaimPaymentPartyTypeType,
        ByVal oSAMErrorCollection As SAMErrorCollection)

            Select Case PartyType
                Case ClaimPaymentPartyTypeType.AGENT

                    ValidateAgentDetailsForClaim(oClaimDetails, oSAMErrorCollection, PartyKey)

                Case ClaimPaymentPartyTypeType.CLIENT

                    ValidateClientDetailsForClaim(oClaimDetails, oSAMErrorCollection, PartyKey)

                Case ClaimPaymentPartyTypeType.CLMPAYABLE

                    If PartyKey <> 0 Then
                        ' add invalid data error  - invalid client specified
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.PaymentPartyTypeCLMPAYABLESpecifiedPartyKeyShouldBeZero,
                                                       SAMInvalidData.PaymentPartyTypeCLMPAYABLESpecifiedPartyKeyShouldBeZero.ToString,
                                                           "PartyKey", PartyKey.ToString())

                    End If

                Case ClaimPaymentPartyTypeType.PARTY

                    ValidateOtherPartyDetailsForClaim(oClaimDetails, oSAMErrorCollection, PartyKey)

            End Select

        End Sub

        Public Function GetClaimRiskLinks(ByVal oRequest As BaseGetClaimRiskLinksRequestType) As Object

            Dim oBusiness As New CoreBusiness

        Dim oResponse As Object = Nothing
            Dim nTypeOfPackage As enumTypeOfPackage

            ' determine the type of package and thus the type of response
            If oRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetClaimRiskLinksRequestType) Then
                nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GetClaimRiskLinksResponseType
        ElseIf oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimRiskLinksRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimRiskLinksResponseType
        End If

        '*********************
        ' STRUCTURE VALIDATION 
        '*********************
        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection

        ' validate the mandatory structure data
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        ' raise an error if any errors have been added to the collection
        oSAMErrorCollection.CheckForErrors()

        '*********************
        ' DATA VALIDATION 
        '*********************

        ' branch code
        oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
        PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        ' validate the insurance file risk link
        CoreClaimValidateDataLinks(oRequest.InsuranceFileKey, oRequest.RiskKey,
             0, 0, oSAMErrorCollection, InternalSAMConstants.kInsuranceFileRiskLinkValid)

        ' if there were any data errors in the structure throw an exception
        oSAMErrorCollection.CheckForErrors()

        ' process the request
        ProcessGetClaimRiskLinks(oBusiness, oRequest,
            CType(oResponse, BaseImplementationTypes.BaseGetClaimRiskLinksResponseType))

        Return oResponse

        End Function

    ''' <summary>  
    ''' Retrieves financial details for a claim. This is a sub functionality of Maintain Claim process. 
    ''' </summary>  
    ''' <param name="GetClaimPerilSummaryRequest">An object of type SiriusFS.SAM.StructureBaseImplementationTypes.BaseGetClaimPerilSummaryRequestType</param>  
    ''' <returns>An object of type SiriusFS.SAM.StructureBaseImplementationTypes.BaseGetClaimPerilSummaryResponseType</returns>  
    Public Function GetClaimPerilSummary(ByVal GetClaimPerilSummaryRequest As BaseGetClaimPerilSummaryRequestType) As BaseImplementationTypes.BaseGetClaimPerilSummaryResponseType

        Dim oResponse As New BaseImplementationTypes.BaseGetClaimPerilSummaryResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage

        ' Determine the type of package and thus the type of response
        If GetClaimPerilSummaryRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimPerilSummaryRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimPerilSummaryResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        '**************************
        ' STRUCTURE VALIDATION 
        '**************************

        ' Validate the mandatory structure data (empty strings etc)
        GetClaimPerilSummaryRequest.Validate(CObj(oSAMErrorCollection))

        ' If there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            '**************************
            ' PERIL TOTALS
            '**************************
            If GetClaimPerilSummaryRequest.IncludeTotals Then
                ' Retrieve Peril Totals
                Dim dsPerilTotals As DataSet = Nothing
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Peril_Totals")
                    cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimPerilSummaryRequest.ClaimKey
                    dsPerilTotals = con.ExecuteDataSet(cmd, "Row")
                End Using
                dsPerilTotals.DataSetName = "BaseGetClaimPerilSummaryResponseTypePerilTotals"

                If GetClaimPerilSummaryRequest.WCFSecurityToken = "" Then
                Dim xmlDocPerilTotals As New System.Xml.XmlDocument
                xmlDocPerilTotals.LoadXml(dsPerilTotals.GetXml)
                oResponse.PerilTotals = xmlDocPerilTotals.DocumentElement()
            End If
                oResponse.ResultDataPerilTotals = dsPerilTotals
            End If

            '**************************
            ' TPRECOVERY PERILS
            '**************************
            If GetClaimPerilSummaryRequest.IncludeTPRecovery Then
                ' Retrieve TPRecovery Perils
                Dim dsTPRecoveryPerils As DataSet = Nothing
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Perils_For_Recovery")
                    cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimPerilSummaryRequest.ClaimKey
                    cmd.AddInParameter("@is_salvage", SqlDbType.Int).Value = 0
                    dsTPRecoveryPerils = con.ExecuteDataSet(cmd, "Row")
                End Using
                dsTPRecoveryPerils.DataSetName = "BaseGetClaimPerilSummaryResponseTypeTPRecoveryPerils"

                If GetClaimPerilSummaryRequest.WCFSecurityToken = "" Then
                Dim xmlDocTPRecoveryPerils As New System.Xml.XmlDocument
                xmlDocTPRecoveryPerils.LoadXml(dsTPRecoveryPerils.GetXml)
                oResponse.TPRecoveryPerils = xmlDocTPRecoveryPerils.DocumentElement()
            End If
                oResponse.ResultDataTPRecoveryPerils = dsTPRecoveryPerils

            End If

            '**************************
            ' SALVAGE RECOVERY PERILS
            '**************************
            If GetClaimPerilSummaryRequest.IncludeSalvageRecovery Then
                ' Retrieve Salvage Recovery Perils
                Dim dsSalvageRecoveryPerils As DataSet = Nothing
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Perils_For_Recovery")
                    cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimPerilSummaryRequest.ClaimKey
                    cmd.AddInParameter("@is_salvage", SqlDbType.Int).Value = 1
                    dsSalvageRecoveryPerils = con.ExecuteDataSet(cmd, "Row")
                End Using
                dsSalvageRecoveryPerils.DataSetName = "BaseGetClaimPerilSummaryResponseTypeSalvageRecoveryPerils"

                If GetClaimPerilSummaryRequest.WCFSecurityToken = "" Then
                Dim xmlDocSalvageRecoveryPerils As New System.Xml.XmlDocument
                xmlDocSalvageRecoveryPerils.LoadXml(dsSalvageRecoveryPerils.GetXml)
                oResponse.SalvageRecoveryPerils = xmlDocSalvageRecoveryPerils.DocumentElement()
            End If
                oResponse.ResultDataSalvageRecoveryPerils = dsSalvageRecoveryPerils

            End If

            '**************************
            ' RESERVE TYPE PERILS
            '**************************
            If GetClaimPerilSummaryRequest.IncludeReserveTypes Then
                ' Retrieve the Claim Peril Reserve Type Ids
                Dim dsReserveTypes As DataSet = Nothing
                Dim dsReserveTypePerils As DataSet = Nothing
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Reserve_Types_For_Claim")
                    cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimPerilSummaryRequest.ClaimKey
                    dsReserveTypes = con.ExecuteDataSet(cmd, "Row")
                End Using

                Dim nCount As Integer = dsReserveTypes.Tables(0).Rows.Count
                Dim iCount As Integer
                If (nCount > 0) Then
                    Dim oReserveTypePerils(0 To nCount - 1) As BaseGetClaimPerilSummaryResponseTypeReserveType
                    For iCount = 0 To nCount - 1
                        oReserveTypePerils(iCount) = New BaseGetClaimPerilSummaryResponseTypeReserveType
                        With dsReserveTypes.Tables(0).Rows(iCount)
                            oReserveTypePerils(iCount).Code = Cast.ToString(.Item("Code"))
                            oReserveTypePerils(iCount).Description = Cast.ToString(.Item("Description"))

                            ' Retrieve Reserve Type Perils
                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Perils_For_Reserve")
                                cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimPerilSummaryRequest.ClaimKey
                                cmd.AddInParameter("@Reserve_type_id", SqlDbType.Int).Value = Cast.ToInt32(.Item("Key"), 0)
                                dsReserveTypePerils = con.ExecuteDataSet(cmd, "Row")
                            End Using
                            dsReserveTypePerils.DataSetName = "BaseGetClaimPerilSummaryResponseTypeReserveTypePerils"

                            Dim xmlDocReserveTypePerils As New System.Xml.XmlDocument
                            xmlDocReserveTypePerils.LoadXml(dsReserveTypePerils.GetXml)

                            oReserveTypePerils(iCount).Perils = xmlDocReserveTypePerils.DocumentElement()
                            dsReserveTypePerils = Nothing
                        End With
                    Next
                    oResponse.ReserveType = oReserveTypePerils
                End If
            End If
        End Using

        Return oResponse
    End Function

