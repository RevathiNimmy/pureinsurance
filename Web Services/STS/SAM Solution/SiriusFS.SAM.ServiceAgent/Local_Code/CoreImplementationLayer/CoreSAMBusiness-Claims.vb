    Private Sub SaveCoinsurerReinsurerPayments(
    ByVal con As SiriusConnection,
    ByVal Request As BaseClaimReceiptRequestType,
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal ClaimReceiptItem As BaseClaimReceiptItemType)

        ' recalculate the coinsurance / reinsurance amounts
        RecalculateCoinsuranceReinsuranceAmounts(ClaimReceipt, ClaimReceiptItem)

        ' process coinsurance 
        If ClaimReceipt.Coinsurers IsNot Nothing Then
            For Each Coinsurer As BaseInsurerType In ClaimReceipt.Coinsurers

                If Coinsurer.RecoveryId = ClaimReceiptItem.RecoveryId Then

                    ' save claim payment 
                    SaveClaimPaymentForCoinsurerReinsurer(con, Coinsurer, Request, ClaimReceipt, ClaimReceiptItem)

                End If

            Next
        End If

        ' process reinsurance
        If ClaimReceipt.Reinsurers IsNot Nothing Then

            For Each Reinsurer As BaseInsurerType In ClaimReceipt.Reinsurers

                If Reinsurer.RecoveryId = ClaimReceiptItem.RecoveryId Then

                    ' save claim payment 
                    SaveClaimPaymentForCoinsurerReinsurer(con, Reinsurer, Request, ClaimReceipt, ClaimReceiptItem)

                End If

            Next

        End If

    End Sub

    Private Sub RecalculateCoinsuranceReinsuranceAmounts(
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal ClaimReceiptItem As BaseClaimReceiptItemType)

        'Const kMethodName As String = "RecalculateInsurance"

        Dim AdditionalDetails As BaseAdditionalClaimRelatedDetails = ClaimReceipt.AdditionalDetails

        Dim ReinsuranceAmount As Decimal
        Dim ReinsuranceTaxAmount As Decimal
        Dim TotalAmount As Decimal
        Dim TotalTaxAmount As Decimal
        Dim ThisPayment As Decimal
        Dim ThisTax As Decimal
        'Dim lCount As Integer
        'Dim lReturn As Integer

        ' If we are posting taxes reinsure them seperately, else rollup into receipt
        If AdditionalDetails.Risk.PostTaxEntriesSeparately Then
            ReinsuranceAmount = ClaimReceiptItem.NetAmount
            TotalAmount = ClaimReceiptItem.NetAmount
            ReinsuranceTaxAmount = ClaimReceiptItem.TotalTaxAmount
            TotalTaxAmount = ClaimReceiptItem.TotalTaxAmount
        Else
            ReinsuranceAmount = ClaimReceiptItem.ReceiptAmount
            TotalAmount = ClaimReceiptItem.ReceiptAmount
            ReinsuranceTaxAmount = ClaimReceiptItem.TotalTaxAmount
            TotalTaxAmount = ClaimReceiptItem.TotalTaxAmount
        End If

        ' for each coinsurance item in the collection
        For Each Coinsurer As BaseInsurerType In ClaimReceipt.Coinsurers

            ' if its for the selected recovery
            If Coinsurer.RecoveryId = ClaimReceiptItem.RecoveryId Then

                ' Calculate payment and adjust amount available for reinsurance
                ThisPayment = TotalAmount * (Coinsurer.SharePercentage / 100)
                ReinsuranceAmount -= ThisPayment

                ' Set payment share and loss equvalent
                Coinsurer.ThisRecoveryAmount = TotalAmount
                Coinsurer.ThisRecoverySplitAmount = ThisPayment
                Coinsurer.ReceiptToLossXRate = ClaimReceipt.ReceiptToLossXRate

                ' Calculate tax and adjust amount available for reinsurance
                ThisTax = TotalTaxAmount * (Coinsurer.SharePercentage / 100)
                ReinsuranceTaxAmount -= ThisTax

                ' Set tax ... only if shared with CI
                If CBool(Coinsurer.IsTaxShared) OrElse (AdditionalDetails.Risk.PostTaxEntriesSeparately = False) Then
                    ' Set tax share and loss equivalent
                    Coinsurer.ThisRecoveryTaxAmount = TotalTaxAmount
                    Coinsurer.ThisRecoverySplitTaxAmount = ThisTax

                End If

            End If

        Next

        ' for each reinsurance item in the collection
        For Each Reinsurer As BaseInsurerType In ClaimReceipt.Reinsurers

            ' if its for the selected recovery
            If Reinsurer.RecoveryId = ClaimReceiptItem.RecoveryId Then

                ' Calculate payment
                ThisPayment = ReinsuranceAmount * (Reinsurer.SharePercentage / 100)

                ' Set payment share and loss equvalent
                Reinsurer.ThisRecoveryAmount = ReinsuranceAmount
                Reinsurer.ThisRecoverySplitAmount = ThisPayment
                Reinsurer.ReceiptToLossXRate = ClaimReceipt.ReceiptToLossXRate

                ' Calculate tax
                ThisTax = ReinsuranceTaxAmount * (Reinsurer.SharePercentage / 100)

                ' Set tax ... only if shared with RI
                If CBool(Reinsurer.IsTaxShared) OrElse (AdditionalDetails.Risk.PostTaxEntriesSeparately = False) Then
                    ' Set tax share and loss equivalent
                    Reinsurer.ThisRecoveryTaxAmount = ReinsuranceTaxAmount
                    Reinsurer.ThisRecoverySplitTaxAmount = ThisTax
                End If

            End If

        Next

    End Sub

    Private Sub PopulateClaimPaymentRequestForCoinsurerReinsurerPayment(
    ByVal Insurer As BaseInsurerType,
    ByVal ClaimReceiptRequest As BaseClaimReceiptRequestType,
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal ClaimReceiptItem As BaseClaimReceiptItemType,
    ByRef ClaimPaymentRequest As BaseClaimPaymentRequestType)

        ' set up claim payment objects
