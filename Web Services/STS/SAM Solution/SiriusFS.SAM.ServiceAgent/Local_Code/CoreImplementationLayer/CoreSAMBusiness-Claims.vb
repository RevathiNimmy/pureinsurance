    Private Sub PreprocessClaimPerils(
    ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal sTransactionTypeCode As String,
    ByVal oClaim As BaseClaimType,
    ByVal oClaimPerils As BaseClaimPerilType())

        If oClaimPerils IsNot Nothing Then

            Dim oClaimPeril As BaseClaimPerilType

            ' for the open claim process only 
            ' (maintain claim already done whilst validating base claim peril ids)
            'If sTransactionTypeCode = TransactionTypeCode.OpenClaim Then

            Dim dt As New DataTable

            ' get current claim perils ids and types
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Claim_Perils")

                cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oClaim.ClaimId

                con.ExecuteDataTable(cmd, dt)

            End Using

            ' if there are claim peril records in the database for this claim 
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                ' add a new column to the table to hold  an allocated value
                dt.Columns.Add(New DataColumn("allocated", System.Type.GetType("System.Boolean")))

                If sTransactionTypeCode = TransactionTypeCode.OpenClaim Then

                    ' for each claim peril in the request
                    For Each oClaimPeril In oClaimPerils

                        Dim dr As DataRow

                        ' for each claim peril in the database
                        For Each dr In dt.Rows

                            ' attempt to match database and request entries via type code
                            If oClaimPeril.TypeCode.Trim = Cast.ToStringTrim(dr.Item("code")) _
                                AndAlso Not Cast.ToBoolean(dr.Item("allocated"), False) Then

                                ' store the matched claim peril id
                                oClaimPeril.ClaimPerilId = Cast.ToInt32(dr.Item("claim_peril_id"), 0)

                                ' indicate that the item has already been allocated and as such
                                ' should not be allocated again
                                dr.Item("allocated") = True

                                Exit For

                            End If

                        Next

                    Next

                ElseIf sTransactionTypeCode = TransactionTypeCode.MaintainClaim Then

                    ' for each claim peril in the request
                    For Each oMaintainClaimPeril As BaseClaimPerilMaintainType In oClaimPerils

                        Dim dr As DataRow

                        ' for each claim peril in the database
                        For Each dr In dt.Rows

                            ' attempt to match database and request entries via type code
                            If Cast.ToInt32(dr.Item("base_claim_peril_Id"), 0) > 0 AndAlso
                                oMaintainClaimPeril.BaseClaimPerilKeySpecified AndAlso oMaintainClaimPeril.BaseClaimPerilKey = Cast.ToInt32(dr.Item("base_claim_peril_Id"), 0) AndAlso
                                Not Cast.ToBoolean(dr.Item("allocated"), False) Then

                                ' store the matched claim peril id
                                oMaintainClaimPeril.ClaimPerilId = Cast.ToInt32(dr.Item("claim_peril_id"), 0)

                                ' indicate that the item has already been allocated and as such
                                ' should not be allocated again
                                dr.Item("allocated") = True

                                Exit For

                            End If

                        Next

                    Next

                End If

            End If

            ' for each claim peril in the request
            For Each oClaimPeril In oClaimPerils

                ' if the claim peril doesnt tie up with an existing one then 
                If oClaimPeril.ClaimPerilId = 0 Then

                    ' add a new claim peril
                    oClaimPeril.ClaimPerilId = AddClaimPeril(con, oBusiness, oClaim, oClaimPeril)

                End If

            Next

        End If

    End Sub

    Private Function AddClaimPeril(ByVal con As SiriusConnection, ByVal oBusiness As CoreBusiness,
                                    ByVal oClaim As BaseClaimType,
                                     ByVal oClaimPeril As BaseClaimPerilType) As Integer

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Add_Claim_Peril")
            cmd.AddInParameter("@ClaimId", SqlDbType.Int).Value = oClaim.ClaimId
            cmd.AddInParameter("@PerilTypeId", SqlDbType.Int).Value = Cast.ToInt32(oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.PerilType, oClaimPeril.TypeCode, "PerilTypeCode"))
            cmd.AddInParameter("@RiskID", SqlDbType.Int).Value = oClaim.RiskKey
            cmd.AddInParameter("@Description", SqlDbType.VarChar, 255).Value = oClaimPeril.Description

            Return Cast.ToInt32(con.ExecuteScalar(cmd), 0)

        End Using

    End Function

