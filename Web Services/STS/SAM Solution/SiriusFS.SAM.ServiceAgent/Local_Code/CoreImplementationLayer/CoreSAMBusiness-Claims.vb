    Public Overloads Function UpdateClaimRIArrangementLinesRI2007(ByVal con As SiriusConnection, ByVal oUpdateClaimRIArrangementLinesRI2007Request As BaseUpdateClaimRIArrangementLinesRI2007RequestType) As BaseUpdateClaimRIArrangementLinesRI2007ResponseType

        Dim oUpdateClaimRIArrangementLinesRI2007Response As New BaseUpdateClaimRIArrangementLinesRI2007ResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim dsUpdateClaimRILines As DataSet = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oCoreBusiness As New CoreBusiness
        Dim oReinsurance As BaseClaimRiskRIArrangementLineType
        Dim iClaimId As Integer
        Dim sTransType As String = ""

        If oUpdateClaimRIArrangementLinesRI2007Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateClaimRIArrangementLinesRI2007RequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateClaimRIArrangementLinesRI2007Response = New SAMForInsuranceV2ImplementationTypes.UpdateClaimRIArrangementLinesRI2007ResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        oUpdateClaimRIArrangementLinesRI2007Request.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()

        For Each oReinsurance In oUpdateClaimRIArrangementLinesRI2007Request.ClaimRIArrangementLines
            If Not (String.IsNullOrEmpty(oReinsurance.TreatyCode)) Then
                oReinsurance.TreatyID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, "treaty", oReinsurance.TreatyCode, "treaty_id", oSAMErrorCollection)
            End If
        Next
        oSAMErrorCollection.CheckForErrors()

        Dim dsClaimRIDetails As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetClaimFromRIArrangement")
            cmd.AddInParameter("@Claim_ri_arrangement_line_id", SqlDbType.Int).Value = Cast.ToInt32(oUpdateClaimRIArrangementLinesRI2007Request.ClaimRIArrangementLines(0).RIArrangementLineKey)
            dsClaimRIDetails = con.ExecuteDataSet(cmd, "row")
            If (dsClaimRIDetails.Tables.Count > 0) Then
                If (dsClaimRIDetails.Tables(0).Rows.Count > 0) Then
                    iClaimId = Cast.ToInt32(dsClaimRIDetails.Tables(0).Rows(0).Item("claim_id"), 0)
                    sTransType = dsClaimRIDetails.Tables(0).Rows(0).Item("code").ToString
                End If
            End If
        End Using


        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_claim_RI_Arrangement_upd")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = iClaimId
            cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = Cast.ToInt32(oUpdateClaimRIArrangementLinesRI2007Request.ClaimRIArrangementLines(0).RIArrangementKey)
            cmd.AddInParameter("@is_modified", SqlDbType.Int).Value = 1
            con.ExecuteNonQuery(cmd)
        End Using


        For Each oReinsurance In oUpdateClaimRIArrangementLinesRI2007Request.ClaimRIArrangementLines
            If oReinsurance.Type <> "FX" Then
                If oReinsurance.ActionType = RowAction.EditRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_upd")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                        cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = iClaimId
                        cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = oReinsurance.ThisSharePercent / 100
                        cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.AgreementCode
                        cmd.AddInParameter("@this_reserve", SqlDbType.Money).Value = oReinsurance.ThisReserve
                        cmd.AddInParameter("@this_payment", SqlDbType.Money).Value = oReinsurance.ThisPayment
                        cmd.AddInParameter("@Grouping", SqlDbType.Int).Value = oReinsurance.Grouping
                        cmd.AddInParameter("@Sum_insured", SqlDbType.Money).Value = oReinsurance.SumInsured
                        cmd.AddInParameter("@Trans_type", SqlDbType.VarChar, 20).Value = sTransType

                        con.ExecuteNonQuery(cmd)
                    End Using
                ElseIf oReinsurance.ActionType = RowAction.AddRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_add")
                        cmd.AddOutParameter("@ri_arrangement_line_id", SqlDbType.Int)
                        cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oReinsurance.RIArrangementKey
                        cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = iClaimId
                        cmd.AddInParameter("@type", SqlDbType.Int).Value = oReinsurance.Type
                        cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = IIf(oReinsurance.TreatyID = 0, Nothing, oReinsurance.TreatyID)
                        cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = IIf(oReinsurance.PartyKey = 0, Nothing, oReinsurance.PartyKey)
                        cmd.AddInParameter("@xol_arrangement_id", SqlDbType.Int).Value = Nothing
                        cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = oReinsurance.DefaultSharePercent
                        cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = oReinsurance.ThisSharePercent
                        cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.AgreementCode
                        cmd.AddInParameter("@priority", SqlDbType.Int).Value = oReinsurance.Priority
                        cmd.AddInParameter("@number_of_lines", SqlDbType.Int).Value = oReinsurance.NumberOfLines
                        cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                        cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.SumInsured
                        cmd.AddInParameter("@reserve", SqlDbType.Money).Value = oReinsurance.ReserveToDate
                        cmd.AddInParameter("@payment", SqlDbType.Money).Value = oReinsurance.PaymentToDate
                        cmd.AddInParameter("@this_reserve", SqlDbType.Money).Value = oReinsurance.ThisReserve
                        cmd.AddInParameter("@this_payment", SqlDbType.Money).Value = oReinsurance.ThisPayment
                        cmd.AddInParameter("@lower_limit", SqlDbType.Money).Value = oReinsurance.LowerLimit
                        cmd.AddInParameter("@retained", SqlDbType.Float).Value = oReinsurance.Retained
                        cmd.AddInParameter("@participation_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@Trans_type", SqlDbType.VarChar, 20).Value = sTransType

                        con.ExecuteNonQuery(cmd)

                        oReinsurance.RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)
                    End Using

                ElseIf oReinsurance.ActionType = RowAction.DeleteRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_del_RI2007")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                        con.ExecuteNonQuery(cmd)
                    End Using
                End If
                If oReinsurance.ActionType <> RowAction.DeleteRow Then

                    If oReinsurance.Type = "F" And oReinsurance.BrokerParticipants IsNot Nothing Then

                        For iCount As Integer = 0 To oReinsurance.BrokerParticipants.Length - 1
                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_AddBrokerParticipants")
                                cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                                cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oReinsurance.BrokerParticipants(iCount).PartyKey
                                cmd.AddInParameter("@Part_percent", SqlDbType.Float).Value = oReinsurance.BrokerParticipants(iCount).ParticpationPercentage
                                cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
                                con.ExecuteNonQuery(cmd)
                            End Using
                        Next
                    End If
                End If
            Else
                ProcessClaimFAXRILines(con, iClaimId, sTransType, oReinsurance)
            End If
        Next


        Return oUpdateClaimRIArrangementLinesRI2007Response
    End Function

    Private Sub ProcessClaimFAXRILines(ByVal con As SiriusConnection,
                                 ByVal iClaimId As Integer,
                                 ByVal sTransType As String,
                                 ByVal oReinsurance As BaseClaimRiskRIArrangementLineType)
        Dim sRiIds As String
        If oReinsurance.ActionType = RowAction.AddRow Then
            For iCount As Integer = 0 To oReinsurance.FAXParticipants.Length - 1
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_add")
                    cmd.AddOutParameter("@ri_arrangement_line_id", SqlDbType.Int)
                    cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oReinsurance.RIArrangementKey
                    cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = iClaimId
                    cmd.AddInParameter("@type", SqlDbType.Int).Value = oReinsurance.Type
                    cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = Nothing
                    cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).PartyKey
                    cmd.AddInParameter("@xol_arrangement_id", SqlDbType.Int).Value = Nothing
                    cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = 0D
                    cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = 0D
                    cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.FAXParticipants(iCount).AgreementCode
                    cmd.AddInParameter("@priority", SqlDbType.Int).Value = 1
                    cmd.AddInParameter("@number_of_lines", SqlDbType.Int).Value = 1
                    cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                    cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).SumInsured
                    cmd.AddInParameter("@reserve", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).ReserveToDate
                    cmd.AddInParameter("@payment", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).PaymentToDate
                    cmd.AddInParameter("@this_reserve", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).ThisReserve
                    cmd.AddInParameter("@this_payment", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).ThisPayment
                    cmd.AddInParameter("@lower_limit", SqlDbType.Money).Value = oReinsurance.LowerLimit
                    cmd.AddInParameter("@retained", SqlDbType.Float).Value = IIf(oReinsurance.FAXParticipants(iCount).AccountType = "Retained", 1D, 0D)
                    cmd.AddInParameter("@participation_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).ParticpationPercentage
                    cmd.AddInParameter("@Trans_type", SqlDbType.VarChar, 20).Value = sTransType

                    con.ExecuteNonQuery(cmd)

                    oReinsurance.FAXParticipants(iCount).RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)

                    If iCount = 0 Then
                        oReinsurance.RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)
                    End If

                    If iCount <> oReinsurance.FAXParticipants.Length - 1 Then
                        sRiIds = sRiIds & oReinsurance.FAXParticipants(iCount).RIArrangementLineKey.ToString & ","
                    Else
                        sRiIds = sRiIds & oReinsurance.FAXParticipants(iCount).RIArrangementLineKey.ToString
                    End If

                End Using


                If oReinsurance.FAXParticipants(iCount).BrokerParticipants IsNot Nothing Then

                    For iCount1 As Integer = 0 To oReinsurance.FAXParticipants(iCount).BrokerParticipants.Length - 1
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_AddBrokerParticipants")
                            cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                            cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).PartyKey
                            cmd.AddInParameter("@Part_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).ParticpationPercentage
                            cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
                            con.ExecuteNonQuery(cmd)
                        End Using
                    Next
                End If


            Next
            If sRiIds <> "" Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_Update_RiArrangementLine_Grouping")
                    cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                    cmd.AddInParameter("@sRiIds", SqlDbType.VarChar, 100).Value = sRiIds
                    cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
                    con.ExecuteNonQuery(cmd)
                End Using
            End If

        ElseIf oReinsurance.ActionType = RowAction.EditRow Then

            For iCount As Integer = 0 To oReinsurance.FAXParticipants.Length - 1
                If oReinsurance.FAXParticipants(iCount).ActionType = RowAction.AddRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_add")
                        cmd.AddOutParameter("@ri_arrangement_line_id", SqlDbType.Int)
                        cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oReinsurance.RIArrangementKey
                        cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = iClaimId
                        cmd.AddInParameter("@type", SqlDbType.Int).Value = oReinsurance.Type
                        cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = Nothing
                        cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).PartyKey
                        cmd.AddInParameter("@xol_arrangement_id", SqlDbType.Int).Value = Nothing
                        cmd.AddInParameter("@default_share_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.FAXParticipants(iCount).AgreementCode
                        cmd.AddInParameter("@priority", SqlDbType.Int).Value = 1
                        cmd.AddInParameter("@number_of_lines", SqlDbType.Int).Value = 1
                        cmd.AddInParameter("@line_limit", SqlDbType.Money).Value = oReinsurance.LineLimit
                        cmd.AddInParameter("@sum_insured", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).SumInsured
                        cmd.AddInParameter("@reserve", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).ReserveToDate
                        cmd.AddInParameter("@payment", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).PaymentToDate
                        cmd.AddInParameter("@this_reserve", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).ThisReserve
                        cmd.AddInParameter("@this_payment", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).ThisPayment
                        cmd.AddInParameter("@lower_limit", SqlDbType.Money).Value = oReinsurance.LowerLimit
                        cmd.AddInParameter("@retained", SqlDbType.Float).Value = IIf(oReinsurance.FAXParticipants(iCount).AccountType = "Retained", 1D, 0D)
                        cmd.AddInParameter("@participation_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).ParticpationPercentage
                        cmd.AddInParameter("@Trans_type", SqlDbType.VarChar, 20).Value = sTransType
                        con.ExecuteNonQuery(cmd)
                        oReinsurance.FAXParticipants(iCount).RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("@ri_arrangement_line_id").Value, 0)
                    End Using
                ElseIf oReinsurance.FAXParticipants(iCount).ActionType = RowAction.EditRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_upd")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                        cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = iClaimId
                        cmd.AddInParameter("@this_share_percent", SqlDbType.Float).Value = 0D
                        cmd.AddInParameter("@agreement_code", SqlDbType.VarChar, 255).Value = oReinsurance.FAXParticipants(iCount).AgreementCode
                        cmd.AddInParameter("@this_reserve", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).ThisReserve
                        cmd.AddInParameter("@this_payment", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).ThisPayment
                        cmd.AddInParameter("@Grouping", SqlDbType.Int).Value = oReinsurance.Grouping
                        cmd.AddInParameter("@Sum_insured", SqlDbType.Money).Value = oReinsurance.FAXParticipants(iCount).SumInsured
                        cmd.AddInParameter("@Trans_type", SqlDbType.VarChar, 20).Value = sTransType

                        con.ExecuteNonQuery(cmd)
                    End Using
                ElseIf oReinsurance.FAXParticipants(iCount).ActionType = RowAction.DeleteRow Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_DelBrokerParticipants")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                        cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = 0
                        cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
                        con.ExecuteNonQuery(cmd)
                    End Using

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_Delete_RI2007ArrangementLines")
                        cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                        cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = iClaimId
                        cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
                        cmd.AddOutParameter("@NewgroupingId", SqlDbType.Int)
                        con.ExecuteNonQuery(cmd)
                        oReinsurance.RIArrangementLineKey = Cast.ToInt32(cmd.Parameters("NewgroupingId").Value, 0)
                    End Using
                End If

                If oReinsurance.FAXParticipants(iCount).ActionType = RowAction.AddRow Or
                   oReinsurance.FAXParticipants(iCount).ActionType = RowAction.EditRow Then
                    If iCount <> oReinsurance.FAXParticipants.Length - 1 Then
                        sRiIds = sRiIds & oReinsurance.FAXParticipants(iCount).RIArrangementLineKey.ToString & ","
                    Else
                        sRiIds = sRiIds & oReinsurance.FAXParticipants(iCount).RIArrangementLineKey.ToString
                    End If

                    If oReinsurance.FAXParticipants(iCount).BrokerParticipants IsNot Nothing Then

                        For iCount1 As Integer = 0 To oReinsurance.FAXParticipants(iCount).BrokerParticipants.Length - 1

                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_DelBrokerParticipants")
                                cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                                cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).PartyKey
                                cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
                                con.ExecuteNonQuery(cmd)
                            End Using

                            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_AddBrokerParticipants")
                                cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).RIArrangementLineKey
                                cmd.AddInParameter("@PartyCnt", SqlDbType.Int).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).PartyKey
                                cmd.AddInParameter("@Part_percent", SqlDbType.Float).Value = oReinsurance.FAXParticipants(iCount).BrokerParticipants(iCount1).ParticpationPercentage
                                cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
                                con.ExecuteNonQuery(cmd)
                            End Using
                        Next
                    End If
                End If
            Next

            If Right(sRiIds, 1) = "," Then
                sRiIds = Left(sRiIds, Len(sRiIds) - 1)
            End If

            If sRiIds <> "" Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_Update_RiArrangementLine_Grouping")
                    cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                    cmd.AddInParameter("@sRiIds", SqlDbType.VarChar, 100).Value = sRiIds
                    cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
                    con.ExecuteNonQuery(cmd)
                End Using
            End If

        ElseIf oReinsurance.ActionType = RowAction.DeleteRow Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_del_RI2007")
                cmd.AddInParameter("@ri_arrangement_line_id", SqlDbType.Int).Value = oReinsurance.RIArrangementLineKey
                con.ExecuteNonQuery(cmd)
            End Using
        End If

    End Sub

