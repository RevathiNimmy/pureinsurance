    ''' <summary>
    ''' add the claim record
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Sub AddClaim(ByVal con As SiriusConnection,
                         ByVal oBusiness As CoreBusiness,
                         ByVal oOpenClaimRequest As BaseClaimOpenRequestType)

        Try

            ' add the claim address
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_add")

                Dim sClaimStatusCode As String = String.Empty

                If oOpenClaimRequest.Claim.InfoOnly Then
                    sClaimStatusCode = ClaimStatus.ProvisionalOpenClaim
                Else
                    sClaimStatusCode = ClaimStatus.LiveOpenClaim
                End If

                cmd.AddInParameter("@policy_id", SqlDbType.Int).Value = oOpenClaimRequest.Claim.InsuranceFileKey
                cmd.AddInParameter("@policy_number", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(Cast.NullIfDefault(oOpenClaimRequest.Claim.InsuranceRef, String.Empty))
                cmd.AddInParameter("@description", SqlDbType.VarChar, 1000).Value = Cast.NullIfDefault(Cast.NullIfDefault(oOpenClaimRequest.Claim.Description, String.Empty))
                cmd.AddInParameter("@claim_status_id", SqlDbType.Int).Value = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.ClaimStatus, sClaimStatusCode, "ClaimStatusCode")
                cmd.AddInParameter("@progress_status_id", SqlDbType.Int).Value = oOpenClaimRequest.Claim.ProgressStatusId
                cmd.AddInParameter("@primary_cause_id", SqlDbType.Int).Value = oOpenClaimRequest.Claim.PrimaryCauseId
                cmd.AddInParameter("@secondary_cause_id", SqlDbType.Int).Value = Cast.NullIfDefault(oOpenClaimRequest.Claim.SecondaryCauseId, 0)
                cmd.AddInParameter("@catastrophe_code_id", SqlDbType.Int).Value = oOpenClaimRequest.Claim.CatastropheId
                cmd.AddInParameter("@loss_from_date", SqlDbType.DateTime).Value = oOpenClaimRequest.Claim.LossFromDate
                cmd.AddInParameter("@loss_to_date", SqlDbType.DateTime).Value = oOpenClaimRequest.Claim.LossToDate
                cmd.AddInParameter("@reported_date", SqlDbType.DateTime).Value = oOpenClaimRequest.Claim.ReportedDate
