    ''' <summary>
    ''' stored claim ri arrangement / arrangement item details in class structure
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="lClaimId"></param>
    ''' <param name="aoRIArrangement"></param>
    ''' <param name="lBalanceAndCloseClaim"></param>
    ''' <remarks></remarks>
    Private Sub StoreClaimRIArrangements(ByVal con As SiriusConnection,
                                            ByVal lClaimId As Integer,
                                                ByRef aoRIArrangement() As RIArrangement,
                                                  ByVal lBalanceAndCloseClaim As Integer)

        Dim ds As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_saa")

            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = lClaimId

            ds = con.ExecuteDataSet(cmd, "RiArrangement")

        End Using

        If ds.Tables.Count > 0 Then

            Dim dr As DataRow

            For Each dr In ds.Tables("RIArrangement").Rows

                Dim oRIArrangement As New RIArrangement

                oRIArrangement.ArrangementID = Cast.ToInt32(dr.Item("ri_arrangement_id"), 0)
                oRIArrangement.RIBand = Cast.ToInt32(dr.Item("ri_band_id"), 0)
                oRIArrangement.RIModelID = Cast.ToInt32(dr.Item("ri_model_id"), 0)
                oRIArrangement.SumInsured = Cast.ToDecimal(dr.Item("sum_insured"), 0)
                oRIArrangement.ReserveToDate = Cast.ToDecimal(dr.Item("reserve"), 0)
                oRIArrangement.PaymentToDate = Cast.ToDecimal(dr.Item("payment"), 0)
                oRIArrangement.ThisReserve = Cast.ToDecimal(dr.Item("this_reserve"), 0)
                oRIArrangement.ThisPayment = Cast.ToDecimal(dr.Item("this_payment"), 0)
                oRIArrangement.CatastropheCodeID = Cast.ToInt32(dr.Item("catastrophe_code_id"), 0)

                ' Store xol triggers
                oRIArrangement.XolClmModelID = Cast.ToInt32(dr.Item("xol_clm_ri_model_id"), 0)
                oRIArrangement.XolClmLimit = Cast.ToDecimal(dr.Item("xol_clm_limit"), 0)
                oRIArrangement.XolCatModelID = Cast.ToInt32(dr.Item("xol_cat_ri_model_id"), 0)
                oRIArrangement.XolCatLimit = Cast.ToDecimal(dr.Item("xol_cat_limit"), 0)
                oRIArrangement.XolCatReinstatements = Cast.ToInt32(dr.Item("xol_cat_reinstatements"), 0)

                ' get the lines
                GetRIArrangementLines(con, lClaimId, oRIArrangement)

                Dim lNewBound As Integer
                If IsArray(aoRIArrangement) Then
                    lNewBound = aoRIArrangement.GetUpperBound(0) + 1
                Else
                    lNewBound = 0
                End If

                ' resize array to hold new ri_arrangment
                Array.Resize(aoRIArrangement, lNewBound + 1)

                aoRIArrangement(lNewBound) = oRIArrangement

            Next
        End If

    End Sub

