    Private Function GetAgentFileCode(ByVal con As SiriusConnection,
                                    ByVal lAgentCnt As Integer) As String

        Dim ds As DataSet = Nothing
        Dim returnValue As String = String.Empty

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_Party_sel")

            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = lAgentCnt

            ds = con.ExecuteDataSet(cmd, "PartyDetails")

            Dim dr As DataRow

            If ds.Tables("PartyDetails").Rows.Count > 0 Then

