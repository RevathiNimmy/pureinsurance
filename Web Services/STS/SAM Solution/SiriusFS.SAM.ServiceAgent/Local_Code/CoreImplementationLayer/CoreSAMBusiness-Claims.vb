    Private Sub GetContactDetailsFromClaimtable(ByVal con As SiriusConnection,
    ByVal iClaimId As Int32,
    ByVal IsInsurer As Boolean,
    ByRef dsClaimContacts As DataSet)
        ' get the claim risks status 
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Contact_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = iClaimId
            dsClaimContacts = con.ExecuteDataSet(cmd, "ContactDetails")
