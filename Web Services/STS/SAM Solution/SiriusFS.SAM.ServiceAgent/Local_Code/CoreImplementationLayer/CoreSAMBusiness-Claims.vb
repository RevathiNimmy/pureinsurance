    ''' <summary>
    ''' ClaimReceipt
    ''' </summary>
    ''' <param name="oRequest"></param>
    ''' <param name="oResponse"></param>
    ''' <remarks></remarks>
    Private Overloads Sub ClaimReceipt(ByRef oRequest As BaseImplementationTypes.BaseClaimProcessRequestType, ByRef oResponse As BaseImplementationTypes.BaseClaimProcessResponseType)

        Dim nCount As Int32
        Dim nPCount As Int32 = -1
        Dim oBusiness As New CoreBusiness
        If Not oRequest.Claim.ClaimPeril Is Nothing Then
            For Each inPeril As BaseImplementationTypes.BaseClaimProcessPerilType In oRequest.Claim.ClaimPeril
                Dim oReceiptCashlist As BaseImplementationTypes.BaseReceiptCashListType
                oReceiptCashlist = New BaseImplementationTypes.BaseReceiptCashListType
                nPCount = nPCount + 1
                Dim oClaimReceiptRequest As New SAMForInsuranceV2ImplementationTypes.ClaimReceiptRequestType
                Dim oClaimReceiptResponse As New SAMForInsuranceV2ImplementationTypes.ClaimReceiptResponseType

                oClaimReceiptRequest.BranchCode = oRequest.BranchCode
                oClaimReceiptRequest.TimeStamp = oRequest.TimeStamp

                oClaimReceiptRequest.ClaimReceipt = New BaseImplementationTypes.BaseClaimReceiptType
                oClaimReceiptRequest.ClaimReceipt.CurrencyCode = oRequest.Claim.CurrencyCode
                oClaimReceiptRequest.ClaimReceipt.PartyKey = oRequest.ClaimDetails.ClaimDetails.InsuranceHolderCnt
                oClaimReceiptRequest.ClaimReceipt.ReceiptPartyType = BaseImplementationTypes.ClaimReceiptPartyTypeType.CLMRECEIVABLE

                'Receipt is per-reserve
                For Each ClaimPeril In oRequest.ClaimDetails.ClaimPeril
                    If (Not oRequest.ClaimDetails.ClaimPeril(nPCount).Recovery Is Nothing) AndAlso (Not inPeril.Recovery Is Nothing) Then
                    Dim oReceiptList() As BaseImplementationTypes.BaseClaimReceiptItemType
                    ReDim oReceiptList(inPeril.Recovery.Length - 1)
                        nCount = -1
                        Dim dReceiptAmount As Decimal = 0
                        oClaimReceiptRequest.ClaimReceipt.BaseClaimKey = oRequest.BaseClaimKey
                        If IsArray(oRequest.ClaimDetails.ClaimPeril) AndAlso ((oRequest.ClaimDetails.ClaimPeril(nPCount) Is Nothing) = False) Then
                            oClaimReceiptRequest.ClaimReceipt.BaseClaimPerilKey = oRequest.ClaimDetails.ClaimPeril(nPCount).BaseClaimPerilKey
                        End If
                    For Each inRecovery As BaseImplementationTypes.BaseClaimProcessPerilRecoveryType In inPeril.Recovery

                        Dim inReceipt As New BaseImplementationTypes.BaseClaimReceiptItemType

                            nCount = nCount + 1

                        inReceipt.BaseRecoveryKey = GetBaseRecoveryKey(inPeril.TypeCode, inRecovery.TypeCode, oRequest.ClaimDetails)
                            inReceipt.ReceiptAmount = inRecovery.RecoveryAmount
                            dReceiptAmount = dReceiptAmount + inReceipt.ReceiptAmount
                            oReceiptList(nCount) = inReceipt
                    Next
                        If dReceiptAmount > 0 Then
                            oReceiptCashlist.BranchCode = oRequest.BranchCode
                            oReceiptCashlist.BankAccountCode = inPeril.Recovery(0).RecoveryDetails.ReceiptBankCode
                            oReceiptCashlist.CurrencyCode = inPeril.Recovery(0).RecoveryDetails.ReceiptCurrencyCode
                            oReceiptCashlist.ListDate = DateTime.Now
                            oReceiptCashlist.Reference = Right("CLR " & oRequest.ClaimDetails.ClaimDetails.ClaimNumber, 25)
                            oReceiptCashlist.StatusCode = "E"
                            oReceiptCashlist.TypeCode = "R"
                            oReceiptCashlist.SourceID = GetListIDFromCode(Core.STSListType.PMLookup, "source", oRequest.BranchCode)
                            oReceiptCashlist.TypeKey = GetListIDFromCode(Core.STSListType.PMLookup, "CashListType", oReceiptCashlist.TypeCode)
                            oReceiptCashlist.CurrencyKey = GetListIDFromCode(Core.STSListType.PMLookup, "Currency", oRequest.Claim.ClaimPeril(nCount).Recovery(0).RecoveryDetails.ReceiptCurrencyCode)
                            ReDim Preserve oReceiptCashlist.ReceiptItem(nCount)
                            oReceiptCashlist.ReceiptItem(nCount) = New BaseImplementationTypes.BaseReceiptCashListItemType
                            If Not oRequest.Claim.ReceiptPayee Is Nothing Then
                                ProcessReceiptPayeeDetails(oRequest.Claim.ReceiptPayee, oClaimReceiptRequest.ClaimReceipt.Payee)
                            End If
                            With oReceiptCashlist.ReceiptItem(nCount)
                                .AccountShortCode = InternalSAMConstants.kAccountShortnameCLMRECEIVABLE
                                .AllocationStatusCode = ""
                                .Amount = Math.Round(dReceiptAmount, 4)
                                .Bank = New BaseImplementationTypes.BaseBankReceiptType
                                .Bank.BankCode = inPeril.Recovery(0).RecoveryDetails.ReceiptBankCode
                                .Bank.PayerName = oClaimReceiptRequest.ClaimReceipt.Payee.Name
                                .Bank.ChequeDate = DateTime.Now
                                .MediaReference = inPeril.Recovery(0).RecoveryDetails.ReceiptMediaReference
                                .MediaTypeCode = inPeril.Recovery(0).RecoveryDetails.ReceiptMediaTypeCode
                                .TransactionDate = DateTime.Now
                                .TypeCode = inPeril.Recovery(0).TypeCode
                            End With
                    oClaimReceiptRequest.ClaimReceipt.ReceiptItem = oReceiptList
                    oClaimReceiptRequest.ClaimReceipt.IsGetClaimReceiptTaxesType = False
                            oClaimReceiptRequest.ClaimReceipt.IsSalvageRecovery = inPeril.Recovery(0).IsSalvageRecovery
                            oClaimReceiptRequest.ClaimReceipt.ReceiptcashList = oReceiptCashlist
                            If inPeril.Recovery(0).RecoveryDetails.ReceiptPartyKey <> 0 Then
                                oClaimReceiptRequest.ClaimReceipt.ReceiptPartyType = inPeril.Recovery(0).RecoveryDetails.ReceiptPartyType
                            End If
                            If oClaimReceiptRequest.ClaimReceipt.TransactionDate = Date.MinValue Then
                                oClaimReceiptRequest.ClaimReceipt.TransactionDate = DateTime.Now
                            End If

                    ' Call CoreSAMBusiness method
                    oClaimReceiptResponse = CType(ClaimReceipt(oClaimReceiptRequest), SAMForInsuranceV2ImplementationTypes.ClaimReceiptResponseType)
                            If Not oClaimReceiptResponse.TimeStamp Is Nothing Then
                    oRequest.TimeStamp = oClaimReceiptResponse.TimeStamp
                            End If

                    oRequest.ClaimKey = oClaimReceiptResponse.ClaimKey

                    'For each Receipt
                            BindClaim(oRequest, False, oResponse, isReceiptClaim:=True, oClaimReceiptRequest:=oClaimReceiptRequest)
                        End If
                    End If
                    nCount = nCount + 1
                Next


            Next
        End If

    End Sub
