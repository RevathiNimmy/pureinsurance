    ''' <summary>
    ''' To settle multiple claim payment
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oSettleAllClaimPaymentsRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function SettleAllClaimPayments(ByVal con As SiriusConnection, ByVal oSettleAllClaimPaymentsRequest As BaseSettleAllClaimPaymentsRequestType) As BaseSettleAllClaimPaymentsResponseType
        Dim oResponse As BaseSettleAllClaimPaymentsResponseType
        Dim dAuthorityAmount As Double = 0.0
        Dim dConvertedAmount As Double = 0.0
        Dim dRate As Decimal = CDec(0.0)
        Dim iAuthorityCurrencyID As Integer = 0
        Dim bHasPaymentsAuthority As Boolean = False
        Dim bNoPaymentsAuthority As Boolean = False
        Dim sDocumentRef As String = String.Empty
        Dim iReferredTransactionCount As Integer = 0
        Dim iNonReferredTransactionCount As Integer = 0
        Dim dReferredTransactionAmount As Decimal = CDec(0.0)
        Dim dNonReferredTransactionAmount As Decimal = CDec(0.0)
        Dim dTotalAmountReferredForAuthorisation As Decimal = CDec(0.0)
        Dim iNoOfTransactionsReferredForAuthorisation As Integer = 0
        Try

            Dim oUserAuthRequest As New BaseGetUserAuthorityValueRequestType
            Dim oUserAuthResponse As New BaseGetUserAuthorityValueResponseType

            Dim oCoreBusiness As New CoreBusiness()
            Dim oSAMErrorCollection As New SAMErrorCollection
            If oSettleAllClaimPaymentsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.SettleAllClaimPaymentsRequestType) Then
                oResponse = New SAMForInsuranceV2ImplementationTypes.SettleAllClaimPaymentsResponseType
            End If
            'add new warning colection
            oResponse.Warnings = New System.Collections.Generic.List(Of BaseGeneralWarningResponseType)
            'validate each payment request
            For Each oPayment In oSettleAllClaimPaymentsRequest.claimPayments
                oPayment.ClaimPaymentBranchKey = oCoreBusiness.GetListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oPayment.ClaimPaymentBranchCode)
                oPayment.CurrencyKey = oCoreBusiness.GetListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, oPayment.CurrencyCode)
                oPayment.Validate(oSAMErrorCollection)
            Next
            oSAMErrorCollection.CheckForErrors()

            'Check payment authority
            oUserAuthRequest.BranchCode = "HeadOff"
            oUserAuthRequest.UserAuthorityOption = UserAuthorityOptions.HasPaymentsAuthority
            oUserAuthRequest.UserCode = _SiriusUser.Username
            oUserAuthResponse = GetUserAuthorityValue(oUserAuthRequest)
            bHasPaymentsAuthority = CBool(oUserAuthResponse.UserAuthorityValue)
            dAuthorityAmount = oUserAuthResponse.UserAuthorityOptionalValue2
            iAuthorityCurrencyID = oUserAuthResponse.UserAuthorityOptionalValue1
            'loop through each payment
            For Each oPayment In oSettleAllClaimPaymentsRequest.claimPayments
                sDocumentRef = oPayment.DocumentRef
                Dim bIsDeleted As Boolean = False
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_is_account_deleted")
                    cmd.AddOutParameter("@Is_Deleted", SqlDbType.Int)
                    cmd.AddInParameter("@Account_Code", SqlDbType.VarChar).Value = oPayment.AccountCode
                    cmd.AddInOutParameter("@Account_Id", SqlDbType.Int)
                    con.ExecuteNonQuery(cmd)
                    bIsDeleted = Cast.ToBoolean(cmd.Parameters("@Is_Deleted").Value, False)
                    oPayment.AccountKey = Cast.ToInt32(cmd.Parameters("@Account_Id").Value, 0)
                End Using
                'check account is not deleted
                If bIsDeleted = False Then
                    If iAuthorityCurrencyID <> oPayment.CurrencyKey Then
                        GetCurrencyToCurrencyExchangeRate(con, Date.Now, iAuthorityCurrencyID, oPayment.CurrencyKey, oPayment.ClaimPaymentBranchKey, dRate)
                        dConvertedAmount = dAuthorityAmount * dRate
                    Else
                        dConvertedAmount = dAuthorityAmount
                    End If
                    If bHasPaymentsAuthority AndAlso dConvertedAmount < oPayment.ClaimPaymentAmount Then

                        dTotalAmountReferredForAuthorisation += oPayment.ClaimPaymentAmount
                        iNoOfTransactionsReferredForAuthorisation += 1
                        bNoPaymentsAuthority = True
                        iReferredTransactionCount = iReferredTransactionCount + 1
                        dReferredTransactionAmount = dReferredTransactionAmount + oPayment.ClaimPaymentAmount
                        'add a warning claim payment referred
                        AddWarning(oResponse.Warnings,
                         SAMBusinessWarnings.UserDoesntHaveAuthorityToMakeThisPaymentPaymentWasReferred,
                            oPayment.DocumentRef & " was Referred because User Doesn’t Have Authority To Make This Payment.")
                        'save summary for referred transaction
                        SaveSummary(oResponse, oPayment.MediaTypeCode, oPayment.ClaimPaymentAmount, "Referred")
                    Else
                        bNoPaymentsAuthority = False
                        'save summary for Settled transaction
                        SaveSummary(oResponse, oPayment.MediaTypeCode, oPayment.ClaimPaymentAmount, "Settled")
                    End If
                    SettleSingleClaimPayment(con, oPayment, oCoreBusiness, bNoPaymentsAuthority, oSAMErrorCollection)
                Else
                    'add a warning account is deleted in system
                    AddWarning(oResponse.Warnings,
                        SAMBusinessWarnings.PaymentToDeletedParty,
                        oPayment.DocumentRef & " can’t be processed because Party associated with the client is deleted.")
                End If
            Next
            Return oResponse
        Catch
            'add a warning for unknown error
            AddWarning(oResponse.Warnings,
                    SAMBusinessWarnings.GeneralFailure,
                    sDocumentRef & " can’t be processed because of an unknown error. Check Error log for more details.")

        End Try
    End Function
