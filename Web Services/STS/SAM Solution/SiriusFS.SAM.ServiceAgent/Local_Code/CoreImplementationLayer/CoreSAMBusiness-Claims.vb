    Private Sub ValidateClaimStatus(ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal oClaim As BaseClaimType)

        Dim dt As New DataTable

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_GetCurrentReserveRecovery")
            cmd.AddInParameter("@ClaimId", SqlDbType.Int).Value = oClaim.ClaimId
            con.ExecuteDataTable(cmd, dt)
        End Using

        Dim dr As DataRow
        For Each dr In dt.Rows

            Const kClaimStatus As Integer = 0
            Const kCurrentReserve As Integer = 1
            Const kCurrentRecovery As Integer = 2

            Dim lClaimStatusId As Integer
            Dim crCurrentReserve As Decimal
            Dim crCurrentRecovery As Decimal

            lClaimStatusId = Cast.ToInt32(dr.Item(kClaimStatus), 0)
            crCurrentReserve = Cast.ToDecimal(dr.Item(kCurrentReserve), 0)
            crCurrentRecovery = Cast.ToDecimal(dr.Item(kCurrentRecovery), 0)

            ' default the claim status
            oClaim.ClaimStatusId = lClaimStatusId

            ' get the closed claim status id 
            Dim lClosedClaimStatusId As Integer = oBusiness.GetAndValidateListItemFromCode(
                Core.STSListType.PMLookup, PMLookupTable.ClaimStatus, ClaimStatus.Closed, "ClaimStatusCode")

            ' get the live claim status id 
            Dim lLiveClaimStatusId As Integer = oBusiness.GetAndValidateListItemFromCode(
             Core.STSListType.PMLookup, PMLookupTable.ClaimStatus, ClaimStatus.LiveOpenClaim, "ClaimStatusCode")

            ' if the claim is already closed
            If lClaimStatusId = lClosedClaimStatusId Then

                ' if the current recovery and the current reserve are not zero
                If crCurrentRecovery <> 0 AndAlso crCurrentReserve <> 0 Then

                    ' update the claim status
                    UpdateClaimStatus(con, oClaim.ClaimId, lLiveClaimStatusId)

                    ' set the claim status id 
                    oClaim.ClaimStatusId = lLiveClaimStatusId

                End If

            End If

        Next

    End Sub

