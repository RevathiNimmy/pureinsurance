    ''' <summary>
    ''' process claims reinsurance
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="lClaimid"></param>
    ''' <remarks></remarks>
    Private Sub ProcessClaimsReinsurance(ByVal con As SiriusConnection,
                                    ByVal lClaimId As Integer,
                                    ByVal lBalanceAndCloseClaim As Integer)

        Dim oCoreBusiness As New CoreBusiness
        Dim sRI2007 As String = ""

        ' calculate the claims reinsurance
        sRI2007 = oCoreBusiness.GetProductOption(gPMConstants.SIRHiddenOptions.SIROPTEnableRI2007, 1)
        If sRI2007 = "1" Then
            CalculateClaimsRI2007(con, lClaimId, lBalanceAndCloseClaim)
        Else
            CalculateClaimsRI(con, lClaimId, lBalanceAndCloseClaim)
        End If

        Dim aoRIArrangement() As RIArrangement = Nothing

        ' store the RI Arrangment Details into the structure
        StoreClaimRIArrangements(con, lClaimId, aoRIArrangement, lBalanceAndCloseClaim)

        Dim lValid As Integer = 0
        Dim lBand As Integer = 0

        ' validate the reinsurance bands
        ValidateClaimRIArrangements(aoRIArrangement, lValid, lBand)

        ' if the validation of the bands failed
        If lValid <> 0 Then

            ' build appropriate error message
            Dim sMessage As String = String.Empty
            If lValid = AutoReinsuranceFailure.Payment Then
                sMessage = "Auto Reinsurance of payment amounts failed on Band:-" & lBand
            ElseIf lValid = AutoReinsuranceFailure.Reserve Then
                sMessage = "Auto Reinsurance of reserve amounts failed on Band:-" & lBand
            End If

            ' raise error
            Dim oSAMErrorCollection As New SAMErrorCollection
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.AutoReinsuranceFailed,
                                                    SAMBusinessErrors.AutoReinsuranceFailed.ToString,
                                                        sMessage)
            oSAMErrorCollection.CheckForErrors()

        End If

    End Sub

