    ''' <summary>
    ''' To Generate Cash List
    ''' </summary>
    ''' <param name="oRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function GenerateCashList(ByVal oRequest As BaseGenerateCashListRequestType) As BaseGenerateCashListResponseType

        Dim oResponse As New BaseGenerateCashListResponseType

        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim oCLMChangeClaimStatus As New bCLMChangeClaimStatus.Business

        SAMFunc.InitialiseSBOObject(oObject:=oCLMChangeClaimStatus, siriusUser:=_SiriusUser, sObjectName:="bCLMChangeClaimStatus.Business")

        ' set the process modes
        Dim nReturn As Integer = oCLMChangeClaimStatus.SetProcessModes(0, 0, 0, "C_SA", Date.Today)
        If (nReturn <> PMEReturnCode.PMTrue) Then
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                "bCLMChangeClaimStatus.Business.SetProcessModes")
            oSAMErrorCollection.CheckForErrors()
        End If

        nReturn = oCLMChangeClaimStatus.GenerateClaimCashList(oRequest.ClaimId)
        If nReturn <> PMEReturnCode.PMTrue Then
            ' raise an error
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bCLMChangeClaimStatus.Business.GenerateCashList Failed")
            oSAMErrorCollection.CheckForErrors()
        End If

        ' destroy the instance of oCLMChangeClaimStatus.busness
        If oCLMChangeClaimStatus IsNot Nothing Then
            oCLMChangeClaimStatus.Dispose()
            oCLMChangeClaimStatus = Nothing
        End If
        Return oResponse

    End Function

