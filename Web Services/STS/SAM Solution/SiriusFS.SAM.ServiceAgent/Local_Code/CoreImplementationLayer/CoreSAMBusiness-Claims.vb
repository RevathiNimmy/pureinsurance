    Public Overloads Function UpdateClaimReservesOrPayments(ByVal con As SiriusConnection, ByVal oUpdateClaimReservesOrPaymentsRequest As BaseUpdateClaimReservesOrPaymentsRequestType) As BaseUpdateClaimReservesOrPaymentsResponseType
        Dim oUpdateClaimReservesOrPaymentsResponse As New BaseUpdateClaimReservesOrPaymentsResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iBaseClaimKey As Integer
        Dim sTransactionType As String = ""
        Dim sRI2007 As String = ""
        Dim iClaimXOLCount As Integer = 0

        If oUpdateClaimReservesOrPaymentsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateClaimReservesOrPaymentsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateClaimReservesOrPaymentsResponse = New SAMForInsuranceV2ImplementationTypes.UpdateClaimReservesOrPaymentsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If


        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        If String.IsNullOrEmpty(oUpdateClaimReservesOrPaymentsRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If


        GetBaseClaimKey(con, oUpdateClaimReservesOrPaymentsRequest.ClaimKey, iBaseClaimKey)


        If CheckDuplicateClaimVersion(con, oUpdateClaimReservesOrPaymentsRequest.ClaimKey) Then
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.RecordChanged,
                                                        SAMBusinessErrors.RecordChanged.ToString,
                                                        "There is already a Live claim exists with Same Version Number")
            oSAMErrorCollection.CheckForErrors()
        End If

        '' check timestamp and lock
        If oUpdateClaimReservesOrPaymentsRequest.ClaimKey <> iBaseClaimKey Then
            oCoreBusiness.CheckSAMTSAndLock(con, oUpdateClaimReservesOrPaymentsRequest.BranchCode,
                CoreBusiness.LockName.ClaimId,
                iBaseClaimKey,
                oUpdateClaimReservesOrPaymentsRequest.TimeStamp)
        End If

        ' process the maintain claim functionality
        If oUpdateClaimReservesOrPaymentsRequest.ProcessType = 1 Or oUpdateClaimReservesOrPaymentsRequest.ProcessType = 2 Then
            ProcessUpdateClaimReserves(con, oCoreBusiness, oUpdateClaimReservesOrPaymentsRequest, oUpdateClaimReservesOrPaymentsResponse, oSAMErrorCollection)
        ElseIf oUpdateClaimReservesOrPaymentsRequest.ProcessType = 3 Then
            ProcessUpdateClaimPayments(con, oCoreBusiness, oUpdateClaimReservesOrPaymentsRequest, oUpdateClaimReservesOrPaymentsResponse, oSAMErrorCollection)
        ElseIf oUpdateClaimReservesOrPaymentsRequest.ProcessType = 4 Then
            ProcessUpdateClaimReserves(con, oCoreBusiness, oUpdateClaimReservesOrPaymentsRequest, oUpdateClaimReservesOrPaymentsResponse, oSAMErrorCollection)
            ProcessUpdateClaimPayments(con, oCoreBusiness, oUpdateClaimReservesOrPaymentsRequest, oUpdateClaimReservesOrPaymentsResponse, oSAMErrorCollection, True)
        ElseIf oUpdateClaimReservesOrPaymentsRequest.ProcessType = 5 Then
            ProcessUpdateThisClaimPayments(con, oCoreBusiness, oUpdateClaimReservesOrPaymentsRequest, oUpdateClaimReservesOrPaymentsResponse, oSAMErrorCollection)
        End If
        If oUpdateClaimReservesOrPaymentsRequest.ProcessType = 1 Then
            sTransactionType = "C_CO"
        ElseIf oUpdateClaimReservesOrPaymentsRequest.ProcessType = 2 Then
            sTransactionType = "C_CR"
        Else
            sTransactionType = "C_CP"
        End If

        ProcessClaimsCoinsurance(con, oCoreBusiness, oUpdateClaimReservesOrPaymentsRequest.ClaimKey, sTransactionType, oUpdateClaimReservesOrPaymentsRequest.BranchCode)

        ProcessClaimsReinsurance(con:=con,
                          lClaimId:=oUpdateClaimReservesOrPaymentsRequest.ClaimKey,
                          lBalanceAndCloseClaim:=kBalanceAndCloseClaim)
        If sTransactionType = "C_CP" Then
            sRI2007 = oCoreBusiness.GetProductOption(ProductOption.RI2007, 1)
            If sRI2007 = "1" Then
                ValidateXOLPayment(con, oUpdateClaimReservesOrPaymentsRequest.ClaimKey, iClaimXOLCount)
                If iClaimXOLCount > 0 Then
                    oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.PendingClaimWithXOLLines, SAMBusinessErrors.PendingClaimWithXOLLines.ToString, "You cannot add any further payments onto this claim as it has pending authorisations with Excess of Loss Reinsurance.")
                    oSAMErrorCollection.CheckForErrors()
                End If
            End If
        End If

        If oUpdateClaimReservesOrPaymentsRequest.ClaimKey <> iBaseClaimKey Then
            oCoreBusiness.UnlockAndGetSAMTS(
                    con,
                    oUpdateClaimReservesOrPaymentsRequest.BranchCode,
                    CoreBusiness.LockName.ClaimId,
                    iBaseClaimKey,
                     oUpdateClaimReservesOrPaymentsResponse.TimeStamp)
        End If
        ' return the populated response object
        Return oUpdateClaimReservesOrPaymentsResponse

    End Function

    Private Sub GetClaimVersionDetail(ByVal con As SiriusConnection, ByVal iClaimKey As Integer, ByVal iSourceId As Integer, ByRef oClaim As BaseClaimType)
        Dim dsClaimDetails As DataSet
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = iClaimKey
            cmd.AddInParameter("@source_id", SqlDbType.Int).Value = iSourceId
            dsClaimDetails = con.ExecuteDataSet(cmd, "Row")
        End Using

        If dsClaimDetails.Tables(0).Rows.Count > 0 Then
            Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
            With oClaim
                .CurrencyId = Cast.DefaultIfNull(Cast.ToInt32(dr.Item("currency_id")))
                .ClaimVersion = Cast.DefaultIfNull(Cast.ToInt32(dr.Item("version_id")))
                .VersionId = Cast.DefaultIfNull(Cast.ToInt32(dr.Item("version_id")))
            End With
        End If
    End Sub

    Private Sub GetBaseClaimKey(ByVal con As SiriusConnection, ByVal v_iClaimKey As Integer, ByRef r_iBaseClaimKey As Integer)
        Dim dsClaimDetails As DataSet
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Base_Claim")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = v_iClaimKey
            dsClaimDetails = con.ExecuteDataSet(cmd, "Row")
        End Using

        Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
        If dsClaimDetails.Tables(0).Rows.Count > 0 Then
            r_iBaseClaimKey = Cast.DefaultIfNull(Cast.ToInt32(dr.Item("base_Claim_id")))
        End If
    End Sub

    Private Function CheckDuplicateClaimVersion(ByVal con As SiriusConnection, ByVal v_iClaimKey As Integer) As Boolean

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Check_Duplicate_Version")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = v_iClaimKey
            cmd.AddOutParameter("@is_duplicate", SqlDbType.Bit)
            con.ExecuteNonQuery(cmd)
            If Cast.ToInt16(cmd.Parameters("@is_duplicate").Value, 0) = 1 Then
                Return True
            Else
                Return False
            End If
        End Using
    End Function

