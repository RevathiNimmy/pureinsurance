    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="lBranchID"></param>
    ''' <param name="lSourceId"></param>
    ''' <param name="lClaimId"></param>
    ''' <param name="sClaimNumber"></param>
    ''' <param name="totCurrAmount"></param>
    ''' <remarks></remarks>
    Private Sub CreateReferralTask(ByVal Con As SiriusConnection,
                                       ByVal lBranchID As Integer,
                                       ByVal lSourceId As Integer,
                                       ByVal lClaimId As Integer,
                                       ByVal sClaimNumber As String,
                                       ByVal totCurrAmount As Decimal)
        Dim sUnderwritting As String = String.Empty
        Dim oBusiness As New CoreBusiness
        Dim lTaskGroupId As Integer
        Dim sMultiStepApproval As String = String.Empty
        Dim sUserGroupCode As String = String.Empty
        Dim lUserGroupId As Integer
        Dim sTaskDescription As String = String.Empty
        Dim lTaskId As Integer
        Dim lWrkTaskInsCnt As Integer
        Const ACClaimPaymentsType As Integer = 1
        Const ACAuthoriseTask As String = "Authorise Claim Payments"

        sUnderwritting = oBusiness.GetProductOption(ProductOption.Underwriting, 1)
        If sUnderwritting = "U" Then
            lTaskGroupId = InternalSAMConstants.ACTClaimAdminTaskGroupID
        Else
            lTaskGroupId = InternalSAMConstants.ACTBrokingTaskGroupID
        End If

        sMultiStepApproval = oBusiness.GetProductOption(ProductOption.MultiStepApproval, 1)

        If sMultiStepApproval = "1" Then

            GetStepGroupCode(con:=Con,
            sGroupType:="Claim Payments",
            sSourceId:=CStr(lSourceId),
            lPaymentType:=ACClaimPaymentsType,
            lPaymentId:=lClaimId,
            r_sGroupCode:=sUserGroupCode)

            If Cast.ToString(sUserGroupCode, "") = "" Then
                GetClaimAdminGroup(con:=Con,
                                      r_lGroupId:=lUserGroupId)
            Else
                GetClaimAdminGroup(con:=Con,
                                        r_lGroupId:=lUserGroupId,
                                        sGroupCode:=sUserGroupCode)

            End If
            sTaskDescription = "Authorise Claim Payment for Claim Number: " &
                                sClaimNumber & " for the amount of: " &
                                totCurrAmount

        Else
            GetClaimAdminGroup(con:=Con,
                                    r_lGroupId:=lUserGroupId)

            sTaskDescription = sClaimNumber & " - " & ACAuthoriseTask
        End If

        getTaskGroupId(Con:=Con,
                            sPMWrkTaskCode:="AUTHPMNT",
                            r_PMWrkTaskId:=lTaskId)

        SaveReferralTask(con:=Con,
                    lTaskGroupId:=lTaskGroupId,
                    ltaskId:=lTaskId,
                    sCustomer:="System",
                    TaskDueDate:=Now,
                    lUserGroupId:=lUserGroupId,
                    lUserId:=Nothing,
                    sDescription:=sTaskDescription,
                    ltaskStatus:=0,
                    lIsUrgent:=0,
                    DateCreated:=Now,
                    lCreatedById:=_SiriusUser.UserID,
                    lLastModified:=Now,
                    lModifiedById:=vbNull,
                    lIsvisible:=1,
                    sWorkFlowInformation:="",
                    r_lWrkTaskInsCnt:=lWrkTaskInsCnt)

        AddTaskInstKey(con:=Con,
                            lWrkTaskInsCnt:=lWrkTaskInsCnt,
                            sKeyName:="claim_id",
                            sKeyValue:=CStr(lClaimId))

        AddTaskInstKey(con:=Con,
                                    lWrkTaskInsCnt:=lWrkTaskInsCnt,
                                    sKeyName:="claim_number",
                                    sKeyValue:=CStr(sClaimNumber))

    End Sub

    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="sGroupType"></param>
    ''' <param name="sSourceId"></param>
    ''' <param name="lPaymentType"></param>
    ''' <param name="lPaymentId"></param>
    ''' <param name="r_sGroupCode"></param>
    ''' <remarks></remarks>
    Private Sub GetStepGroupCode(ByVal con As SiriusConnection,
                                    ByVal sGroupType As String,
                                    ByVal sSourceId As String,
                                    ByVal lPaymentType As Integer,
                                    ByVal lPaymentId As Integer,
                                    ByRef r_sGroupCode As String)
        Dim dsSteps As DataSet = Nothing
        Dim dsApprovalSteps As DataSet = Nothing
        Dim dsStepDesc As DataSet = Nothing
        'Dim bGroupsExists As Boolean = False

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Debtor_User_Groups")
            cmd.AddInParameter("@GroupType", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(sGroupType)
            cmd.AddInParameter("@SourceID", SqlDbType.Int).Value = Convert.ToInt32(sSourceId)

            dsSteps = con.ExecuteDataSet(cmd, "StepGroupCode")
        End Using

        If dsSteps.Tables(0).Rows.Count > 0 Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Approval_Records_Sel")
                cmd.AddInParameter("@PaymentType", SqlDbType.Int).Value = Cast.NullIfDefault(lPaymentType)
                cmd.AddInParameter("@PaymentID", SqlDbType.Int).Value = lPaymentId
                dsApprovalSteps = con.ExecuteDataSet(cmd, "ApprovedSteps")
            End Using

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Approval_Step_Details")
                cmd.AddInParameter("@GroupType", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(sGroupType)
                cmd.AddInParameter("@SourceID", SqlDbType.Int).Value = Convert.ToInt32(sSourceId)
                cmd.AddInParameter("@StepNumber", SqlDbType.Int).Value = dsApprovalSteps.Tables(0).Rows.Count + 1

                dsStepDesc = con.ExecuteDataSet(cmd, "StepDesc")
                If dsStepDesc.Tables(0).Rows.Count > 0 Then
                    r_sGroupCode = Cast.ToString(dsStepDesc.Tables(0).Rows(0).Item(1))
                Else
                    r_sGroupCode = ""
                End If
            End Using

        End If

    End Sub

