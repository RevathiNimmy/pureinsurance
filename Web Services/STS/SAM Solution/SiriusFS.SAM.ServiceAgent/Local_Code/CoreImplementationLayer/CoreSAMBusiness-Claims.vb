                        cmd.AddInParameter("@client_tel_no_off", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(Cast.NullIfDefault(oOpenClaimRequest.Claim.Client.PartyTelNoOff, String.Empty))
                       
                    End If

                    If oOpenClaimRequest.Claim.Insurer IsNot Nothing Then
