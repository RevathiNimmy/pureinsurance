    ''' <summary>
    ''' Implementation logic to delete the abandon claim
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oRequest"></param>
    ''' <returns></returns>
    Public Overloads Function DeletAbandonClaim(ByVal con As SiriusConnection,
        ByVal oRequest As BaseDeleteAbandonClaimRequestType) As BaseDeleteAbandonClaimResponseType

        Dim oBaseDeleteAbandonClaimResponse As New BaseDeleteAbandonClaimResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim oBusiness As New CoreBusiness
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oResponse As New BaseImplementationTypes.BaseDeleteAbandonClaimResponseType

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.DeleteAbandonClaimRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.DeleteAbandonClaimResponseType
        End If
        '*******************************************************************************************
        'Structure Validation
        '*******************************************************************************************
        ' Check mandatory fields
        If String.IsNullOrEmpty(oRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, "BranchCode")
        End If

        If oRequest.ClaimKey = 0 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "Claim Key")
        End If

        '' exit if there are any missing parameters
        oSAMErrorCollection.CheckForErrors()

        Dim iBranchCodeId As Integer
        Dim nClaimKey As Integer
        'Lookups Validations
        Try
            iBranchCodeId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode")
        Catch ex As Exception
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                    SAMInvalidData.InvalidLookupListValue.ToString,
                                    "BranchCode",
                                    oRequest.BranchCode)
        End Try

        If oRequest.ClaimKey <> 0 Then
            nClaimKey = GetAndValidateSpecifiedTableCode(con, "Claim", "Claim_id", "Claim_id", oRequest.ClaimKey.ToString, oSAMErrorCollection, "ClaimKey")
            oSAMErrorCollection.CheckForErrors()
        End If

        '' exit if there are any missing parameters
        oSAMErrorCollection.CheckForErrors()

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_delete_claim")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
            cmd.AddOutParameter("@status", SqlDbType.Int).Value = 0
            con.ExecuteNonQuery(cmd)

        End Using
        Return oResponse

    End Function


