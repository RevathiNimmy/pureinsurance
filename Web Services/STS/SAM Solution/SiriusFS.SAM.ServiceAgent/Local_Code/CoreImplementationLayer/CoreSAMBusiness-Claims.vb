    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="v_sQuoteRefPassword"></param>
    ''' <param name="v_sDataModelCode"></param>
    ''' <param name="v_lGisPolicyLinkId"></param>
    ''' <remarks></remarks>
    Private Sub UpdateGisPolicyLinkQuoteRef(
                            ByVal Con As SiriusConnection,
                            ByVal v_sQuoteRefPassword As String,
                            ByVal v_sDataModelCode As String,
                            ByVal v_lGisPolicyLinkId As Integer)

        Dim sPrefix As String = String.Empty
        Dim sPaddedValue As String = String.Empty
        Dim iDivisor As Integer
        Dim lRemainder As Long
        Dim sQuoteRef As String = String.Empty
        Const OneBillion As Integer = 1000000000
        Dim sEncryptedPassword As String = String.Empty

        'Find letter prefix of the given number using integer division
        iDivisor = v_lGisPolicyLinkId \ OneBillion

        Select Case iDivisor
            Case 0
                sPrefix = "AA"
            Case 1
                sPrefix = "AB"
            Case 2
                sPrefix = "AC"
        End Select

        'Find remainder of the given number
        lRemainder = v_lGisPolicyLinkId Mod OneBillion

        'If remainder is zero then set to 1 to prevent AA000000000 etc
        If lRemainder = 0 Then lRemainder = 1

        'Zero pad remainder to be 9 characters long
        sPaddedValue = lRemainder.ToString("000000000")

        'Return letter prefix and padded remainder
        sQuoteRef = sPrefix & sPaddedValue

        If (UCase(Trim$(v_sDataModelCode)) = "MAR") _
        Or (UCase(Trim$(v_sDataModelCode)) = "SIF") Then
            sQuoteRef = "LAW" & Right$(sQuoteRef, Len(sQuoteRef) - 3)
        End If

        SAMFunc.Encrypt(v_sQuoteRefPassword,
                    sEncryptedPassword)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_gis_policy_link_qte_ref_upd")
            cmd.AddInParameter("@gis_policy_link_id", SqlDbType.Int).Value = v_lGisPolicyLinkId
            cmd.AddInParameter("@quote_ref", SqlDbType.Char, 11).Value = sQuoteRef
            cmd.AddInParameter("@quote_ref_password", SqlDbType.VarChar, 30).Value = sEncryptedPassword
            Con.ExecuteNonQuery(cmd)
        End Using

    End Sub

