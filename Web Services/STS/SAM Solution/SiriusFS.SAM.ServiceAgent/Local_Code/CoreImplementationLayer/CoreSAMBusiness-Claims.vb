    Private Function GetBalanceAndCloseClaimStatus(ByVal oClaim As BaseClaimType) As Boolean

        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nIsClosedClaimCheckStatus As Integer = 0
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            nIsClosedClaimCheckStatus = GetAndValidateSpecifiedTableCode(con, "Progress_Status", "is_closed_check_status", "code", oClaim.ProgressStatusCode, oSAMErrorCollection, "is_closed_check_status")
        End Using

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                        SiriusUserDefaults.AppName)

            Dim iProgstatus As Integer
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_LookUp_List")

                cmd.AddInParameter("@KeyIdFieldName", SqlDbType.VarChar).Value = "code"
                cmd.AddInParameter("@DescFieldName", SqlDbType.VarChar).Value = "is_closed_check_status"
                cmd.AddInParameter("@TableName", SqlDbType.VarChar).Value = "progress_status"

                Dim dt As DataTable = con.ExecuteDataTable(cmd)

                If dt IsNot Nothing And dt.Rows.Count <> 0 Then
                    For iProgstatus = 0 To dt.Rows.Count - 1
                        If dt.Rows(iProgstatus).Item(0).ToString().ToUpper().Trim() = oClaim.ProgressStatusCode.ToUpper.Trim AndAlso dt.Rows(iProgstatus).Item(1).ToString().ToUpper().Trim() = "1" Then
                            If oClaim.PreviousClaimStatusCode <> ClaimStatus.Closed Then
                                Return True
                            End If
                        End If
                    Next
        Return False
                End If
                Return False
            End Using
        End Using

    End Function
    Private Function GetBalanceAndCloseClaimStatus(ByVal con As SiriusConnection, ByVal oClaim As BaseClaimType) As Boolean

        Dim bReturnStatus As Boolean = False
        If oClaim.ProgressStatusCode <> "" Then
            ' if the claim has been set to closed 
            Dim lIs_closed_check_status As Integer
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_clm_is_progress_status_closed")
                cmd.AddOutParameter("@is_closed_check_status", SqlDbType.Int)
                cmd.AddInParameter("@ProgressStatusCode", SqlDbType.VarChar).Value = oClaim.ProgressStatusCode

                con.ExecuteNonQuery(cmd)
                lIs_closed_check_status = Cast.ToInt32(cmd.Parameters("@is_closed_check_status").Value, 0)
            End Using
            ' and the previous claim status was not closed
            If oClaim.PreviousClaimStatusCode <> ClaimStatus.Closed And lIs_closed_check_status = 1 Then
                bReturnStatus = True
            End If
        End If

        Return bReturnStatus

    End Function
    Private Overloads Sub CreateTaskExternalClaimHandler(ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal sBranchCode As String,
    ByVal oRequest As BaseClaimMaintainRequestType)

        ' if this claim isnt info only and the previous one was
        If Not oRequest.Claim.InfoOnly AndAlso oRequest.Claim.PreviousInfoOnly Then

            ' and the claim is not closed
            If oBusiness.GetListItemFromID(Core.STSListType.PMLookup,
                PMLookupTable.ClaimStatus,
                oRequest.Claim.ClaimStatusId) <> ClaimStatus.LiveOpenClaim Then

                ' and the user indicated that this claim should be handled externally
                If oRequest.Claim.ExternalHandler Then
                    Dim sOptionValue As String = String.Empty

                    'Create GetProductRiskOptions request
                    Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType

                    ' Claim Handler Acknowledged Task Allowed Time
                    'oBusiness.GetSystemOption(sBranchCode, SystemOption.ClaimHandlerAcknowlegedTaskAllowedTime, sOptionValue)
                    oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ExtClmHandlerAcknowledgedTaskAllowedTime
                    sOptionValue = GetProductRiskOptions(con, oRequest.Claim.ProductId, oGetProductRiskOptionsRequest)
                    Dim lAcknowledgedTaskTimeAllowed As Integer = Cast.ToInt32(sOptionValue, 0)

                    ' Claim Handler Prelinary Report Task Allowed Time
                    'oBusiness.GetSystemOption(sBranchCode, SystemOption.ClaimHandlerPreliminaryReportTaskAllowedTime, sOptionValue)
                    oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ExtClmHandlerSupplyPreReportTaskAllowedTime
                    sOptionValue = GetProductRiskOptions(con, oRequest.Claim.ProductId, oGetProductRiskOptionsRequest)
                    Dim lPreliminaryReportTaskTimeAllowed As Integer = Cast.ToInt32(sOptionValue, 0)

                    ' Claim Default Task Group
                    'oBusiness.GetSystemOption(sBranchCode, SystemOption.ClaimTaskGroup, sOptionValue)
                    oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ClaimTaskGroup
                    sOptionValue = GetProductRiskOptions(con, oRequest.Claim.ProductId, oGetProductRiskOptionsRequest)
                    Dim lTaskGroupId As Integer = Cast.ToInt32(sOptionValue, 0)

                    ' Claim Default User Group
                    'oBusiness.GetSystemOption(sBranchCode, SystemOption.ClaimUserGroup, sOptionValue)
                    oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ClaimUserGroup
                    sOptionValue = GetProductRiskOptions(con, oRequest.Claim.ProductId, oGetProductRiskOptionsRequest)
                    Dim lUserGroupId As Integer = Cast.ToInt32(sOptionValue, 0)

                    ' Task Id
                    Dim lTaskId As Integer = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Task, Task.Memo, "TaskCode")

                    ' create external handler tasks
                    Dim sClientName As String = oRequest.Claim.ClientShortName
                    Dim sDescription As String = "Claim No. " & oRequest.Claim.ClaimNumber & " - External Claims Handler Acknowledged Task"
                    Dim dtTaskDueDate As Date = DateAdd(DateInterval.Day, CDbl(lAcknowledgedTaskTimeAllowed), Date.Now)
                    Dim lTaskInstanceCnt As Integer

                    ' create external handler acknowledged task
                    CreateTaskInstance(con, lTaskInstanceCnt, lTaskGroupId, lTaskId,
                        sClientName, dtTaskDueDate, lUserGroupId, _SiriusUser.UserID,
                        sDescription, PMEWrkManTaskStatus.pmeWMTSNew, 0, Date.Today,
                        _SiriusUser.UserID, Date.Today, _SiriusUser.UserID, 1, String.Empty)

                    sClientName = oRequest.Claim.ClientShortName
                    sDescription = "Claim No. " & oRequest.Claim.ClaimNumber & " - External Claims Handler Preliminary Report Task"
                    dtTaskDueDate = DateAdd(DateInterval.Day, CDbl(lPreliminaryReportTaskTimeAllowed), Date.Now)

                    ' create external handler preliminary report task
                    CreateTaskInstance(con, lTaskInstanceCnt, lTaskGroupId, lTaskId,
                        sClientName, dtTaskDueDate, lUserGroupId, _SiriusUser.UserID,
                        sDescription, PMEWrkManTaskStatus.pmeWMTSNew, 0, Date.Today,
                        _SiriusUser.UserID, Date.Today, _SiriusUser.UserID, 1, String.Empty)

                End If

            End If

        End If

    End Sub

    Private Overloads Sub CreateTaskExternalClaimHandler(ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal sBranchCode As String,
    ByVal oClaim As BaseClaimMaintainType)

        ' if this claim isnt info only and the previous one was
        If Not oClaim.InfoOnly AndAlso oClaim.PreviousInfoOnly Then

            ' and the claim is not closed
            If oBusiness.GetListItemFromID(Core.STSListType.PMLookup,
                PMLookupTable.ClaimStatus,
                oClaim.ClaimStatusId) <> ClaimStatus.LiveOpenClaim Then

                ' and the user indicated that this claim should be handled externally
                If oClaim.ExternalHandler Then
                    Dim sOptionValue As String = String.Empty

                    'Create GetProductRiskOptions request
                    Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType

                    ' Claim Handler Acknowledged Task Allowed Time
                    'oBusiness.GetSystemOption(sBranchCode, SystemOption.ClaimHandlerAcknowlegedTaskAllowedTime, sOptionValue)
                    oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ExtClmHandlerAcknowledgedTaskAllowedTime
                    sOptionValue = GetProductRiskOptions(con, oClaim.ProductId, oGetProductRiskOptionsRequest)
                    Dim lAcknowledgedTaskTimeAllowed As Integer = Cast.ToInt32(sOptionValue, 0)

                    ' Claim Handler Prelinary Report Task Allowed Time
                    'oBusiness.GetSystemOption(sBranchCode, SystemOption.ClaimHandlerPreliminaryReportTaskAllowedTime, sOptionValue)
                    oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ExtClmHandlerSupplyPreReportTaskAllowedTime
                    sOptionValue = GetProductRiskOptions(con, oClaim.ProductId, oGetProductRiskOptionsRequest)
                    Dim lPreliminaryReportTaskTimeAllowed As Integer = Cast.ToInt32(sOptionValue, 0)

                    ' Claim Default Task Group
                    'oBusiness.GetSystemOption(sBranchCode, SystemOption.ClaimTaskGroup, sOptionValue)
                    oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ClaimTaskGroup
                    sOptionValue = GetProductRiskOptions(con, oClaim.ProductId, oGetProductRiskOptionsRequest)
                    Dim lTaskGroupId As Integer = Cast.ToInt32(sOptionValue, 0)

                    ' Claim Default User Group
                    'oBusiness.GetSystemOption(sBranchCode, SystemOption.ClaimUserGroup, sOptionValue)
                    oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ClaimUserGroup
                    sOptionValue = GetProductRiskOptions(con, oClaim.ProductId, oGetProductRiskOptionsRequest)
                    Dim lUserGroupId As Integer = Cast.ToInt32(sOptionValue, 0)

                    ' Task Id
                    Dim lTaskId As Integer = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Task, Task.Memo, "TaskCode")

                    ' create external handler tasks
                    Dim sClientName As String = oClaim.ClientShortName
                    Dim sDescription As String = "Claim No. " & oClaim.ClaimNumber & " - External Claims Handler Acknowledged Task"
                    Dim dtTaskDueDate As Date = DateAdd(DateInterval.Day, CDbl(lAcknowledgedTaskTimeAllowed), Date.Now)
                    Dim lTaskInstanceCnt As Integer

                    ' create external handler acknowledged task
                    CreateTaskInstance(con, lTaskInstanceCnt, lTaskGroupId, lTaskId,
                        sClientName, dtTaskDueDate, lUserGroupId, _SiriusUser.UserID,
                        sDescription, PMEWrkManTaskStatus.pmeWMTSNew, 0, Date.Today,
                        _SiriusUser.UserID, Date.Today, _SiriusUser.UserID, 1, String.Empty)

                    sClientName = oClaim.ClientShortName
                    sDescription = "Claim No. " & oClaim.ClaimNumber & " - External Claims Handler Preliminary Report Task"
                    dtTaskDueDate = DateAdd(DateInterval.Day, CDbl(lPreliminaryReportTaskTimeAllowed), Date.Now)

                    ' create external handler preliminary report task
                    CreateTaskInstance(con, lTaskInstanceCnt, lTaskGroupId, lTaskId,
                        sClientName, dtTaskDueDate, lUserGroupId, _SiriusUser.UserID,
                        sDescription, PMEWrkManTaskStatus.pmeWMTSNew, 0, Date.Today,
                        _SiriusUser.UserID, Date.Today, _SiriusUser.UserID, 1, String.Empty)

                End If

            End If

        End If

    End Sub

