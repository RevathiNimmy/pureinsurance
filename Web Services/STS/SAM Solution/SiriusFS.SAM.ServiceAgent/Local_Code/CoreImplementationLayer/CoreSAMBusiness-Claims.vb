    End Function

    Private Sub ExecuteAdvancedTaxScript(
    ByVal con As SiriusConnection,
    ByVal AdvancedTaxScriptName As String,
    ByVal SourceCode As String,
    ByVal AdvancedTaxScriptDataArray As Object(),
                    ByRef UpdatedAdvancedTaxScriptDataArray As Object(),
                    ByVal nTaxGroupID As Nullable(Of Integer))

        ' create new instance of bCLMPeril.Business
        Dim oCLMPeril As New bCLMPeril.Business

        ' initialise 
        SAMFunc.InitialiseSBOObject(Con:=con, oObject:=oCLMPeril, SiriusUser:=_SiriusUser, sBranchCode:=SourceCode, sObjectName:="bCLMPeril.Business")

        Dim iRet As Integer

        Dim UpdatedAdvancedTaxScriptDataArrayForCOMUse As Object() = UpdatedAdvancedTaxScriptDataArray

        'called executeAdvancedScript function
        iRet = oCLMPeril.ExecuteAdvancedTaxScript(
                        v_lTaxScriptMode:=TaxScriptMode.Receipt,
                        v_sTaxScriptName:=AdvancedTaxScriptName,
                        v_vTaxParameters:=AdvancedTaxScriptDataArray,
                        r_vUpdatedTaxParameters:=UpdatedAdvancedTaxScriptDataArrayForCOMUse,
                        nTaxGroupID:=Convert.ToInt32(nTaxGroupID))

        ' if the function is unsuccessful 
        If iRet <> PMEReturnCode.PMTrue Then
            ' raise an error
            Dim oSAMErrorCollection As New SAMErrorCollection
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                 "bCLMPeril.Business.ExecuteAdvancedTaxScript Failed")
            oSAMErrorCollection.CheckForErrors()
        End If

        UpdatedAdvancedTaxScriptDataArray = TryCast(UpdatedAdvancedTaxScriptDataArrayForCOMUse, Object())

        ' destroy the instance of bCLMPeril.busness
        If oCLMPeril IsNot Nothing Then
            oCLMPeril.Dispose()
            oCLMPeril = Nothing
        End If

    End Sub

    Private Sub DefaultClaimVersionDescription(
    ByVal transactionType As String,
    ByRef ClaimVersionDescription As String)

        ' if the claim version description hasnt been set in the request
        If String.IsNullOrEmpty(ClaimVersionDescription) Then

            ' use the defaults
            Select Case transactionType
                Case TransactionTypeCode.OpenClaim
                    ClaimVersionDescription = "Opened Claim"
                Case TransactionTypeCode.MaintainClaim
                    ClaimVersionDescription = "Maintained Claim"
                Case TransactionTypeCode.PayClaim
                    ClaimVersionDescription = "Payment Of Claim"
                Case TransactionTypeCode.SalvageRecovery
                    ClaimVersionDescription = "Salvage Recovery"
                Case TransactionTypeCode.ThirdPartyRecovery
                    ClaimVersionDescription = "Third Party Recovery"
            End Select

        End If

    End Sub

    ''' <summary>
    ''' Saving claim Receipt
    ''' </summary>
    ''' <param name="oReceipt"></param>
    ''' <param name="oClaimReceiptResponse"></param>
    ''' <param name="con"></param>
    ''' <param name="oTax"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function ProcessClaimReceipt(
    ByVal con As SiriusConnection,
    ByVal oCoreBusiness As CoreBusiness,
    ByVal request As BaseClaimReceiptRequestType) As BaseClaimResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nInsuranceFolderKey As Integer
        Dim oBaseClaimResponse As BaseClaimResponseType
        Dim sRecoveryExcludeTax As String
        Dim bExcludeTax As Boolean
        Dim nClientKey As Integer
        ' determine the type of package and thus the type of response
        If request.GetType Is GetType(SAMForInsuranceImplementationTypes.ClaimReceiptRequestType) Then
            oBaseClaimResponse = New SAMForInsuranceImplementationTypes.ClaimReceiptResponseType
        ElseIf request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ClaimReceiptRequestType) Then
            oBaseClaimResponse = New SAMForInsuranceV2ImplementationTypes.ClaimReceiptResponseType
        Else
            oBaseClaimResponse = New BaseImplementationTypes.BaseClaimResponseType
        End If

        Dim GetClaimReceiptTaxesResponse As BaseGetClaimReceiptTaxesResponseType
        Dim ClaimReceipt As BaseClaimReceiptType = request.ClaimReceipt
        Dim AdditionalDetails As BaseAdditionalClaimRelatedDetails = ClaimReceipt.AdditionalDetails
        Dim sSalvageAndRecoveryReservesExcludeTax As String = String.Empty
        oCoreBusiness.GetSystemOption(request.BranchCode,
                                      SystemOption.SalvageAndTPRecoveryReservesExcludeTax,
                                      sSalvageAndRecoveryReservesExcludeTax)
        DefaultClaimVersionDescription(ClaimReceipt.TransactionTypeCode, ClaimReceipt.ClaimVersionDescription)

        If (request.IsDataTransferClaim) And
         Not (request.DataTransferIsUsingFullClaimVersioning) Then

            ClaimReceipt.ClaimId = ClaimReceipt.BaseClaimKey
            ClaimReceipt.ClaimPerilId = ClaimReceipt.BaseClaimPerilKey
            ClaimReceipt.VersionId = 1

        Else
   If request.ClaimReceipt.DoNotCreateClaimVersionOnSalvageReceipt = 0 Then

            ' copy the claim and return the new claim id and version id 
            ProcessCopyClaim(con, ClaimReceipt.BaseClaimKey, request.SourceId,
                ClaimReceipt.TransactionTypeCode, _SiriusUser.UserID,
                ClaimReceipt.ClaimId, ClaimReceipt.VersionId, request.IsDataTransferClaim, request.DataTransferClaimHasClaimRiskDataSpecified, request.DataTransferIsUsingFullClaimVersioning)

            ' get the new claim peril id
            ClaimReceipt.ClaimPerilId = oCoreBusiness.GetCurrentIdFromBaseIdAndVersionId _
                            (con, "Claim_Peril", CInt(ClaimReceipt.BaseClaimPerilKey),
                            ClaimReceipt.VersionId)

        End If
            End If
        ' get the taxes items and populates the recovery id's
        GetClaimReceiptTaxesResponse = GetClaimReceiptTaxDetails(con, oCoreBusiness, request)

        ' get the exchange rate details for the receipt 
        GetCurrencyExchangeRatesForAll(con, Date.Today.Date, request.ReceiptPartyAccountId,
             request.SourceId, ClaimReceipt.CurrencyId, ClaimReceipt.TotalReceiptAmountGross,
            ClaimReceipt.BaseCurrencyId, ClaimReceipt.BaseAmount, ClaimReceipt.AccountCurrencyId,
            ClaimReceipt.AccountAmount, ClaimReceipt.SystemCurrencyId, ClaimReceipt.SystemAmount,
            ClaimReceipt.CurrencyToBaseXRate, ClaimReceipt.CurrencyToBaseDate, ClaimReceipt.AccountToBaseXRate,
            ClaimReceipt.AccountToBaseDate, ClaimReceipt.SystemToBaseXRate, ClaimReceipt.SystemToBaseDate)

        ' get coinsurers
        GetCoinsurance(con, ClaimReceipt)

        ' get reinsurers
        GetReinsurance(con, ClaimReceipt)
        GetCurrencyToCurrencyExchangeRate(con, ClaimReceipt.TransactionDate, ClaimReceipt.CurrencyId, ClaimReceipt.AdditionalDetails.Claim.LossCurrencyKey, request.SourceId, ClaimReceipt.ReceiptToLossXRate)
        '****************************************
        ' save claim payment record to database  
        '****************************************
        oCoreBusiness.GetSystemOption(request.BranchCode, 5067, sRecoveryExcludeTax)
        If sRecoveryExcludeTax = "1" Then
            bExcludeTax = True
        Else
            bExcludeTax = False
        End If
        SaveClaimReceiptDetails(con, ClaimReceipt, bExcludeTax)
        '**********************************************
        ' save claim payment item records to database 
        '**********************************************
        SaveClaimReceiptItems(con, request, bExcludeTax)
        ProcessClaimsCoinsurance(con, oCoreBusiness, request.ClaimReceipt.ClaimId, request.ClaimReceipt.TransactionTypeCode, request.BranchCode)

        If Not request.DataTransferClaimHasSpecifiedReinsurance Then

            '**********************************************************
            ' Create Claim Reinsurance Arrangement / Arrangement Lines 
            '**********************************************************
            UpdateClaimReinsurance(con, ClaimReceipt.ClaimPerilId)
            Dim sRI2007 As String = ""

            ' calculate the claims reinsurance
            sRI2007 = oCoreBusiness.GetProductOption(ProductOption.RI2007, 1)

            '**********************************************************
            ' Create Claim Reinsurance Arrangement / Arrangement Lines 
            '**********************************************************
            If sRI2007 = "1" Then
                CalculateClaimsRI2007(con, request.ClaimReceipt.ClaimId, 0)
        End If
        End If

        ' End Of Specific Receipting Process 
        If Not request.IsDataTransferClaim Then
            FinaliseClaimDetails(con:=con, lClaimId:=ClaimReceipt.ClaimId, sClaimVersionDescription:=ClaimReceipt.ClaimVersionDescription)
        End If

        UpdateInsuranceFileSystem(con:=con, lUserId:=_SiriusUser.UserID, lInsuranceFileCnt:=AdditionalDetails.InsuranceFile.InsuranceFileKey, sTransactionTypeCode:=ClaimReceipt.TransactionTypeCode)

        GetTransactionTypeId(con, ClaimReceipt.TransactionTypeCode, ClaimReceipt.TransactionTypeId)

        nInsuranceFolderKey = GetAndValidateSpecifiedTableCode(con,
    PMLookupTable.Insurance_file, "insurance_folder_cnt", "insurance_file_cnt", AdditionalDetails.InsuranceFile.InsuranceFileKey.ToString(), oSAMErrorCollection, "InsuranceFolderKey")
        If Not request.IsDataTransferClaim Then
            RaiseTransactions(con:=con, lClaimId:=ClaimReceipt.ClaimId, lTransactionTypeId:=ClaimReceipt.TransactionTypeId, sTransactionTypeCode:=ClaimReceipt.TransactionTypeCode, lSuppressReserveTransactions:=0, CurrecnyID:=ClaimReceipt.CurrencyId)
        End If

        If AdditionalDetails.Client.PartyKey = 0 Then
            nClientKey = ClaimReceipt.PartyKey
        Else
            nClientKey = AdditionalDetails.Client.PartyKey
        End If

        CreateDefaultClaimEvent(con:=con,
                               lInsuranceHolderCnt:=nClientKey,
                            lInsuranceFolderCnt:=nInsuranceFolderKey,
                               lInsuranceFileCnt:=AdditionalDetails.InsuranceFile.InsuranceFileKey,
                               lClaimId:=ClaimReceipt.ClaimId,
                               sTransactionType:=ClaimReceipt.TransactionTypeCode,
                               lUserId:=_SiriusUser.UserID,
                               sEventDescription:=ClaimReceipt.ClaimVersionDescription)




        '*********************************
        'Generate Claim Receipt Response 
        '*********************************
        oBaseClaimResponse.BaseClaimKey = ClaimReceipt.BaseClaimKey
        oBaseClaimResponse.ClaimKey = ClaimReceipt.ClaimId
        oBaseClaimResponse.ClaimNumber = AdditionalDetails.Claim.ClaimNumber
        oBaseClaimResponse.Version = ClaimReceipt.VersionId

        Return oBaseClaimResponse

    End Function

    Private Sub ProcessGetClaimRiskLinks(ByVal oBusiness As CoreBusiness,
    ByVal oRequest As BaseGetClaimRiskLinksRequestType,
    ByVal oResponse As BaseGetClaimRiskLinksResponseType)

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            GetClaimRiskPerilLinks(con, oRequest.RiskKey, oResponse)

            GetClaimRiskPerilReserveLinks(con, oRequest.RiskKey, oResponse)

            GetRecoveryLinks(con, oRequest.RiskKey, oResponse)

        End Using

    End Sub

    Private Sub GetRecoveryLinks(ByVal con As SiriusConnection,
            ByVal iRiskCnt As Integer,
            ByVal oResponse As BaseGetClaimRiskLinksResponseType)

        Const kClaimRecoveryLinks As Integer = 3

        Dim dt As DataTable = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Claim_Risk_Links")
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = iRiskCnt
            cmd.AddInParameter("@links_option", SqlDbType.Int).Value = kClaimRecoveryLinks
            dt = con.ExecuteDataTable(cmd)
        End Using

        If oResponse.PerilType IsNot Nothing Then

            For iPerilIndex As Integer = 0 To oResponse.PerilType.Length - 1

                If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                    Dim iRecoveryIndex As Integer = 0

                    For Each dr As DataRow In dt.Rows

                        Dim sRecoveryTypeCode As String = Cast.ToStringTrim(dr.Item("recovery_type_code"))
                        Dim sRecoveryTypeDescription As String = Cast.ToStringTrim(dr.Item("description"))
                        Dim iIsSalvage As Integer = Cast.ToInt32(dr.Item("is_salvage"), 0)

                        Array.Resize(oResponse.PerilType(iPerilIndex).RecoveryType, iRecoveryIndex + 1)

                        Dim oRecovery As New BaseImplementationTypes.BaseGetClaimRiskLinksResponseTypePerilTypeRecoveryType
                        oRecovery.Code = sRecoveryTypeCode
                        oRecovery.Description = sRecoveryTypeDescription
                        oRecovery.IsSalvage = iIsSalvage

                        oResponse.PerilType(iPerilIndex).RecoveryType(iRecoveryIndex) = oRecovery

                        iRecoveryIndex += 1

                    Next

                End If

            Next

        End If

    End Sub

    Private Sub GetClaimRiskPerilReserveLinks(ByVal con As SiriusConnection,
            ByVal iRiskCnt As Integer,
            ByVal oResponse As BaseGetClaimRiskLinksResponseType)

        Const kRiskPerilReserveLinks As Integer = 2

        Dim dt As DataTable = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Claim_Risk_Links")
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = iRiskCnt
            cmd.AddInParameter("@links_option", SqlDbType.Int).Value = kRiskPerilReserveLinks
            dt = con.ExecuteDataTable(cmd)
        End Using

        If oResponse.PerilType IsNot Nothing Then

            For iPerilIndex As Integer = 0 To oResponse.PerilType.Length - 1

                If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                    Dim iReserveIndex As Integer = 0

                    For Each dr As DataRow In dt.Rows

                        Dim sPerilTypeCode As String = Cast.ToStringTrim(dr.Item("peril_type_code"))
                        Dim sReserveTypeCode As String = Cast.ToStringTrim(dr.Item("reserve_type_code"))
                        Dim sReserveTypeDescription As String = Cast.ToStringTrim(dr.Item("description"))

                        If oResponse.PerilType(iPerilIndex).Code = sPerilTypeCode Then

                            Array.Resize(oResponse.PerilType(iPerilIndex).ReserveType, iReserveIndex + 1)

                            Dim oReserve As New BaseImplementationTypes.BaseGetClaimRiskLinksResponseTypePerilTypeReserveType
                            oReserve.Code = sReserveTypeCode
                            oReserve.Description = sReserveTypeDescription
                            oResponse.PerilType(iPerilIndex).ReserveType(iReserveIndex) = oReserve

                            iReserveIndex += 1

                        End If

                    Next

                End If

            Next

        End If

    End Sub

    Private Sub GetClaimRiskPerilLinks(ByVal con As SiriusConnection,
    ByVal iRiskCnt As Integer,
    ByVal oResponse As BaseGetClaimRiskLinksResponseType)

        Const kRiskPerilLinks As Integer = 1

        Dim dt As DataTable = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Claim_Risk_Links")
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = iRiskCnt
            cmd.AddInParameter("@links_option", SqlDbType.Int).Value = kRiskPerilLinks
            dt = con.ExecuteDataTable(cmd)
        End Using

        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

            Dim sPerilTypeCode As String = String.Empty
            Dim sPerilTypeDescription As String = String.Empty
            Dim sPreviousPerilTypeCode As String = String.Empty
            Dim crSumInsured As Decimal
            Dim iPerilIndex As Integer = 0

            ' for each row
            For Each dr As DataRow In dt.Rows

                sPerilTypeCode = Cast.ToStringTrim(dr.Item("peril_type_code"))
                sPerilTypeDescription = Cast.ToStringTrim(dr.Item("peril_type_description"))
                crSumInsured = Cast.ToDecimal(dr.Item("sum_insured"), 0)

                If sPerilTypeCode <> sPreviousPerilTypeCode Then
                    sPreviousPerilTypeCode = sPerilTypeCode

                    Array.Resize(oResponse.PerilType, iPerilIndex + 1)

                    Dim oPerilType As New BaseImplementationTypes.BaseGetClaimRiskLinksResponseTypePerilType

                    oPerilType.Code = sPerilTypeCode
                    oPerilType.Description = sPerilTypeDescription
                    oPerilType.SumInsured = crSumInsured
                    oResponse.PerilType(iPerilIndex) = oPerilType

                End If

                iPerilIndex += 1

            Next

        End If

    End Sub

    Private Sub GetVersionId(ByVal baseClaimPerilId As Integer, ByRef versionId As Integer, ByVal con As SiriusConnection)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Current_version_id")
            cmd.AddInParameter("@baseClaimPeril_id", SqlDbType.Int).Value = baseClaimPerilId
            cmd.AddOutParameter("@version_id", SqlDbType.Int)
            con.ExecuteNonQuery(cmd)
            versionId = Cast.ToInt32(cmd.Parameters("@version_id").Value).GetValueOrDefault(0)
        End Using

    End Sub

    Private Sub SetupClaimReceiptAdvancedTaxScriptArrays(
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal ClaimReceiptItemAmount As Decimal,
    ByVal TaxCalculation As DataSet,
    ByRef AdvancedTaxScriptDataArray As Object())

        ' resize the advanced tax script data array
        ReDim AdvancedTaxScriptDataArray(kAdvancedTaxScriptDetailsArraySize)

        AdvancedTaxScriptDataArray(0) = "CLR"
        AdvancedTaxScriptDataArray(1) = ClaimReceipt.Payee.Name
        AdvancedTaxScriptDataArray(2) = String.Empty
        AdvancedTaxScriptDataArray(3) = ClaimReceipt.AdvancedTaxDetails.InsuredDomiciled
        AdvancedTaxScriptDataArray(4) = ClaimReceipt.AdvancedTaxDetails.InsuredPercentage
        AdvancedTaxScriptDataArray(5) = ClaimReceipt.AdvancedTaxDetails.InsuredTaxNumber
        AdvancedTaxScriptDataArray(6) = ClaimReceipt.AdvancedTaxDetails.IsTaxExempt
        AdvancedTaxScriptDataArray(7) = ClaimReceipt.AdvancedTaxDetails.IsSettlement
        AdvancedTaxScriptDataArray(8) = ClaimReceipt.CurrencyCode
        AdvancedTaxScriptDataArray(9) = ClaimReceiptItemAmount

        ' setup the array of tax band rates

        ' resize the array to hold the items
        Dim vTaxParameters(12, TaxCalculation.Tables(0).Rows.Count - 1) As Object

        If TaxCalculation IsNot Nothing AndAlso TaxCalculation.Tables.Count > 0 Then

            Dim TaxCalculationItems As DataTable = TaxCalculation.Tables("Row")

            Dim iRow As Integer = 0

            For Each dr As DataRow In TaxCalculationItems.Rows

                ' tax group id
                vTaxParameters(ClaimTaxArray.TaxGroupId, iRow) = dr.Item(0)

                ' tax band id 
                vTaxParameters(ClaimTaxArray.TaxBandId, iRow) = dr.Item(1)

                ' currency code
                vTaxParameters(ClaimTaxArray.CurrencyCode, iRow) = Cast.ToStringTrim(dr.Item(2))

                ' tax percentage
                vTaxParameters(ClaimTaxArray.Percentage, iRow) = dr.Item(3)

                ' tax value
                vTaxParameters(ClaimTaxArray.Value, iRow) = dr.Item(4)

                ' tax is value
                vTaxParameters(ClaimTaxArray.IsValue, iRow) = dr.Item(5)

                ' class of business id
                vTaxParameters(ClaimTaxArray.ClassOfBusinessId, iRow) = dr.Item(6)

                ' sequence
                vTaxParameters(ClaimTaxArray.Sequence, iRow) = dr.Item(7)

                ' is manually changed
                vTaxParameters(ClaimTaxArray.IsManuallyChanged, iRow) = dr.Item(8)

                ' tax group description
                vTaxParameters(ClaimTaxArray.TaxGroupDescription, iRow) = Cast.ToStringTrim(dr.Item(9))

                ' tax band description
                vTaxParameters(ClaimTaxArray.TaxBandDescription, iRow) = Cast.ToStringTrim(dr.Item(10))

                ' tax band code
                vTaxParameters(ClaimTaxArray.TaxBandCode, iRow) = Cast.ToStringTrim(dr.Item(11))

                ' increment counter
                iRow += 1

            Next

            ' insert tax details at 10th position in the DataArray
            AdvancedTaxScriptDataArray(10) = vTaxParameters
            AdvancedTaxScriptDataArray(11) = ClaimReceipt.AdvancedTaxDetails.ReceivableTaxPercentage
            AdvancedTaxScriptDataArray(12) = ""
        End If

    End Sub

