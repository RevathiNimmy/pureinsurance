            End If
            ds.Tables.Add(dt)

            For iCount As Integer = 0 To ds.Tables(0).Rows.Count - 1
                Dim oXMLDoc As New System.Xml.XmlDocument
                oXMLDoc.LoadXml(ds.GetXml)
                oGetProductDocumentsResponse.ResultDataset = oXMLDoc.DocumentElement
            Next iCount

        Catch ex As Exception
            Throw
        Finally
            oCoreBusiness = Nothing
        End Try

        Return oGetProductDocumentsResponse

