    Private Overloads Sub ProcessBalanceAndCloseClaim(ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal oRequest As BaseClaimMaintainRequestType)

        ' Risk Details ( Balance Reserves ) 
        BalanceClaimReserves(con, oRequest.Claim)

        ' Coinsurance Recoveries
        ' Not Currently Supported by the Balance And Close Claim process

        ' Reinsurance Recoveries
        Const kBalanceAndCloseClaim As Integer = 1
        ProcessClaimsReinsurance(con, oRequest.Claim.ClaimId, kBalanceAndCloseClaim)

        ' Balance Thid Party Recovery
        Const kThirdPartyRecovery As Integer = 0
        BalanceRecovery(con, oRequest.Claim, kThirdPartyRecovery)

        ' Balance Salvage Recovery
        Const kSalvageRecovery As Integer = 1
