    ''' <summary>
    ''' To get default bank account for currency
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function GetDefaultBankAccountWithCurrency(ByVal con As SiriusConnection, ByVal oRequest As BaseGetDefaultBankAccountWithCurrencyRequestType) As BaseGetDefaultBankAccountWithCurrencyResponseType

        Dim oGetDefaultBankAccountWithCurrencyResponse As New BaseGetDefaultBankAccountWithCurrencyResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim dsGetDefaultBankAccountWithCurrency As DataSet = Nothing
        Dim oCoreBusiness As New CoreBusiness
        Dim nSourceID As Integer
        Dim nProductID As Integer

        Try
            oGetDefaultBankAccountWithCurrencyResponse = New SAMForInsuranceV2ImplementationTypes.GetDefaultBankAccountWithCurrencyResponseType
            'Check Mandatory Fields
            If String.IsNullOrEmpty(oRequest.BranchCode) Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode", oRequest.BranchCode)
            End If

            Try
                nSourceID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, "Source", oRequest.BranchCode, "BranchCode")
            Catch ex As Exception
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "BranchCode", oRequest.BranchCode)
            End Try

            oSAMErrorCollection.CheckForErrors()

            nProductID = GetAndValidateSpecifiedTableCode(con, "Product", "Product_Id", "Code", Trim(oRequest.ProductCode), oSAMErrorCollection, "Product_Id")

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetDefaultBankAccountWithCurrency")
                If nProductID <> 0 Then
                    cmd.AddInParameter("@nProductId", SqlDbType.Int).Value = nProductID
                Else
                    cmd.AddInParameter("@nProductId", SqlDbType.Int).Value = 0
                End If
                If oRequest.MediaTypeID <> 0 Then
                    cmd.AddInParameter("@nMediaTypeID", SqlDbType.Int).Value = Cast.ToInt32(oRequest.MediaTypeID)
                Else
                    cmd.AddInParameter("@nMediaTypeID", SqlDbType.Int).Value = 0
                End If
                If oRequest.CashListTypeID <> 0 Then
                    cmd.AddInParameter("@nCashListTypeID", SqlDbType.Int).Value = Cast.ToInt32(oRequest.CashListTypeID)
                Else
                    cmd.AddInParameter("@nCashListTypeID", SqlDbType.Int).Value = 0
                End If
                If nSourceID <> 0 Then
                    cmd.AddInParameter("@nSourceID", SqlDbType.Int).Value = nSourceID
                Else
                    cmd.AddInParameter("@nSourceID", SqlDbType.Int).Value = 0
                End If

                dsGetDefaultBankAccountWithCurrency = con.ExecuteDataSet(cmd, "row")

            End Using

            If Not (dsGetDefaultBankAccountWithCurrency IsNot Nothing AndAlso dsGetDefaultBankAccountWithCurrency.Tables.Count > 0 AndAlso dsGetDefaultBankAccountWithCurrency.Tables(0).Rows.Count > 0) Then
                Return oGetDefaultBankAccountWithCurrencyResponse
            End If

            Dim Docxml As New System.Xml.XmlDocument
            dsGetDefaultBankAccountWithCurrency.DataSetName = "BaseGetDefaultBankAccountWithCurrencyResponseTypeResults"
            dsGetDefaultBankAccountWithCurrency.Tables(0).TableName = "Row"
            Docxml.LoadXml(dsGetDefaultBankAccountWithCurrency.GetXml)

            oGetDefaultBankAccountWithCurrencyResponse.ResultDataset = Docxml.DocumentElement()

        Catch ex As Exception
            Dim STSErrorEx As New STSErrorPublisher("Failed to convert XML (ResultArray).", ex)
            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), "GetDefaultBankAccountWithCurrency", "GetDefaultBankAccountWithCurrency", True)
        Finally
        End Try

        Return oGetDefaultBankAccountWithCurrencyResponse
    End Function

