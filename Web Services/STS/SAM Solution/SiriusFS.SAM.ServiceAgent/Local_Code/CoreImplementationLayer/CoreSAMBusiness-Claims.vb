    ''' <summary>  
    '''  This method is used to update cover note Book
    '''<param name="oGetUnallocatedClaimPaymentsRequest" type="BaseGetUnallocatedClaimPaymentsRequestType"></param>   
    '''<returns>BaseGetUnallocatedClaimPaymentsResponseType</returns>
    '''<remarks></remarks>
    Public Overloads Function GetUnallocatedClaimPayments(ByVal con As SiriusConnection, ByVal oGetUnallocatedClaimPaymentsRequest As BaseGetUnallocatedClaimPaymentsRequestType, Optional ByRef dsUnallocatedClaimPaymentsResponse As DataSet = Nothing) As BaseGetUnallocatedClaimPaymentsResponseType

        Dim oGetUnallocatedClaimPaymentsResponse As New BaseGetUnallocatedClaimPaymentsResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection

        Dim ibranchId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim iAccountId As Integer

        If oGetUnallocatedClaimPaymentsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetUnallocatedClaimPaymentsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oGetUnallocatedClaimPaymentsResponse = New SAMForInsuranceV2ImplementationTypes.GetUnallocatedClaimPaymentsResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        ' Check mandatory fields, i.e. – Repeat for rest of mandatory fields
        If String.IsNullOrEmpty(oGetUnallocatedClaimPaymentsRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If

        If oGetUnallocatedClaimPaymentsRequest.AccountKey = 0 And oGetUnallocatedClaimPaymentsRequest.PaymentDate <= Date.MinValue And String.IsNullOrEmpty(oGetUnallocatedClaimPaymentsRequest.ShortCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                           SAMInvalidData.MandatoryInputMissing.ToString,
                                            "AccountKey , PaymentDate & ShortCode")
        End If

        oErrors.CheckForErrors()

        ' Lookup Codes to ensure they are valid, i.e.
        Try
            ibranchId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oGetUnallocatedClaimPaymentsRequest.BranchCode, "BranchCode")
        Catch ex As Exception
            oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                        SAMInvalidData.InvalidLookupListValue.ToString,
                                        "BranchCode",
                                        oGetUnallocatedClaimPaymentsRequest.BranchCode)
        End Try

        If String.IsNullOrEmpty(oGetUnallocatedClaimPaymentsRequest.ShortCode) = False And oGetUnallocatedClaimPaymentsRequest.AccountKey = 0 Then
            Using cmdUnallocatedClaimPayments As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Get_AccountID_From_ShortCode")
                cmdUnallocatedClaimPayments.AddInParameter("@company_id", SqlDbType.Int).Value = Cast.NullIfDefault(ibranchId)
                cmdUnallocatedClaimPayments.AddInParameter("@ShortCode", SqlDbType.VarChar).Value = Cast.NullIfDefault(oGetUnallocatedClaimPaymentsRequest.ShortCode)
                cmdUnallocatedClaimPayments.AddOutParameter("@AccountID", SqlDbType.Int)
                cmdUnallocatedClaimPayments.AddOutParameter("@delete_at_purge", SqlDbType.Int)
                con.ExecuteNonQuery(cmdUnallocatedClaimPayments)
                iAccountId = Cast.ToInt32(cmdUnallocatedClaimPayments.Parameters("@AccountID").Value, 0)
            End Using
        Else
            Using cmdUnallocatedClaimPayments As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Get_AccountID_From_partyCnt")
                cmdUnallocatedClaimPayments.AddInParameter("@companyid", SqlDbType.Int).Value = Cast.NullIfDefault(ibranchId)
                cmdUnallocatedClaimPayments.AddInParameter("@PartyCnt", SqlDbType.Int).Value = Cast.NullIfDefault(oGetUnallocatedClaimPaymentsRequest.AccountKey)
                cmdUnallocatedClaimPayments.AddOutParameter("@AccountID", SqlDbType.Int)
                cmdUnallocatedClaimPayments.AddOutParameter("@SubBranchID", SqlDbType.Int)
                con.ExecuteNonQuery(cmdUnallocatedClaimPayments)
                iAccountId = Cast.ToInt32(cmdUnallocatedClaimPayments.Parameters("@AccountID").Value, 0)
            End Using
        End If

        ' exit if there are any missing parameters
        oErrors.CheckForErrors()

        'Validate – Either of the two request parameters must be set.
        If oGetUnallocatedClaimPaymentsRequest.AccountKey > 0 Or oGetUnallocatedClaimPaymentsRequest.PaymentDate > Date.MinValue Or String.IsNullOrEmpty(oGetUnallocatedClaimPaymentsRequest.ShortCode) = False Then
            Dim dsUnallocatedClaimPayments As DataSet = Nothing

            If oGetUnallocatedClaimPaymentsRequest.AccountKey <> 0 Or String.IsNullOrEmpty(oGetUnallocatedClaimPaymentsRequest.ShortCode) = False Then
                Using cmdUnallocatedClaimPayments As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Get_Unallocated_Claim_Payments")
                    If oGetUnallocatedClaimPaymentsRequest.AccountKeySpecified Or oGetUnallocatedClaimPaymentsRequest.ShortCodeSpecified Then
                        cmdUnallocatedClaimPayments.AddInParameter("@account_id", SqlDbType.Int).Value = Cast.NullIfDefault(iAccountId)
                    End If

                    dsUnallocatedClaimPayments = con.ExecuteDataSet(cmdUnallocatedClaimPayments, "Row")
                End Using
            Else
                Using cmdUnallocatedClaimPayments As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Get_Unallocated_Claim_Payments_By_PaymentDate")
                    If oGetUnallocatedClaimPaymentsRequest.PaymentDateSpecified Then
                        cmdUnallocatedClaimPayments.AddInParameter("@date_of_payment", SqlDbType.DateTime).Value = oGetUnallocatedClaimPaymentsRequest.PaymentDate
                        cmdUnallocatedClaimPayments.AddInParameter("@date_of_payment_To", SqlDbType.DateTime).Value = oGetUnallocatedClaimPaymentsRequest.PaymentDateTo
                    End If

                    dsUnallocatedClaimPayments = con.ExecuteDataSet(cmdUnallocatedClaimPayments, "Row")

                End Using
            End If

            dsUnallocatedClaimPayments.DataSetName = "BaseGetUnallocatedClaimPaymentsResponseTypeUnallocatedClaimPayments"
            If dsUnallocatedClaimPayments.Tables.Count > 0 Then
                If dsUnallocatedClaimPayments.Tables(0).Rows.Count > 0 Then
                    With dsUnallocatedClaimPayments.Tables(0)
                        .Columns("document_id").ColumnName = "DocumentKey"
                        .Columns("document_ref").ColumnName = "DocumentRef"
                        .Columns("currency_amount").ColumnName = "CurrencyAmount"
                        .Columns("currency_id").ColumnName = "CurrencyKey"
                        .Columns("amount").ColumnName = "Amount"
                        .Columns("amount_currency_id").ColumnName = "AmountCurrencyKey"
                        .Columns("account_amount").ColumnName = "AccountAmount"
                        .Columns("account_currency_id").ColumnName = "AccountCurrencyKey"
                        .Columns("claim_number").ColumnName = "ClaimNumber"
                        .Columns("comment").ColumnName = "DocumentComment"
                        .Columns("currency_description").ColumnName = "CurrencyDescription"
                        .Columns("currency_format_string").ColumnName = "CurrencyFormatString"
                        .Columns("date_of_payment").ColumnName = "DateOfPayment"
                        .Columns("payee_media_type").ColumnName = "PayeeMediaTypeKey"
                        .Columns("base_currency_description").ColumnName = "BaseCurrencyDescription"
                        .Columns("base_format_string").ColumnName = "BaseCurrencyFormatstring"
                        .Columns("claim_payment_id").ColumnName = "MaxClaimPaymentKey"
                        .Columns("document_date").ColumnName = "DocumentDate"
                        .Columns("account_id").ColumnName = "AccountKey"
                        .Columns("base_claim_payment_id").ColumnName = "BaseClaimPaymentKey"
                        .Columns("account_name").ColumnName = "AccountName"
                        .Columns("Status").ColumnName = "Status"
                        .Columns("MediaTypeCode").ColumnName = "MediaTypeCode"
                        .Columns("CurrencyCode").ColumnName = "CurrencyCode"
                        .Columns("BankAccountCode").ColumnName = "BankAccountCode"
                        .Columns("CashListItem_id").ColumnName = "CashListItemKey"
                        .Columns("AccountCode").ColumnName = "AccountCode"
                        .Columns("BranchCode").ColumnName = "ClaimPaymentBranchCode"
                        .Columns("PayeeName").ColumnName = "PayeeName"
                        .Columns("our_ref").ColumnName = "OurRef"
                        .Columns("MaxClaimPaymentKey").ColumnName = "ClaimPaymentKey"
                        .Columns("MediaTypeDesc").ColumnName = "MediaTypeDesc"
                        .Columns("ThirdPartyReference").ColumnName = "TheirRef"
                        .Columns("PayeeSortCode").ColumnName = "PayeeSortCode"
                        .Columns("PayeeAccountNo").ColumnName = "PayeeAccountNo"
                        .Columns("PartyBankId").ColumnName = "PartyBankId"
                    End With
                End If
            End If

            dsUnallocatedClaimPaymentsResponse = dsUnallocatedClaimPayments

            'Populate the XML Document here with the result dataset information. Set the values on the response.
            If oGetUnallocatedClaimPaymentsRequest.WCFSecurityToken = "" Then
            Dim xmlDoc As New System.Xml.XmlDocument
            xmlDoc.LoadXml(dsUnallocatedClaimPayments.GetXml)
            oGetUnallocatedClaimPaymentsResponse.ResultDataset = xmlDoc.DocumentElement()
        End If
            oGetUnallocatedClaimPaymentsResponse.ResultData = dsUnallocatedClaimPayments
        End If
        Return oGetUnallocatedClaimPaymentsResponse

    End Function

