    Private Sub GetTransactionType(ByVal con As SiriusConnection,
                                    ByVal sTransactionTypeCode As String,
                                    ByRef lTransactionTypeId As Integer,
                                    ByRef sDescription As String)

        Dim ds As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Transaction_Type_Details")

            cmd.AddInParameter("@code", SqlDbType.VarChar, 10).Value = sTransactionTypeCode

            ds = con.ExecuteDataSet(cmd, "TransactionType")

            Dim dr As DataRow

            If ds.Tables("TransactionType").Rows.Count > 0 Then

                dr = ds.Tables("TransactionType").Rows(0)

                lTransactionTypeId = Cast.ToInt32(dr.Item("transaction_type_id"), 0)
                sDescription = dr.Item("description").ToString

            Else
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(
                    SAMBusinessErrors.TransactionTypeNotFound,
                        SAMBusinessErrors.TransactionTypeNotFound.ToString,
                            "Transaction Type Details Not Returned for TransactionTypeCode :" & sTransactionTypeCode)
                oSAMErrorCollection.CheckForErrors()
