    Private Sub GetUserDefinedTableDetails(ByVal con As SiriusConnection,
                                 ByVal oBusiness As CoreBusiness,
                                 ByVal OpenClaimRequest As BaseClaimOpenRequestType)
        Dim strUserDefTableA, strUserDefTableB, strUserDefTableC, strUserDefTableD, strUserDefTableE As String
        Dim oErrors As New SAMErrorCollection

        Dim oGetProductRiskOptionValueRequest As New BaseProductRiskOptionValueRequestType

        If OpenClaimRequest.Claim.UserDefFldACode <> "" And OpenClaimRequest.Claim.UserDefFldACode <> "(None)" Then
            oGetProductRiskOptionValueRequest.ProducRiskOption = ProductRiskOptions.ClaimsUDTA
            strUserDefTableA = GetProductRiskOptions(con, OpenClaimRequest.Claim.ProductId, oGetProductRiskOptionValueRequest)
            OpenClaimRequest.Claim.UserDefFldAId = oBusiness.GetListItemFromCode(Core.STSListType.UserDefinedTable, strUserDefTableA, OpenClaimRequest.Claim.UserDefFldACode)
        End If

        If OpenClaimRequest.Claim.UserDefFldBCode <> "" And OpenClaimRequest.Claim.UserDefFldBCode <> "(None)" Then
            oGetProductRiskOptionValueRequest.ProducRiskOption = ProductRiskOptions.ClaimsUDTB
            strUserDefTableB = GetProductRiskOptions(con, OpenClaimRequest.Claim.ProductId, oGetProductRiskOptionValueRequest)
            OpenClaimRequest.Claim.UserDefFldBId = oBusiness.GetListItemFromCode(Core.STSListType.UserDefinedTable, strUserDefTableB, OpenClaimRequest.Claim.UserDefFldBCode)
        End If

        If OpenClaimRequest.Claim.UserDefFldCCode <> "" And OpenClaimRequest.Claim.UserDefFldCCode <> "(None)" Then
            oGetProductRiskOptionValueRequest.ProducRiskOption = ProductRiskOptions.ClaimsUDTC
            strUserDefTableC = GetProductRiskOptions(con, OpenClaimRequest.Claim.ProductId, oGetProductRiskOptionValueRequest)
            OpenClaimRequest.Claim.UserDefFldCId = oBusiness.GetListItemFromCode(Core.STSListType.UserDefinedTable, strUserDefTableC, OpenClaimRequest.Claim.UserDefFldCCode)
        End If

        If OpenClaimRequest.Claim.UserDefFldDCode <> "" And OpenClaimRequest.Claim.UserDefFldDCode <> "(None)" Then
            oGetProductRiskOptionValueRequest.ProducRiskOption = ProductRiskOptions.ClaimsUDTD
            strUserDefTableD = GetProductRiskOptions(con, OpenClaimRequest.Claim.ProductId, oGetProductRiskOptionValueRequest)
            OpenClaimRequest.Claim.UserDefFldDId = oBusiness.GetListItemFromCode(Core.STSListType.UserDefinedTable, strUserDefTableD, OpenClaimRequest.Claim.UserDefFldDCode)
        End If

        If OpenClaimRequest.Claim.UserDefFldECode <> "" And OpenClaimRequest.Claim.UserDefFldECode <> "(None)" Then
            oGetProductRiskOptionValueRequest.ProducRiskOption = ProductRiskOptions.ClaimsUDTE
            strUserDefTableE = GetProductRiskOptions(con, OpenClaimRequest.Claim.ProductId, oGetProductRiskOptionValueRequest)
            OpenClaimRequest.Claim.UserDefFldEId = oBusiness.GetListItemFromCode(Core.STSListType.UserDefinedTable, strUserDefTableE, OpenClaimRequest.Claim.UserDefFldECode)
        End If

    End Sub

