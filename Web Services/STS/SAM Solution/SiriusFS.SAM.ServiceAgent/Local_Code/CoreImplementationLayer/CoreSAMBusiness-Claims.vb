    ''' <summary>
    ''' 
    ''' 
    ''' populate the response object with claim and timestamp details
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="oRequest"></param>
    ''' <param name="oResponse"></param>
    ''' <remarks></remarks>
    Private Sub PopulateResponseObject(ByVal oBusiness As CoreBusiness,
                                        ByVal oRequest As BaseClaimOpenRequestType,
                                        ByVal oResponse As BaseClaimResponseType)

        ' populate the response object
        oResponse.ClaimKey = oRequest.Claim.ClaimId
        oResponse.BaseClaimKey = oRequest.Claim.ClaimId
        oResponse.ClaimNumber = oRequest.Claim.ClaimNumber
        oResponse.Version = 1

        Dim bIsLocked As Boolean = False

        ' get the timestamp to be returned
        oBusiness.GetSAMTimestamp(
                           oRequest.BranchCode,
                           CoreBusiness.LockName.ClaimId,
                           oResponse.BaseClaimKey,
                           oResponse.TimeStamp,
                           bIsLocked)

    End Sub

    Private Overloads Sub CreateClaimsDMEFolder(ByVal con As SiriusConnection,
                                      ByVal oBusiness As CoreBusiness,
                                      ByVal oRequest As BaseClaimOpenRequestType)

        Dim sOptionValue As String = String.Empty

        ' determine is dme is installed by retrieving the relevant system option
        oBusiness.GetSystemOption(oRequest.BranchCode,
                                    SystemOption.DMEInstalled,
                                    sOptionValue)

        '  if the option is set 
        If Not String.IsNullOrEmpty(sOptionValue) Then

            ' and it indicates that DME is installed
            If CType(sOptionValue, Integer) = 1 Then

                ' instantiate the business object
                Dim lReturn As Integer
                Dim oDocAPI As New bSIRDOCAPI.Form

                Try

                    ' cast the database to object for passing via interop
                    Dim oDatabaseObject As Object = con.PMDAODatabase

                    ' initialise the object
                    lReturn = CInt(oDocAPI.Initialise(
                                           _SiriusUser.Username,
                                           _SiriusUser.Password,
                                           _SiriusUser.UserID,
                                           _SiriusUser.SourceID,
                                           _SiriusUser.LanguageID,
                                           _SiriusUser.CurrencyID,
                                           1,
                                           SiriusUserDefaults.AppName,
                                           False, oDatabaseObject))

                    Dim sClaimRef As String = oRequest.Claim.ClaimNumber.Trim & Space(3) & oRequest.Claim.ClaimVersionDescription.Trim

                    ' create the dme folder for the claim
                    lReturn = oDocAPI.ProcessIndex(
                                    lMode:=1,
                                    iSourceID:=CShort(oRequest.Claim.SourceId),
                                    lPartyId:=oRequest.Claim.InsuranceHolderCnt,
                                    sPartyName:=oRequest.Claim.ClientShortName.Trim,
                                    lInsuranceFolderId:=oRequest.Claim.InsuranceFolderCnt,
                                    sInsuranceFileRef:=oRequest.Claim.InsuranceRef.Trim,
                                    lClaimId:=oRequest.Claim.ClaimId,
                                    sClaimRef:=sClaimRef.Trim)

                    ' raise a business error if the dme folder is not created correctly
                    If lReturn <> PMEReturnCode.PMTrue Then
                        Dim oSAMErrorCollection As New SAMErrorCollection
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.DMEFolderCreationFailed,
                                                             SAMBusinessErrors.DMEFolderCreationFailed.ToString)
                        oSAMErrorCollection.CheckForErrors()
                    End If

                Finally
                    If oDocAPI IsNot Nothing Then
                        oDocAPI.Dispose()
                        oDocAPI = Nothing
                    End If
                End Try

            End If

        End If

    End Sub
    Private Overloads Sub CreateClaimsDMEFolder(ByVal con As SiriusConnection,
                                      ByVal oBusiness As CoreBusiness,
                                      ByVal BranchCode As String,
                                      ByVal oClaim As BaseClaimType)

        Dim sOptionValue As String = String.Empty

        ' determine is dme is installed by retrieving the relevant system option
        oBusiness.GetSystemOption(BranchCode,
                                    SystemOption.DMEInstalled,
                                    sOptionValue)

        '  if the option is set 
        If Not String.IsNullOrEmpty(sOptionValue) Then

            ' and it indicates that DME is installed
            If CType(sOptionValue, Integer) = 1 Then

                ' instantiate the business object
                Dim lReturn As Integer
                Dim oDocAPI As New bSIRDOCAPI.Form

                Try

                    ' cast the database to object for passing via interop
                    Dim oDatabaseObject As Object = con.PMDAODatabase

                    ' initialise the object
                    lReturn = CInt(oDocAPI.Initialise(
                                           _SiriusUser.Username,
                                           _SiriusUser.Password,
                                           _SiriusUser.UserID,
                                           _SiriusUser.SourceID,
                                           _SiriusUser.LanguageID,
                                           _SiriusUser.CurrencyID,
                                           1,
                                           SiriusUserDefaults.AppName,
                                           False, oDatabaseObject))

                    Dim sClaimRef As String = oClaim.ClaimNumber.Trim & Space(3) & oClaim.ClaimVersionDescription.Trim

                    ' create the dme folder for the claim
                    lReturn = oDocAPI.ProcessIndex(
                                    lMode:=1,
                                    iSourceID:=CShort(oClaim.SourceId),
                                    lPartyId:=oClaim.InsuranceHolderCnt,
                                    sPartyName:=oClaim.ClientShortName.Trim,
                                    lInsuranceFolderId:=oClaim.InsuranceFolderCnt,
                                    sInsuranceFileRef:=oClaim.InsuranceRef.Trim,
                                    lClaimId:=oClaim.ClaimId,
                                    sClaimRef:=sClaimRef.Trim)

                    ' raise a business error if the dme folder is not created correctly
                    If lReturn <> PMEReturnCode.PMTrue Then
                        Dim oSAMErrorCollection As New SAMErrorCollection
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.DMEFolderCreationFailed,
                                                             SAMBusinessErrors.DMEFolderCreationFailed.ToString)
                        oSAMErrorCollection.CheckForErrors()
                    End If

                Finally
                    If oDocAPI IsNot Nothing Then
                        oDocAPI.Dispose()
                        oDocAPI = Nothing
                    End If
                End Try

            End If

        End If

    End Sub

    Private Sub UpdateClaimPerilDetails(
    ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal sTransactionTypeCode As String,
    ByVal oClaim As BaseClaimType,
    ByVal oClaimPerils As BaseClaimPerilType(),
    ByVal IsDataTransfer As Boolean,
    Optional ByVal IsUpdateReserve As Boolean = False,
    Optional ByVal IsUpdateRecovery As Integer = 0)

        Dim bStatsFolderCreated As Boolean

        ' if there are claim peril details in the request
        If oClaimPerils IsNot Nothing Then

            Dim oClaimPeril As BaseClaimPerilType

            ' for each peril in structure 
            For Each oClaimPeril In oClaimPerils

                ' update the claim perils details
                UpdateClaimPeril(con, oClaimPeril.ClaimPerilId, oClaimPeril.Description, "",
                                      oClaimPeril.ClassOfBusinessCode, oClaimPeril.ClassOfBusinessId)

                ' if there are reserves in the request
                If IsArray(oClaimPeril.Reserve) Then

                    Dim oReserve As BaseClaimPerilReserveType

                    ' for each reserve specified in the request
                    For Each oReserve In oClaimPeril.Reserve

                        ' update the reserve and store the reserve id
                        oReserve.ReserveId = UpdateClaimPerilReserve(con, oClaimPeril.ClaimPerilId,
                                          0, oReserve.TypeCode, oReserve.RevisionAmount,
                                              sTransactionTypeCode, IsUpdateReserve)

                        ' get the total transaction amount for this claim peril ( total of all reserve amounts )
                        oClaimPeril.TransactionAmount = oClaimPeril.TransactionAmount + oReserve.RevisionAmount

                    Next

                End If

                ' if there are recoveries in the request
                If IsArray(oClaimPeril.Recovery) Then

                    Dim oRecovery As BaseClaimPerilRecoveryType

                    ' for each recovery specified in the recovery
                    For Each oRecovery In oClaimPeril.Recovery

                        oRecovery.RecoveryTypeId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                                                        PMLookupTable.RecoveryType, oRecovery.TypeCode, "RecoveryTypeCode")

                        If (oRecovery.RecoveryPartyKeySpecified = True) Then
                            Dim oSAMErrorCollection As New SAMErrorCollection
                            oRecovery.RecoveryPartyKey = GetAndValidateSpecifiedTableCode(con, "Party", "party_cnt", "party_cnt",
                                                            oRecovery.RecoveryPartyKey.ToString, oSAMErrorCollection, "RecoveryPartyKey")
                            oSAMErrorCollection.CheckForErrors()
                        End If
                        If (oRecovery.RecoveryPartyTypeKeySpecified = True) Then
                            oRecovery.RecoveryPartyTypeKey = oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup,
                                                            "Recovery_Party_Type", oRecovery.RecoveryPartyTypeKey, "RecoveryPartyTypeKey")
                        End If
                        oRecovery.RecoveryId = ProcessClaimPerilRecovery(con, oClaimPeril.ClaimPerilId,
                                                    oRecovery.RecoveryTypeId,
                                                    oClaim.CurrencyId,
                                                    oRecovery.RevisionAmount,
                                                    oClaim.ClaimVersion,
                                                    oRecovery.RecoveryPartyKey, oRecovery.RecoveryPartyTypeKey,
                                                    oRecovery.IsDeletedRecovery,
                                                    oRecovery.BaseRecoveryKey,
                                                    IsUpdateRecovery,
                                                    oRecovery.IsNew, oRecovery.Initialamount)
                    Next

                End If

                ' do not create any stats if this is the data transfer process
                If Not IsDataTransfer Then

                    ' if the transaction amount for this claim peril is not zero
                    ' and the stats folder has not already been created for the claim 
                    If oClaimPeril.TransactionAmount <> 0 AndAlso Not bStatsFolderCreated Then

                        Dim lTransactionTypeId As Integer = oBusiness.GetAndValidateListItemFromCode(
                                                                Core.STSListType.PMLookup,
                                                                    PMLookupTable.TransactionType,
                                                                        sTransactionTypeCode, "TransactionType")

                        If sTransactionTypeCode = "C_CO" Then
                            ' create the stats folder and get the stats folder detail
                            oClaim.StatsFolderId = AddClaimsStatsFolder(con,
                                                    oClaim.InsuranceFileKey,
                                                     "D", "Reserve for claim number " & oClaim.ClaimId,
                                                        lTransactionTypeId, TransactionTypeCode.OpenClaim,
                                                          _SiriusUser.UserID, _SiriusUser.Username, oClaim.ClaimId,
                                                            InternalSAMConstants.kDocumentTypeTransferredDebit)

                        Else
                            oClaim.StatsFolderId = AddClaimsStatsFolder(con,
                                                    oClaim.InsuranceFileKey,
                                                     "D", "Reserve for claim number " & oClaim.ClaimId,
                                                        lTransactionTypeId, TransactionTypeCode.MaintainClaim,
                                                          _SiriusUser.UserID, _SiriusUser.Username, oClaim.ClaimId,
                                                            InternalSAMConstants.kDocumentTypeTransferredDebit)

                        End If
                        bStatsFolderCreated = True

                    End If

                    ' if there is a transaction amount
                    If oClaimPeril.TransactionAmount <> 0 Then

                        Dim sCreditAccountCode As String = "CLMRES" & oClaimPeril.ClassOfBusinessCode
                        Dim lRIPartyCnt As Integer = 0
                        Dim lRIPartyType As Integer = 0
                        Dim dRISharePercent As Double = 0

                        ' Add Stats Details 
                        AddClaimsStatsDetail(con, oClaim.StatsFolderId,
                                                oClaim.ClaimId,
                                                oClaimPeril.ClaimPerilId, InternalSAMConstants.kStatsDetailTypeGross,
                                                oClaimPeril.ClassOfBusinessId,
                                                oClaimPeril.ClassOfBusinessCode,
                                                lRIPartyCnt,
                                                sCreditAccountCode,
                                                lRIPartyType,
                                                dRISharePercent,
                                                oClaimPeril.TransactionAmount,
                                                InternalSAMConstants.kDocumentTypeTransferredDebit)
                    End If
                End If
            Next

        End If

    End Sub

    Private Sub UpdateClaimPeril(ByVal con As SiriusConnection,
                                ByVal lClaimPerilId As Integer,
                                ByVal sDescription As String,
                                ByVal sComments As String,
                                ByRef sClassOfBusiness As String,
                                ByRef lClassOfBusinessId As Integer)

        Try

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Update_Claim_Peril")

                cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = lClaimPerilId
                cmd.AddInParameter("@description", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(sDescription)
                cmd.AddInParameter("@comments", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(sComments)
                cmd.AddOutParameter("@class_of_business_id", SqlDbType.Int)
                cmd.AddOutParameter("@class_of_business_code", SqlDbType.VarChar, 10)

                con.ExecuteNonQuery(cmd)

                lClassOfBusinessId = Cast.ToInt32(cmd.Parameters("@class_of_business_id").Value).GetValueOrDefault(0)
                sClassOfBusiness = cmd.Parameters("@class_of_business_code").Value.ToString

            End Using

