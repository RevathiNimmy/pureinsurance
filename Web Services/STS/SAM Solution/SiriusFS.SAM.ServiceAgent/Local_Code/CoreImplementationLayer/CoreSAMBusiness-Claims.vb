    Private Sub ValidateProductOptionPreventCancelledAgentsMakingClaimPayments(
    ByVal oClaimDetails As BaseAdditionalClaimRelatedDetails,
    ByVal oClaimPayment As BaseClaimPaymentType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        ' if the payment party agent is specified
        If oClaimPayment.PaymentPartyType = ClaimPaymentPartyTypeType.AGENT Then

            ' the product option prevents 
            If oClaimDetails.Product IsNot Nothing AndAlso
                oClaimDetails.Product.PreventsCancelledAgentsMakingClaimPayments Then

                ' if there is an agent specified 
                ' ( there should be at this point - previous validation code should have set it)
                If oClaimPayment.PartyKey <> 0 Then

                    ' is there a transfer agent
                    If oClaimDetails.Agent.IsInTransferMode AndAlso
                        oClaimDetails.Agent.TransferToBusinessTypeCode <> InternalSAMConstants.kBusinessTypeDIRECT Then

                        ' if the transfer agent is cancelled 
                        If oClaimDetails.TransferAgent IsNot Nothing AndAlso
                            oClaimDetails.TransferAgent.Cancelled = True Then

                            ' raise a business rules error
                            oSAMErrorCollection.AddInvalidData(SAMBusinessErrors.ProductOptionPreventCancelledAgentsMakingClaimPaymentsEnforcedAsAgentOnThisClaimIsCancelled,
                                                 SAMBusinessErrors.ProductOptionPreventCancelledAgentsMakingClaimPaymentsEnforcedAsAgentOnThisClaimIsCancelled.ToString,
                                                 "PaymentPartyType")

                        End If
                    Else

                        ' if the agent is cancelled 
                        If oClaimDetails.Agent.Cancelled Then

                            ' raise a business rules error
                            oSAMErrorCollection.AddInvalidData(SAMBusinessErrors.ProductOptionPreventCancelledAgentsMakingClaimPaymentsEnforcedAsAgentOnThisClaimIsCancelled,
                                                 SAMBusinessErrors.ProductOptionPreventCancelledAgentsMakingClaimPaymentsEnforcedAsAgentOnThisClaimIsCancelled.ToString,
                                                 "PaymentPartyType")

                        End If

                    End If

                End If

            End If

        End If

    End Sub

    Private Sub FurtherClaimPaymentDataValidation(
    ByVal oRequest As BaseClaimPaymentRequestType,
    ByVal oClaimDetails As BaseAdditionalClaimRelatedDetails,
    ByVal oBusiness As CoreBusiness,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        'If payment party type is claim payable, party key will not be used.
        If oRequest.ClaimPayment.PaymentPartyType <> ClaimPaymentPartyTypeType.CLMPAYABLE Then
            oSAMErrorCollection.CheckForErrors()

            Using conPartyBank As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

                If oRequest.ClaimPayment IsNot Nothing AndAlso oRequest.ClaimPayment.Payee IsNot Nothing Then
                    With oRequest.ClaimPayment.Payee
                        If Not oRequest.ClaimPayment.ClaimPaymentWorkflowEnabled Then
                            If .PartyBankKey > 0 Then
                                If .MediaTypeCode = "CC" Then
                                    'Currently, SAM request contains any fields to support credit card details. We have to decide how to proceed in this scenario. 
                                    'Commenting the section as told by Gaurav.
                                    'ValidatePartyBank(conPartyBank, oSAMErrorCollection, .PartyBankKey, oRequest.ClaimPayment.PartyKey)
                                Else
                                    If String.IsNullOrEmpty(.BankNumber) Then
                                        'If bank number is not provided, validate the party bank key
                                        ValidatePartyBank(conPartyBank, oSAMErrorCollection, .PartyBankKey, oRequest.ClaimPayment.PartyKey)
                                    Else

                                        'We are not sure request's bank number actually maps to bank account number. So commenting this section as told by Gaurav.
                                        'If Bank number is provided, check its validity with bank account number.
                                        ValidatePartyBank(conPartyBank, oSAMErrorCollection, .PartyBankKey, oRequest.ClaimPayment.PartyKey, Nothing, True, .BankNumber)
                                    End If
                                End If
                                oSAMErrorCollection.CheckForErrors()
                            End If
                        Else
                            'If claim payment workflow is enabled, and the cashlist contains a party bank item, assign that party bank key to oRequest.ClaimPayment.Payee.PartyBankKey
                            'Cashlist details are not getting saved in claim payment table. We have to make sure that the party bank key in cashlist is  getting saved in calim payment table.
                            If oRequest.ClaimPayment.CashList IsNot Nothing AndAlso oRequest.ClaimPayment.CashList.PaymentItem IsNot Nothing AndAlso oRequest.ClaimPayment.CashList.PaymentItem.Length > 0 Then
                                If oRequest.ClaimPayment.CashList.PaymentItem(0).Bank IsNot Nothing AndAlso oRequest.ClaimPayment.CashList.PaymentItem(0).Bank.PartyBankKey > 0 Then
                                    oRequest.ClaimPayment.Payee.PartyBankKey = oRequest.ClaimPayment.CashList.PaymentItem(0).Bank.PartyBankKey
                                ElseIf oRequest.ClaimPayment.CashList.PaymentItem(0).CreditCard IsNot Nothing AndAlso oRequest.ClaimPayment.CashList.PaymentItem(0).CreditCard.PartyBankKey > 0 Then
                                    oRequest.ClaimPayment.Payee.PartyBankKey = oRequest.ClaimPayment.CashList.PaymentItem(0).CreditCard.PartyBankKey
                                End If
                            End If
                        End If
                    End With
                End If
            End Using
        End If
    End Sub

    Public Function ProcessGetTaxDetails(ByVal Con As SiriusConnection,
                                         ByVal oRequest As BaseClaimPaymentRequestType,
                                         ByRef oSAMErrorCollection As SAMErrorCollection) _
                                         As Object

        Dim oResponse As Object = Nothing
        Dim oBusiness As New CoreBusiness
        Dim oClaimPayment As BaseClaimPaymentType = oRequest.ClaimPayment
        Dim nGetSavedTaxOfPeril As Integer = oRequest.GetSavedTaxOfPeril

        ' get the live claim id
        oClaimPayment.ClaimId = oBusiness.GetCurrentIdFromBaseIdAndVersionId(Con,
                                                "Claim",
                                                CInt(oRequest.ClaimPayment.BaseClaimKey),
                                                oRequest.ClaimPayment.VersionId)

        ' get the live claim peril id
        oClaimPayment.ClaimPerilId = oBusiness.GetCurrentIdFromBaseIdAndVersionId(Con,
                                                "Claim_Peril",
                                                CInt(oRequest.ClaimPayment.BaseClaimPerilKey),
                                                oRequest.ClaimPayment.VersionId)

        ' for each payment item
        If oRequest.ClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For Each oPaymentItem As BaseClaimPaymentItemType In oRequest.ClaimPayment.ClaimPaymentItem

                ' default the is withholding tax details
                oPaymentItem.IsWHTTax = oRequest.ClaimPayment.TaxIsWithHoldingTax

                ' reset the tax amounts
                oPaymentItem.TaxAmount = 0
                oPaymentItem.TaxAmountWHT = 0

                oPaymentItem.ReserveId = oBusiness.GetCurrentIdFromBaseIdAndVersionId _
                (Con, "Reserve", CInt(oPaymentItem.BaseReserveKey), oRequest.ClaimPayment.VersionId)

            Next
        End If

        Dim oClaimDetails As New BaseAdditionalClaimRelatedDetails
        ' Collect all the other information required to process payment of claim
        GetClaimDetailsForPaymentOrReceipt(Con,
            oClaimPayment.ClaimId,
            oClaimPayment.ClaimPerilId,
            oClaimDetails)

        oClaimPayment.LossCurrencyId = oClaimDetails.Claim.LossCurrencyKey
        oClaimPayment.ClassOfBusinessID = oClaimDetails.ClaimPeril.ClassOfBusinessId
        oClaimPayment.ClassOfBusinessCode = oClaimDetails.ClaimPeril.ClassOfBusinessCode
        oClaimPayment.InsuranceFileCNT = oClaimDetails.InsuranceFile.InsuranceFileKey
        oClaimPayment.PostClaimTaxesSeperately = oClaimDetails.Risk.PostTaxEntriesSeparately

        GetCurrencyToCurrencyExchangeRate(Con, oClaimPayment.TransactionDate, oClaimPayment.CurrencyId, oClaimPayment.LossCurrencyId, oRequest.SourceId, oClaimPayment.PaymentToLossXRate)

        ' danny davis reckons this is done deliberately in sbo because of rounding issues 
        ' encountered by australia so therefore replicated it here.
        'oClaimPayment.PaymentToLossXRate = Decimal.Round(oClaimPayment.PaymentToLossXRate, 4)

        oResponse = DirectCast(oResponse, BaseImplementationTypes.BaseGetClaimPaymentTaxesResponseType)

        oResponse = getPerilReservePaymentdetails(Con, oRequest.ClaimPayment, oSAMErrorCollection, False, nGetSavedTaxOfPeril)

        Return oResponse

    End Function

    Public Function ProcessPayClaim(ByVal con As SiriusConnection,
                                    ByVal oRequest As BaseClaimPaymentRequestType,
                                    ByRef oSAMErrorCollection As SAMErrorCollection,
                                    Optional ByVal iProductId As Integer = 1) _
                                    As Object

        Dim oResponse As Object = Nothing
        Dim oBusiness As New CoreBusiness(_SiriusUser)

        ' get the relevant exchanges rates for the payment items
        Dim oClaimPayment As BaseClaimPaymentType = oRequest.ClaimPayment
        Dim iClientKey As Integer
        Dim bUserIsAuthorisedToMakePayment As Boolean

        Dim creditedAccountKey As Integer = 0
        Dim creditedDocumentKey As Integer = 0
        Dim creditedTransdetailKey As Integer = 0
        Dim sRI2007 As String = "" 'WPR022
        Dim iClaimXOLCount As Integer = 0 'WPR022

        If (oRequest.IsDataTransferClaim) And
          Not (oRequest.DataTransferIsUsingFullClaimVersioning) Then
            oClaimPayment.ClaimId = oClaimPayment.BaseClaimKey
            oClaimPayment.ClaimPerilId = oClaimPayment.BaseClaimPerilKey
            oClaimPayment.VersionId = 1
        Else

            ' Copy Claim Details (copies the existing claim and 
            ' returns the claim id, version id of the new version) 
            ProcessCopyClaim(con,
                    oClaimPayment.BaseClaimKey,
                    oClaimPayment.SourceId,
                    ksPayClaimType,
                     _SiriusUser.UserID,
                     oClaimPayment.ClaimId,
                     oClaimPayment.VersionId, oRequest.IsDataTransferClaim, oRequest.DataTransferClaimHasClaimRiskDataSpecified, oRequest.DataTransferIsUsingFullClaimVersioning)

            ' Retrieve the correct version of the peril id ( just added by the copyclaim routine )
            oClaimPayment.ClaimPerilId = oBusiness.GetCurrentIdFromBaseIdAndVersionId(con,
                    "Claim_Peril",
                        CInt(oClaimPayment.BaseClaimPerilKey),
                            oClaimPayment.VersionId)

        End If

        ' get account details for CLMPAYABLE Account
        GetAccountDetailsFromShortCode(con, InternalSAMConstants.kAccountShortnameCLMPAYABLE, oRequest.PaymentPartyAccountId)

        ' if a party to pay has been selected then get the account details for that party
        If oClaimPayment.PaymentPartyType <> ClaimPaymentPartyTypeType.CLMPAYABLE Then

            If oClaimPayment.PartyKey <> ClaimPaymentPartyTypeType.CLMPAYABLE Then

                GetAccountDetailsForParty(con, oClaimPayment.PartyKey,
                    oRequest.PaymentPartyAccountId,
                    oRequest.PaymentPartyAccountCode,
                    oRequest.PaymentPartyShortCode)

            End If

        End If

        Dim oClaimDetails As New BaseAdditionalClaimRelatedDetails

        ' Collect all the other information required to process payment of claim
        GetClaimDetailsForPaymentOrReceipt(con,
            oClaimPayment.ClaimId,
            oClaimPayment.ClaimPerilId,
            oClaimDetails)

        oClaimPayment.LossCurrencyId = oClaimDetails.Claim.LossCurrencyKey
        oClaimPayment.ClassOfBusinessID = oClaimDetails.ClaimPeril.ClassOfBusinessId
        oClaimPayment.ClassOfBusinessCode = oClaimDetails.ClaimPeril.ClassOfBusinessCode
        oClaimPayment.InsuranceFileCNT = oClaimDetails.InsuranceFile.InsuranceFileKey
        oClaimPayment.PostClaimTaxesSeperately = oClaimDetails.Risk.PostTaxEntriesSeparately

        Dim oPaymentItem As BaseClaimPaymentItemType = Nothing

        For Each oPaymentItem In oClaimPayment.ClaimPaymentItem

            oPaymentItem.IsWHTTax = oClaimPayment.TaxIsWithHoldingTax
            oPaymentItem.TaxAmount = 0
            oPaymentItem.TaxAmountWHT = 0

            oPaymentItem.ReserveId = oBusiness.GetCurrentIdFromBaseIdAndVersionId(con,
               "Reserve", CInt(oPaymentItem.BaseReserveKey), oClaimPayment.VersionId)

        Next

        ' Retrieve the Transaction To Loss Currency Exchange Rate 
        GetCurrencyToCurrencyExchangeRate(con, oClaimPayment.TransactionDate, oClaimPayment.CurrencyId, oClaimPayment.LossCurrencyId, oRequest.SourceId, oClaimPayment.PaymentToLossXRate)

        ' danny davis reckons this is done deliberately in sbo because of rounding issues 
        ' encountered by australia so therefore replicated it here.
        'oClaimPayment.PaymentToLossXRate = Decimal.Round(oClaimPayment.PaymentToLossXRate, 4)

        Dim oClaimPaymentTaxes As New BaseImplementationTypes.BaseGetClaimPaymentTaxesResponseType

        ' 1 - Below is the function used to build the reserve details on all
        '     claim payment items in the request structure.
        ' 2-  It put all the retrieved details in respected items on request and response Structures
        oClaimPaymentTaxes = getPerilReservePaymentdetails(con, oRequest.ClaimPayment, oSAMErrorCollection)

        ' get the exchange rate details for the payment 
        GetCurrencyExchangeRatesForAll(con, Date.Today.Date, oRequest.PaymentPartyAccountId,
            oClaimPayment.SourceId, oClaimPayment.CurrencyId, oClaimPayment.TotCurrAmount,
            oClaimPayment.BaseCurrencyId, oClaimPayment.BaseAmount, oClaimPayment.AccountCurrencyId,
            oClaimPayment.AccountAmount, oClaimPayment.SystemCurrencyId, oClaimPayment.SystemAmount,
            oClaimPayment.CurrencyToBaseXRate, oClaimPayment.CurrencyToBaseDate, oClaimPayment.AccountToBaseXRate,
            oClaimPayment.AccountToBaseDate, oClaimPayment.SystemToBaseXRate, oClaimPayment.SystemToBaseDate)

        oClaimPayment.Comments = ""
        oClaimPayment.IsReferred = Nothing
        oClaimPayment.DocumentId = Nothing
        oClaimPayment.TreatyId = Nothing
        oClaimPayment.SequenceNo = Nothing
        oPaymentItem.RecoveryId = Nothing
        oPaymentItem.RecoveryTypeId = Nothing

        oClaimPayment.ClaimPaymentToId = oClaimPayment.PaymentPartyType

        ' Save Payment to the Claim_Payment table
        SaveClaimPayment(con, oRequest.ClaimPayment)

        ' Save Payment to the Claim_Payment_item table
        SaveClaimPaymentItems(con:=con, oClaimPayment:=oRequest.ClaimPayment, sRequestFrom:="CLMPayable", bIsDataTransferClaim:=oRequest.IsDataTransferClaim, bDataTransferIsUsingFullClaimVersioning:=oRequest.DataTransferIsUsingFullClaimVersioning, oClaimPaymentTaxes:=oClaimPaymentTaxes)

        If oRequest.ClaimPayment.PaymentOnly = False Then

            If Not oRequest.IsDataTransferClaim Then
                If oClaimPayment.AllowNegativeReserve = "0" Then
                    SaveReserveAdjustmentsToAccounts(con, oRequest.ClaimPayment)
                End If
            End If

            If Not oRequest.IsDataTransferClaim Then
                SavePaymentToAccounts(con, oRequest.ClaimPayment)
            End If

            'For pay claim, transaction type code in database is C_CP
            Const ksTransactionType As String = "C_CP"
            ProcessClaimsCoinsurance(con, oBusiness, oRequest.ClaimPayment.ClaimId, ksTransactionType, oRequest.BranchCode)

            If Not oRequest.DataTransferClaimHasSpecifiedReinsurance Then
                ProcessClaimsReinsurance(con:=con,
                                          lClaimId:=oClaimPayment.ClaimId,
                                          lBalanceAndCloseClaim:=kBalanceAndCloseClaim)

                sRI2007 = oBusiness.GetProductOption(ProductOption.RI2007, 1)
                If sRI2007 = "1" Then
                    ValidateXOLPayment(con, oClaimPayment.ClaimId, iClaimXOLCount)
                    If iClaimXOLCount > 0 Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.PendingClaimWithXOLLines, SAMBusinessErrors.PendingClaimWithXOLLines.ToString, "You cannot add any further payments onto this claim as it has pending authorisations with Excess of Loss Reinsurance.")
                        oSAMErrorCollection.CheckForErrors()
                    End If
                End If
            End If
            If oRequest.ClaimPayment.PartyKey = 0 Then
                iClientKey = oRequest.ClaimPayment.ClientKey
            Else
                iClientKey = oClaimPayment.PartyKey
            End If
            CreateDefaultClaimEvent(con:=con,
                                         lInsuranceHolderCnt:=iClientKey,
                                         lInsuranceFolderCnt:=0,
                                         lInsuranceFileCnt:=oClaimPayment.InsuranceFileCNT,
                                         lClaimId:=oClaimPayment.ClaimId,
                                         sTransactionType:=TransactionTypeCode.PayClaim,
                                         lUserId:=_SiriusUser.UserID,
                                         sEventDescription:=oClaimPayment.ClaimVersionDescription)

            If Not oRequest.IsDataTransferClaim Then
                FinaliseClaimDetails(con:=con,
                                        lClaimId:=oClaimPayment.ClaimId,
                                        sClaimVersionDescription:=oClaimPayment.ClaimVersionDescription)
            End If

            ' Finalise the Payment process
            ProcessClaimPayment(con, oRequest.ClaimPayment, bUserIsAuthorisedToMakePayment, oRequest.IsDataTransferClaim)

            ' reset the claim is dirty flag
            UpdateClaimIsDirtyFlag(con, oClaimPayment.ClaimId, 0)

            GetPaymentCreditedAccountDetails(con,
                                                oClaimPayment.ClaimId,
                                                CInt(oClaimPayment.PaymentId),
                                                creditedAccountKey,
                                                creditedDocumentKey,
                                                creditedTransdetailKey)
        End If
        oClaimPayment.ClaimNumber = GetAndValidateDescriptionById(con, "claim", "Claim_Number", "Claim_id", oClaimPayment.ClaimId.ToString())
        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.PayClaimRequestType) Then

            Dim oClaimResponse As New SAMForInsuranceV2ImplementationTypes.PayClaimResponseType

            oResponse = DirectCast(oResponse, SAMForInsuranceV2ImplementationTypes.PayClaimResponseType)

            If Not bUserIsAuthorisedToMakePayment Then
                If oRequest.ClaimPayment.PaymentOnly = False Then

                    AddWarning(oClaimResponse,
                            SAMBusinessWarnings.UserDoesntHaveAuthorityToMakeThisPaymentPaymentWasReferred,
                            SAMBusinessWarnings.UserDoesntHaveAuthorityToMakeThisPaymentPaymentWasReferred.ToString)
                    oClaimResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                            (con, oClaimPayment.ClaimId, oClaimPayment.CloseClaimOnZeroReserveRecoveryBalance)
                End If
            Else
                'Using new webmethod GetProductClaimsWorkflowOptions to retrieve the CashPaymentProcess value. 
                'This option identifies claim payment workflow is enabled or not. 
                'Previously, this was in system options now it has been moved to product risk options
                'To call GetProductClaimsWorkflowOptions, we need to know the Product ID
                If oRequest.ClaimPayment.PaymentOnly = False Then
                    Dim oGetProductClaimsWorkflowOptionsRequest As New BaseGetProductClaimsWorkflowOptionsRequestType
                    Dim dsWorkflowOptions As DataSet = Nothing

                    oGetProductClaimsWorkflowOptionsRequest.ProductID = iProductId
                    oGetProductClaimsWorkflowOptionsRequest.ClaimProcessType = ClaimProcessType.ClaimPayment

                    dsWorkflowOptions = GetProductClaimsWorkflowOptions(con, oGetProductClaimsWorkflowOptionsRequest)

                    If (dsWorkflowOptions IsNot Nothing AndAlso dsWorkflowOptions.Tables.Count > 0 _
                    AndAlso dsWorkflowOptions.Tables(0).Rows.Count > 0) Then
                        If Cast.ToBoolean(dsWorkflowOptions.Tables(0).Rows(0).Item("CashPaymentProcess"), False) And oRequest.ClaimPayment.BaseAmount <> 0 Then

                            'Payment Workflow is Enabled
                            oRequest.ClaimPayment.ClaimPaymentWorkflowEnabled = True

                            Dim oClaimResponsewarning As New SAMForInsuranceV2ImplementationTypes.PayClaimResponseType
                            ClaimPaymentWorkFlowValidation(DirectCast(oRequest.ClaimPayment, BaseImplementationTypes.BaseClaimPaymentType), oSAMErrorCollection, DirectCast(oClaimResponsewarning, BaseClaimResponseType))

                            'Check for errors
                            oSAMErrorCollection.CheckForErrors()
                            If oRequest.ClaimPayment.ClaimPaymentWorkflowEnabled Then
                                If oRequest.ClaimPayment.CashList IsNot Nothing Then
                                    If oRequest.ClaimPayment.BaseAmount < 0 Then
                                        oRequest.ClaimPayment.CashList.TypeCode = "R"
                                    End If
                                    PayClaimValidateCashList(con, oBusiness, oRequest.ClaimPayment.CashList, oSAMErrorCollection)

                                    'If there were any errors throw an exception
                                    oSAMErrorCollection.CheckForErrors()
                                End If
                            End If
                            Dim SourceId As Integer
                            If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
                                SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                                    PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
                            End If
                            oRequest.ClaimPayment.CashList.SourceID = SourceId
                        Else
                            oClaimResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                                   (con, oClaimPayment.ClaimId, oClaimPayment.CloseClaimOnZeroReserveRecoveryBalance)

                        End If
                    Else
                        'Failed to get Product Claim Workflow Options
                        oSAMErrorCollection.AddInvalidData(
                                            SAMConstants.SAMInvalidData.GeneralFailure,
                                            "Failed to get claim workflow options for the given Product")

                        oSAMErrorCollection.CheckForErrors()
                    End If

                    If Not oRequest.IsDataTransferClaim Then
                        If oRequest.ClaimPayment.ClaimPaymentWorkflowEnabled Then
                            oRequest.ClaimPayment.CashList.BranchCode = oRequest.BranchCode
                            oRequest.ClaimPayment.CashList.SourceID = oRequest.SourceId
                            ProcessClaimPaymentCashList(con, oRequest.ClaimPayment, creditedAccountKey, creditedDocumentKey)
                            oClaimResponse.CashList = New BaseCashListResponseType
                            oClaimResponse.CashList.CashListKey = oClaimPayment.CashList.CashListKey
                        End If
                    End If

                    oClaimResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                              (con, oClaimPayment.ClaimId, oClaimPayment.CloseClaimOnZeroReserveRecoveryBalance)

                End If

            End If
            oClaimResponse.BaseClaimKey = oClaimPayment.BaseClaimKey
            oClaimResponse.ClaimKey = oClaimPayment.ClaimId
            oClaimResponse.ClaimNumber = oClaimPayment.ClaimNumber
            oClaimResponse.Version = oClaimPayment.VersionId
            oClaimResponse.creditedAccountKey = creditedAccountKey
            oClaimResponse.creditedDocumentKey = creditedDocumentKey
            oClaimResponse.creditedTransdetailKey = creditedTransdetailKey

            oResponse = oClaimResponse
        Else
            Dim oClaimResponse As New SAMForInsuranceImplementationTypes.PayClaimResponseType

            ' Build the Pay Claim response Object
            oResponse = DirectCast(oResponse, SAMForInsuranceImplementationTypes.PayClaimResponseType) '

            oClaimResponse.BaseClaimKey = oClaimPayment.BaseClaimKey
            oClaimResponse.ClaimKey = oClaimPayment.ClaimId
            oClaimResponse.ClaimNumber = oClaimPayment.ClaimNumber
            oClaimResponse.Version = oClaimPayment.VersionId
            oClaimResponse.creditedAccountKey = creditedAccountKey
            oClaimResponse.creditedDocumentKey = creditedDocumentKey
            oClaimResponse.creditedTransdetailKey = creditedTransdetailKey

            If Not bUserIsAuthorisedToMakePayment Then
                AddWarning(oClaimResponse,
                        SAMBusinessWarnings.UserDoesntHaveAuthorityToMakeThisPaymentPaymentWasReferred,
                        SAMBusinessWarnings.UserDoesntHaveAuthorityToMakeThisPaymentPaymentWasReferred.ToString)
            End If

            oClaimResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                                 (con, oClaimPayment.ClaimId, oClaimPayment.CloseClaimOnZeroReserveRecoveryBalance)

            oResponse = oClaimResponse
        End If
        Return oResponse

    End Function

    ''' <summary>
    ''' Processes the claim payment request type
    ''' </summary>
    '''<param name="con">An object of SiriusConnection class</param>
    '''<param name="oBusiness">An object of CoreBusiness class</param>
    '''<param name="oClaimPaymentRequest">An object of BaseClaimPaymentRequestType class</param>
    '''<param name="iClaimPaymentAccountKey">Payment account key</param>
    '''<param name="iClaimPaymentDocumentKey">Payment document key</param>
    Private Sub ProcessClaimPaymentCashList(ByVal con As SiriusConnection,
                                            ByRef oClaimPaymentRequest As BaseClaimPaymentType,
                                            ByVal iClaimPaymentAccountKey As Integer,
                                            ByVal iClaimPaymentDocumentKey As Integer)

        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oBusiness As New CoreBusiness
        'oClaimPaymentRequest.ClaimPayment.CashList.BranchCode = oClaimPaymentRequest.BranchCode
        'oClaimPaymentRequest.ClaimPayment.CashList.SourceID = oClaimPaymentRequest.SourceId
        For Each oPaymentItem As BasePaymentCashListItemType In oClaimPaymentRequest.CashList.PaymentItem
            ProcessClaimPaymentCashListItem(con, oPaymentItem, iClaimPaymentAccountKey, iClaimPaymentDocumentKey)
        Next
        'Deviation from Tech Spec-ProcessCashList method takes an extra parameter to indicate whether the validations
        ' are already done or not. Here we are passing the value true because this method is getting called
        ' as a part of PayClaim, and validations on CashList object has been done already.
        ProcessCashList(con, oBusiness, DirectCast(oClaimPaymentRequest.CashList, BaseCoreCashListType), oSAMErrorCollection, True, True, Convert.ToInt32(oClaimPaymentRequest.PaymentId))
        'Check for errors
        oSAMErrorCollection.CheckForErrors()
    End Sub

