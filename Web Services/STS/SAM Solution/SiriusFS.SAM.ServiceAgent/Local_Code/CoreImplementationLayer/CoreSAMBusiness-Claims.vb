    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="PayClaimRequest"></param>
    ''' <param name="oPaymentItem"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function UpdateReserve(ByVal Con As SiriusConnection,
                                ByVal oClaimPayment As BaseClaimPaymentType,
                                ByVal oPaymentItem As BaseClaimPaymentItemType,
                                ByVal bIsDataTransferClaim As Boolean,
                                ByVal bDataTransferIsUsingFullClaimVersioning As Boolean,
                                Optional ByVal SkipUpdate As Boolean = False,
                                Optional ByVal lProcessType As Integer = 1,
                                Optional ByVal bSkipUpdateReserve As Boolean = False,
                                Optional ByVal bClaimsReservesAreGross As Boolean = False,
                                Optional ByVal bPaymentCannotExceedReserve As Boolean = False) As Long

        Dim TotalPayment As Decimal

        'Commented form 907 Arch
        If oClaimPayment.ClaimPaymentIsGross = "1" Then
            'Total amount adjusted should be just the payment amount
            TotalPayment = oPaymentItem.LCurrencyAmount + oPaymentItem.LCurrencyTax + oPaymentItem.LCurrencyTaxWHT
        Else
            'Total amount adjusted should be payment amount and the tax amount
            TotalPayment = oPaymentItem.LCurrencyAmount
        End If

        If oClaimPayment.AllowNegativeReserve = "0" Then ' PN3590

            ' if this isnt an excess row then
            If Not oPaymentItem.IsExcess Then

                If oPaymentItem.CurrentReserve < TotalPayment Then
                    ' Negative reserve is not allowed then set the revision amount for reserve
                    oPaymentItem.RevisionAmount = TotalPayment - oPaymentItem.CurrentReserve
                End If

            ElseIf oPaymentItem.IsExcess Then

                If TotalPayment < oPaymentItem.CurrentReserve AndAlso oPaymentItem.CurrencyAmount <> 0 Then
                    oPaymentItem.RevisionAmount = TotalPayment - oPaymentItem.CurrentReserve
                End If

            End If

        End If

        ' if this is the data transfer and it is with full claim versioning 
        ' dont adjust the claim reserve 
        ' by the payment amount (this change was requested by Adam Lewis and Steve Ross)
        ' this will be done after the payment has been processed and
        ' with the amount specified on the reserve rather than the payment amount
        If (bIsDataTransferClaim And bDataTransferIsUsingFullClaimVersioning) Then
            oPaymentItem.RevisionAmount = 0
        End If
        If (bPaymentCannotExceedReserve = True) Then
                If (lProcessType = 3 OrElse lProcessType = 4) Then
                    oPaymentItem.RevisionAmount = 0
                End If
        Else
                If TotalPayment > oPaymentItem.CurrentReserve AndAlso oPaymentItem.CurrentReserve < 0 Then
                    oPaymentItem.RevisionAmount = Math.Abs(oPaymentItem.CurrentReserve)
                ElseIf TotalPayment > oPaymentItem.CurrentReserve AndAlso oPaymentItem.CurrentReserve > 0 Then
                    oPaymentItem.RevisionAmount = TotalPayment - oPaymentItem.CurrentReserve
                End If
        End If
        If SkipUpdate = False Then
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Claim_Payment_Item_Reserve_Update")

                ' Add Required Stored Procedure Parameters
                cmd.AddInParameter("@reserve_id", SqlDbType.Int).Value = oPaymentItem.ReserveId
                cmd.AddInParameter("@this_revision", SqlDbType.Money).Value = oPaymentItem.RevisionAmount
                cmd.AddInParameter("@this_payment", SqlDbType.Money).Value = TotalPayment
                cmd.AddInParameter("@nSkipUpdateReserve", SqlDbType.Int).Value = If(bSkipUpdateReserve, 1, 0)
                cmd.AddInParameter("@transaction_type", SqlDbType.NVarChar).Value = If(bIsDataTransferClaim, "C_CP", "") 'Added for DTU - Defect:22352
                cmd.AddInParameter("@nDataTransfer", SqlDbType.Int).Value = If(bIsDataTransferClaim, 1, 0) 'Added for DTU - Defect:22352

                ' Execute Action Query
                Con.ExecuteNonQuery(cmd)

            End Using
        End If
    End Function

    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="payClaimRequest"></param>
    ''' <remarks></remarks>
    Private Sub SaveReserveAdjustmentsToAccounts(
    ByVal Con As SiriusConnection,
    ByVal oClaimPayment As BaseClaimPaymentType)

        Dim crTotalRevisionAmount As Decimal
        Dim opaymentItem As BaseClaimPaymentItemType

        If oClaimPayment.AllowNegativeReserve = "0" Then
            For Each opaymentItem In oClaimPayment.ClaimPaymentItem
                crTotalRevisionAmount = crTotalRevisionAmount + opaymentItem.RevisionAmount
            Next
        End If

        Dim sTransactionTypeCode As String = "C_CR"
        Dim lTransactionTypeID As Integer = 28
        Dim sDebitAccountCode As String = String.Empty
        Dim sCreditAccountCode As String = String.Empty
        Dim DebitCredit As String = "D"
        Dim DocumentComment As String = "Reserve Adjustment for Claim Number " & oClaimPayment.ClaimNumber
        Dim TransactionAmount As Decimal = crTotalRevisionAmount
        Dim DocumentTypeID As Integer = 41

        sDebitAccountCode = "CLMEXP" & Trim$(oClaimPayment.ClassOfBusinessCode)
        sCreditAccountCode = "CLMRES" & Trim$(oClaimPayment.ClassOfBusinessCode)

        ' this is a payment adjustment

        ' if there is a revision amount
        If crTotalRevisionAmount <> 0 Then

            Dim lStatsFolderCnt As Integer
            ' Get the Stats folder if already exist on it
            lStatsFolderCnt = GetStatsFolder(Con,
                                                oClaimPayment.ClaimId,
                                                sTransactionTypeCode)

            ' if stats folder does'nt exist then create ir
            If lStatsFolderCnt = 0 Then
                lStatsFolderCnt = AddClaimsStatsFolder(con:=Con,
                                                        lInsuranceFileCnt:=oClaimPayment.InsuranceFileCNT,
                                                        sDebitOrCredit:=DebitCredit,
                                                        sDocumentComment:=DocumentComment,
                                                        lTransactionTypeId:=lTransactionTypeID,
                                                        sTransactionTypeCode:=sTransactionTypeCode,
                                                        lUserId:=_SiriusUser.UserID,
                                                        sUserName:=_SiriusUser.Username,
                                                        lClaimId:=oClaimPayment.ClaimId,
                                                        lDocumentTypeId:=DocumentTypeID)
            End If

            ' Add stats_detail for payment adjustment
            AddClaimsStatsDetail(con:=Con,
                                    lStatsFolderCnt:=lStatsFolderCnt,
                                    lClaimId:=oClaimPayment.ClaimId,
                                    lClaimPerilId:=oClaimPayment.ClaimPerilId,
                                    sStatsDetailType:="GRS",
                                    lClassOfBusinessId:=oClaimPayment.ClassOfBusinessID,
                                    sClassOfBusinessCode:=oClaimPayment.ClassOfBusinessCode,
                                    lRIPartyCnt:=oClaimPayment.PartyKey,
                                    sRIShortname:=sCreditAccountCode,
                                    lRIPartyType:=0,
                                    dRISharePercent:=0,
                                    crTransactionAmount:=crTotalRevisionAmount,
                                    lDocumentTypeId:=DocumentTypeID)
        End If

    End Sub

    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="PayClaimRequest"></param>
    ''' <remarks></remarks>
    Private Sub SavePaymentToAccounts(ByVal Con As SiriusConnection,
                                        ByVal oClaimPayment As BaseClaimPaymentType)

        'Const kMethodName As String = "SavePaymentToAccounts"

        'Dim lReturn As Long
        Dim crTotalPaymentInPaymentCurrency As Decimal
        Dim sShortName As String = String.Empty
        'Dim crPaymentAmount As Decimal

        If oClaimPayment.PostClaimTaxesSeperately = True Then
            ' calculate the total amount
            If oClaimPayment.ClaimPaymentIsGross = "1" Then
                crTotalPaymentInPaymentCurrency = oClaimPayment.TotCurrAmount - oClaimPayment.TotTaxAmount
            Else
                crTotalPaymentInPaymentCurrency = oClaimPayment.TotCurrAmount
            End If
        Else

            ' calculate the total amount
            crTotalPaymentInPaymentCurrency = oClaimPayment.TotCurrAmount + (oClaimPayment.TotTaxAmount + oClaimPayment.TotTaxWHTAmount)

        End If

        ' if there is a valid class of business code
        If Not String.IsNullOrEmpty(oClaimPayment.ClassOfBusinessCode) Then

            If Not oClaimPayment.Payee Is Nothing Then  'CHECK
                sShortName = oClaimPayment.Payee.Name
            Else
                sShortName = InternalSAMConstants.kAccountShortnameCLMPAYABLE
            End If

            'Dim lStatsFolderCnt As Integer
            Dim sTransactionTypeCode As String = ksPayClaimType
            Dim lTransactionTypeID As Integer = 27
            Dim sDebitAccountCode As String = String.Empty
            Dim sCreditAccountCode As String = String.Empty
            Dim DebitCredit As String = "C"
            Dim sDocumentComment As String = "Reserve Adjustment for Claim Number " & oClaimPayment.ClaimNumber
            Dim TransactionAmount As Decimal = crTotalPaymentInPaymentCurrency
            Dim DocumentTypeID As Integer = 28

            sDebitAccountCode = "CLMRES" & Trim$(oClaimPayment.ClassOfBusinessCode)

            Dim ds As DataSet = Nothing
            Dim shortCode As String = String.Empty
            Dim accountId As Integer
            Dim statsFolderCnt As Integer

            '''''Code Changed ----- Saurabh
            If oClaimPayment.PaymentPartyType <> ClaimPaymentPartyTypeType.CLMPAYABLE Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_shortname")
                    cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = oClaimPayment.PartyKey
                    ds = Con.ExecuteDataSet(cmd, "Row")
                    shortCode = Cast.ToStringTrim(ds.Tables(0).Rows(0).Item("shortname"), String.Empty)
                End Using
            Else
                shortCode = "CLMPAYABLE"
            End If

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Account_ID")
                cmd.AddInParameter("@short_code", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(shortCode)
                cmd.AddInParameter("@account_key", SqlDbType.Int).Value = oClaimPayment.PartyKey
                ds = Con.ExecuteDataSet(cmd, "Row")
                accountId = Cast.ToInt32(ds.Tables(0).Rows(0).Item("account_id"), 0)
            End Using

            statsFolderCnt = AddClaimsStatsFolder(con:=Con,
                                lInsuranceFileCnt:=oClaimPayment.InsuranceFileCNT,
                                sDebitOrCredit:=DebitCredit,
                                sDocumentComment:=sDocumentComment,
                                lTransactionTypeId:=lTransactionTypeID,
                                sTransactionTypeCode:=sTransactionTypeCode,
                                lUserId:=_SiriusUser.UserID,
                                sUserName:=_SiriusUser.Username,
                                lClaimId:=oClaimPayment.ClaimId,
                                lDocumentTypeId:=DocumentTypeID)

            AddClaimsStatsDetail(con:=Con,
                                lStatsFolderCnt:=statsFolderCnt,
                                lClaimId:=oClaimPayment.ClaimId,
                                lClaimPerilId:=oClaimPayment.ClaimPerilId,
                                sStatsDetailType:="GRS",
                                lClassOfBusinessId:=oClaimPayment.ClassOfBusinessID,
                                sClassOfBusinessCode:=oClaimPayment.ClassOfBusinessCode,
                                lRIPartyCnt:=oClaimPayment.PartyKey,
                                sRIShortname:=shortCode,
                                lRIPartyType:=0,
                                dRISharePercent:=0,
                                crTransactionAmount:=TransactionAmount,
                                lDocumentTypeId:=DocumentTypeID)

            'Dim icount As Integer
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Claim_Tax_Amounts_By_Tax_Type")
                cmd.AddInParameter("@claim_payment_id", SqlDbType.Int).Value = oClaimPayment.PaymentId
                cmd.AddInParameter("@claim_receipt_id", SqlDbType.Int)
                ds = Con.ExecuteDataSet(cmd, "Row")
            End Using

            If ds.Tables(0).Rows.Count > 0 Then
                For TaxCounts As Integer = 0 To ds.Tables(0).Rows.Count - 1

                    Dim crTaxAmount As Decimal
                    Dim sTaxTypeCode As String = String.Empty

                    ' get the tax type details
                    sTaxTypeCode = Cast.ToStringTrim(ds.Tables(0).Rows(TaxCounts).Item(1), String.Empty) 'Trim$(CStr(TaxAmountsByTaxType(TaxCounts, 1)))
                    crTaxAmount = Cast.ToDecimal(ds.Tables(0).Rows(TaxCounts).Item(2), 0) ' CDec(TaxAmountsByTaxType(TaxCounts, 2))

                    If crTaxAmount <> 0 And oClaimPayment.PostClaimTaxesSeperately Then
                        ' set tan / tag account code

                        sCreditAccountCode = "NOTA" & sTaxTypeCode & "IN"

                        AddClaimsStatsDetail(con:=Con,
                                                    lStatsFolderCnt:=statsFolderCnt,
                                                    lClaimId:=oClaimPayment.ClaimId,
                                                    lClaimPerilId:=oClaimPayment.ClaimPerilId,
                                                    sStatsDetailType:="TAG",
                                                    lClassOfBusinessId:=oClaimPayment.ClassOfBusinessID,
                                                    sClassOfBusinessCode:=oClaimPayment.ClassOfBusinessCode,
                                                    lRIPartyCnt:=oClaimPayment.PartyKey,
                                                    sRIShortname:=sCreditAccountCode,
                                                    lRIPartyType:=0,
                                                    dRISharePercent:=0,
                                                    crTransactionAmount:=crTaxAmount,
                                                    lDocumentTypeId:=DocumentTypeID)
                    End If
                Next
            End If
        Else
            Dim oSAMErrorCollection As New SAMErrorCollection
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.PostingOfPaymentToAccountsFailedMissingClassOfBusinessCode,
                SAMBusinessErrors.PostingOfPaymentToAccountsFailedMissingClassOfBusinessCode.ToString(),
                "SaveReceiptsToAccounts Failed - No Class Of Business Code Available")
            oSAMErrorCollection.CheckForErrors()
        End If
    End Sub

