    Public Function ValidateTaxItem(ByVal v_sTaxScriptName As String,
                            ByRef r_vUpdatedTaxArray As Object(,),
                            ByVal v_lTaxItem As Integer,
                             ByRef oSAMErrorCollection As SAMErrorCollection, ByVal SourceID As Integer, ByVal con As SiriusConnection, ByVal CurrencyCode As String, ByVal CurrencyID As Integer, ByVal LossCurrencyId As Integer) As Integer

        Dim m_vTaxGroupLookup As Object(,)
        Dim m_vTaxBandLookup As Object(,)
        Dim m_vCurrencyArray As Object(,)
        Dim m_vClassOfBusinessLookup As Object(,)
        Dim m_vTaxGroupTaxBandLookup(,) As Object
        Dim ds As DataSet = Nothing
        Dim icount As Integer
        Dim lReturn As Integer
        Dim taxGroupDescription As String = String.Empty
        Dim taxBandDescription As String = String.Empty
        Dim vTaxGroupId As Integer
        Dim vTaxBandId As Integer
        Dim vCurrencyCode As String = String.Empty
        Dim vTaxPercentage As Double
        Dim vTaxValue As Decimal
        Dim vIsValue As Byte
        Dim vClassOfBusinessId As Integer

        ' get details from array
        vTaxGroupId = Cast.ToInt32(r_vUpdatedTaxArray(kTaxArrayTaxGroupId, v_lTaxItem)).GetValueOrDefault(0) '.tostring
        vTaxBandId = Cast.ToInt32(r_vUpdatedTaxArray(kTaxArrayTaxBandId, v_lTaxItem), 0)
        vCurrencyCode = Cast.ToString(r_vUpdatedTaxArray(kTaxArrayTaxCurrencyCode, v_lTaxItem))
        vTaxPercentage = CDbl(r_vUpdatedTaxArray(kTaxArrayPercentage, v_lTaxItem))
        vTaxValue = CDec(r_vUpdatedTaxArray(kTaxArrayValue, v_lTaxItem))
        'Int32.TryParse(r_vUpdatedTaxArray(kTaxArrayClassOfBusinessId, v_lTaxItem).ToString(), vClassOfBusinessId)
        If String.IsNullOrEmpty(ToSafeString(r_vUpdatedTaxArray(kTaxArrayClassOfBusinessId, v_lTaxItem), "")) = False Then
            vClassOfBusinessId = Cast.ToInt32(r_vUpdatedTaxArray(kTaxArrayClassOfBusinessId, v_lTaxItem), 0)
        End If
        vIsValue = CByte(r_vUpdatedTaxArray(kTaxArrayIsValue, v_lTaxItem))

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Lookup_Values_By_Effective_Date")
            cmd.AddInParameter("@table", SqlDbType.VarChar).Value = "tax_band"
            ds = con.ExecuteDataSet(cmd, "rows")
            ReDim m_vTaxBandLookup(2, ds.Tables(0).Rows.Count - 1)
            For icount = 0 To ds.Tables(0).Rows.Count - 1
                m_vTaxBandLookup(0, icount) = Cast.ToInt32(ds.Tables(0).Rows(icount).Item("tax_band_id")).GetValueOrDefault(0)
                m_vTaxBandLookup(1, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("description"))
                m_vTaxBandLookup(2, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("code"))
            Next
        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Tax_Group_Details")
            ds = con.ExecuteDataSet(cmd, "rows")
            ReDim m_vTaxGroupLookup(4, ds.Tables(0).Rows.Count - 1)
            For icount = 0 To ds.Tables(0).Rows.Count - 1
                m_vTaxGroupLookup(0, icount) = Cast.ToInt32(ds.Tables(0).Rows(icount).Item("tax_group_id"), 0)
                m_vTaxGroupLookup(1, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("description"))
                m_vTaxGroupLookup(2, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("Code"))
                m_vTaxGroupLookup(3, icount) = CByte(ds.Tables(0).Rows(icount).Item("is_withholding_tax"))
                m_vTaxGroupLookup(4, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("advanced_tax_script"))
            Next
        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Lookup_Values_By_Effective_Date")
            cmd.AddInParameter("@table", SqlDbType.VarChar, 50).Value = "currency"
            ds = con.ExecuteDataSet(cmd, "rows")
            ReDim m_vCurrencyArray(2, ds.Tables(0).Rows.Count - 1)
            For icount = 0 To ds.Tables(0).Rows.Count - 1
                m_vCurrencyArray(0, icount) = CInt(ds.Tables(0).Rows(icount).Item("currency_id"))
                m_vCurrencyArray(1, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("description"))
                m_vCurrencyArray(2, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("code"))
            Next
        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Lookup_Values_By_Effective_Date")
            cmd.AddInParameter("@table", SqlDbType.VarChar, 50).Value = "class_of_business"
            ds = con.ExecuteDataSet(cmd, "rows")
            ReDim m_vClassOfBusinessLookup(2, ds.Tables(0).Rows.Count - 1)
            For icount = 0 To ds.Tables(0).Rows.Count - 1
                m_vClassOfBusinessLookup(0, icount) = Cast.ToInt32(ds.Tables(0).Rows(icount).Item("class_of_business_id"), 0)
                m_vClassOfBusinessLookup(1, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("description"))
                m_vClassOfBusinessLookup(2, icount) = Cast.ToString(ds.Tables(0).Rows(icount).Item("code"))
            Next
        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Tax_Group_Tax_Band_Select")
            ds = con.ExecuteDataSet(cmd, "rows")
            ReDim m_vTaxGroupTaxBandLookup(2, ds.Tables(0).Rows.Count - 1)
            For icount = 0 To ds.Tables(0).Rows.Count - 1
                m_vTaxGroupTaxBandLookup(0, icount) = Cast.ToInt32(ds.Tables(0).Rows(icount).Item("tax_group_id"), 0)
                m_vTaxGroupTaxBandLookup(1, icount) = Cast.ToInt32(ds.Tables(0).Rows(icount).Item("tax_band_id"), 0)
                m_vTaxGroupTaxBandLookup(2, icount) = CByte(ds.Tables(0).Rows(icount).Item("is_withholding_tax"))
            Next
        End Using

        '*******************
        ' VALIDATE VALUES
        '*******************

        '**********************
        '* VALIDATE TAX GROUP *
        '**********************
        lReturn = GetLookupItemFromArray(v_vArray:=m_vTaxGroupLookup,
                                         r_sItemDesc:=taxGroupDescription,
                                         r_sItemCode:="",
                                         r_lItemId:=vTaxGroupId)
        If lReturn <> PMEReturnCode.PMTrue Then

            oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure, "Invalid tax group specified. Tax Group Id " & vTaxGroupId & " could not be found.")
        Else
            r_vUpdatedTaxArray(kTaxArrayTaxGroupDescription, v_lTaxItem) = taxGroupDescription
        End If

        ''*********************
        ''* VALIDATE TAX BAND *
        ''*********************
        lReturn = GetLookupItemFromArray(v_vArray:=m_vTaxBandLookup,
                                 r_sItemDesc:=taxBandDescription,
                                 r_sItemCode:="",
                                 r_lItemId:=vTaxBandId)
        If lReturn <> PMEReturnCode.PMTrue Then

            oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure, "Invalid tax group specified. Tax Group Id " & vTaxGroupId & " could not be found.")

        Else
            r_vUpdatedTaxArray(kTaxArrayTaxBandDescription, v_lTaxItem) = (taxBandDescription)
        End If

        ''**********************************************
        ''* VALIDATE TAX GROUP / TAX BAND RELATIONSHIP *
        ''**********************************************
        Dim llbound As Integer
        Dim lUBound As Integer
        Dim lItem As Integer
        Dim kLookupTGTBDetailsTaxGroupId As Integer = 0
        Dim kLookupTGTBDetailsTaxBandId As Integer = 1
        Dim kLookupTGTBDetailsIsWithholdingTax As Integer = 2
        Dim lTaxGroupId As Integer
        Dim lTaxbandId As Integer
        Dim bIsWithHoldingTax As Byte
        Dim bvalid As Boolean

        ' for each item in the tax group tax band array

        ' get array boundaries
        llbound = LBound(m_vTaxGroupTaxBandLookup, 2)
        lUBound = UBound(m_vTaxGroupTaxBandLookup, 2)

        ' for each tax group tax band item
        For lItem = llbound To lUBound

            ' get the item details
            lTaxGroupId = Cast.ToInt32(m_vTaxGroupTaxBandLookup(kLookupTGTBDetailsTaxGroupId, lItem), 0)
            lTaxbandId = Cast.ToInt32(m_vTaxGroupTaxBandLookup(kLookupTGTBDetailsTaxBandId, lItem), 0)
            bIsWithHoldingTax = CByte(m_vTaxGroupTaxBandLookup(kLookupTGTBDetailsIsWithholdingTax, lItem))

            ' if the items matches the selected one
            If lTaxGroupId = vTaxGroupId And
                lTaxbandId = vTaxBandId Then

                bvalid = True
                Exit For
            End If
        Next

        ''**************************
        ''* VALIDATE CURRENCY CODE *
        ''**************************
        lReturn = GetLookupItemFromArray(v_vArray:=m_vCurrencyArray,
                                 r_sItemDesc:="",
                                 r_sItemCode:=CurrencyCode,
                                 r_lItemId:=CurrencyID)
        If lReturn <> PMEReturnCode.PMTrue Then
            If lReturn <> PMEReturnCode.PMNotFound Then
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure, "currency Code " & vTaxGroupId & " could not be found.")
            Else
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure, "Invalid tax group specified. Tax Group Id " & vTaxGroupId & " could not be found.")
            End If
        End If
        Dim crPaymentCurrencyTaxAmount As Decimal
        If CurrencyID <> LossCurrencyId Then
            CurrencyToCurrencyConversion(v_lCurrencyIdFrom:=CurrencyID,
                                         v_crCurrencyAmountFrom:=vTaxValue,
                                         v_lCompanyId:=SourceID,
                                         v_lCurrencyIdTo:=LossCurrencyId,
                                         r_crCurrencyAmountTo:=crPaymentCurrencyTaxAmount, con:=con)
            r_vUpdatedTaxArray(kTaxArrayTaxLossCuurencyAmount, v_lTaxItem) = crPaymentCurrencyTaxAmount
        End If

        ''*********************************
        ''* VALIDATE CLASS OF BUSINESS ID *
        ''*********************************
        '' if the class of business has been specified
        '' 0 will be treated as null
        If vClassOfBusinessId <> 0 Then

            ' verify that it is a valid class of business id
            lReturn = GetLookupItemFromArray(v_vArray:=m_vClassOfBusinessLookup,
                                    r_sItemDesc:="",
                                    r_sItemCode:="",
                                    r_lItemId:=vClassOfBusinessId)
            If lReturn <> PMEReturnCode.PMTrue Then
                If lReturn <> PMEReturnCode.PMNotFound Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure, "Class of business ID  " & vClassOfBusinessId & " could not be found.")
                Else
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure, "Invalid Class of business ID " & vClassOfBusinessId)
                End If

            End If
        End If

        ''***********************
        ''* VALIDATE PERCENTAGE *
        ''***********************

        If vTaxPercentage < 0 Or vTaxPercentage > 100 Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure, "Invalid tax Percentage specified." & vTaxPercentage & " Not in range of <0->100.")
        End If

    End Function

