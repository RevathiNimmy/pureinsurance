    ''' <param name="lVersion_id"></param>
    ''' <param name="lBaseClaimKey"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub ValidatePayeeMediaType(ByVal con As SiriusConnection, ByVal sMediaTypeCode As String,
                                            ByVal lVersion_id As Integer,
                                            ByVal lBaseClaimKey As Integer,
                                            ByRef oSAMErrorCollection As SAMErrorCollection)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_media_type_mendatory") ' New SP
            cmd.AddInParameter("@Base_claim_id", SqlDbType.Int).Value = lBaseClaimKey
            cmd.AddInParameter("@Version_id", SqlDbType.Int).Value = lVersion_id
            cmd.AddOutParameter("@media_type_mandatory", SqlDbType.Int)

            con.ExecuteNonQuery(cmd)

            If Convert.ToString(cmd.Parameters.Item("@media_type_mandatory").Value) = "1" Then
                If sMediaTypeCode = "" Then

                    oSAMErrorCollection.AddBusinessRule(
                                                SAMBusinessErrors.MediaTypeMandatory,
                                                SAMBusinessErrors.MediaTypeMandatory.ToString,
                                                "MediaTypeMandatory:" & lBaseClaimKey)
                End If

            End If
        End Using

    End Sub
    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="oClaimPayment"></param>
    ''' <remarks></remarks>
    Private Sub UpdateThisClaimPayment(ByVal Con As SiriusConnection,
                                   ByVal oClaimPayment As BaseClaimPaymentType)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_update_claim_this_payment_Details")

            If oClaimPayment.Payee IsNot Nothing Then
                cmd.AddInParameter("@nClaimID", SqlDbType.Int).Value = oClaimPayment.ClaimId
                cmd.AddInParameter("@nClaimPerilID", SqlDbType.Int).Value = oClaimPayment.ClaimPerilId
