    ''' </summary>
    ''' <param name="lBaseClaimId"></param>
    ''' <param name="lVersionId"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function getRiskId(ByVal con As SiriusConnection, ByVal lBaseClaimId As Integer,
                                    ByVal lVersionId As Integer) As Integer

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_risk_id") ' New SP
            cmd.AddInParameter("@Base_Claim_id", SqlDbType.Int).Value = lBaseClaimId
            cmd.AddInParameter("@Version_id", SqlDbType.Int).Value = lVersionId
            cmd.AddOutParameter("@Risk_id", SqlDbType.Int)
            con.ExecuteNonQuery(cmd)

            Return Cast.ToInt32(cmd.Parameters.Item("@risk_id").Value, 0)
        End Using

    End Function

    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="BaseClaimId"></param>
    ''' <param name="VersionId"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub ValidateIsDeferredRisk(ByVal con As SiriusConnection, ByVal BaseClaimId As Integer,
                                           ByVal VersionId As Integer,
                                           ByRef oSAMErrorCollection As SAMErrorCollection)
        Dim dsIsDeffered As DataSet = Nothing
        Dim lRisk_id As Integer
        lRisk_id = getRiskId(con, BaseClaimId, VersionId)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_risk_status_sel") ' New SP
            cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = lRisk_id
            dsIsDeffered = con.ExecuteDataSet(cmd, "IsDefferedReinsurance")
            If dsIsDeffered IsNot Nothing AndAlso dsIsDeffered.Tables(0).Rows.Count > 0 Then
            If dsIsDeffered.Tables(0).Rows(0).Item("Code").ToString = ksDeferredRIRiskStatus Then
                    oSAMErrorCollection.AddBusinessRule(
                                                SAMBusinessErrors.DefferedReinsurance,
                                                SAMBusinessErrors.DefferedReinsurance.ToString,
                                            "Deffered Reinsurance:" & lRisk_id)

            End If
            End If

        End Using

        ' use this sp to ret the boolean spu_CLM_risk_status_sel
    End Sub

    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="InsuredPercentage"></param>
    ''' <param name="PayeePercentage"></param>
    ''' <param name="oSamErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub ValidatePercentageFields(ByVal InsuredPercentage As Decimal,
                                        ByVal PayeePercentage As Decimal,
                                        ByRef oSamErrorCollection As SAMErrorCollection)

        If InsuredPercentage < 0 Or InsuredPercentage > 100 Then
            oSamErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure,
                                                    "Insured Percentage Invalid",
                                                    "Insured Percentage",
                                                    CStr(InsuredPercentage))

        End If
        If PayeePercentage < 0 Or PayeePercentage > 100 Then
            oSamErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure,
                                                    "Payee Percentage Invalid",
                                                    "Payee Percentage",
                                                    CStr(PayeePercentage))

        End If

    End Sub

