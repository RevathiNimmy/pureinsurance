    ''' <summary>
    ''' accounts processing 
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="lTransactionExportFolderCnt"></param>
    ''' <param name="lDocumentId"></param>
    ''' <remarks></remarks>
    Private Sub SendToOrion(ByVal con As SiriusConnection, _
                            ByVal lTransactionExportFolderCnt As Integer, _
                            ByRef lDocumentId As Integer, _
                            ByVal CurrencyID As Integer)

        ' update the 
        UpdateExportStatus(con, "f", lTransactionExportFolderCnt)

        Dim oTransactionBusiness As bPMBTransactions.Automated = Nothing

        Try
            Dim lReturn As Integer

            ' instantiate the business object
            oTransactionBusiness = New bPMBTransactions.Automated

            Dim oDatabaseObject As Object = con.PMDAODatabase

            ' initialise the object
            lReturn = CInt(oTransactionBusiness.Initialise( _
                                   _SiriusUser.Username, _
                                   _SiriusUser.Password, _
                                   _SiriusUser.UserID, _
                                   _SiriusUser.SourceID, _
                                   _SiriusUser.LanguageID, _
                                   CurrencyID, _
                                   1, _
                                   SiriusUserDefaults.AppName, _
                                   False, oDatabaseObject))

            If (lReturn <> PMEReturnCode.PMTrue) Then
                ' if the account processing fails then throw a business rule error
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bPMBTransactions.Initialise")
                oSAMErrorCollection.CheckForErrors()
            End If

            ' set the process modes
            lReturn = oTransactionBusiness.SetProcessModes(0, 0, 0, 0, Date.Today)

            If (lReturn <> PMEReturnCode.PMTrue) Then
                ' if the account processing fails then throw a business rule error
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bPMBTransactions.SetProcessModes")
                oSAMErrorCollection.CheckForErrors()
            End If

            ' run the accounts process
            lReturn = oTransactionBusiness.SendToOrion(v_lTransactionFolderCnt:=lTransactionExportFolderCnt,
                                                       r_lDocumentId:=lDocumentId)

            If (lReturn <> PMEReturnCode.PMTrue) Then
                ' if the account processing fails then throw a business rule error
                Dim oSAMErrorCollection As New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.AccountsProcessingFailed,
                                                    SAMBusinessErrors.AccountsProcessingFailed.ToString,
                                                    "bPMBTransactions.SendToOrion")
                oSAMErrorCollection.CheckForErrors()
            Else
                UpdateExportStatus(con, "c", lTransactionExportFolderCnt)
            End If

        Finally
            If oTransactionBusiness IsNot Nothing Then
                oTransactionBusiness.Dispose()
                oTransactionBusiness = Nothing
            End If
        End Try

    End Sub

