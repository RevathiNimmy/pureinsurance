    ''' <summary>
    ''' Validate claim client contact details
    ''' </summary>
    ''' <param name="oContact"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <param name=""></param>
    ''' <remarks></remarks>
    Private Sub CoreValidateClientContactTypes(
    ByVal oContacts() As BaseContactType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        '***************************************
        ''' Validate claim client contact details
        '***************************************

        Dim oContact As BaseContactType

        If oContacts IsNot Nothing Then

            For Each oContact In oContacts
                ''' only client contact types of type (EMAIL/HOMEPHONE/MOBILE/MAIN/FAX/OTHER) are valid
                If oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.EMAIL And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.HOMEPHONE And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.MOBILE And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.MAIN And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.FAX And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.WEB And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.TELEPHONE And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.MAINEMAILCONTACT And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.LETTER And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.OTHER Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                         "Invalid Client Contact Specified " & ":" & oContact.ContactTypeCode,
                            "Client.ContactType",
                                oContact.ContactTypeCode.ToString)
                End If
            Next
        End If
    End Sub

    Private Sub CoreValidateInsurerContactTypes(
    ByVal oContacts() As BaseContactType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        If oContacts IsNot Nothing Then

            Dim oContact As BaseContactType

            For Each oContact In oContacts
                ''' only insurer contact types of type (EMAIL/MAIN/FAX/OTHER) are valid
                If oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.EMAIL And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.MAIN And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.FAX And
                     oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.HOMEPHONE And
                     oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.MOBILE And
                     oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.WEB And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.TELEPHONE And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.MAINEMAILCONTACT And
                    oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.LETTER And
                     oContact.ContactTypeCode <> BaseImplementationTypes.ContactTypeType.OTHER Then
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                          "Invalid Insurer Contact Specified " & ":" & oContact.ContactTypeCode,
                            "Insurer.ContactType",
                                oContact.ContactTypeCode.ToString())
                End If
            Next
        End If

    End Sub

    ''' <summary>
    ''' validate various other data 
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub OpenClaimValidateDataOther(
                ByVal oBusiness As CoreBusiness,
                ByRef oRequest As BaseClaimOpenRequestType,
                ByRef oSAMErrorCollection As SAMErrorCollection)

        'Dim oContact As BaseContactType

        '***************************************
        ''' Validate Core Claim Data Links
        '***************************************
        ''' The insurance file key and risk key should be linked appropriately,
        ''' likewise the primary_cause_id and secondary_cause_id should be 
        ''' linked appropriately to the specified risk

        CoreClaimValidateDataLinks(oRequest.Claim.InsuranceFileKey,
                                   oRequest.Claim.RiskKey,
                                   oRequest.Claim.PrimaryCauseId,
                                   oRequest.Claim.SecondaryCauseId, oSAMErrorCollection)

        '***************************************
        ''' Validate Claim Peril Types
        '***************************************
        CoreValidateClaimPerilDetails(oRequest.Claim.RiskKey,
                                    oRequest.Claim.ClaimPeril, oSAMErrorCollection)

        '***************************************
        ''' Validate claim client contact details
        '***************************************        
        If oRequest.Claim.Client IsNot Nothing Then
