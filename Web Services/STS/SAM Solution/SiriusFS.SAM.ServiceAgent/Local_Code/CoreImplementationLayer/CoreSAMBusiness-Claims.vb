    Private Sub CreateEvent(ByVal con As SiriusConnection,
                            ByVal lPartyCnt As Integer,
                            ByVal lInsuranceFolderCnt As Nullable(Of Integer),
                            ByVal lInsuranceFileCnt As Nullable(Of Integer),
                            ByVal lClaimId As Nullable(Of Integer),
                            ByVal lDocumentCnt As Nullable(Of Integer),
                            ByVal lOldAddressCnt As Nullable(Of Integer),
                            ByVal lNewAddressCnt As Nullable(Of Integer),
                            ByVal lCampaignId As Nullable(Of Integer),
                            ByVal lDocumentTypeId As Nullable(Of Integer),
                            ByVal lReportTypeId As Nullable(Of Integer),
                            ByVal lEventTypeID As Nullable(Of Integer),
                            ByVal lUserId As Integer,
                            ByVal dtEventDate As DateTime,
                            ByVal sDescription As String,
                            ByVal lOldPartyTypeID As Nullable(Of Integer),
                            ByVal lEventTypeSubjectId As Nullable(Of Integer),
                            ByVal sEventTypeCode As String,
                            ByVal lAccountKey As Nullable(Of Integer),
                            ByVal lFSAComplaintFolderCnt As Nullable(Of Integer),
                            ByVal sShortDescription As String,
                            ByVal sPriorityCode As String,
                            ByVal lIsCompleted As Nullable(Of Integer),
                            ByVal lPerilId As Nullable(Of Integer),
                            ByRef lEventCnt As Integer,
                            Optional ByVal iBGKey As Integer = 0,
                            Optional ByVal IsManualDescription As Boolean = False,
                            Optional ByVal iCaseKey As Integer = 0)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spe_event_log_add")

            cmd.AddOutParameter("@event_cnt", SqlDbType.Int)

            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = lPartyCnt
            If Cast.ToInt32(lInsuranceFolderCnt, 0) > 0 Then
                cmd.AddInParameter("@insurance_folder_cnt", SqlDbType.Int).Value = lInsuranceFolderCnt
            End If
            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = lInsuranceFileCnt
            cmd.AddInParameter("@claim_cnt", SqlDbType.Int).Value = lClaimId
            cmd.AddInParameter("@document_cnt", SqlDbType.Int).Value = lDocumentCnt
            cmd.AddInParameter("@old_address_cnt", SqlDbType.Int).Value = lOldAddressCnt
            cmd.AddInParameter("@new_address_cnt", SqlDbType.Int).Value = lNewAddressCnt
            cmd.AddInParameter("@campaign_id", SqlDbType.Int).Value = lCampaignId
            cmd.AddInParameter("@document_type_id", SqlDbType.Int).Value = lDocumentTypeId
            cmd.AddInParameter("@report_type_id", SqlDbType.Int).Value = lReportTypeId
            cmd.AddInParameter("@event_type_id", SqlDbType.Int).Value = lEventTypeID
            cmd.AddInParameter("@user_id", SqlDbType.Int).Value = lUserId
            cmd.AddInParameter("@event_date", SqlDbType.DateTime).Value = dtEventDate
            cmd.AddInParameter("@description", SqlDbType.VarChar, 1000).Value = Cast.NullIfDefault(sDescription)
            cmd.AddInParameter("@old_party_type_id", SqlDbType.Int).Value = lOldPartyTypeID
            cmd.AddInParameter("@event_log_subject_id", SqlDbType.Int).Value = lEventTypeSubjectId
            cmd.AddInParameter("@event_type_code", SqlDbType.VarChar, 10).Value = Cast.NullIfDefault(sEventTypeCode)
            cmd.AddInParameter("@account_key", SqlDbType.Int).Value = lAccountKey
            cmd.AddInParameter("@fsa_complaint_folder_cnt", SqlDbType.Int).Value = lFSAComplaintFolderCnt
            cmd.AddInParameter("@short_description", SqlDbType.VarChar, 70).Value = Cast.NullIfDefault(sShortDescription)
            cmd.AddInParameter("@priority_code", SqlDbType.VarChar, 10).Value = Cast.NullIfDefault(sPriorityCode)
            cmd.AddInParameter("@is_completed", SqlDbType.Int).Value = lIsCompleted
            cmd.AddInParameter("@peril_id", SqlDbType.Int).Value = lPerilId
            If IsManualDescription = True Then
                cmd.AddInParameter("@is_manual_description", SqlDbType.TinyInt).Value = 1
            End If
            If (iBGKey > 0) Then
                cmd.AddInParameter("@bg_id", SqlDbType.Int).Value = iBGKey
            End If
            If (iCaseKey > 0) Then
                cmd.AddInParameter("@case_id", SqlDbType.Int).Value = iCaseKey
            End If
            con.ExecuteNonQuery(cmd)

            lEventCnt = Cast.ToInt32(cmd.Parameters("@event_cnt").Value, 0)

        End Using

    End Sub

