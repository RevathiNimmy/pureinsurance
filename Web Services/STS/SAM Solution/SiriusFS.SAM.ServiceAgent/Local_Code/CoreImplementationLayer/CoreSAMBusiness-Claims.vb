    ''' <summary>
    ''' CheckReserveRecovery
    ''' </summary>
    ''' <param name="oRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function CheckReserveRecovery(ByVal oRequest As SAMForInsuranceV2ImplementationTypes.CheckReserveRecoveryRequestType) As SAMForInsuranceV2ImplementationTypes.CheckReserveRecoveryResponseType
        Dim oResponse As New SAMForInsuranceV2ImplementationTypes.CheckReserveRecoveryResponseType

        Const kClaimStatusId As Integer = 0
        Const kCurrentReserve As Integer = 1
        Const kCurrentRecovery As Integer = 2

        Dim lClaimStatus As Integer = 0
        Dim crCurrentReserve As Decimal
        Dim crCurrentRecovery As Decimal
        Dim dt As New DataTable

        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_GetCurrentReserveRecovery_SFU")
                cmd.AddInParameter("@ClaimID", SqlDbType.Int).Value = oRequest.ClaimKey
                con.ExecuteDataTable(cmd, dt)
            End Using
        End Using

        If dt IsNot Nothing AndAlso dt.Rows IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            Dim dr As DataRow
            For Each dr In dt.Rows
                lClaimStatus = Cast.ToInt32(dr.Item(kClaimStatusId), 0)
                crCurrentReserve = Decimal.Round(Cast.ToDecimal(dr.Item(kCurrentReserve), 0), 2)
                crCurrentRecovery = Decimal.Round(Cast.ToDecimal(dr.Item(kCurrentRecovery), 0), 2)

                oResponse.CurrentReserve = crCurrentReserve
                oResponse.CurrentRecovery = crCurrentRecovery
                oResponse.ClaimStatus = lClaimStatus

            Next
        End If

        Return oResponse
    End Function
