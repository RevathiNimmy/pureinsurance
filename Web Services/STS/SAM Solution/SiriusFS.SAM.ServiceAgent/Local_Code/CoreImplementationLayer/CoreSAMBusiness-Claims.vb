    ''' <summary>
    ''' To settle single claim payment
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oRequest"></param>
    ''' <param name="oCoreBusiness"></param>
    ''' <param name="bNoPaymentsAuthority"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Public Overloads Sub SettleSingleClaimPayment(ByVal con As SiriusConnection, ByVal oRequest As BaseSettleClaimPaymentType, ByVal oCoreBusiness As CoreBusiness, ByVal bNoPaymentsAuthority As Boolean, ByRef oSAMErrorCollection As SAMErrorCollection)

        Dim oCashlist As BaseImplementationTypes.BasePaymentCashListType
        oCashlist = New BaseImplementationTypes.BasePaymentCashListType
        'add cash list
        oCashlist.BranchCode = oRequest.ClaimPaymentBranchCode
        oCashlist.SourceID = oRequest.ClaimPaymentBranchKey
        oCashlist.BankAccountCode = oRequest.BankAccountCode
        oCashlist.CurrencyCode = oRequest.CurrencyCode
        oCashlist.ListDate = DateTime.Now
        oCashlist.Reference = "CLP "
        oCashlist.StatusCode = "E"
        oCashlist.TypeCode = "CP"
        'add cashlist item
        ReDim Preserve oCashlist.PaymentItem(0)
        oCashlist.PaymentItem(0) = New BaseImplementationTypes.BasePaymentCashListItemType
        With oCashlist.PaymentItem(0)
            .AccountShortCode = oRequest.AccountCode
            .AllocationStatusCode = ""
            .Amount = oRequest.ClaimPaymentAmount
            .MediaTypeCode = oRequest.MediaTypeCode
            .TransactionDate = DateTime.Now
            .TypeCode = "CLP"
        End With
        'Process cashlist item
        ProcessClaimPaymentCashListItem(con, oCashlist.PaymentItem(0), oRequest.AccountKey, oRequest.DocumentKey)
        'process cash list
        ProcessCashList(con, oCoreBusiness, DirectCast(oCashlist, BaseCoreCashListType), oSAMErrorCollection, False, True, oRequest.ClaimPaymentKey, bNoPaymentsAuthority, True)
        'check if no authority to pay
        If bNoPaymentsAuthority Then
            'add cashlist item link with claim
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CashListItem_claim_link_add")
                cmd.AddInParameter("@claim_payment_id", SqlDbType.Int).Value = oRequest.ClaimPaymentKey
                cmd.AddInParameter("@cashlistitem_id", SqlDbType.Int).Value = oCashlist.PaymentItem(0).CashListItemKey
                cmd.AddInParameter("@claim_receipt_id", SqlDbType.Int).Value = DBNull.Value
                con.ExecuteNonQuery(cmd)
            End Using
            'update the status of transaction
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_upd_CLI_PaymentStatus_Pending")
                cmd.AddInParameter("@cashlistitem_id", SqlDbType.Int).Value = oCashlist.PaymentItem(0).CashListItemKey
                con.ExecuteNonQuery(cmd)
            End Using
        End If
    End Sub

    ''' <summary>
    ''' to save summary return by settle claim payment function
    ''' </summary>
    ''' <param name="oResponse"></param>
    ''' <param name="sMediaTypeCode"></param>
    ''' <param name="dPaymentAmount"></param>
    ''' <param name="sStatusOfTransaction"></param>
    ''' <remarks></remarks>
    Private Sub SaveSummary(ByRef oResponse As BaseSettleAllClaimPaymentsResponseType, ByVal sMediaTypeCode As String, ByVal dPaymentAmount As Decimal, ByVal sStatusOfTransaction As String)

        If oResponse.Summary Is Nothing Then
            oResponse.Summary = New System.Collections.Generic.List(Of BaseSettleAllClaimPaymentSummaryResponseType)
            Dim oSummaryItem As New BaseSettleAllClaimPaymentSummaryResponseType
            oSummaryItem.Amount = dPaymentAmount
            oSummaryItem.MediaTypeCode = sMediaTypeCode
            oSummaryItem.NoOfTransactions = 1
            oSummaryItem.StatusOfTransaction = sStatusOfTransaction
            oResponse.Summary.Add(oSummaryItem)
        Else
            Dim bFound As Boolean
            For Each oRow As BaseSettleAllClaimPaymentSummaryResponseType In oResponse.Summary
                If sMediaTypeCode = oRow.MediaTypeCode AndAlso sStatusOfTransaction = oRow.StatusOfTransaction Then
                    oRow.Amount = oRow.Amount + dPaymentAmount
                    oRow.NoOfTransactions = oRow.NoOfTransactions + 1
                    bFound = True
                    Exit For
                End If
            Next
            If bFound = False Then
                Dim oSummaryItem As New BaseSettleAllClaimPaymentSummaryResponseType
                oSummaryItem.Amount = dPaymentAmount
                oSummaryItem.MediaTypeCode = sMediaTypeCode
                oSummaryItem.NoOfTransactions = 1
                oSummaryItem.StatusOfTransaction = sStatusOfTransaction
                oResponse.Summary.Add(oSummaryItem)
            End If
        End If
    End Sub
    Private Function SkipMaintainClaim(ByRef oRequest As BaseImplementationTypes.BaseClaimProcessRequestType) As Boolean
        Dim bSkipMaintainClaim As Boolean = False
        Dim bIsReserveAmountPresent As Boolean = False
        Dim bIsPaymentAmountPresent As Boolean = False
        Dim TmpPaymentAmount As Decimal
        Dim TmpReserveAmount As Decimal
        Try

            If Not oRequest.Claim.ClaimPeril Is Nothing Then
                For Each inPeril As BaseImplementationTypes.BaseClaimProcessPerilType In oRequest.Claim.ClaimPeril

                    If Not inPeril.Reserve Is Nothing Then
                        For Each inReserve As BaseImplementationTypes.BaseClaimProcessPerilReserveType In inPeril.Reserve
                            TmpPaymentAmount = 0
                            TmpReserveAmount = 0
                            'The amount passed in is the full amount.  Work out the revision amount
                            Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
                                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_CLM_Get_Reserve_Revised_Amount")
                                    cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
                                    cmd.AddInParameter("@peril_type_code", SqlDbType.VarChar, 30).Value = inPeril.TypeCode
                                    cmd.AddInParameter("@reserve_type_code", SqlDbType.VarChar, 30).Value = inReserve.TypeCode

                                    Dim dtReserve As DataTable = con.ExecuteDataTable(cmd)
                                    If dtReserve IsNot Nothing AndAlso dtReserve.Rows.Count = 1 Then
                                        If inReserve.IsPaidToDate Then
                                            If oRequest.Claim.CurrencyCode <> inReserve.PaymentDetails.PaymentCurrencyCode Then
                                                Dim dAmount As Decimal = 0, dRate As Decimal = 0
                                                GetCurrencyToCurrencyExchangeRate(con, Date.Now, oRequest.Claim.CurrencyCode, inReserve.PaymentDetails.PaymentCurrencyCode, 1, dRate)
                                                dAmount = Cast.ToDecimal(dtReserve.Rows(0).Item("paid_to_date"), 0D) * dRate
                                                TmpPaymentAmount = inReserve.PaymentAmount - dAmount 'Cast.ToDecimal(dtReserve.Rows(0).Item("paid_to_date"), 0D)
                                            Else
                                                TmpPaymentAmount = inReserve.PaymentAmount - Cast.ToDecimal(dtReserve.Rows(0).Item("paid_to_date"), 0D)
                                            End If
                                        Else
                                            TmpPaymentAmount = inReserve.PaymentAmount
                                        End If

                                        If inReserve.IsReserveToDate Then
                                            TmpReserveAmount = inReserve.Amount - Cast.ToDecimal(dtReserve.Rows(0).Item("Revised_reserve"), 0D) + TmpPaymentAmount
                                        Else
                                            TmpReserveAmount = inReserve.Amount
                                        End If

                                    End If

                                End Using
                            End Using

                            If Convert.ToDecimal(TmpReserveAmount) <> 0 Then
                                bIsReserveAmountPresent = True
                            End If
                            If TmpPaymentAmount <> 0 Then
                                oRequest.IsPaymentRequired = True
                                bIsPaymentAmountPresent = True
                            End If
                        Next
                    End If
                Next
            End If
            If bIsReserveAmountPresent Then
                bSkipMaintainClaim = False
            ElseIf Not bIsPaymentAmountPresent Then
                bSkipMaintainClaim = False
            Else
                bSkipMaintainClaim = True
            End If
            Return bSkipMaintainClaim
        Catch

        End Try
        Return bSkipMaintainClaim
    End Function

