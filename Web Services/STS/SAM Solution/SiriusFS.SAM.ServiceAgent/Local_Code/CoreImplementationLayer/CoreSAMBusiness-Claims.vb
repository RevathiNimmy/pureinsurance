    ''' <summary>
    ''' returns the user defined tables id for the user defined claims fields from system options
    ''' </summary>
    ''' <param name="oRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    ''' 
    Private Sub GetClaimUserDefinedTables(
                        ByRef oRequest As BaseClaimType)

        Dim ds As DataSet = Nothing

        '***********************************************************
        ' get the system options for the claim user defined lookups
        '***********************************************************

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Claim_User_Defined_Tables")
                cmd.AddInParameter("@Source_Id", SqlDbType.Int).Value = oRequest.SourceId
                Try
                    Dim dr As DataRow

                    ds = con.ExecuteDataSet(cmd, "SystemOptions")

                    If ds.Tables.Count = 1 Then
                        For Each dr In ds.Tables("SystemOptions").Rows
                            Select Case CType(dr.Item("option_number"), Integer)
                                Case 2003
                                    oRequest.UserDefFldATableCode = dr.Item("code").ToString
                                Case 2004
                                    oRequest.UserDefFldBTableCode = dr.Item("code").ToString
                                Case 2005
                                    oRequest.UserDefFldCTableCode = dr.Item("code").ToString
                                Case 2006
                                    oRequest.UserDefFldDTableCode = dr.Item("code").ToString
                                Case 2007
                                    oRequest.UserDefFldETableCode = dr.Item("code").ToString
                            End Select
                        Next
                    End If

                Catch ex As Exception
                    ds = Nothing
                End Try
            End Using
        End Using

    End Sub

    ''' <summary>
    ''' validate the core claim data links
    ''' </summary>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Sub CoreClaimValidateDataLinks(
                        ByVal lInsuranceFileCnt As Integer,
                        ByVal lRiskCnt As Integer,
                        ByVal lPrimaryCauseId As Integer,
                        ByVal lSecondaryCauseId As Integer,
                        ByVal oSAMErrorCollection As SAMErrorCollection,
                        Optional ByVal iExpectedResult As Integer = 0)

        Dim iValidationStatus As Integer

        ''' validate the core claim links
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Validate_Core_Claim_Data_Links")

                cmd.AddInParameter("@Insurance_File_Cnt", SqlDbType.Int).Value = lInsuranceFileCnt
                cmd.AddInParameter("@Risk_cnt", SqlDbType.Int).Value = lRiskCnt
                cmd.AddInParameter("@Primary_Cause_Id", SqlDbType.Int).Value = lPrimaryCauseId
                cmd.AddInParameter("@Secondary_Cause_Id", SqlDbType.Int).Value = Cast.NullIfDefault(lSecondaryCauseId)
                cmd.AddOutParameter("@Status", SqlDbType.Int)

                Try
                    con.ExecuteNonQuery(cmd)

                    iValidationStatus = CType(cmd.Parameters.Item("@Status").Value, Integer)

                Catch ex As Exception
                 
                End Try
            End Using
        End Using

        ' if the expected result matches the one we expected 
        ' then return without any error
        If iExpectedResult <> 0 AndAlso ((iExpectedResult And iValidationStatus) > 0) Then
            Return
        End If

        '1 = Insurance File / Risk Cnt Link Valid
        '2 = Primary_cause / Risk Cnt Link Valid
        '4 = Primary_cause / Secondary_Cause Link Valid
        '7 = ALL LINKS VALID

        ' if there were validation errors
        If iValidationStatus <> 7 Then

            ''' validate the risk key and insurance file key link
            If Not CBool(iValidationStatus And 1) Then
                Dim strMsg As String = "Risk Key:" & lRiskCnt & " - Insurance File Key:" & lInsuranceFileCnt
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed, "Risk Key - Insurance File Key link is invalid", strMsg, strMsg)
            End If

            ''' validate the primary cause id and risk key link
            If Not CBool(iValidationStatus And 2) Then
                Dim strMsg As String = "Primary Cause Id:" & lPrimaryCauseId & ": Risk Key:" & lRiskCnt
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed, "Primary Cause - Risk Key link is invalid", strMsg, strMsg)
            End If

            ''' validate the secondary cause id and primary cause id link 
            If Not CBool(iValidationStatus And 4) Then
                Dim strMsg As String = "Secondary Cause Id:" & lSecondaryCauseId & ": Primary Cause Id:" & lPrimaryCauseId
                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ValidationRulesFailed, "Secondary Cause - Primary Cause link is invalid", strMsg, strMsg)
            End If

        End If

    End Sub

    ''' <summary>
    ''' validates claim peril level details
    ''' </summary>
    ''' <remarks></remarks>
    Private Sub CoreValidateClaimPerilDetails(
                        ByVal lRiskCnt As Integer,
                        ByVal ClaimPerils() As BaseClaimPerilType,
                        ByVal oSAMErrorCollection As SAMErrorCollection)

        Dim ds As DataSet = New DataSet
        Dim dsRecoveryDetails As DataSet = New DataSet
        ' if claim perils have been specified
        If ClaimPerils IsNot Nothing Then

            '***************************************
            ''' Validate Claim Peril Types
            '***************************************

            Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

                ' get the valid claim peril types for the specified risk
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Valid_Claim_Peril_Types")

                    cmd.AddInParameter("@Risk_cnt", SqlDbType.Int).Value = lRiskCnt

                    Try
                        Dim dt As DataTable = con.ExecuteDataTable(cmd)
                        dt.TableName = "Claim_Peril_Type_Reserve_Type"
                        ds.Tables.Add(dt)
                    Catch ex As Exception

                        ExceptionPolicy.HandleException(ex, "Business Layer")

                    End Try

                End Using

                ' get the valid recovery_types (all those not deleted)
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Valid_Claim_Recovery_Types")

                    Try
                        Dim dt As DataTable = con.ExecuteDataTable(cmd)
                        dt.TableName = "Recovery_Types"
                        ds.Tables.Add(dt)
                    Catch ex As Exception
                        ExceptionPolicy.HandleException(ex, "Business Layer")

                    End Try

                End Using

            End Using

            Dim oClaimPeril As BaseClaimPerilType
            Dim bValidPerilType As Boolean

            ' validate each claim peril is a valid type for the specified risk
            For Each oClaimPeril In ClaimPerils

                Dim dr As DataRow

                ' assume peril type is invalid
                bValidPerilType = False

                ' for each claim peril reserve type
                For Each dr In ds.Tables.Item("Claim_Peril_Type_Reserve_Type").Rows

                    ' if the peril type matches 
                    If Strings.Trim(dr.Item("peril_type_code").ToString) = oClaimPeril.TypeCode.Trim Then

                        ' indicate that we have found the record so it is actually valid
                        bValidPerilType = True

                        Exit For
                    End If

                Next

                ' if the peril type is invalid then raise an error
                If Not bValidPerilType Then

                    ' add an item to the error collection to indicate this
                    oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                            SAMInvalidData.InvalidLookupListValue.ToString,
                                            "PerilTypeCode",
                                            oClaimPeril.TypeCode)
                End If

            Next

            For Each oClaimPeril In ClaimPerils
                Dim oRecovery As BaseClaimPerilRecoveryType
                Dim oReserve As BaseClaimPerilReserveType

                ' if recoveries have been specified 
                If IsArray(oClaimPeril.Recovery) Then

                    Dim bValidRecovery As Boolean

                    ' for each specified recovery 
                    For Each oRecovery In oClaimPeril.Recovery

                        Dim dr As DataRow

                        ' invalid recovery
                        bValidRecovery = False

                        ' for each valid recovery type
                        For Each dr In ds.Tables("Recovery_Types").Rows

                            ' if the recovery type matches the current item
                            If Strings.Trim(dr.Item("code").ToString) = oRecovery.TypeCode.Trim Then

                                ' its a valid recovery
                                bValidRecovery = True

                                Exit For

                            End If

                        Next

                        ' if the recovery is not valid
                        If bValidRecovery = False Then
                            ' add an item to the error collection to indicate this
                            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                                    SAMInvalidData.InvalidLookupListValue.ToString,
                                                    "RecoveryTypeCode",
                                                    oRecovery.TypeCode)
                        End If
                        If oRecovery.IsDeletedRecovery And oRecovery.BaseRecoveryKey <> 0 Then
                            Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

                                ' get the valid claim peril types for the specified risk
                                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Recovery_Details")

                                    cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = 0
                                    cmd.AddInParameter("@base_recovery_id", SqlDbType.Int).Value = oRecovery.BaseRecoveryKey
                                    dsRecoveryDetails = con.ExecuteDataSet(cmd, "RecoveryDetails")
                                    Try
                                        If Cast.ToDecimal(dsRecoveryDetails.Tables(0).Rows(0).Item("received_to_date"), 0) <> 0 Then
                                            If Cast.ToInt32(dsRecoveryDetails.Tables(0).Rows(0).Item("is_salvage"), 0) = 1 Then
                                                oSAMErrorCollection.AddFatal("Salvage Recovery Reserves cannont be deleted once Receipt has been Rasied against it")
                                            Else
                                                oSAMErrorCollection.AddFatal("Third Party Recovery Reserves cannont be deleted once Receipt has been Rasied against it")
                                            End If
                                        End If
                                    Catch ex As Exception
                                        ExceptionPolicy.HandleException(ex, "Business Layer")
                                    End Try

                                End Using
                            End Using

                        End If
                    Next

                End If

                '  if there are reserve entries 
                If IsArray(oClaimPeril.Reserve) Then

                    ' for each reserve 
                    For Each oReserve In oClaimPeril.Reserve

                        Dim dr As DataRow

                        Dim bValidReserve As Boolean

                        ' for each claim peril reserve type
                        For Each dr In ds.Tables.Item("Claim_Peril_Type_Reserve_Type").Rows

                            bValidReserve = False

                            ' if the peril type matches 
                            If Strings.Trim(dr.Item("peril_type_code").ToString) = oClaimPeril.TypeCode Then

                                ' if the reserve type matches the current one
                                If Strings.Trim(dr.Item("reserve_type_code").ToString) = oReserve.TypeCode.Trim Then

                                    ' indicate that we have found the record so its valid
                                    bValidReserve = True

                                    Exit For
                                End If

                            End If

                        Next

                        ' if this is not a valid reserve then
                        If bValidReserve = False Then
                            ' add an item to the error collection to indicate this
                            oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                        SAMInvalidData.InvalidLookupListValue.ToString,
                                        "ReserveTypeCode",
                                        oReserve.TypeCode)
                        End If

                    Next

                End If

            Next

        End If

    End Sub

    ''' <summary>
    ''' validates the standard lookup data 
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub CoreClaimValidateDataStandardLookup(
                ByVal oBusiness As CoreBusiness,
                ByVal oRequest As BaseClaimType,
                ByVal oSAMErrorCollection As SAMErrorCollection,
                ByVal sBranchCode As String)

        '*********************
        'mandatory
        '*********************

        ' branch code
        oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, sBranchCode, "BranchCode", oSAMErrorCollection)

        ' progress status
        oRequest.ProgressStatusId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.ProgressStatus, oRequest.ProgressStatusCode, "ProgressStatusCode", oSAMErrorCollection)

        ' handler
        oRequest.HandlerId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Handler, oRequest.HandlerCode, "HandlerCode", oSAMErrorCollection)

        ' primary cause
        oRequest.PrimaryCauseId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.PrimaryCause, oRequest.PrimaryCauseCode, "PrimaryCauseCode", oSAMErrorCollection)

        '*********************
        ' optional
        '*********************

        ' catastrophe code
        If Not String.IsNullOrEmpty(oRequest.CatastropheCode) Then
            oRequest.CatastropheId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.CatastropheCode, oRequest.CatastropheCode, "CatastropheCode", oSAMErrorCollection)
        Else
            oRequest.CatastropheId = Nothing
        End If

        ' town 
        If Not String.IsNullOrEmpty(oRequest.TownCode) Then
            oRequest.TownId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Town, oRequest.TownCode, "TownCode", oSAMErrorCollection)
        Else
            oRequest.TownId = Nothing
        End If

        ' secondary cause
        If String.IsNullOrEmpty(oRequest.SecondaryCauseCode) = False Then
            oRequest.SecondaryCauseId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.SecondaryCause, oRequest.SecondaryCauseCode, "SecondaryCauseCode", oSAMErrorCollection)
        Else
            oRequest.SecondaryCauseId = Nothing
        End If

        ' client address 
        If oRequest.Client IsNot Nothing _
            AndAlso oRequest.Client.Address IsNot Nothing _
            AndAlso String.IsNullOrEmpty(oRequest.Client.Address.CountryCode) = False Then
            oRequest.Client.Address.CountryId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Country, oRequest.Client.Address.CountryCode, "ClientCountryCode", oSAMErrorCollection)
        End If

        ' insurer address 
        If oRequest.Insurer IsNot Nothing _
            AndAlso oRequest.Insurer.Address IsNot Nothing _
            AndAlso String.IsNullOrEmpty(oRequest.Insurer.Address.CountryCode) = False Then
            oRequest.Insurer.Address.CountryId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Country, oRequest.Insurer.Address.CountryCode, "InsurerCountryCode", oSAMErrorCollection)
        End If

    End Sub

