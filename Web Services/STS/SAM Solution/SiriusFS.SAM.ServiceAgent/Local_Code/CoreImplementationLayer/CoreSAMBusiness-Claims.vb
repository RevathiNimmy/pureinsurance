    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="PayClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub PayClaimValidateBusinessRules(ByVal con As SiriusConnection, ByVal oClaimPayment As BaseClaimPaymentType,
                                              ByVal ClaimDetails As BaseAdditionalClaimRelatedDetails,
                                              ByVal oSAMErrorCollection As SAMErrorCollection)

        ' validates that the payment party and the specified party key are valid combinations
        'ValidatePartyType(oClaimPayment.PartyKey, oClaimPayment.PaymentPartyType, oSAMErrorCollection)

        ' validates that the product prevent cancelled agent making claim payment doesnt impact the request
        ValidateProductOptionPreventCancelledAgentsMakingClaimPayments(ClaimDetails, oClaimPayment, oSAMErrorCollection)

        ValidateAdvScriptOn(Cast.ToString(oClaimPayment.AdvanceScript),
                                    oClaimPayment,
                                    oSAMErrorCollection)

        ValidateClaimPaymentInfoOnly(con, oClaimPayment.BaseClaimKey,
                                    oSAMErrorCollection)
        If oClaimPayment.Payee IsNot Nothing Then
            If oClaimPayment.Payee.MediaTypeCode IsNot Nothing AndAlso oClaimPayment.Payee.MediaTypeCode <> "" Then
                ValidateBankAccDetails(con, oClaimPayment.Payee.MediaTypeCode,
                                                    oClaimPayment.Payee.BankCode,
                                                    oClaimPayment.Payee.BankName,
                                                    oClaimPayment.Payee.BankNumber,
                                                    oSAMErrorCollection)

                ValidatePayeeMediaType(con, oClaimPayment.Payee.MediaTypeCode,
                                                    oClaimPayment.VersionId,
                                                    oClaimPayment.BaseClaimKey,
                                                    oSAMErrorCollection)
            End If
        End If
        ValidateIsDeferredRisk(con, oClaimPayment.BaseClaimKey,
                                oClaimPayment.VersionId,
                                oSAMErrorCollection)

    End Sub

    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="bAdvScriptOpt"></param>
    ''' <param name="PayClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub ValidateAdvScriptOn(ByVal bAdvScriptOpt As String,
                                    ByVal oClaimPayment As BaseClaimPaymentType,
                                    ByRef oSAMErrorCollection As SAMErrorCollection) ', _

        ' if the advanced tax script system option is on 
        If bAdvScriptOpt = "1" Then

            ' confirm that an advanced tax details object has been provided in the request
            If oClaimPayment.AdvancedTaxDetails IsNot Nothing Then

                ' if the insured is domiciled
                If oClaimPayment.AdvancedTaxDetails.InsuredDomiciled = True Then

                    ' if the insured tax percentage has been supplied then the 
                    ' tax number must also be supplied
                    If oClaimPayment.AdvancedTaxDetails.InsuredPercentage > 0 AndAlso
                        String.IsNullOrEmpty(oClaimPayment.AdvancedTaxDetails.InsuranceTaxNumber) Then
                        oSAMErrorCollection.AddBusinessRule(
                            SAMBusinessErrors.UseOfAdvancedTaxScriptRequiresMandatoryInsurerTaxNumber,
                            SAMBusinessErrors.UseOfAdvancedTaxScriptRequiresMandatoryInsurerTaxNumber.ToString(),
                            "InsuredTaxNumber")

                    End If

                End If

                'Else

                ' if an advanced tax details object has not been provided in the request
                ' raise an invalid data error
                'oSAMErrorCollection.AddInvalidData(SAMBusinessErrors.UseOfAdvanceTaxScriptSystemOptionEnforcedMandatoryAdvanceTaxDetails, _
                'SAMBusinessErrors.UseOfAdvanceTaxScriptSystemOptionEnforcedMandatoryAdvanceTaxDetails.ToString(), _
                '"AdvanceTaxDetails")
            End If

        End If

    End Sub

