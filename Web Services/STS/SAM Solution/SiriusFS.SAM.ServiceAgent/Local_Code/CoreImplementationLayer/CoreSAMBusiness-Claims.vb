    Public Overloads Function OpenClaim(ByVal Con As SiriusConnection, ByVal OpenClaimRequest As BaseClaimOpenRequestType) As BaseClaimResponseType

        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oBusiness As New CoreBusiness
        Dim oResponse As BaseClaimResponseType
        Dim nTypeOfPackage As enumTypeOfPackage
       
        ' determine the type of package and thus the type of response
        If OpenClaimRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.OpenClaimRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.OpenClaimResponseType
        ElseIf OpenClaimRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.OpenClaimRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.OpenClaimResponseType
        Else
            oResponse = New BaseImplementationTypes.BaseClaimResponseType
        End If

        '*********************
        ' Initial Defaults
        '*********************

        If (OpenClaimRequest.IsDataTransferClaim AndAlso
            OpenClaimRequest.DataTransferIsUsingFullClaimVersioning) Or
            Not (OpenClaimRequest.IsDataTransferClaim) Then
            OpenClaimRequest.Claim.VersionId = 1
        End If

        '*********************
        ' STRUCTURE VALIDATION 
        '*********************

        ' validate the mandatory structure data (empty strings etc)
        OpenClaimRequest.Validate(CType(oSAMErrorCollection, Object))

        ' if there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        '*********************
        ' DATA VALIDATION 
        '*********************

        ' validate the data provided in the structure ( valid lookups etc)
        OpenClaimValidateData(oBusiness, OpenClaimRequest, oSAMErrorCollection)

        ' if there were any data errors in the structure throw an exception
        oSAMErrorCollection.CheckForErrors()

        '*********************
        ' BUSINESS RULE VALIDATION 
        '*********************

        ' validate the request structure against the specified business rules
        OpenClaimValidateBusinessRules(oBusiness, OpenClaimRequest, oSAMErrorCollection)

        ' validate the request structures against the specified business rules 
        '( used by both open claim and maintain claim)
        CoreClaimValidateBusinessRules(oBusiness, OpenClaimRequest.Claim, oSAMErrorCollection)

        ' if there were any business rule errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        '*********************
        ' BUSINESS RULE WARNING 
        '*********************

        ' if warnings should be taken into account 
        If OpenClaimRequest.Claim.IgnoreWarnings = False Then

            ' validate the request structure against the specified business warnings
            OpenClaimValidateBusinessWarnings(oBusiness, OpenClaimRequest, oResponse, oSAMErrorCollection)

            ' if warnings have been raised then return them...
            If oResponse.Warnings IsNot Nothing AndAlso oResponse.Warnings.Length <> 0 Then

                ' return the response populated with the warnings
                Return oResponse

            End If

            ' if any errors raided by the warnings throws an exception
            oSAMErrorCollection.CheckForErrors()

        End If

        '***************************************
        ' Validation Completed : Process the Claim
        '***************************************

        ' process the open claim functionality
        ProcessOpenClaim(Con, oBusiness, OpenClaimRequest, oResponse)

        ' return the fully populated response object
        Return oResponse

    End Function

