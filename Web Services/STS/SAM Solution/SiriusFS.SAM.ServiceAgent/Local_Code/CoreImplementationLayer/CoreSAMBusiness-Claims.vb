    Public Function CompareTaxArrays(
                ByVal v_vOrigTaxArray(,) As Object,
                ByRef r_vUpdatedTaxArray(,) As Object) As Integer

        'Const kMethodName As String = "CompareTaxArrays"

        Dim lReturn As Integer
        Dim lTaxItem As Integer
        Dim lOrigTaxLBound As Integer
        Dim lOrigTaxUBound As Integer
        Dim lUpdatedTaxLBound As Integer
        Dim lUpdatedTaxUBound As Integer
        Dim bOrigTaxIsArray As Boolean
        Dim bUpdatedTaxIsArray As Boolean
        Dim lProcessType As Integer
        Dim lCompareTaxUBound As Integer

        CompareTaxArrays = PMEReturnCode.PMTrue

        bOrigTaxIsArray = IsArray(v_vOrigTaxArray)
        bUpdatedTaxIsArray = IsArray(r_vUpdatedTaxArray)

        ' get the original array boundaries
        If bOrigTaxIsArray Then
            lOrigTaxLBound = LBound(v_vOrigTaxArray, 2)
            lOrigTaxUBound = UBound(v_vOrigTaxArray, 2)
        End If

        ' get the updated array boundaries
        If bUpdatedTaxIsArray Then
            lUpdatedTaxLBound = LBound(r_vUpdatedTaxArray, 2)
            lUpdatedTaxUBound = UBound(r_vUpdatedTaxArray, 2)
        End If

        ' determine what process needs to take place
        If bOrigTaxIsArray And bUpdatedTaxIsArray Then
            ' do compare
            lProcessType = 1
        ElseIf bOrigTaxIsArray And Not bUpdatedTaxIsArray Then
            ' no taxes to compare
            lProcessType = 2
        ElseIf Not bOrigTaxIsArray And bUpdatedTaxIsArray Then
            ' mark all as manually changed
            lProcessType = 3
        End If

        Select Case lProcessType

            Case 1

                ' Compare Original To Updated
                If lUpdatedTaxUBound > lOrigTaxUBound Then
                    lCompareTaxUBound = lOrigTaxUBound
                ElseIf lOrigTaxUBound > lUpdatedTaxUBound Then
                    lCompareTaxUBound = lUpdatedTaxUBound
                End If

                ' Compare Matching Array Items
                lReturn = CompareArrayItems(v_vOrigTaxArray, r_vUpdatedTaxArray, lCompareTaxUBound)

                If lOrigTaxUBound = lUpdatedTaxUBound Then
                    'mark any additional tax items as manually changed
                    If lCompareTaxUBound < lUpdatedTaxUBound Then
                        ' mark all other items as changed by script
                        For lTaxItem = 0 To lUpdatedTaxUBound
                            r_vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem) = kIsManuallyChangedScript
                        Next
                    End If
                Else
                    ' Compare Matching Array Items
                    lReturn = CompareArrayItems(v_vOrigTaxArray, r_vUpdatedTaxArray, lCompareTaxUBound)



                    'mark any additional tax items as manually changed
                    If lCompareTaxUBound < lUpdatedTaxUBound Then

                        ' mark all other items as changed by script
                        For lTaxItem = lCompareTaxUBound + 1 To lUpdatedTaxUBound
                            r_vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem) = kIsManuallyChangedScript
                        Next
                    End If
                End If
            Case 2
                ' do nothing

            Case 3
                ' mark all as changed by script
                For lTaxItem = lUpdatedTaxLBound To lUpdatedTaxUBound
                    r_vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem) = kIsManuallyChangedScript
                Next

        End Select
    End Function
    Public Function CompareArrayItems(
                ByVal v_vOrigTaxArray(,) As Object,
                ByRef r_vUpdatedTaxArray(,) As Object,
                ByVal v_lNoOfItemsToCompare As Integer) As Integer
        'Dim lReturn As Integer
        Dim lTaxItem As Integer

        Dim lOrigCOBID As Integer = 0
        Dim lUpdCOBID As Integer = 0

        ' for each tax item
        For lTaxItem = 0 To v_lNoOfItemsToCompare

            Int32.TryParse(v_vOrigTaxArray(kTaxArrayClassOfBusinessId, lTaxItem).ToString(), lOrigCOBID)
            Int32.TryParse(r_vUpdatedTaxArray(kTaxArrayClassOfBusinessId, lTaxItem).ToString(), lUpdCOBID)

            ' if any items doesnt match the original
            If CInt(v_vOrigTaxArray(kTaxArrayTaxGroupId, lTaxItem)) <> CInt(r_vUpdatedTaxArray(kTaxArrayTaxGroupId, lTaxItem)) Or
                 CInt(v_vOrigTaxArray(kTaxArrayTaxBandId, lTaxItem)) <> CInt(r_vUpdatedTaxArray(kTaxArrayTaxBandId, lTaxItem)) Or
                  CStr(v_vOrigTaxArray(kTaxArrayTaxCurrencyCode, lTaxItem)) <> CStr(r_vUpdatedTaxArray(kTaxArrayTaxCurrencyCode, lTaxItem)) Or
                  CDec(v_vOrigTaxArray(kTaxArrayPercentage, lTaxItem)) <> CDec(r_vUpdatedTaxArray(kTaxArrayPercentage, lTaxItem)) Or
                   CDec(v_vOrigTaxArray(kTaxArrayValue, lTaxItem)) <> CDec(r_vUpdatedTaxArray(kTaxArrayValue, lTaxItem)) Or
                    ((v_vOrigTaxArray(kTaxArrayClassOfBusinessId, lTaxItem) IsNot System.DBNull.Value) AndAlso CInt(v_vOrigTaxArray(kTaxArrayIsValue, lTaxItem)) <> CInt(r_vUpdatedTaxArray(kTaxArrayIsValue, lTaxItem)) Or
                      lOrigCOBID <> lUpdCOBID) Then

                ' mark it as changed by script
                r_vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem) = kIsManuallyChangedScript

            End If
        Next
    End Function
    Private Function GetLookupItemFromArray(
                                 ByVal v_vArray(,) As Object,
                                 ByRef r_sItemDesc As String,
                                 ByRef r_sItemCode As String,
                                 ByRef r_lItemId As Integer) As Integer

        'Dim lRow As Integer
        Dim lCntr As Integer
        'Dim bFoundMatch As Boolean
        Dim sCode As String = String.Empty
        Dim llBound As Integer
        Dim lUBound As Integer
        Dim v_vLookupItem As Object = Nothing
        Dim lLookupItem As Integer

        ' Lookup value contants.
        'Const ACValueTableName As Integer = 0
        'Const ACValueID As Integer = 1
        'Const ACValueStartPos As Integer = 2
        'Const ACValueNumber As Integer = 3

        Const ACDetailKey As Integer = 0
        Const ACDetailDesc As Integer = 1
        Const ACDetailCode As Integer = 2

        If IsArray(v_vArray) Then

            llBound = LBound(v_vArray, 2)
            lUBound = UBound(v_vArray, 2)

            ' set lookup properties
            If r_lItemId <> 0 Then
                v_vLookupItem = r_lItemId
                lLookupItem = 0

            ElseIf r_sItemDesc <> "" Then
                v_vLookupItem = r_sItemDesc
                lLookupItem = 1

            ElseIf r_sItemCode <> "" Then
                v_vLookupItem = r_sItemCode
                lLookupItem = 2
            End If

            ' loop around the available items for the specified table
            For lCntr = llBound To lUBound

                ' get the code for the specified lookup items key
                If Trim$(CStr(v_vArray(lLookupItem, lCntr)).ToString) = CStr(v_vLookupItem) Then

                    ' return the requested code, id, description
                    r_sItemDesc = Trim$(CStr((v_vArray(ACDetailDesc, lCntr))))
                    r_sItemCode = Trim$(CStr(v_vArray(ACDetailCode, lCntr)))
                    r_lItemId = CInt(v_vArray(ACDetailKey, lCntr))

                    Return 1
                    Exit For
                End If

            Next lCntr

        End If
        '''this is the end of the scripted option Check
    End Function

    ''' <summary>
    ''' Validate the claim ri arrangment totals
    ''' </summary>
    ''' <param name="aoRIArrangement"></param>
    ''' <param name="lValid"></param>
    ''' <param name="lBand"></param>
    ''' <remarks></remarks>
    Private Sub ValidateClaimRIArrangements(ByRef aoRIArrangement() As RIArrangement,
                                            ByRef lValid As Integer,
                                            ByRef lBand As Integer)

        lValid = 0
        lBand = 0

        Dim oRIArrangement As RIArrangement

        If aoRIArrangement IsNot Nothing Then
            ' Process each band
            For Each oRIArrangement In aoRIArrangement

                ' Check for minor rounding
                oRIArrangement.Round()

                ' Check band reserve against allocated reserve (no rounding issues)
                If oRIArrangement.TotalThisReserve <> oRIArrangement.ThisReserve Then
                    lValid = AutoReinsuranceFailure.Reserve
                    lBand = oRIArrangement.RIBand
                    Exit For
                End If

                ' Check band payment against allocated payment (no rounding issues)
                If oRIArrangement.TotalThisPayment <> oRIArrangement.ThisPayment Then
                    lValid = AutoReinsuranceFailure.Payment
                    lBand = oRIArrangement.RIBand
                    Exit For
                End If

            Next

        End If

    End Sub

