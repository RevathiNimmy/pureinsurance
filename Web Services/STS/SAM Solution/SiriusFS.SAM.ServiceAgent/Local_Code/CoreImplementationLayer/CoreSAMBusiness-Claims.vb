    Private Sub GetClaimReceiptTaxGroupsValidateData(
            ByVal oBusiness As CoreBusiness,
            ByVal oRequest As BaseGetClaimReceiptTaxGroupsRequestType,
            ByVal oSAMErrorCollection As SAMErrorCollection)

        ' Branch code
        oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        If Not String.IsNullOrEmpty(oRequest.TypeCode) Then
            If oRequest.TypeCode.Trim <> TransactionTypeCode.ThirdPartyRecovery AndAlso
                oRequest.TypeCode.Trim <> TransactionTypeCode.SalvageRecovery Then

                oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure,
                                                                                   "TypeCode is Invalid. Acceptable Values Are C_RV (Default) and C_SA",
                                                                                   "TypeCode",
                                                                                   oRequest.TypeCode.ToString())

            End If
        End If
    End Sub

    Private Sub ClaimReceiptValidateDataLinks(
    ByVal con As SiriusConnection,
    ByVal oRequest As BaseClaimReceiptRequestType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        For Each oClaimReceiptItem As BaseClaimReceiptItemType In oRequest.ClaimReceipt.ReceiptItem

            Dim dt As DataTable = Nothing

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Validate_Claim_Receipt_Data_Links")

                cmd.AddInParameter("@base_claim_id", SqlDbType.Int).Value = oRequest.ClaimReceipt.BaseClaimKey
                cmd.AddInParameter("@base_claim_peril_id", SqlDbType.Int).Value = oRequest.ClaimReceipt.BaseClaimPerilKey
                cmd.AddInParameter("@base_recovery_id", SqlDbType.Int).Value = oClaimReceiptItem.BaseRecoveryKey

                dt = con.ExecuteDataTable(cmd)

            End Using

            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                Dim dr As DataRow = dt.Rows(0)

                ' only get the results for claim / claim peril once 
                If oRequest.ClaimReceipt.ClaimId = 0 Then

                    ' use the latest version of the links before we create a new copy
                    oRequest.ClaimReceipt.ClaimId = Cast.ToInt32(dr.Item("claim_id"), 0)
                    oRequest.ClaimReceipt.ClaimPerilId = Cast.ToInt32(dr.Item("claim_peril_id"), 0)

                End If

                ' use the latest version of the links before we create a new copy 
                oClaimReceiptItem.RecoveryId = Cast.ToInt32(dr.Item("recovery_id"), 0)
            ElseIf oRequest.ClaimReceipt.ClaimId > 0 Then
                oClaimReceiptItem.RecoveryId = CInt(oClaimReceiptItem.BaseRecoveryKey)
            Else

                oSAMErrorCollection.AddInvalidData(SAMInvalidData.ClaimReceiptInvalidDataLinksProvidedNoLinkExistsBetweenClaimAndClaimPerilAndRecovery,
                                 SAMInvalidData.ClaimReceiptInvalidDataLinksProvidedNoLinkExistsBetweenClaimAndClaimPerilAndRecovery.ToString(),
                                 "BaseClaimKey And BaseClaimPerilKey And BaseRecoveryKey",
                                 "BaseClaimKey:-" & oRequest.ClaimReceipt.BaseClaimKey & ": BaseCLaimPerilKey:-" & oRequest.ClaimReceipt.BaseClaimPerilKey & ": BaseRecoveryKey:-" & oClaimReceiptItem.BaseRecoveryKey)

            End If

        Next

    End Sub

    '        ''' <summary>
    '        ''' builds the structure of recovery details on the basis of claim_id supplied
    '        ''' </summary>
    '        ''' <param name=""></param>
    '        ''' <returns></returns>
    '        ''' <remarks></remarks>
    Private Function getRecoveries(ByVal Con As SiriusConnection,
                                             ByVal GetClaimDetailsRequest As BaseGetClaimDetailsRequestType) _
                                             As BaseGetClaimRecoveryDetailsType()
        Dim dsRecovery As DataSet = Nothing

        ' Get Recovery Details
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Recovery_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimDetailsRequest.ClaimKey
            dsRecovery = Con.ExecuteDataSet(cmd, "ClaimRecoveries")
        End Using

        Dim oRecovery(dsRecovery.Tables(0).Rows.Count - 1) As BaseGetClaimRecoveryDetailsType
        'Dim drRec As DataRow
        With dsRecovery.Tables(0)
            For iCnt As Integer = 0 To .Rows.Count - 1
                oRecovery(iCnt) = New BaseGetClaimRecoveryDetailsType

                oRecovery(iCnt).ClaimPerilId = Cast.ToInt32(.Rows(iCnt).Item("claim_peril_id"), 0)
                oRecovery(iCnt).BaseRecoveryKey = Cast.ToInt32(.Rows(iCnt).Item("base_recovery_id"), 0)
                oRecovery(iCnt).TypeKey = Cast.ToInt32(.Rows(iCnt).Item("Recovery_type_id"), 0)
                oRecovery(iCnt).CurrencyCode = Cast.ToString(.Rows(iCnt).Item("Currency_code"))
                oRecovery(iCnt).InitialRecovery = Cast.ToDecimal(.Rows(iCnt).Item("Initial_reserve"), 0)
                oRecovery(iCnt).RevisedRecovery = Cast.ToDecimal(.Rows(iCnt).Item("Revised_reserve"), 0)
                oRecovery(iCnt).ReceiptedAmount = Cast.ToDecimal(.Rows(iCnt).Item("received_to_date"), 0)
                If oRecovery(iCnt).ReceiptedAmount <> 0 Then
                    oRecovery(iCnt).CanDelete = False
                Else
                    oRecovery(iCnt).CanDelete = True
                End If
                oRecovery(iCnt).ReceiptedTaxAmount = Cast.ToDecimal(.Rows(iCnt).Item("Tax_Amount"), 0)
                oRecovery(iCnt).TypeCode = Cast.ToString(.Rows(iCnt).Item("code"))
                oRecovery(iCnt).IsSalvage = Cast.ToInt32(.Rows(iCnt).Item("is_salvage"), 0)
            Next
        End With
        Return oRecovery
    End Function

    ''' <summary>
    ''' builds the structure of reserves details on the basis of peril_id supplied
    ''' </summary>
    ''' <param name="GetClaimsDetailsRequest [claim_id,source_id]"></param>
    ''' <returns Array of BaseGetClaimReserveDetailsType></returns>
    ''' <remarks></remarks>
    Private Function getReserves(ByVal Con As SiriusConnection,
                                           ByVal GetClaimDetailsRequest As BaseGetClaimDetailsRequestType) _
                                           As BaseGetClaimReserveDetailsType()
        Dim dsReserve As DataSet = Nothing

        ' Get Reserve Details
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Reserve_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimDetailsRequest.ClaimKey
            dsReserve = Con.ExecuteDataSet(cmd, "ClaimReserves")
        End Using

        Dim oReserve(dsReserve.Tables(0).Rows.Count - 1) As BaseGetClaimReserveDetailsType
        With dsReserve.Tables(0)
            For iCnt As Integer = 0 To .Rows.Count - 1
                oReserve(iCnt) = New BaseGetClaimReserveDetailsType
                oReserve(iCnt).ClaimPerilId = Cast.ToInt32(.Rows(iCnt).Item("claim_peril_id"), 0)
                oReserve(iCnt).BaseReserveKey = Cast.ToInt32(.Rows(iCnt).Item("base_reserve_id"), 0)
                oReserve(iCnt).TypeKey = Cast.ToInt32(.Rows(iCnt).Item("Reserve_type_id"), 0)
                oReserve(iCnt).SumInsured = Cast.ToDecimal(.Rows(iCnt).Item("Sum_insured"), 0)
                oReserve(iCnt).InitialReserve = Cast.ToDecimal(.Rows(iCnt).Item("Initial_reserve"), 0)
                oReserve(iCnt).RevisedReserve = Cast.ToDecimal(.Rows(iCnt).Item("Revised_reserve"), 0)
                oReserve(iCnt).PaidAmount = Cast.ToDecimal(.Rows(iCnt).Item("Paid_to_date"), 0)
                oReserve(iCnt).ThisRevision = Cast.ToDecimal(.Rows(iCnt).Item("this_revision"), 0)
                If oReserve(iCnt).PaidAmount <> 0 Then
                    oReserve(iCnt).CanDelete = False
                Else
                    oReserve(iCnt).CanDelete = True
                End If
                oReserve(iCnt).TypeCode = Cast.ToStringTrim(.Rows(iCnt).Item("reserve_type_code").ToString, String.Empty)
                oReserve(iCnt).TypeDescription = Cast.ToStringTrim(.Rows(iCnt).Item("Description").ToString, String.Empty)
                If Cast.ToInt32(.Rows(iCnt).Item("is_excess"), 0) = 1 Then
                    oReserve(iCnt).IsExcess = True
                End If
                If Cast.ToInt32(.Rows(iCnt).Item("is_indemnity"), 0) = 1 Then
                    oReserve(iCnt).IsIndemnity = True
                End If
                If Cast.ToInt32(.Rows(iCnt).Item("is_expense"), 0) = 1 Then
                    oReserve(iCnt).IsExpense = True
                End If
            Next
        End With

        Return oReserve

    End Function

    ''' <summary>
    ''' builds the structure of Payment details on the basis of peril_id supplied
    ''' </summary>
    ''' <param name="GetClaimsDetailsRequest [claim_id,source_id]"></param>
    ''' <returns> Array of BaseGetClaimPaymentDetailsType</returns>
    ''' <remarks></remarks>

    Private Function getPayments(ByVal Con As SiriusConnection,
                                           ByVal GetClaimDetailsRequest As BaseGetClaimDetailsRequestType,
                                           ByRef oSAMErrorCollection As SAMErrorCollection) _
                                           As BaseGetClaimPaymentDetailsType()
        ' Get Payment Item Details
        Dim dsPayment As DataSet = Nothing
        Dim oCoreBusiness As New CoreBusiness
        Dim iCountPaymentRows As Integer = 0
        Dim dToTalTaxAmount As Decimal = 0
        ' Look Up Codes
        Dim dsPaymentItem As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Payment_Item_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimDetailsRequest.ClaimKey
            cmd.AddInParameter("@iFetchAllVersionAmounts", SqlDbType.Int).Value = GetClaimDetailsRequest.FetchAllVersionAmounts
            dsPaymentItem = Con.ExecuteDataSet(cmd, "ClaimPaymentItems")
        End Using

        Dim aoPaymentItem(dsPaymentItem.Tables(0).Rows.Count - 1) As BaseGetClaimPaymentItemDetailsType
        With dsPaymentItem.Tables(0)
            For iCnt As Integer = 0 To .Rows.Count - 1
                aoPaymentItem(iCnt) = New BaseGetClaimPaymentItemDetailsType
                aoPaymentItem(iCnt).BaseClaimPaymentItemKey = Cast.ToInt32(.Rows(iCnt).Item("base_claim_payment_item_id"), 0)
                aoPaymentItem(iCnt).BaseReserveKey = Cast.ToInt32(.Rows(iCnt).Item("base_reserve_id"), 0)
                aoPaymentItem(iCnt).BaseRecoveryKey = Cast.ToInt32(.Rows(iCnt).Item("recovery_id"), 0)
                aoPaymentItem(iCnt).PaymentAmount = Cast.ToDecimal(.Rows(iCnt).Item("this_payment"), 0)
                aoPaymentItem(iCnt).TaxAmount = Cast.ToDecimal(.Rows(iCnt).Item("tax_amount"), 0)
                aoPaymentItem(iCnt).PaymentAdjustment = Cast.ToDecimal(.Rows(iCnt).Item("payment_adjustment"), 0)
                aoPaymentItem(iCnt).ReserveKey = Cast.ToInt32(.Rows(iCnt).Item("reserve_id"), 0)
                aoPaymentItem(iCnt).ThisRevision = Cast.ToDecimal(.Rows(iCnt).Item("This_Revision"), 0)
                aoPaymentItem(iCnt).LossAmount = Cast.ToDecimal(.Rows(iCnt).Item("LossAmount"), 0)
                aoPaymentItem(iCnt).BaseAmount = Cast.ToDecimal(.Rows(iCnt).Item("BaseAmount"), 0)
                aoPaymentItem(iCnt).LossTaxAmount = Cast.ToDecimal(.Rows(iCnt).Item("LossTaxAmount"), 0)
                aoPaymentItem(iCnt).TaxGroupCode = Cast.ToString(.Rows(iCnt).Item("tax_group_code"))
                iCountPaymentRows = iCountPaymentRows + 1
                dToTalTaxAmount = dToTalTaxAmount + Cast.ToDecimal(.Rows(iCnt).Item("LossTaxAmount"), 0)
            Next
        End With
        For iCountPaymentRows = 0 To iCountPaymentRows - 1
            aoPaymentItem(iCountPaymentRows).TotalTaxAmount = dToTalTaxAmount
        Next

        ' Get Payment Details
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Payments_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimDetailsRequest.ClaimKey
            cmd.AddInParameter("@iFetchAllVersionAmounts", SqlDbType.Int).Value = GetClaimDetailsRequest.FetchAllVersionAmounts
            dsPayment = Con.ExecuteDataSet(cmd, "ClaimPayments")
        End Using

        Dim aoPayment(dsPayment.Tables(0).Rows.Count - 1) As BaseGetClaimPaymentDetailsType
        Dim aoAdvTax(dsPayment.Tables(0).Rows.Count - 1) As BaseClaimPaymentAdvancedTaxDetailsType
        Dim aoPayee(dsPayment.Tables(0).Rows.Count - 1) As BaseClaimPayeeType

        Dim lMapPayItem As Integer = 0
        With dsPayment.Tables(0)
            For iCnt As Integer = 0 To .Rows.Count - 1
                aoPayment(iCnt) = New BaseGetClaimPaymentDetailsType
                aoPayment(iCnt).ClaimPerilId = Cast.ToInt32(.Rows(iCnt).Item("claim_peril_id"), 0)
                aoPayment(iCnt).BaseClaimPaymentKey = Cast.ToInt32(.Rows(iCnt).Item("base_claim_payment_id"), 0)
                aoPayment(iCnt).PaymentDate = Cast.ToDateTime(.Rows(iCnt).Item("date_of_payment"), Now)
                aoPayment(iCnt).CurrencyCode = Cast.ToString(.Rows(iCnt).Item("Currency_code"))
                aoPayment(iCnt).PartyKey = Cast.ToInt32(.Rows(iCnt).Item("party_cnt"), 0)
                aoPayment(iCnt).PaymentAmount = Cast.ToDecimal(.Rows(iCnt).Item("amount"), 0)
                aoPayment(iCnt).IsReferred = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("is_referred"), CByte(0)))
                aoPayment(iCnt).CurrencyDescription = Cast.ToString(.Rows(iCnt).Item("CurrencyDescription"))
                aoPayment(iCnt).LossAmount = Cast.ToDecimal(.Rows(iCnt).Item("LossAmount"), 0)
                aoPayment(iCnt).BaseAmount = Cast.ToDecimal(.Rows(iCnt).Item("BaseAmount"), 0)
                aoPayment(iCnt).PartyPaidName = Cast.ToString(.Rows(iCnt).Item("resolved_name"))
                aoPayment(iCnt).PartyPaidCode = Cast.ToString(.Rows(iCnt).Item("shortname"))
                Select Case Cast.ToInt32(.Rows(iCnt).Item("payment_party_to"), 0)
                    Case PaymentPartyTo.Agent
                        aoPayment(iCnt).PaymentPartyType = "AGENT"
                    Case PaymentPartyTo.Client
                        aoPayment(iCnt).PaymentPartyType = "CLIENT"
                    Case PaymentPartyTo.CLMPayable
                        aoPayment(iCnt).PaymentPartyType = "CLMPAYABLE"
                    Case PaymentPartyTo.Party
                        aoPayment(iCnt).PaymentPartyType = "PARTY"
                End Select

                aoPayment(iCnt).TaxAmount = Cast.ToDecimal(.Rows(iCnt).Item("LossTaxAmount"), 0)
                aoPayment(iCnt).OurRef = Cast.ToString(.Rows(iCnt).Item("Our_Ref"))
                aoPayment(iCnt).UltimatePayee = Cast.ToString(.Rows(iCnt).Item("ultimate_payee"))
                aoPayment(iCnt).IsExGratia = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("is_ex_gratia"), CByte(0)))
                aoPayment(iCnt).IsThisPayment = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("IsThisPayment"), CByte(0)))
                If Not String.IsNullOrEmpty(.Rows(iCnt).Item("insured_domiciled").ToString) Then  'BUG  Problem of NULL data needs to be changed
                    aoAdvTax(iCnt) = New BaseClaimPaymentAdvancedTaxDetailsType
                    aoAdvTax(iCnt).InsuredDomiciled = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("insured_domiciled"), CByte(0)))
                    aoAdvTax(iCnt).InsuredPercentage = CDec(Cast.ToDouble(.Rows(iCnt).Item("insured_percentage"), 0))
                    aoAdvTax(iCnt).InsuranceTaxNumber = Cast.ToString(.Rows(iCnt).Item("insured_tax_number").ToString)
                    aoAdvTax(iCnt).PayeeDomiciled = Cast.ToBoolean(.Rows(iCnt).Item("payee_domiciled"), False)
                    aoAdvTax(iCnt).PayeePercentage = Cast.ToDecimal(.Rows(iCnt).Item("payee_percentage"), 0)
                    aoAdvTax(iCnt).PayeeTaxNumber = Cast.ToString(.Rows(iCnt).Item("payee_tax_number"))
                    aoAdvTax(iCnt).SafeHarbourCode = Cast.ToString(.Rows(iCnt).Item("safe_harbour_code"))

                    aoAdvTax(iCnt).SafeHarbourPercentage = Cast.ToDecimal(.Rows(iCnt).Item("safe_harbour_percentage"), 0)
                    aoAdvTax(iCnt).IsTaxExempt = CBool(Cast.ToInt32(.Rows(iCnt).Item("is_tax_exempt"), 0))
                    aoAdvTax(iCnt).IsWHTExempt = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("is_wht_exempt"), CByte(0)))
                    aoAdvTax(iCnt).IsSettlement = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("is_settlement"), CByte(0)))

                    'To be map with claim_peril
                    aoPayment(iCnt).AdvancedTaxDetails = aoAdvTax(iCnt)
                End If

                aoPayee(iCnt) = New BaseClaimPayeeType
                aoPayee(iCnt).Name = Cast.ToString(.Rows(iCnt).Item("PayeeName"))
                aoPayee(iCnt).BankName = Cast.ToString(.Rows(iCnt).Item("PayeeBankName"))
                aoPayee(iCnt).BankNumber = Cast.ToString(.Rows(iCnt).Item("PayeeAccountNo"))
                aoPayee(iCnt).BankCode = Cast.ToString(.Rows(iCnt).Item("PayeeSortCode"))
                aoPayee(iCnt).PartyBankKey = Cast.ToInt32(.Rows(iCnt).Item("Party_bank_id"), 0)
                aoPayee(iCnt).BIC = Cast.ToString(.Rows(iCnt).Item("business_identifier_code"))
                aoPayee(iCnt).IBAN = Cast.ToString(.Rows(iCnt).Item("international_bank_account_number"))
                '''''Casting problem 
                aoPayee(iCnt).MediaTypeCode = Cast.ToString(.Rows(iCnt).Item("PayeeMediaType"))
                aoPayee(iCnt).MediaTypeDesc = Cast.ToString(.Rows(iCnt).Item("PayeeMediaTypeDesc"))
                If Not (IsDBNull(.Rows(iCnt).Item("PayeeComments"))) Then
                    aoPayee(iCnt).Comments = Cast.ToString(.Rows(iCnt).Item("PayeeComments"))
                Else
                    aoPayee(iCnt).Comments = String.Empty
                End If
                If Not IsDBNull(.Rows(iCnt).Item("PayeeMediaRef")) Then
                    aoPayee(iCnt).MediaReference = .Rows(iCnt).Item("PayeeMediaRef").ToString
                End If
                aoPayee(iCnt).TheirReference = Cast.ToString(.Rows(iCnt).Item("ThirdPartyReference"))

                aoPayee(iCnt).Address = New BaseAddressType
                aoPayee(iCnt).Address.AddressLine1 = Cast.ToString(.Rows(iCnt).Item("PayeeAddress1"))
                aoPayee(iCnt).Address.AddressLine2 = Cast.ToString(.Rows(iCnt).Item("PayeeAddress2"))
                aoPayee(iCnt).Address.AddressLine3 = Cast.ToString(.Rows(iCnt).Item("PayeeAddress3"))
                aoPayee(iCnt).Address.AddressLine4 = Cast.ToString(.Rows(iCnt).Item("PayeeAddress4"))
                If Not IsDBNull(.Rows(iCnt).Item("PayeePostalCode")) Then
                    aoPayee(iCnt).Address.PostCode = Cast.ToString(.Rows(iCnt).Item("PayeePostalCode"))
                End If
                If Not IsDBNull(.Rows(iCnt).Item("PayeeCountry")) Then
                    aoPayee(iCnt).Address.CountryCode = .Rows(iCnt).Item("PayeeCountry").ToString
                End If
                aoPayment(iCnt).LossCurrencyCode = Cast.ToString(.Rows(iCnt).Item("LossCurrencyCode"))
                aoPayment(iCnt).Payee = aoPayee(iCnt)

                lMapPayItem = 0
                For payItemCount As Integer = 0 To dsPaymentItem.Tables(0).Rows.Count - 1
                    If .Rows(iCnt).Item("claim_payment_id").ToString = dsPaymentItem.Tables(0).Rows(payItemCount).Item("claim_payment_id").ToString Then
                        ReDim Preserve aoPayment(iCnt).ClaimPaymentItems(lMapPayItem)
                        aoPayment(iCnt).ClaimPaymentItems(lMapPayItem) = aoPaymentItem(payItemCount)
                        lMapPayItem = lMapPayItem + 1
                    End If
                Next

            Next
        End With
        Return aoPayment

    End Function

    '        ''' <summary>
    '        ''' builds the structure of Receipts details on the basis of peril_id supplied
    '        ''' </summary>
    '        ''' <param name="GetClaimsDetailsRequest [claim_id,source_id]"></param>
    '        ''' <returns Array of BaseGetClaimReceiptDetailsType></returns>
    '        ''' <remarks></remarks>
    Private Function getReceipts(ByVal Con As SiriusConnection,
                                           ByVal GetClaimDetailsRequest As BaseGetClaimDetailsRequestType) _
                                           As BaseGetClaimReceiptDetailsType()
        Dim dsReceipt As DataSet = Nothing
        ' Get Receipts Item
        Dim drReceiptItem As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Receipt_Item_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimDetailsRequest.ClaimKey
            drReceiptItem = Con.ExecuteDataSet(cmd, "ClaimReceiptItems")
        End Using
        Dim aoReceiptItem(drReceiptItem.Tables(0).Rows.Count - 1) As BaseGetClaimReceiptItemDetailsType

        With drReceiptItem.Tables(0)
            For iCnt As Integer = 0 To .Rows.Count - 1
                aoReceiptItem(iCnt) = New BaseGetClaimReceiptItemDetailsType
                aoReceiptItem(iCnt).BaseClaimReceiptItemKey = Cast.ToInt32(.Rows(iCnt).Item("base_claim_receipt_item_id"), 0)
                aoReceiptItem(iCnt).BaseReserveKey = Cast.ToInt32(.Rows(iCnt).Item("reserve_id"), 0)
                aoReceiptItem(iCnt).BaseRecoveryKey = Cast.ToInt32(.Rows(iCnt).Item("recovery_id"), 0)
                aoReceiptItem(iCnt).ReceiptAmount = Cast.ToDecimal(.Rows(iCnt).Item("this_receipt"), 0)
                aoReceiptItem(iCnt).TaxAmount = Cast.ToDecimal(.Rows(iCnt).Item("tax_amount"), 0)
                aoReceiptItem(iCnt).ReceiptBaseAmount = Cast.ToDecimal(.Rows(iCnt).Item("BaseAmount"), 0)
                aoReceiptItem(iCnt).ReceiptLossAmount = Cast.ToDecimal(.Rows(iCnt).Item("LossAmount"), 0)
                aoReceiptItem(iCnt).ClaimReceiptItemKey = Cast.ToInt32(.Rows(iCnt).Item("claim_receipt_item_id"), 0)
                aoReceiptItem(iCnt).RecoveryTypeCode = Cast.ToString(.Rows(iCnt).Item("recovery_type_code"), "")
                aoReceiptItem(iCnt).TaxGroupCode = Cast.ToString(.Rows(iCnt).Item("tax_group_code"), "")
            Next
        End With

        ' Call stored proc to get Claim Peril Details from the SP  spu_SAM_Get_Claim_Receipt_Details
        Dim lMapRecItem As Integer = 0
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Receipt_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimDetailsRequest.ClaimKey
            dsReceipt = Con.ExecuteDataSet(cmd, "ClaimReceipt")
        End Using

        Dim aoReceipt(dsReceipt.Tables(0).Rows.Count - 1) As BaseGetClaimReceiptDetailsType
        Dim aoRecAdvanceTax(dsReceipt.Tables(0).Rows.Count - 1) As BaseClaimReceiptAdvancedTaxDetailsType
        Dim aoRecPayee(dsReceipt.Tables(0).Rows.Count - 1) As BaseClaimPayeeType
        With dsReceipt.Tables(0)
            For iCnt As Integer = 0 To .Rows.Count - 1
                aoReceipt(iCnt) = New BaseGetClaimReceiptDetailsType
                aoReceipt(iCnt).ClaimPerilId = Cast.ToInt32(.Rows(iCnt).Item("claim_peril_id"), 0)
                aoReceipt(iCnt).BaseClaimReceiptKey = Cast.ToInt32(.Rows(iCnt).Item("base_claim_receipt_id"), 0)
                aoReceipt(iCnt).ReceiptDate = Cast.ToDateTime(.Rows(iCnt).Item("date_of_receipt"), Now)
                aoReceipt(iCnt).PartyKey = Cast.ToInt32(.Rows(iCnt).Item("party_cnt"), 0)
                'aoReceipt(iCnt).ReceiptPartyType = Cast.ToString(.Rows(iCnt).Item("").ToString) ' i think solved
                aoReceipt(iCnt).CurrencyCode = Cast.ToString(.Rows(iCnt).Item("currrency_code").ToString)
                aoReceipt(iCnt).ReceiptAmount = Cast.ToDecimal(.Rows(iCnt).Item("Amount"), 0)
                aoReceipt(iCnt).TaxAmount = Cast.ToDecimal(.Rows(iCnt).Item("tax_amount"), 0)
                aoReceipt(iCnt).ReceiptPartyCode = Cast.ToString(.Rows(iCnt).Item("shortname").ToString)
                aoReceipt(iCnt).ClaimReceiptKey = Cast.ToInt32(.Rows(iCnt).Item("claim_receipt_id"), 0)
                aoReceipt(iCnt).ReceiptPartyType = Cast.ToString(.Rows(iCnt).Item("party_type"), "0")
                ' 
                If Not String.IsNullOrEmpty(.Rows(iCnt).Item("PayeeName").ToString) Then  'BUG  Problem of NULL data needs to be changed
                    aoRecPayee(iCnt) = New BaseClaimPayeeType
                    aoRecPayee(iCnt).Name = Cast.ToString(.Rows(iCnt).Item("PayeeName"))
                    aoRecPayee(iCnt).BankName = Cast.ToString(.Rows(iCnt).Item("PayeeBankName"))
                    aoRecPayee(iCnt).BankNumber = Cast.ToString(.Rows(iCnt).Item("PayeeAccountNo"))
                    aoRecPayee(iCnt).BankCode = Cast.ToString(.Rows(iCnt).Item("PayeeSortCode"))
                    aoRecPayee(iCnt).MediaTypeCode = Cast.ToString(.Rows(iCnt).Item("PayeeMediaType"))
                    aoRecPayee(iCnt).MediaReference = Cast.ToString(.Rows(iCnt).Item("PayeeMediaRef"))
                    aoRecPayee(iCnt).TheirReference = Cast.ToString(.Rows(iCnt).Item("ThirdPartyReference").ToString)
                    aoRecPayee(iCnt).Comments = Cast.ToString(.Rows(iCnt).Item("PayeeComments").ToString)

                    aoRecPayee(iCnt).Address = New BaseAddressType
                    aoRecPayee(iCnt).Address.AddressLine1 = Cast.ToString(.Rows(iCnt).Item("PayeeAddress1"))
                    aoRecPayee(iCnt).Address.AddressLine2 = Cast.ToString(.Rows(iCnt).Item("PayeeAddress2"))
                    aoRecPayee(iCnt).Address.AddressLine3 = Cast.ToString(.Rows(iCnt).Item("PayeeAddress3"))
                    aoRecPayee(iCnt).Address.AddressLine4 = Cast.ToString(.Rows(iCnt).Item("PayeeAddress4"))
                    aoRecPayee(iCnt).Address.PostCode = Cast.ToString(.Rows(iCnt).Item("PayeePostalCode"))
                    aoRecPayee(iCnt).Address.CountryCode = Cast.ToString(.Rows(iCnt).Item("PayeeCountry"))
                    aoReceipt(iCnt).Payee = aoRecPayee(iCnt)
                End If

                If Not String.IsNullOrEmpty(.Rows(iCnt).Item("insured_domiciled").ToString) Then  'BUG  Problem of NULL data needs to be changed
                    aoRecAdvanceTax(iCnt) = New BaseClaimReceiptAdvancedTaxDetailsType
                    aoRecAdvanceTax(iCnt).IsSettlement = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("is_settlement"), CByte(0)))
                    aoRecAdvanceTax(iCnt).IsTaxExempt = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("is_tax_exempt"), CByte(0)))
                    aoRecAdvanceTax(iCnt).ReceivableTaxPercentage = Cast.ToDecimal(.Rows(iCnt).Item("receivable_tax_percentage"), 0)
                    aoRecAdvanceTax(iCnt).InsuredDomiciled = BooleanDataConvert.ToBoolean(Cast.ToByte(.Rows(iCnt).Item("insured_domiciled"), CByte(0)))
                    aoRecAdvanceTax(iCnt).InsuredPercentage = CDec(Cast.ToDouble(.Rows(iCnt).Item("insured_percentage"), 0))
                    aoRecAdvanceTax(iCnt).InsuredTaxNumber = Cast.ToString(.Rows(iCnt).Item("insured_tax_number"))
                    aoReceipt(iCnt).AdvancedTax = aoRecAdvanceTax(iCnt)
                End If

                lMapRecItem = 0
                For recItemCount As Integer = 0 To drReceiptItem.Tables(0).Rows.Count - 1
                    If .Rows(iCnt).Item("claim_receipt_id").ToString = drReceiptItem.Tables(0).Rows(recItemCount).Item("claim_receipt_id").ToString Then
                        ReDim Preserve aoReceipt(iCnt).ReceiptItem(lMapRecItem)
                        aoReceipt(iCnt).ReceiptItem(lMapRecItem) = aoReceiptItem(recItemCount)
                        lMapRecItem = lMapRecItem + 1
                    End If
                Next

            Next
        End With
        Return aoReceipt
    End Function

    '        ''' <summary>
    '        ''' Builds the structure of Peril details. 
    '        ''' Binds all the structures related to the Peril i.e - Payments, Receipts, Reserves, Recoveries  and etc
    '        ''' </summary>
    '        ''' <param name="GetClaimsDetailsRequest [claim_id,source_id]"></param>
    '        ''' <returns Array of BaseGetClaimPerilDetailsType></returns>
    '        ''' <remarks></remarks>
    Private Function getPerils(ByVal Con As SiriusConnection,
                                         ByVal GetClaimDetailsRequest As BaseGetClaimDetailsRequestType,
                                         ByRef oSAMErrorCollection As SAMErrorCollection) _
                                         As BaseGetClaimPerilDetailsType()

        ' Get Peril Reserves
        ' Collect all the reserves by calling the getReserves Function
        Dim aoReserve() As BaseGetClaimReserveDetailsType
        aoReserve = getReserves(Con, GetClaimDetailsRequest)

        ' Get Peril Recoveries
        ' Collect all the Recoveries by calling the getrecoveries Function
        Dim aoRecovery() As BaseGetClaimRecoveryDetailsType
        aoRecovery = getRecoveries(Con, GetClaimDetailsRequest)

        ' Get Peril Payments
        ' Collect all the Recoveries by calling the getrecoveries Function
        Dim aoPayments() As BaseGetClaimPaymentDetailsType
        aoPayments = getPayments(Con, GetClaimDetailsRequest, oSAMErrorCollection)

        ' Get peril Recipts
        ' Collect all the Recoveries by calling the getrecoveries Function
        Dim aoReceipts() As BaseGetClaimReceiptDetailsType
        aoReceipts = getReceipts(Con, GetClaimDetailsRequest)

        ' Get Peril Details
        Dim drPeril As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Peril_Details")
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = GetClaimDetailsRequest.ClaimKey
            drPeril = Con.ExecuteDataSet(cmd, "ClaimPerilDetails")
        End Using

        Dim iCntPerils As Integer
        Dim aoPeril(drPeril.Tables(0).Rows.Count - 1) As BaseGetClaimPerilDetailsType
        Dim lMapReserve As Integer
        Dim lMapRecovery As Integer
        Dim lMapPayment As Integer
        Dim lMapReceipt As Integer

        With drPeril.Tables(0)
            For iCntPerils = 0 To .Rows.Count - 1
                aoPeril(iCntPerils) = New BaseGetClaimPerilDetailsType
                aoPeril(iCntPerils).ClaimPerilKey = Cast.ToInt32(.Rows(iCntPerils).Item("Claim_Peril_id"), 0)
                aoPeril(iCntPerils).BaseClaimPerilKey = Cast.ToInt32(.Rows(iCntPerils).Item("base_Claim_Peril_id"), 0)
                aoPeril(iCntPerils).Comments = Cast.ToString(.Rows(iCntPerils).Item("comments"))
                aoPeril(iCntPerils).Description = Cast.ToString(.Rows(iCntPerils).Item("description"))
                aoPeril(iCntPerils).RIBand = Cast.ToString(.Rows(iCntPerils).Item("ri_band_code").ToString)
                aoPeril(iCntPerils).SumInsured = Cast.ToDecimal(.Rows(iCntPerils).Item("sum_insured"), 0)
                aoPeril(iCntPerils).GisScreenCode = Cast.ToStringTrim(.Rows(iCntPerils).Item("gis_screen_code"), String.Empty)
                aoPeril(iCntPerils).TypeCode = Cast.ToStringTrim(.Rows(iCntPerils).Item("peril_type_code"), String.Empty)

                lMapReserve = 0

                For reserveCount As Integer = 0 To aoReserve.GetUpperBound(0) 'dsReserve.Tables(0).Rows.Count - 1

                    If .Rows(iCntPerils).Item("claim_peril_id").ToString = aoReserve(reserveCount).ClaimPerilId.ToString Then 'dsReserve.Tables(0).Rows(reserveCount).Item("claim_peril_id").ToString Then

                        ReDim Preserve aoPeril(iCntPerils).Reserve(lMapReserve)
                        aoPeril(iCntPerils).Reserve(lMapReserve) = New BaseGetClaimReserveDetailsType
                        aoPeril(iCntPerils).Reserve(lMapReserve) = aoReserve(reserveCount)
                        lMapReserve = lMapReserve + 1

                    End If

                Next

                lMapRecovery = 0
                For recoveryCount As Integer = 0 To aoRecovery.GetUpperBound(0) 'dsRecovery.Tables(0).Rows.Count - 1
                    If .Rows(iCntPerils).Item("claim_peril_id").ToString = aoRecovery(recoveryCount).ClaimPerilId.ToString Then 'dsRecovery.Tables(0).Rows(recoveryCount).Item("claim_peril_id").ToString Then
                        ReDim Preserve aoPeril(iCntPerils).Recovery(lMapRecovery)
                        aoPeril(iCntPerils).Recovery(lMapRecovery) = New BaseGetClaimRecoveryDetailsType
                        aoPeril(iCntPerils).Recovery(lMapRecovery) = aoRecovery(recoveryCount)
                        lMapRecovery = lMapRecovery + 1
                    End If
                Next

                lMapPayment = 0
                ' check Whether we have receipts attached with this claim
                If Not aoPayments Is Nothing Then
                    For paymentCount As Integer = 0 To aoPayments.GetUpperBound(0) 'dsPayment.Tables(0).Rows.Count - 1
                        If .Rows(iCntPerils).Item("claim_peril_id").ToString = aoPayments(paymentCount).ClaimPerilId.ToString Then 'dsPayment.Tables(0).Rows(paymentCount).Item("claim_peril_id").ToString Then
                            ReDim Preserve aoPeril(iCntPerils).ClaimPayments(lMapPayment)
                            aoPeril(iCntPerils).ClaimPayments(lMapPayment) = New BaseGetClaimPaymentDetailsType
                            aoPeril(iCntPerils).ClaimPayments(lMapPayment) = aoPayments(paymentCount)
                            lMapPayment = lMapPayment + 1
                        End If
                    Next
                End If

                lMapReceipt = 0
                ' check Whether we have receipts attached with this claim
                If Not aoReceipts Is Nothing Then
                    For receiptCount As Integer = 0 To aoReceipts.GetUpperBound(0) 'dsReceipt.Tables(0).Rows.Count - 1
                        If .Rows(iCntPerils).Item("claim_peril_id").ToString = aoReceipts(receiptCount).ClaimPerilId.ToString Then 'dsReceipt.Tables(0).Rows(receiptCount).Item("claim_peril_id").ToString Then
                            ReDim Preserve aoPeril(iCntPerils).ClaimReceipts(lMapReceipt)
                            aoPeril(iCntPerils).ClaimReceipts(lMapReceipt) = New BaseGetClaimReceiptDetailsType
                            aoPeril(iCntPerils).ClaimReceipts(lMapReceipt) = aoReceipts(receiptCount)
                            lMapReceipt = lMapReceipt + 1
                        End If
                    Next
                End If
            Next
        End With
        Return aoPeril

    End Function

