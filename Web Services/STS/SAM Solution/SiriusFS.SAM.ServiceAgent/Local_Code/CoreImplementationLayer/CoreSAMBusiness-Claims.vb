    Public Function FindClaim(ByVal FindClaimRequest As BaseFindClaimRequestType) As BaseFindClaimResponseType

        Dim oFindClaimResponse As New BaseImplementationTypes.BaseFindClaimResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oErrors As New SAMErrorCollection
        Dim sDisableWildcardSearchOption As String
        Dim sEnablePartialWildcardSearchOption As String
        sDisableWildcardSearchOption = ""
        sEnablePartialWildcardSearchOption = ""
        Dim bDisableWildcardSearchOption As Boolean
        Dim bEnablePartialWildcardSearchOption As Boolean
        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If FindClaimRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.FindClaimRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oFindClaimResponse = New SAMForInsuranceImplementationTypes.FindClaimResponseType
        ElseIf FindClaimRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.FindClaimRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oFindClaimResponse = New SAMForInsuranceV2ImplementationTypes.FindClaimResponseType
        End If

        ' Check mandatory fields
        If String.IsNullOrEmpty(FindClaimRequest.BranchCode) Then
            oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If
        oErrors.CheckForErrors()

        ' Check wildcard searches
        oCoreBusiness.GetSystemOption(FindClaimRequest.BranchCode, SystemOption.DisableWildcardSearch, sDisableWildcardSearchOption)
        oCoreBusiness.GetSystemOption(FindClaimRequest.BranchCode, SystemOption.EnablePartialWildcardSearch, sEnablePartialWildcardSearchOption)
        If (Trim(sDisableWildcardSearchOption) = "1") Then
            bDisableWildcardSearchOption = True
        Else
            bDisableWildcardSearchOption = False
        End If

        If (Trim(sEnablePartialWildcardSearchOption) = "1") Then
            bEnablePartialWildcardSearchOption = True
        Else
            bEnablePartialWildcardSearchOption = False
        End If

        If Not oCoreBusiness.ValidWildcardSearch(bDisableWildcardSearchOption, bEnablePartialWildcardSearchOption, FindClaimRequest.ClaimNumber) Then
            oErrors.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     SAMInvalidData.InvalidWildcardSearch.ToString,
                                     "ClaimNumber")
        End If
        oErrors.CheckForErrors()

        If Not oCoreBusiness.ValidWildcardSearch(bDisableWildcardSearchOption, bEnablePartialWildcardSearchOption, FindClaimRequest.InsuranceFileRef) Then
            oErrors.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     SAMInvalidData.InvalidWildcardSearch.ToString,
                                     "InsuranceFileRef")
        End If
        oErrors.CheckForErrors()

        If Not oCoreBusiness.ValidWildcardSearch(bDisableWildcardSearchOption, bEnablePartialWildcardSearchOption, FindClaimRequest.ClientShortName) Then
            oErrors.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                     SAMInvalidData.InvalidWildcardSearch.ToString,
                                     "ClientShortName")
        End If
        oErrors.CheckForErrors()

        If FindClaimRequest.CaseNumberSpecified Then
            If Not oCoreBusiness.ValidWildcardSearch(bDisableWildcardSearchOption, bEnablePartialWildcardSearchOption, FindClaimRequest.CaseNumber) Then
                oErrors.AddInvalidData(SAMInvalidData.InvalidWildcardSearch,
                                         SAMInvalidData.InvalidWildcardSearch.ToString,
                                         "CaseNumber")
            End If
            oErrors.CheckForErrors()
        End If

        ' Lookup Codes to ensure they are valid
        Try
            iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, FindClaimRequest.BranchCode, "BranchCode")
        Catch ex As Exception
            oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue,
                                    SAMInvalidData.InvalidLookupListValue.ToString,
                                    "BranchCode",
                                    FindClaimRequest.BranchCode)
        End Try

        If FindClaimRequest.LossDateFromSpecified And FindClaimRequest.LossDateToSpecified Then
            If FindClaimRequest.LossDateFrom > FindClaimRequest.LossDateTo Then
                oErrors.AddInvalidData(SAMInvalidData.ValidationRulesFailed,
                                        SAMInvalidData.ValidationRulesFailed.ToString,
                                          "LossDateFrom",
                                          "LossDateFrom (" & FindClaimRequest.LossDateFrom & ") should be <= LossDateTo  (" & FindClaimRequest.LossDateTo & ")")
            End If
        End If

        ' exit if there are any invalid parameters
        oErrors.CheckForErrors()
        ' exit if there are any invalid parameters
        oErrors.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim ds As DataSet = Nothing
        Dim dsUser As DataSet = Nothing
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_User_OtherPartyID")
                cmd.AddInParameter("@userid", SqlDbType.Int).Value = _SiriusUser.UserID
                dsUser = con.ExecuteDataSet(cmd, "User")
            End Using

            If Not dsUser Is Nothing AndAlso Not dsUser.Tables Is Nothing Then
                If dsUser.Tables(0).Rows.Count > 0 And Not dsUser.Tables(0).Rows(0).Item("shortname") Is Nothing AndAlso Not IsDBNull(dsUser.Tables(0).Rows(0).Item("shortname")) Then
                    FindClaimRequest.TPA = dsUser.Tables(0).Rows(0).Item("shortname").ToString()
                End If
            End If

        End Using


        With FindClaimRequest
            Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

                'Get Agent Group Details if AgentKey is provided
                If (FindClaimRequest.AgentKey <> 0) Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Agent_Group_From_Agent_Key")
                        cmd.AddOutParameter("@agent_group_cnt", SqlDbType.Int)
                        cmd.AddInParameter("@agent_cnt", SqlDbType.Int).Value = .AgentKey

                        con.ExecuteNonQuery(cmd)
                        .AgentGroupKey = Cast.ToInt32(cmd.Parameters("@agent_group_cnt").Value, 0)
                    End Using
                End If
            End Using

            If .RiskIndex <> "" Then
                Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_GetMultiPolicyClaimsByRiskIndex")
                        cmd.AddInParameter("@RiskIndex", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(.RiskIndex)
                        cmd.AddInParameter("@ClaimNumber", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(Cast.NullIfDefault(.ClaimNumber))
                        cmd.AddInParameter("@PolicyNumber", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(Cast.NullIfDefault(.InsuranceFileRef))
                        cmd.AddInParameter("@ClientShortName", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(Cast.NullIfDefault(.ClientShortName))
                        If .LossDateFromSpecified Then
                            cmd.AddInParameter("@LossDateFrom", SqlDbType.DateTime).Value = .LossDateFrom
                        End If
                        If .LossDateToSpecified Then
                            cmd.AddInParameter("@LossDateTo", SqlDbType.DateTime).Value = .LossDateTo
                        End If
                        cmd.AddInParameter("@IncludeClosed", SqlDbType.Int).Value = .IncludeClosedClaim
                        cmd.AddInParameter("@UserID", SqlDbType.Int).Value = _SiriusUser.UserID
                        cmd.AddInParameter("@SourceID", SqlDbType.Int).Value = iSourceId
                        cmd.AddInParameter("@TransactionType", SqlDbType.VarChar, 10).Value = String.Empty
                        If FindClaimRequest.MaxRowsToFetchSpecified = True Then
                            cmd.AddInParameter("@MaxRowsToFetch", SqlDbType.Int).Value = FindClaimRequest.MaxRowsToFetch
                        End If
                        cmd.AddInParameter("@TPA", SqlDbType.VarChar, 255).Value = FindClaimRequest.TPA
                        If FindClaimRequest.ExactClaimOnly = True Then
                            cmd.AddInParameter("@ExactClaimOnly", SqlDbType.Int).Value = 1
                        End If
                        cmd.AddInParameter("@CaseNumber", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(Cast.NullIfDefault(.CaseNumber))
                        cmd.AddInParameter("@Description", SqlDbType.VarChar, 1000).Value = FindClaimRequest.Description
                        cmd.AddInParameter("@RetrieveAssociates", SqlDbType.Int).Value = IIf(.RetrieveAssociates, 1, 0)
                        ds = con.ExecuteDataSet(cmd, "Row")
                    End Using
                End Using



            Else
                Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_find_claim_details_u")
                        cmd.AddInParameter("@ClaimNumber", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(Cast.NullIfDefault(.ClaimNumber))
                        cmd.AddInParameter("@PolicyNumber", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(Cast.NullIfDefault(.InsuranceFileRef))
                        cmd.AddInParameter("@ClientShortName", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(Cast.NullIfDefault(.ClientShortName))
                        If .LossDateFromSpecified Then
                            cmd.AddInParameter("@LossDateFrom", SqlDbType.DateTime).Value = .LossDateFrom
                        End If
                        If .LossDateToSpecified Then
                            cmd.AddInParameter("@LossDateTo", SqlDbType.DateTime).Value = .LossDateTo
                        End If
                        If FindClaimRequest.IncludeClosedClaim = False Then
                            cmd.AddInParameter("@IncludeClosed", SqlDbType.Int).Value = 1
                        Else
                            cmd.AddInParameter("@IncludeClosed", SqlDbType.Int).Value = 0
                        End If
                        cmd.AddInParameter("@UserID", SqlDbType.Int).Value = _SiriusUser.UserID
                        cmd.AddInParameter("@SourceID", SqlDbType.Int).Value = iSourceId
                        cmd.AddInParameter("@agent_group_cnt", SqlDbType.Int).Value = .AgentGroupKey
                        If FindClaimRequest.MaxRowsToFetchSpecified Then
                            cmd.AddInParameter("@MaxRowsToFetch", SqlDbType.Int).Value = FindClaimRequest.MaxRowsToFetch
                        End If
                        cmd.AddInParameter("@TPA", SqlDbType.VarChar, 255).Value = FindClaimRequest.TPA
                        cmd.AddInParameter("@CaseNumber", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(Cast.NullIfDefault(.CaseNumber))
                        cmd.AddInParameter("@Description", SqlDbType.VarChar, 1000).Value = FindClaimRequest.Description
                        cmd.AddInParameter("@AgentKey", SqlDbType.Int).Value = FindClaimRequest.AgentKey
                        cmd.AddInParameter("@RetrieveAssociates", SqlDbType.Int).Value = IIf(FindClaimRequest.RetrieveAssociates = True, 1, 0)

                        ds = con.ExecuteDataSet(cmd, "Row")
                    End Using
                End Using
            End If
        End With
        If FindClaimRequest.RetrieveAssociates Then
            AddExtraXMLElementForPolicyAssociate(ds, "AssociatedClients")
        End If
        ds.DataSetName = "BaseFindClaimResponseTypeClaims"
        If FindClaimRequest.WCFSecurityToken = "" Then
        Dim xmlDoc As New System.Xml.XmlDocument
        xmlDoc.LoadXml(ds.GetXml)
        oFindClaimResponse.ResultDataset = xmlDoc.DocumentElement()
        End If
        oFindClaimResponse.ResultData = ds
        Return oFindClaimResponse
    End Function

    Public Function GetClaimDetails(ByVal oGetClaimDetailsRequest As BaseGetClaimDetailsRequestType) _
                                                                     As BaseGetClaimDetailsResponseType
        Dim oBusiness As New CoreBusiness
        Dim oResponse As New BaseImplementationTypes.BaseGetClaimDetailsResponseType

        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection

        ' validate the data provided in the structure
        oGetClaimDetailsRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()

        ' validate the data provided in the structure
        GetClaimDetailsValidateData(oBusiness, oGetClaimDetailsRequest, oSAMErrorCollection)
        oSAMErrorCollection.CheckForErrors()

        ' Checking the Type of package we are receiving in form of request
        Dim nTypeOfPackage As CoreSAMBusiness.enumTypeOfPackage
        If oGetClaimDetailsRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetClaimDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GetClaimDetailsResponseType
        ElseIf oGetClaimDetailsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimDetailsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimDetailsResponseType
        End If

        ' Retrieve the Claim Details
        Dim dsClaimDetails As DataSet = Nothing
        Dim oClaimdetails As New BaseGetClaimDetailsTypeClaimDetails
        Dim dsClaimDetailsContacts As DataSet = Nothing
        ' Call stored proc to get Claim Details from the SP 

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Details")
                cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = oGetClaimDetailsRequest.ClaimKey
                cmd.AddInParameter("@source_id", SqlDbType.Int).Value = oGetClaimDetailsRequest.SourceId 'GetClaimDetailsRequest.BranchCode
                dsClaimDetails = con.ExecuteDataSet(cmd, "Row")
            End Using

            Dim oBaseGetClaimDetailsType As New BaseGetClaimDetailsType
            Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
            If dsClaimDetails.Tables(0).Rows.Count > 0 Then
                With oClaimdetails
                    .ClaimNumber = Cast.ToStringTrim(dr.Item("Claim_Number"))

                    .GisScreenCode = Cast.ToStringTrim(dr.Item("gis_screen_code"))
                    .ClaimKey = oGetClaimDetailsRequest.ClaimKey
                    .Description = Cast.ToString(dr.Item("Description"))
                    .ProgressStatusCode = Cast.ToString(dr.Item("Progress_Status_code"))
                    .PrimaryCauseCode = Cast.ToString(dr.Item("Primary_Cause_code").ToString)
                    .LossFromDate = Cast.ToDateTime(dr.Item("Loss_from_date"), Now)
                    .ReportedDate = Cast.ToDateTime(dr.Item("Reported_date"), Now)
                    .HandlerCode = Cast.ToString(dr.Item("Handler_code"))
                    .InfoOnly = Cast.ToBoolean(dr.Item("Info_only"), False)
                    .LikelyClaim = Cast.ToBoolean(dr.Item("Likely_claim"), False)
                    .InsuranceFileKey = Cast.ToInt32(dr.Item("policy_id"), 0)
                    .ClientShortName = Cast.ToString(dr.Item("client_short_name").ToString)
                    .SecondaryCauseCode = Cast.ToString(dr.Item("secondary_cause_code"))
                    .CatastropheCode = Cast.ToString(dr.Item("Catastrophe_code"))
                    .LossToDate = Cast.ToDateTime(dr.Item("Loss_to_date"), Now)
                    .Location = Cast.ToString(dr.Item("Location"))
                    .TownCode = Cast.ToString(dr.Item("town_code"))
                    .UserDefFldACode = Cast.ToString(dr.Item("user_defined_field_A_code"))
                    .UserDefFldBCode = Cast.ToString(dr.Item("user_defined_field_B_code"))

                    .UserDefFldCCode = Cast.ToString(dr.Item("user_defined_field_C_code"))
                    .UserDefFldDCode = Cast.ToString(dr.Item("user_defined_field_D_code"))
                    .UserDefFldECode = Cast.ToString(dr.Item("user_defined_field_E_code"))
                    .Comments = Cast.ToString(dr.Item("Comments"))
                    .ClaimVersionDescription = Cast.ToString(dr.Item("claim_version_description"))

                    .BaseClaimKey = Cast.ToInt32(dr.Item("base_claim_id"), 0)
                    .RiskKey = Cast.ToInt32(dr.Item("risk_type_id"), 0)
                    .CurrencyCode = Cast.ToString(dr.Item("currency_code"))
                    If dr.Item("underwriting_year_code") IsNot Nothing Then
                        .UnderwritingYearCode = Cast.ToString(dr.Item("underwriting_year_code").ToString)
                    End If
                    If dr.Item("underwriting_year_id") IsNot Nothing AndAlso String.IsNullOrEmpty(Convert.ToString(dr.Item("underwriting_year_id"))) = False Then
                        .UnderwritingYearId = Cast.ToInt32(dr.Item("underwriting_year_id"), 0)
                    End If
                    .ClaimVersion = Cast.ToInt32(dr.Item("version_id"), 0)
                    .ClaimStatus = Cast.ToString(dr.Item("ClaimStatusDescription"), String.Empty)
                    .ClaimStatusDate = Cast.ToDateTime(dr.Item("Claims_status_date"), Date.MinValue)
                    .LastModifiedDate = Cast.ToDateTime(dr.Item("Last_modified_date"), Date.MinValue)
                    .TPA = Cast.ToInt32(dr.Item("other_party_id"), 0)
                    .BaseCaseKey = Cast.ToInt32(dr.Item("base_case_id"), 0)

                    ' Retrieving the client details 
                    Dim oClaimPartyClientType As New BaseClaimPartyClientType
                    oClaimPartyClientType.PartyClaimNumber = Cast.ToString(dr.Item("Client_claim_number"))
                    oClaimPartyClientType.TaxRegistered = Cast.ToBoolean(dr.Item("VAT_registered"), False)
                    oClaimPartyClientType.TaxRegistrationNumber = Cast.ToString(dr.Item("VAT_reg_no"))
                    oClaimPartyClientType.PartyKey = Cast.ToInt32(dr.Item("client_id"), 0)

                    oClaimPartyClientType.PartyEmail = Cast.ToString(dr.Item("Client_email"))
                    oClaimPartyClientType.PartyFaxNo = Cast.ToString(dr.Item("Client_fax_no"))
                    oClaimPartyClientType.PartyMobileNo = Cast.ToString(dr.Item("Client_mobile_no"))
                    oClaimPartyClientType.PartyTelNo = Cast.ToString(dr.Item("Client_tel_no"))
                    oClaimPartyClientType.PartyTelNoOff = Cast.ToString(dr.Item("Client_tel_no_off"))

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_contacts_for_party")
                        cmd.AddInParameter("@Party_Cnt", SqlDbType.Int).Value = oClaimPartyClientType.PartyKey
                        dsClaimDetailsContacts = con.ExecuteDataSet(cmd, "Row")
                    End Using
                    Dim iCnt As Integer
                    Dim oClaimContactType(0) As BaseContactType
                    Dim dataViewPC As DataView = New DataView
                    With dataViewPC
                        .Table = dsClaimDetailsContacts.Tables(0)
                        .RowFilter = "contacttypecode <> 'LETTER'"
                    End With
                    With dataViewPC.ToTable
                        ReDim oClaimContactType(.Rows.Count - 1)
                        For iCnt = 0 To .Rows.Count - 1
                            oClaimContactType(iCnt) = New BaseContactType()
                            oClaimContactType(iCnt).ContactDetail = New BaseContactDetailType
                            oClaimContactType(iCnt).ContactDetail.Item = Cast.ToString(.Rows(iCnt).Item("number"))
                            Select Case Trim(.Rows(iCnt).Item("ContactTypeCode").ToString)
                                Case "E-MAIL"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.EMAIL
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.EmailAddress
                                Case "HOMEPHONE"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.HOMEPHONE
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                Case "MOBILE"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.MOBILE
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                Case "FAX"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.FAX
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                Case "WEB"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.WEB
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.EmailAddress
                                Case "MAIN"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.MAIN
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                Case "MEMAIL"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.MAINEMAILCONTACT
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.EmailAddress
                                Case "OTHER"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.OTHER
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                    oClaimContactType(iCnt).OtherContactTypeCode = "OTHER"
                                Case "LETTER"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.LETTER
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                Case "TELEPHONE"
                                    oClaimContactType(iCnt).ContactTypeCode = ContactTypeType.TELEPHONE
                                    oClaimContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                            End Select
                            oClaimContactType(iCnt).Extension = Cast.ToString(.Rows(iCnt).Item("extension"))
                            oClaimContactType(iCnt).AreaCode = Cast.ToString(.Rows(iCnt).Item("area_code").ToString)
                            oClaimContactType(iCnt).ContactTypeId = Cast.ToInt32(.Rows(iCnt).Item("contact_type_id"), 0)
                            oClaimContactType(iCnt).Description = Cast.ToString(.Rows(iCnt).Item("description").ToString)
                        Next iCnt
                    End With
                    oClaimPartyClientType.Contact = oClaimContactType
                    Dim oAddressResponseCli As New BaseGetAddressResponseType
                    Dim oAddressRequestCli As New BaseGetAddressRequestType
                    oAddressResponseCli = New BaseGetAddressResponseType
                    oAddressRequestCli.AddressKey = Cast.ToInt32(dr.Item("client_address"), 0)
                    oAddressRequestCli.BranchCode = Cast.ToString(oGetClaimDetailsRequest.BranchCode)

                    GetClaimAddress(con, oAddressRequestCli.AddressKey, oAddressResponseCli.Address)

                    ' Assigning the address Structure to the address property of claimdetails
                    oClaimPartyClientType.Address = oAddressResponseCli.Address

                    ' Assigning the party Claim Structure to the client property of claimdetails
                    oClaimdetails.Client = oClaimPartyClientType

                    ' Retrieving the Insurer details 
                    Dim oClaimPartyInsurerType As New BaseClaimPartyInsurerType
                    If Not dr.Item("Insurer_name").ToString = String.Empty Then
                        oClaimPartyInsurerType.PartyClaimNumber = Cast.ToString(dr.Item("insurer_claim_number"))
                        oClaimPartyInsurerType.ContactName = Cast.ToString(dr.Item("Insurer_Contact"))
                        oClaimPartyInsurerType.InsurerShortName = Cast.ToString(dr.Item("insurer_short_name"))

                        .InsurerName = Cast.ToString(dr.Item("Insurer_name"))


                        oClaimPartyInsurerType.InsurerContact = Cast.ToString(dr.Item("insurer_Contact"))
                        oClaimPartyInsurerType.InsurerEmail = Cast.ToString(dr.Item("insurer_email"))
                        oClaimPartyInsurerType.InsurerFaxNo = Cast.ToString(dr.Item("insurer_fax_no"))
                        oClaimPartyInsurerType.InsurerTelNo = Cast.ToString(dr.Item("insurer_tel_no"))


                        Dim oAddressResponseIns As New BaseGetAddressResponseType
                        Dim oAddressRequestIns As New BaseGetAddressRequestType
                        oAddressResponseIns = New BaseGetAddressResponseType

                        oAddressRequestIns.AddressKey = Cast.ToInt32(dsClaimDetails.Tables(0).Rows(0).Item("insurer_address"), 0)
                        oAddressRequestIns.BranchCode = oGetClaimDetailsRequest.BranchCode

                        GetClaimAddress(con, oAddressRequestIns.AddressKey, oAddressResponseIns.Address)
                        oClaimPartyInsurerType.Address = oAddressResponseIns.Address
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_contacts_for_party")
                            cmd.AddInParameter("@Party_Cnt", SqlDbType.Int).Value = 0
                            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = .InsuranceFileKey
                            cmd.AddInParameter("@TransactionMode", SqlDbType.Int).Value = 1
                            dsClaimDetailsContacts = con.ExecuteDataSet(cmd, "Row")
                        End Using

                        Dim oClaimInsurerContactType(0) As BaseContactType
                        With dataViewPC
                            .Table = dsClaimDetailsContacts.Tables(0)
                            .RowFilter = "contacttypecode <> 'LETTER'"
                        End With
                        With dataViewPC.ToTable
                            ReDim oClaimInsurerContactType(.Rows.Count - 1)
                            For iCnt = 0 To .Rows.Count - 1
                                oClaimInsurerContactType(iCnt) = New BaseContactType()
                                oClaimInsurerContactType(iCnt).ContactDetail = New BaseContactDetailType
                                oClaimInsurerContactType(iCnt).ContactDetail.Item = Cast.ToString(.Rows(iCnt).Item("number"))
                                Select Case Trim(.Rows(iCnt).Item("ContactTypeCode").ToString)
                                    Case "E-MAIL"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.EMAIL
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.EmailAddress
                                    Case "HOMEPHONE"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.HOMEPHONE
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                    Case "MOBILE"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.MOBILE
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                    Case "FAX"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.FAX
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                    Case "WEB"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.WEB
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.EmailAddress
                                    Case "MAIN"
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                    Case "MEMAIL"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.MAINEMAILCONTACT
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.EmailAddress
                                    Case "OTHER"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.OTHER
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                        oClaimInsurerContactType(iCnt).OtherContactTypeCode = "OTHER"
                                    Case "LETTER"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.LETTER
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                    Case "TELEPHONE"
                                        oClaimInsurerContactType(iCnt).ContactTypeCode = ContactTypeType.TELEPHONE
                                        oClaimInsurerContactType(iCnt).ContactDetail.ItemElementName = ItemChoiceType.Number
                                End Select
                                oClaimInsurerContactType(iCnt).Extension = Cast.ToString(.Rows(iCnt).Item("extension"))
                                oClaimInsurerContactType(iCnt).AreaCode = Cast.ToString(.Rows(iCnt).Item("area_code").ToString)
                                oClaimInsurerContactType(iCnt).ContactTypeId = CInt(.Rows(iCnt).Item("contact_type_id"))
                                oClaimInsurerContactType(iCnt).Description = Cast.ToString(.Rows(iCnt).Item("description").ToString)
                            Next iCnt
                        End With

                        oClaimPartyInsurerType.Contact = oClaimInsurerContactType

                        ' Assigning the Insurer Claim Structure to the Insurer property of claimdetails
                        oClaimdetails.Insurer = oClaimPartyInsurerType
                    End If

                    ' Assign the Claimdetails Structure to the main claim details structure
                    oBaseGetClaimDetailsType.ClaimDetails = oClaimdetails
                End With
            End If

            Dim dtPolicyoutstanding As New DataTable
            If oClaimdetails.ClaimNumber IsNot Nothing Then

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_Premium_Payment_Status")
                    cmd.AddInParameter("@claim_number", SqlDbType.VarChar, 30).Value = oClaimdetails.ClaimNumber
                    dtPolicyoutstanding = con.ExecuteDataTable(cmd)
                End Using
            End If
            If dtPolicyoutstanding IsNot Nothing AndAlso dtPolicyoutstanding.Rows.Count > 0 Then
                If ToSafeInteger(dtPolicyoutstanding.Rows(0).Item("PaidUpToDate")) = 0 OrElse ToSafeInteger(dtPolicyoutstanding.Rows(0).Item("DefaultInstalmentCnt")) > 0 Then
                    oBaseGetClaimDetailsType.ClaimDetails.IsPolicyOutstanding = True
                Else
                    oBaseGetClaimDetailsType.ClaimDetails.IsPolicyOutstanding = False
                End If
            End If

            ' Get Peril Reserves
            ' Collect all the reserves by calling the getReserves Function
            Dim aoPerils() As BaseGetClaimPerilDetailsType
            aoPerils = getPerils(con, oGetClaimDetailsRequest, oSAMErrorCollection)

            ' Map the Claim Details Structure 
            oBaseGetClaimDetailsType.ClaimDetails = oClaimdetails

            ' Map the Claim Peril structure
            oBaseGetClaimDetailsType.ClaimPeril = aoPerils

            ' Map the Complete Claim Details to oResponse object
            oResponse.ClaimDetails = oBaseGetClaimDetailsType

            Dim bIslocked As Boolean = False
            oBusiness.GetTimestamp(oGetClaimDetailsRequest.BranchCode,
                               CoreBusiness.LockName.ClaimId,
                               oResponse.ClaimDetails.ClaimDetails.BaseClaimKey,
                               oResponse.TimeStamp,
                               bIslocked)

            'Add An Exclusive Lock
           If oGetClaimDetailsRequest.ExclusiveLock Then
                AddExlusiveLock(con,
                                oBusiness,
                               CoreBusiness.LockName.ClaimId,
                                oResponse.ClaimDetails.ClaimDetails.BaseClaimKey,
                                0, oGetClaimDetailsRequest.SessionValue,
                                _SiriusUser.UserID,
                                oGetClaimDetailsRequest.BranchCode)
            End If

            Return oResponse
        End Using

    End Function

    ''' <summary>  
    '''  Retrieves reserve reinsurance recoveries details.
    ''' </summary>  
    ''' <param name="BaseGetRecoveryReinsuranceRequestType">An object of type SiriusFS.SAM.BaseImplementationTypes.BaseGetRecoveryReinsuranceRequestType</param>  
    ''' <returns>An object of type SiriusFS.SAM.BaseImplementationTypes.BaseGetRecoveryReinsuranceResponseType</returns>  
    Public Function GetRecoveryReinsurance(ByVal request As BaseGetRecoveryReinsuranceRequestType) As BaseGetRecoveryReinsuranceResponseType

        Dim oResponse As New BaseImplementationTypes.BaseGetRecoveryReinsuranceResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim oSAMErrorsCollection As New SAMErrorCollection

        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetRecoveryReinsuranceRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetRecoveryReinsuranceResponseType
        End If

        ' Structure Validation
        request.Validate(CObj(oSAMErrorsCollection))
        oSAMErrorsCollection.CheckForErrors()

        ' Lookup Codes to ensure they are valid
        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, request.BranchCode, "BranchCode", oSAMErrorsCollection)
        oSAMErrorsCollection.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsRecovery As DataSet = Nothing
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_claims_recovery_reins_select")
                cmd.AddInParameter("@peril_id", SqlDbType.Int).Value = request.ClaimPerilKey
                cmd.AddInParameter("@is_salvage", SqlDbType.Int).Value = request.IsSalvage
                dsRecovery = con.ExecuteDataSet(cmd, "Row")
            End Using
        End Using
        dsRecovery.Tables(0).Columns("recovery_id").ColumnName = "RecoveryKey"
        dsRecovery.Tables(0).Columns("description").ColumnName = "RecoveryType"
        dsRecovery.Tables(0).Columns("party_cnt").ColumnName = "PartyKey"
        dsRecovery.Tables(0).Columns("name").ColumnName = "Reinsurer"
        dsRecovery.Tables(0).Columns("this_share_percent").ColumnName = "SharePercent"
        dsRecovery.Tables(0).Columns("to_date").ColumnName = "RecoveryToDate"
        dsRecovery.Tables(0).Columns("salvage").ColumnName = "Salvage"
        dsRecovery.Tables(0).Columns("this_salvage").ColumnName = "ThisSalvage"
        dsRecovery.Tables(0).Columns("recovery").ColumnName = "Recovery"
        dsRecovery.Tables(0).Columns("this_recovery").ColumnName = "ThisRecovery"

        dsRecovery.Tables(0).Columns.Remove("is_tax_shared")
        dsRecovery.Tables(0).Columns.Remove("ri_arrangement_line_id")
        dsRecovery.Tables(0).Columns.Remove("treaty_id")
        dsRecovery.Tables(0).Columns.Remove("lower_limit")
        dsRecovery.Tables(0).Columns.Remove("line_limit")
        dsRecovery.Tables(0).Columns.Remove("type")
        dsRecovery.Tables(0).Columns.Remove("payment")

        dsRecovery.DataSetName = "BaseGetRecoveryReinsuranceResponseTypeReinsurances"
        If request.WCFSecurityToken = "" Then
        Dim xmlDoc As New System.Xml.XmlDocument
        xmlDoc.LoadXml(dsRecovery.GetXml)
        oResponse.ResultDataset = xmlDoc.DocumentElement()
        End If
        oResponse.ResultData = dsRecovery
        Return oResponse
    End Function

        Public Function GenerateClaimsDocuments(ByVal GenerateClaimsDocumentsRequest As BaseGenerateClaimsDocumentsRequestType) As BaseGenerateClaimsDocumentsResponseType

        '************************************************************************************************************
        'Const declaration
        '************************************************************************************************************
        Const ACMethodName As String = "GenerateClaimsDocuments"
        '************************************************************************************************************
        'Variable Declaration
        '************************************************************************************************************
        Dim oResponse As BaseGenerateClaimsDocumentsResponseType = Nothing
        Dim oGenerateClaimsDocuments As New BaseImplementationTypes.BaseGenerateClaimsDocumentsResponseType
        'Dim oSAMForInsuranceGenerateClaimsDocumentsRequest As SAMForInsuranceImplementationTypes.GenerateClaimsDocumentsRequestType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim oErrors As New SAMErrorCollection
        Dim iRet As Integer
        Dim sZipFilePath As String = String.Empty
        'Dim flInputFile As File
        Dim lInsuranceCnt As Integer
        Dim lPartyCnt As Integer
        Dim lProcessType As Integer
        Dim sTransactionType As String = String.Empty
        Dim lLeadAgentCnt As Integer
        Dim asDocumentArray(0) As String
        Dim sShortName As String = String.Empty
        Dim sValue As String = String.Empty
        Dim dTotalIncurred As Decimal
        Dim sTemplateCode As String = String.Empty
        Dim lDocumentTemplateId As Integer
        'Dim lSpoolNumber As Integer
        Dim lDocumentTypeId As Integer
        Dim sDescription As String = String.Empty
        'Dim sPrinterName As String = String.Empty
        Dim lInsuranceFolderCnt As Integer
        Dim lSourceID As Integer
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim sMergedFilePath As String = ""
        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection

        Using con As SiriusConnection = New SiriusConnectionPMDAO(_SiriusUser.Username, _SiriusUser.SourceID, _SiriusUser.LanguageID, "test")
            If GenerateClaimsDocumentsRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GenerateClaimsDocumentsRequestType) Then
                nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
                oResponse = New SAMForInsuranceImplementationTypes.GenerateClaimsDocumentsResponseType
            ElseIf GenerateClaimsDocumentsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GenerateClaimsDocumentsRequestType) Then
                nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
                oResponse = New SAMForInsuranceV2ImplementationTypes.GenerateClaimsDocumentsResponseType
            End If
            '*********************
            ' STRUCTURE VALIDATION 
            '*********************
            ' validate the mandatory structure data
            GenerateClaimsDocumentsRequest.Validate(CType(oSAMErrorCollection, Object))
            ' if there were any errors throw an exception
            oSAMErrorCollection.CheckForErrors()
            '*********************
            ' DATA VALIDATION 
            '*********************
            ' validate the data provided in the structure
            GenerateClaimDocumentsValidateData(con, oCoreBusiness, GenerateClaimsDocumentsRequest, oSAMErrorCollection)
            oSAMErrorCollection.CheckForErrors()

            ' Dataset that will hold the returned results		
            Dim ds As DataSet = Nothing
            Dim status As Boolean

            If Not (String.IsNullOrEmpty(GenerateClaimsDocumentsRequest.BranchCode)) Then
                Try

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Document_Generated_Status")
                        cmd.AddInParameter("@ClaimKey", SqlDbType.Int).Value = Cast.ToInt32(GenerateClaimsDocumentsRequest.ClaimKey).GetValueOrDefault(0)
                        Try
                            ds = con.ExecuteDataSet(cmd, "DocumentStatus")
                            status = Cast.ToBoolean(ds.Tables(0).Rows(0).Item("document_generated_status"), False)
                        Catch ex As Exception
                            ds = Nothing
                        End Try
                    End Using
                    ' if the claim documents have already been produced
                    If status Then
                        ' raise a business rule error - as this should only occur once
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.ClaimDocumentsAlreadyProduced,
                        SAMBusinessErrors.ClaimDocumentsAlreadyProduced.ToString)
                        oSAMErrorCollection.CheckForErrors()
                    Else

                        Using cmd1 As SiriusCommand = SiriusCommand.FromProcedure("spu_get_claim_clipol_id")
                            cmd1.AddInParameter("@Claim_id", SqlDbType.Int).Value = GenerateClaimsDocumentsRequest.ClaimKey
                            ds = con.ExecuteDataSet(cmd1, "Row")
                            lInsuranceCnt = Cast.ToInt32(ds.Tables(0).Rows(0).Item("insurance_file_cnt")).GetValueOrDefault(0)
                            lPartyCnt = Cast.ToInt32(ds.Tables(0).Rows(0).Item("insured_cnt")).GetValueOrDefault(0)
                            lLeadAgentCnt = Cast.ToInt32(ds.Tables(0).Rows(0).Item("lead_agent_cnt")).GetValueOrDefault(0)
                            sShortName = Cast.ToString(ds.Tables(0).Rows(0).Item("Shortname"))
                            dTotalIncurred = Cast.ToDecimal(ds.Tables(0).Rows(0).Item("total_incurred"), 0)
                            lInsuranceFolderCnt = Cast.ToInt32(ds.Tables(0).Rows(0).Item("Insurance_folder_cnt")).GetValueOrDefault(0)
                            lProcessType = SIRDocTypeClaims 'claim documents CLM
                            sTransactionType = GenerateClaimsDocumentsRequest.TransactionType
                        End Using

                        'Check transaction type
                        Select Case sTransactionType.Trim().Substring(sTransactionType.Length - 2)
                            Case SIRTransactionCodeClaimOpen,
                                SIRTransactionCodeClaimRevision

                                ' Check if we have a lead agent cnt, if not then must be direct business
                                If lLeadAgentCnt <> 0 Then
                                    ' AGENT so notify agent
                                    asDocumentArray(UBound(asDocumentArray)) = "CA"
                                Else
                                    ' DIRECT business so only notify client
                                    asDocumentArray(UBound(asDocumentArray)) = "CC"
                                End If

                                ' Now add transaction type for the claim jacket, always required
                                ReDim Preserve asDocumentArray(UBound(asDocumentArray) + 1)
                                asDocumentArray(UBound(asDocumentArray)) = "CJ"

                                ' Only remains for the reinsurance documentation to be checked.
                                ' A loss advice needs to be produced for reinsurers and if claim is for
                                ' over a specified amount then a large loss advice is produced instead
                                If sShortName.TrimEnd().Length <> 0 Then 'We have a reinsurer who is not RETAINED

                                    'This means reinsurance records exist for claim on claim_party table
                                    'other than 100% RETAINED
                                    ReDim Preserve asDocumentArray(UBound(asDocumentArray) + 1)

                                    'Get the Source Id from source code
                                    lSourceID = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, GenerateClaimsDocumentsRequest.BranchCode, "BranchCode", oSAMErrorCollection) ' Change

                                    ' We have reinsurance on the claim, now need to check if total
                                    ' claim exceeds specified limit
                                    Using cmd2 As SiriusCommand = SiriusCommand.FromProcedure("spu_get_system_options")
                                        'Create GetProductRiskOptions request
                                        Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType

                                        'Get the product id
                                        Dim dsProductId As DataSet = Nothing
                                        Dim iProductId As Integer
                                        'Getting the product id from insurance file count 
                                        GetInsFileCntProductId(con:=con,
                                                                lInsuranceFileCnt:=0,
                                                                dsProductId:=dsProductId,
                                                                lBaseClaimID:=GenerateClaimsDocumentsRequest.ClaimKey)
                                        If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
                                        AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso dsProductId.Tables(0).Rows(0).Item("product_id") IsNot Nothing AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
                                            iProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
                                        Else
                                            'Failed to get the product id from the given base claim key
                                            oSAMErrorCollection.AddInvalidData(
                                                                    SAMConstants.SAMInvalidData.GeneralFailure,
                                                                    "Failed to get product details for the given policy")

                                            oSAMErrorCollection.CheckForErrors()
                                        End If

                                        'GenerateClaimDocumentRILimit in System options has been changed to ClaimValueForLargeLossAdvice in ProductRiskOptions
                                        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.ClaimValueForLargeLossAdvice

                                        sValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
                                    End Using
                                    If Not (String.IsNullOrEmpty(sValue)) Then

                                        If Not String.IsNullOrEmpty(CStr(dTotalIncurred)) Then
                                            If dTotalIncurred >= Decimal.Parse(sValue, Globalization.NumberStyles.Currency, Globalization.CultureInfo.InvariantCulture) Then
                                                asDocumentArray(UBound(asDocumentArray)) = "LL"
                                            Else
                                                asDocumentArray(UBound(asDocumentArray)) = "LA"
                                            End If
                                        Else
                                            asDocumentArray(UBound(asDocumentArray)) = "LA"
                                        End If
                                    Else
                                        asDocumentArray(UBound(asDocumentArray)) = "LA"
                                    End If
                                End If

                            Case SIRTransactionCodeClaimPaid

                                ' Claim payment advice - always required
                                asDocumentArray(UBound(asDocumentArray)) = "CP"

                                ReDim Preserve asDocumentArray(UBound(asDocumentArray) + 1)

                                ' Cheque requisition form - always required
                                asDocumentArray(UBound(asDocumentArray)) = "CQ"

                                ReDim Preserve asDocumentArray(UBound(asDocumentArray) + 1)

                                ' Claim Acceptance form - always required
                                asDocumentArray(UBound(asDocumentArray)) = "AF"

                                ' Check if reinsurer payment advice is required

                                If RTrim(sShortName) <> "" Then 'We a have reinsurer who is not RETAINED
                                    'This means reinsurance records exist for claim on claim_party table
                                    ReDim Preserve asDocumentArray(UBound(asDocumentArray) + 1)
                                    asDocumentArray(UBound(asDocumentArray)) = "NT"
                                End If

                                ' Check if we have a lead agent cnt
                                If lLeadAgentCnt > 0 Then
                                    ' AGENT so produce advice slip to agent
                                    ReDim Preserve asDocumentArray(UBound(asDocumentArray) + 1)
                                    asDocumentArray(UBound(asDocumentArray)) = "AS"
                                End If

                            Case Else

                                Return oResponse

                        End Select

                        'Now after getting transaction types we need to find out document template code

                        Dim oGIS As bGIS.STS = Nothing
                        Dim oDatabase As Object = Nothing
                        oDatabase = con.PMDAODatabase

                        Try
                            oGIS = New bGIS.STS
                        Catch ex As Exception
                            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToCreateBackofficeComponent, "Failed to create bGIS.Application", ex.Message)
                            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "CreatebGISSTS", True)
                            Return oResponse
                        End Try

                        Try
                            iRet = oGIS.Initialise(sUserName:=_SiriusUser.Username,
                                                   sPassword:=_SiriusUser.Password,
                                                   iUserID:=CInt(_SiriusUser.UserID),
                                                   iSourceID:=CInt(_SiriusUser.SourceID),
                                                   iLanguageID:=CInt(_SiriusUser.LanguageID),
                                                   iCurrencyID:=CInt(_SiriusUser.CurrencyID),
                                                   iLogLevel:=SiriusUserDefaults.LogLevel,
                                                   sCallingAppName:=ACMethodName,
                                                   vDatabase:=oDatabase)
                        Catch ex As Exception
                            If oGIS IsNot Nothing Then
                                oGIS.Dispose()
                                oGIS = Nothing
                            End If
                            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.FailedToInitialiseBackofficeComponent, "Failed to initialise bGIS.Application", ex.Message)
                            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "oGIS.Initialise", True)
                            Return oResponse
                        End Try

                        If (iRet <> 1) Then
                            If oGIS IsNot Nothing Then
                                oGIS.Dispose()
                                oGIS = Nothing
                            End If
                            Dim STSError2 As New STSErrorPublisher(iRet, "Failed to initialise GIS")
                            STSError2.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "GISInitialise", True)
                        End If

                        sZipFilePath = String.Empty
                        'Document Generation
                        Dim lDocCount As Integer = 0
                        'Dim count As Integer
                        Dim lReportPtr As Integer
                        oResponse.Documents = New BaseImplementationTypes.BaseGenerateClaimsDocumentsResponseTypeDocuments

                        For icount As Integer = 0 To UBound(asDocumentArray)
                            If asDocumentArray(icount) <> String.Empty Then
                                sTransactionType = asDocumentArray(icount)
                                sTemplateCode = "CLM" & sTransactionType  ' Generating Document template
                                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Product_id_sel")
                                    cmd.AddInParameter("@lInsuranceFileCnt", SqlDbType.Int).Value = lInsuranceCnt
                                    ds = con.ExecuteDataSet(cmd, "ReportPointer")
                                    lReportPtr = Cast.ToInt32(ds.Tables(0).Rows(0).Item("report_pointer")).GetValueOrDefault(0)
                                    If (lReportPtr <> 0) Then
                                        sTemplateCode = sTemplateCode & CStr(lReportPtr)
                                    End If
                                    Using cmd1 As SiriusCommand = SiriusCommand.FromProcedure("spu_get_document_template_saa")
                                        cmd1.AddInParameter("@Code", SqlDbType.VarChar, 30).Value = sTemplateCode
                                        cmd1.AddOutParameter("@document_template_id", SqlDbType.Int)
                                        cmd1.AddOutParameter("@document_type_id", SqlDbType.Int)
                                        cmd1.AddOutParameter("@description", SqlDbType.VarChar, 30)

                                        con.ExecuteNonQuery(cmd1)
                                        lDocumentTemplateId = Cast.ToInt32((cmd1.Parameters("@document_template_id").Value)).GetValueOrDefault(0)
                                        lDocumentTypeId = Cast.ToInt32((cmd1.Parameters("@document_type_id").Value)).GetValueOrDefault(0)
                                        If (cmd1.Parameters("@description").Value) IsNot DBNull.Value Then
                                            sDescription = Cast.ToString(cmd1.Parameters("@description").Value)
                                        Else
                                            sDescription = String.Empty
                                        End If
                                    End Using
                                End Using

                                ReDim Preserve oResponse.Documents.Row(lDocCount)
                                oResponse.Documents.Row(lDocCount) = New BaseGenerateClaimsDocumentsResponseTypeDocumentsRow
                                oResponse.Documents.Row(lDocCount).DocumentDescription = sDescription
                                oResponse.Documents.Row(lDocCount).DocumentName = sTemplateCode
                                lDocCount += 1

                                Dim oMergedFilePath As Object = sMergedFilePath
                                Dim oZipFilePath As Object = sZipFilePath
                                iRet = oGIS.GenerateDocument(
                                                        v_sDocumentTemplateCode:=sTemplateCode,
                                                        v_lMode:=GenerateClaimsDocumentsRequest.Mode,
                                                        v_lPartyCnt:=CInt(lPartyCnt),
                                                        v_lInsuranceFolderCnt:=CInt(lInsuranceFolderCnt),
                                                        v_lInsuranceFileCnt:=CInt(lInsuranceCnt),
                                                        v_sParameterXML:=GenerateClaimsDocumentsRequest.ParameterXML,
                                                        v_bOutputAsHTML:=GenerateClaimsDocumentsRequest.OutputAsHTML,
                                                        r_sMergedFilePath:=CStr(oMergedFilePath),
                                                        r_sSpooledFilePath:=CStr(oZipFilePath),
                                                        v_bOutputAsPDF:=GenerateClaimsDocumentsRequest.OutputAsPDF,
                                                        v_lClaimKey:=GenerateClaimsDocumentsRequest.ClaimKey)
                            End If
                        Next icount

                        If iRet <> 1 Then
                            Dim STSErrorEx As New STSErrorPublisher(STSErrorCodes.GeneralFailure, "bGis.Application.GeneratePolicyDocument returned an ErrorCode", "")
                            STSErrorEx.SetContext(oResponse.STSError, HttpContext.Current.Request.Url.ToString(), ACMethodName, "", True)
                            Return oResponse
                        End If

                        Try
                            If oGIS IsNot Nothing Then
                                oGIS.Dispose()
                            oGIS = Nothing
                            End If
                        Catch ex As Exception
                            Dim STSErrorEx As New STSErrorPublisher("Failed to terminate business", ex)
                            STSErrorEx.Raise(HttpContext.Current.Request.Url.ToString(), ACMethodName, "Terminate", True)
                        End Try

                        'set value of Document_generated_status field to 1 as soon as it produce document
                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Set_Document_Generated_Status")
                            cmd.AddInParameter("@ClaimKey", SqlDbType.Int).Value = GenerateClaimsDocumentsRequest.ClaimKey
                            cmd.AddInParameter("@documentGeneratedStatus", SqlDbType.Bit).Value = 1
                            con.ExecuteNonQuery(cmd)
                        End Using

                    End If

                Catch ex As Exception
                    Handler.BusinessLayerBoundary(ex, oResponse)
                End Try
            End If
        End Using
        Return oResponse
    End Function

        Public Function SaveRisk(ByVal SaveRiskRequest As BaseSaveRiskRequestType) As BaseSaveRiskResponseType

            Dim oSaveRiskResponse As New BaseImplementationTypes.BaseSaveRiskResponseType
            Dim oCoreBusiness As New CoreBusiness
            Dim iSourceId As Integer
            Dim nTypeOfPackage As enumTypeOfPackage
        Dim sDataModelCode As String = String.Empty
            Dim sXMLDataset As String = String.Empty

            Dim oErrors As New SAMErrorCollection

        Using con As SiriusConnection = New SiriusConnectionPMDAO(_SiriusUser.Username, _SiriusUser.SourceID, _SiriusUser.LanguageID, "test")
            'Write Away Data and Generate return Values (if rules to be ran).
            Dim oSaveToDBRequest As New SaveToDBIn
            Dim oSaveToDBResponse As SaveToDBOut

            If SaveRiskRequest.GetType Is GetType(BaseImplementationTypes.BaseSaveRiskRequestType) Then
                nTypeOfPackage = enumTypeOfPackage.UnknownPackage
                oSaveRiskResponse = New BaseImplementationTypes.BaseSaveRiskResponseType
            ElseIf SaveRiskRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.SaveRiskRequestType) Then
                nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
                oSaveRiskResponse = New SAMForInsuranceImplementationTypes.SaveRiskResponseType
            ElseIf SaveRiskRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.SaveRiskRequestType) Then
                nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
                oSaveRiskResponse = New SAMForInsuranceV2ImplementationTypes.SaveRiskResponseType
            Else
                nTypeOfPackage = enumTypeOfPackage.UnknownPackage
                Return Nothing
            End If

            'Check Mandatory Fields
            If String.IsNullOrEmpty(SaveRiskRequest.BranchCode) Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "BranchCode", SaveRiskRequest.BranchCode)
            End If

            If String.IsNullOrEmpty(SaveRiskRequest.XMLDataSet) Then
                ' XMLDataSet not set
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "XMLDataSet", SaveRiskRequest.XMLDataSet)
            End If

            If SaveRiskRequest.InsuranceFileKey = 0 Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "InsuranceFileKey", SaveRiskRequest.InsuranceFileKey.ToString)
            End If

            If SaveRiskRequest.InsuranceFolderKey = 0 Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "InsuranceFolderKey", SaveRiskRequest.InsuranceFolderKey.ToString)
            End If

            If SaveRiskRequest.RiskKey = 0 Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "RiskKey", SaveRiskRequest.RiskKey.ToString)
            End If

            If SaveRiskRequest.QuoteTimeStamp Is Nothing Then
                oErrors.AddInvalidData(SAMInvalidData.MandatoryInputMissing, SAMInvalidData.MandatoryInputMissing.ToString, "QuoteTimeStamp")
            End If

            ' exit if there are any missing parameters
            oErrors.CheckForErrors()

            iSourceId% = 1
            ' Convert branch code to ID
            Try
                iSourceId% = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, "Source", SaveRiskRequest.BranchCode, "BranchCode")
            Catch ex As Exception
                oErrors.AddInvalidData(SAMInvalidData.InvalidLookupListValue, SAMInvalidData.InvalidLookupListValue.ToString, "BranchCode", SaveRiskRequest.BranchCode)
            End Try

            Try
                Dim xmlDocTest As New System.Xml.XmlDocument
                xmlDocTest.LoadXml(SaveRiskRequest.XMLDataSet)
                sDataModelCode = xmlDocTest.SelectSingleNode("DATA_SET").Attributes("DataModelCode").Value.ToUpper
            Catch ex As Exception
                oErrors.AddInvalidData(SAMInvalidData.ValidationRulesFailed, "XmlDataSet is not in valid format.", "XmlDataSet", SaveRiskRequest.XMLDataSet)
            End Try

            ' Check the insurance file cnt is valid
            Dim iFileFolderCnt As Integer

            ' Check the insurance folder cnt/insurance file cnt is valid
            If oCoreBusiness.CheckInsuranceParams(con:=con, nInsurancefolderCnt:=SaveRiskRequest.InsuranceFolderKey,
                                                          nInsuranceFileCnt:=SaveRiskRequest.InsuranceFileKey,
                                                         nRiskCnt:=SaveRiskRequest.RiskKey, r_nInsuranceFolderCnt:=iFileFolderCnt) = False Then

                oErrors.AddInvalidData(SAMInvalidData.ValidationRulesFailed, "Validation failed", "The InsuranceFolder/InsuranceFile/Risk record does not exist for:  Insurance Folder" & SaveRiskRequest.InsuranceFolderKey & " , Insurance File : " & SaveRiskRequest.InsuranceFileKey & " , Risk cnt = " & SaveRiskRequest.RiskKey)
            End If

            If iFileFolderCnt <> SaveRiskRequest.InsuranceFolderKey Then
                oErrors.AddInvalidData(SAMInvalidData.ValidationRulesFailed, "Insurance File validation failed.", "InsuranceFileKey", SaveRiskRequest.InsuranceFileKey.ToString)
            End If


            oErrors.CheckForErrors()

            'Check that the timestamp matches and lock the Quote
            Try
                oCoreBusiness.CheckSAMTSAndLock(Con:=con,
                    BranchCode:=SaveRiskRequest.BranchCode,
                    Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                    LockValue:=SaveRiskRequest.InsuranceFolderKey,
                TStamp:=SaveRiskRequest.QuoteTimeStamp)

            oSaveToDBRequest.BusinessTypeCode = "NB"
            oSaveToDBRequest.DataModelCode = sDataModelCode
            ClearRiskOutput(sDataModelCode, SaveRiskRequest.XMLDataSet)
            oSaveToDBRequest.XMLDataset = SaveRiskRequest.XMLDataSet

            oSaveToDBResponse = oCoreBusiness.SaveToDB(con, oSaveToDBRequest)

            oSaveRiskResponse.XMLDataSet = oSaveToDBResponse.XMLDataset
            oSaveRiskResponse.RiskTypeID = GetAndValidateSpecifiedTableCode(con, "risk", "risk_type_id", "risk_cnt", SaveRiskRequest.RiskKey.ToString, oErrors, "risk_cnt")
            oSaveRiskResponse.BranchID = iSourceId
            SAMErrorCollection.CheckForErrorsFromSTS(oSaveRiskResponse.Errors)
            Catch ex As Exception

                Throw

            Finally
            ' Unlock and return the new timestamp
                oCoreBusiness.UnlockAndGetSAMTS(Con:=con,
                    BranchCode:=SaveRiskRequest.BranchCode,
                    Lockname:=CoreBusiness.LockName.InsuranceFolderCnt,
                    LockValue:=SaveRiskRequest.InsuranceFolderKey,
                TStamp:=oSaveRiskResponse.QuoteTimeStamp)
            End Try
        End Using

        Return oSaveRiskResponse
        End Function

