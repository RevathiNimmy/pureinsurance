                cmd.AddInParameter("@policy_deductible_id", SqlDbType.Int).Value = SqlInt32.Null
                cmd.AddInParameter("@non_standard_excess", SqlDbType.Money).Value = SqlMoney.Null
                cmd.AddInParameter("@subsidiary_company_name", SqlDbType.VarChar, 255).Value = Nothing
                cmd.AddInParameter("@created_by_id", SqlDbType.Int).Value = _SiriusUser.UserID
                cmd.AddInParameter("@claim_handled", SqlDbType.Int).Value = SqlInt32.Null
                cmd.AddInParameter("@tpa", SqlDbType.Int).Value = oOpenClaimRequest.Claim.TPA
                cmd.AddOutParameter("@claim_id", SqlDbType.Int)

             

                con.ExecuteNonQuery(cmd)

                ' return the claim id
                oOpenClaimRequest.Claim.ClaimId = Cast.ToInt32(cmd.Parameters("@claim_id")).GetValueOrDefault(0)

            End Using

        Catch ex As Exception
            Debug.WriteLine(ex.Message)
            Throw
        End Try
    End Sub

    ''' <summary>
    ''' AddClaimAddress - Insurer / Client
    ''' </summary>
    ''' <param name="OpenClaimRequest"></param>
    ''' <remarks></remarks>
    Private Function AddClaimAddress(
                                ByRef con As SiriusConnection,
                                ByRef oBusiness As CoreBusiness,
                                ByVal SourceCode As String,
                                ByVal Address As BaseAddressType) As Integer

        Try

            ' add the claim address
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_Address_add")

                cmd.AddInParameter("@source_id", SqlDbType.Int).Value = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, SourceCode, "BranchCode")
                cmd.AddInParameter("@address1", SqlDbType.VarChar, 60).Value = Address.AddressLine1
                cmd.AddInParameter("@address2", SqlDbType.VarChar, 60).Value = Address.AddressLine2
                cmd.AddInParameter("@address3", SqlDbType.VarChar, 60).Value = Address.AddressLine3
                cmd.AddInParameter("@address4", SqlDbType.VarChar, 60).Value = Address.AddressLine4
                cmd.AddInParameter("@postal_code", SqlDbType.VarChar, 20).Value = Address.PostCode
                cmd.AddInParameter("@country_id", SqlDbType.Int).Value = Address.CountryId

                cmd.AddInParameter("@created_by_id", SqlDbType.Int).Value = _SiriusUser.UserID
                cmd.AddInParameter("@date_created", SqlDbType.DateTime).Value = Date.Now
                cmd.AddInParameter("@modified_by_id", SqlDbType.Int).Value = _SiriusUser.UserID
                cmd.AddInParameter("@last_modified", SqlDbType.DateTime).Value = Date.Now
                cmd.AddInParameter("@address_usage_type_id", SqlDbType.Int).Value = Address.AddressTypeCode
                cmd.AddInParameter("@update_address", SqlDbType.Bit).Value = 0
                cmd.AddInParameter("@address_id", SqlDbType.Int).Value = 0

                cmd.AddOutParameter("@address_cnt", SqlDbType.Int)

                con.ExecuteNonQuery(cmd)

                ' return the address cnt
                Return CType(cmd.Parameters("@address_cnt").Value, Integer)

            End Using
        Catch ex As Exception
            Debug.Write(ex.Message)
            Throw
        End Try
    End Function

