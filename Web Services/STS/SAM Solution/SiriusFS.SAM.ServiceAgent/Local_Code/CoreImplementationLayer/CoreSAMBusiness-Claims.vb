        ' claim payment
        ClaimPayment.ClaimId = ClaimReceipt.ClaimId
        ClaimPayment.ClaimPerilId = ClaimReceipt.ClaimPerilId
        ClaimPayment.TransactionDate = ClaimReceipt.TransactionDate
        ClaimPayment.TotCurrAmount = Insurer.ThisRecoverySplitAmount
        ClaimPayment.TotTaxAmount = Insurer.ThisRecoverySplitTaxAmount
        ClaimPayment.TotTaxWHTAmount = 0
        ClaimPayment.PartyKey = Insurer.PartyCnt
        ClaimPayment.TreatyId = Insurer.TreatyId
        ClaimPayment.CurrencyId = ClaimReceipt.CurrencyId

        ' set in order to override payment party type being defaulted to 1
        ClaimPayment.PaymentToReinsurer = True

        ClaimPayment.PaymentPartyType = Nothing
        ClaimPayment.Comments = Nothing
        ClaimPayment.IsReferred = Nothing
        ClaimPayment.SequenceNo = Nothing
        ClaimPayment.DocumentId = Nothing
        ClaimPayment.TotExcessAmount = Nothing

        ' advanced tax
        ClaimPayment.AdvancedTaxDetails = Nothing

        ' payee
        Dim Payee As New BaseClaimPayeeType

        Payee.TheirReference = Nothing
        Payee.MediaTypeId = ToSafeInteger(ClaimReceipt.Payee.MediaTypeId)
        Payee.Name = Cast.NullIfDefault(ClaimReceipt.Payee.Name, String.Empty)
        Payee.BankName = Cast.NullIfDefault(ClaimReceipt.Payee.BankName, String.Empty)
        Payee.BankCode = Cast.NullIfDefault(ClaimReceipt.Payee.BankCode, String.Empty)
        Payee.BankNumber = Cast.NullIfDefault(ClaimReceipt.Payee.BankNumber, String.Empty)
        Payee.Comments = Cast.NullIfDefault(ClaimReceipt.Payee.Comments, String.Empty)
        Payee.MediaReference = Cast.NullIfDefault(ClaimReceipt.Payee.MediaReference, String.Empty)
        ClaimPayment.Payee = Payee

        ' payee address
        ClaimPayment.Payee.Address = Nothing

        ' claim payment item
        ClaimPaymentItem.RecoveryId = ClaimReceiptItem.RecoveryId
        ClaimPaymentItem.RecoveryTypeId = ClaimReceiptItem.RecoveryTypeId
        ClaimPaymentItem.CurrencyAmount = Insurer.ThisRecoverySplitAmount
        ClaimPaymentItem.TaxAmount = Insurer.ThisRecoverySplitTaxAmount
        ClaimPaymentItem.ReserveId = Nothing
        ClaimPaymentItem.TaxGroupId = Nothing
        ClaimPaymentItem.TaxAmountWHT = Nothing

        ' claim payment  rates
        ClaimPayment.ExgRateReasonId = Nothing
        ClaimPayment.CurrencyToBaseXRate = ClaimReceipt.CurrencyToBaseXRate
        ClaimPayment.CurrencyToBaseDate = ClaimReceipt.CurrencyToBaseDate
        ClaimPayment.AccountToBaseXRate = ClaimReceipt.AccountToBaseXRate
        ClaimPayment.AccountToBaseDate = ClaimReceipt.AccountToBaseDate
        ClaimPayment.SystemToBaseXRate = ClaimReceipt.SystemToBaseXRate
        ClaimPayment.SystemToBaseDate = ClaimReceipt.SystemToBaseDate
        ClaimPayment.PaymentToLossXRate = ClaimReceipt.ReceiptToLossXRate
        ClaimPaymentItem.PaymentAdjustment = Nothing

        ClaimPaymentRequest = Request

    End Sub

