        ' set claim status to closed
        Dim lClosedClaimStatusId As Integer = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.ClaimStatus, ClaimStatus.Closed, "ClaimStatusCode")
        UpdateClaimStatus(con, oRequest.Claim.ClaimId, lClosedClaimStatusId)

