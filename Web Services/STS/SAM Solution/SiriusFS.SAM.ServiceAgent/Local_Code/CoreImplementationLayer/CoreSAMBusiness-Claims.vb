    Private Sub UpdatePaymentValidateClaimPaymentStandardLookup(
                       ByVal oClaimPayment As BaseClaimPaymentType,
                       ByVal oSAMErrorCollection As SAMErrorCollection,
                       ByVal oBusiness As CoreBusiness, ByVal sBranchCode As String, ByRef r_iSourceId As Integer)
        ' Mandatory Fields in the Structure--------------------------------------
        ' branch code
        oClaimPayment.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, sBranchCode, "BranchCode", oSAMErrorCollection)
        r_iSourceId = oClaimPayment.SourceId

        '' Currency Code
        oClaimPayment.CurrencyId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, oClaimPayment.CurrencyCode, "CurrencyCode", oSAMErrorCollection)

        '' TaxGroupCode
        If oClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For cntTax As Integer = oClaimPayment.ClaimPaymentItem.GetLowerBound(0) To oClaimPayment.ClaimPaymentItem.GetUpperBound(0)
                If Not oClaimPayment.ClaimPaymentItem(cntTax).TaxGroupCode = Nothing Then
                    oClaimPayment.ClaimPaymentItem(cntTax).TaxGroupId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.TaxGroup, oClaimPayment.ClaimPaymentItem(cntTax).TaxGroupCode, "TaxGroupCode", oSAMErrorCollection)  ' CHECK IN
                End If
            Next
        End If

        ' Optional Fields In Structure
        ' Safe Harbour
        If oClaimPayment.AdvancedTaxDetails IsNot Nothing Then
            If String.IsNullOrEmpty(oClaimPayment.AdvancedTaxDetails.SafeHarbourCode) = False Then
                oClaimPayment.AdvancedTaxDetails.SafeHarbourID = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.SafeHarbour, oClaimPayment.AdvancedTaxDetails.SafeHarbourCode, "SafeHarbourCode", oSAMErrorCollection)  ' CHECK IN
            End If
        End If

        ' Media Type Code
        If oClaimPayment.Payee IsNot Nothing Then
            If String.IsNullOrEmpty(oClaimPayment.Payee.MediaTypeCode) = False Then
                oClaimPayment.Payee.MediaTypeId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.MediaType, oClaimPayment.Payee.MediaTypeCode, "MediaTypeCode", oSAMErrorCollection)
            End If

            ' Country Code
            If oClaimPayment.Payee.Address IsNot Nothing Then
                If String.IsNullOrEmpty(oClaimPayment.Payee.Address.CountryCode) = False Then
                    oClaimPayment.Payee.Address.CountryId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Country, oClaimPayment.Payee.Address.CountryCode, "CountryCode", oSAMErrorCollection)
                End If
            End If
        End If
    End Sub

    Private Sub UpdatePaymentValidateClaimPaymentData(ByVal con As SiriusConnection,
                       ByVal oClaimPayment As BaseClaimPaymentType,
                       ByVal oSAMErrorCollection As SAMErrorCollection,
                       ByVal oBusiness As CoreBusiness)
        ' validate claim payment data links
        UpdatePaymentClaimPaymentValidateDataLinks(con, oClaimPayment,
                                        oSAMErrorCollection)

        ' Validate Base Claim  Key 
        ValidateBaseClaimKey(CInt(oClaimPayment.BaseClaimKey),
                                        oSAMErrorCollection, oBusiness, con)

        ' Validate Base Claim Peril Key
        ValidateBaseClaimPerilKey(CInt(oClaimPayment.BaseClaimPerilKey),
                                        oSAMErrorCollection, oBusiness, con)

        ' Validate Base base reserve Key
        If oClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For icount As Integer = oClaimPayment.ClaimPaymentItem.GetLowerBound(0) To oClaimPayment.ClaimPaymentItem.GetUpperBound(0)
                ValidateBaseReserveKey(con, CInt(oClaimPayment.ClaimPaymentItem(icount).BaseReserveKey),
                                            CInt(oClaimPayment.BaseClaimPerilKey),
                                            oSAMErrorCollection)
            Next
        End If

        ' Validate Advanced Tax Scripts Data
        If oClaimPayment.AdvancedTaxDetails IsNot Nothing Then
            ValidatePercentageFields(oClaimPayment.AdvancedTaxDetails.InsuredPercentage,
                                            oClaimPayment.AdvancedTaxDetails.PayeePercentage,
                                            oSAMErrorCollection)
        End If

        Dim oClaimDetails As BaseAdditionalClaimRelatedDetails = Nothing
        ' get details for the claim 
        GetClaimDetailsForPaymentOrReceipt(con,
                oClaimPayment.ClaimId,
                oClaimPayment.ClaimPerilId,
                oClaimDetails)

        ValidateClaimPaymentPayeeInformation(oClaimDetails, oClaimPayment.PartyKey,
                    oClaimPayment.PaymentPartyType, oSAMErrorCollection)

        ' determine whether is withholding tax 
        UpdatePaymentValidateClaimPaymentTaxGroup(con, oClaimPayment, oSAMErrorCollection)
    End Sub

    Private Sub UpdatePaymentClaimPaymentValidateDataLinks(
   ByVal con As SiriusConnection,
   ByVal oClaimPayment As BaseClaimPaymentType,
   ByVal oSAMErrorCollection As SAMErrorCollection)
        If oClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For Each oClaimPaymentItem As BaseClaimPaymentItemType In oClaimPayment.ClaimPaymentItem
                If oClaimPaymentItem IsNot Nothing Then
                    Dim dt As DataTable = Nothing

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Validate_Claim_Payment_Data_Links")

                        cmd.AddInParameter("@base_claim_id", SqlDbType.Int).Value = oClaimPayment.BaseClaimKey
                        cmd.AddInParameter("@base_claim_peril_id", SqlDbType.Int).Value = oClaimPayment.BaseClaimPerilKey
                        cmd.AddInParameter("@base_reserve_id", SqlDbType.Int).Value = oClaimPaymentItem.BaseReserveKey

                        dt = con.ExecuteDataTable(cmd)

                    End Using

                    If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                        Dim dr As DataRow = dt.Rows(0)

                        ' only get the results for claim / claim peril once 
                        If oClaimPayment.ClaimId = 0 Then

                            ' use the latest version of the links before we create a new copy
                            oClaimPayment.ClaimId = Cast.ToInt32(dr.Item("claim_id"), 0)
                            oClaimPayment.ClaimPerilId = Cast.ToInt32(dr.Item("claim_peril_id"), 0)

                        End If

                        ' use the latest version of the links before we create a new copy 
                        oClaimPaymentItem.ReserveId = Cast.ToInt32(dr.Item("reserve_id"), 0)

                    Else

                        oSAMErrorCollection.AddInvalidData(SAMInvalidData.ClaimReceiptInvalidDataLinksProvidedNoLinkExistsBetweenClaimAndClaimPerilAndRecovery,
                                         SAMInvalidData.ClaimReceiptInvalidDataLinksProvidedNoLinkExistsBetweenClaimAndClaimPerilAndRecovery.ToString(),
                                         "BaseClaimKey And BaseClaimPerilKey And BaseRecoveryKey",
                                         "BaseClaimKey:-" & oClaimPayment.BaseClaimKey & ": BaseCLaimPerilKey:-" & oClaimPayment.BaseClaimPerilKey & ": BaseReserveKey:-" & oClaimPaymentItem.BaseReserveKey)

                    End If
                End If

            Next
        End If
    End Sub

    Private Sub UpdatePaymentValidateClaimPaymentTaxGroup(ByVal con As SiriusConnection,
                                ByVal oClaimPayment As BaseClaimPaymentType,
                                ByVal oSAMErrorCollection As SAMErrorCollection)

        Dim AdvancedTaxSpecified As Boolean = False
        Dim PayeeDomiciled As Boolean = False
        Dim PayeeTaxNumber As String = String.Empty
        Dim PayeeTaxPercentage As Decimal = 0

        ' get the advanced tax defaults
        If oClaimPayment.AdvancedTaxDetails IsNot Nothing Then
            AdvancedTaxSpecified = True
            PayeeDomiciled = oClaimPayment.AdvancedTaxDetails.PayeeDomiciled
            PayeeTaxNumber = oClaimPayment.AdvancedTaxDetails.PayeeTaxNumber
            PayeeTaxPercentage = oClaimPayment.AdvancedTaxDetails.PayeePercentage
        End If

        Dim IsWithholdingTax As Integer = GetIsWithholdingTax(con, oClaimPayment.PaymentPartyType,
            oClaimPayment.PartyKey, AdvancedTaxSpecified,
            PayeeDomiciled, PayeeTaxNumber, PayeeTaxPercentage)

        ' store the fact that any tax on this payment must be WithHoldingTax / Not WithHoldingTax
        oClaimPayment.TaxIsWithHoldingTax = CBool(IsWithholdingTax)

        Dim dt As DataTable = Nothing

        ' get the relevant tax groups ( either those with withholding tax set on / or those with withholding tax set off)
        GetTaxGroupDetails(con, IsWithholdingTax, TransactionTypeCode.PayClaim, dt)

        Dim bTaxGroupsFound As Boolean = False

        ' if there are tax group rows then
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            bTaxGroupsFound = True
        End If

        ' validate tax group selection
        For Each oPaymentItem As BaseClaimPaymentItemType In oClaimPayment.ClaimPaymentItem

            Dim sTaxGroupCode As String = Cast.ToStringTrim(oPaymentItem.TaxGroupCode)
            Dim bFound As Boolean = False

            ' if there is a tax group code specified for the claim payment item
            If Not String.IsNullOrEmpty(oPaymentItem.TaxGroupCode) Then

                ' if there are valid tax groups for the selected payee
                If bTaxGroupsFound Then

                    ' determine if the selected tax group is one of the valid ones
                    For Each dr As DataRow In dt.Rows
                        If sTaxGroupCode = Cast.ToStringTrim(dr.Item("Code")) Then
                            bFound = True
                        End If
                    Next

                End If

                ' if no valid tax group was found
                If Not bFound Then
                    If IsWithholdingTax = WithholdingTaxSwitch.IsOn Then
                        oSAMErrorCollection.AddInvalidData(SAMInvalidData.SelectedPayeeRequiresAnIsWithholdingTaxTaxGroup,
                         SAMInvalidData.SelectedPayeeRequiresAnIsWithholdingTaxTaxGroup.ToString,
                         "TaxGroupCode", oPaymentItem.TaxGroupCode)
                    Else
                        oSAMErrorCollection.AddInvalidData(SAMInvalidData.SelectedPayeeRequiresATaxGroupWhichIsNotAnIsWithholdingTaxTaxGroup,
                         SAMInvalidData.SelectedPayeeRequiresATaxGroupWhichIsNotAnIsWithholdingTaxTaxGroup.ToString,
                         "TaxGroupCode", oPaymentItem.TaxGroupCode)
                    End If
                End If

            End If
        Next

    End Sub

    Private Sub UpdateClaimPaymentDetails(
    ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal oRequest As BaseUpdateClaimReservesOrPaymentsRequestType,
    ByVal oClaimPayment As BaseClaimPaymentType,
    ByRef oSAMErrorCollection As SAMErrorCollection, Optional bSkipUpdateReserve As Boolean = False,
                                Optional ByVal bClaimsReservesAreGross As Boolean = False,
                                Optional ByVal bPaymentCannotExceedReserve As Boolean = False)

        Dim lPaymentPartyAccountId As Integer
        Dim sPaymentPartyAccountCode As String
        Dim sPaymentPartyShortCode As String

        GetAccountDetailsFromShortCode(con, InternalSAMConstants.kAccountShortnameCLMPAYABLE, lPaymentPartyAccountId)

        ' if a party to pay has been selected then get the account details for that party
        If oClaimPayment.PaymentPartyType <> ClaimPaymentPartyTypeType.CLMPAYABLE Then

            If oClaimPayment.PartyKey <> ClaimPaymentPartyTypeType.CLMPAYABLE Then

                GetAccountDetailsForParty(con, oClaimPayment.PartyKey,
                    lPaymentPartyAccountId,
                    sPaymentPartyAccountCode,
                    sPaymentPartyShortCode)

            End If

        End If

        Dim oClaimDetails As New BaseAdditionalClaimRelatedDetails

        ' Collect all the other information required to process payment of claim
        GetClaimDetailsForPaymentOrReceipt(con,
            oClaimPayment.ClaimId,
            oClaimPayment.ClaimPerilId,
            oClaimDetails)

        oClaimPayment.LossCurrencyId = oClaimDetails.Claim.LossCurrencyKey
        oClaimPayment.ClassOfBusinessID = oClaimDetails.ClaimPeril.ClassOfBusinessId
        oClaimPayment.ClassOfBusinessCode = oClaimDetails.ClaimPeril.ClassOfBusinessCode
        oClaimPayment.InsuranceFileCNT = oClaimDetails.InsuranceFile.InsuranceFileKey
        oClaimPayment.PostClaimTaxesSeperately = oClaimDetails.Risk.PostTaxEntriesSeparately


        If Not (oRequest.ProcessType = 3 Or oRequest.ProcessType = 4) Then
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_claim_payment_del")

            cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oRequest.ClaimPayment.ClaimPerilId
            cmd.AddInParameter("@process_type", SqlDbType.Int).Value = oRequest.ProcessType

            con.ExecuteNonQuery(cmd)

        End Using
        End If
        Dim oPaymentItem As BaseClaimPaymentItemType = Nothing

        For Each oPaymentItem In oClaimPayment.ClaimPaymentItem

            oPaymentItem.IsWHTTax = oClaimPayment.TaxIsWithHoldingTax
            oPaymentItem.TaxAmount = 0
            oPaymentItem.TaxAmountWHT = 0

        Next

        ' Retrieve the Transaction To Loss Currency Exchange Rate 
        GetCurrencyToCurrencyExchangeRate(con, oClaimPayment.TransactionDate, oClaimPayment.CurrencyId, oClaimPayment.LossCurrencyId, oRequest.SourceId, oClaimPayment.PaymentToLossXRate)

        ' danny davis reckons this is done deliberately in sbo because of rounding issues 
        ' encountered by australia so therefore replicated it here.
        'oClaimPayment.PaymentToLossXRate = Decimal.Round(oClaimPayment.PaymentToLossXRate, 4)

        Dim oClaimPaymentTaxes As New BaseImplementationTypes.BaseGetClaimPaymentTaxesResponseType

        ' 1 - Below is the function used to build the reserve details on all
        '     claim payment items in the request structure.
        ' 2-  It put all the retrieved details in respected items on request and response Structures
        oClaimPaymentTaxes = getPerilReservePaymentdetails(con, oRequest.ClaimPayment, oSAMErrorCollection)

        ' get the exchange rate details for the payment 
        GetCurrencyExchangeRatesForAll(con, Date.Today.Date, lPaymentPartyAccountId,
            oClaimPayment.SourceId, oClaimPayment.CurrencyId, oClaimPayment.TotCurrAmount,
            oClaimPayment.BaseCurrencyId, oClaimPayment.BaseAmount, oClaimPayment.AccountCurrencyId,
            oClaimPayment.AccountAmount, oClaimPayment.SystemCurrencyId, oClaimPayment.SystemAmount,
            oClaimPayment.CurrencyToBaseXRate, oClaimPayment.CurrencyToBaseDate, oClaimPayment.AccountToBaseXRate,
            oClaimPayment.AccountToBaseDate, oClaimPayment.SystemToBaseXRate, oClaimPayment.SystemToBaseDate)

        oClaimPayment.Comments = ""
        oClaimPayment.IsReferred = Nothing
        oClaimPayment.DocumentId = Nothing
        oClaimPayment.TreatyId = Nothing
        oClaimPayment.SequenceNo = Nothing
        oPaymentItem.RecoveryId = Nothing
        oPaymentItem.RecoveryTypeId = Nothing

        oClaimPayment.ClaimPaymentToId = oClaimPayment.PaymentPartyType

        ' Save Payment to the Claim_Payment table
        SaveClaimPayment(con, oRequest.ClaimPayment)

        ' Save Payment to the Claim_Payment_item table
        SaveClaimPaymentItems(con:=con, oClaimPayment:=oRequest.ClaimPayment, sRequestFrom:="CLMPayable", bIsDataTransferClaim:=False, bDataTransferIsUsingFullClaimVersioning:=False, lProcessType:=oRequest.ProcessType, oClaimPaymentTaxes:=oClaimPaymentTaxes, bSkipUpdateReserve:=bSkipUpdateReserve, bClaimsReservesAreGross:=bClaimsReservesAreGross,bPaymentCannotExceedReserve:=bPaymentCannotExceedReserve)
    End Sub

    Public Function BindClaim(ByVal oRequest As BaseBindClaimRequestType) As BaseBindClaimResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim nBaseClaimKey As Integer

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                           _SiriusUser.Username, _SiriusUser.SourceID,
                                           _SiriusUser.LanguageID,
                                           SiriusUserDefaults.AppName)
            oRequest.Validate(CType(oSAMErrorCollection, Object))
            oSAMErrorCollection.CheckForErrors()

            ' Lookup Codes to ensure they are valid
            If Not String.IsNullOrEmpty(oRequest.BranchCode) Then
                oRequest.SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
            End If

            'validate the ClaimNumber number 
            Dim nClaimId As Integer
            If oRequest.ClaimKey = 0 Then
                nClaimId = GetAndValidateSpecifiedTableCode(con,
                "claim", "claim_id", "claim_id",
                oRequest.ClaimKey.ToString, oSAMErrorCollection, "ClaimKey")
            End If

            oSAMErrorCollection.CheckForErrors()

            GetBaseClaimKey(con, oRequest.ClaimKey, nBaseClaimKey)

            If CheckDuplicateClaimVersion(con, oRequest.ClaimKey) Then
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.RecordChanged,
                                                            SAMBusinessErrors.RecordChanged.ToString,
                                                            "There is already a Live claim exists with Same Version Number")
                oSAMErrorCollection.CheckForErrors()
            End If

            If oRequest.ProcessType <> 1 Then
                oCoreBusiness.CheckSAMTSAndLock(con, oRequest.BranchCode,
                    CoreBusiness.LockName.ClaimId,
                    nBaseClaimKey,
                    oRequest.TimeStamp)
            End If

            Dim oResponse As BaseBindClaimResponseType

            Try

                con.BeginTransaction()
            If oRequest.ProcessType = 1 Then
                oResponse = ProcessBindOpenClaim(con, oRequest, oCoreBusiness, oSAMErrorCollection)
            ElseIf oRequest.ProcessType = 2 Then
                oResponse = ProcessBindMaintainClaim(con, oRequest, oCoreBusiness, oSAMErrorCollection)
                ElseIf oRequest.ProcessType = 3 Then
                    oResponse = ProcessBindPayClaim(con, oRequest, oCoreBusiness, oSAMErrorCollection)
                ElseIf oRequest.ProcessType = 4 Then
                    oResponse = ProcessBindMaintainClaim(con, oRequest, oCoreBusiness, oSAMErrorCollection)
                oResponse = ProcessBindPayClaim(con, oRequest, oCoreBusiness, oSAMErrorCollection)
                ElseIf oRequest.ProcessType = 5 Then '' Process Receipt
                    oResponse = ProcessBindReceiptClaim(con, oRequest, oCoreBusiness, oSAMErrorCollection)
                End If

                If oRequest.BaseCaseKey > 0 Then
                    UpdateBaseCaseKey(con, oResponse.BaseClaimKey, oRequest.BaseCaseKey)
                End If

                If oRequest.ProcessType <> 1 Then
                    oCoreBusiness.UnlockAndGetSAMTS(
                    con,
                    oRequest.BranchCode,
                    CoreBusiness.LockName.ClaimId,
                    nBaseClaimKey,
                    oResponse.TimeStamp)

                    'Delete An Exclusive Locks
                    DeleteExlusiveLock(con,
                                       oCoreBusiness,
                                       CoreBusiness.LockName.ClaimId,
                                       nBaseClaimKey,
                                       oRequest.BranchCode)
            End If
                con.CommitTransaction()
            Catch ex As Exception
                con.RollbackTransaction()
            If oRequest.ProcessType <> 1 Then
                    oCoreBusiness.UnlockAndGetSAMTS(
                    con,
                    oRequest.BranchCode,
                    CoreBusiness.LockName.ClaimId,
                    nBaseClaimKey,
                oResponse.TimeStamp)

                'Delete An Exclusive Locks
                    DeleteExlusiveLock(con,
                                       oCoreBusiness,
                                       CoreBusiness.LockName.ClaimId,
                                       nBaseClaimKey,
                                   oRequest.BranchCode)
            End If
            End Try
            

            Return oResponse

        End Using

    End Function
    ''' <summary>
    ''' ProcessBindReceiptClaim
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oRequest"></param>
    ''' <param name="oBusiness"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function ProcessBindReceiptClaim(ByVal con As SiriusConnection, ByVal oRequest As BaseBindClaimRequestType, ByVal oBusiness As CoreBusiness, ByRef oSAMErrorCollection As SAMErrorCollection) As BaseBindClaimResponseType

        Dim sOptionValue As String = String.Empty
        'Create GetProductRiskOptions request
        Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType
        Dim oResponse As New BaseBindClaimResponseType
        'Get the product id
        Dim dsProductId As DataSet = Nothing
        Dim sTransactionTypeCode As String = String.Empty
        Dim iTransactionTypeId As Int32 = 0
        Dim creditedAccountKey As Integer = 0
        Dim creditedDocumentKey As Integer = 0
        Dim creditedTransdetailKey As Integer = 0
        Dim nClaimReceiptAccountKey As Integer = 0
        Dim nInsuranceFileCnt As Integer = 0
        Dim iIsDirtyClaim As Integer = 0
        Dim sCreditedPartyAccountCode As String
        Dim sCreditedPartyShortCode As String

        Dim oClaimReceipt As BaseClaimReceiptType = oRequest.claimReceipt
        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.BindClaimRequestType) Then
            oResponse = New SAMForInsuranceV2ImplementationTypes.BindClaimResponseType
        End If

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Details")
            Dim dsClaimDetails As DataSet = Nothing
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
            cmd.AddInParameter("@source_id", SqlDbType.Int).Value = oRequest.SourceId
            cmd.AddInParameter("@BaseClaim_id", SqlDbType.Int).Value = 0

            dsClaimDetails = con.ExecuteDataSet(cmd, "Row")

            Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
            If dsClaimDetails.Tables(0).Rows.Count > 0 Then
                iIsDirtyClaim = Cast.ToInt32(dr.Item("is_dirty"), 0)
                iTransactionTypeId = Cast.ToInt32(dr.Item("transaction_type_id"), 0)
                nInsuranceFileCnt = Cast.ToInt32(dr.Item("Policy_id"), 0)
            End If

        End Using
        If iTransactionTypeId <> 0 Then
            oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.TransactionType, iTransactionTypeId, "Code", Nothing, "NOTPASSED", sTransactionTypeCode)
        End If

        ' create new instance of bCLMChangeClaimStatus.Business
        Dim oCLMChangeClaimStatus As New bCLMChangeClaimStatus.Business
        ' initialise 
        SAMFunc.InitialiseSBOObject(Con:=con, oObject:=oCLMChangeClaimStatus, SiriusUser:=_SiriusUser, sObjectName:="bCLMChangeClaimStatus.Business")
        Try
            ' set the process modes
            Dim iReturn As Integer = oCLMChangeClaimStatus.SetProcessModes(0, 0, 0, CType(sTransactionTypeCode, Object), Date.Today)
            If (iReturn <> PMEReturnCode.PMTrue) Then
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                    "bCLMChangeClaimStatus.Business.SetProcessModes")
                oSAMErrorCollection.CheckForErrors()
            End If

            iReturn = oCLMChangeClaimStatus.RaiseTransactions(oRequest.ClaimKey, r_lDocumentId:=creditedDocumentKey)
            If iReturn <> PMEReturnCode.PMTrue Then
                ' raise an error
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.COMComponentMethodFailed,
                                                    SAMBusinessErrors.COMComponentMethodFailed.ToString,
                                                     "bCLMChangeClaimStatus.Business.GenerateCashListWPR085 Failed")
                oSAMErrorCollection.CheckForErrors()
            End If

            If oClaimReceipt IsNot Nothing Then
                If oClaimReceipt.PartyKey <> 0 Then

                    GetAccountDetailsForParty(con, oClaimReceipt.PartyKey,
                        nClaimReceiptAccountKey,
                            sCreditedPartyAccountCode,
                            sCreditedPartyShortCode)
                Else
                    ' if this is a payment to clmreceivable default the account shortcode
                    sCreditedPartyShortCode = InternalSAMConstants.kAccountShortnameCLMRECEIVABLE
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Account_ID_For_Claim_details")
                        Dim dsClaimDetails As DataSet = Nothing
                        cmd.AddInParameter("@sAccount_Short_Code", SqlDbType.VarChar).Value = sCreditedPartyShortCode

                        dsClaimDetails = con.ExecuteDataSet(cmd, "Row")
                        If dsClaimDetails IsNot Nothing Then
                            Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
                            If dsClaimDetails.Tables(0).Rows.Count > 0 Then
                                nClaimReceiptAccountKey = Cast.ToInt32(dr.Item("account_id"), 0)
                            End If
                        End If
                    End Using
                End If

                ProcessClaimReceiptCashList(con:=con, oClaimReceiptRequest:=oRequest.claimReceipt, iClaimReceiptAccountKey:=nClaimReceiptAccountKey, iClaimReceiptDocumentKey:=creditedDocumentKey)
            End If
            UpdateClaimIsDirtyFlag(con:=con, lClaimId:=oRequest.ClaimKey, lIsDirty:=0)
            oResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                   (con, oRequest.ClaimKey, oRequest.CloseClaimOnZeroReserveRecoveryBalance)
        Catch

        Finally
            ' destroy the instance of oCLMChangeClaimStatus.busness
            If oCLMChangeClaimStatus IsNot Nothing Then
                oCLMChangeClaimStatus.Dispose()
                oCLMChangeClaimStatus = Nothing
            End If
        End Try


        oResponse.ClaimKey = oRequest.ClaimKey


        Return oResponse

    End Function
    Public Function ProcessBindOpenClaim(ByVal con As SiriusConnection, ByVal oRequest As BaseBindClaimRequestType, ByVal oCoreBusiness As CoreBusiness, ByRef oSAMErrorCollection As SAMErrorCollection) As BaseBindClaimResponseType

        Dim GetClaimDetailsRequest As New BaseGetClaimDetailsRequestType

        Dim oPerils() As BaseGetClaimPerilDetailsType
        Dim oClaimPeril() As BaseClaimPerilType
        Dim oClaim As New BaseClaimType
        Dim iIsDirtyClaim As Integer = 0
        Dim oResponse As BaseBindClaimResponseType
        Dim sOptionValue As String = String.Empty
        Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType
        Dim lProductID As Integer
        Dim dsProductId As DataSet = Nothing

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.BindClaimRequestType) Then
            oResponse = New SAMForInsuranceV2ImplementationTypes.BindClaimResponseType
        End If

        GetInsFileCntProductId(con:=con,
                         lInsuranceFileCnt:=0,
                         dsProductId:=dsProductId,
                         lBaseClaimID:=oRequest.ClaimKey)
        If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
        AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
            lProductID = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
        Else
            'Failed to get the product id from the given base claim key
            oSAMErrorCollection.AddInvalidData(
                                    SAMConstants.SAMInvalidData.GeneralFailure,
                                    "Failed to get product details for the given policy")

            oSAMErrorCollection.CheckForErrors()
        End If

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsReservesReadOnly

        sOptionValue = GetProductRiskOptions(con, lProductID, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"

        End If
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Details")
            Dim dsClaimDetails As DataSet = Nothing
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
            cmd.AddInParameter("@source_id", SqlDbType.Int).Value = oRequest.SourceId 'GetClaimDetailsRequest.BranchCode
            dsClaimDetails = con.ExecuteDataSet(cmd, "Row")

            If dsClaimDetails.Tables(0).Rows.Count > 0 Then
                Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
                oClaim.InsuranceFileKey = Cast.ToInt32(dr.Item("policy_id"), 0)
                oClaim.ClaimId = oRequest.ClaimKey
                oClaim.ClaimVersionDescription = Cast.ToString(dr.Item("claim_version_description"))
                oClaim.ClaimNumber = Cast.ToString(dr.Item("claim_number"))
                oClaim.ClientShortName = Cast.ToString(dr.Item("Client_short_name"))
                oClaim.Description = Cast.ToString(dr.Item("Description"))
                iIsDirtyClaim = Cast.ToInt32(dr.Item("is_dirty"), 0)
            End If
        End Using

        GetInsuranceFileDetails(con, oClaim)
        If sOptionValue = "0" Then
        Dim oPeril As BaseGetClaimPerilDetailsType
        Dim oReserve As BaseGetClaimReserveDetailsType

        GetClaimDetailsRequest.BranchCode = oRequest.BranchCode
        GetClaimDetailsRequest.ClaimKey = oRequest.ClaimKey
        GetClaimDetailsRequest.SourceId = oRequest.SourceId

        oPerils = getPerils(con, GetClaimDetailsRequest, oSAMErrorCollection)

        Dim i As Integer = 0
        Dim bStatsFolderCreated As Boolean = False
        For Each oPeril In oPerils
            ReDim Preserve oClaimPeril(i)
            oClaimPeril(i) = New BaseClaimPerilType
            oClaimPeril(i).ClaimPerilId = oPeril.ClaimPerilKey
            oClaimPeril(i).Description = oPeril.Description
            oClaimPeril(i).TypeCode = oPeril.TypeCode

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Claim_Peril_Class_Of_Business")
                Dim dsClaimDetails As DataSet = Nothing
                cmd.AddInParameter("@peril_type_id", SqlDbType.Int).Value = 0
                cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oPeril.ClaimPerilKey
                dsClaimDetails = con.ExecuteDataSet(cmd, "Row")

                Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
                If dsClaimDetails.Tables(0).Rows.Count > 0 Then
                    oClaimPeril(i).ClassOfBusinessId = Cast.ToInt32(dr.Item("class_of_business_id"), 0)
                    oClaimPeril(i).ClassOfBusinessCode = dr.Item("code").ToString
                End If
            End Using

            Dim j As Integer = 0
            Dim oClaimReserve() As BaseClaimPerilReserveType = Nothing
            If Not (oPeril.Reserve Is Nothing) Then
                For Each oReserve In oPeril.Reserve
                    ReDim Preserve oClaimReserve(j)
                    oClaimReserve(j) = New BaseClaimPerilReserveType
                    oClaimPeril(i).TransactionAmount = oClaimPeril(i).TransactionAmount + oReserve.ThisRevision
                    j = j + 1
                Next
            End If
            oClaimPeril(i).Reserve = oClaimReserve
            If iIsDirtyClaim = 0 Then
                Return oResponse
            End If

            '' Post to Stats
                Dim lTransactionTypeId As Integer = oCoreBusiness.GetAndValidateListItemFromCode(
                Core.STSListType.PMLookup,
                PMLookupTable.TransactionType,
            TransactionTypeCode.OpenClaim, "TransactionType")

            '' if there is a transaction amount
            If oClaimPeril(i).TransactionAmount <> 0 Then
                Dim iStatsFolderId As Integer
                If bStatsFolderCreated = False Then
                    '    ' create the stats folder and get the stats folder detail
                        iStatsFolderId = AddClaimsStatsFolder(con,
                        oClaim.InsuranceFileKey,
                        "D", "Reserve for claim number " & oRequest.ClaimKey,
                        lTransactionTypeId, TransactionTypeCode.OpenClaim,
                        _SiriusUser.UserID, _SiriusUser.Username, oRequest.ClaimKey,
                        InternalSAMConstants.kDocumentTypeTransferredDebit)
                    bStatsFolderCreated = True
                End If

                Dim sCreditAccountCode As String = "CLMRES" & oClaimPeril(i).ClassOfBusinessCode.ToString
                Dim lRIPartyCnt As Integer = 0
                Dim lRIPartyType As Integer = 0
                Dim dRISharePercent As Double = 0

                '    ' Add Stats Details 
                    AddClaimsStatsDetail(con, iStatsFolderId,
                    oRequest.ClaimKey,
                    oClaimPeril(i).ClaimPerilId, InternalSAMConstants.kStatsDetailTypeGross,
                    oClaimPeril(i).ClassOfBusinessId,
                    oClaimPeril(i).ClassOfBusinessCode,
                    lRIPartyCnt,
                    sCreditAccountCode,
                    lRIPartyType,
                    dRISharePercent,
                    oClaimPeril(i).TransactionAmount,
                    InternalSAMConstants.kDocumentTypeTransferredDebit)
            End If
            i = i + 1
        Next
        End If
        If String.IsNullOrEmpty(oClaim.ClaimVersionDescription) Then
                oClaim.ClaimVersionDescription = "Opened Claim"
            Else
            oClaim.ClaimVersionDescription = oClaim.ClaimVersionDescription
        End If

        Const ksTransactionType As String = "C_CO"
        ProcessClaimsCoinsurance(con, oCoreBusiness, oRequest.ClaimKey, ksTransactionType, oRequest.BranchCode)

        ProcessClaimsReinsurance(con, oRequest.ClaimKey, 0)

        ' finalise the claim details
        FinaliseClaimDetails(con, oClaim.ClaimId, oClaim.ClaimVersionDescription)

        ' create dme folder for the claim
        CreateClaimsDMEFolder(con, oCoreBusiness, oRequest.BranchCode, oClaim)

        ' Update Insurance File System
        UpdateInsuranceFileSystem(con, _SiriusUser.UserID,
                                                    oClaim.InsuranceFileKey,
                                                        TransactionTypeCode.OpenClaim)
        If Not oRequest.NoTrans Then
        ' Raise the transactions
            RaiseTransactions(con, oClaim.ClaimId, _
            oClaim.TransactionTypeId, _
            TransactionTypeCode.OpenClaim, _
            oClaim.PaymentSuppressReserves, _
            oClaim.CurrencyId)

            ' create default claim event
        CreateDefaultClaimEvent(con, oClaim.InsuranceHolderCnt,
                                       oClaim.InsuranceFolderCnt,
                                         oClaim.InsuranceFileKey,
                                          oClaim.ClaimId,
                                           TransactionTypeCode.OpenClaim,
                                            _SiriusUser.UserID,
                                             oClaim.ClaimVersionDescription)

        ' Update Claim Is Dirty Flag to indicate that the open claim process has completed
        UpdateClaimIsDirtyFlag(con, oClaim.ClaimId, InternalSAMConstants.kClaimProcessed)

        Return oResponse
    End Function

    Public Function ProcessBindMaintainClaim(ByVal con As SiriusConnection, ByVal oRequest As BaseBindClaimRequestType, ByVal oCoreBusiness As CoreBusiness, ByRef oSAMErrorCollection As SAMErrorCollection) As BaseBindClaimResponseType

        Dim GetClaimDetailsRequest As New BaseGetClaimDetailsRequestType
        Dim bStatsFolderCreated As Boolean = False
        Dim oPerils() As BaseGetClaimPerilDetailsType
        Dim oClaimPeril() As BaseClaimPerilType
        Dim oClaim As New BaseClaimMaintainType
        Dim oResponse As BaseBindClaimResponseType
        Dim iIsDirtyClaim As Integer = 0

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.BindClaimRequestType) Then
            oResponse = New SAMForInsuranceV2ImplementationTypes.BindClaimResponseType
        End If

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Details")
            Dim dsClaimDetails As DataSet = Nothing
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
            cmd.AddInParameter("@source_id", SqlDbType.Int).Value = oRequest.SourceId 'GetClaimDetailsRequest.BranchCode
            dsClaimDetails = con.ExecuteDataSet(cmd, "Row")

            Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
            If dsClaimDetails.Tables(0).Rows.Count > 0 Then

                oClaim.InsuranceFileKey = Cast.ToInt32(dr.Item("policy_id"), 0)
                oClaim.ClaimId = oRequest.ClaimKey
                oClaim.ClaimVersionDescription = Cast.ToString(dr.Item("claim_version_description"))
                oClaim.ClaimNumber = Cast.ToString(dr.Item("claim_number"))
                oClaim.ClientShortName = Cast.ToString(dr.Item("Client_short_name"))
                oClaim.BaseClaimKey = Cast.ToInt32(dr.Item("base_claim_id"), 0)
                oClaim.InfoOnly = Cast.ToBoolean(dr.Item("Info_only"), False)
                oClaim.ClaimStatusId = Cast.ToInt32(dr.Item("Claim_Status_id"), 0)
                oClaim.ProgressStatusCode = Cast.ToString(dr.Item("progress_status_code"))

                iIsDirtyClaim = Cast.ToInt32(dr.Item("is_dirty"), 0)
            End If
        End Using

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Base_Claim_Details")

            cmd.AddInParameter("@base_claim_id", SqlDbType.Int).Value = oClaim.BaseClaimKey

            Dim dt As DataTable = con.ExecuteDataTable(cmd)

            If dt IsNot Nothing AndAlso dt.Rows.Count <> 0 Then

                oClaim.PreviousInfoOnly = Cast.ToBoolean(dt.Rows(0).Item("info_only"), False)
            End If
        End Using

        GetInsuranceFileDetails(con, oClaim)

        Dim oPeril As BaseGetClaimPerilDetailsType
        Dim oReserve As BaseGetClaimReserveDetailsType

        GetClaimDetailsRequest.BranchCode = oRequest.BranchCode
        GetClaimDetailsRequest.ClaimKey = oRequest.ClaimKey
        GetClaimDetailsRequest.SourceId = oRequest.SourceId

        oPerils = getPerils(con, GetClaimDetailsRequest, oSAMErrorCollection)

        Dim i As Integer = 0
        For Each oPeril In oPerils
            ReDim Preserve oClaimPeril(i)
            oClaimPeril(i) = New BaseClaimPerilType
            oClaimPeril(i).ClaimPerilId = oPeril.ClaimPerilKey
            oClaimPeril(i).Description = oPeril.Description
            oClaimPeril(i).TypeCode = oPeril.TypeCode

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Claim_Peril_Class_Of_Business")
                Dim dsClaimDetails As DataSet = Nothing
                cmd.AddInParameter("@peril_type_id", SqlDbType.Int).Value = 0
                cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oPeril.ClaimPerilKey
                dsClaimDetails = con.ExecuteDataSet(cmd, "Row")

                Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
                If dsClaimDetails.Tables(0).Rows.Count > 0 Then
                    oClaimPeril(i).ClassOfBusinessId = Cast.ToInt32(dr.Item("class_of_business_id"), 0)
                    oClaimPeril(i).ClassOfBusinessCode = dr.Item("code").ToString
                End If
            End Using

            Dim j As Integer = 0
            Dim oClaimReserve() As BaseClaimPerilReserveType = Nothing
            If Not (oPeril.Reserve Is Nothing) Then
                For Each oReserve In oPeril.Reserve
                    ReDim Preserve oClaimReserve(j)
                    oClaimReserve(j) = New BaseClaimPerilReserveType
                    oClaimPeril(i).TransactionAmount = oClaimPeril(i).TransactionAmount + oReserve.ThisRevision
                    j = j + 1
                Next
            End If
            oClaimPeril(i).Reserve = oClaimReserve
            If iIsDirtyClaim = 0 Then
                Return oResponse
            End If
            '' Post to Stats
            Dim lTransactionTypeId As Integer = oCoreBusiness.GetAndValidateListItemFromCode(
            Core.STSListType.PMLookup,
            PMLookupTable.TransactionType,
            TransactionTypeCode.MaintainClaim, "TransactionType")

            '' if there is a transaction amount
            If oClaimPeril(i).TransactionAmount <> 0 Then
                Dim iStatsFolderId As Integer
                '    ' create the stats folder and get the stats folder detail
                If bStatsFolderCreated = False Then
                    iStatsFolderId = AddClaimsStatsFolder(con,
                    oClaim.InsuranceFileKey,
                    "D", "Reserve for claim number " & oRequest.ClaimKey,
                    lTransactionTypeId, TransactionTypeCode.MaintainClaim,
                    _SiriusUser.UserID, _SiriusUser.Username, oRequest.ClaimKey,
                    InternalSAMConstants.kDocumentTypeTransferredDebit)
                    bStatsFolderCreated = True
                End If

                Dim sCreditAccountCode As String = "CLMRES" & oClaimPeril(i).ClassOfBusinessCode.ToString
                Dim lRIPartyCnt As Integer = 0
                Dim lRIPartyType As Integer = 0
                Dim dRISharePercent As Double = 0

                '    ' Add Stats Details 
                AddClaimsStatsDetail(con, iStatsFolderId,
                oRequest.ClaimKey,
                oClaimPeril(i).ClaimPerilId, InternalSAMConstants.kStatsDetailTypeGross,
                oClaimPeril(i).ClassOfBusinessId,
                oClaimPeril(i).ClassOfBusinessCode,
                lRIPartyCnt,
                sCreditAccountCode,
                lRIPartyType,
                dRISharePercent,
                oClaimPeril(i).TransactionAmount,
                InternalSAMConstants.kDocumentTypeTransferredDebit)
            End If
            i = i + 1
        Next

        Dim bBalanceAndCloseClaim As Boolean = False
        bBalanceAndCloseClaim = GetBalanceAndCloseClaimStatus(con, oClaim)

        ' if the claim is info only then finish processing at this point
        If Not oClaim.InfoOnly Then

            Const ksTransactionType As String = "C_CR"
            If String.IsNullOrEmpty(oClaim.ClaimVersionDescription) Then
                If String.IsNullOrEmpty(oClaim.Description) Then
                    oClaim.ClaimVersionDescription = "Maintained Claim"
                Else
                    oClaim.ClaimVersionDescription = oClaim.Description
                End If
            Else
                oClaim.ClaimVersionDescription = oClaim.ClaimVersionDescription
            End If

            ' balance and close the claim 
            If bBalanceAndCloseClaim Then
                ' balance the claims reserves and recoveries
                ProcessBalanceAndCloseClaim(con, oCoreBusiness, oClaim)
            Else
                ProcessClaimsCoinsurance(con, oCoreBusiness, oRequest.ClaimKey, ksTransactionType, oRequest.BranchCode)

                ProcessClaimsReinsurance(con, oRequest.ClaimKey, 0)
            End If
            ' if reserves and recoveries are not balanced ensure that the 
            ' claim status is not set to "closed"
            ValidateClaimStatus(con, oCoreBusiness, oClaim)

            ' finalise the claim details
            FinaliseClaimDetails(con, oClaim.ClaimId, oClaim.ClaimVersionDescription)

            ' create default claim event
            CreateDefaultClaimEvent(con, oClaim.InsuranceHolderCnt,
                                            oClaim.InsuranceFolderCnt,
                                             oClaim.InsuranceFileKey,
                                              oClaim.ClaimId,
                                               TransactionTypeCode.MaintainClaim,
                                                _SiriusUser.UserID,
                                                 oClaim.ClaimVersionDescription)

            ' if the claim dates have changed between this version of the claim 
            ' and the previous version
            CreateEventClaimDatesHaveChanged(con, oClaim)

            ' Create External Handler Task If Required
            CreateTaskExternalClaimHandler(con, oCoreBusiness, oRequest.BranchCode, oClaim)

            ' Update Insurance File System
            UpdateInsuranceFileSystem(con, _SiriusUser.UserID,
                                        oClaim.InsuranceFileKey,
                                            TransactionTypeCode.MaintainClaim)

            ' Raise the transactions
            RaiseTransactions(con, oClaim.ClaimId, _
                                oClaim.TransactionTypeId, _
                                  TransactionTypeCode.MaintainClaim, _
                                    oClaim.PaymentSuppressReserves, _
                                    oClaim.CurrencyId)

            ' ensure that the maintained version of the claim is also on claims builder
            ' if the original version is
            SetupClaimGisDetails(con, oClaim.ClaimId, oClaim.BaseClaimKey)
            oClaim.CloseClaimOnZeroReserveRecoveryBalance = oRequest.CloseClaimOnZeroReserveRecoveryBalance
            oResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                (con, oClaim.ClaimId, oClaim.CloseClaimOnZeroReserveRecoveryBalance)
            ' Update Claim Is Dirty Flag 
            If oRequest.ProcessType <> 4 Then ' Don't Update IsDirty flag if process type = 4 as ProcessBindPayClaim will do it
                UpdateClaimIsDirtyFlag(con, oClaim.ClaimId, InternalSAMConstants.kClaimProcessed)
            End If
        End If
        Return oResponse
    End Function

    Public Function ProcessBindPayClaim(ByVal con As SiriusConnection, ByVal oRequest As BaseBindClaimRequestType, ByVal oBusiness As CoreBusiness, ByRef oSAMErrorCollection As SAMErrorCollection) As BaseBindClaimResponseType

        Dim sOptionValue As String = String.Empty
        'Create GetProductRiskOptions request
        Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType
        Dim oResponse As New BaseBindClaimResponseType
        'Get the product id
        Dim dsProductId As DataSet = Nothing
        Dim nProductID As Integer
        Dim iClientKey As Integer
        Dim bUserIsAuthorisedToMakePayment As Boolean

        Dim creditedAccountKey As Integer = 0
        Dim creditedDocumentKey As Integer = 0
        Dim creditedTransdetailKey As Integer = 0

        Dim iIsDirtyClaim As Integer = 0
        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.BindClaimRequestType) Then
            oResponse = New SAMForInsuranceV2ImplementationTypes.BindClaimResponseType
        End If

        GetVersionId(oRequest.ClaimPayment.BaseClaimPerilKey,
                               oRequest.ClaimPayment.VersionId,
                               con)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_Details")
            Dim dsClaimDetails As DataSet = Nothing
            cmd.AddInParameter("@Claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
            cmd.AddInParameter("@source_id", SqlDbType.Int).Value = oRequest.SourceId 'GetClaimDetailsRequest.BranchCode
            cmd.AddInParameter("@BaseClaim_id", SqlDbType.Int).Value = oRequest.ClaimPayment.BaseClaimKey
            dsClaimDetails = con.ExecuteDataSet(cmd, "Row")
            Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
            If dsClaimDetails.Tables(0).Rows.Count > 0 Then
                iIsDirtyClaim = Cast.ToInt32(dr.Item("is_dirty"), 0)
            End If
        End Using

        'Getting the product id from insurance file count 
        GetInsFileCntProductId(con:=con,
                                lInsuranceFileCnt:=oRequest.ClaimPayment.InsuranceFileCNT,
                                dsProductId:=dsProductId,
                                lBaseClaimID:=oRequest.ClaimPayment.BaseClaimKey)
        If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
        AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso dsProductId.Tables(0).Rows(0).Item("product_id") IsNot Nothing AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
            nProductID = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
        Else
            'Failed to get the product id from the given base claim key
            oSAMErrorCollection.AddInvalidData(
                                    SAMConstants.SAMInvalidData.GeneralFailure,
                                    "Failed to get product details for the given policy")

            oSAMErrorCollection.CheckForErrors()
        End If
        Dim SourceId As Integer

        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If

        If oRequest.ClaimPayment.CashList IsNot Nothing Then
            oRequest.ClaimPayment.CashList.SourceID = SourceId
        End If

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsAdvancedTaxScriptEnabled

        sOptionValue = GetProductRiskOptions(con, nProductID, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If
        If oRequest.ClaimPayment.CashList IsNot Nothing Then
            If oRequest.ClaimPayment.CashList.CurrencyKey = 0 Then
                oRequest.ClaimPayment.CashList.CurrencyKey = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                    PMLookupTable.Currency, oRequest.ClaimPayment.CashList.CurrencyCode, "CurrencyCode", oSAMErrorCollection)
            End If
        End If
        oRequest.ClaimPayment.AdvanceScript = sOptionValue

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsGrossClaimPaymentAmount

        sOptionValue = GetProductRiskOptions(con, nProductID, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If

        oRequest.ClaimPayment.ClaimPaymentIsGross = sOptionValue

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.AllowNegativeReserve

        sOptionValue = GetProductRiskOptions(con, nProductID, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If

        oRequest.ClaimPayment.AllowNegativeReserve = sOptionValue
        If iIsDirtyClaim = 0 Then
            oResponse.ClaimNumber = GetAndValidateDescriptionById(con, "claim", "Claim_Number", "Claim_id", oRequest.ClaimPayment.ClaimId.ToString())
            Return oResponse
        End If

        Dim oClaimDetails As New BaseAdditionalClaimRelatedDetails

        ' validate the data provided in the request structure
        UpdatePaymentValidateData(con, oBusiness, oRequest.ClaimPayment, oSAMErrorCollection, oClaimDetails, oRequest.BranchCode, oRequest.SourceId)

        'validate the request structure against the specified business rules
        PayClaimValidateBusinessRules(con, oRequest.ClaimPayment, oClaimDetails, oSAMErrorCollection)

        'if there were any business rule errors throw an exception
        oSAMErrorCollection.CheckForErrors()
        ' validate the data provided in the structure
        'PayClaimValidateData(con, oBusiness, oRequest.ClaimPayment, oSAMErrorCollection)

        ' get the details for the last version of the specified claim so we can perform further validation
        ' of the request

        ' get details for the claim 
        GetClaimDetailsForPaymentOrReceipt(con,
                oRequest.ClaimPayment.ClaimId,
                oRequest.ClaimPayment.ClaimPerilId,
                oClaimDetails)

        oRequest.ClaimPayment.LossCurrencyId = oClaimDetails.Claim.LossCurrencyKey
        oRequest.ClaimPayment.ClassOfBusinessID = oClaimDetails.ClaimPeril.ClassOfBusinessId
        oRequest.ClaimPayment.ClassOfBusinessCode = oClaimDetails.ClaimPeril.ClassOfBusinessCode
        oRequest.ClaimPayment.InsuranceFileCNT = oClaimDetails.InsuranceFile.InsuranceFileKey
        oRequest.ClaimPayment.PostClaimTaxesSeperately = oClaimDetails.Risk.PostTaxEntriesSeparately
        oRequest.ClaimPayment.ClaimNumber = GetAndValidateDescriptionById(con, "claim", "Claim_Number", "Claim_id", oRequest.ClaimPayment.ClaimId.ToString())

        ' Retrieve the system options, Id's from codes
        oRequest.ClaimPayment.CurrencyId = oBusiness.GetListItemFromCode _
        (Core.STSListType.PMLookup, PMLookupTable.Currency, oRequest.ClaimPayment.CurrencyCode)


        ' Retrieve the system options, Id's from codes
        If oRequest.ClaimPayment.Payee IsNot Nothing Then
            If String.IsNullOrEmpty(oRequest.ClaimPayment.Payee.MediaTypeCode) = False Then
                oRequest.ClaimPayment.Payee.MediaTypeId = oBusiness.GetListItemFromCode _
                (Core.STSListType.PMLookup, PMLookupTable.MediaType, oRequest.ClaimPayment.Payee.MediaTypeCode)
            End If
        End If

        '-------------------------------------------------------------------

        Dim lPaymentPartyAccountId As Integer
        Dim sPaymentPartyAccountCode As String
        Dim sPaymentPartyShortCode As String

        GetAccountDetailsFromShortCode(con, InternalSAMConstants.kAccountShortnameCLMPAYABLE, lPaymentPartyAccountId)

        ' if a party to pay has been selected then get the account details for that party
        If oRequest.ClaimPayment.PaymentPartyType <> ClaimPaymentPartyTypeType.CLMPAYABLE Then

            If oRequest.ClaimPayment.PartyKey <> ClaimPaymentPartyTypeType.CLMPAYABLE Then

                GetAccountDetailsForParty(con, oRequest.ClaimPayment.PartyKey,
                    lPaymentPartyAccountId,
                    sPaymentPartyAccountCode,
                    sPaymentPartyShortCode)

            End If

        End If

        Dim oPaymentItem As BaseClaimPaymentItemType = Nothing

        For Each oPaymentItem In oRequest.ClaimPayment.ClaimPaymentItem

            oPaymentItem.IsWHTTax = oRequest.ClaimPayment.TaxIsWithHoldingTax
            oPaymentItem.TaxAmount = 0
            oPaymentItem.TaxAmountWHT = 0

        Next

        ' Retrieve the Transaction To Loss Currency Exchange Rate 
        GetCurrencyToCurrencyExchangeRate(con, oRequest.ClaimPayment.TransactionDate, oRequest.ClaimPayment.CurrencyId, oRequest.ClaimPayment.LossCurrencyId, oRequest.SourceId, oRequest.ClaimPayment.PaymentToLossXRate)

        ' danny davis reckons this is done deliberately in sbo because of rounding issues 
        ' encountered by australia so therefore replicated it here.
        'oRequest.ClaimPayment.PaymentToLossXRate = Decimal.Round(oRequest.ClaimPayment.PaymentToLossXRate, 4)

        Dim oClaimPaymentTaxes As New BaseImplementationTypes.BaseGetClaimPaymentTaxesResponseType
        Dim bProcessBimdClaim As Boolean = True
        ' 1 - Below is the function used to build the reserve details on all
        '     claim payment items in the request structure.
        ' 2-  It put all the retrieved details in respected items on request and response Structures
        oClaimPaymentTaxes = getPerilReservePaymentdetails(con, oRequest.ClaimPayment, oSAMErrorCollection, bProcessBimdClaim)

        ' get the exchange rate details for the payment 
        GetCurrencyExchangeRatesForAll(con, Date.Today.Date, lPaymentPartyAccountId,
            oRequest.ClaimPayment.SourceId, oRequest.ClaimPayment.CurrencyId, oRequest.ClaimPayment.TotCurrAmount,
            oRequest.ClaimPayment.BaseCurrencyId, oRequest.ClaimPayment.BaseAmount, oRequest.ClaimPayment.AccountCurrencyId,
            oRequest.ClaimPayment.AccountAmount, oRequest.ClaimPayment.SystemCurrencyId, oRequest.ClaimPayment.SystemAmount,
            oRequest.ClaimPayment.CurrencyToBaseXRate, oRequest.ClaimPayment.CurrencyToBaseDate, oRequest.ClaimPayment.AccountToBaseXRate,
            oRequest.ClaimPayment.AccountToBaseDate, oRequest.ClaimPayment.SystemToBaseXRate, oRequest.ClaimPayment.SystemToBaseDate)

        oRequest.ClaimPayment.Comments = ""
        oRequest.ClaimPayment.IsReferred = Nothing
        oRequest.ClaimPayment.DocumentId = Nothing
        oRequest.ClaimPayment.TreatyId = Nothing
        oRequest.ClaimPayment.SequenceNo = Nothing
        oPaymentItem.RecoveryId = Nothing
        oPaymentItem.RecoveryTypeId = Nothing

        oRequest.ClaimPayment.ClaimPaymentToId = oRequest.ClaimPayment.PaymentPartyType

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsPaymentsReadOnly

        sOptionValue = GetProductRiskOptions(con, nProductID, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If

        If sOptionValue = "0" Then
        ' Save Payment to the Claim_Payment table
        GetClaimPayment(con, oRequest.ClaimPayment)

        ' Save Payment to the Claim_Payment_item table
        GetClaimPaymentItems(con, oRequest.ClaimPayment)
        End If

        'For pay claim, transaction type code in database is C_CP
        Const ksTransactionType As String = "C_CP"
        ProcessClaimsCoinsurance(con, oBusiness, oRequest.ClaimPayment.ClaimId, ksTransactionType, oRequest.BranchCode)

        ProcessClaimsReinsurance(con:=con,
                                  lClaimId:=oRequest.ClaimPayment.ClaimId,
                                  lBalanceAndCloseClaim:=kBalanceAndCloseClaim)

        If oRequest.ClaimPayment.PartyKey = 0 Then
            iClientKey = oRequest.ClaimPayment.ClientKey
        Else
            iClientKey = oRequest.ClaimPayment.PartyKey
        End If
        'CreateDefaultClaimEvent(con:=con, _
        '                             lInsuranceHolderCnt:=iClientKey, _
        '                             lInsuranceFolderCnt:=0, _
        '                             lInsuranceFileCnt:=oRequest.ClaimPayment.InsuranceFileCNT, _
        '                             lClaimId:=oRequest.ClaimPayment.ClaimId, _
        '                             sTransactionType:=TransactionTypeCode.PayClaim, _
        '                             lUserId:=_SiriusUser.UserID, _
        '                             sEventDescription:=oRequest.ClaimPayment.ClaimVersionDescription)

        FinaliseClaimDetails(con:=con,
                                lClaimId:=oRequest.ClaimPayment.ClaimId,
                                sClaimVersionDescription:=oRequest.ClaimPayment.ClaimVersionDescription)

        ' Finalise the Payment process
        ProcessClaimPayment(Con:=con, oClaimPayment:=oRequest.ClaimPayment, r_bUserIsAuthorisedToMakePayment:=bUserIsAuthorisedToMakePayment,
                            IsDataTransferClaim:=False, bIsTPASettleDirectly:=oRequest.TPASettleDirectly)

        ' reset the claim is dirty flag
        UpdateClaimIsDirtyFlag(con, oRequest.ClaimPayment.ClaimId, 0)

        GetPaymentCreditedAccountDetails(con,
                                            oRequest.ClaimPayment.ClaimId,
                                            CInt(oRequest.ClaimPayment.PaymentId),
                                            creditedAccountKey,
                                            creditedDocumentKey,
                                            creditedTransdetailKey)
        If Not (bUserIsAuthorisedToMakePayment) Then

            AddWarning(oResponse,
                    SAMBusinessWarnings.UserDoesntHaveAuthorityToMakeThisPaymentPaymentWasReferred,
                    SAMBusinessWarnings.UserDoesntHaveAuthorityToMakeThisPaymentPaymentWasReferred.ToString)

            CreateDefaultClaimEvent(con:=con,
                        lInsuranceHolderCnt:=oRequest.ClaimPayment.ClientKey,
                        lInsuranceFolderCnt:=0,
                        lInsuranceFileCnt:=oRequest.ClaimPayment.InsuranceFileCNT,
                        lClaimId:=oRequest.ClaimPayment.ClaimId,
                        sTransactionType:=TransactionTypeCode.PayClaim,
                        lUserId:=_SiriusUser.UserID,
                        sEventDescription:="Payment Of Claim - Awaiting Claim Payment Authority " & oRequest.ClaimPayment.ClaimVersionDescription)


            oResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                    (con, oRequest.ClaimPayment.ClaimId, oRequest.ClaimPayment.CloseClaimOnZeroReserveRecoveryBalance)
        Else
            CreateDefaultClaimEvent(con:=con,
                       lInsuranceHolderCnt:=oRequest.ClaimPayment.ClientKey,
                       lInsuranceFolderCnt:=0,
                       lInsuranceFileCnt:=oRequest.ClaimPayment.InsuranceFileCNT,
                       lClaimId:=oRequest.ClaimPayment.ClaimId,
                       sTransactionType:=TransactionTypeCode.PayClaim,
                       lUserId:=_SiriusUser.UserID,
                       sEventDescription:=oRequest.ClaimPayment.ClaimVersionDescription)


            Dim oGetProductClaimsWorkflowOptionsRequest As New BaseGetProductClaimsWorkflowOptionsRequestType
            Dim dsWorkflowOptions As DataSet = Nothing

            oGetProductClaimsWorkflowOptionsRequest.ProductID = nProductID
            oGetProductClaimsWorkflowOptionsRequest.ClaimProcessType = ClaimProcessType.ClaimPayment

            dsWorkflowOptions = GetProductClaimsWorkflowOptions(con, oGetProductClaimsWorkflowOptionsRequest)

            If (dsWorkflowOptions IsNot Nothing AndAlso dsWorkflowOptions.Tables.Count > 0 _
            AndAlso dsWorkflowOptions.Tables(0).Rows.Count > 0) Then
                If Cast.ToBoolean(dsWorkflowOptions.Tables(0).Rows(0).Item("CashPaymentProcess"), False) And oRequest.ClaimPayment.BaseAmount >= 0 Then
                    If (oRequest.TPASettleDirectly AndAlso oRequest.IsTPASpecified) Or (Not oRequest.IsTPASpecified) Then
                    'Payment Workflow is Enabled
                    oRequest.ClaimPayment.ClaimPaymentWorkflowEnabled = True

                    Dim oClaimResponsewarning As New SAMForInsuranceV2ImplementationTypes.PayClaimResponseType
                    ClaimPaymentWorkFlowValidation(DirectCast(oRequest.ClaimPayment, BaseImplementationTypes.BaseClaimPaymentType), oSAMErrorCollection, DirectCast(oClaimResponsewarning, BaseClaimResponseType))

                    'Check for errors
                    oSAMErrorCollection.CheckForErrors()
                    If oRequest.ClaimPayment.ClaimPaymentWorkflowEnabled Then
                        If oRequest.ClaimPayment.CashList IsNot Nothing Then
                                If oRequest.ClaimPayment.BaseAmount < 0 Then
                                    oRequest.ClaimPayment.CashList.TypeCode = "R"
                                End If
                            PayClaimValidateCashList(con, oBusiness, oRequest.ClaimPayment.CashList, oSAMErrorCollection)

                            'If there were any errors throw an exception
                            oSAMErrorCollection.CheckForErrors()
                        End If
                    End If
                    Dim lSourceId As Integer
                    If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
                            lSourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                            PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
                    End If
                    oRequest.ClaimPayment.CashList.SourceID = SourceId
                    End If
                Else
                    oResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                           (con, oRequest.ClaimPayment.ClaimId, oRequest.ClaimPayment.CloseClaimOnZeroReserveRecoveryBalance)
                End If
            Else
                'Failed to get Product Claim Workflow Options
                oSAMErrorCollection.AddInvalidData(
                                    SAMConstants.SAMInvalidData.GeneralFailure,
                                    "Failed to get claim workflow options for the given Product")

                oSAMErrorCollection.CheckForErrors()
            End If

            If oRequest.ClaimPayment.ClaimPaymentWorkflowEnabled Then
                If (oRequest.TPASettleDirectly AndAlso oRequest.IsTPASpecified) Or (Not oRequest.IsTPASpecified) Then
                oRequest.ClaimPayment.CashList.BranchCode = oRequest.BranchCode
                oRequest.ClaimPayment.CashList.SourceID = oRequest.SourceId
                ProcessClaimPaymentCashList(con, oRequest.ClaimPayment, creditedAccountKey, creditedDocumentKey)
                oResponse.CashList = New BaseCashListResponseType
                oResponse.CashList.CashListKey = oRequest.ClaimPayment.CashList.CashListKey
            End If
            End If
            oResponse.ResultingStatus = GetClaimStatusOnCheckReserveRecovery _
                      (con, oRequest.ClaimPayment.ClaimId, oRequest.ClaimPayment.CloseClaimOnZeroReserveRecoveryBalance)
        End If
        oResponse.BaseClaimKey = oRequest.ClaimPayment.BaseClaimKey
        oResponse.ClaimKey = oRequest.ClaimPayment.ClaimId
        oResponse.ClaimNumber = oRequest.ClaimPayment.ClaimNumber
        oResponse.Version = oRequest.ClaimPayment.VersionId
        oResponse.creditedAccountKey = creditedAccountKey
        oResponse.creditedDocumentKey = creditedDocumentKey
        oResponse.creditedTransdetailKey = creditedTransdetailKey
        oResponse.PaymentAuthorized = bUserIsAuthorisedToMakePayment
        Return oResponse

    End Function

    Private Sub GetClaimPayment(ByVal Con As SiriusConnection,
                                    ByVal oClaimPayment As BaseClaimPaymentType)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Claim_Payment_id_Select")

            cmd.AddOutParameter("@claim_payment_id", SqlDbType.Int)
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oClaimPayment.ClaimId
            cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oClaimPayment.ClaimPerilId

            Con.ExecuteNonQuery(cmd)

            ' return id..
            oClaimPayment.PaymentId = Cast.ToInt32(cmd.Parameters("@claim_payment_id").Value, 0)

        End Using
    End Sub

    Private Sub GetClaimPaymentItems(ByVal con As SiriusConnection,
                                    ByVal oClaimPayment As BaseClaimPaymentType)

        'Dim r_lClaimPaymentItemId As Integer
        Dim oBusiness As New CoreBusiness
        Dim oClaimPaymentTaxes As New BaseImplementationTypes.BaseGetClaimPaymentTaxesResponseType

        For Each oPaymentItem As BaseClaimPaymentItemType In oClaimPayment.ClaimPaymentItem

            If oPaymentItem.CurrencyAmount <> 0 Then

                ' save the claim payment item
                GetClaimPaymentItem(con, oClaimPayment, oPaymentItem)

                If Not oPaymentItem.TaxGroupCode = Nothing AndAlso oPaymentItem.IsExcess = False AndAlso Not oPaymentItem.IsTaxOverridden Then

                    GetTaxCalculations(con,
                                        oClaimPayment,
                                        Cast.ToInt32(oClaimPayment.PaymentId, 0),
                                        oPaymentItem.ClaimPaymentItemId,
                                        oPaymentItem)

                End If

                ' update the associated reserve with the payment details
                UpdateReserve(con, oClaimPayment, oPaymentItem, False, False, True)

            End If
        Next

    End Sub

    Private Sub GetClaimPaymentItem(
    ByVal con As SiriusConnection,
    ByVal oClaimPayment As BaseClaimPaymentType,
    ByVal ClaimPaymentItem As BaseClaimPaymentItemType)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Claim_Payment_Item_id_Select")

            cmd.AddOutParameter("@claim_payment_item_id", SqlDbType.Int)
            cmd.AddInParameter("@claim_payment_id", SqlDbType.Int).Value = oClaimPayment.PaymentId
            cmd.AddInParameter("@reserve_id", SqlDbType.Int).Value = Cast.NullIfDefault(ClaimPaymentItem.ReserveId, 0)

            con.ExecuteNonQuery(cmd)

            ClaimPaymentItem.ClaimPaymentItemId = Cast.ToInt32(cmd.Parameters.Item("@claim_payment_item_id").Value, 0)

        End Using

    End Sub

    Private Sub GetTaxCalculations(
                                        ByVal Con As SiriusConnection,
                                        ByVal oClaimPayment As BaseClaimPaymentType,
                                        ByVal v_lClaimPaymentId As Integer,
                                        ByVal v_lClaimPaymentItemId As Integer,
                                        ByVal oPaymentItem As BaseClaimPaymentItemType)

        'Const kPayeeOptClaimPayable As Integer = 1

        Dim dsTaxBandDet As DataSet = Nothing
        Dim crCurrencyAmount As Decimal
        Dim crTaxLossAmount As Decimal
        Dim crTaxBaseAmount As Decimal

        ' Call Recalculate function to build the tax ban details and save them to the database
        CalculateTaxAmounts(con:=Con,
                    lCompanyId:=oClaimPayment.SourceId,
                    lTaxGroupId:=Cast.ToInt32(oPaymentItem.TaxGroupId, 0),
                    sTranstype:=kTaxTransTypeClaimPayment,
                    lCurrencyId:=oClaimPayment.CurrencyId,
                    lLossCurrencyId:=oClaimPayment.LossCurrencyId,
                    crAmount:=oPaymentItem.PaymentAmount,
                    crTaxCurrencyAmount:=crCurrencyAmount,
                    crTaxLossAmount:=crTaxLossAmount,
                    crTaxBaseAmount:=crTaxBaseAmount,
                    lClaimPerilId:=oClaimPayment.ClaimPerilId,
                    lClaimPaymentId:=v_lClaimPaymentId,
                    lClaimReceiptId:=1,
                    lClaimPaymentItemId:=v_lClaimPaymentItemId,
                    lClaimReceiptItemId:=0,
                    lCalculateOnly:=1,
                    oTaxBandDetails:=dsTaxBandDet)

        If oClaimPayment.PostClaimTaxesSeperately AndAlso oClaimPayment.ClaimPaymentIsGross = "1" Then
            ' calculate the scripted tax Amount only if the scripted option is switched on
            'And check if the selected tax group have any ATS Rule file or not

            Dim advancedTaxScript As String = String.Empty
            GetAdvancedTaxScript(con:=Con, taxGroupId:=Cast.ToInt32(oPaymentItem.TaxGroupId, 0), advancedTaxScript:=advancedTaxScript)
            If oClaimPayment.AdvanceScript = "1" AndAlso advancedTaxScript IsNot Nothing AndAlso advancedTaxScript <> "" Then

                Dim crScriptedTaxAmount As Decimal = 0
                Dim oUpDatedTaxBandRate As DataSet = Nothing
                crScriptedTaxAmount = CalculateScriptedTax(Con:=Con,
                                                                oClaimPayment:=oClaimPayment,
                                                                payClaimItem:=oPaymentItem,
                                                                oSAMErrorCollection:=Nothing,
                                                                m_vTaxBandRate:=dsTaxBandDet,
                                                                oUpDatedTaxBandRate:=oUpDatedTaxBandRate)
                crCurrencyAmount = crScriptedTaxAmount
                oClaimPayment.TotTaxAmount = oClaimPayment.TotTaxAmount + crScriptedTaxAmount
            Else
                If dsTaxBandDet.Tables(0).Rows.Count > 0 Then
                    For lCount As Int32 = 0 To dsTaxBandDet.Tables(0).Rows.Count - 1
                        oClaimPayment.TotTaxAmount = oClaimPayment.TotTaxAmount + Cast.ToDecimal(dsTaxBandDet.Tables(0).Rows(lCount)("value")).GetValueOrDefault(0)
                    Next
                End If
            End If
        End If

    End Sub

    Public Sub ProcessClaimRiskData(ByRef sRiskXML As String, ByVal oAmendments() As BaseImplementationTypes.BaseClaimProcessBuilderRiskType)
        Dim xDoc As New XmlDocument()

        'Load XML
        xDoc.LoadXml(sRiskXML)

        'Manipluate XML
        Dim xNode As XmlNode
        ' For each ClaimBuilder data item

        If Not oAmendments Is Nothing Then

            For Each oAmend As BaseImplementationTypes.BaseClaimProcessBuilderRiskType In oAmendments
                ' Get the XPath value
                Dim xpath As String = oAmend.ClaimBuilderData.ItemName
                ' Select the node using the XPath
                xNode = xDoc.SelectSingleNode(xpath)
                ' If the node has been found then
                If Not xNode Is Nothing Then
                    ' Set the value of the attribute to the value passed in
                    xNode.InnerText = oAmend.ClaimBuilderData.Value
                    ' Set the UpdateStatus of the Object
                    Dim attr As XmlAttribute = CType(xNode, XmlAttribute)
                    If (attr.OwnerElement.Attributes("US") Is Nothing) = False Then
                        If attr.OwnerElement.Attributes("US").Value = "0" Then
                            attr.OwnerElement.Attributes("US").Value = "2"
                        End If
                    End If
                    ' Else no attribute found so create one
                Else
                    Dim objectName As String = String.Empty
                    ' Split the Object and property name of the Xpath
                    Dim propertyName As String = String.Empty
                    Dim split As String() = xpath.Split(New [Char]() {"@"c})
                    If split.Length = 2 Then
                        objectName = IIf(split(0).EndsWith("/"), split(0).Substring(0, split(0).Length - 1), split(0)).ToString
                        propertyName = split(1)
                        ' Find the Element/Object
                        xNode = GetPBNode(xDoc, objectName)
                        If Not xNode Is Nothing Then
                            ' Create the attribute and set the value
                            Dim attr As XmlNode = xDoc.CreateNode(XmlNodeType.Attribute, propertyName, "")
                            attr.Value = oAmend.ClaimBuilderData.Value
                            xNode.Attributes.SetNamedItem(attr)
                            ' Set the UpdateStatus of the Object
                            If (xNode.Attributes("US") Is Nothing) = False Then
                                If xNode.Attributes("US").Value = "0" Then
                                    xNode.Attributes("US").Value = "2"
                                End If
                            End If
                        End If
                    End If
                End If
            Next
        End If

        'Update the return string
        sRiskXML = xDoc.OuterXml

    End Sub


