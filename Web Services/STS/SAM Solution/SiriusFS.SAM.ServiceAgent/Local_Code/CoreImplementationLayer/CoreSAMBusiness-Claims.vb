    Private Function GetPaymentSuppressValue(ByVal Con As SiriusConnection,
                                           ByVal iClaimId As Integer,
                                           ByRef sTransactionType As String) As Integer
        Try
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Suppress_Stats")
                cmd.AddInParameter("@Claim_id", SqlDbType.Int, 10).Value = iClaimId
                cmd.AddInParameter("@transaction_type_code", SqlDbType.VarChar).Value = sTransactionType
                cmd.AddOutParameter("@suppress", SqlDbType.Int)
                Con.ExecuteNonQuery(cmd)
                Return Convert.ToInt32(cmd.Parameters.Item("@suppress").Value)
            End Using
        Catch
            Return 0
        End Try

    End Function
    Private Sub RaiseTransactions(ByVal con As SiriusConnection,
                                ByVal lClaimId As Integer,
                                ByVal lTransactionTypeId As Integer,
                                ByVal sTransactionTypeCode As String,
                                ByVal lSuppressReserveTransactions As Integer,
                                Optional ByVal bPostAllStats As Boolean = False,
                                Optional ByVal lSuppressPaymentTransactions As Integer = 0)
        Dim ds As DataSet
        ' lets check there are work_stats before trying to process them.
        If bPostAllStats = False Then
            ds = GetClaimStatsFolder(con, lClaimId, sTransactionTypeCode)
        Else
            ds = GetClaimStatsFolder(con, lClaimId)
        End If

        ' if there are stats for this claim
        If ds.Tables("StatsFolder").Rows.Count > 0 Then

            Dim dr As DataRow

            ' for each stats folder 
            For Each dr In ds.Tables("StatsFolder").Rows

                Dim lTransactionExportFolderCnt As Integer
                Dim lStatsFolderCnt As Integer = Cast.ToInt32(dr.Item("Stats_Folder_Cnt"), 0)
                Dim lDocumentId As Integer
                Dim lDocumentTypeId As Integer = 0

                Const ClaimPaymentDocumentTypeId As Integer = 28
                'Const ClaimReceiptDocumentTypeId As Integer = 29

                If sTransactionTypeCode = TransactionTypeCode.PayClaim Then
                    lDocumentTypeId = ClaimPaymentDocumentTypeId
                ElseIf sTransactionTypeCode = TransactionTypeCode.ThirdPartyRecovery Then
                    'lDocumentTypeId = ClaimReceiptDocumentTypeId
                End If

                ' create stats for coinsurance / reinsurance 
                CreateStatsForCoinsReins(con, lClaimId, lStatsFolderCnt, lDocumentTypeId)

                ' finalise the stats
                FinaliseStats(con, lClaimId, lTransactionTypeId, sTransactionTypeCode, lStatsFolderCnt, 0)
                If Cast.ToInt32(lSuppressReserveTransactions, 0) = 1 Or (sTransactionTypeCode = TransactionTypeCode.PayClaim AndAlso Cast.ToInt32(lSuppressPaymentTransactions, 0) = 1) Then
                    Exit Sub
                End If
                ' create the transactions 
                CreateTransactions(con, lStatsFolderCnt, lTransactionExportFolderCnt)

                ' call the accounts process and get the generated document id
                SendToOrion(con, lTransactionExportFolderCnt, lDocumentId, CurrencyID:=CurrecnyID)

                ' associate the claim payment with the returned document
                If sTransactionTypeCode = TransactionTypeCode.PayClaim Then

                    UpdatePaymentDocumentDetails(con, lStatsFolderCnt)

                Else

                    ' associate the claim receipt with the returned document
                    UpdateReceiptDocumentDetails(con, lStatsFolderCnt)

                End If

            Next

        End If

    End Sub

