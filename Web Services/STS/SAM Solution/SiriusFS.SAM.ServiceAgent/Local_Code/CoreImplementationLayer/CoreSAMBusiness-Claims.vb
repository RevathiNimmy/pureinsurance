    Private Function ConvertBaseTaxCalculationItemToBaseClaimReceiptTaxItemType(ByVal ConvertFrom As BaseTaxCalculationItemType) As BaseClaimReceiptTaxItemType

        Dim ConvertTo As New BaseClaimReceiptTaxItemType

