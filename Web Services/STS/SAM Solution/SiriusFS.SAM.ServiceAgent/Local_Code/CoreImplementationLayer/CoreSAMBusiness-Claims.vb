    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="oClaimPayment"></param>
    ''' <param name="r_bUserIsAuthorisedToMakePayment"></param>
    ''' <param name="IsDataTransferClaim"></param>
    ''' <param name="lProcessType"></param>
    ''' <param name="bIsTPASettleDirectly"></param>
    ''' <remarks></remarks>
    Private Sub ProcessClaimPayment(ByVal Con As SiriusConnection,
                               ByVal oClaimPayment As BaseClaimPaymentType,
                               ByRef r_bUserIsAuthorisedToMakePayment As Boolean,
                               ByVal IsDataTransferClaim As Boolean,
                               Optional ByVal lProcessType As Long = 3,
                               Optional ByVal bIsTPASettleDirectly As Boolean = True)

        Dim oBusiness As New CoreBusiness
        Dim sTransactionTypeid As Integer
        Dim oSAMErrorCollection As New SAMErrorCollection

        Const ACModeProcessed As Integer = 0
        Const ACModeReferred As Integer = 1

        r_bUserIsAuthorisedToMakePayment = IsUserAuthorisedToMakePayment(Con, oBusiness, oClaimPayment, bIsTPASettleDirectly)

        If IsDataTransferClaim Then
            r_bUserIsAuthorisedToMakePayment = True
        End If

        If r_bUserIsAuthorisedToMakePayment OrElse bIsTPASettleDirectly Then
            If oClaimPayment.AllowNegativeReserve = "0" Then
                SaveReserveAdjustmentsToAccounts(Con, oClaimPayment)
            End If

            SavePaymentToAccounts(Con, oClaimPayment)
        End If

        If r_bUserIsAuthorisedToMakePayment = True Then

            UpdateInsuranceFileSystem(con:=Con,
                                        lUserId:=_SiriusUser.UserID,
                                        lInsuranceFileCnt:=oClaimPayment.InsuranceFileCNT,
                                        sTransactionTypeCode:=ksPayClaimType)

            GetTransactionTypeId(Con:=Con,
                                        sTransactionTypeCode:=ksPayClaimType,
                                        r_TransactionTypeId:=sTransactionTypeid)

            If Not IsDataTransferClaim Then

                If oClaimPayment.AllowNegativeReserve = "0" Then ''PN 3677
                    lProcessType = 4
                End If
                Dim lSuppressPaymentTransactions As Integer = 0
                lSuppressPaymentTransactions = GetPaymentSuppressValue(Con, oClaimPayment.ClaimId, TransactionTypeCode.PayClaim)

                RaiseTransactions(con:=Con, _
                                            lClaimId:=oClaimPayment.ClaimId, _
                                            lTransactionTypeId:=sTransactionTypeid, _
                                            sTransactionTypeCode:=TransactionTypeCode.PayClaim, _
                                            lSuppressReserveTransactions:=0, _
                                            CurrecnyID:=oClaimPayment.CurrencyId, _
                                            bPostAllStats:=CBool(IIf(lProcessType = 4, True, False)))
            End If

            UpdateClaimIsDirtyFlag(con:=Con,
                                lClaimId:=oClaimPayment.ClaimId,
                                lIsDirty:=0)

            SetPaymentReferred(Con,
                                lClaimId:=oClaimPayment.ClaimId,
                                lStatus:=ACModeProcessed)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_UpdateClaimDescription")
                cmd.AddInParameter("@Claim_id", SqlDbType.BigInt).Value = oClaimPayment.ClaimId
                cmd.AddInParameter("@description", SqlDbType.VarChar, 1000).Value = "Payment of Claim - Payment Authorized"
                Con.ExecuteNonQuery(cmd)
            End Using

        Else



            SetPaymentReferred(Con:=Con,
                                lClaimId:=oClaimPayment.ClaimId,
                                lStatus:=ACModeReferred)
            Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType
            Dim sOptionValue As String = "0"
            Dim nReturn As Integer = 0
            'Get the product id
            Dim dsProductId As DataSet = Nothing
            Dim nProductId As Integer

            Try

                'Get the product id from insurance file count 
                GetInsFileCntProductId(con:=Con,
                                        lInsuranceFileCnt:=0,
                                        dsProductId:=dsProductId,
                                        lBaseClaimID:=oClaimPayment.BaseClaimKey)
                If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
                AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
                    nProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
                Else
                    'Failed to get the product id from the given base claim key
                    oSAMErrorCollection.AddInvalidData(
                                            SAMConstants.SAMInvalidData.GeneralFailure,
                                            "Failed to get product details for the given Claim")

                    oSAMErrorCollection.CheckForErrors()

                End If
            End If

                oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsRecommendClaimPayments

                sOptionValue = GetProductRiskOptions(Con, nProductId, oGetProductRiskOptionsRequest)
                If String.IsNullOrEmpty(sOptionValue) Then
                    sOptionValue = "0"
                End If

                If sOptionValue = "1" Then
                    nReturn = SetPaymentRecommendation(Con, oClaimPayment.ClaimId, 1)
                    If nReturn <> PMReturnCode.PMTrue Then
                        oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.RecommendationProcessingFailed,
                                                                            SAMBusinessErrors.RecommendationProcessingFailed.ToString,
                                                                            "Unable to set payment for recommendation")
                        oSAMErrorCollection.CheckForErrors()
                    End If
                End If

                CreateReferralTask(Con:=Con,
                                    lBranchID:=oClaimPayment.SourceId,
                                           lSourceId:=oClaimPayment.SourceId,
                                           lClaimId:=oClaimPayment.ClaimId,
                                           sClaimNumber:=oClaimPayment.ClaimNumber,
                                       totCurrAmount:=oClaimPayment.TotCurrAmount)

            Catch ex As Exception
            Finally
                oGetProductRiskOptionsRequest = Nothing
            End Try
        End If

    End Sub

