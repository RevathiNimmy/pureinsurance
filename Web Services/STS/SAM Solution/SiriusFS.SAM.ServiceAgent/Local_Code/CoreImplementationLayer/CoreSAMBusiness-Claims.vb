    Public Overloads Function GetClaimRIArrangementLinesRI2007(ByVal con As SiriusConnection, ByVal oRequest As BaseGetClaimRIArrangementLinesRI2007RequestType) As BaseGetClaimRIArrangementLinesRI2007ResponseType

        Dim oResponse As New BaseGetClaimRIArrangementLinesRI2007ResponseType
        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim iSourceId As Integer
        Dim nTypeOfPackage As enumTypeOfPackage

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimRIArrangementLinesRI2007RequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimRIArrangementLinesRI2007ResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
            Return Nothing
        End If

        oRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()
        ' Lookup Codes to ensure they are valid
        iSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        oSAMErrorCollection.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim dsArrangementLines As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_saa_RI2007")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
            cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oRequest.ArrangementKey
            If oRequest.ModeSpecified Then
                cmd.AddInParameter("@mode", SqlDbType.Int).Value = oRequest.Mode
            End If
            If oRequest.IsRecoverySpecified Then
                cmd.AddInParameter("@recovery", SqlDbType.Int).Value = IIf(oRequest.IsRecovery, 1, 0)
                If oRequest.ModeSpecified = False Then
                    cmd.AddInParameter("@mode", SqlDbType.Int).Value = 0
                End If
            End If
            dsArrangementLines = con.ExecuteDataSet(cmd, "Row")

            If (dsArrangementLines.Tables.Count > 0) Then
                If (dsArrangementLines.Tables(0).Rows.Count > 0) Then
                    For icount As Integer = 0 To dsArrangementLines.Tables(0).Rows.Count - 1
                        ReDim Preserve oResponse.RIArrangementLines(icount)
                        oResponse.RIArrangementLines(icount) = New BaseClaimRiskRIArrangementLineType

                        With oResponse.RIArrangementLines(icount)
                            .RIArrangementKey = oRequest.ArrangementKey
                            .RIArrangementLineKey = Cast.ToInt32(dsArrangementLines.Tables(0).Rows(icount).Item("ri_arrangement_line_id"), 0)
                            .RIPlacement = dsArrangementLines.Tables(0).Rows(icount).Item("ri_placement").ToString
                            .RIName = dsArrangementLines.Tables(0).Rows(icount).Item("ri_name").ToString
                            .Type = dsArrangementLines.Tables(0).Rows(icount).Item("type").ToString
                            .Retained = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("retained"), 0)
                            .RetainedSpecified = True
                            .DefaultSharePercent = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("default_share_percent"), 0) * 100
                            .ThisSharePercent = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("this_share_percent"), 0) * 100
                            .LowerLimit = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("lower_limit"), 0)
                            If .LowerLimit > 0 Then
                                .LowerLimitSpecified = True
                            End If
                            .LineLimit = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("line_limit"), 0)
                            .SumInsured = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("sum_insured"), 0)
                            .AgreementCode = dsArrangementLines.Tables(0).Rows(icount).Item("agreement_code").ToString
                            .IsDomiciledForTax = dsArrangementLines.Tables(0).Rows(icount).Item("Domiciled_For_Tax").ToString = "1"
                            .IsDomiciledForTaxSpecified = True
                            .Grouping = Cast.ToInt32(dsArrangementLines.Tables(0).Rows(icount).Item("grouping"), 0)
                            If .Grouping > 0 Then
                                .GroupingSpecified = True
                            End If
                            .IsRIBroker = dsArrangementLines.Tables(0).Rows(icount).Item("is_ri_broker").ToString = "1"
                            .IsRIBrokerSpecified = True
                            .ReinsuranceTypeCode = dsArrangementLines.Tables(0).Rows(icount).Item("type").ToString
                            If Cast.ToInt32(dsArrangementLines.Tables(0).Rows(icount).Item("treaty_id"), 0) > 0 Then
                                .TreatyCode = GetListCodeFromID(Core.STSListType.PMLookup, "treaty", Cast.ToInt32(dsArrangementLines.Tables(0).Rows(icount).Item("treaty_id"), 0))
                            End If
                            .TreatyID = Cast.ToInt32(dsArrangementLines.Tables(0).Rows(icount).Item("treaty_id"), 0)
                            .PartyKey = Cast.ToInt32(dsArrangementLines.Tables(0).Rows(icount).Item("party_cnt"), 0)
                            If .PartyKey > 0 Then
                                .PartyKeySpecified = True
                            End If
                            .Priority = Cast.ToInt32(dsArrangementLines.Tables(0).Rows(icount).Item("priority"), 0)
                            .NumberOfLines = Cast.ToInt32(dsArrangementLines.Tables(0).Rows(icount).Item("number_of_lines"), 0)
                            .Incurred = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("Incurred"), 0)
                            If .Incurred <> 0 Then
                                .IncurredSpecified = True
                            End If
                            .ReserveToDate = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("Reserve"), 0)
                            .ThisReserve = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("This_Reserve"), 0)
                            .PaymentToDate = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("Payment"), 0)
                            .ThisPayment = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("This_Payment"), 0)
                            .RecoverToDate = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("RecoveredToDate"), 0)
                            If .RecoverToDate <> 0 Then
                                .RecoverToDateSpecified = True
                            End If
                            .Balance = Cast.ToDouble(dsArrangementLines.Tables(0).Rows(icount).Item("Balance"), 0)
                            .BalanceSpecified = True
                            .CedePremiumOnly = dsArrangementLines.Tables(0).Rows(icount).Item("cede_premium_only").ToString = "1"
                            If (Trim(.ReinsuranceTypeCode.ToString.ToLower) <> "fx") Then
                                .BrokerParticipants = GetBrokerParticipants(con, .RIArrangementLineKey, False)
                            Else
                                .FAXParticipants = GetClaimFAXParticipants(con, oRequest.ClaimKey, .Grouping)
                            End If
                        End With
                    Next
                End If
            End If
        End Using

        Return oResponse

    End Function

    Private Function GetClaimFAXParticipants(ByVal con As SiriusConnection, ByVal lClaimKey As Long, ByVal lGroupingKey As Long) As BaseClaimFAXParticipants()
        Dim oFAXParticipants As BaseClaimFAXParticipants()
        Dim dsFAXParticipants As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_Sir_GetClaimGroupedRiArangementLines")
            cmd.AddInParameter("@Claim_Id", SqlDbType.Int).Value = lClaimKey
            cmd.AddInParameter("@GroupingId", SqlDbType.Int).Value = lGroupingKey
            cmd.AddInParameter("@ProcessId", SqlDbType.Int).Value = 2
            dsFAXParticipants = con.ExecuteDataSet(cmd, "Row")
            If (dsFAXParticipants.Tables.Count > 0) Then
                If (dsFAXParticipants.Tables(0).Rows.Count > 0) Then
                    For icount As Integer = 0 To dsFAXParticipants.Tables(0).Rows.Count - 1
                        ReDim Preserve oFAXParticipants(icount)
                        oFAXParticipants(icount) = New BaseClaimFAXParticipants
                        oFAXParticipants(icount).RIArrangementLineKey = Cast.ToInt32(dsFAXParticipants.Tables(0).Rows(icount).Item("ri_arrangement_line_id"), 0)
                        oFAXParticipants(icount).PartyKey = Cast.ToInt32(dsFAXParticipants.Tables(0).Rows(icount).Item("party_cnt"), 0)
                        oFAXParticipants(icount).PartyCode = dsFAXParticipants.Tables(0).Rows(icount).Item("shortname").ToString
                        oFAXParticipants(icount).PartyName = dsFAXParticipants.Tables(0).Rows(icount).Item("name").ToString
                        oFAXParticipants(icount).AccountType = dsFAXParticipants.Tables(0).Rows(icount).Item("Acct_Type").ToString
                        oFAXParticipants(icount).ParticpationPercentage = Cast.ToSingle(dsFAXParticipants.Tables(0).Rows(icount).Item("participation_percent"), 0)
                        oFAXParticipants(icount).SumInsured = Cast.ToDouble(dsFAXParticipants.Tables(0).Rows(icount).Item("Sum_Insured"), 0)
                        oFAXParticipants(icount).AgreementCode = dsFAXParticipants.Tables(0).Rows(icount).Item("Agreement_Code").ToString
                        oFAXParticipants(icount).ReserveToDate = Cast.ToDouble(dsFAXParticipants.Tables(0).Rows(icount).Item("reserve"), 0)
                        oFAXParticipants(icount).ThisReserve = Cast.ToDouble(dsFAXParticipants.Tables(0).Rows(icount).Item("this_reserve"), 0)
                        oFAXParticipants(icount).PaymentToDate = Cast.ToDouble(dsFAXParticipants.Tables(0).Rows(icount).Item("payment"), 0)
                        oFAXParticipants(icount).ThisPayment = Cast.ToDouble(dsFAXParticipants.Tables(0).Rows(icount).Item("this_payment"), 0)
                        oFAXParticipants(icount).RecoverToDate = Cast.ToDouble(dsFAXParticipants.Tables(0).Rows(icount).Item("Recovery"), 0)
                        oFAXParticipants(icount).RecoverToDateSpecified = True
                        oFAXParticipants(icount).BrokerParticipants = GetBrokerParticipants(con, oFAXParticipants(icount).RIArrangementLineKey, False)
                    Next
                End If
            End If
        End Using
        Return oFAXParticipants
    End Function

