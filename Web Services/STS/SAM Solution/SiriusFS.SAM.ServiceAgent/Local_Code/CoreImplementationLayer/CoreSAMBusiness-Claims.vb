            End If
            Dim xmlDoc As New System.Xml.XmlDocument
            dsResultInsuranceFile.DataSetName = "BaseFindInsuranceFileResponseTypeInsuranceFileDetails"
            dsResultInsuranceFile.Tables(0).TableName = "Row"

            If oRequest.WCFSecurityToken = "" Then
            xmlDoc.LoadXml(dsResultInsuranceFile.GetXml)
            If (dsInsuranceFile.Tables.Count >= 1) Then
                oResponse.ResultDataset = xmlDoc.DocumentElement()
            End If
            End If
            oResponse.ResultData = dsResultInsuranceFile
        Else
            oResponse.ResultDataset = Nothing
            oResponse.ResultData = Nothing
        End If
        

        Return oResponse
    End Function

