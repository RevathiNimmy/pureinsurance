            ConvertTo.Amount = ConvertFrom.TaxValue
            ConvertTo.Percentage = ConvertFrom.TaxPercentage
            ConvertTo.RecoveryType = ConvertFrom.RecoveryType
            ConvertTo.TaxBandCode = ConvertFrom.TaxBandCode
            ConvertTo.TaxGroupCode = ConvertFrom.TaxGroupCode

