    ''' <summary>
    ''' validate the request structure against the specified warnings 
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="oRequest"></param>
    ''' <param name="oResponse"></param>
    ''' <remarks></remarks>
    Private Sub MaintainClaimValidateBusinessWarnings(
                        ByVal oBusiness As CoreBusiness,
                        ByRef oRequest As BaseClaimMaintainRequestType,
                        ByRef oResponse As BaseClaimResponseType,
                        ByRef oSAMErrorCollection As SAMErrorCollection)

        ' check if the loss date has changed between this and the previous version
        BusinessWarningLossDateChanged(oRequest, oResponse)

        ' check if the risk is deferred
        BusinessWarningValidateRiskStatus(oRequest.Claim.RiskKey, oResponse, oSAMErrorCollection)

        ' check the claim dates and policy dates tie up correctly
        BusinessWarningValidateClaimPolicyDates(oRequest.Claim.InsuranceFileKey, oRequest.Claim, oResponse, oSAMErrorCollection)

        ' if the claim is info only confirm that the request doesnt contain data that will not be saved
        BusinessWarningsValidateInfoOnly(oRequest.Claim, oRequest.Claim.ClaimPeril,
                oResponse, oSAMErrorCollection)

    End Sub

    Private Sub BusinessWarningLossDateChanged(
    ByVal oRequest As BaseClaimMaintainRequestType,
    ByVal oResponse As BaseClaimResponseType)

        If oRequest.Claim.LossFromDate <> oRequest.Claim.PreviousLossFromDate Then

            AddWarning(oResponse,
                    SAMBusinessWarnings.LossDateChanged,
                        SAMBusinessWarnings.LossDateChanged.ToString)

        End If

    End Sub

    ''' <summary>
    '''  validates all the data in the request that can be validated
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub MaintainClaimValidateData(
                ByVal oBusiness As CoreBusiness,
                ByRef oRequest As BaseClaimMaintainRequestType,
                ByRef oSAMErrorCollection As SAMErrorCollection)

        Dim iUnderWritingYearID As Integer = 0

        If oRequest.Claim IsNot Nothing Then
            iUnderWritingYearID = Convert.ToInt32(oRequest.Claim.UnderwritingYearId)
        End If


        ' validate core standard lookup data (used by both open claim and maintain claim)
        CoreClaimValidateDataStandardLookup(oBusiness, oRequest.Claim, oSAMErrorCollection, oRequest.BranchCode)

        ' validate gis lookup data (used by both open claim and maintain claim
        CoreClaimValidateDataGISLookup(oBusiness, oRequest.Claim, oSAMErrorCollection)

        '***************************************
        ' Validate Core Claim Data Links
        '***************************************
        ' The insurance file key and risk key should be linked appropriately,
        ' likewise the primary_cause_id and secondary_cause_id should be 
        ' linked appropriately to the specified risk

        ' get the default claim links
        GetBaseClaimDetails(oRequest, oSAMErrorCollection)

        If iUnderWritingYearID > 0 Then
            If oRequest.Claim IsNot Nothing Then
                oRequest.Claim.UnderwritingYearId = iUnderWritingYearID
            End If
        End If

        CoreClaimValidateDataLinks(oRequest.Claim.InsuranceFileKey, oRequest.Claim.RiskKey,
           oRequest.Claim.PrimaryCauseId, oRequest.Claim.SecondaryCauseId, oSAMErrorCollection)

        ''*************************************** 
        ''' Validate Claim Peril Ids
        '***************************************
        MaintainClaimValidateClaimPerilDetails(oRequest, oSAMErrorCollection)

        '*************************************** 
        ''' Validate Claim Peril / Reserve / Recovery Types
        '***************************************
        CoreValidateClaimPerilDetails(oRequest.Claim.RiskKey, oRequest.Claim.ClaimPeril,
            oSAMErrorCollection)

        '***************************************
        ''' Validate claim client contact details
        '***************************************   
        If oRequest.Claim.Client IsNot Nothing Then
            CoreValidateClientContactTypes(oRequest.Claim.Client.Contact, oSAMErrorCollection)
        End If

        '***************************************
        ''' Validate claim insurer contact details
        '***************************************      
        If oRequest.Claim.Insurer IsNot Nothing Then
            CoreValidateInsurerContactTypes(oRequest.Claim.Insurer.Contact, oSAMErrorCollection)
        End If

    End Sub

        'Process Flow 
        '1.Determine the type of package and thus the type of response 
        '2.Structure Validation (function called-->ClaimReceiptRequest.validate)
        '3.Data Validation (function called-->ClaimReceiptValidateData.validate)
        '4.Business Rule Validation (function called-->ClaimReceiptValidateBusinessRules)
        '5.Main Function saveClaimReceipt
        '---------------------------------------------------CLAIM RECEIPT----------------------------------------------------------------
    Public Overloads Function ClaimReceipt(ByVal con As SiriusConnection, ByVal Request As BaseClaimReceiptRequestType) As Object

        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim oResponse As Object = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim TimeStamp As Byte()

        Dim oClaimReceipt As BaseClaimReceiptType = Request.ClaimReceipt

        ' determine the type of package and thus the type of response
        If Request.GetType Is GetType(SAMForInsuranceImplementationTypes.ClaimReceiptRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.ClaimReceiptResponseType
        ElseIf Request.GetType Is GetType(SAMForInsuranceImplementationTypes.GetClaimReceiptTaxesRequestType) Then
            oResponse = New SAMForInsuranceImplementationTypes.GetClaimReceiptTaxesResponseType
        ElseIf Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ClaimReceiptRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.ClaimReceiptResponseType
        ElseIf Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxesRequestType) Then
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxesResponseType
        Else
            oResponse = New BaseImplementationTypes.BaseClaimResponseType
        End If
        GetVersionId(Request.ClaimReceipt.BaseClaimPerilKey,
                                      Request.ClaimReceipt.VersionId,
                                       con)

        '************************
        ' get system options details
        '************************
        ' get these here as some of the validation requires knowledge of which system options are set
        GetClaimReceiptSystemOptions(Request, oCoreBusiness)

        '************************
        ' Validation 
        '************************
        ' validate that the requests  struture / data and passes any existing business rules
        ' return and populates the claim details object
        ''Saurabh -- Validate Claim Receipt only if request is not from GetClaimReceiptTaxesRequest
        If Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxesRequestType) Then
            Request.ClaimReceipt.IsGetClaimReceiptTaxesType = True
        Else
            Request.ClaimReceipt.IsGetClaimReceiptTaxesType = False
        End If
        ValidateClaimReceiptRequest(con, Request, oCoreBusiness, oSAMErrorCollection)

        ' catch any validation errors which havent already been raised
        oSAMErrorCollection.CheckForErrors()

        '*********************
        ' Get Required Information 
        ' Try and retrieve as much information as possible prior to 
        ' opening the more expensive interop connection object
        '*********************

        ' retrieve the following information only if the advanced tax system option is on 
        If Request.ClaimReceipt.IsAdvancedTaxSystemOptionOn Then

            ' get the details of the tax groups / tax bands for use in advanced tax validation
            Request.ClaimReceipt.AdditionalDetails.TaxGroupTaxBandDetails = GetClaimTaxGroupTaxBandDetails(con)

        End If

        ' only get the following information if this is actually a claim receipt 
        ' getclaimreceipttaxes does not need this information
        If Request.GetType Is GetType(SAMForInsuranceImplementationTypes.ClaimReceiptRequestType) Or
            Request.GetType Is GetType(BaseImplementationTypes.BaseClaimReceiptRequestType) Or
            Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ClaimReceiptRequestType) Then

            ' Retrieve the account details for CLMRECEIVABLE Account
            GetAccountDetailsFromShortCode(con, InternalSAMConstants.kAccountShortnameCLMRECEIVABLE, Request.ReceiptPartyAccountId)

            ' if a party to pay has been selected then get the account details for that party
            If oClaimReceipt.ReceiptPartyType <> ClaimReceiptPartyTypeType.CLMRECEIVABLE Then

                If oClaimReceipt.PartyKey <> ClaimReceiptPartyTypeType.CLMRECEIVABLE Then

                    GetAccountDetailsForParty(con, oClaimReceipt.PartyKey,
                        Request.ReceiptPartyAccountId,
                        Request.ReceiptPartyAccountCode,
                        Request.ReceiptPartyShortCode)

                End If

            Else

                ' if this is a payment to clmreceivable default the account shortcode
                Request.ReceiptPartyShortCode = InternalSAMConstants.kAccountShortnameCLMRECEIVABLE

            End If

        End If

        ' Retrieve the Transaction To Loss Currency Exchange Rate 
        GetCurrencyToCurrencyExchangeRate(con, oClaimReceipt.TransactionDate,
            oClaimReceipt.CurrencyId, Request.ClaimReceipt.AdditionalDetails.Claim.LossCurrencyKey,
                Request.SourceId, oClaimReceipt.ReceiptToLossXRate)


        If Not Request.IsDataTransferClaim Then
            con.BeginTransaction()
        End If

        If Request.GetType Is GetType(SAMForInsuranceImplementationTypes.ClaimReceiptRequestType) Or
            Request.GetType Is GetType(BaseImplementationTypes.BaseClaimReceiptRequestType) Or
            Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ClaimReceiptRequestType) Then

            Try

                oResponse = ProcessClaimReceipt(con, oCoreBusiness, Request)

                oSAMErrorCollection.CheckForErrors()

                If Not Request.IsDataTransferClaim Then
                    ' commit transaction
                    con.CommitTransaction()
                End If

            Catch

                If Not Request.IsDataTransferClaim Then
                    ' rollback transaction
                    con.RollbackTransaction()
                End If

                If Not Request.IsDataTransferClaim Then
                    If Request.GetType IsNot GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxesRequestType) Then
                        ' unlock and get the new timestamp
                        oCoreBusiness.UnlockAndGetSAMTS( _
                            con, _
                            Request.BranchCode, _
                            CoreBusiness.LockName.ClaimId, _
                            Request.ClaimReceipt.BaseClaimKey, _
                             TimeStamp)

                        DeleteExlusiveLock(con, _
                                  oCoreBusiness, _
                                  CoreBusiness.LockName.ClaimId, _
                                  Request.ClaimReceipt.BaseClaimKey, _
                                  Request.BranchCode)
                    End If
                End If

                Throw

            End Try

        ElseIf Request.GetType Is GetType(SAMForInsuranceImplementationTypes.GetClaimReceiptTaxesRequestType) Or Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxesRequestType) Then ' Process 1'st kind of Request

            oResponse = GetClaimReceiptTaxDetails(con, oCoreBusiness, Request)

        End If


        ' unlock and get the new timestamp
        If Request.GetType IsNot GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxesRequestType) Then
            oCoreBusiness.UnlockAndGetSAMTS( _
                con, _
                Request.BranchCode, _
                CoreBusiness.LockName.ClaimId, _
                Request.ClaimReceipt.BaseClaimKey, _
                 TimeStamp)
            DeleteExlusiveLock(con, _
                             oCoreBusiness, _
                             CoreBusiness.LockName.ClaimId, _
                             Request.ClaimReceipt.BaseClaimKey, _
                             Request.BranchCode)
        End If
        End If
        If Request.GetType Is GetType(SAMForInsuranceImplementationTypes.ClaimReceiptRequestType) Or _
          Request.GetType Is GetType(BaseImplementationTypes.BaseClaimPaymentRequestType) Then ' Process 1'st kind of Request
            CType(oResponse, SAMForInsuranceImplementationTypes.ClaimReceiptResponseType).TimeStamp = TimeStamp
        ElseIf Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.ClaimReceiptRequestType) Then
            CType(oResponse, SAMForInsuranceV2ImplementationTypes.ClaimReceiptResponseType).TimeStamp = TimeStamp
        End If

        Return oResponse

    End Function
    Public Overloads Function ClaimReceipt(ByVal Request As BaseClaimReceiptRequestType) As Object

