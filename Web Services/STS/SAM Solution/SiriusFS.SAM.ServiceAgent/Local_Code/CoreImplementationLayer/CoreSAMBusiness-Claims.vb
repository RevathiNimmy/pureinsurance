    Private Sub GetRIArrangementLines(ByVal con As SiriusConnection,
                                     ByVal lClaimId As Integer,
                                       ByVal oRIArrangement As RIArrangement)

        Const kDefaultSharePercent As Integer = 1
        Const kThisSharePercent As Integer = 2

        Dim ds As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_RI_Arrangement_Line_saa")

            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = lClaimId
            cmd.AddInParameter("@ri_arrangement_id", SqlDbType.Int).Value = oRIArrangement.ArrangementID

            ds = con.ExecuteDataSet(cmd, "RIArrangementLines")

        End Using

        ' if there were rows returned
        If ds.Tables.Count > 0 Then

            If ds.Tables("RIArrangementLines").Rows.Count > 0 Then

                Dim dr As DataRow

                ' for each arrangement line associated with the arrangement
                For Each dr In ds.Tables("RIArrangementLines").Rows

                    Dim oRIArrangementLine As New RIArrangementLine

                    oRIArrangementLine.RiName = Cast.ToString(dr.Item("ri_name"))
                    oRIArrangementLine.DefaultSharePercent = Cast.ToDouble(dr.Item(kDefaultSharePercent), 0)
                    oRIArrangementLine.ThisSharePercent = Cast.ToDouble(dr.Item(kThisSharePercent), 0)
                    oRIArrangementLine.SumInsured = Cast.ToDecimal(dr.Item("sum_insured"), 0)
                    oRIArrangementLine.Reserve = Cast.ToDecimal(dr.Item("reserve"), 0)
                    oRIArrangementLine.ThisReserve = Cast.ToDecimal(dr.Item("this_reserve"), 0)
                    oRIArrangementLine.Payment = Cast.ToDecimal(dr.Item("payment"), 0)
                    oRIArrangementLine.ThisPayment = Cast.ToDecimal(dr.Item("this_payment"), 0)
                    oRIArrangementLine.Balance = Cast.ToDecimal(dr.Item("balance"), 0)
                    oRIArrangementLine.AgreementCode = dr.Item("agreement_code").ToString
                    oRIArrangementLine.RiArrangementLineId = Cast.ToInt32(dr.Item("ri_arrangement_line_id"), 0)
                    oRIArrangementLine.Type = dr.Item("type").ToString
                    oRIArrangementLine.TreatyId = Cast.ToInt32(dr.Item("treaty_id"), 0)
                    oRIArrangementLine.PartyCnt = Cast.ToInt32(dr.Item("party_cnt"), 0)
                    oRIArrangementLine.XolArrangementId = Cast.ToInt32(dr.Item("xol_arrangement_id"), 0)
                    oRIArrangementLine.Priority = Cast.ToInt32(dr.Item("priority"), 0)
                    oRIArrangementLine.NumberofLines = Cast.ToInt16(dr.Item("number_of_lines"), CShort(0))
                    oRIArrangementLine.LineLimit = Cast.ToDecimal(dr.Item("line_limit"), 0)
                    oRIArrangementLine.Layer = Cast.ToInt32(dr.Item("layer"), 0)
                    oRIArrangementLine.CatastropheCodeId = Cast.ToInt32(dr.Item("catastrophe_code_id"), 0)
                    oRIArrangementLine.CatastropheCode = dr.Item("code").ToString
                    oRIArrangementLine.RIModelId = Cast.ToInt32(dr.Item("ri_model_id"), 0)
                    oRIArrangementLine.NextLayerModelId = Cast.ToInt32(dr.Item("xol_ri_model_id"), 0)
                    oRIArrangementLine.NextLayerTriggerAmount = Cast.ToDecimal(dr.Item("xol_limit"), 0)

                    ' resize the ri arrangement lines array
                    Dim lNextLine As Integer

                    If IsArray(oRIArrangement.RILines) Then
                        lNextLine = oRIArrangement.RILines.GetUpperBound(0) + 1
                    Else
                        lNextLine = 0
                    End If

                    Array.Resize(oRIArrangement.RILines, lNextLine + 1)

                    ' add the line to the RIArrangement
                    oRIArrangement.RILines(lNextLine) = oRIArrangementLine

                Next

            End If

        End If

    End Sub

    ''' <summary>
    ''' if there is no agent no the policy ensure that no agent details are saved to the claim
    ''' </summary>
    ''' <param name="oRequest"></param>
    ''' <remarks></remarks>
    Private Sub ClearAgentDetails(ByVal oRequest As BaseClaimOpenRequestType)
        ' if there is no insurer - ensure agent details are cleared down in request
        oRequest.Claim.InsurerFaxNo = String.Empty
        oRequest.Claim.InsurerEmail = String.Empty
        oRequest.Claim.InsurerShortName = String.Empty
        oRequest.Claim.InsurerAddressId = 0
        oRequest.Claim.InsurerAddressTypeId = 0
