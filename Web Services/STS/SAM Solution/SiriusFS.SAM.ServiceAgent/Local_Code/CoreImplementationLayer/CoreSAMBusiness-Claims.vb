    Private Sub GetClaimPaymentTaxGroupsValidateData(
    ByVal oBusiness As CoreBusiness,
    ByVal oRequest As BaseGetClaimPaymentTaxGroupsRequestType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        ' Branch code
        oRequest.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)

        ' Validate Base Party Key/Receipt Party Type
        ValidatePaymentPartyType(oRequest.PartyKey, oRequest.PaymentPartyType, oSAMErrorCollection)

