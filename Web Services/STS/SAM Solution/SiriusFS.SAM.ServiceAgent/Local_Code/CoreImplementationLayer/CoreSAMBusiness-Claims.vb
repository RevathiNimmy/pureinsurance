    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="lBaseClaimId"></param>
    ''' <param name="lBranchCode"></param>
    ''' <param name="sTransTypeCode"></param>
    ''' <param name="lCreatedBy"></param>
    ''' <param name="r_lClaimId"></param>
    ''' <param name="r_lVersionId"></param>
    ''' <param name="r_lStatus"></param>
    ''' <remarks></remarks>
    Private Sub ProcessCopyClaim(ByVal Con As SiriusConnection,
                                      ByVal lBaseClaimId As Integer,
                                      ByVal lBranchId As Integer,
                                      ByVal sTransTypeCode As String,
                                      ByVal lCreatedBy As Integer,
                                      ByRef r_lClaimId As Integer,
                                      ByRef r_lVersionId As Integer,
                                      ByVal isDataTransferProcess As Boolean,
                                      ByVal dataTransferHasClaimRiskDataSpecified As Boolean,
                                      ByVal dataTransferIsUsingFullClaimVersioning As Boolean,
                                      Optional ByVal oRequest As BaseClaimMaintainRequestType = Nothing)

        Dim oBusiness As New CoreBusiness
        Dim lStatus As Integer
        Dim lOriginalClaimId As Integer
        Dim bBaseInfoOnly As Boolean
        ' Get the Current Version of Claim id and pass it to the Copy Claim process
        GetCurrentClaimId(Con:=Con,
                       lBaseClaimId:=lBaseClaimId,
                       r_lClaimId:=lOriginalClaimId)

        ' copy the claim related details
        CopyClaim(con:=Con,
                      lClaimId:=lOriginalClaimId,
                      sTransTypeCode:=sTransTypeCode,
                      lCreatedBy:=lCreatedBy,
                      r_lClaimId:=r_lClaimId,
                      r_lVersionId:=r_lVersionId,
                      r_lStatus:=lStatus,
                      r_bisBaseInfoOnly:=bBaseInfoOnly)

        If sTransTypeCode = "C_CR" AndAlso Not oRequest Is Nothing Then
            If bBaseInfoOnly And Not oRequest.Claim.InfoOnly Then
                GetClaimNumber(Con, oRequest)
            End If
        End If
        ' if the return status from the stored procedure indicates
        ' that it failed raise an error
        If lStatus <> 0 Then
            Dim oSAMErrorCollection As New SAMErrorCollection
            oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.CopyClaimFailed,
                                                 SAMBusinessErrors.CopyClaimFailed.ToString)
            oSAMErrorCollection.CheckForErrors()
        End If

        ' if this is the data transfer process 

        ' if this is not the data transfer process - copy claim

        ' OR if this is the full claims data transfer process
        ' and data transfer risk data has not been specified

        If (Not isDataTransferProcess) OrElse
            (dataTransferIsUsingFullClaimVersioning AndAlso dataTransferHasClaimRiskDataSpecified = False) Then

            ' determine if the claims builder product option is switched on...
            Dim sResult As String = String.Empty
            Dim ClaimBuilderIsEnabled As Boolean
            sResult = oBusiness.GetProductOption(ProductOption.ClaimsBuilderEnabled, 1)

            If sResult = "1" Then
                ClaimBuilderIsEnabled = True
            Else
                ClaimBuilderIsEnabled = False
            End If

            If ClaimBuilderIsEnabled = True And r_lClaimId <> 0 Then
                CopyClaimGISWithVersions(
                    Con:=Con,
                    v_lOriginalClaimId:=lOriginalClaimId,
                    v_lCopyClaimId:=r_lClaimId)
            End If

        End If

    End Sub

