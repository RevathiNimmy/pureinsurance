    Private Sub GetClaimDetailsForPaymentOrReceipt(ByVal con As SiriusConnection,
    ByVal ClaimId As Integer,
    ByVal ClaimPerilId As Integer,
    ByRef AdditionalDetails As BaseAdditionalClaimRelatedDetails)

        Dim dt As DataTable = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Claim_Details_For_Payment")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = ClaimId
            cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = ClaimPerilId

            dt = con.ExecuteDataTable(cmd)

        End Using

        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

            ' there will always be one row
            Dim dr As DataRow = dt.Rows(0)

            If AdditionalDetails Is Nothing Then
                AdditionalDetails = New BaseAdditionalClaimRelatedDetails
            End If

            With AdditionalDetails.Claim
                .LossCurrencyKey = Cast.ToInt32(dr.Item("loss_currency_id"), 0)
                .LossCurrencyDescription = Cast.ToStringTrim(dr.Item("loss_currency_description"))
                .ClaimNumber = Cast.ToStringTrim(dr.Item("claim_number"))
                .LossFromdate = Cast.ToDateTime(dr.Item("loss_from_date"), Date.MinValue)
            End With

            If Cast.ToInt32(dr.Item("lead_agent_cnt"), 0) <> 0 Then
                AdditionalDetails.Agent = New BaseAgentAdditionalDetailsType
                With AdditionalDetails.Agent

                    'agent.name agent_name,  
                    'agent.domiciled_for_tax agent_domiciled_for_tax,  
                    'agent.tax_number agent_tax_number,  
                    'agent.tax_percentage agent_tax_percentage,  
                    'agent.tax_exempt agent_tax_exempt,  
                    'pa.is_in_transfer_mode,  
                    'business_type.code as transfer_to_business_type_id,  

                    .AccountCurrencyKey = Cast.ToInt32(dr.Item("agent_currency"), 0)
                    If InStr(dr.Item("agent_date_cancelled").ToString, "1899") > 0 Then
                        .Cancelled = False
                    Else
                        .Cancelled = CBool(Cast.ToDateTime(dr.Item("agent_date_cancelled"), Date.MinValue) < Date.Now)
                    End If
                    .IsDomiciledForTax = CBool(Cast.ToInt16(dr.Item("agent_domiciled_for_tax"), 0))
                    .Name = Cast.ToStringTrim(dr.Item("agent_name"))
                    .PartyKey = Cast.ToInt32(dr.Item("lead_agent_cnt"), 0)
                    .IsTaxExempt = CBool(Cast.ToInt32(dr.Item("agent_tax_exempt"), 0))
                    .TaxNumber = Cast.ToStringTrim(dr.Item("agent_tax_number"))
                    .TaxPercentage = Cast.ToDecimal(dr.Item("agent_tax_percentage"), 0)
                    .TransferToBusinessTypeCode = Cast.ToStringTrim(dr.Item("transfer_to_business_type_id"))
                    .IsInTransferMode = CBool(Cast.ToInt32(dr.Item("is_in_transfer_mode"), 0))

                End With
            End If

            If AdditionalDetails.Agent IsNot Nothing _
                AndAlso AdditionalDetails.Agent.IsInTransferMode = False _
                AndAlso AdditionalDetails.Agent.TransferToBusinessTypeCode <> InternalSAMConstants.kBusinessTypeDIRECT Then

                AdditionalDetails.TransferAgent = New BaseAgentAdditionalDetailsType
                With AdditionalDetails.TransferAgent

                    'transfer_party.domiciled_for_tax transfer_agent_domiciled_for_tax,  
                    'transfer_party.tax_number transfer_agent_tax_number,  
                    'transfer_party.tax_percentage transfer_agent_tax_percentage,  
                    'transfer_party.tax_exempt transfer_agent_tax_exempt,  
                    'transfer_party_account.currency_id as transfer_agent_currency,  
                    'transfer_party.resolved_name transfer_agent_name,  
                    'transfer_agent.date_cancelled transfer_agent_date_cancelled,  
                    'pa.transfer_to_party_cnt,  

                    .AccountCurrencyKey = Cast.ToInt32(dr.Item("transfer_agent_currency"), 0)
                    If InStr(dr.Item("transfer_agent_date_cancelled").ToString, "1899") > 0 Then
                        .Cancelled = False
                    Else
                        .Cancelled = CBool(Cast.ToDateTime(dr.Item("transfer_agent_date_cancelled"), Date.MinValue) < Date.Now)
                    End If
                    .IsDomiciledForTax = CBool(Cast.ToInt16(dr.Item("transfer_agent_domiciled_for_tax"), 0))
                    .Name = Cast.ToStringTrim(dr.Item("transfer_agent_name"))
                    .PartyKey = Cast.ToInt32(dr.Item("transfer_to_party_cnt"), 0)
                    .IsTaxExempt = CBool(Cast.ToInt32(dr.Item("transfer_agent_tax_exempt"), 0))
                    .TaxNumber = Cast.ToStringTrim(dr.Item("transfer_agent_tax_number"))
                    .TaxPercentage = Cast.ToDecimal(dr.Item("transfer_agent_tax_percentage"), 0)

                End With

            End If

            With AdditionalDetails.Client

                'client.domiciled_for_tax client_domiciled_for_tax,  
                'client.tax_number client_tax_number,  
                'client.tax_percentage client_tax_percentage,  
                'client.tax_exempt client_tax_exempt,  
                'ifi.insured_cnt,  
                'ifi.insured_name,  
                'client_account.currency_id as client_currency,  

                .AccountCurrencyKey = Cast.ToInt32(dr.Item("client_currency"), 0)
                .IsDomiciledForTax = CBool(Cast.ToInt16(dr.Item("client_domiciled_for_tax"), 0))
                .Name = Cast.ToStringTrim(dr.Item("insured_name"), String.Empty)
                .PartyKey = Cast.ToInt32(dr.Item("insured_cnt"), 0)
                .IsTaxExempt = CBool(Cast.ToInt32(dr.Item("client_tax_exempt"), 0))
                .TaxNumber = Cast.ToStringTrim(dr.Item("client_tax_number"), String.Empty)
                .TaxPercentage = Cast.ToDecimal(dr.Item("client_tax_percentage"), 0)
            End With

            With AdditionalDetails.ClaimPeril
                .ClassOfBusinessCode = Cast.ToStringTrim(dr.Item("class_of_business_code"))
                .ClassOfBusinessId = Cast.ToInt32(dr.Item("class_of_business_id"), 0)
                .Description = Cast.ToStringTrim(dr.Item("claim_peril_description"))

            End With

            With AdditionalDetails.InsuranceFile
                .InsuranceFileKey = Cast.ToInt32(dr.Item("insurance_file_cnt"), 0)
            End With

            With AdditionalDetails.Product
                .MediaTypeMandatory = CBool(Cast.ToInt32(dr.Item("media_type_mandatory"), 0))
                .PreventsCancelledAgentsMakingClaimPayments = CBool(Cast.ToInt32(dr.Item("prevent_cancelled_agents"), 0))
                .ProductKey = Cast.ToInt32(dr.Item("product_id"), 0)
            End With

            With AdditionalDetails.Risk
                .RiskKey = Cast.ToInt32(dr.Item("risk_type_id"), 0)
                .PostTaxEntriesSeparately = CBool(Cast.ToInt32(dr.Item("claims_is_post_taxes"), 0))
                .RiskTypeDescription = Cast.ToStringTrim(dr.Item("risk_type_description"), String.Empty)
            End With

            With AdditionalDetails.Source
                .CurrencyKey = Cast.ToInt32(dr.Item("base_currency_id"), 0)
                .SourceKey = Cast.ToInt32(dr.Item("source_id"), 0)
            End With

        End If

    End Sub
  
    Public Overloads Sub GetCurrencyToCurrencyExchangeRate(
                               ByVal con As SiriusConnection,
                               ByVal TransactionDate As Date,
                               ByVal CurrencyFromCode As String,
                               ByVal CurrencyToCode As String,
                               ByVal SourceId As Integer,
                               ByRef CurrencyFromToCurrencyToExchangeRate As Decimal)

        Dim oCoreBusiness As New CoreBusiness
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim lFromCurrencyId As Integer = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, "currency", CurrencyFromCode, "currency_id", oSAMErrorCollection)
        Dim lToCurrencyId As Integer = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, "currency", CurrencyToCode, "currency_id", oSAMErrorCollection)
        GetCurrencyToCurrencyExchangeRate(con, TransactionDate, lFromCurrencyId, lToCurrencyId, SourceId, CurrencyFromToCurrencyToExchangeRate)

    End Sub

    Private Overloads Sub GetCurrencyToCurrencyExchangeRate(
    ByVal con As SiriusConnection,
    ByVal TransactionDate As Date,
    ByVal CurrencyFromId As Integer,
    ByVal CurrencyToId As Integer,
    ByVal SourceId As Integer,
    ByRef CurrencyFromToCurrencyToExchangeRate As Decimal)

        Dim dCurrencyFromToBaseXRate As Decimal
        Dim dCurrencyToToBaseXRate As Decimal

        If CurrencyFromId <> CurrencyToId Then

            ' get the payment currency to base currency exchange rate
            GetCurrencyToBaseXRate(con, CurrencyFromId, SourceId, TransactionDate, dCurrencyFromToBaseXRate)

            If dCurrencyFromToBaseXRate = 0 Then
                RaiseBusinessError(SAMBusinessErrors.FailedToGetCurrencyToBaseExchangeRate,
                    "Failed to get CurrencyToBase exchange rate for currency_id : " + CurrencyFromId.ToString +
                    " source_id :=" + SourceId.ToString + " effective_date:=" + TransactionDate.ToString)
            End If

            ' get the loss currency to base currency exchange rate
            GetCurrencyToBaseXRate(con, CurrencyToId, SourceId, TransactionDate, dCurrencyToToBaseXRate)

            If dCurrencyToToBaseXRate = 0 Then
                RaiseBusinessError(SAMBusinessErrors.FailedToGetCurrencyToBaseExchangeRate,
                    "Failed To GetCurrencyToBase exchange rate for currency_id : " + CurrencyToId.ToString +
                    " source_id :=" + SourceId.ToString + " effective_date:=" + TransactionDate.ToString)
            End If

            ' get the payment to loss currency exchange rate and store it on the payment
            CurrencyFromToCurrencyToExchangeRate = dCurrencyFromToBaseXRate / dCurrencyToToBaseXRate

        Else

            CurrencyFromToCurrencyToExchangeRate = 1

        End If

    End Sub

    Private Sub RaiseBusinessError(ByVal SAMBusinessError As SAMBusinessErrors, ByVal Details As String)
        Dim oSAMErrorCollection As New SAMErrorCollection
        oSAMErrorCollection.AddBusinessRule(SAMBusinessError, SAMBusinessError.ToString, Details)
        oSAMErrorCollection.CheckForErrors()
    End Sub

    Private Sub GetCurrencyToBaseXRate(ByVal con As SiriusConnection,
    ByVal CurrencyId As Integer,
    ByVal SourceId As Integer,
    ByVal EffectiveDate As Date,
    ByRef Rate As Decimal)

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_ACT_Get_Currency_Rate")
            cmd.AddInParameter("@currency_id", SqlDbType.SmallInt).Value = CurrencyId
            cmd.AddInParameter("@company_id", SqlDbType.Int).Value = SourceId
            cmd.AddInParameter("@effective_date", SqlDbType.DateTime).Value = EffectiveDate
            cmd.AddOutParameter("@rate", SqlDbType.Decimal, 12, 8)
            con.ExecuteNonQuery(cmd)
            Rate = Cast.ToDecimal(cmd.Parameters.Item("@rate").Value, 0)
        End Using

    End Sub

    Private Sub LoadAdvancedPaymentScript(ByVal PaymentAmount As Decimal,
                                                ByVal m_vTaxBandRate As DataSet,
                                                ByVal oClaimPayment As BaseClaimPaymentType,
                                                ByVal oPaymentItem As BaseClaimPaymentItemType,
                                                ByRef v_vDataArray As Object(),
                                                Optional ByVal oClaimPaymenttaxDetails As BaseCalculateTaxForClaimsRequestType = Nothing,
                                                Optional ByVal dExcessAmount As Decimal = 0)
        Dim vTaxParameters(,) As Object
        Dim vUpdatedTaxParameters() As Object
        ReDim v_vDataArray(20)
        ReDim vUpdatedTaxParameters(10)
        v_vDataArray(0) = "CLP"
        If oClaimPaymenttaxDetails IsNot Nothing Then
            With oClaimPaymenttaxDetails
                'ReDim v_vDataArray(20)
                v_vDataArray(1) = .AdvancedTaxDetails.PayeeName
                v_vDataArray(2) = .AdvancedTaxDetails.PaymentTo
                v_vDataArray(3) = .AdvancedTaxDetails.SafeHarbourCode
                v_vDataArray(4) = .AdvancedTaxDetails.SafeHarbourPercentage

                v_vDataArray(5) = .AdvancedTaxDetails.InsuredDomiciled
                v_vDataArray(6) = .AdvancedTaxDetails.InsuredPercentage
                v_vDataArray(7) = .AdvancedTaxDetails.InsuranceTaxNumber

                v_vDataArray(8) = .AdvancedTaxDetails.PayeeDomiciled
                v_vDataArray(9) = .AdvancedTaxDetails.PayeePercentage
                v_vDataArray(10) = .AdvancedTaxDetails.PayeeTaxNumber

                v_vDataArray(11) = .AdvancedTaxDetails.IsTaxExempt
                v_vDataArray(12) = .AdvancedTaxDetails.IsWHTExempt
                v_vDataArray(13) = .AdvancedTaxDetails.IsSettlement

                v_vDataArray(14) = .CurrencyCode
                v_vDataArray(15) = .Amount

                If oPaymentItem Is Nothing Then
                    v_vDataArray(16) = 0
                    v_vDataArray(17) = 0
                Else
                    v_vDataArray(16) = dExcessAmount
                    v_vDataArray(17) = 0
                End If

                Dim icount As Integer
                ' array of tax band rates
                ReDim vTaxParameters(12, m_vTaxBandRate.Tables(0).Rows.Count - 1)

                For icount = 0 To m_vTaxBandRate.Tables(0).Rows.Count - 1
                    vTaxParameters(0, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(0)
                    vTaxParameters(1, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(1)
                    vTaxParameters(2, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(2)
                    vTaxParameters(3, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(3)
                    vTaxParameters(4, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(4)
                    vTaxParameters(5, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(5)
                    vTaxParameters(6, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(6)
                    vTaxParameters(7, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(7)
                    vTaxParameters(8, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(8)
                    vTaxParameters(9, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(9)
                    vTaxParameters(10, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(10)
                    vTaxParameters(11, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(11)
                Next
                ' insert tax details at 18th position in the DataArray
                v_vDataArray(18) = vTaxParameters
                v_vDataArray(19) = ""
            End With
        Else
            v_vDataArray(1) = oClaimPayment.UltimatePayee '' change

            If oClaimPayment.AdvancedTaxDetails IsNot Nothing Then
                v_vDataArray(2) = oClaimPayment.AdvancedTaxDetails.PaymentTo '' change
                v_vDataArray(3) = oClaimPayment.AdvancedTaxDetails.SafeHarbourCode
                v_vDataArray(4) = oClaimPayment.AdvancedTaxDetails.SafeHarbourPercentage

                v_vDataArray(5) = oClaimPayment.AdvancedTaxDetails.InsuredDomiciled
                v_vDataArray(6) = oClaimPayment.AdvancedTaxDetails.InsuredPercentage
                v_vDataArray(7) = oClaimPayment.AdvancedTaxDetails.InsuranceTaxNumber

                v_vDataArray(8) = oClaimPayment.AdvancedTaxDetails.PayeeDomiciled
                v_vDataArray(9) = oClaimPayment.AdvancedTaxDetails.PayeePercentage
                v_vDataArray(10) = oClaimPayment.AdvancedTaxDetails.PayeeTaxNumber

                v_vDataArray(11) = oClaimPayment.AdvancedTaxDetails.IsTaxExempt
                v_vDataArray(12) = oClaimPayment.AdvancedTaxDetails.IsWHTExempt
                v_vDataArray(13) = oClaimPayment.AdvancedTaxDetails.IsSettlement
            End If

            v_vDataArray(14) = oClaimPayment.CurrencyCode
            v_vDataArray(15) = PaymentAmount

            v_vDataArray(16) = oPaymentItem.ExcessAmount
            v_vDataArray(17) = oPaymentItem.PaymentAdjustment

            Dim icount As Integer
            ' array of tax band rates
            ReDim vTaxParameters(12, m_vTaxBandRate.Tables(0).Rows.Count - 1)

            For icount = 0 To m_vTaxBandRate.Tables(0).Rows.Count - 1
                vTaxParameters(0, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(0)
                vTaxParameters(1, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(1)
                vTaxParameters(2, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(2)
                vTaxParameters(3, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(3)
                vTaxParameters(4, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(4)
                vTaxParameters(5, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(5)
                vTaxParameters(6, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(6)
                vTaxParameters(7, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(7)
                vTaxParameters(8, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(8)
                vTaxParameters(9, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(9)
                vTaxParameters(10, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(10)
                vTaxParameters(11, icount) = m_vTaxBandRate.Tables(0).Rows(icount).Item(11)
            Next

            ' insert tax details at 18th position in the DataArray
            v_vDataArray(18) = vTaxParameters
            v_vDataArray(19) = ""
        End If
    End Sub

    Private Function CalculateScriptedTax(ByVal Con As SiriusConnection,
                                                ByVal oClaimPayment As BaseClaimPaymentType,
                                                ByVal payClaimItem As BaseClaimPaymentItemType,
                                                ByVal oSAMErrorCollection As SAMErrorCollection,
                                                ByVal m_vTaxBandRate As DataSet,
                                                Optional ByRef dLossCurrencyAmount As Double = 0,
                                                Optional ByRef dBaseCurrencyAmount As Double = 0,
                                                Optional ByVal ReserveId As Integer = 0,
                                                Optional ByRef oUpDatedTaxBandRate As DataSet = Nothing) As Decimal
        'Scripted Tax
        Dim vUpdatedTaxParameters() As Object
        Dim vUpdatedTaxArray As Object(,)
        ReDim vUpdatedTaxParameters(18)
        Dim crScriptedTaxAmount As Decimal = 0
        Dim advancedTaxScript As String = String.Empty
        Dim v_vDataArray() As Object = Nothing

        If oClaimPayment.AdvanceScript = "1" Then
            'Checking if there is any script present for corresponding Tax Group 
            If payClaimItem.IsExcess = True Then
                payClaimItem.ExcessAmount = payClaimItem.PaymentAmount
            End If

            GetAdvancedTaxScript(con:=Con, taxGroupId:=Cast.ToInt32(payClaimItem.TaxGroupId, 0), advancedTaxScript:=advancedTaxScript)

            'Calculate Scripted amount and set it with structure
            LoadAdvancedPaymentScript(PaymentAmount:=payClaimItem.PaymentAmount,
                                        m_vTaxBandRate:=m_vTaxBandRate,
                                        oClaimPayment:=oClaimPayment,
                                        oPaymentItem:=payClaimItem,
                                        v_vDataArray:=v_vDataArray)

            Dim kTaxArray As Integer = 18

            Dim oCLMPeril As bCLMPeril.Business
            oCLMPeril = New bCLMPeril.Business

            If Con Is Nothing Then
                'Following line is being added by rk as part of SAM Interop conversions and as per internal and SSP discussion in place of LOC next to it (now commented somewhere below saying oDatabase = con.PMDAODatabase)
                Con = New SiriusConnectionPMDAO(
                                                _SiriusUser.Username, _SiriusUser.SourceID,
                                                _SiriusUser.LanguageID,
                                                SiriusUserDefaults.AppName)
            End If

            Const ACMethodName As String = "ClaimPayment"
            Dim iRet As Integer
            Dim llBound As Integer
            Dim lUbound As Integer
            Dim lTaxItem As Integer
            Dim lIsManuallyChanged As Integer
            Dim crTaxAmount As Decimal
            Dim oDatabase As Object = Nothing

            ' initialise CLMPeril
            iRet = CInt(oCLMPeril.Initialise(sUsername:=_SiriusUser.Username,
                                       sPassword:=_SiriusUser.Password,
                                       iUserID:=_SiriusUser.UserID,
                                       iSourceID:=_SiriusUser.SourceID,
                                       iLanguageID:=_SiriusUser.LanguageID,
                                       iCurrencyID:=_SiriusUser.CurrencyID,
                                       iLogLevel:=SiriusUserDefaults.LogLevel,
                                       sCallingAppName:=ACMethodName,
                                       vDatabase:=oDatabase))

            Dim oUpdatedTaxParameters As Object() = vUpdatedTaxParameters

            'called executeAdvancedScript function
            iRet = oCLMPeril.ExecuteAdvancedTaxScript(
                            v_lTaxScriptMode:=1,
                            v_sTaxScriptName:=advancedTaxScript,
                            v_vTaxParameters:=v_vDataArray,
                            r_vUpdatedTaxParameters:=oUpdatedTaxParameters,
                            nTaxGroupID:=Convert.ToInt32(payClaimItem.TaxGroupId))

            vUpdatedTaxParameters = DirectCast(oUpdatedTaxParameters, Object())

            ValidateTaxArray(v_sTaxScriptName:=advancedTaxScript,
                                                v_vOrigTaxParameters:=v_vDataArray,
                                                v_vUpdatedTaxParameters:=vUpdatedTaxParameters,
                                                SourceId:=CInt(oClaimPayment.SourceId),
                                                kTaxArray:=kTaxArray,
                                                con:=Con,
                                                oSAMErrorCollection:=oSAMErrorCollection,
                                                CurrencyCode:=oClaimPayment.CurrencyCode,
                                                CurrencyID:=oClaimPayment.CurrencyId,
                                                LossCurrencyId:=oClaimPayment.LossCurrencyId)

            vUpdatedTaxArray = DirectCast(vUpdatedTaxParameters(kTaxArray), Object(,))

            llBound = LBound(vUpdatedTaxArray, 2)
            lUbound = UBound(vUpdatedTaxArray, 2)

            For lTaxItem = llBound To lUbound
                crTaxAmount = CDec(vUpdatedTaxArray(kTaxArrayValue, lTaxItem))
                lIsManuallyChanged = Cast.ToInt32(vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem)).GetValueOrDefault(0)
                If lIsManuallyChanged = 2 Then 'check if it is manually checked.
                    crScriptedTaxAmount = crScriptedTaxAmount + crTaxAmount
                End If
            Next

            Dim uBoundTaxBands As Integer = 0
            If vUpdatedTaxArray Is Nothing Then
                uBoundTaxBands = 0
            Else
                uBoundTaxBands = vUpdatedTaxArray.GetUpperBound(0) + 1
            End If

            m_vTaxBandRate = Nothing
            m_vTaxBandRate = New DataSet

            If vUpdatedTaxArray.Length > 0 Then
                oUpDatedTaxBandRate = Utilities.ArrayToDataSet(vUpdatedTaxArray)
            End If

            Dim dsResultTaxBandRate As New DataSet
            If oUpDatedTaxBandRate IsNot Nothing Then
                If oUpDatedTaxBandRate.Tables.Count >= 1 Then
                    If (oUpDatedTaxBandRate.Tables(0).Rows.Count >= 1) Then
                        dsResultTaxBandRate.Tables.Add()
                        dsResultTaxBandRate.Tables(0).Columns.Add("tax_group_id", GetType(System.Int32))
                        dsResultTaxBandRate.Tables(0).Columns.Add("tax_band_id", GetType(System.Int32))
                        dsResultTaxBandRate.Tables(0).Columns.Add("code", GetType(System.String))
                        dsResultTaxBandRate.Tables(0).Columns.Add("percentage", GetType(System.Decimal))
                        dsResultTaxBandRate.Tables(0).Columns.Add("value", GetType(System.Decimal))
                        dsResultTaxBandRate.Tables(0).Columns.Add("is_value", GetType(System.Int32))
                        dsResultTaxBandRate.Tables(0).Columns.Add("class_of_business", GetType(System.String))
                        dsResultTaxBandRate.Tables(0).Columns.Add("sequence", GetType(System.Int32))
                        dsResultTaxBandRate.Tables(0).Columns.Add("is_manually_changed", GetType(System.Int32))
                        dsResultTaxBandRate.Tables(0).Columns.Add("description", GetType(System.String))
                        dsResultTaxBandRate.Tables(0).Columns.Add("description1", GetType(System.String))
                        dsResultTaxBandRate.Tables(0).Columns.Add("band_code", GetType(System.String))
                        dsResultTaxBandRate.Tables(0).Columns.Add("tax_group_code", GetType(System.String))
                        Dim iCount As Integer
                        Dim sTaxGroupCode As String
                        Dim sBandCode As String
                        For iCount = 0 To oUpDatedTaxBandRate.Tables(0).Rows.Count - 1
                            'Data are extracted from the DataSet and put it into corresponding objects
                            With oUpDatedTaxBandRate.Tables(0).Rows(iCount)
                                'Note:Ideally we should fetch the data using column names 
                                'but as we havenot got the column names we are using the column index.
                                dsResultTaxBandRate.Tables(0).Rows.Add()
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("tax_group_id") = Convert.ToInt32(oUpDatedTaxBandRate.Tables(0).Rows(iCount)(0))
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("tax_band_id") = Convert.ToInt32(oUpDatedTaxBandRate.Tables(0).Rows(iCount)(1))
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("code") = oUpDatedTaxBandRate.Tables(0).Rows(iCount)(2).ToString()
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("percentage") = Convert.ToDecimal(oUpDatedTaxBandRate.Tables(0).Rows(iCount)(3).ToString())
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("value") = Convert.ToDecimal(oUpDatedTaxBandRate.Tables(0).Rows(iCount)(4).ToString())
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("is_value") = Convert.ToInt32(oUpDatedTaxBandRate.Tables(0).Rows(iCount)(5).ToString())
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("class_of_business") = oUpDatedTaxBandRate.Tables(0).Rows(iCount)(6).ToString()
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("sequence") = Convert.ToInt32(oUpDatedTaxBandRate.Tables(0).Rows(iCount)(7).ToString())
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("is_manually_changed") = Convert.ToInt32(oUpDatedTaxBandRate.Tables(0).Rows(iCount)(8))
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("description") = oUpDatedTaxBandRate.Tables(0).Rows(iCount)(9).ToString
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("description1") = oUpDatedTaxBandRate.Tables(0).Rows(iCount)(10).ToString
                                sTaxGroupCode = GetAndValidateDescriptionById(Con, "tax_group", "code", "tax_group_id", oUpDatedTaxBandRate.Tables(0).Rows(iCount)(0).ToString)
                                sBandCode = GetAndValidateDescriptionById(Con, "tax_band", "code", "tax_band_id", oUpDatedTaxBandRate.Tables(0).Rows(iCount)(1).ToString)
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("band_code") = sBandCode
                                dsResultTaxBandRate.Tables(0).Rows(iCount)("tax_group_code") = sTaxGroupCode

                            End With
                        Next
                    End If
                End If
                oUpDatedTaxBandRate = dsResultTaxBandRate

            End If

            payClaimItem.AdvancedTaxDetails = vUpdatedTaxArray
            oCLMPeril.Dispose()
            oCLMPeril = Nothing

            Return crScriptedTaxAmount

        End If
    End Function

    Private Function CalculateScriptedTaxNew(ByVal Con As SiriusConnection,
                                               ByVal oClaimPaymenttaxDetails As BaseCalculateTaxForClaimsRequestType,
                                               ByVal oSAMErrorCollection As SAMErrorCollection,
                                               ByVal m_vTaxBandRate As DataSet,
                                                 ByRef oCalculateTaxForClaimsResponseType As BaseCalculateTaxForClaimsResponseType) As Decimal
        'Scripted Tax
        Dim vUpdatedTaxParameters() As Object
        Dim vUpdatedTaxArray As Object(,)
        ReDim vUpdatedTaxParameters(18)
        Dim crScriptedTaxAmount As Decimal = 0
        Dim advancedTaxScript As String = String.Empty
        Dim v_vDataArray() As Object = Nothing
        Dim dExcessAmount As Decimal = 0

        'Checking if there is any script present for corresponding Tax Group 
        If oClaimPaymenttaxDetails.AdvancedTaxDetails.IsExcess Then
            dExcessAmount = Convert.ToDecimal(oClaimPaymenttaxDetails.Amount)
        End If

        GetAdvancedTaxScript(con:=Con, taxGroupId:=Cast.ToInt32(oClaimPaymenttaxDetails.TaxGroupKey, 0), advancedTaxScript:=advancedTaxScript)

        'Calculate Scripted amount and set it with structure
        LoadAdvancedPaymentScript(PaymentAmount:=Convert.ToDecimal(oClaimPaymenttaxDetails.Amount),
                                    m_vTaxBandRate:=m_vTaxBandRate,
                                    oClaimPayment:=Nothing,
                                    oPaymentItem:=Nothing,
                                    v_vDataArray:=v_vDataArray,
                                     oClaimPaymenttaxDetails:=oClaimPaymenttaxDetails)

        Dim kTaxArray As Integer = 18

        Dim oCLMPeril As bCLMPeril.Business
        oCLMPeril = New bCLMPeril.Business

        If Con Is Nothing Then
            'Following line is being added by rk as part of SAM Interop conversions and as per internal and SSP discussion in place of LOC next to it (now commented somewhere below saying oDatabase = con.PMDAODatabase)
            Con = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)
        End If

        Const ACMethodName As String = "ClaimPayment"
        Dim iRet As Integer
        Dim llBound As Integer
        Dim lUbound As Integer
        Dim lTaxItem As Integer
        Dim lIsManuallyChanged As Integer
        Dim crTaxAmount As Decimal
        Dim oDatabase As Object = Nothing

        ' initialise CLMPeril
        iRet = CInt(oCLMPeril.Initialise(sUsername:=_SiriusUser.Username,
                                   sPassword:=_SiriusUser.Password,
                                   iUserID:=_SiriusUser.UserID,
                                   iSourceID:=_SiriusUser.SourceID,
                                   iLanguageID:=_SiriusUser.LanguageID,
                                   iCurrencyID:=_SiriusUser.CurrencyID,
                                   iLogLevel:=SiriusUserDefaults.LogLevel,
                                   sCallingAppName:=ACMethodName,
                                   vDatabase:=oDatabase))

        Dim oUpdatedTaxParameters As Object() = vUpdatedTaxParameters

        'called executeAdvancedScript function
        iRet = oCLMPeril.ExecuteAdvancedTaxScript(v_lTaxScriptMode:=1,
                        v_sTaxScriptName:=advancedTaxScript,
                        v_vTaxParameters:=v_vDataArray,
                        r_vUpdatedTaxParameters:=oUpdatedTaxParameters,
                        nTaxGroupID:=Cast.ToInt32(oClaimPaymenttaxDetails.TaxGroupKey, 0))

        vUpdatedTaxParameters = DirectCast(oUpdatedTaxParameters, Object())

        ValidateTaxArray(v_sTaxScriptName:=advancedTaxScript,
                                            v_vOrigTaxParameters:=v_vDataArray,
                                            v_vUpdatedTaxParameters:=vUpdatedTaxParameters,
                                            SourceId:=CInt(oClaimPaymenttaxDetails.SourceId),
                                            kTaxArray:=kTaxArray,
                                            con:=Con,
                                            oSAMErrorCollection:=oSAMErrorCollection,
                                            CurrencyCode:=oClaimPaymenttaxDetails.CurrencyCode,
                                            CurrencyID:=oClaimPaymenttaxDetails.CurrencyKey,
                                            LossCurrencyId:=oClaimPaymenttaxDetails.LossCurrencyKey)

        vUpdatedTaxArray = DirectCast(vUpdatedTaxParameters(kTaxArray), Object(,))

        llBound = LBound(vUpdatedTaxArray, 2)
        lUbound = UBound(vUpdatedTaxArray, 2)
        Dim sreserveType As String

        sreserveType = GetAndValidateDescriptionById(Con, "reserve_type", "description", "name", oClaimPaymenttaxDetails.ReserveType.ToString)

        Dim oClaimPaymentTaxItem As BaseClaimPaymentTaxItemType
        For lTaxItem = llBound To lUbound
            ' oClaimPaymentTaxItem = New BaseClaimPaymentTaxItemType 
            ReDim Preserve oCalculateTaxForClaimsResponseType.TaxItems(lTaxItem)
            oCalculateTaxForClaimsResponseType.TaxItems(lTaxItem) = New BaseClaimPaymentTaxItemType
            With oCalculateTaxForClaimsResponseType.TaxItems(lTaxItem)
                .Amount = CDec(vUpdatedTaxArray(kTaxArrayValue, lTaxItem))
                If Not String.IsNullOrEmpty(Convert.ToString(vUpdatedTaxArray(kTaxArrayClassOfBusinessId, lTaxItem))) Then
                    .ClassOfBusinessID = Convert.ToInt32(vUpdatedTaxArray(kTaxArrayClassOfBusinessId, lTaxItem))
                End If
                .ReserveType = sreserveType
                .IsManuallyChanges = Convert.ToInt32(vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem))
                .Percentage = Convert.ToDecimal(vUpdatedTaxArray(kTaxArrayPercentage, lTaxItem))
                .Sequence = Convert.ToInt32(vUpdatedTaxArray(kTaxArraySequence, lTaxItem))
                .TaxBandCode = Convert.ToString(vUpdatedTaxArray(kTaxArrayTaxBandDescription, lTaxItem))
                .TaxBandId = Convert.ToInt32(vUpdatedTaxArray(kTaxArrayTaxBandId, lTaxItem))
                .TaxGroupCode = Convert.ToString(vUpdatedTaxArray(kTaxArrayTaxGroupDescription, lTaxItem))
                .TaxGroupId = Convert.ToInt32(vUpdatedTaxArray(kTaxArrayTaxGroupId, lTaxItem))
            End With

            crTaxAmount = CDec(vUpdatedTaxArray(kTaxArrayValue, lTaxItem))

            lIsManuallyChanged = Cast.ToInt32(vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem)).GetValueOrDefault(0)
            If lIsManuallyChanged = 2 Then 'check if it is manually checked.
                crScriptedTaxAmount = crScriptedTaxAmount + crTaxAmount

            End If
        Next

        Return crScriptedTaxAmount

    End Function

    Public Function SaveAdvancedTaxCalculations(ByVal Con As SiriusConnection,
                                                      ByVal PayClaimRequest As BaseClaimPaymentType,
                                                      ByVal payClaimItem As BaseClaimPaymentItemType) As Integer
        Dim ilBound As Integer
        Dim iUbound As Integer
        Dim iTaxIndex As Integer
        Dim TaxArray As Object(,)
        If payClaimItem.AdvancedTaxDetails Is Nothing Then
            Exit Function
        Else
            TaxArray = payClaimItem.AdvancedTaxDetails
        End If

        ilBound = LBound(TaxArray, 2)
        iUbound = UBound(TaxArray, 2)

        For iTaxIndex = ilBound To iUbound

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Tax_Calculation_Add")

                cmd.AddOutParameter("@tax_calculation_cnt", SqlDbType.Int)
                cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = PayClaimRequest.ClaimPerilId
                cmd.AddInParameter("@claim_payment_id", SqlDbType.Int).Value = PayClaimRequest.PaymentId
                cmd.AddInParameter("@claim_receipt_id", SqlDbType.Int).Value = Nothing
                cmd.AddInParameter("@claim_payment_item_id", SqlDbType.Int).Value = payClaimItem.ClaimPaymentItemId
                cmd.AddInParameter("@claim_receipt_item_id", SqlDbType.Int).Value = Nothing
                cmd.AddInParameter("@tax_band_id", SqlDbType.Int).Value = Cast.ToInt32(TaxArray(kTaxArrayTaxBandId, iTaxIndex))
                cmd.AddInParameter("@premium", SqlDbType.Money).Value = payClaimItem.CurrencyAmount
                cmd.AddInParameter("@percentage", SqlDbType.Float).Value = Double.Parse(TaxArray(kTaxArrayPercentage, iTaxIndex).ToString())
                cmd.AddInParameter("@value", SqlDbType.Money).Value = Cast.ToDouble(TaxArray(kTaxArrayValue, iTaxIndex))

                cmd.AddInParameter("@is_value", SqlDbType.TinyInt).Value = 1
                cmd.AddInParameter("@currency_id", SqlDbType.SmallInt).Value = PayClaimRequest.CurrencyId
                cmd.AddInParameter("@class_of_business_id", SqlDbType.Int).Value = Nothing
                cmd.AddInParameter("@tax_group_id", SqlDbType.Int).Value = Cast.ToInt32(TaxArray(kTaxArrayTaxGroupId, iTaxIndex))
                cmd.AddInParameter("@sequence", SqlDbType.TinyInt).Value = Cast.ToInt32(TaxArray(kTaxArraySequence, iTaxIndex))
                cmd.AddInParameter("@transtype", SqlDbType.VarChar, 10).Value = "TTCP"
                cmd.AddInParameter("@is_manually_changed", SqlDbType.Int).Value = 2

                Con.ExecuteNonQuery(cmd)

            End Using

        Next
    End Function

    ''' <summary>
    ''' Used to collect all the information related to the reserves mentioned in the request
    ''' Used to build the Response for Get Payment Taxes Request Type
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="oClaimPayment"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <param name="bProcessBimdClaim"></param>
    ''' <param name="nGetSavedTaxOfPeril"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function getPerilReservePaymentdetails(ByVal Con As SiriusConnection,
                                                    ByVal oClaimPayment As BaseClaimPaymentType,
                                                    ByRef oSAMErrorCollection As SAMErrorCollection,
                                                    Optional ByVal bProcessBimdClaim As Boolean = Nothing,
                                                    Optional ByVal nGetSavedTaxOfPeril As Integer = 0) _
                                                    As BaseGetClaimPaymentTaxesResponseType

        Dim dsReservePaymentDet As DataSet = Nothing
        Dim oPerilReserveDet() As BaseClaimPerilReservePaymentType = Nothing
        Dim oTaxItemDet() As BaseClaimPaymentTaxItemType = Nothing
        Dim oPaymentItemDet() As BaseGetClaimPaymentTaxesResponseTypePaymentItems = Nothing
        Dim iClaimPaymentIsGross As Integer = 0
        Dim iPostTaxSeperately As Integer = 0
        Dim dsProductRiskOptions As DataSet = Nothing
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Claim_ProductRisk_Options")
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oClaimPayment.ClaimId
            dsProductRiskOptions = Con.ExecuteDataSet(cmd, "ProductRisk")
        End Using

        If dsProductRiskOptions IsNot Nothing AndAlso dsProductRiskOptions.Tables IsNot Nothing AndAlso dsProductRiskOptions.Tables.Count > 0 AndAlso dsProductRiskOptions.Tables(0).Rows IsNot Nothing AndAlso dsProductRiskOptions.Tables(0).Rows.Count > 0 Then
            iClaimPaymentIsGross = Convert.ToInt32(dsProductRiskOptions.Tables(0).Rows(0).Item("is_Gross_Claim_Payment_Amount"))
            iPostTaxSeperately = Convert.ToInt32(dsProductRiskOptions.Tables(0).Rows(0).Item("claims_is_post_taxes"))
        End If
        ' Get the details related to all the reserves on the claim
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Current_Claim_Payments_By_Reserve")
            cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oClaimPayment.ClaimPerilId
            dsReservePaymentDet = Con.ExecuteDataSet(cmd, "Rowtest")
        End Using

        Dim ClaimPaymentItem As BaseClaimPaymentItemType
        Dim lItemCount As Integer = 0
        Dim cnt As Integer = 0

        ' for each claim payment item
        If oClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For Each ClaimPaymentItem In oClaimPayment.ClaimPaymentItem

                ' for each reserve item
                For cnt = 0 To dsReservePaymentDet.Tables(0).Rows.Count - 1

                    ' if the payment is for the current reserve
                    If Cast.ToInt32(dsReservePaymentDet.Tables(0).Rows(cnt).Item("reserve_id"), 0) =
                        Cast.ToInt32(ClaimPaymentItem.ReserveId, 0) Then

                        Dim m_vTaxBandRate As DataSet = Nothing
                        Dim lTmpClaimReceiptId As Integer

                        ' if the claim payment is gross
                        If oClaimPayment.ClaimPaymentIsGross = "1" Then
                            lTmpClaimReceiptId = 1
                        Else
                            lTmpClaimReceiptId = 0
                        End If

                        ' determine if this claim payment item is against an excess row
                        ClaimPaymentItem.IsExcess = CBool(dsReservePaymentDet.Tables(0).Rows(cnt).Item("is_excess"))

                        ' Variables for storing the Tax Amounts retrieved from Recalculate Sub routine
                        Dim crTaxLossAmount As Decimal = 0
                        Dim crCurrencyAmount As Decimal = 0
                        Dim crTaxBaseAmount As Decimal = 0

                        If Not ClaimPaymentItem.TaxGroupCode = Nothing Then

                            If bProcessBimdClaim Then
                                ' Get the details related to all the reserves on the claim
                                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Tax_Calculation_sel")
                                    cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oClaimPayment.ClaimPerilId
                                    cmd.AddInParameter("@claim_payment_id", SqlDbType.Int).Value = ClaimPaymentItem.ClaimPaymentItemId
                                    cmd.AddInParameter("@claim_payment_item_id", SqlDbType.Int).Value = oClaimPayment.PaymentId
                                    cmd.AddInParameter("@version_id", SqlDbType.Int).Value = oClaimPayment.VersionId
                                    cmd.AddInParameter("@reserve_id", SqlDbType.Int).Value = Cast.ToInt32(ClaimPaymentItem.ReserveId, 0)
                                    m_vTaxBandRate = Con.ExecuteDataSet(cmd, "Rowtest")
                                End Using
                            Else

                                ' call recalculate routine to get the tax details for all the bands
                                CalculateTaxAmounts(con:=Con,
                                                        lCompanyId:=oClaimPayment.SourceId,
                                                        lTaxGroupId:=Cast.ToInt32(ClaimPaymentItem.TaxGroupId, 0),
                                                        sTranstype:=kTaxTransTypeClaimPayment,
                                                        lCurrencyId:=oClaimPayment.CurrencyId,
                                                        lLossCurrencyId:=oClaimPayment.LossCurrencyId,
                                                        crAmount:=ClaimPaymentItem.PaymentAmount,
                                                        crTaxCurrencyAmount:=crCurrencyAmount,
                                                        crTaxLossAmount:=crTaxLossAmount,
                                                        crTaxBaseAmount:=crTaxBaseAmount,
                                                        lClaimPerilId:=CInt(oClaimPayment.BaseClaimPerilKey),
                                                        lClaimPaymentId:=1,
                                                        lClaimReceiptId:=lTmpClaimReceiptId,
                                                        lClaimPaymentItemId:=0,
                                                        lClaimReceiptItemId:=1,
                                                        lCalculateOnly:=1,
                                                            oTaxBandDetails:=m_vTaxBandRate,
                                                            nGetSavedTaxOfPeril:=nGetSavedTaxOfPeril)

                                ' calculate the scripted tax Amount only if the scripted option is switched on
                                'And check if the selected tax group have any ATS Rule file or not

                                Dim advancedTaxScript As String = String.Empty
                                GetAdvancedTaxScript(con:=Con, taxGroupId:=Cast.ToInt32(ClaimPaymentItem.TaxGroupId, 0), advancedTaxScript:=advancedTaxScript)
                                If oClaimPayment.AdvanceScript = "1" AndAlso advancedTaxScript IsNot Nothing AndAlso advancedTaxScript <> "" AndAlso nGetSavedTaxOfPeril = 0 Then

                                    Dim crScriptedTaxAmount As Decimal = 0
                                    Dim oUpDatedTaxBandRate As DataSet = Nothing

                                    crScriptedTaxAmount = CalculateScriptedTax(Con:=Con,
                                                                                    oClaimPayment:=oClaimPayment,
                                                                                    payClaimItem:=ClaimPaymentItem,
                                                                                    oSAMErrorCollection:=oSAMErrorCollection,
                                                                                        m_vTaxBandRate:=m_vTaxBandRate,
                                                                                    oUpDatedTaxBandRate:=oUpDatedTaxBandRate)
                                    crCurrencyAmount = crScriptedTaxAmount
                                    If oUpDatedTaxBandRate IsNot Nothing Then
                                        m_vTaxBandRate = oUpDatedTaxBandRate
                                    End If
                                End If
                            End If

                        Else
                            If oClaimPayment.ViewMode Then
                                ' Get the details related to all the reserves on the claim
                                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Tax_Calculation_sel")
                                    cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oClaimPayment.ClaimPerilId
                                    cmd.AddInParameter("@claim_payment_id", SqlDbType.Int).Value = ClaimPaymentItem.ClaimPaymentItemId
                                    cmd.AddInParameter("@claim_payment_item_id", SqlDbType.Int).Value = oClaimPayment.PaymentId
                                    cmd.AddInParameter("@version_id", SqlDbType.Int).Value = oClaimPayment.VersionId
                                    cmd.AddInParameter("@reserve_id", SqlDbType.Int).Value = Cast.ToInt32(ClaimPaymentItem.ReserveId, 0)
                                    m_vTaxBandRate = Con.ExecuteDataSet(cmd, "Rowtest")
                                End Using
                            End If
                        End If

                        If ClaimPaymentItem.IsTaxOverridden AndAlso nGetSavedTaxOfPeril = 0 _
                         AndAlso m_vTaxBandRate IsNot Nothing AndAlso m_vTaxBandRate.Tables(0).Rows.Count > 0 Then
                            For iRow As Integer = 0 To m_vTaxBandRate.Tables(0).Rows.Count - 1
                                m_vTaxBandRate.Tables(0).Rows(iRow).Item("percentage") = 0
                                m_vTaxBandRate.Tables(0).Rows(iRow).Item("value") = 0
                                m_vTaxBandRate.Tables(0).Rows(iRow).Item("is_value") = 1
                            Next
                            'Now Put all the tax on first Band
                            m_vTaxBandRate.Tables(0).Rows(0).Item("value") = ClaimPaymentItem.OverriddedTaxAmount
                            crCurrencyAmount = ClaimPaymentItem.OverriddedTaxAmount
                        End If

                        ' if is whithhold tax then put amount in taxAmountWHT property
                        If ClaimPaymentItem.IsWHTTax = True Then
                            ClaimPaymentItem.TaxAmountWHT = crCurrencyAmount
                        ElseIf ClaimPaymentItem.IsWHTTax = False Then
                            ClaimPaymentItem.TaxAmount = crCurrencyAmount
                        End If

                        ' Adjust the amounts for the following options
                        ' -- IsExcess Reserve Type Option
                        ' -- Reverse Excess Reserve Option
                        ' -- Is Withhold Tax Option
                        ' -- Is Claim Paid to gross
                        ' -- Is Advance Tax Script Option is On
                        AdjustAmounts(oClaimPayment,
                                      ClaimPaymentItem)

                        ReDim Preserve oPerilReserveDet(lItemCount)
                        oPerilReserveDet(lItemCount) = New BaseClaimPerilReservePaymentType

                        ' Store Current Reserve Details to Structure for building Response object
                        oPerilReserveDet(lItemCount).BaseReserveKey = ClaimPaymentItem.BaseReserveKey
                        oPerilReserveDet(lItemCount).CurrentReserve = CDec(dsReservePaymentDet.Tables(0).Rows(cnt).Item("current_reserve"))
                        oPerilReserveDet(lItemCount).PaidToDate = Cast.ToDecimal(dsReservePaymentDet.Tables(0).Rows(cnt).Item("paid_to_date")).GetValueOrDefault(0)
                        oPerilReserveDet(lItemCount).PaidToDateTax = Cast.ToDecimal(dsReservePaymentDet.Tables(0).Rows(cnt).Item("paid_to_date_tax")).GetValueOrDefault(0)

                        oClaimPayment.TotCurrAmount = Cast.ToDecimal(oClaimPayment.TotCurrAmount +
                                                                                    ClaimPaymentItem.CurrencyAmount).GetValueOrDefault(0)
                        oClaimPayment.TotTaxAmount = Cast.ToDecimal(oClaimPayment.TotTaxAmount +
                                                                                    ClaimPaymentItem.TaxAmount).GetValueOrDefault(0)
                        oClaimPayment.TotTaxWHTAmount = Cast.ToDecimal(oClaimPayment.TotTaxWHTAmount +
                                                                                        ClaimPaymentItem.TaxAmountWHT).GetValueOrDefault(0)
                        ' Save excess amount if we have got the excess reserve type
                        If ClaimPaymentItem.IsExcess = True Then
                            oClaimPayment.TotExcessAmount = CDec(Cast.ToDouble(oClaimPayment.TotExcessAmount.GetValueOrDefault(0) +
                                                                                          ClaimPaymentItem.CurrencyAmount).GetValueOrDefault(0))
                        End If
                        oPerilReserveDet(lItemCount).ThisPaymentINCLTax = CDec(Cast.ToDouble((ClaimPaymentItem.CurrencyAmount +
                                                                            (ClaimPaymentItem.TaxAmount + ClaimPaymentItem.TaxAmountWHT)) *
                                                                             oClaimPayment.PaymentToLossXRate).GetValueOrDefault(0))

                        oPerilReserveDet(lItemCount).ThisPaymentTax = CDec(Cast.ToDouble((ClaimPaymentItem.TaxAmount +
                                                                             ClaimPaymentItem.TaxAmountWHT) *
                                                                             oClaimPayment.PaymentToLossXRate).GetValueOrDefault(0))
                        oPerilReserveDet(lItemCount).TotalReserve = Cast.ToDecimal(dsReservePaymentDet.Tables(0).Rows(cnt).Item(3)).GetValueOrDefault(0)
                        oPerilReserveDet(lItemCount).TypeCode = CStr(dsReservePaymentDet.Tables(0).Rows(cnt).Item("reserve_type_code"))
                        oPerilReserveDet(lItemCount).CostToClaim = CDec(Cast.ToDouble(oPerilReserveDet(lItemCount).ThisPaymentINCLTax -
                                                                        oPerilReserveDet(lItemCount).ThisPaymentTax).GetValueOrDefault(0))
                        If iClaimPaymentIsGross = 0 Then
                            If iPostTaxSeperately = 1 Then
                                ClaimPaymentItem.CurrentReserve = (CDec(oPerilReserveDet(lItemCount).TotalReserve)) - oPerilReserveDet(lItemCount).CostToClaim - (Cast.ToDecimal(dsReservePaymentDet.Tables(0).Rows(cnt).Item("paid_to_date")).GetValueOrDefault(0)) 'Format(crTotalReserve - crCostToClaim - crPaidToDate, "0.00")
                            Else
                                ClaimPaymentItem.CurrentReserve = (CDec(oPerilReserveDet(lItemCount).TotalReserve)) - (Cast.ToDecimal(dsReservePaymentDet.Tables(0).Rows(cnt).Item("paid_to_date")).GetValueOrDefault(0)) - (Cast.ToDecimal(dsReservePaymentDet.Tables(0).Rows(cnt).Item("paid_to_date_tax")).GetValueOrDefault(0)) - (Cast.ToDecimal(dsReservePaymentDet.Tables(0).Rows(cnt).Item("paid_to_date_tax_WHT")).GetValueOrDefault(0))
                            End If
                        Else
                            ClaimPaymentItem.CurrentReserve = CDec(oPerilReserveDet(lItemCount).TotalReserve - oPerilReserveDet(lItemCount).PaidToDate)
                        End If

                        ' Building Tax Item Response
                        If (Not ClaimPaymentItem.TaxGroupCode = Nothing AndAlso ClaimPaymentItem.IsExcess = False) Or oClaimPayment.ViewMode Then
                            Dim uBoundTaxBands As Integer = 0
                            If oTaxItemDet Is Nothing Then
                                uBoundTaxBands = 0
                            Else
                                uBoundTaxBands = oTaxItemDet.GetUpperBound(0) + 1
                            End If

                            If oClaimPayment.AdvanceScript = "1" AndAlso oClaimPayment.SkipTaxItemExpansion = False Then
                                ReDim Preserve oTaxItemDet(uBoundTaxBands + m_vTaxBandRate.Tables(0).Rows.Count + 5 - 1)
                            Else
                                ReDim Preserve oTaxItemDet(uBoundTaxBands + m_vTaxBandRate.Tables(0).Rows.Count - 1)
                            End If

                            For TaxBandsCNT As Integer = 0 To m_vTaxBandRate.Tables(0).Rows.Count - 1
                                oTaxItemDet(uBoundTaxBands + TaxBandsCNT) = New BaseClaimPaymentTaxItemType
                                oTaxItemDet(uBoundTaxBands + TaxBandsCNT).TaxGroupCode = Cast.ToString(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("tax_group_code"))
                                oTaxItemDet(uBoundTaxBands + TaxBandsCNT).TaxBandCode = Cast.ToString(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("band_code"))
                                'oTaxItemDet(uBoundTaxBands + TaxBandsCNT).ReserveType = GetAndValidateDescriptionById(Con, "reserve_type", "Description", "reserve_type_code", reserve_type_code.ToString)

                                'If oClaimPayment.ViewMode Then
                                '    oTaxItemDet(uBoundTaxBands + TaxBandsCNT).ReserveType = Cast.ToString(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("reserve_type_code"))
                                'Else
                                    oTaxItemDet(uBoundTaxBands + TaxBandsCNT).ReserveType = Cast.ToString(dsReservePaymentDet.Tables(0).Rows(cnt).Item("reserve_type_code"))
                                'End If
                                oTaxItemDet(uBoundTaxBands + TaxBandsCNT).Percentage = CDec(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("percentage"))
                                oTaxItemDet(uBoundTaxBands + TaxBandsCNT).Amount = CDec(Cast.ToDecimal(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("value"), 0) *
                                                                             oClaimPayment.PaymentToLossXRate)

                                If oClaimPayment.AdvanceScript = "1" AndAlso oClaimPayment.SkipTaxItemExpansion = False AndAlso bProcessBimdClaim = False Then
                                    oTaxItemDet(uBoundTaxBands + TaxBandsCNT).TaxGroupId = Convert.ToInt32(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("tax_group_id"))
                                    oTaxItemDet(uBoundTaxBands + TaxBandsCNT).TaxBandId = Convert.ToInt32(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("tax_band_id"))
                                    oTaxItemDet(uBoundTaxBands + TaxBandsCNT).Sequence = Convert.ToInt32(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("sequence"))
                                    oTaxItemDet(uBoundTaxBands + TaxBandsCNT).IsManuallyChanges = Convert.ToInt32(m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("is_manually_changed"))
                                    oTaxItemDet(uBoundTaxBands + TaxBandsCNT).ClassOfBusinessID = oClaimPayment.ClassOfBusinessID 'Cast.ToInt32((m_vTaxBandRate.Tables(0).Rows(TaxBandsCNT).Item("class_of_business")), 0)
                                End If


                            Next
                        End If

                        ' Building Claim Payment item Type Response Object
                        ReDim Preserve oPaymentItemDet(lItemCount)
                        oPaymentItemDet(lItemCount) = New BaseGetClaimPaymentTaxesResponseTypePaymentItems

                        oPaymentItemDet(lItemCount).BaseReserveKey = Cast.ToInt32(ClaimPaymentItem.BaseReserveKey).GetValueOrDefault(0)
                        oPaymentItemDet(lItemCount).TaxGroupCode = Cast.ToString(ClaimPaymentItem.TaxGroupCode)
                        oPaymentItemDet(lItemCount).PaymentAmount = CDec(Cast.ToDouble(ClaimPaymentItem.CurrencyAmount * oClaimPayment.PaymentToLossXRate).GetValueOrDefault(0)) 'Modified
                        If ClaimPaymentItem.IsWHTTax = True Then
                            oPaymentItemDet(lItemCount).TaxAmount = CDec(Cast.ToDouble(ClaimPaymentItem.TaxAmountWHT * oClaimPayment.PaymentToLossXRate).GetValueOrDefault(0))     'Modified
                        ElseIf ClaimPaymentItem.IsWHTTax = False Then
                            oPaymentItemDet(lItemCount).TaxAmount = CDec(Cast.ToDouble(ClaimPaymentItem.TaxAmount * oClaimPayment.PaymentToLossXRate).GetValueOrDefault(0))     'Modified
                        End If

                        oPaymentItemDet(lItemCount).PaymentAdjustment = 0

                        oPaymentItemDet(lItemCount).RecoveryId = Nothing
                        oPaymentItemDet(lItemCount).RecoveryTypeId = Nothing
                        oPaymentItemDet(lItemCount).PaymentAdjustment = 0
                        ClaimPaymentItem.RevisionAmount = Cast.ToDecimal(dsReservePaymentDet.Tables(0).Rows(cnt).Item("this_revision")).GetValueOrDefault(0)

                        lItemCount += 1
                        Exit For
                    End If
                Next
                cnt = 0
            Next
        End If
        Dim oClaimPerilReservePaymentType As New SAMForInsuranceV2ImplementationTypes.GetClaimPaymentTaxesResponseType

        ReDim oClaimPerilReservePaymentType.Reserves(lItemCount)
        oClaimPerilReservePaymentType.Reserves = oPerilReserveDet

        ' there may be no tax details
        If oTaxItemDet IsNot Nothing Then
            ReDim oClaimPerilReservePaymentType.TaxItems(oTaxItemDet.GetUpperBound(0))
            oClaimPerilReservePaymentType.TaxItems = oTaxItemDet
        End If

        If oClaimPerilReservePaymentType.PaymentItems IsNot Nothing Then
            ReDim Preserve oClaimPerilReservePaymentType.PaymentItems(oPaymentItemDet.GetUpperBound(0))
            oClaimPerilReservePaymentType.PaymentItems = oPaymentItemDet
        End If

        Return oClaimPerilReservePaymentType
    End Function

    ''' <summary>
    ''' Manipulate the Pay Amount and Tax Amount on the basis of system options and options like
    ''' --IsExcess Reserves
    ''' --Reverse Excess
    ''' --Advance tax Script
    ''' --Claim paid is Gross
    ''' --Withhold Tax
    ''' </summary>
    ''' <param name="PayClaimRequest"></param>
    ''' <param name="oPaymentItem"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Sub AdjustAmounts(ByVal oClaimPayment As BaseClaimPaymentType,
                                   ByVal oPaymentItem As BaseClaimPaymentItemType)

        ' Set initialy the Currency Amount to Payment Amount
        oPaymentItem.CurrencyAmount = oPaymentItem.PaymentAmount

        If oPaymentItem.IsExcess = True Then
            ' excess rows should always be negitive if Reverse excess
            ' is switched off
            If oPaymentItem.ReverseExcess = False Then
                If oPaymentItem.PaymentAmount > 0 Then
                    oPaymentItem.CurrencyAmount = -oPaymentItem.PaymentAmount

                End If
                ' excess rows should always be positive if Reverse excess
                ' is switched on
            ElseIf oPaymentItem.ReverseExcess = True Then
                If oPaymentItem.PaymentAmount < 0 Then
                    oPaymentItem.CurrencyAmount = -oPaymentItem.PaymentAmount
                End If
            End If
            ' No tax is applicable for excess rows thus set it to 0
            oPaymentItem.TaxAmount = 0
            oPaymentItem.TaxAmountWHT = 0
            ' Set Loss currency amount for excess rows
            oPaymentItem.LCurrencyAmount = oPaymentItem.CurrencyAmount * oClaimPayment.PaymentToLossXRate

            ' set the Excess amount only if the Advance Tax Script is Switched ON
            If oClaimPayment.AdvanceScript = "1" Then
                oPaymentItem.ExcessAmount = oPaymentItem.ExcessAmount + oPaymentItem.CurrencyAmount
            End If
        Else
            ' Claim
            If oClaimPayment.ClaimPaymentIsGross = "0" Then
                oPaymentItem.CurrencyAmount = oPaymentItem.PaymentAmount
                oPaymentItem.LCurrencyAmount = oPaymentItem.CurrencyAmount * oClaimPayment.PaymentToLossXRate
            ElseIf oClaimPayment.ClaimPaymentIsGross = "1" Then
                oPaymentItem.CurrencyAmount = oPaymentItem.PaymentAmount - (oPaymentItem.TaxAmount + oPaymentItem.TaxAmountWHT)
                oPaymentItem.LCurrencyAmount = (oPaymentItem.CurrencyAmount - (oPaymentItem.TaxAmount + oPaymentItem.TaxAmountWHT)) * oClaimPayment.PaymentToLossXRate
            End If

            If oPaymentItem.IsWHTTax = True Then
                oPaymentItem.LCurrencyTaxWHT = oPaymentItem.TaxAmountWHT * oClaimPayment.PaymentToLossXRate
            ElseIf oPaymentItem.IsWHTTax = False Then
                oPaymentItem.LCurrencyTax = oPaymentItem.TaxAmount * oClaimPayment.PaymentToLossXRate
            End If
        End If

    End Sub

    Private Sub CalculateTax(ByVal Con As SiriusConnection, ByVal oClaimPaymenttaxDetails As BaseCalculateTaxForClaimsRequestType, ByRef r_dCurrencyTaxAmount As Decimal, ByRef r_dLossTaxAmount As Decimal, ByRef r_dBaseTaxAmount As Decimal, ByRef oCalculateTaxForClaimsResponseType As BaseCalculateTaxForClaimsResponseType, ByRef rError As SAMErrorCollection, Optional ByRef r_sScriptFile As String = "")

        Dim lItemCount As Integer = 0
        Dim cnt As Integer = 0

        ' for each claim payment item

        ' if the payment is for the current reserve

        Dim m_vTaxBandRate As DataSet = Nothing
        Dim lTmpClaimReceiptId As Integer

        ' if the claim payment is gross -- todo
        If oClaimPaymenttaxDetails.AdvancedTaxDetails.IsExcess Then
            lTmpClaimReceiptId = 1
        Else
            lTmpClaimReceiptId = 0
        End If

        ' Variables for storing the Tax Amounts retrieved from Recalculate Sub routine
        Dim crTaxLossAmount As Decimal = 0
        Dim crCurrencyAmount As Decimal = 0
        Dim crTaxBaseAmount As Decimal = 0

        If Not oClaimPaymenttaxDetails.TaxGroupCode = Nothing Then

            ' call recalculate routine to get the tax details for all the bands
            CalculateTaxAmounts(con:=Con,
                                    lCompanyId:=oClaimPaymenttaxDetails.CompanyKey,
                                    lTaxGroupId:=Cast.ToInt32(oClaimPaymenttaxDetails.TaxGroupKey, 0),
                                    sTranstype:=kTaxTransTypeClaimPayment,
                                    lCurrencyId:=oClaimPaymenttaxDetails.CurrencyKey,
                                    lLossCurrencyId:=oClaimPaymenttaxDetails.LossCurrencyKey,
                                    crAmount:=Convert.ToDecimal(oClaimPaymenttaxDetails.Amount),
                                    crTaxCurrencyAmount:=crCurrencyAmount,
                                    crTaxLossAmount:=crTaxLossAmount,
                                    crTaxBaseAmount:=crTaxBaseAmount,
                                    lClaimPerilId:=CInt(oClaimPaymenttaxDetails.PerilId),
                                    lClaimPaymentId:=1,
                                    lClaimReceiptId:=lTmpClaimReceiptId,
                                    lClaimPaymentItemId:=0,
                                    lClaimReceiptItemId:=1,
                                    lCalculateOnly:=1,
                                    oTaxBandDetails:=m_vTaxBandRate)



            Dim crScriptedTaxAmount As Decimal = 0
            Dim sScriptFile As String = ""
            crScriptedTaxAmount = CalculateScriptedTaxNew(Con:=Con,
                                                            oClaimPaymenttaxDetails:=oClaimPaymenttaxDetails,
                                                            oSAMErrorCollection:=rError,
                                                            m_vTaxBandRate:=m_vTaxBandRate, oCalculateTaxForClaimsResponseType:=oCalculateTaxForClaimsResponseType)
          
            crCurrencyAmount = crScriptedTaxAmount

            Dim dBaserate As Decimal
            Dim dLossRate As Decimal
            GetCurrencyToBaseXRate(Con, oClaimPaymenttaxDetails.CurrencyKey, oClaimPaymenttaxDetails.SourceId, Date.Now, dBaserate)
            r_dBaseTaxAmount = crCurrencyAmount * dBaserate

            ' get the loss currency to base currency exchange rate
            GetCurrencyToBaseXRate(Con, oClaimPaymenttaxDetails.LossCurrencyKey, oClaimPaymenttaxDetails.SourceId, Date.Now, dLossRate)

            ' get the payment to loss currency exchange rate and store it on the payment
            r_dLossTaxAmount = r_dBaseTaxAmount / dLossRate
            r_dCurrencyTaxAmount = crCurrencyAmount

        End If

    End Sub

    Private Sub CalculateReceiptTax(ByVal Con As SiriusConnection, ByVal oClaimReceipttaxDetails As BaseCalculateTaxForClaimsRequestType,
                                    ByRef r_dCurrencyTaxAmount As Decimal, ByRef r_dLossTaxAmount As Decimal, ByRef r_dBaseTaxAmount As Decimal,
                                    ByRef rError As SAMErrorCollection,
                                    ByRef oCalculateTaxForClaimsResponseType As BaseCalculateTaxForClaimsResponseType)

        Dim lItemCount As Integer = 0
        Dim cnt As Integer = 0
        Dim oSAMErrorCollection As SAMErrorCollection

        Dim m_vTaxBandRate As DataSet = Nothing
        Dim lTmpClaimReceiptId As Integer

        ' Variables for storing the Tax Amounts retrieved from Recalculate Sub routine
        Dim crTaxLossAmount As Decimal = 0
        Dim crCurrencyAmount As Decimal = 0
        Dim crTaxBaseAmount As Decimal = 0

        If Not oClaimReceipttaxDetails.TaxGroupCode = Nothing Then

            Dim TaxCalculationItems As DataSet = Nothing

            Dim sTransType As String = String.Empty

            ' determine which tax transaction type to use
            If oClaimReceipttaxDetails.IsSalvageRecovery Then
                sTransType = kTaxTransTypeClaimSalvageReceipt
            Else
                sTransType = kTaxTransTypeClaimThirdPartyRecoveryReceipt
            End If

            ' if the receipt item had a tax group id specified then use it to calculate the system tax
            CalculateTaxAmounts(con:=Con,
                                lCompanyId:=oClaimReceipttaxDetails.SourceId,
                                lTaxGroupId:=CInt(oClaimReceipttaxDetails.TaxGroupKey),
                                sTranstype:=sTransType,
                                lCurrencyId:=oClaimReceipttaxDetails.CurrencyKey,
                                lLossCurrencyId:=oClaimReceipttaxDetails.LossCurrencyKey,
                                crAmount:=Convert.ToDecimal(oClaimReceipttaxDetails.Amount),
                                crTaxCurrencyAmount:=0,
                                crTaxLossAmount:=0,
                                crTaxBaseAmount:=0,
                                lClaimPerilId:=oClaimReceipttaxDetails.PerilId,
                                lClaimPaymentId:=0,
                                lClaimReceiptId:=1,
                                lClaimPaymentItemId:=0,
                                lClaimReceiptItemId:=1,
                                lCalculateOnly:=1,
                                oTaxBandDetails:=TaxCalculationItems)


            Dim AdvancedTaxScriptDataArray() As Object = Nothing
            Dim UpdatedAdvancedTaxScriptDataArray() As Object = Nothing
            Dim advancedTaxScript As String
            ' load the advanced tax script data array
            SetupClaimReceiptAdvancedTaxScriptArraysNew(oClaimReceipttaxDetails.ReceiptAdvancedTaxDetails, oClaimReceipttaxDetails.Amount, TaxCalculationItems, oClaimReceipttaxDetails.CurrencyCode, AdvancedTaxScriptDataArray)

            GetAdvancedTaxScript(con:=Con, taxGroupId:=Cast.ToInt32(oClaimReceipttaxDetails.TaxGroupKey, 0), advancedTaxScript:=advancedTaxScript)

            ' execute advanced tax script
            ExecuteAdvancedTaxScript(Con, advancedTaxScript, oClaimReceipttaxDetails.BranchCode, AdvancedTaxScriptDataArray, UpdatedAdvancedTaxScriptDataArray, Cast.ToInt32(oClaimReceipttaxDetails.TaxGroupKey, 0))

            ' validate the updated details
            ' ValidateAdvancedTaxScriptArray(Con, ClaimDetails, ClaimReceipt, ClaimReceiptItem, UpdatedAdvancedTaxScriptDataArray, Response)
            Dim vUpdatedTaxParameters() As Object
            vUpdatedTaxParameters = DirectCast(UpdatedAdvancedTaxScriptDataArray, Object())

            ValidateTaxArray(v_sTaxScriptName:=advancedTaxScript,
                                                v_vOrigTaxParameters:=AdvancedTaxScriptDataArray,
                                                v_vUpdatedTaxParameters:=vUpdatedTaxParameters,
                                                SourceId:=CInt(oClaimReceipttaxDetails.SourceId),
                                                kTaxArray:=10,
                                                con:=Con,
                                                oSAMErrorCollection:=oSAMErrorCollection,
                                                CurrencyCode:=oClaimReceipttaxDetails.CurrencyCode,
                                                CurrencyID:=oClaimReceipttaxDetails.CurrencyKey,
                                                LossCurrencyId:=oClaimReceipttaxDetails.LossCurrencyKey)

            Dim vUpdatedTaxArray As Object(,)
            Dim llbound As Integer
            Dim lubound As Integer
            Dim lTaxItem As Integer
            vUpdatedTaxArray = DirectCast(vUpdatedTaxParameters(10), Object(,))

            llbound = LBound(vUpdatedTaxArray, 2)
            lubound = UBound(vUpdatedTaxArray, 2)
            Dim lIsManuallyChanged As Integer
            Dim crScriptedTaxAmount As Decimal
            Dim crTaxAmount As Decimal
            For lTaxItem = llbound To lubound
                crTaxAmount = CDec(vUpdatedTaxArray(kTaxArrayValue, lTaxItem))

                ReDim Preserve oCalculateTaxForClaimsResponseType.ReceiptTaxItems(lTaxItem)
                oCalculateTaxForClaimsResponseType.ReceiptTaxItems(lTaxItem) = New BaseClaimReceiptTaxItemType
                With oCalculateTaxForClaimsResponseType.ReceiptTaxItems(lTaxItem)
                    .Amount = CDec(vUpdatedTaxArray(kTaxArrayValue, lTaxItem))
                    If Not String.IsNullOrEmpty(Convert.ToString(vUpdatedTaxArray(kTaxArrayClassOfBusinessId, lTaxItem))) Then
                        .ClassOfBusinessID = Convert.ToInt32(vUpdatedTaxArray(kTaxArrayClassOfBusinessId, lTaxItem))
                    End If
                    .IsManuallyChanges = Convert.ToInt32(vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem))
                    .Percentage = Convert.ToDecimal(vUpdatedTaxArray(kTaxArrayPercentage, lTaxItem))
                    .Sequence = Convert.ToInt32(vUpdatedTaxArray(kTaxArraySequence, lTaxItem))
                    .TaxBandCode = Convert.ToString(vUpdatedTaxArray(kTaxArrayTaxBandDescription, lTaxItem))
                    .TaxBandId = Convert.ToInt32(vUpdatedTaxArray(kTaxArrayTaxBandId, lTaxItem))
                    .TaxGroupCode = Convert.ToString(vUpdatedTaxArray(kTaxArrayTaxGroupDescription, lTaxItem))
                    .TaxGroupId = Convert.ToInt32(vUpdatedTaxArray(kTaxArrayTaxGroupId, lTaxItem))
                End With


                lIsManuallyChanged = Cast.ToInt32(vUpdatedTaxArray(kTaxArrayIsManuallyChanged, lTaxItem)).GetValueOrDefault(0)
                If lIsManuallyChanged = 2 Then 'check if it is manually checked.

                    crScriptedTaxAmount = crScriptedTaxAmount + crTaxAmount

                End If
            Next
            r_dCurrencyTaxAmount = crScriptedTaxAmount

            Dim dBaserate As Decimal
            Dim dLossRate As Decimal
            GetCurrencyToBaseXRate(Con, oClaimReceipttaxDetails.CurrencyKey, oClaimReceipttaxDetails.SourceId, Date.Now, dBaserate)
            r_dBaseTaxAmount = r_dCurrencyTaxAmount * dBaserate

            ' get the loss currency to base currency exchange rate
            GetCurrencyToBaseXRate(Con, oClaimReceipttaxDetails.LossCurrencyKey, oClaimReceipttaxDetails.SourceId, Date.Now, dLossRate)

            ' get the payment to loss currency exchange rate and store it on the payment
            r_dLossTaxAmount = r_dBaseTaxAmount / dLossRate
            ' r_dCurrencyTaxAmount = crCurrencyAmount


        Else
            ' No advanced tax script has been specified for the tax group specified on this receipt iten
            ' do nothing
        End If
    End Sub

    ''' <summary>
    '''  validates all the data in the request that can be validated
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub PayClaimValidateData(ByVal con As SiriusConnection,
                ByVal oBusiness As CoreBusiness,
                ByRef PayClaimRequest As BaseClaimPaymentRequestType,
                ByRef oSAMErrorCollection As SAMErrorCollection)

        ' Validate standard lookup data
        PayClaimValidateDataStandardLookup(oBusiness, PayClaimRequest, oSAMErrorCollection)

        ' validate other data
        PayClaimValidateDataOther(con, oBusiness, PayClaimRequest, oSAMErrorCollection)

    End Sub

    ''' <summary>
    ''' validates the standard lookup data 
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub PayClaimValidateDataStandardLookup(
                ByVal oBusiness As CoreBusiness,
                ByRef PayClaimRequest As BaseClaimPaymentRequestType,
                ByRef oSAMErrorCollection As SAMErrorCollection)

        ' Mandatory Fields in the Structure--------------------------------------
        ' branch code
        PayClaimRequest.ClaimPayment.SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, PayClaimRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        PayClaimRequest.SourceId = PayClaimRequest.ClaimPayment.SourceId

        '' Currency Code
        PayClaimRequest.ClaimPayment.CurrencyId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, PayClaimRequest.ClaimPayment.CurrencyCode, "CurrencyCode", oSAMErrorCollection)

        '' TaxGroupCode
        If PayClaimRequest.ClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For cntTax As Integer = PayClaimRequest.ClaimPayment.ClaimPaymentItem.GetLowerBound(0) To PayClaimRequest.ClaimPayment.ClaimPaymentItem.GetUpperBound(0)
                If Not PayClaimRequest.ClaimPayment.ClaimPaymentItem(cntTax).TaxGroupCode = Nothing Then
                    PayClaimRequest.ClaimPayment.ClaimPaymentItem(cntTax).TaxGroupId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.TaxGroup, PayClaimRequest.ClaimPayment.ClaimPaymentItem(cntTax).TaxGroupCode, "TaxGroupCode", oSAMErrorCollection)  ' CHECK IN
                End If
            Next
        End If

        ' Optional Fields In Structure
        ' Safe Harbour
        If PayClaimRequest.ClaimPayment.AdvancedTaxDetails IsNot Nothing Then
            If String.IsNullOrEmpty(PayClaimRequest.ClaimPayment.AdvancedTaxDetails.SafeHarbourCode) = False Then
                PayClaimRequest.ClaimPayment.AdvancedTaxDetails.SafeHarbourID = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.SafeHarbour, PayClaimRequest.ClaimPayment.AdvancedTaxDetails.SafeHarbourCode, "SafeHarbourCode", oSAMErrorCollection)  ' CHECK IN
            End If
        End If

        ' Media Type Code
        If PayClaimRequest.ClaimPayment.Payee IsNot Nothing Then
            If String.IsNullOrEmpty(PayClaimRequest.ClaimPayment.Payee.MediaTypeCode) = False Then
                PayClaimRequest.ClaimPayment.Payee.MediaTypeId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.MediaType, PayClaimRequest.ClaimPayment.Payee.MediaTypeCode, "MediaTypeCode", oSAMErrorCollection)
            End If

            ' Country Code
            If PayClaimRequest.ClaimPayment.Payee.Address IsNot Nothing Then
                If String.IsNullOrEmpty(PayClaimRequest.ClaimPayment.Payee.Address.CountryCode) = False Then
                    PayClaimRequest.ClaimPayment.Payee.Address.CountryId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Country, PayClaimRequest.ClaimPayment.Payee.Address.CountryCode, "CountryCode", oSAMErrorCollection)
        End If
            End If
        End If

    End Sub

    ''' <summary>
    ''' validate various other data 
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub PayClaimValidateDataOther(ByVal con As SiriusConnection,
                       ByVal oBusiness As CoreBusiness,
                       ByRef PayClaimRequest As BaseImplementationTypes.BaseClaimPaymentRequestType,
                       ByRef oSAMErrorCollection As SAMErrorCollection)

        ' validate claim payment data links
        ClaimPaymentValidateDataLinks(con, PayClaimRequest,
                                        oSAMErrorCollection)

        ' Validate Base Claim  Key 
        ValidateBaseClaimKey(con, CInt(PayClaimRequest.ClaimPayment.BaseClaimKey),
                                        oSAMErrorCollection)

        ' Validate Base Claim Peril Key
        ValidateBaseClaimPerilKey(con, CInt(PayClaimRequest.ClaimPayment.BaseClaimPerilKey),
                                        oSAMErrorCollection)

        ' Validate Base base reserve Key
        If PayClaimRequest.ClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For icount As Integer = PayClaimRequest.ClaimPayment.ClaimPaymentItem.GetLowerBound(0) To PayClaimRequest.ClaimPayment.ClaimPaymentItem.GetUpperBound(0)
                ValidateBaseReserveKey(con, CInt(PayClaimRequest.ClaimPayment.ClaimPaymentItem(icount).BaseReserveKey),
                                            CInt(PayClaimRequest.ClaimPayment.BaseClaimPerilKey),
                                            oSAMErrorCollection)
            Next
        End If

        ' Validate Advanced Tax Scripts Data
        If PayClaimRequest.ClaimPayment.AdvancedTaxDetails IsNot Nothing Then
            ValidatePercentageFields(PayClaimRequest.ClaimPayment.AdvancedTaxDetails.InsuredPercentage,
                                            PayClaimRequest.ClaimPayment.AdvancedTaxDetails.PayeePercentage,
                                            oSAMErrorCollection)
        End If
        ' get the details for the last version of the specified claim so we can perform further validation
        ' of the request
        Dim oClaimDetails As New BaseAdditionalClaimRelatedDetails

        ' get details for the claim 
        GetClaimDetailsForPaymentOrReceipt(con,
                PayClaimRequest.ClaimPayment.ClaimId,
                PayClaimRequest.ClaimPayment.ClaimPerilId,
                oClaimDetails)

        ' validates the payment party information - and sets the correct default value if a value is not provided by the request
        ValidateClaimPaymentPayeeInformation(oClaimDetails, PayClaimRequest.ClaimPayment.PartyKey,
                    PayClaimRequest.ClaimPayment.PaymentPartyType, oSAMErrorCollection)

        ' determine whether is withholding tax 
        ValidateClaimPaymentTaxGroup(con, PayClaimRequest, oSAMErrorCollection)

    End Sub

    Private Sub ClaimPaymentValidateDataLinks(
   ByVal con As SiriusConnection,
   ByVal oRequest As BaseClaimPaymentRequestType,
   ByVal oSAMErrorCollection As SAMErrorCollection)
        If oRequest.ClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For Each oClaimPaymentItem As BaseClaimPaymentItemType In oRequest.ClaimPayment.ClaimPaymentItem
                If oClaimPaymentItem IsNot Nothing Then
                    Dim dt As DataTable = Nothing

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Validate_Claim_Payment_Data_Links")

                        cmd.AddInParameter("@base_claim_id", SqlDbType.Int).Value = oRequest.ClaimPayment.BaseClaimKey
                        cmd.AddInParameter("@base_claim_peril_id", SqlDbType.Int).Value = oRequest.ClaimPayment.BaseClaimPerilKey
                        cmd.AddInParameter("@base_reserve_id", SqlDbType.Int).Value = oClaimPaymentItem.BaseReserveKey

                        dt = con.ExecuteDataTable(cmd)

                    End Using

                    If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                        Dim dr As DataRow = dt.Rows(0)

                        ' only get the results for claim / claim peril once 
                        If oRequest.ClaimPayment.ClaimId = 0 Then

                            ' use the latest version of the links before we create a new copy
                            oRequest.ClaimPayment.ClaimId = Cast.ToInt32(dr.Item("claim_id"), 0)
                            oRequest.ClaimPayment.ClaimPerilId = Cast.ToInt32(dr.Item("claim_peril_id"), 0)

                        End If

                        ' use the latest version of the links before we create a new copy 
                        oClaimPaymentItem.ReserveId = Cast.ToInt32(dr.Item("reserve_id"), 0)

                    Else

                        oSAMErrorCollection.AddInvalidData(SAMInvalidData.ClaimReceiptInvalidDataLinksProvidedNoLinkExistsBetweenClaimAndClaimPerilAndRecovery,
                                         SAMInvalidData.ClaimReceiptInvalidDataLinksProvidedNoLinkExistsBetweenClaimAndClaimPerilAndRecovery.ToString(),
                                         "BaseClaimKey And BaseClaimPerilKey And BaseRecoveryKey",
                                         "BaseClaimKey:-" & oRequest.ClaimPayment.BaseClaimKey & ": BaseCLaimPerilKey:-" & oRequest.ClaimPayment.BaseClaimPerilKey & ": BaseReserveKey:-" & oClaimPaymentItem.BaseReserveKey)

                    End If
                End If

            Next
        End If
    End Sub

    ''' <summary>
    '''  validates that the selected tax groups are appropriate to the selected payee
    ''' </summary>
    ''' <param name="oRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub ValidateClaimReceiptTaxGroup(
    ByVal Request As BaseClaimReceiptRequestType,
    ByVal oSAMErrorCollection As SAMErrorCollection,
    ByVal TransactionTypeCode As String)



        Dim dt As DataTable = Nothing
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
        ' get the relevant tax groups ( either those with withholding tax set on / or those with withholding tax set off)
        GetTaxGroupDetails(con, Nothing, TransactionTypeCode, dt)
        End Using
        Dim ValidTaxGroupsFound As Boolean = False

        ' if there are tax group rows then
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            ValidTaxGroupsFound = True
        End If

        ' validate tax group selection
        If Request.ClaimReceipt.ReceiptItem IsNot Nothing Then
            For Each ClaimReceiptItem As BaseClaimReceiptItemType In Request.ClaimReceipt.ReceiptItem

                Dim TaxGroupCode As String = String.Empty
                Dim TaxGroupCodeFound As Boolean = False

                If Not String.IsNullOrEmpty(ClaimReceiptItem.TaxGroupCode) Then
                    TaxGroupCode = ClaimReceiptItem.TaxGroupCode.ToString.Trim
                End If

                ' if there is a tax group code specified for the claim receipt item
                If Not String.IsNullOrEmpty(TaxGroupCode) Then

                    ' if there are valid tax groups for the selected payee / recovery type
                    If ValidTaxGroupsFound Then

                        ' determine if the selected tax group is one of the valid ones
                        For Each dr As DataRow In dt.Rows

                            If TaxGroupCode = Cast.ToStringTrim(dr.Item("Code")) Then

                                ' found the specified tax group so store away the id and the
                                ClaimReceiptItem.TaxGroupId = Cast.ToInt32(dr.Item("tax_group_id"))

                                ' associated advanced tax script details
                                ClaimReceiptItem.TaxGroupAdvancedTaxScript = Cast.ToStringTrim(dr.Item("advanced_tax_script"))

                                TaxGroupCodeFound = True

                            End If

                        Next

                    End If

                    ' if no valid tax group was found
                    If Not TaxGroupCodeFound Then
                        ' raise an error
                        oSAMErrorCollection.AddInvalidData(SAMInvalidData.InvalidTaxGroupSpecified,
                                 SAMInvalidData.InvalidTaxGroupSpecified.ToString,
                                 "TaxGroupCode", ClaimReceiptItem.TaxGroupCode)
                    End If
                Else
                    ' otherwise there isnt a tax group sepcified - this is valid; a tax group doesnt have to be specified
                    ' for every receipt item
                End If
            Next
        End If
    End Sub

    ''' <summary>
    '''  validates that the selected tax groups are appropriate to the selected payee
    ''' </summary>
    ''' <param name="oRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub ValidateClaimPaymentTaxGroup(ByVal con As SiriusConnection, ByVal oRequest As BaseClaimPaymentRequestType, ByVal oSAMErrorCollection As SAMErrorCollection)

        Dim AdvancedTaxSpecified As Boolean = False
        Dim PayeeDomiciled As Boolean = False
        Dim PayeeTaxNumber As String = String.Empty
        Dim PayeeTaxPercentage As Decimal = 0
        Dim IsWithHoldingTaxValue As Integer = -1

        ' get the advanced tax defaults
        If oRequest.ClaimPayment.AdvancedTaxDetails IsNot Nothing Then
            AdvancedTaxSpecified = True
            PayeeDomiciled = oRequest.ClaimPayment.AdvancedTaxDetails.PayeeDomiciled
            PayeeTaxNumber = oRequest.ClaimPayment.AdvancedTaxDetails.PayeeTaxNumber
            PayeeTaxPercentage = oRequest.ClaimPayment.AdvancedTaxDetails.PayeePercentage
        End If

        Dim IsWithholdingTax As Integer
        Dim taxGroupCode As String = String.Empty
        Dim dt As DataTable = Nothing

        For row As Integer = 0 To oRequest.ClaimPayment.ClaimPaymentItem.Count - 1
            If oRequest.ClaimPayment.ClaimPaymentItem(row).TaxGroupCode <> String.Empty Then
                taxGroupCode = oRequest.ClaimPayment.ClaimPaymentItem(row).TaxGroupCode

                Dim sDtNull As String = String.Empty

                Dim dt1 As DataTable = Nothing
                If (taxGroupCode <> String.Empty) Then
                    GetWithHoldingTaxValue(con, taxGroupCode, dt1)
                End If

                If dt1 IsNot Nothing AndAlso dt1.Rows.Count > 0 Then
                    If Convert.ToString(dt1.Rows(0).Item("IsWithholdingTax")) <> "" Then
                        IsWithHoldingTaxValue = CInt(dt1.Rows(0).Item("IsWithholdingTax"))
                    Else
                        IsWithHoldingTaxValue = 0
                    End If
                End If
                IsWithholdingTax = GetIsWithholdingTax(con, oRequest.ClaimPayment.PaymentPartyType,
            oRequest.ClaimPayment.PartyKey, AdvancedTaxSpecified,
                  PayeeDomiciled, PayeeTaxNumber, PayeeTaxPercentage, IsWithHoldingTaxValue)

        ' store the fact that any tax on this payment must be WithHoldingTax / Not WithHoldingTax
        oRequest.ClaimPayment.TaxIsWithHoldingTax = CBool(IsWithholdingTax)

                ' get the relevant tax groups ( either those with withholding tax set on / or those with withholding tax set off)
                GetTaxGroupDetails(con, IsWithholdingTax, TransactionTypeCode.PayClaim, dt)

            End If
        Next

        'In case No Taxgroup is set in the reserves then this will execute
        If IsWithHoldingTaxValue = -1 Then

            IsWithholdingTax = GetIsWithholdingTax(con, oRequest.ClaimPayment.PaymentPartyType,
                         oRequest.ClaimPayment.PartyKey, AdvancedTaxSpecified,
                           PayeeDomiciled, PayeeTaxNumber, PayeeTaxPercentage)

            ' store the fact that any tax on this payment must be WithHoldingTax / Not WithHoldingTax
            oRequest.ClaimPayment.TaxIsWithHoldingTax = CBool(IsWithholdingTax)

        ' get the relevant tax groups ( either those with withholding tax set on / or those with withholding tax set off)
        GetTaxGroupDetails(con, IsWithholdingTax, TransactionTypeCode.PayClaim, dt)

        End If

        Dim bTaxGroupsFound As Boolean = False

        ' if there are tax group rows then
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            bTaxGroupsFound = True
        End If

        ' validate tax group selection
        If oRequest.ClaimPayment.ClaimPaymentItem IsNot Nothing Then
            For Each oPaymentItem As BaseClaimPaymentItemType In oRequest.ClaimPayment.ClaimPaymentItem

                Dim sTaxGroupCode As String = Cast.ToStringTrim(oPaymentItem.TaxGroupCode)
                Dim bFound As Boolean = False

                ' if there is a tax group code specified for the claim payment item
                If Not String.IsNullOrEmpty(oPaymentItem.TaxGroupCode) Then

                    ' if there are valid tax groups for the selected payee
                    If bTaxGroupsFound Then

                        ' determine if the selected tax group is one of the valid ones
                        For Each dr As DataRow In dt.Rows
                            If sTaxGroupCode = Cast.ToStringTrim(dr.Item("Code")) Then
                                bFound = True
                            End If
                        Next

                    End If

                    ' if no valid tax group was found
                    If Not bFound Then
                        If IsWithholdingTax = WithholdingTaxSwitch.IsOn Then
                            oSAMErrorCollection.AddInvalidData(SAMInvalidData.SelectedPayeeRequiresAnIsWithholdingTaxTaxGroup,
                             SAMInvalidData.SelectedPayeeRequiresAnIsWithholdingTaxTaxGroup.ToString,
                             "TaxGroupCode", oPaymentItem.TaxGroupCode)
                        Else
                            oSAMErrorCollection.AddInvalidData(SAMInvalidData.SelectedPayeeRequiresATaxGroupWhichIsNotAnIsWithholdingTaxTaxGroup,
                             SAMInvalidData.SelectedPayeeRequiresATaxGroupWhichIsNotAnIsWithholdingTaxTaxGroup.ToString,
                             "TaxGroupCode", oPaymentItem.TaxGroupCode)
                        End If
                    End If

                End If
            Next
        End If
    End Sub
    ''' <summary>
    ''' Validates payment Party Type on the basis of
    ''' if PartyType is CLMPAYABLE then PartyKey must be 0
    ''' if PartyType is Agent then PartyCode must start with 'AG_____'
    ''' if Party Type is Client then PartyCode must start with 'PC____','CC_____' OR 'GC_____'
    ''' if party Type is Other then PartyCode must start with 'OT_____'
    ''' </summary>
    ''' <param name="lPartyKey"></param>
    ''' <param name="lPartyType"></param>
    ''' <param name="oSamErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub ValidatePaymentPartyType(ByVal PartyKey As Integer,
                                         ByVal PartyType As Integer,
                                         ByVal oSAMErrorCollection As SAMErrorCollection)

        Dim sPartyType As String = String.Empty
        ' Select the type of party into string variable
        If PartyType = ClaimPaymentPartyTypeType.PARTY Then
            sPartyType = "PARTY"
        ElseIf PartyType = ClaimPaymentPartyTypeType.CLIENT Then
            sPartyType = "CLIENT"
        ElseIf PartyType = ClaimPaymentPartyTypeType.AGENT Then
            sPartyType = "AGENT"
        End If

        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

            Select Case PartyType

                Case ClaimPaymentPartyTypeType.CLMPAYABLE

                    If PartyKey <> 0 Then
                        oSAMErrorCollection.AddInvalidData(
                               SAMInvalidData.PaymentPartyTypeCLMPAYABLESpecifiedPartyKeyShouldBeZero,
                               SAMInvalidData.PaymentPartyTypeCLMPAYABLESpecifiedPartyKeyShouldBeZero.ToString(),
                               "PartyKey",
                               PartyKey.ToString())
                    End If

                Case Else

                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Check_PaymentPartyType")

                        cmd.AddInParameter("@Partykey", SqlDbType.Int).Value = Cast.ToInt32(PartyKey)
                        cmd.AddInParameter("@PartyType", SqlDbType.VarChar, 10).Value = sPartyType
                        cmd.AddOutParameter("@Valid", SqlDbType.Int)
                        con.ExecuteNonQuery(cmd)

                        If Cast.ToInt32(cmd.Parameters.Item("@Valid").Value, 0) = 0 Then
                            oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure,
                                                                "Payment Party Type Invalid",
                                                                "Payment Party Type",
                                                                PartyKey.ToString())
                        End If

                    End Using

            End Select

        End Using

    End Sub

