        Dim dsProductClaimsWorkflowOptions As DataSet = Nothing

        Using conGetProductClaimsWorkflowOptions As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            dsProductClaimsWorkflowOptions = GetProductClaimsWorkflowOptions(conGetProductClaimsWorkflowOptions, oGetProductClaimsWorkflowOptionsRequest)
        End Using

        If (dsProductClaimsWorkflowOptions IsNot Nothing AndAlso dsProductClaimsWorkflowOptions.Tables.Count > 0 AndAlso dsProductClaimsWorkflowOptions.Tables(0).Rows.Count > 0) Then

            'Populate response object
            With dsProductClaimsWorkflowOptions.Tables(0).Rows(0)
                oResponse.CashPaymentProcess = Cast.ToBoolean(.Item("CashPaymentProcess"), False)
                oResponse.CheckDeferredReinsurance = Cast.ToBoolean(.Item("CheckDeferredReinsurance"), False)
                oResponse.CheckUnpaidStatus = Cast.ToBoolean(.Item("CheckUnpaidStatus"), False)
                oResponse.ClaimNotificationDocMessage = Cast.ToBoolean(.Item("ClaimNotificationDocMessage"), False)
                oResponse.ClaimPaymentDocMessage = Cast.ToBoolean(.Item("ClaimPaymentDocMessage"), False)
                oResponse.ClaimPaymentProcess = Cast.ToBoolean(.Item("ClaimPaymentProcess"), False)
                oResponse.DescriptionForChangeInPayment = Cast.ToBoolean(.Item("DescriptionForChangeInPayment"), False)
                oResponse.DescriptionForChangeInReserve = Cast.ToBoolean(.Item("DescriptionForChangeInReserve"), False)
                oResponse.ExternalClaimHandling = Cast.ToBoolean(.Item("ExternalClaimHandling"), False)
                oResponse.FastTrackClaims = Cast.ToBoolean(.Item("FastTrackClaims"), False)
                oResponse.GenerateClaimNotificationDoc = Cast.ToBoolean(.Item("GenerateClaimNotificationDoc"), False)
                oResponse.GenerateClaimPaymentDoc = Cast.ToBoolean(.Item("GenerateClaimPaymentDoc"), False)
                oResponse.MakeFurtherPayments = Cast.ToBoolean(.Item("MakeFurtherPayments"), False)
                oResponse.ReinsurancePayment = Cast.ToBoolean(.Item("ReinsurancePayment"), False)
                oResponse.ReinsuranceRecovery = Cast.ToBoolean(.Item("ReinsuranceRecovery"), False)
                oResponse.SalvageRecovery = Cast.ToBoolean(.Item("SalvageRecovery"), False)
                oResponse.ThirdPartyRecovery = Cast.ToBoolean(.Item("ThirdPartyRecovery"), False)
            End With
        End If

        Return oResponse
    End Function

    ''' <summary>
    '''This method sends the request object values to the Stored Procedure and get the reponse object 
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>
    '''<param name="oGetProductClaimsWorkflowOptionsRequest" type="BaseGetProductClaimsWorkflowOptionsRequestType"></param>
    '''<returns> DataSet</returns>
    '''<remarks></remarks>
    Private Overloads Function GetProductClaimsWorkflowOptions(ByVal con As SiriusConnection,
ByVal oGetProductClaimsWorkflowOptionsRequest As BaseGetProductClaimsWorkflowOptionsRequestType) As DataSet
        Dim dsProductClaimsWorkflowOptions As DataSet = Nothing
        
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Get_Product_Claims_Workflow_Options")
