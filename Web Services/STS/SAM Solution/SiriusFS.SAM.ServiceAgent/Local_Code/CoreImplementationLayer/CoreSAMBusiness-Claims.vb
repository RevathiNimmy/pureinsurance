    Private Function UpdateClaimPerilReserve(ByVal con As SiriusConnection,
                                            ByVal lClaimPerilId As Integer,
                                            ByVal lReserveId As Integer,
                                            ByVal sTypeCode As String,
                                            ByVal crRevisionAmount As Decimal,
                                            ByVal sTransactionType As String,
                                            Optional ByVal IsUpdateReserve As Boolean = False) As Integer

        Try
            If IsUpdateReserve = False Then
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Update_Claim_Peril_Reserve")

                    cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = lClaimPerilId
                    cmd.AddInParameter("@type_code", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(sTypeCode)
                    cmd.AddInParameter("@revision_amount", SqlDbType.Money).Value = crRevisionAmount
                    cmd.AddInParameter("@transaction_type", SqlDbType.VarChar, 10).Value = Cast.NullIfDefault(sTransactionType)
                    cmd.AddInOutParameter("@reserve_id", SqlDbType.Int).Value = lReserveId

                    con.ExecuteNonQuery(cmd)

                    lReserveId = Cast.ToInt32(cmd.Parameters("@reserve_id").Value).GetValueOrDefault()

                End Using
            Else
                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Reserve_Update")

                    cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = lClaimPerilId
                    cmd.AddInParameter("@type_code", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(sTypeCode)
                    cmd.AddInParameter("@revision_amount", SqlDbType.Money).Value = crRevisionAmount
                    cmd.AddInParameter("@transaction_type", SqlDbType.VarChar, 10).Value = Cast.NullIfDefault(sTransactionType)
                    cmd.AddInOutParameter("@reserve_id", SqlDbType.Int).Value = lReserveId

                    con.ExecuteNonQuery(cmd)

                    lReserveId = Cast.ToInt32(cmd.Parameters("@reserve_id").Value).GetValueOrDefault()

                End Using
            End If
            Return lReserveId

        Catch ex As Exception
            Debug.WriteLine(ex.Message)
            Throw
        End Try

    End Function

    Private Function ProcessClaimPerilRecovery(ByVal con As SiriusConnection,
                                            ByVal ClaimPerilId As Integer,
                                            ByVal RecoveryTypeId As Integer,
                                            ByVal CurrencyId As Integer,
                                            ByVal RevisionAmount As Decimal,
                                            ByVal VersionId As Integer,
                                            ByVal iRecoveryPartykey As Integer,
                                            ByVal iRecoveryPartyTypeKey As Integer,
                                            Optional ByVal iIsDeletedRecovery As Boolean = False,
                                            Optional ByVal iBaseRecoveryKey As Integer = 0,
                                            Optional ByVal IsUpdateRecovery As Integer = 0,
                                            Optional ByVal IsNew As Boolean = False,
                                            Optional ByVal InitialAmount As Decimal = 0) As Integer
        Dim nRecoveryId As Integer = 0

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_process_recovery")

            cmd.AddOutParameter("@recovery_id", SqlDbType.Int)
            cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = ClaimPerilId
            cmd.AddInParameter("@recovery_type_id", SqlDbType.Int).Value = RecoveryTypeId
            cmd.AddInParameter("@currency_id", SqlDbType.Int).Value = CurrencyId
            cmd.AddInParameter("@revision_amount", SqlDbType.Money).Value = RevisionAmount
            cmd.AddInParameter("@version_id", SqlDbType.Int).Value = VersionId
            cmd.AddInParameter("@recovery_party_type_id", SqlDbType.Int).Value = Cast.NullIfDefault(iRecoveryPartyTypeKey, 0)
            cmd.AddInParameter("@recovery_party_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(iRecoveryPartykey, 0)
            cmd.AddInParameter("@is_deleted_recovery", SqlDbType.Bit).Value = Cast.ToByte(iIsDeletedRecovery, 0)
            cmd.AddInParameter("@base_recovery_key", SqlDbType.Int).Value = iBaseRecoveryKey
            cmd.AddInParameter("@Initial_amount", SqlDbType.Money).Value = InitialAmount
            If IsUpdateRecovery = 2 And IsNew = True Then
                cmd.AddInParameter("@OverllapExisting", SqlDbType.TinyInt).Value = 1
            Else
                cmd.AddInParameter("@OverllapExisting", SqlDbType.TinyInt).Value = IsUpdateRecovery
            End If
            con.ExecuteNonQuery(cmd)

            nRecoveryId = Cast.ToInt32(cmd.Parameters("@recovery_id").Value, 0)

        End Using

        Return nRecoveryId

    End Function

