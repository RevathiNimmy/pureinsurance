    Private Sub GetClaimPerilRecoveryDetails(
    ByVal con As SiriusConnection,
    ByVal oCoreBusiness As CoreBusiness,
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal Response As BaseGetClaimReceiptTaxesResponseType)

        Dim dt As DataTable = Nothing

        Dim IsSalvage As Integer
        Dim iPerilid As Integer

        If ClaimReceipt.IsSalvageRecovery Then
            IsSalvage = 1
        Else
            IsSalvage = 0
        End If

        If ClaimReceipt.ClaimPerilId = 0 Then
            iPerilid = ClaimReceipt.BaseClaimPerilKey
        Else
            iPerilid = ClaimReceipt.ClaimPerilId
        End If

        ' get the default details for the recovery items
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Recovery_saa")

            cmd.AddInParameter("@peril_id", SqlDbType.Int).Value = iPerilid ' ClaimReceipt.ClaimPerilId
            cmd.AddInParameter("@is_salvage", SqlDbType.Int).Value = IsSalvage

            dt = con.ExecuteDataTable(cmd)

        End Using

        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

            Dim ReceivedToDate As Decimal = 0
            Dim InitialReserve As Decimal = 0
            Dim RevisedReserve As Decimal = 0
            Dim TotalRecovery As Decimal = 0
            Dim TotalRecovered As Decimal = 0
            Dim BaseRecoveryKey As Integer = 0

            Dim ListOfRecoveries As New List(Of BaseClaimPerilRecoveryReceiptType)

            For Each dr As DataRow In dt.Rows

                ' create a new instance of object
                Dim oRecovery As New BaseClaimPerilRecoveryReceiptType

                ' get values from data table
                BaseRecoveryKey = Cast.ToInt32(dr.Item("base_recovery_id"), 0)
                ReceivedToDate = Cast.ToDecimal(dr.Item("revised_reserve"), 0)
                InitialReserve = Cast.ToDecimal(dr.Item("initial_reserve"), 0)
                RevisedReserve = Cast.ToDecimal(dr.Item("revised_reserve"), 0)
                TotalRecovered = Cast.ToDecimal(dr.Item("received_to_date"), 0)
                TotalRecovery = InitialReserve + RevisedReserve

                ' populate recovery receipt object
                oRecovery.BalanceAmount = TotalRecovery - TotalRecovered
                oRecovery.BaseRecoveryKey = BaseRecoveryKey
                oRecovery.ThisReceiptINCLTaxAmount = 0
                oRecovery.ThisReceiptNetAmount = 0
                oRecovery.ThisReceiptTaxAmount = 0
                oRecovery.TotalReceiptAmount = TotalRecovered
                oRecovery.TotalRecoveryAmount = TotalRecovery
                oRecovery.TypeCode = Cast.ToStringTrim(dr.Item("recovery_type_code"))
                oRecovery.RecoveryId = Cast.ToInt32(dr.Item("recovery_id"), 0)
                oRecovery.RecoveryTypeId = Cast.ToInt32(dr.Item("recovery_type_id"), 0)

                ' add recovey receipt to list
                ListOfRecoveries.Add(oRecovery)

            Next

            ' set the details into the response
            Response.Recoveries = ListOfRecoveries.ToArray

        End If

    End Sub

    Private Sub UpdateRecovery(
    ByVal con As SiriusConnection,
                                ByVal ClaimReceipt As BaseClaimReceiptType,
                                ByVal ClaimReceiptItem As BaseClaimReceiptItemType,
    Optional ByVal bExcludeTax As Boolean = False)

        Dim ThisRevision As Decimal = 0
        Dim ThisReceipt As Decimal = 0
        Dim TaxAmount As Decimal = 0

        ' always update the recovery in loss currency

        ThisReceipt = ClaimReceiptItem.ReceiptAmount * ClaimReceipt.ReceiptToLossXRate
        TaxAmount = ClaimReceiptItem.TotalTaxAmount * ClaimReceipt.ReceiptToLossXRate

        ThisRevision = 0

        If Not bExcludeTax Then
            ThisReceipt = ThisReceipt - TaxAmount
        End If
        ' update the claim receipt items associated recovery entry
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Claim_Receipt_Item_Recovery_Update")
            cmd.AddInParameter("@recovery_id", SqlDbType.Int).Value = ClaimReceiptItem.RecoveryId
            cmd.AddInParameter("@this_revision", SqlDbType.Money).Value = ThisRevision
            cmd.AddInParameter("@this_receipt", SqlDbType.Money).Value = ThisReceipt
            cmd.AddInParameter("@tax_amount", SqlDbType.Money).Value = TaxAmount
            con.ExecuteNonQuery(cmd)
        End Using

    End Sub

