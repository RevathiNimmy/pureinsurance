                oBindClaimRequest.claimReceipt.ReceiptItem(lCPICount).TaxGroupId = oClaimReceiptRequest.ClaimReceipt.ReceiptItem(lCPICount).TaxGroupId

            Next
        ElseIf isReceiptClaim Then
            oBindClaimRequest.ProcessType = 5 ' Receipt Claim

            oBindClaimRequest.claimReceipt = New BaseImplementationTypes.BaseClaimReceiptType
            oBindClaimRequest.claimReceipt.CurrencyCode = oRequest.Claim.ClaimPeril(0).Recovery(0).RecoveryDetails.ReceiptCurrencyCode
            oBindClaimRequest.claimReceipt.CurrencyId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, oRequest.Claim.ClaimPeril(0).Recovery(0).RecoveryDetails.ReceiptCurrencyCode, "CurrencyCode")
            oBindClaimRequest.claimReceipt.BaseClaimKey = oRequest.BaseClaimKey
            oBindClaimRequest.claimReceipt.BaseClaimPerilKey = oClaimReceiptRequest.ClaimReceipt.BaseClaimPerilKey
