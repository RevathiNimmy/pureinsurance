    Private Sub UpdateReserveValidateClaimPerilDetails(
                        ByVal oUpdateClaimReserve As BaseUpdateClaimReservesOrPaymentsRequestType,
                        ByVal oSAMErrorCollection As SAMErrorCollection)

        If oUpdateClaimReserve IsNot Nothing Then

            Dim dt As New DataTable

            ' get the existing claim perils present on the claim
            Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_CLM_Get_Claim_Peril_id")

                    cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oUpdateClaimReserve.ClaimKey

                    con.ExecuteDataTable(cmd, dt)

                End Using

            End Using

            ' if there are claim peril records in the database
            If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

                ' add a new column to hold allocated status
                dt.Columns.Add(New DataColumn("allocated", System.Type.GetType("System.Boolean")))

                Dim oClaimPeril As BaseClaimPerilType
                ' for each claim peril in the request
                For Each oClaimPeril In oUpdateClaimReserve.ClaimPeril

                    ' assume peril is invalid
                    Dim bPerilValid As Boolean = False

                    Dim dr As DataRow

                    ' for each claim peril that exists on the claim
                    For Each dr In dt.Rows
                        Dim DTReserve As New DataTable
                        ' confirm that the peril id corresponds to a valid clam peril id on the claim
                        If UCase(Trim(oClaimPeril.TypeCode)) = UCase(Trim(Cast.ToString(dr.Item("code"), ""))) _
                            AndAlso Not Cast.ToBoolean(dr.Item("allocated"), False) Then

                            ' allocate the actual claim peril id for use later in the process
                            'oClaimPeril.ClaimPerilId = Cast.ToInt32(dr.Item("claim_peril_id"), 0)

                            ' the claim peril exists and is valid
                            bPerilValid = True

                            ' stop this record being used again by another claim peril
                            dr.Item("allocated") = True

                            oClaimPeril.ClaimPerilId = Cast.ToInt32(dr.Item("claim_peril_id"), 0)
                            If oClaimPeril.Reserve IsNot Nothing Then
                                ' get the existing claim perils present on the claim
                                Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
                                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("Spu_CLM_Get_Reserve_On_Peril_id")
                                        cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = Cast.ToInt32(dr.Item("claim_peril_id"), 0)
                                        con.ExecuteDataTable(cmd, DTReserve)
                                    End Using
                                End Using

                                Dim IsColumnExists As Boolean = False
                                For Each DC As DataColumn In DTReserve.Columns
                                    If DC.ColumnName = "allocated" Then
                                        IsColumnExists = True
                                        Exit For
                                    End If
                                Next
                                If IsColumnExists = False Then
                                    DTReserve.Columns.Add(New DataColumn("allocated", System.Type.GetType("System.Boolean")))
                                End If
                                Dim drReserve As DataRow

                                Dim oReserve As BaseClaimPerilReserveType
                                For Each oReserve In oClaimPeril.Reserve
                                    ' for each claim peril that exists on the claim
                                    For Each drReserve In DTReserve.Rows

                                        ' confirm that the peril id corresponds to a valid clam peril id on the claim
                                        If UCase(Trim(oReserve.TypeCode)) = UCase(Trim(Cast.ToString(drReserve.Item("name"), ""))) Then
                                            ' stop this record being used again by another claim peril
                                            drReserve.Item("allocated") = True
                                            Exit For
                                        End If

                                    Next

                                    If Not Cast.ToBoolean(drReserve.Item("allocated"), False) Then
                                        ' If Reserve is inavalid then this situation will come and raise the validation error
                                        oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure,
                                                                            SAMInvalidData.GeneralFailure.ToString,
                                                                            "ReserveTypeCode",
                                                                            oReserve.TypeCode)
                                    End If

                                Next
                                Exit For
                            End If
                        End If

                    Next

                    ' if the base claim peril key id specified on the claim peril was not found
                    If Not bPerilValid Then

                        ' add an error to the collection
                        oSAMErrorCollection.AddInvalidData(SAMInvalidData.GeneralFailure,
                                                            SAMInvalidData.GeneralFailure.ToString,
                                                            "ClaimPerilCode",
                                                            oClaimPeril.TypeCode)
                    End If

                Next
            End If
        End If

    End Sub
    Private Sub ProcessUpdateClaimPayments(ByVal con As SiriusConnection,
                                               ByVal oBusiness As CoreBusiness,
                                               ByVal oRequest As BaseUpdateClaimReservesOrPaymentsRequestType,
                                               ByVal oResponse As BaseUpdateClaimReservesOrPaymentsResponseType,
                                               ByRef oSAMErrorCollection As SAMErrorCollection, Optional bSkipUpdateReserve As Boolean = False)

        Dim sOptionValue As String = String.Empty
        'Create GetProductRiskOptions request
        Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType

        GetVersionId(oRequest.ClaimPayment.BaseClaimPerilKey,
                               oRequest.ClaimPayment.VersionId,
                               con)

        Dim oClaimDetails As New BaseAdditionalClaimRelatedDetails
        'Get the product id
        Dim dsProductId As DataSet = Nothing
        Dim iProductId As Integer
        'Getting the product id from insurance file count 
        GetInsFileCntProductId(con:=con,
                                lInsuranceFileCnt:=oRequest.ClaimPayment.InsuranceFileCNT,
                                dsProductId:=dsProductId,
                                lBaseClaimID:=oRequest.ClaimPayment.BaseClaimKey)
        If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
        AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso dsProductId.Tables(0).Rows(0).Item("product_id") IsNot Nothing AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
            iProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
        Else
            'Failed to get the product id from the given base claim key
            oSAMErrorCollection.AddInvalidData(
                                    SAMConstants.SAMInvalidData.GeneralFailure,
                                    "Failed to get product details for the given policy")

            oSAMErrorCollection.CheckForErrors()
        End If
        Dim SourceId As Integer

        If (Not String.IsNullOrEmpty(oRequest.BranchCode)) Then
            SourceId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        End If
        If oRequest.ClaimPayment.CashList IsNot Nothing Then
            oRequest.ClaimPayment.CashList.SourceID = SourceId
        End If

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsAdvancedTaxScriptEnabled

        sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If
        If oRequest.ClaimPayment.CashList IsNot Nothing Then
            If oRequest.ClaimPayment.CashList.CurrencyKey = 0 Then
                oRequest.ClaimPayment.CashList.CurrencyKey = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup,
                    PMLookupTable.Currency, oRequest.ClaimPayment.CashList.CurrencyCode, "CurrencyCode", oSAMErrorCollection)
            End If
        End If
        oRequest.ClaimPayment.AdvanceScript = sOptionValue

        ' validate the data provided in the request structure
        UpdatePaymentValidateData(con, oBusiness, oRequest.ClaimPayment, oSAMErrorCollection, oClaimDetails, oRequest.BranchCode, oRequest.SourceId)

        'validate the request structure against the specified business rules
        PayClaimValidateBusinessRules(con, oRequest.ClaimPayment, oClaimDetails, oSAMErrorCollection)

        'if there were any business rule errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        ' Retrieve the system options, Id's from codes
        oRequest.ClaimPayment.CurrencyId = oBusiness.GetListItemFromCode _
        (Core.STSListType.PMLookup, PMLookupTable.Currency, oRequest.ClaimPayment.CurrencyCode)

        ' Retrieve the system options, Id's from codes
        ' Retrieve the system options, Id's from codes
        If oRequest.ClaimPayment.Payee IsNot Nothing Then
            If String.IsNullOrEmpty(oRequest.ClaimPayment.Payee.MediaTypeCode) = False Then
                oRequest.ClaimPayment.Payee.MediaTypeId = oBusiness.GetListItemFromCode _
                (Core.STSListType.PMLookup, PMLookupTable.MediaType, oRequest.ClaimPayment.Payee.MediaTypeCode)
            End If
        End If

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsGrossClaimPaymentAmount

        sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If

        oRequest.ClaimPayment.ClaimPaymentIsGross = sOptionValue
        Dim claimsReservesAreGross As Boolean = False
        If Not String.IsNullOrEmpty(sOptionValue) AndAlso sOptionValue.Trim = "1" Then
            claimsReservesAreGross = True
        End If
        Dim PaymentCannotExceedReserve As Boolean = False
        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.PaymentCannotExceedReserve
        sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
        If Not String.IsNullOrEmpty(sOptionValue) AndAlso sOptionValue.Trim = "1" Then
            PaymentCannotExceedReserve = True
        End If
        
        ' Retrieve the value for '--Allow Negative Reserve--' from System Options
        'Previously, Allow Negative Reserve was a system option. 
        'Now it has been moved to ProductRiskMaintenance options.
        'Changing the code accordingly.
        'oBusiness.GetSystemOption _
        '(oRequest.BranchCode, SystemOption.AllowNegativeReserve, oRequest.ClaimPayment.AllowNegativeReserve)
        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.AllowNegativeReserve

        sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(sOptionValue) Then
            sOptionValue = "0"
        End If

        oRequest.ClaimPayment.AllowNegativeReserve = sOptionValue
        oRequest.ClaimPayment.ClaimNumber = oClaimDetails.Claim.ClaimNumber

        Try
            ' check timestamp and lock
            'oBusiness.CheckSAMTSAndLock(con, oRequest.BranchCode, _
            '    CoreBusiness.LockName.ClaimId, _
            '    oRequest.ClaimKey, _
            '    oRequest.TimeStamp)
            Dim sTransactionType As String

            sTransactionType = TransactionTypeCode.PayClaim

            UpdateClaimPaymentDetails(con,
                                            oBusiness,
                                            oRequest, oRequest.ClaimPayment, oSAMErrorCollection, bSkipUpdateReserve, bClaimsReservesAreGross:= claimsReservesAreGross,bPaymentCannotExceedReserve:=PaymentCannotExceedReserve)

            'oBusiness.UnlockAndGetSAMTS( _
            '        con, _
            '        oRequest.BranchCode, _
            '        CoreBusiness.LockName.ClaimId, _
            '        oRequest.ClaimKey, _
            '         oResponse.TimeStamp)

        Catch ex As Exception

            Throw
        End Try

