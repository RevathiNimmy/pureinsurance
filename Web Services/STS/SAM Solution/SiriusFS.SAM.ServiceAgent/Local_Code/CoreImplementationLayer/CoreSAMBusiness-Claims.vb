        Public ReadOnly Property Payment() As Decimal
            Get
                Return _PaymentToDate + _ThisPayment
            End Get
        End Property

        Public ReadOnly Property Reserve() As Decimal
            Get
                Return ReserveToDate + ThisReserve
            End Get
        End Property

        Public ReadOnly Property TotalThisPayment() As Decimal
            Get
                Dim lCount As Integer
                Dim cPaymentValue As Decimal

                ' If we have a treaty array add up our values
                If IsArray(RILines) Then

                    Dim lLBound As Integer = RILines.GetLowerBound(0)
                    Dim lUBound As Integer = RILines.GetUpperBound(0)

                    For lCount = lLBound To lUBound
                        cPaymentValue += _RILines(lCount).ThisPayment
                    Next

                End If

                Return cPaymentValue
            End Get
        End Property

        Public ReadOnly Property TotalThisReserve() As Decimal
            Get
                Dim lCount As Integer
                Dim cReserveValue As Decimal

                ' If we have a treaty array add up our values
                If IsArray(RILines) Then

                    Dim lLBound As Integer = RILines.GetLowerBound(0)
                    Dim lUBound As Integer = RILines.GetUpperBound(0)

                    For lCount = lLBound To lUBound
                        cReserveValue = cReserveValue + _RILines(lCount).ThisReserve
                    Next
                End If

                ' Return total
                Return cReserveValue

            End Get
        End Property

        Public Function Round() As Integer

            Const kTolerance As Double = 0.01

            Dim crDiff As Decimal
            'Dim lReturn As Integer

            ' If we have no treaty array we have nothing to do!
            If Not IsArray(RILines) Then
                ' do nothing
            Else

                ' Initialise rows
                Dim lRounding As Integer = 0
                Dim llBound As Integer = RILines.GetLowerBound(0)
                Dim lUBound As Integer = RILines.GetUpperBound(0)
                Dim lCount As Integer

                ' Find best lines for allocating rounding amounts
                For lCount = llBound To lUBound
                    Select Case RILines(lCount).Type
                        Case "R"
                            ' First ret row is ideal, set rounding row and exit loop
                            lRounding = lCount
                            Exit For
                        Case "T"
                            ' Keep track of first treaty in case no ret row is found
                            If lRounding < lCount Then
                                lRounding = lCount
                            End If
                    End Select
                Next lCount

                ' Check for tiny allocation discrepencies and sneak it into our rounding line
                crDiff = ThisReserve - TotalThisReserve

                Dim dDiff As Double = crDiff

                If Math.Abs(dDiff) < kTolerance Then
                    RILines(lRounding).ThisReserve = RILines(lRounding).ThisReserve + crDiff
                End If

                ' Check payment rounding
                crDiff = ThisPayment - TotalThisPayment
                If Math.Abs(dDiff) < kTolerance Then
                    RILines(lRounding).ThisPayment = RILines(lRounding).ThisPayment + crDiff
                End If

            End If

        End Function
    End Class

