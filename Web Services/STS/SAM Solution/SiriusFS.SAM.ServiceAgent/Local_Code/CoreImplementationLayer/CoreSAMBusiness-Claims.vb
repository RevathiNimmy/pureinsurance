    Private Sub GetClaimReceiptSystemOptions(ByVal oRequest As BaseClaimReceiptRequestType,
        ByVal oBusiness As CoreBusiness)
        Dim sResult As String = String.Empty

        Dim oSAMErrorCollection As New SAMErrorCollection

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            'Get the product id
            Dim dsProductId As DataSet = Nothing
            Dim iProductId As Integer
            'Getting the product id from insurance file count since GetProductRiskOptions method expects it
            GetInsFileCntProductId(con:=con,
                                    lInsuranceFileCnt:=0,
                                    dsProductId:=dsProductId,
                                    lBaseClaimID:=oRequest.ClaimReceipt.BaseClaimKey)
            If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
            AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso dsProductId.Tables(0).Rows(0).Item("product_id") IsNot Nothing AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
                iProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
            Else
                'Failed to get the product id from the given base claim key
                oSAMErrorCollection.AddInvalidData(
                                        SAMConstants.SAMInvalidData.GeneralFailure,
                                        "Failed to get product details for the given policy")

                oSAMErrorCollection.CheckForErrors()
            End If

            'Create GetProductRiskOptions request
            Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType
            oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsAdvancedTaxScriptEnabled

            sResult = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)

            If String.IsNullOrEmpty(sResult) Then
                sResult = "0"
            End If

        End Using

        If sResult = "1" Then
                oRequest.ClaimReceipt.IsAdvancedTaxSystemOptionOn = True
            Else
                oRequest.ClaimReceipt.IsAdvancedTaxSystemOptionOn = False
            End If

        End Sub

        ''' <summary>
        ''' Performs all necessary validation of the structure / data in the request
        ''' and ensures that the request passes any existing business rules / warnings
        ''' </summary>
        ''' <param name="con"></param>
        ''' <param name="oRequest"></param>
        ''' <param name="oBusiness"></param>
        ''' <param name="oSAMErrorCollection"></param>
        ''' <param name="ClaimDetails"></param>
        ''' <remarks></remarks>
    Private Sub ValidateClaimReceiptRequest(ByVal con As SiriusConnection,
    ByVal oRequest As BaseClaimReceiptRequestType,
    ByVal oBusiness As CoreBusiness,
        ByVal oSAMErrorCollection As SAMErrorCollection)

            '*********************
            ' STRUCTURE VALIDATION 
            '*********************

            ' validate the mandatory structure data
            oRequest.Validate(CType(oSAMErrorCollection, Object))

            ' if there were any errors throw an exception
            oSAMErrorCollection.CheckForErrors()

            '*********************
            ' DATA VALIDATION 
            '*********************

            ' validate the data provided in the structure
            ClaimReceiptValidateData(con, oBusiness, oRequest, oSAMErrorCollection)

            ' if there were any data errors in the structure throw an exception
            oSAMErrorCollection.CheckForErrors()

            ' get the details for the last version of the specified claim so we can perform further validation
            ' of the request
        GetClaimDetailsForPaymentOrReceipt(con,
                oRequest.ClaimReceipt.ClaimId,
                oRequest.ClaimReceipt.ClaimPerilId,
                    oRequest.ClaimReceipt.AdditionalDetails)

        GetCurrencyToCurrencyExchangeRate(con, oRequest.ClaimReceipt.TransactionDate, oRequest.ClaimReceipt.CurrencyId, oRequest.ClaimReceipt.AdditionalDetails.Claim.LossCurrencyKey, oRequest.SourceId, oRequest.ClaimReceipt.ReceiptToLossXRate)

            ' validate payment party type details
            FurtherClaimReceiptDataValidation(oRequest, oBusiness, oSAMErrorCollection)

            '*********************
            ' BUSINESS RULE VALIDATION 
            '*********************

            ' validate the request structure against the specified business rules
            ClaimReceiptValidateBusinessRules(oBusiness, oRequest, oSAMErrorCollection, con)

            ' if there were any business rule errors throw an exception
            oSAMErrorCollection.CheckForErrors()

            '*********************
            ' BUSINESS WARNINGS
            '*********************

            ' TODO : MEvans : 08-02-2007 : Add Code for IsDeferred Reinsurance Warning

        End Sub

