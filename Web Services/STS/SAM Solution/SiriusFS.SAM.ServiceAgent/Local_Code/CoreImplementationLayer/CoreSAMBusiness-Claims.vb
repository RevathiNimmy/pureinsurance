    Private Sub GetContactDetails(ByVal con As SiriusConnection,
                                  ByVal oBusiness As CoreBusiness,
                                  ByVal oClaim As BaseClaimType,
                                  ByVal Contacts() As BaseContactType,
                                  ByVal IsInsurer As Boolean,
                                  Optional ByVal bNewClaimProcess As Boolean = False)

        If bNewClaimProcess Then
            Dim dsClaimContacts As DataSet = Nothing
            GetContactDetailsFromClaimtable(con, oClaim.ClaimId, IsInsurer, dsClaimContacts)

            If dsClaimContacts IsNot Nothing Then
                If dsClaimContacts.Tables.Count > 0 Then
                    If dsClaimContacts.Tables(0).Rows.Count > 0 Then
                        With dsClaimContacts.Tables(0).Rows(0)
                            If IsInsurer Then
                                oClaim.InsurerEmail = Convert.ToString(.Item("insurer_email"))
                                oClaim.InsurerFaxNo = Convert.ToString(.Item("insurer_fax_no"))
                                oClaim.InsurerTelNo = Convert.ToString(.Item("insurer_tel_no"))
                                oClaim.InsurerContact = Convert.ToString(.Item("Insurer_Contact"))
                            Else
                                oClaim.ClientEmail = Convert.ToString(.Item("Client_email"))
                                oClaim.ClientFaxNo = Convert.ToString(.Item("Client_fax_no"))
                                oClaim.ClientTelNo = Convert.ToString(.Item("Client_tel_no"))
                                oClaim.ClientTelNoOff = Convert.ToString(.Item("Client_tel_no_off"))
                                oClaim.ClientMobileNo = Convert.ToString(.Item("Client_mobile_no"))
                            End If
                        End With
                    End If
                End If
            End If

        Else

            'Dim oContacts As BaseContactType

            ' if the user has specified contacts in the request
            If IsArray(Contacts) Then

                Dim oContact As BaseContactType

                ' for each contact in the array
                For Each oContact In Contacts

                    ' override the default policy contact type with that specified in the user request
                    Select Case oContact.ContactTypeCode
                        Case BaseImplementationTypes.ContactTypeType.EMAIL
                            If IsInsurer Then
                                oClaim.InsurerEmail = oContact.ContactDetail.Item
                            Else
                                oClaim.ClientEmail = oContact.ContactDetail.Item
                            End If
                        Case BaseImplementationTypes.ContactTypeType.FAX
                            If IsInsurer Then
                                oClaim.InsurerFaxNo = oContact.ContactDetail.Item
                            Else
                                oClaim.ClientFaxNo = oContact.ContactDetail.Item
                            End If
                        Case BaseImplementationTypes.ContactTypeType.HOMEPHONE
                            If IsInsurer Then
                                oClaim.InsurerTelNo = oContact.ContactDetail.Item
                            Else
                                oClaim.ClientTelNo = oContact.ContactDetail.Item
                            End If
                        Case BaseImplementationTypes.ContactTypeType.MAIN
                            If IsInsurer Then
                                oClaim.InsurerTelNo = oContact.ContactDetail.Item
                            Else
                                oClaim.ClientTelNoOff = oContact.ContactDetail.Item
                            End If
                        Case BaseImplementationTypes.ContactTypeType.MOBILE
                            If IsInsurer Then
                                oClaim.InsurerMobileNo = oContact.ContactDetail.Item
                            Else
                                oClaim.ClientMobileNo = oContact.ContactDetail.Item
                            End If
                        Case BaseImplementationTypes.ContactTypeType.WEB
                            If IsInsurer Then
                                oClaim.InsurerWebNo = oContact.ContactDetail.Item
                            Else
                                oClaim.ClientWebNo = oContact.ContactDetail.Item
                            End If
                        Case BaseImplementationTypes.ContactTypeType.OTHER
                            If IsInsurer Then
                                oClaim.InsurerOtherContacts = oContact.ContactDetail.Item
                            Else
                                oClaim.ClientOtherContacts = oContact.ContactDetail.Item
                            End If
                    End Select
                Next

            End If
        End If
    End Sub

    ''' <summary>
    ''' get default contact details for the specified parties from the database
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <remarks></remarks>
    Private Sub GetDefaultContactDetails(ByVal con As SiriusConnection,
                                        ByVal oBusiness As CoreBusiness,
                                        ByVal OpenClaimRequest As BaseClaimOpenRequestType,
                                        ByVal IsInsurer As Boolean)

        Dim oAddress As BaseAddressType = New BaseImplementationTypes.BaseAddressType

        Dim sMain As String = String.Empty
        Dim sEmail As String = String.Empty
        Dim sFax As String = String.Empty
        Dim sMobile As String = String.Empty
        Dim sTelephone As String = String.Empty
        Dim sOther As String = String.Empty

        ' get the claim risks status 
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Default_Contact_Details")

            cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = OpenClaimRequest.Claim.InsuranceFileKey

            cmd.AddInParameter("@isInsurer", SqlDbType.Int).Value = BooleanDataConvert.ToInt32(IsInsurer)

            Dim ds As DataSet = Nothing

            ds = con.ExecuteDataSet(cmd, "ContactDetails")

            If ds.Tables("ContactDetails").Rows.Count > 0 Then

                Dim dr As DataRow

                For Each dr In ds.Tables("ContactDetails").Rows

                    Dim sContactTypeCode As String = Cast.ToStringTrim(dr.Item("code"))
                    Dim sAreaCode As String = Cast.ToStringTrim(dr.Item("area_code"))
                    Dim sNumber As String = Cast.ToStringTrim(dr.Item("number"))
                    Dim sExtension As String = Cast.ToStringTrim(dr.Item("extension"))

                    If Not String.IsNullOrEmpty(sAreaCode) Then
                        sAreaCode = sAreaCode.Trim
                    Else
                        sAreaCode = String.Empty
                    End If

                    If Not String.IsNullOrEmpty(sNumber) Then
                        sNumber = sNumber.Trim
                    Else
                        sNumber = String.Empty
                    End If

                    If Not String.IsNullOrEmpty(sExtension) Then
                        sExtension = sExtension.Trim
                    Else
                        sExtension = String.Empty
                    End If

                    Dim sContact As String = String.Empty

                    Select Case sContactTypeCode
                        Case ContactType.Main
                            sMain = IIf(sExtension.Length > 0, sNumber & " Ext " & sExtension, sNumber).ToString()
                        Case ContactType.Email
                            sEmail = sNumber
                        Case ContactType.Fax
                            sFax = IIf(sExtension.Length > 0, sNumber & " Ext " & sExtension, sNumber).ToString()
                        Case ContactType.Mobile
                            sMobile = IIf(sExtension.Length > 0, sNumber & " Ext " & sExtension, sNumber).ToString()
                        Case ContactType.Telephone
                            sTelephone = IIf(sExtension.Length > 0, sNumber & " Ext " & sExtension, sNumber).ToString()
                        Case ContactType.Letter
                            ' do nothing
                        Case ContactType.Web
                            ' do nothing
                        Case Else
                            sOther = IIf(sExtension.Length > 0, sNumber & " Ext " & sExtension, sNumber).ToString()
                    End Select

                Next

            End If

        End Using

        ' if any details are not passed then use the defaults 
        ' otherwise retain the details passed in the request
        If IsInsurer Then
            If String.IsNullOrEmpty(OpenClaimRequest.Claim.InsurerTelNo) Then
                OpenClaimRequest.Claim.InsurerTelNo = sMain
            End If

            If String.IsNullOrEmpty(OpenClaimRequest.Claim.InsurerEmail) Then
                OpenClaimRequest.Claim.InsurerEmail = sEmail
            End If

            If String.IsNullOrEmpty(OpenClaimRequest.Claim.InsurerFaxNo) Then
                OpenClaimRequest.Claim.InsurerFaxNo = sFax
            End If
            If Not OpenClaimRequest.Claim.ClientOtherContacts Is Nothing Then
                If String.IsNullOrEmpty(OpenClaimRequest.Claim.ClientOtherContacts) Then
                    OpenClaimRequest.Claim.ClientOtherContacts = sOther
                End If
            End If
        Else
            If String.IsNullOrEmpty(OpenClaimRequest.Claim.ClientTelNoOff) Then
                OpenClaimRequest.Claim.ClientTelNoOff = sMain
            End If
            If String.IsNullOrEmpty(OpenClaimRequest.Claim.ClientEmail) Then
                OpenClaimRequest.Claim.ClientEmail = sEmail
            End If
            If String.IsNullOrEmpty(OpenClaimRequest.Claim.ClientFaxNo) Then
                OpenClaimRequest.Claim.ClientFaxNo = sFax
            End If
            If String.IsNullOrEmpty(OpenClaimRequest.Claim.ClientMobileNo) Then
                OpenClaimRequest.Claim.ClientMobileNo = sMobile
            End If
            If String.IsNullOrEmpty(OpenClaimRequest.Claim.ClientTelNo) Then
                OpenClaimRequest.Claim.ClientTelNo = sTelephone
            End If
            If Not OpenClaimRequest.Claim.InsurerOtherContacts Is Nothing Then
                If String.IsNullOrEmpty(OpenClaimRequest.Claim.InsurerOtherContacts) Then
                    OpenClaimRequest.Claim.InsurerOtherContacts = sOther
                End If
            End If
        End If

    End Sub

    ''' <summary>
    ''' populates the clients address if it hasnt already beeen specified
    ''' </summary>
    ''' <param name="OpenClaimRequest"></param>
    ''' <remarks></remarks>
    Private Sub GetClientAddressDetails(ByVal con As SiriusConnection,
                                        ByVal oBusiness As CoreBusiness,
                                        ByVal OpenClaimRequest As BaseClaimOpenRequestType)

        Dim oAddress As BaseAddressType = New BaseImplementationTypes.BaseAddressType

        ' returns the claim client address and contacts
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_client_details_U")

            cmd.AddInParameter("@pol_id", SqlDbType.Int).Value = OpenClaimRequest.Claim.InsuranceFileKey
            cmd.AddInParameter("@clm_dt", SqlDbType.DateTime).Value = OpenClaimRequest.Claim.LossFromDate

            Dim ds As DataSet = Nothing

            ds = con.ExecuteDataSet(cmd, "ClientDetails")

            If ds.Tables.Count > 0 AndAlso ds.Tables("ClientDetails").Rows.Count > 0 Then

                Dim dr As DataRow = ds.Tables("ClientDetails").Rows(0)

                Const kName As Integer = 0
                Const kShortName As Integer = 1
                Const kAddress1Col As Integer = 2
                Const kAddress2Col As Integer = 3
                Const kAddress3Col As Integer = 4
                Const kAddress4Col As Integer = 5
                Const kPostCode As Integer = 6
                Const kCountryId As Integer = 13
                Const kAddressUsageTypeIdCol As Integer = 15

                For Each dr In ds.Tables("ClientDetails").Rows

                    If Not IsDBNull(dr.Item(kAddressUsageTypeIdCol)) Then

                        If oBusiness.GetListItemFromID(
                                        Core.STSListType.PMLookup,
                                            PMLookupTable.AddressUsageType,
                                                CType(dr.Item(kAddressUsageTypeIdCol), Integer)) =
                                InternalSAMConstants.kAddressUsageTypeCodeCorrespondanceAddress Then

                            '0 - p.resolved_name,  
                            '1 - p.shortname,  
                            '2 - a.address1,  
                            '3 - a.address2,  
                            '4 - a.address3,  
                            '5 - a.address4,  
                            '6 - a.postal_code,  
                            '7 - c.area_code,  
                            '8 - c.number,  
                            '9 - c.extension,  
                            '10 - ct.contact_type_id,  
                            '11 - ct.code,  
                            '12 - p.party_cnt,  
                            '13 - a.country_id,  
                            '14 - aut.description,  
                            '15 - aut.address_usage_type_id,  
                            '16 - a.address_cnt()

                            oAddress.AddressLine1 = dr.Item(kAddress1Col).ToString
                            oAddress.AddressLine2 = dr.Item(kAddress2Col).ToString
                            oAddress.AddressLine3 = dr.Item(kAddress3Col).ToString
                            oAddress.AddressLine4 = dr.Item(kAddress4Col).ToString
                            oAddress.PostCode = dr.Item(kPostCode).ToString
                            oAddress.CountryId = Cast.ToInt32(dr.Item(kCountryId), 0)
                            oAddress.CountryCode = oBusiness.GetListItemFromID(Core.STSListType.PMLookup, PMLookupTable.Country, Integer.Parse(dr.Item(kCountryId).ToString))

                            OpenClaimRequest.Claim.ClientName = Cast.ToString(dr.Item(kName))
                            OpenClaimRequest.Claim.ClientShortName = Cast.ToString(dr.Item(kShortName))

                            Exit For

                        End If

                    End If

                Next
            End If

            ' only use the default address details if 
            ' the address details were not specified in the request
            If OpenClaimRequest.Claim.Client Is Nothing Then

                Dim oClient As New BaseImplementationTypes.BaseClaimPartyClientType

                OpenClaimRequest.Claim.Client = oClient

                ' add the address to the client 
                OpenClaimRequest.Claim.Client.Address = oAddress

                ' always default to correspondence address
                OpenClaimRequest.Claim.Client.Address.AddressTypeCode = AddressTypeType.Correspondence

            End If

        End Using

    End Sub

    ''' <summary>
    ''' populates the insurers address if it hasnt already beeen specified
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <remarks></remarks>
    Private Sub GetInsurerAddressDetails(
                        ByVal con As SiriusConnection,
                        ByVal oBusiness As CoreBusiness,
                        ByVal OpenClaimRequest As BaseClaimOpenRequestType)

        Dim oAddress As BaseAddressType = New BaseImplementationTypes.BaseAddressType

        ' get the claim risks status 
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_insurer_details")

            cmd.AddInParameter("@pol_id", SqlDbType.Int).Value = OpenClaimRequest.Claim.InsuranceFileKey
            cmd.AddInParameter("@TransactionMode", SqlDbType.Int).Value = 1

            Dim ds As DataSet = Nothing

            ' execute the stored procedure
            ds = con.ExecuteDataSet(cmd, "InsurerDetails")

            ' if there are any results
            If ds.Tables.Count <> 0 AndAlso ds.Tables("InsurerDetails").Rows.Count > 0 Then

                Dim dr As DataRow

                For Each dr In ds.Tables("InsurerDetails").Rows

                    If oBusiness.GetListItemFromID(
                                    Core.STSListType.PMLookup,
                                        PMLookupTable.AddressUsageType,
                                            CType(dr.Item("address_usage_type_id"), Integer)) =
                                        InternalSAMConstants.kAddressUsageTypeCodeCorrespondanceAddress Then

                        oAddress.AddressLine1 = dr.Item("address1").ToString
                        oAddress.AddressLine2 = dr.Item("address2").ToString
                        oAddress.AddressLine3 = dr.Item("address3").ToString
                        oAddress.AddressLine4 = dr.Item("address4").ToString
                        oAddress.PostCode = dr.Item("postal_code").ToString

                        OpenClaimRequest.Claim.InsurerName = dr.Item("name").ToString
                        OpenClaimRequest.Claim.InsurerShortName = dr.Item("shortname").ToString
                        oAddress.CountryId = Cast.ToInt32(dr.Item("country_id"), 0)
                        oAddress.CountryCode = oBusiness.GetListItemFromID(Core.STSListType.PMLookup, PMLookupTable.Country, Integer.Parse(dr.Item("country_id").ToString))
                        oAddress.CountryId = Integer.Parse(dr.Item("country_id").ToString)
                        Exit For

                    End If
                Next

                ' only use the default details if the insurers address 
                ' was not passed in the request
                If OpenClaimRequest.Claim.Insurer Is Nothing Then

                    Dim oInsurer As New BaseImplementationTypes.BaseClaimPartyInsurerType

                    OpenClaimRequest.Claim.Insurer = oInsurer

                    ' add the address to the client 
                    OpenClaimRequest.Claim.Insurer.Address = oAddress

                    ' always default to correspondence address
                    OpenClaimRequest.Claim.Insurer.Address.AddressTypeCode = AddressTypeType.Correspondence

                End If

            End If
        End Using

    End Sub

    Private Sub GetClaimAddress(ByVal con As SiriusConnection,
    ByVal ClaimAddressId As Integer,
    ByRef oAddress As BaseAddressType)

        Dim dt As DataTable = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Claim_Address_sel")
            cmd.AddInParameter("@address_cnt", SqlDbType.Int).Value = ClaimAddressId
            dt = con.ExecuteDataTable(cmd)
        End Using

        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then

            ' there should only ever be a single row returned
            Dim dr As DataRow = dt.Rows(0)

            If oAddress Is Nothing Then
                oAddress = New BaseAddressType
            End If

            oAddress.AddressLine1 = Cast.ToStringTrim(dr.Item("address1"), String.Empty)
            oAddress.AddressLine2 = Cast.ToStringTrim(dr.Item("address2"), String.Empty)
            oAddress.AddressLine3 = Cast.ToStringTrim(dr.Item("address3"), String.Empty)
            oAddress.AddressLine4 = Cast.ToStringTrim(dr.Item("address4"), String.Empty)
            oAddress.AddressTypeCode = AddressTypeType.Correspondence
            oAddress.CountryCode = Cast.ToStringTrim(dr.Item("country_code"), String.Empty)
            oAddress.CountryId = Cast.ToInt32(dr.Item("country_id"), 0)
            oAddress.PostCode = Cast.ToStringTrim(dr.Item("postal_code"), String.Empty)

        End If

    End Sub

    Private Sub BusinessWarningValidateRiskStatus(
    ByVal lRiskId As Integer,
    ByVal oResponse As BaseClaimResponseType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        ' 6.3.2.1 Risk Status 
        ' If the RiskStatus of the selected risk is Deferred Reinsurance 
        ' then a warning should be produced indicating that the selected policy is on deferred reinsurance.

        ' get the claim risks status 
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_risk_status_sel")

                cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = lRiskId

                Dim ds As DataSet = Nothing

                ds = con.ExecuteDataSet(cmd, "RiskStatus")

                If (ds.Tables("RiskStatus").Rows(0).Item(1).ToString) = InternalSAMConstants.ksRiskStatusReInsuranceDeferred Then
                    AddWarning(oResponse,
                            SAMBusinessWarnings.RiskIsDeferred,
                                SAMBusinessWarnings.RiskIsDeferred.ToString)
                End If

            End Using
        End Using

    End Sub

    Private Sub BusinessWarningValidateClaimPolicyDates(
    ByVal v_lInsuranceFileId As Integer,
    ByVal oRequest As BaseClaimType,
    ByVal oResponse As BaseClaimResponseType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        ' 6.3.2.2	Claim  / Policy Problems - Warnings
        ' There are a number of scenarios that require a warning to be produced with regard to the claim and the specified policy.
        ' These are as follow:
        ' i.	The selected policy is void.
        ' ii.	The loss date is prior to  the policies start date.
        ' iii.	The loss date is after the policies end date.
        ' iv. the policy returned is not the one we selected.

        ' get the claim policy information
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_Get_Policy_For_Claim_Date")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = v_lInsuranceFileId

                Dim ds As DataSet = Nothing
                Dim dr As DataRow
                Dim dtPolicyStartDate As Date
                Dim dtPolicyExpiryDate As Date
                Dim dtEarliestPolicyStartDate As Date
                Dim dtLatestPolicyExpiryDate As Date
                Dim bFoundSelectedPolicy As Boolean
                Dim bFoundClaimDateInVoidPolicyBounds As Boolean
                Dim bFoundClaimDateInSelectedPolicyBounds As Boolean
                Dim bFoundClaimDateInDifferentPolicyBounds As Boolean
                'Dim iInsuranceFileCnt As Integer
                'Dim lValidInsuranceFileCnt As Integer
                Dim sPolicyNumber As String = String.Empty
                Dim iPolicyRowNumber As Integer
                ds = con.ExecuteDataSet(cmd, "PolicyDetails")

                ' if rows were returned
                If (ds.Tables("PolicyDetails").Rows.Count > 0) Then

                    Dim iRow As Integer = 0
                    ' for each row
                    For Each dr In ds.Tables("PolicyDetails").Rows

                        Dim dtStartDate As Date = CType(dr.Item("cover_start_date"), Date)
                        Dim dtExpiryDate As Date = CType(dr.Item("expiry_date"), Date)
                        Dim sLapsedReasonCode As String = dr.Item("code").ToString
                        If Not String.IsNullOrEmpty(sLapsedReasonCode) Then
                            sLapsedReasonCode = sLapsedReasonCode.Trim
                        End If

                        Dim lInsuranceFileCnt As Integer = CType(dr.Item("insurance_file_cnt"), Integer)

                        ' if this is the policy we selected then 
                        If lInsuranceFileCnt = v_lInsuranceFileId Then
                            ' get the policies start and expiry dates
                            dtPolicyStartDate = dtStartDate
                            dtPolicyExpiryDate = dtExpiryDate
                            bFoundSelectedPolicy = True
                        End If

                        ' if the claim falls between this version of the policies start and end date
                        If IsDate(oRequest.LossFromDate) AndAlso IsDate(dtStartDate) AndAlso IsDate(dtExpiryDate) Then
                            If (CType(oRequest.LossFromDate.ToShortDateString, Date) >= CType(dtStartDate.ToShortDateString, Date)) _
                                And (CType(oRequest.LossFromDate.ToShortDateString, Date) <= CType(dtExpiryDate.ToShortDateString, Date)) Then

                                If sLapsedReasonCode <> InternalSAMConstants.ksLapsedReasonVoided Then
                                If lInsuranceFileCnt <> v_lInsuranceFileId Then
                                    bFoundClaimDateInDifferentPolicyBounds = True
                                    iPolicyRowNumber = iRow
                                Else
                                    bFoundClaimDateInSelectedPolicyBounds = True
                                End If
                            Else
                                bFoundClaimDateInVoidPolicyBounds = True
                            End If

                        End If

                        End If

                        ' default the initial values
                        If iRow = 0 Then
                            dtEarliestPolicyStartDate = dtStartDate
                            dtLatestPolicyExpiryDate = dtExpiryDate
                        End If

                        ' get the earliest policy start date 
                        If dtEarliestPolicyStartDate >= dtStartDate Then
                            dtEarliestPolicyStartDate = dtStartDate
                        End If

                        ' get the latest policy expiry date
                        If dtLatestPolicyExpiryDate <= dtExpiryDate Then
                            dtLatestPolicyExpiryDate = dtExpiryDate
                        End If

                        iRow += 1

                    Next

                    If Not bFoundSelectedPolicy Then
                        dr = ds.Tables("PolicyDetails").Rows(0)
                        dtPolicyStartDate = CType(dr.Item("cover_start_date"), Date)
                        dtPolicyExpiryDate = CType(dr.Item("expiry_date"), Date)
                    End If

                    If Not bFoundClaimDateInSelectedPolicyBounds Then

                        ' a valid policy could not be found 
                        If (oRequest.LossFromDate > dtLatestPolicyExpiryDate) Then

                            ' the claim date is after the latest expiry date
                            AddWarning(oResponse,
                                SAMBusinessWarnings.LossFromDateAfterPolicyEndDate,
                                    SAMBusinessWarnings.LossFromDateAfterPolicyEndDate.ToString &
                                    " : LossFromDate" & oRequest.LossFromDate.ToShortDateString & " > " &
                                        "PolicyExpiryDate:" & dtLatestPolicyExpiryDate.ToShortDateString)

                        ElseIf (oRequest.LossFromDate < dtEarliestPolicyStartDate) Then

                            ' the claim date is before the earliest start date
                            AddWarning(oResponse,
                                SAMBusinessWarnings.LossFromDateBeforePolicyStartDate,
                                    SAMBusinessWarnings.LossFromDateBeforePolicyStartDate.ToString &
                                        " : LossFromDate:" & oRequest.LossFromDate.ToShortDateString & " < " &
                                            "PolicyStartDate:" & dtEarliestPolicyStartDate.ToShortDateString)

                        ElseIf bFoundClaimDateInVoidPolicyBounds Then

                            ' a policy was found but it has been voided
                            AddWarning(oResponse,
                                SAMBusinessWarnings.PolicyIsVoid,
                                    SAMBusinessWarnings.PolicyIsVoid.ToString)

                        ElseIf bFoundClaimDateInDifferentPolicyBounds Then

                            ' a policy was found but it wasnt the policy that we selected
                            'AddWarning(oResponse, _
                            '    SAMBusinessWarnings.PolicyIsDifferent, _
                            '        SAMBusinessWarnings.PolicyIsDifferent.ToString)
                            dr = ds.Tables("PolicyDetails").Rows(iPolicyRowNumber)
                            dtPolicyStartDate = CType(dr.Item("cover_start_date"), Date)
                            dtPolicyExpiryDate = CType(dr.Item("expiry_date"), Date)

                        End If

                    End If

                Else

                    ' add an errror - no policy data was found
                    oSAMErrorCollection.AddBusinessRule(
                            SAMBusinessErrors.PolicyDataMissing,
                                SAMBusinessErrors.PolicyDataMissing.ToString)

                    ' raise the error
                    oSAMErrorCollection.CheckForErrors()

                End If

            End Using
        End Using

    End Sub

    Private Sub BusinessWarningsValidateInfoOnly(
    ByVal oClaim As BaseClaimType,
    ByVal oClaimPerils As BaseClaimPerilType(),
    ByVal oResponse As BaseClaimResponseType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        ' 6.3.2.3	Info Only Claims
        ' If Info Only was specified as being true then only claim details 
        ' should have been provided, if any other detail were provided, claim peril, 
        ' reserve, recovery or claimsbuilder a warning should be returned indicating that 
        ' only the claim data will be saved, and additional items will not be saved.
        If oClaim.InfoOnly = True Then

            ' if claim peril data was specified
            If oClaimPerils IsNot Nothing Then
                ' add a warning indicating that this data will be truncated
                AddWarning(oResponse,
                        SAMBusinessWarnings.InfoOnlyClaimDataTruncated,
                            SAMBusinessWarnings.InfoOnlyClaimDataTruncated.ToString)
            End If

        End If

    End Sub

