        If oGetProductClaimsWorkflowOptionsRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetProductClaimsWorkflowOptionsRequestType) Then
            nTypeofPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetProductClaimsWorkflowOptionsResponseType
        Else
            nTypeofPackage = enumTypeOfPackage.UnknownPackage
            Return oResponse
        End If

        ' Check Mandatory Field
        oGetProductClaimsWorkflowOptionsRequest.Validate(CObj(oErrors))
        oErrors.CheckForErrors()

        ' Look up validation
        With oGetProductClaimsWorkflowOptionsRequest
            .SourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, .BranchCode, "BranchCode", oErrors)
