    ''' <summary>
    '''This function is used to close the claim.
    '''</summary>
    '''<param name="con" type="SiriusConnection"></param>   
    '''<param name="lClaimId" type="Integer"></param>   
    '''<param name="CloseClaimOnZeroReserveRecoveryBalance" type="Boolean"></param>   
    '''<remarks></remarks>  

    Private Function GetClaimStatusOnCheckReserveRecovery(
                    ByVal con As SiriusConnection,
                    ByVal lClaimId As Integer,
                    ByVal CloseClaimOnZeroReserveRecoveryBalance As Boolean) As String
        Const kClaimStatusId As Integer = 0
        Const kCurrentReserve As Integer = 1
        Const kCurrentRecovery As Integer = 2
        Const kClaimStatusDescription As Integer = 3
        Dim lClaimStatus As Integer
        Dim crCurrentReserve As Decimal
        Dim crCurrentRecovery As Decimal
        Dim sClaimStatus As String
        Dim dt As New DataTable

        sClaimStatus = ""
        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_GetCurrentReserveRecovery_SFU")
            cmd.AddInParameter("@ClaimID", SqlDbType.Int).Value = lClaimId
            con.ExecuteDataTable(cmd, dt)
        End Using

        Dim dr As DataRow
        For Each dr In dt.Rows
            lClaimStatus = Cast.ToInt32(dr.Item(kClaimStatusId), 0)
            crCurrentReserve = Cast.ToDecimal(dr.Item(kCurrentReserve), 0)
            crCurrentRecovery = Cast.ToDecimal(dr.Item(kCurrentRecovery), 0)
            sClaimStatus = Cast.ToString(dr.Item(kClaimStatusDescription), "")
            If lClaimStatus <> 3 _
                And crCurrentReserve <= 0 _
                And crCurrentRecovery <= 0 _
                And CloseClaimOnZeroReserveRecoveryBalance Then

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Close_Now")
                    cmd.AddInParameter("@Claim_ID", SqlDbType.Int).Value = lClaimId
                    con.ExecuteNonQuery(cmd)
                End Using
                sClaimStatus = "CLOSED"

            Else
                'Make change in spu_SAM_CLM_Reopen_Now to check if need to open or Reopen
                If lClaimStatus <> 3 AndAlso lClaimStatus <> 5 Then
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Reopen_Now")
                        cmd.AddInParameter("@Claim_ID", SqlDbType.Int).Value = lClaimId
                        con.ExecuteNonQuery(cmd)
                    End Using
                    sClaimStatus = "REOPENED"
                Else
                    'Make change in spu_SAM_CLM_Close_Now to check if need to Close or ReClose
                    Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Close_Now")
                        cmd.AddInParameter("@Claim_ID", SqlDbType.Int).Value = lClaimId
                        con.ExecuteNonQuery(cmd)
                    End Using
                    sClaimStatus = "RECLOSED"
            End If

            End If
        Next
        GetClaimStatusOnCheckReserveRecovery = sClaimStatus
    End Function

