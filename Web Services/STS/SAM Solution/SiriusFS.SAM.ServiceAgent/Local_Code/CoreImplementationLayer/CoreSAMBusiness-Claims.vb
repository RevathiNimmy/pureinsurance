    Private Overloads Function GetIsWithholdingTax(
    ByVal con As SiriusConnection,
    ByVal PaymentPartyType As ClaimPaymentPartyTypeType,
    ByVal PartyKey As Integer,
    ByVal AdvancedTaxSpecified As Boolean,
    ByVal AdvancedTaxPayeeDomiciled As Boolean,
    ByVal AdvancedTaxPayeeTaxNumber As String,
    ByVal AdvancedTaxPayeeTaxPercentage As Decimal) As Integer

        Return GetIsWithholdingTax(con:=con, PaymentPartyType:=PaymentPartyType, PartyKey:=PartyKey,
                                   AdvancedTaxSpecified:=AdvancedTaxSpecified, AdvancedTaxPayeeDomiciled:=AdvancedTaxPayeeDomiciled,
                                   AdvancedTaxPayeeTaxNumber:=AdvancedTaxPayeeTaxNumber, AdvancedTaxPayeeTaxPercentage:=AdvancedTaxPayeeTaxPercentage,
                                   iSelectedWithHoldingTaxValue:=-99)
    End Function


    Private Overloads Function GetIsWithholdingTax(
                                    ByVal con As SiriusConnection,
                                    ByVal PaymentPartyType As ClaimPaymentPartyTypeType,
                                    ByVal PartyKey As Integer,
                                    ByVal AdvancedTaxSpecified As Boolean,
                                    ByVal AdvancedTaxPayeeDomiciled As Boolean,
                                    ByVal AdvancedTaxPayeeTaxNumber As String,
                                    ByVal AdvancedTaxPayeeTaxPercentage As Decimal,
                                    ByVal iSelectedWithHoldingTaxValue As Integer) As Integer



        Dim DomiciledForTax As Boolean
        Dim TaxNumber As String = String.Empty
        Dim TaxPercentage As Decimal

        ' if this isnt a payment to clmpayable
        If PaymentPartyType <> ClaimPaymentPartyTypeType.CLMPAYABLE Then

            'Dim AccountId As Integer
            'Dim AccountCurrencyId As Integer

            ' get the default tax details for the specified party
            GetClaimPaymentPartyTaxDetails(con, PartyKey, 0, 0, DomiciledForTax, TaxNumber, TaxPercentage)

        Else

            DomiciledForTax = False
            TaxNumber = ""
            TaxPercentage = 0

        End If

        ' override the defaults with the details provided in the request
        If AdvancedTaxSpecified Then
            DomiciledForTax = AdvancedTaxPayeeDomiciled
            TaxNumber = AdvancedTaxPayeeTaxNumber
            TaxPercentage = AdvancedTaxPayeeTaxPercentage
        End If

        Dim IsWithholdingTax As Integer

        ' use payee domiciled override indicator
        If DomiciledForTax Then
            If TaxPercentage <= 0 AndAlso AdvancedTaxSpecified Then
                IsWithholdingTax = WithholdingTaxSwitch.IsOff
            Else
                If iSelectedWithHoldingTaxValue = -99 Then
                    IsWithholdingTax = WithholdingTaxSwitch.IsOn
                Else
                    If iSelectedWithHoldingTaxValue = 0 Then
                        IsWithholdingTax = WithholdingTaxSwitch.IsOff
                    Else
            IsWithholdingTax = WithholdingTaxSwitch.IsOn
                    End If
                End If
            End If
        Else
            IsWithholdingTax = WithholdingTaxSwitch.IsOff
        End If

        Return IsWithholdingTax

    End Function

    Public Function GetClaimPaymentTaxGroups(
      ByVal oRequest As BaseGetClaimPaymentTaxGroupsRequestType) As _
      BaseImplementationTypes.BaseGetClaimPaymentTaxGroupsResponseType

        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oBusiness As New CoreBusiness
        Dim oResponse As BaseGetClaimPaymentTaxGroupsResponseType = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage

        ' determine the type of package and thus the type of response
        If oRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetClaimPaymentTaxGroupsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GetClaimPaymentTaxGroupsResponseType
        ElseIf oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimPaymentTaxGroupsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimPaymentTaxGroupsResponseType
        End If

        '*********************
        ' STRUCTURE VALIDATION 
        '*********************

        ' validate the mandatory structure data (empty strings etc)
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        ' if there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        '*********************
        ' DATA VALIDATION 
        '*********************
        GetClaimPaymentTaxGroupsValidateData(oBusiness, oRequest, oSAMErrorCollection)

        ' if there were any data errors in the structure throw an exception
        oSAMErrorCollection.CheckForErrors()

        ' ********************
        ' PROCESS 
        ' ********************

        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

            Dim AdvancedTaxSpecified As Boolean = False
            Dim PayeeDomiciled As Boolean = False
            Dim PayeeTaxNumber As String = String.Empty
            Dim PayeeTaxPercentage As Decimal = 0

            If oRequest.AdvancedTax IsNot Nothing Then
                AdvancedTaxSpecified = True
                PayeeDomiciled = oRequest.AdvancedTax.PayeeDomiciled
                PayeeTaxNumber = oRequest.AdvancedTax.PayeeTaxNumber
                PayeeTaxPercentage = oRequest.AdvancedTax.PayeePercentage
            End If

            Dim IsWithholdingTax As Integer = GetIsWithholdingTax(con, oRequest.PaymentPartyType,
                oRequest.PartyKey, AdvancedTaxSpecified,
                PayeeDomiciled, PayeeTaxNumber, PayeeTaxPercentage)

            Dim dsTaxGroup As New DataSet
            Dim xmlDoc As New System.Xml.XmlDocument

            ' get the relevant tax groups ( either those with withholding tax set on / or those with withholding tax set off)
            dsTaxGroup = GetTaxGroupDetails(con, IsWithholdingTax, TransactionTypeCode.PayClaim, Nothing)
            If oRequest.WCFSecurityToken = "" Then
                xmlDoc.LoadXml(dsTaxGroup.GetXml)
                oResponse.TaxGroup = xmlDoc.DocumentElement
            End If

            oResponse.ResultData = dsTaxGroup
        End Using

        Return oResponse

    End Function

    Public Function GetClaimReceiptTaxGroups(
              ByVal oRequest As BaseGetClaimReceiptTaxGroupsRequestType) As _
              BaseImplementationTypes.BaseGetClaimReceiptTaxGroupsResponseType

        Dim oSAMErrorCollection As SAMErrorCollection = New SAMErrorCollection
        Dim oBusiness As New CoreBusiness
        Dim oResponse As BaseGetClaimReceiptTaxGroupsResponseType = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage

        ' determine the type of package and thus the type of response
        If oRequest.GetType Is GetType(SAMForInsuranceImplementationTypes.GetClaimReceiptTaxGroupsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsurancePackage
            oResponse = New SAMForInsuranceImplementationTypes.GetClaimReceiptTaxGroupsResponseType
        ElseIf oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxGroupsRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxGroupsResponseType
        End If

        '*********************
        ' STRUCTURE VALIDATION 
        '*********************

        ' validate the mandatory structure data (empty strings etc)
        oRequest.Validate(CType(oSAMErrorCollection, Object))

        ' if there were any errors throw an exception
        oSAMErrorCollection.CheckForErrors()

        '*********************
        ' DATA VALIDATION 
        '*********************
        GetClaimReceiptTaxGroupsValidateData(oBusiness, oRequest, oSAMErrorCollection)

        ' if there were any data errors in the structure throw an exception
        oSAMErrorCollection.CheckForErrors()

        ' ********************
        ' PROCESS 
        ' ********************
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

            ' default transaction type to third party recovery 
            Dim sTransactionType As String = TransactionTypeCode.ThirdPartyRecovery

            ' determine if the user has specified this should be salvage recovery instead
            If Not String.IsNullOrEmpty(oRequest.TypeCode) AndAlso oRequest.TypeCode.Trim = TransactionTypeCode.SalvageRecovery Then
                sTransactionType = TransactionTypeCode.SalvageRecovery
            End If
            ' get the relevant tax groups ( either those with withholding tax set on / or those with withholding tax set off)
            Dim dsTaxGroup As New DataSet
            Dim xmlDoc As New System.Xml.XmlDocument

            dsTaxGroup = GetTaxGroupDetails(con, Nothing, sTransactionType, Nothing)
            If oRequest.WCFSecurityToken = "" Then
                xmlDoc.LoadXml(dsTaxGroup.GetXml)
                oResponse.TaxGroup = xmlDoc.DocumentElement
            End If

            oResponse.ResultData = dsTaxGroup
            Return oResponse
        End Using

    End Function

    Private Function GetTaxGroupDetails(ByVal con As SiriusConnection, ByVal IsWithholdingTax As Nullable(Of Integer), ByVal TransactionTypeCode As String, ByRef dt As DataTable) As DataSet

        Dim ds As DataSet = Nothing

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SIR_Get_Tax_Group_Details")

            cmd.AddInParameter("@is_withholding_tax", SqlDbType.Int).Value = IsWithholdingTax
            cmd.AddInParameter("@transaction_type_code", SqlDbType.VarChar, 20).Value = TransactionTypeCode

            ds = con.ExecuteDataSet(cmd, "Row")

            ds.Tables("Row").Columns("is_withholding_tax").ColumnName = "IsWithholdingTax"
            ds.Tables("Row").Columns("code").ColumnName = "Code"
            ds.Tables("Row").Columns("description").ColumnName = "Description"

            ' set which type the xml will be serialising to 
            ds.DataSetName = "BaseGetClaimPaymentTaxGroupsResponseTypeTaxGroup"

            If ds IsNot Nothing AndAlso ds.Tables.Count > 0 Then
                dt = ds.Tables("Row")
            End If

            'xmlDoc.LoadXml(ds.GetXml)

        End Using

        Return ds

    End Function

