    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="PayClaimRequest"></param>
    ''' <remarks></remarks>
    Private Sub SaveClaimPayment(ByVal Con As SiriusConnection,
                                    ByVal oClaimPayment As BaseClaimPaymentType)

        'Dim oSAMErrorCollection As SAMErrorCollection

        'Const kPayeeOptClaimPayable As Integer = 1

        'Dim oPaymentItem As BaseClaimPaymentItemType

        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Claim_Payment_Add")

            cmd.AddOutParameter("@claim_payment_id", SqlDbType.Int)
            cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oClaimPayment.ClaimId
            cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oClaimPayment.ClaimPerilId
            cmd.AddInParameter("@date_of_payment", SqlDbType.DateTime, 10).Value = IIF(Cast.NullIfDefault(oClaimPayment.TransactionDate, DateTime.MinValue) Is Nothing, DateTime.now, Cast.NullIfDefault(oClaimPayment.TransactionDate, DateTime.MinValue))
            cmd.AddInParameter("@amount", SqlDbType.Money).Value = oClaimPayment.TotCurrAmount
            cmd.AddInParameter("@tax_amount", SqlDbType.Money).Value = oClaimPayment.TotTaxAmount
            cmd.AddInParameter("@tax_amount_wht", SqlDbType.Money).Value = oClaimPayment.TotTaxWHTAmount
            cmd.AddInParameter("@party_cnt", SqlDbType.Int).Value = Cast.NullIfDefault(oClaimPayment.PartyKey, 0)
            cmd.AddInParameter("@comments", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(oClaimPayment.Comments, String.Empty)
            cmd.AddInParameter("@is_referred", SqlDbType.TinyInt).Value = oClaimPayment.IsReferred
            cmd.AddInParameter("@created_by", SqlDbType.Int).Value = _SiriusUser.UserID
            cmd.AddInParameter("@sequenceno", SqlDbType.Int).Value = Cast.NullIfDefault(oClaimPayment.SequenceNo, 0) 'vbNull
            cmd.AddInParameter("@treaty_id", SqlDbType.Int).Value = Cast.NullIfDefault(oClaimPayment.TreatyId, 0)
            cmd.AddInParameter("@claim_payment_to_id", SqlDbType.Int).Value = Nothing
            If oClaimPayment.OurRef IsNot Nothing Then
                cmd.AddInParameter("@our_ref", SqlDbType.VarChar).Value = Convert.ToString(oClaimPayment.OurRef)
            End If
            If Not String.IsNullOrEmpty(oClaimPayment.UltimatePayee) Then
                cmd.AddInParameter("@ultimate_payee", SqlDbType.VarChar, 255).Value = Convert.ToString(oClaimPayment.UltimatePayee)
            End If
            cmd.AddInParameter("@is_ex_gratia", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(oClaimPayment.IsExGratia)
            ' save the correct payment party to value
            Dim lPaymentPartyTo As Integer = 0

            If Not oClaimPayment.PaymentToReinsurer Then

                Select Case oClaimPayment.PaymentPartyType
                    Case ClaimPaymentPartyTypeType.AGENT
                        lPaymentPartyTo = PaymentPartyTo.Agent
                    Case ClaimPaymentPartyTypeType.CLIENT
                        lPaymentPartyTo = PaymentPartyTo.Client
                    Case ClaimPaymentPartyTypeType.CLMPAYABLE
                        lPaymentPartyTo = PaymentPartyTo.CLMPayable
                    Case ClaimPaymentPartyTypeType.PARTY
                        lPaymentPartyTo = PaymentPartyTo.Party
                End Select

            End If
            cmd.AddInParameter("@payment_party_to", SqlDbType.TinyInt).Value = Cast.NullIfDefault(lPaymentPartyTo, 0)
            cmd.AddInParameter("@document_id", SqlDbType.Int).Value = Cast.NullIfDefault(oClaimPayment.DocumentId, 0)
            cmd.AddInParameter("@currency_id", SqlDbType.SmallInt).Value = oClaimPayment.CurrencyId
            cmd.AddInParameter("@excess_amount", SqlDbType.Money).Value = oClaimPayment.TotExcessAmount

            ' advanced tax
            If oClaimPayment.AdvancedTaxDetails IsNot Nothing Then
                cmd.AddInParameter("@insured_domiciled", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(oClaimPayment.AdvancedTaxDetails.InsuredDomiciled)
                cmd.AddInParameter("@insured_percentage", SqlDbType.Float).Value = CDbl(oClaimPayment.AdvancedTaxDetails.InsuredPercentage)
                cmd.AddInParameter("@insured_tax_number", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(oClaimPayment.AdvancedTaxDetails.InsuranceTaxNumber, String.Empty)
                cmd.AddInParameter("@payee_domiciled", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(oClaimPayment.AdvancedTaxDetails.PayeeDomiciled)
                cmd.AddInParameter("@payee_percentage", SqlDbType.Float).Value = CDbl(oClaimPayment.AdvancedTaxDetails.PayeePercentage)
                cmd.AddInParameter("@payee_tax_number", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(oClaimPayment.AdvancedTaxDetails.PayeeTaxNumber, String.Empty)
                cmd.AddInParameter("@safe_harbour_id", SqlDbType.Int).Value = Cast.NullIfDefault(oClaimPayment.AdvancedTaxDetails.SafeHarbourID, 0)
                cmd.AddInParameter("@safe_harbour_percentage", SqlDbType.Float).Value = CDbl(oClaimPayment.AdvancedTaxDetails.SafeHarbourPercentage)
                cmd.AddInParameter("@is_tax_exempt", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(oClaimPayment.AdvancedTaxDetails.IsTaxExempt)
                cmd.AddInParameter("@is_wht_exempt", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(oClaimPayment.AdvancedTaxDetails.IsWHTExempt)
                cmd.AddInParameter("@is_settlement", SqlDbType.TinyInt).Value = BooleanDataConvert.ToByte(oClaimPayment.AdvancedTaxDetails.IsSettlement)

            Else
                cmd.AddInParameter("@insured_domiciled", SqlDbType.TinyInt).Value = Nothing
                cmd.AddInParameter("@insured_percentage", SqlDbType.Float).Value = Nothing
                cmd.AddInParameter("@insured_tax_number", SqlDbType.VarChar, 50).Value = Nothing
                cmd.AddInParameter("@payee_domiciled", SqlDbType.TinyInt).Value = Nothing
                cmd.AddInParameter("@payee_percentage", SqlDbType.Float).Value = Nothing
                cmd.AddInParameter("@payee_tax_number", SqlDbType.VarChar, 50).Value = Nothing
                cmd.AddInParameter("@safe_harbour_id", SqlDbType.Int).Value = Nothing
                cmd.AddInParameter("@safe_harbour_percentage", SqlDbType.Float).Value = Nothing
                cmd.AddInParameter("@is_tax_exempt", SqlDbType.TinyInt).Value = Nothing
                cmd.AddInParameter("@is_wht_exempt", SqlDbType.TinyInt).Value = Nothing
                cmd.AddInParameter("@is_settlement", SqlDbType.TinyInt).Value = Nothing
            End If

            ' payee
            If oClaimPayment.Payee IsNot Nothing Then
                cmd.AddInParameter("@media_ref", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(oClaimPayment.Payee.MediaReference, String.Empty)
                cmd.AddInParameter("@ThirdPartyReference", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(oClaimPayment.Payee.TheirReference, String.Empty)
                cmd.AddInParameter("@payeemediatype", SqlDbType.Int).Value = Cast.NullIfDefault(oClaimPayment.Payee.MediaTypeId, 0)
                cmd.AddInParameter("@payeename", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(oClaimPayment.Payee.Name, String.Empty)
                cmd.AddInParameter("@payeebankname", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(oClaimPayment.Payee.BankName, String.Empty)
                cmd.AddInParameter("@payeesortcode", SqlDbType.VarChar, 8).Value = Cast.NullIfDefault(oClaimPayment.Payee.BankCode, String.Empty)
                cmd.AddInParameter("@payeeaccountno", SqlDbType.VarChar, 30).Value = Cast.NullIfDefault(oClaimPayment.Payee.BankNumber, String.Empty)
                cmd.AddInParameter("@payeecomments", SqlDbType.VarChar, 255).Value = Cast.NullIfDefault(oClaimPayment.Payee.Comments, String.Empty)
                cmd.AddInParameter("@Party_Bank_Id", SqlDbType.Int).Value = Cast.NullIfDefault(oClaimPayment.Payee.PartyBankKey, 0)
                cmd.AddInParameter("@sBusinessIdentifierCode", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(oClaimPayment.Payee.BIC, String.Empty)
                cmd.AddInParameter("@sInternationalBankAccountNumber", SqlDbType.VarChar, 50).Value = Cast.NullIfDefault(oClaimPayment.Payee.IBAN, String.Empty)
                If oClaimPayment.Payee.Chequedate <> Date.MinValue Then
                    cmd.AddInParameter("@Cheque_Date", SqlDbType.DateTime).Value = Cast.NullIfDefault(oClaimPayment.Payee.Chequedate, Date.MinValue)
                Else
                    cmd.AddInParameter("@Cheque_Date", SqlDbType.DateTime).Value = Date.Now
                End If
                ' payee address
                If oClaimPayment.Payee.Address IsNot Nothing Then
                    cmd.AddInParameter("@PayeeAddress1", SqlDbType.VarChar, 60).Value = Cast.NullIfDefault(oClaimPayment.Payee.Address.AddressLine1, String.Empty)
                    cmd.AddInParameter("@PayeeAddress2", SqlDbType.VarChar, 60).Value = Cast.NullIfDefault(oClaimPayment.Payee.Address.AddressLine2, String.Empty)
                    cmd.AddInParameter("@PayeeAddress3", SqlDbType.VarChar, 60).Value = Cast.NullIfDefault(oClaimPayment.Payee.Address.AddressLine3, String.Empty)
                    cmd.AddInParameter("@PayeeAddress4", SqlDbType.VarChar, 60).Value = Cast.NullIfDefault(oClaimPayment.Payee.Address.AddressLine4, String.Empty)
                    cmd.AddInParameter("@PayeePostalCode", SqlDbType.VarChar, 20).Value = Cast.NullIfDefault(oClaimPayment.Payee.Address.PostCode, String.Empty)
                    cmd.AddInParameter("@payeecountry", SqlDbType.Int).Value = Cast.NullIfDefault(oClaimPayment.Payee.Address.CountryId, 0)
                Else
                    cmd.AddInParameter("@PayeeAddress1", SqlDbType.VarChar, 60).Value = Nothing
                    cmd.AddInParameter("@PayeeAddress2", SqlDbType.VarChar, 60).Value = Nothing
                    cmd.AddInParameter("@PayeeAddress3", SqlDbType.VarChar, 60).Value = Nothing
                    cmd.AddInParameter("@PayeeAddress4", SqlDbType.VarChar, 60).Value = Nothing
                    cmd.AddInParameter("@PayeePostalCode", SqlDbType.VarChar, 20).Value = Nothing
                    cmd.AddInParameter("@payeecountry", SqlDbType.Int).Value = Nothing
                End If
            Else
                cmd.AddInParameter("@media_ref", SqlDbType.VarChar, 30).Value = Nothing
                cmd.AddInParameter("@ThirdPartyReference", SqlDbType.VarChar, 30).Value = Nothing
                cmd.AddInParameter("@payeemediatype", SqlDbType.Int).Value = Nothing
                cmd.AddInParameter("@payeename", SqlDbType.VarChar, 255).Value = Nothing
                cmd.AddInParameter("@payeebankname", SqlDbType.VarChar, 255).Value = Nothing
                cmd.AddInParameter("@payeesortcode", SqlDbType.VarChar, 8).Value = Nothing
                cmd.AddInParameter("@payeeaccountno", SqlDbType.VarChar, 30).Value = Nothing
                cmd.AddInParameter("@payeecomments", SqlDbType.VarChar, 255).Value = Nothing
                cmd.AddInParameter("@PayeeAddress1", SqlDbType.VarChar, 60).Value = Nothing
                cmd.AddInParameter("@PayeeAddress2", SqlDbType.VarChar, 60).Value = Nothing
                cmd.AddInParameter("@PayeeAddress3", SqlDbType.VarChar, 60).Value = Nothing
                cmd.AddInParameter("@PayeeAddress4", SqlDbType.VarChar, 60).Value = Nothing
                cmd.AddInParameter("@PayeePostalCode", SqlDbType.VarChar, 20).Value = Nothing
                cmd.AddInParameter("@payeecountry", SqlDbType.Int).Value = Nothing
            End If

            Con.ExecuteNonQuery(cmd)

            ' return id..
            oClaimPayment.PaymentId = Cast.ToInt32(cmd.Parameters("@claim_payment_id").Value, 0)

        End Using
    End Sub

