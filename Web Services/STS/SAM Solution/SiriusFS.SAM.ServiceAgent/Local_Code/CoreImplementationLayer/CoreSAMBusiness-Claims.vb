    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oRequest"></param>
    ''' <param name="sRequestFrom"></param>
    ''' <remarks></remarks>
    Private Sub SaveClaimPaymentItems(ByVal con As SiriusConnection,
                                    ByVal oClaimPayment As BaseClaimPaymentType,
                                    ByVal sRequestFrom As String,
                                    ByVal bIsDataTransferClaim As Boolean,
                                    ByVal bDataTransferIsUsingFullClaimVersioning As Boolean,
                                    Optional ByVal lProcessType As Integer = 1,
                                    Optional ByVal bSkipUpdateReserve As Boolean = False,
                                    Optional ByVal oClaimPaymentTaxes As BaseImplementationTypes.BaseGetClaimPaymentTaxesResponseType = Nothing,
                                    Optional bClaimsReservesAreGross As Boolean = False,
                                    Optional bPaymentCannotExceedReserve As Boolean = False)

        'Dim r_lClaimPaymentItemId As Integer
        Dim oBusiness As New CoreBusiness

        Dim oGetProductRiskOptionValueRequest As New BaseProductRiskOptionValueRequestType

        oGetProductRiskOptionValueRequest.ProducRiskOption = ProductRiskOptions.IsAdvancedTaxScriptEnabled
        Dim dsProductId As DataSet = Nothing
        Dim iProductId As Integer
        Dim sOption As String = String.Empty
        'Get the product id from insurance file count 
        GetInsFileCntProductId(con:=con,
                                lInsuranceFileCnt:=0,
                                dsProductId:=dsProductId,
                                lBaseClaimID:=oClaimPayment.ClaimId)
        If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
          AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
            iProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
            sOption = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionValueRequest)
        End If

        For Each oPaymentItem As BaseClaimPaymentItemType In oClaimPayment.ClaimPaymentItem

            If sOption = "1" Then
                oPaymentItem.CurrencyAmount = oPaymentItem.PaymentAmount
            End If

                ' save the claim payment item
                SaveClaimPaymentItem(con, oClaimPayment, oPaymentItem)

                If sRequestFrom = "CLMPayable" Then

                    If Not oPaymentItem.TaxGroupCode = Nothing AndAlso oPaymentItem.IsExcess = False Then
                    If oClaimPayment.AdvanceScript <> "1" Then
                        SaveTaxCalculations(con,
                                            oClaimPayment,
                                            Cast.ToInt32(oClaimPayment.PaymentId, 0),
                                            oPaymentItem.ClaimPaymentItemId,
                                            oPaymentItem,
                                            oClaimPaymentTaxes)
                    Else
                        SaveAdvancedTaxCalculations(con,
                                                    oClaimPayment,
                                                oPaymentItem)

                    End If
                End If

                ' update the associated reserve with the payment details

                UpdateReserve(con, oClaimPayment, oPaymentItem, bIsDataTransferClaim, bDataTransferIsUsingFullClaimVersioning, False, lProcessType, bSkipUpdateReserve, bClaimsReservesAreGross:=bClaimsReservesAreGross,bPaymentCannotExceedReserve:=bPaymentCannotExceedReserve)
            ElseIf oPaymentItem.RevisionAmount <> 0 Then
                ' update the associated reserve with the payment details
                UpdateReserve(con, oClaimPayment, oPaymentItem, bIsDataTransferClaim, bDataTransferIsUsingFullClaimVersioning, False, lProcessType, bClaimsReservesAreGross:=bClaimsReservesAreGross,bPaymentCannotExceedReserve:=bPaymentCannotExceedReserve)

            End If




        Next

    End Sub


    'ByRef oClaimPaymentTax() As BaseClaimPaymentTaxItemType, _
    Private Sub SaveTaxCalculations(
                                        ByVal Con As SiriusConnection,
                                        ByVal oClaimPayment As BaseClaimPaymentType,
                                        ByVal v_lClaimPaymentId As Integer,
                                        ByVal v_lClaimPaymentItemId As Integer,
                                        ByVal oPaymentItem As BaseClaimPaymentItemType,
                                        Optional ByVal oClaimPaymentTaxes As BaseImplementationTypes.BaseGetClaimPaymentTaxesResponseType = Nothing)

        'Const kPayeeOptClaimPayable As Integer = 1

        Dim dsTaxBandDet As DataSet = Nothing
        Dim crCurrencyAmount As Decimal
        Dim crTaxLossAmount As Decimal
        Dim crTaxBaseAmount As Decimal

        Dim oGetProductRiskOptionValueRequest As New BaseProductRiskOptionValueRequestType

        oGetProductRiskOptionValueRequest.ProducRiskOption = ProductRiskOptions.IsAdvancedTaxScriptEnabled

        Dim dsProductId As DataSet = Nothing
        Dim iProductId As Integer
        Dim sOption As String = String.Empty
        'Get the product id from insurance file count 
        GetInsFileCntProductId(con:=Con,
                                lInsuranceFileCnt:=0,
                                dsProductId:=dsProductId,
                                lBaseClaimID:=oClaimPayment.ClaimId)
        If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
          AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
            iProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
            sOption = GetProductRiskOptions(Con, iProductId, oGetProductRiskOptionValueRequest)
        End If


        If sOption = "1" AndAlso oClaimPaymentTaxes.TaxItems IsNot Nothing Then

            Dim r_lTaxCalculationCnt As Integer
            Dim TaxReserveKey As Integer
            Dim PaymentItemReserveKey As Integer

            If oPaymentItem.IsTaxOverridden Then
                For taxBandsCNT As Integer = 0 To dsTaxBandDet.Tables(0).Rows.Count - 1
                    dsTaxBandDet.Tables(0).Rows(taxBandsCNT).Item("percentage") = 0
                    dsTaxBandDet.Tables(0).Rows(taxBandsCNT).Item("value") = 0
                    dsTaxBandDet.Tables(0).Rows(taxBandsCNT).Item("is_value") = 1
                Next
                'Now Put all the tax on first Band
                dsTaxBandDet.Tables(0).Rows(0).Item("value") = oPaymentItem.OverriddedTaxAmount
            End If

            For taxBandsCNT As Integer = 0 To oClaimPaymentTaxes.TaxItems.Length - 1

                If oClaimPaymentTaxes.TaxItems(taxBandsCNT) IsNot Nothing Then

                    TaxReserveKey = ToSafeInteger(GetAndValidateDescriptionById(Con, "reserve_type", "Reserve_type_id", "name", oClaimPaymentTaxes.TaxItems(taxBandsCNT).ReserveType.ToString))
                    PaymentItemReserveKey = ToSafeInteger(GetAndValidateDescriptionById(Con, "reserve", "Reserve_type_id", "Reserve_id", oPaymentItem.ReserveId.ToString))

                    If TaxReserveKey = PaymentItemReserveKey Then

                        Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Tax_Calculation_Add")

                            cmd.AddOutParameter("@tax_calculation_cnt", SqlDbType.Int)
                            cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oClaimPayment.ClaimPerilId
                            cmd.AddInParameter("@claim_payment_id", SqlDbType.Int).Value = v_lClaimPaymentId
                            cmd.AddInParameter("@claim_receipt_id", SqlDbType.Int).Value = Nothing
                            cmd.AddInParameter("@claim_payment_item_id", SqlDbType.Int).Value = v_lClaimPaymentItemId
                            cmd.AddInParameter("@claim_receipt_item_id", SqlDbType.Int).Value = Nothing
                            cmd.AddInParameter("@tax_band_id", SqlDbType.Int).Value = Cast.ToInt32(oClaimPaymentTaxes.TaxItems(taxBandsCNT).TaxBandId) ' dsTaxBandDet.Tables(0).Rows(taxBandsCNT).Item("tax_band_id")
                            cmd.AddInParameter("@premium", SqlDbType.Money).Value = oPaymentItem.CurrencyAmount
                            cmd.AddInParameter("@percentage", SqlDbType.Float).Value = Cast.ToDouble(oClaimPaymentTaxes.TaxItems(taxBandsCNT).Percentage, 0)
                            cmd.AddInParameter("@value", SqlDbType.Money).Value = Cast.ToDecimal(oClaimPaymentTaxes.TaxItems(taxBandsCNT).Amount, 0)
                            cmd.AddInParameter("@is_value", SqlDbType.TinyInt).Value = 1
                            cmd.AddInParameter("@currency_id", SqlDbType.Int).Value = oClaimPayment.CurrencyId
                            cmd.AddInParameter("@class_of_business_id", SqlDbType.Int).Value = Cast.NullIfDefault(Convert.ToInt32(oClaimPaymentTaxes.TaxItems(taxBandsCNT).ClassOfBusinessID), 0)
                            cmd.AddInParameter("@tax_group_id", SqlDbType.Int).Value = oPaymentItem.TaxGroupId
                            cmd.AddInParameter("@sequence", SqlDbType.TinyInt).Value = CInt(oClaimPaymentTaxes.TaxItems(taxBandsCNT).Sequence)
                            cmd.AddInParameter("@transtype", SqlDbType.VarChar, 10).Value = kTaxTransTypeClaimPayment
                            cmd.AddInParameter("@is_manually_changed", SqlDbType.TinyInt).Value = CInt(oClaimPaymentTaxes.TaxItems(taxBandsCNT).IsManuallyChanges)

                            Con.ExecuteNonQuery(cmd)

                            ' return id...
                            r_lTaxCalculationCnt = Cast.ToInt32(cmd.Parameters.Item("@tax_calculation_cnt").Value, 0)

                        End Using
                    End If
                End If
            Next

        Else
            ' Call Recalculate function to build the tax ban details and save them to the database
            CalculateTaxAmounts(con:=Con,
                        lCompanyId:=oClaimPayment.SourceId,
                        lTaxGroupId:=Cast.ToInt32(oPaymentItem.TaxGroupId, 0),
                        sTranstype:=kTaxTransTypeClaimPayment,
                        lCurrencyId:=oClaimPayment.CurrencyId,
                        lLossCurrencyId:=oClaimPayment.LossCurrencyId,
                        crAmount:=oPaymentItem.PaymentAmount,
                        crTaxCurrencyAmount:=crCurrencyAmount,
                        crTaxLossAmount:=crTaxLossAmount,
                        crTaxBaseAmount:=crTaxBaseAmount,
                        lClaimPerilId:=oClaimPayment.ClaimPerilId,
                        lClaimPaymentId:=v_lClaimPaymentId,
                        lClaimReceiptId:=1,
                        lClaimPaymentItemId:=v_lClaimPaymentItemId,
                        lClaimReceiptItemId:=0,
                        lCalculateOnly:=1,
                        oTaxBandDetails:=dsTaxBandDet)

            Dim r_lTaxCalculationCnt As Integer
            For taxBandsCNT As Integer = 0 To dsTaxBandDet.Tables(0).Rows.Count - 1

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Tax_Calculation_Add")

                    cmd.AddOutParameter("@tax_calculation_cnt", SqlDbType.Int)
                    cmd.AddInParameter("@claim_peril_id", SqlDbType.Int).Value = oClaimPayment.ClaimPerilId
