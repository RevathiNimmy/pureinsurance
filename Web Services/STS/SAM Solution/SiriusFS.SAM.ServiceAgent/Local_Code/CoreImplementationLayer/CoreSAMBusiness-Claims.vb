    Private Function GetClaimReceiptTaxDetails(
    ByVal con As SiriusConnection,
    ByVal oCoreBusiness As CoreBusiness,
        ByVal Request As BaseClaimReceiptRequestType) As BaseGetClaimReceiptTaxesResponseType

            Dim Response As New BaseGetClaimReceiptTaxesResponseType
        Dim nGetSavedTaxOfPeril As Integer
            ' determine the type of package and thus the type of response
            If Request.GetType Is GetType(SAMForInsuranceImplementationTypes.GetClaimReceiptTaxesRequestType) Then
            Response = New SAMForInsuranceImplementationTypes.GetClaimReceiptTaxesResponseType
        ElseIf Request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxesRequestType) Then
            Response = New SAMForInsuranceV2ImplementationTypes.GetClaimReceiptTaxesResponseType
        End If

        ' setup claim receipt 
        Dim ClaimReceipt As BaseClaimReceiptType = Request.ClaimReceipt
        Dim ClaimDetails As BaseAdditionalClaimRelatedDetails = ClaimReceipt.AdditionalDetails
        Dim sSalvageAndRecoveryReservesExcludeTax As String = String.Empty
        Dim dReceiptAmount As Decimal = 0
        nGetSavedTaxOfPeril = Request.GetSavedTaxOfPeril
        oCoreBusiness.GetSystemOption(Request.BranchCode,
                                      SystemOption.SalvageAndTPRecoveryReservesExcludeTax,
                                      sSalvageAndRecoveryReservesExcludeTax)

        ' for each receipt item in the claim receipt
        For Each ClaimReceiptItem As BaseClaimReceiptItemType In ClaimReceipt.ReceiptItem

            ' if this receipt item has a specified tax group
            If ClaimReceiptItem.TaxGroupId.HasValue Then

                'Dim TaxCurrencyAmount As Decimal
                'Dim TaxLossAmount As Decimal
                'Dim TaxBaseAmount As Decimal
                Dim TaxCalculationItems As DataSet = Nothing

                Dim sTransType As String = String.Empty

                ' determine which tax transaction type to use
                If ClaimReceipt.IsSalvageRecovery Then
                    sTransType = kTaxTransTypeClaimSalvageReceipt
                Else
                    sTransType = kTaxTransTypeClaimThirdPartyRecoveryReceipt
                End If

                ' if the receipt item had a tax group id specified then use it to calculate the system tax
                CalculateTaxAmounts(con:=con,
                                    lCompanyId:=Request.SourceId,
                                    lTaxGroupId:=CInt(ClaimReceiptItem.TaxGroupId),
                                    sTranstype:=sTransType,
                                    lCurrencyId:=ClaimReceipt.CurrencyId,
                                    lLossCurrencyId:=ClaimDetails.Claim.LossCurrencyKey,
                                    crAmount:=ClaimReceiptItem.ReceiptAmount,
                                    crTaxCurrencyAmount:=0,
                                    crTaxLossAmount:=0,
                                    crTaxBaseAmount:=0,
                                    lClaimPerilId:=ClaimReceipt.ClaimPerilId,
                                    lClaimPaymentId:=0,
                                    lClaimReceiptId:=1,
                                    lClaimPaymentItemId:=0,
                                    lClaimReceiptItemId:=1,
                                    lCalculateOnly:=1,
                                    oTaxBandDetails:=TaxCalculationItems,
                                    nGetSavedTaxOfPeril:=nGetSavedTaxOfPeril)

                ' if the system option advanced tax scriping enabled is on
                If ClaimReceipt.IsAdvancedTaxSystemOptionOn AndAlso nGetSavedTaxOfPeril = 0 Then

                    ' determine which script we need to be running

                    ' if the tax group specified on the claim receipt item 
                    ' indicates which advanced tax script to run
                    If Not String.IsNullOrEmpty(ClaimReceiptItem.TaxGroupAdvancedTaxScript) Then

                        ' load the required data to run the advanced tax rule and validate its return values
                        ' are within valid ranges
                        CalculateAdvancedTax(con, ClaimDetails, ClaimReceipt, ClaimReceiptItem, TaxCalculationItems, Request.BranchCode, Response)

                    Else
                        ' No advanced tax script has been specified for the tax group specified on this receipt iten
                        ' do nothing
                        'Handle it same as Without ATS
                        ' store the tax calculation items against the claim receipt
                        StoreTaxCalculationItems(con, oCoreBusiness, ClaimReceiptItem, TaxCalculationItems)

                    End If

                Else

                    ' store the tax calculation items against the claim receipt
                    StoreTaxCalculationItems(con, oCoreBusiness, ClaimReceiptItem, TaxCalculationItems)

                End If

            End If

            Next

            ' Setup Response Object

            ' store the full list of tax calculation items
            Dim ListOfAllTaxCalculationItems As New List(Of BaseTaxCalculationItemType)
            Dim ListOfReceiptItems As New List(Of BaseGetClaimReceiptTaxesResponseTypeReceiptItems)

            ' get the default claim peril recovery details and use them to populate the response object
            GetClaimPerilRecoveryDetails(con, oCoreBusiness, ClaimReceipt, Response)

            ' for each claim receipt item
            For Each ClaimReceiptItem As BaseClaimReceiptItemType In ClaimReceipt.ReceiptItem
            If ClaimReceiptItem.IsTaxOverridden AndAlso nGetSavedTaxOfPeril = 0 AndAlso
               ClaimReceiptItem.TaxCalculationItem IsNot Nothing _
               AndAlso ClaimReceiptItem.TaxCalculationItem.Count > 0 Then

                For Each oTaxCalculationItem As BaseTaxCalculationItemType In ClaimReceiptItem.TaxCalculationItem
                    oTaxCalculationItem.IsManuallyChanged = True
                    oTaxCalculationItem.IsValue = True
                    oTaxCalculationItem.TaxPercentage = 0
                    oTaxCalculationItem.TaxValue = 0
                Next
                ClaimReceiptItem.TaxCalculationItem.Item(0).TaxValue = ClaimReceiptItem.OverriddedTaxAmount
            End If
                ' add the tax calculation items to the overall item
                ListOfAllTaxCalculationItems.AddRange(ClaimReceiptItem.TaxCalculationItem)

                ' claim receipt items
                Dim oBaseGetClaimReceiptItem As New BaseGetClaimReceiptTaxesResponseTypeReceiptItems
                oBaseGetClaimReceiptItem.BaseRecoveryKey = ClaimReceiptItem.BaseRecoveryKey
                oBaseGetClaimReceiptItem.ReceiptAmount = ClaimReceiptItem.ReceiptAmount
                oBaseGetClaimReceiptItem.TaxGroupCode = ClaimReceiptItem.TaxGroupCode
                oBaseGetClaimReceiptItem.TaxAmount = ClaimReceiptItem.TotalTaxAmount

                ListOfReceiptItems.Add(oBaseGetClaimReceiptItem)

                ' claim recovery items
            If Response.Recoveries IsNot Nothing Then
                For Each RecoveryItem As BaseClaimPerilRecoveryReceiptType In Response.Recoveries

                    ' attempt to find the matching recovery item
                    If ClaimReceiptItem.BaseRecoveryKey = RecoveryItem.BaseRecoveryKey Then

                        ' and then use the receipts details to override teh defaults
                        ' for the following items
                        If ToSafeString(sSalvageAndRecoveryReservesExcludeTax) = "1" Then
                            RecoveryItem.ThisReceiptINCLTaxAmount = ClaimReceiptItem.ReceiptAmount + ClaimReceiptItem.TotalTaxAmount
                            RecoveryItem.ThisReceiptNetAmount = ClaimReceiptItem.ReceiptAmount + ClaimReceiptItem.TotalTaxAmount
                            RecoveryItem.ThisReceiptTaxAmount = ClaimReceiptItem.TotalTaxAmount
                            RecoveryItem.BalanceAmount = RecoveryItem.TotalRecoveryAmount - RecoveryItem.TotalReceiptAmount - RecoveryItem.ThisReceiptINCLTaxAmount + RecoveryItem.ThisReceiptTaxAmount
                        Else
                        RecoveryItem.ThisReceiptNetAmount = ClaimReceiptItem.ReceiptAmount - ClaimReceiptItem.TotalTaxAmount
                            RecoveryItem.ThisReceiptINCLTaxAmount = ClaimReceiptItem.ReceiptAmount
                        RecoveryItem.ThisReceiptTaxAmount = ClaimReceiptItem.TotalTaxAmount
                        RecoveryItem.BalanceAmount = RecoveryItem.TotalRecoveryAmount - RecoveryItem.TotalReceiptAmount - RecoveryItem.ThisReceiptINCLTaxAmount
                        End If
                        ' store the recovery details back to the receipt item
                        ClaimReceiptItem.RecoveryId = RecoveryItem.RecoveryId
                        ClaimReceiptItem.RecoveryTypeId = RecoveryItem.RecoveryTypeId
                        ClaimReceiptItem.RecoveryTypeCode = RecoveryItem.TypeCode

                    End If
            Next
            End If
        Next

            ' convert tax calculation items to the format required in the response
        Response.TaxItems = Array.ConvertAll(ListOfAllTaxCalculationItems.ToArray(),
                        New Converter(Of BaseTaxCalculationItemType, BaseClaimReceiptTaxItemType) _
                         (AddressOf ConvertBaseTaxCalculationItemToBaseClaimReceiptTaxItemType))

            Response.ReceiptItems = ListOfReceiptItems.ToArray()

            Response.ReceiptToLossExchangeRate = ClaimReceipt.ReceiptToLossXRate

            Return Response

        End Function

    Private Sub CalculateAdvancedTax(
    ByVal con As SiriusConnection,
    ByVal ClaimDetails As BaseAdditionalClaimRelatedDetails,
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal ClaimReceiptItem As BaseClaimReceiptItemType,
    ByVal TaxCalculationItems As DataSet,
    ByVal BranchCode As String,
        ByVal Response As BaseGetClaimReceiptTaxesResponseType)

        Dim AdvancedTaxScriptDataArray() As Object = Nothing
        Dim UpdatedAdvancedTaxScriptDataArray() As Object = Nothing
        If ClaimReceipt.AdvancedTaxDetails IsNot Nothing Then
            ' load the advanced tax script data array-- check advanced
            SetupClaimReceiptAdvancedTaxScriptArraysNew(ClaimReceipt.AdvancedTaxDetails, ClaimReceiptItem.ReceiptAmount, TaxCalculationItems, ClaimReceipt.CurrencyCode, AdvancedTaxScriptDataArray)

            ' execute advanced tax script
            ExecuteAdvancedTaxScript(con, ClaimReceiptItem.TaxGroupAdvancedTaxScript, BranchCode, AdvancedTaxScriptDataArray, UpdatedAdvancedTaxScriptDataArray, ClaimReceiptItem.TaxGroupId)

            ' validate the updated details
            ValidateAdvancedTaxScriptArray(con, ClaimDetails, ClaimReceipt, ClaimReceiptItem, UpdatedAdvancedTaxScriptDataArray, Response)
        End If
        End Sub

    Private Sub StoreTaxCalculationItems(ByVal Con As SiriusConnection,
    ByVal oCoreBusiness As CoreBusiness,
    ByVal ClaimReceiptItem As BaseClaimReceiptItemType,
        ByVal TaxCalculation As DataSet)

            If TaxCalculation IsNot Nothing AndAlso TaxCalculation.Tables.Count > 0 Then

            Dim TaxCalculationItems As DataTable = TaxCalculation.Tables("Row")

            For Each dr As DataRow In TaxCalculationItems.Rows

                Dim oTaxCalculationItem As New TaxCalculationItem
                If dr.Item(ClaimTaxArray.ClassOfBusinessId) IsNot Nothing AndAlso Not String.IsNullOrEmpty(ToSafeString(dr.Item(ClaimTaxArray.ClassOfBusinessId)).Trim) Then
                    oTaxCalculationItem.ClassOfBusinessId = Cast.ToInt32(dr.Item(ClaimTaxArray.ClassOfBusinessId), 0)
                End If
                oTaxCalculationItem.TaxGroupId = Cast.ToInt32(dr.Item(ClaimTaxArray.TaxGroupId), 0)
                oTaxCalculationItem.TaxBandId = Cast.ToInt32(dr.Item(ClaimTaxArray.TaxBandId), 0)
                oTaxCalculationItem.TaxCurrencyCode = Cast.ToStringTrim(dr.Item(ClaimTaxArray.CurrencyCode))
                oTaxCalculationItem.TaxPercentage = CDec(Cast.ToDouble(dr.Item(ClaimTaxArray.Percentage), 0))
                oTaxCalculationItem.TaxValue = Cast.ToDecimal(dr.Item(ClaimTaxArray.Value), 0)
                oTaxCalculationItem.IsValue = CBool(Cast.ToInt32(dr.Item(ClaimTaxArray.IsValue), 0))
                oTaxCalculationItem.Sequence = Cast.ToInt32(dr.Item(ClaimTaxArray.Sequence), 0)
                oTaxCalculationItem.IsManuallyChanged = CBool(Cast.ToInt32(dr.Item(ClaimTaxArray.IsManuallyChanged), 0))
                oTaxCalculationItem.TaxGroupDescription = Cast.ToStringTrim(dr.Item(ClaimTaxArray.TaxGroupDescription))
                oTaxCalculationItem.TaxBandDescription = Cast.ToStringTrim(dr.Item(ClaimTaxArray.TaxBandDescription))
                Dim nTaxbandid As Integer
                Dim oSAMErrorCollection As New SAMErrorCollection
                nTaxbandid = Cast.ToInt32(dr.Item(ClaimTaxArray.TaxBandId), 0)
                oTaxCalculationItem.TaxBandCode = GetAndValidateDescriptionById(Con, "tax_band", "code", "tax_band_id", nTaxbandid.ToString)
                oTaxCalculationItem.RecoveryType = ClaimReceiptItem.RecoveryTypeCode
                ' ensure we have the tax group code as well
                oTaxCalculationItem.TaxGroupId = oCoreBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.TaxGroup, oTaxCalculationItem.TaxGroupId, "TaxGroupId", Nothing, "NOTPASSED", oTaxCalculationItem.TaxGroupCode)

                oTaxCalculationItem.ErrorMessage = Cast.ToStringTrim(dr.Item(ClaimTaxArray.ErrorMessage))

                ' add the items to the tax calculation item list on the receipt item
                ClaimReceiptItem.TaxCalculationItem.Add(oTaxCalculationItem)

            Next

        End If

    End Sub

    Private Sub StoreTaxCalculationItems(
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal ClaimReceiptItem As BaseClaimReceiptItemType,
    ByVal TaxDetailsDataArray As Object(),
    Optional ByVal con As SiriusConnection = Nothing)

        ' initialise boundary variables
        Dim LBound As Integer = 0
        Dim UBound As Integer = -1

        ' get the tax details array stored in position 10 and allocate to a tax details array object
        Dim TaxDetailsArray As Object(,) = TryCast(TaxDetailsDataArray(10), Object(,))

        If TaxDetailsArray IsNot Nothing Then

            ' get the arrays boundaries
            LBound = TaxDetailsArray.GetLowerBound(1)
            UBound = TaxDetailsArray.GetUpperBound(1)

        End If

        Dim ArrayIndex As Integer = 0

        'Dim ListOfTaxCalculationItems As List(Of BaseTaxCalculationItemType)

        For ArrayIndex = LBound To UBound

            Dim oTaxCalculationItem As New TaxCalculationItem

            'Int32.TryParse(CStr(TaxDetailsArray(ClaimTaxArray.ClassOfBusinessId, ArrayIndex)), oTaxCalculationItem.ClassOfBusinessId)
            'oTaxCalculationItem.ClassOfBusinessId = Cast.ToInt32(CStr(TaxDetailsArray(ClaimTaxArray.ClassOfBusinessId, ArrayIndex)), 0)
            If TaxDetailsArray(ClaimTaxArray.ClassOfBusinessId, ArrayIndex) IsNot Nothing AndAlso Not String.IsNullOrEmpty(Convert.ToString(TaxDetailsArray(ClaimTaxArray.ClassOfBusinessId, ArrayIndex))) Then
                oTaxCalculationItem.ClassOfBusinessId = Cast.ToInt32(TaxDetailsArray(ClaimTaxArray.ClassOfBusinessId, ArrayIndex), 0)
            End If
            oTaxCalculationItem.TaxCurrencyCode = Cast.ToStringTrim(TaxDetailsArray(ClaimTaxArray.CurrencyCode, ArrayIndex))
            oTaxCalculationItem.IsManuallyChanged = CBool(Cast.ToInt32(TaxDetailsArray(ClaimTaxArray.IsManuallyChanged, ArrayIndex), 0))
            oTaxCalculationItem.IsValue = CBool(Cast.ToInt32(TaxDetailsArray(ClaimTaxArray.IsValue, ArrayIndex), 0))
            oTaxCalculationItem.TaxPercentage = CDec(TaxDetailsArray(ClaimTaxArray.Percentage, ArrayIndex))
            oTaxCalculationItem.Sequence = Cast.ToInt32(TaxDetailsArray(ClaimTaxArray.Sequence, ArrayIndex), 0)
            Dim nTaxbandid As Integer
            Dim oSAMErrorCollection As New SAMErrorCollection
            nTaxbandid = Cast.ToInt32(TaxDetailsArray(ClaimTaxArray.TaxBandId, ArrayIndex), 0)
            oTaxCalculationItem.TaxBandCode = GetAndValidateDescriptionById(con, "tax_band", "code", "tax_band_id", nTaxbandid.ToString)
            'oTaxCalculationItem.TaxBandCode = Cast.ToStringTrim(TaxDetailsArray(ClaimTaxArray.TaxBandCode, ArrayIndex))
            oTaxCalculationItem.TaxBandDescription = Cast.ToStringTrim(TaxDetailsArray(ClaimTaxArray.TaxBandDescription, ArrayIndex))
            oTaxCalculationItem.TaxBandId = Cast.ToInt32(TaxDetailsArray(ClaimTaxArray.TaxBandId, ArrayIndex), 0)
            oTaxCalculationItem.TaxGroupDescription = Cast.ToStringTrim(TaxDetailsArray(ClaimTaxArray.TaxGroupDescription, ArrayIndex))
            oTaxCalculationItem.TaxGroupId = Cast.ToInt32(TaxDetailsArray(ClaimTaxArray.TaxGroupId, ArrayIndex), 0)
            oTaxCalculationItem.TaxValue = CDec(TaxDetailsArray(ClaimTaxArray.Value, ArrayIndex))
            oTaxCalculationItem.TaxScriptName = ClaimReceiptItem.TaxGroupAdvancedTaxScript
            oTaxCalculationItem.RecoveryType = ClaimReceiptItem.RecoveryTypeCode

            ' store the tax calculation items against the relevant claim receipt / payment item
            ClaimReceiptItem.TaxCalculationItem.Add(oTaxCalculationItem)

        Next

    End Sub

    Private Sub ValidateAdvancedTaxScriptArray(
    ByVal con As SiriusConnection,
    ByVal ClaimDetails As BaseAdditionalClaimRelatedDetails,
    ByVal ClaimReceipt As BaseClaimReceiptType,
    ByVal ClaimReceiptItem As BaseClaimReceiptItemType,
    ByVal TaxDetailsDataArray As Object(),
    ByVal Response As BaseGetClaimReceiptTaxesResponseType)

        ' store the tax calculation items against the receipt
        StoreTaxCalculationItems(ClaimReceipt, ClaimReceiptItem, TaxDetailsDataArray, con)

