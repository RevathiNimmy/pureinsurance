    ''' <summary>
    ''' UpdateRecommendStatus Request Handling
    ''' </summary>
    ''' <param name="oUpdateRecommendStatusRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function UpdateRecommendStatus(ByVal oUpdateRecommendStatusRequest As BaseUpdateRecommendStatusRequestType) As BaseUpdateRecommendStatusResponseType
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                    _SiriusUser.Username, _SiriusUser.SourceID,
                                    _SiriusUser.LanguageID,
                                    SiriusUserDefaults.AppName)
            Dim oResponse As BaseUpdateRecommendStatusResponseType
            oResponse = UpdateRecommendStatus(con, oUpdateRecommendStatusRequest)
            Return oResponse
        End Using
    End Function
    ''' <summary>
    ''' UpdateRecommendStatus Implementation
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="oUpdateRecommendStatusRequest"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function UpdateRecommendStatus(ByVal con As SiriusConnection, ByVal oUpdateRecommendStatusRequest As BaseUpdateRecommendStatusRequestType) As BaseUpdateRecommendStatusResponseType

        Dim oUpdateRecommendStatusResponse As New BaseUpdateRecommendStatusResponseType
        Dim oSAMErrorCollection As New SAMErrorCollection
        Dim dsCashClaimLink As DataSet = Nothing
        Dim nTypeOfPackage As enumTypeOfPackage
        Dim oBusiness As New CoreBusiness(_SiriusUser)
        Dim iBaseClaimKey As Integer

        If oUpdateRecommendStatusRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.UpdateRecommendStatusRequestType) Then
            nTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oUpdateRecommendStatusResponse = New SAMForInsuranceV2ImplementationTypes.UpdateRecommendStatusResponseType
        Else
            nTypeOfPackage = enumTypeOfPackage.UnknownPackage
        End If

        oUpdateRecommendStatusRequest.Validate(CType(oSAMErrorCollection, Object))
        oSAMErrorCollection.CheckForErrors()

        ' Check mandatory fields
        If String.IsNullOrEmpty(oUpdateRecommendStatusRequest.BranchCode) Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "BranchCode")
        End If
        oSAMErrorCollection.CheckForErrors()
        If oUpdateRecommendStatusRequest.ClaimKey = 0 AndAlso (GetAndValidateDescriptionById(con, "Claim", "Claim_Number", "Claim_id", oUpdateRecommendStatusRequest.ClaimKey.ToString) <> "") Then
            oSAMErrorCollection.AddInvalidData(SAMInvalidData.MandatoryInputMissing,
                                        SAMInvalidData.MandatoryInputMissing.ToString,
                                        "ClaimKey")
        End If
        oSAMErrorCollection.CheckForErrors()

        Try

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Base_Claim")
                Dim dsClaimDetails As DataSet = Nothing
                cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oUpdateRecommendStatusRequest.ClaimKey

                dsClaimDetails = con.ExecuteDataSet(cmd, "Row")

                Dim dr As DataRow = dsClaimDetails.Tables(0).Rows(0)
                If dsClaimDetails.Tables(0).Rows.Count > 0 Then

                    iBaseClaimKey = Cast.ToInt32(dr.Item("base_claim_id"), 0)

                End If
            End Using

            oBusiness.CheckSAMTSAndLock(Con:=con, BranchCode:=oUpdateRecommendStatusRequest.BranchCode,
                    Lockname:=CoreBusiness.LockName.ClaimId,
                    LockValue:=iBaseClaimKey,
                    TStamp:=oUpdateRecommendStatusRequest.TimeStamp)

            oSAMErrorCollection.CheckForErrors()

            If SetClaimPaymentRecommendStatus(con, oUpdateRecommendStatusRequest.ClaimKey, oUpdateRecommendStatusRequest.Status, _SiriusUser.UserID) <> 1 Then
                oSAMErrorCollection.AddBusinessRule(SAMBusinessErrors.RecommendationProcessingFailed,
                SAMBusinessErrors.RecommendationProcessingFailed.ToString,
                "UpdateRecommendStatus")
            End If
            oSAMErrorCollection.CheckForErrors()
            Dim dsClaim As DataSet
            Dim nInsuranceFileCnt As Integer
            Dim nInsuranceFolderCnt As Integer
            Dim nInsuranceHolderCnt As Integer
            Dim sClientname As String
            Dim sOriginalUser As String
            Dim iClaimKey As Integer
            Dim dAmount As Double
            Dim sDescription As String
            iClaimKey = oUpdateRecommendStatusRequest.ClaimKey
            dsClaim = getAuthoriseclaimDetail(iClaimKey, con)
            If dsClaim IsNot Nothing And dsClaim.Tables.Count > 0 And dsClaim.Tables(0).Rows.Count > 0 Then
                nInsuranceFileCnt = Cast.ToInt32(dsClaim.Tables(0).Rows(0)("insurance_file_cnt"), 0)
                nInsuranceFolderCnt = Cast.ToInt32(dsClaim.Tables(0).Rows(0)("insurance_folder_cnt"), 0)
                nInsuranceHolderCnt = Cast.ToInt32(dsClaim.Tables(0).Rows(0)("insurance_holder_cnt"), 0)
                sClientname = dsClaim.Tables(0).Rows(0)("insured_name").ToString()
                sOriginalUser = dsClaim.Tables(0).Rows(0)("username").ToString()
            End If
            Dim dsPayment As DataSet = Nothing
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Get_Claim_Payment")
                cmd.AddInParameter("@nClaimKey", SqlDbType.Int).Value = iClaimKey
                dsPayment = con.ExecuteDataSet(cmd, "ClaimPayment")
            End Using
            If dsPayment IsNot Nothing And dsPayment.Tables.Count > 0 And dsPayment.Tables(0).Rows.Count > 0 Then
                dAmount = Cast.ToDouble(dsPayment.Tables(0).Rows(0).Item(0), 0)
            End If
            sDescription = "Recommend of Claim Payment for amount " & dAmount
            CreateDefaultClaimEvent(con, nInsuranceHolderCnt, nInsuranceFolderCnt, nInsuranceFileCnt, iClaimKey, "C_CP", _SiriusUser.UserID, sDescription, EventTypeCode.ClaimRecommend)


            oBusiness.UnlockAndGetTS(
                        oUpdateRecommendStatusRequest.BranchCode,
                        CoreBusiness.LockName.ClaimId,
                        iBaseClaimKey,
                        oUpdateRecommendStatusResponse.TimeStamp)

        Catch ex As Exception

            Throw
        Finally
            oBusiness = Nothing
        End Try

        Return oUpdateRecommendStatusResponse
    End Function
    ''' <summary>
    ''' To Set the Recommend status during Claim Payment
    ''' </summary>
    ''' <param name="con"></param>
    ''' <param name="iClaimId"></param>
    ''' <param name="iStatus"></param>
    ''' <param name="iUserID"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function SetClaimPaymentRecommendStatus(ByVal con As SiriusConnection,
                        ByVal iClaimId As Integer,
                        ByVal iStatus As Int16,
                        ByVal iUserID As Integer) As Integer

        Try
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_CLM_Set_Payment_for_Recommendation")
                cmd.AddInParameter("@claimid", SqlDbType.Int).Value = iClaimId
                cmd.AddInParameter("@status", SqlDbType.SmallInt).Value = iStatus
                cmd.AddInParameter("@user_id", SqlDbType.Int).Value = iUserID
                con.ExecuteNonQuery(cmd)
            End Using
            Return 1
        Catch
            Return 0
        End Try

    End Function
