    End Sub

    ''' <summary>
    ''' Complete the Open CLaim Process
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="oRequest"></param>
    ''' <param name="oResponse"></param>
    ''' <remarks></remarks>
    Private Sub ProcessOpenClaim(ByVal con As SiriusConnection,
                                 ByRef oBusiness As CoreBusiness,
                                 ByRef oRequest As BaseClaimOpenRequestType,
                                 ByRef oResponse As BaseClaimResponseType)

        ' get claim details
        GetClaimDetails(con, oBusiness, oRequest)

        Try

            ' default the claim version description is the data hasnt been provided
            If String.IsNullOrEmpty(oRequest.Claim.ClaimVersionDescription) Then
                If String.IsNullOrEmpty(oRequest.Claim.Description) Then
                    oRequest.Claim.ClaimVersionDescription = "Opened Claim"
                Else
                    oRequest.Claim.ClaimVersionDescription = oRequest.Claim.Description
                End If
            Else
                oRequest.Claim.ClaimVersionDescription = oRequest.Claim.ClaimVersionDescription
            End If

            ' add client address
            oRequest.Claim.ClientAddressId = AddClaimAddress(con, oBusiness, oRequest.BranchCode, oRequest.Claim.Client.Address)

            ' only if there is an agent on the policy 
            If oRequest.Claim.AgentCnt <> 0 Then
                ' add insurer address
                oRequest.Claim.InsurerAddressId = AddClaimAddress(con, oBusiness, oRequest.BranchCode, oRequest.Claim.Insurer.Address)
            Else
                ' ensure no agent details are saved if there is not an agent on the policy
                ClearAgentDetails(oRequest)
            End If

            ' add claim 
            AddClaim(con, oBusiness, oRequest)

            ' add default claim perils
            AddDefaultClaimPerils(con, oRequest)

            ' preprocess the claim perils - adds any new claim perils that are needed
            PreprocessClaimPerils(con, oBusiness, TransactionTypeCode.OpenClaim,
                    oRequest.Claim, oRequest.Claim.ClaimPeril)

            ' if this process is being called via the data transfer
            ' create the sirius peril - samstaging peril links
            If oRequest.IsDataTransferClaim Then
                CreateDataTransferClaimPerilLinks(con, oRequest.Claim.ClaimPeril)
            End If

            ' add default claim peril reserves
            AddALLDefaultClaimPerilReserves(con, oRequest)

            ' if the claim is info only no need to do any further processing
            If Not oRequest.Claim.InfoOnly Then

                ' update the claim peril and associated details (including reserves / recoveries)
                If oRequest.Claim.ReserveOnly = True Then
                    UpdateClaimPerilDetails(con, oBusiness, TransactionTypeCode.OpenClaim,
                            oRequest.Claim, oRequest.Claim.ClaimPeril, True)
                Else
                    UpdateClaimPerilDetails(con, oBusiness, TransactionTypeCode.OpenClaim,
                            oRequest.Claim, oRequest.Claim.ClaimPeril, oRequest.IsDataTransferClaim)
                End If


                    'For Open Claim, transaction type code in database is C_CO
                    Const ksTransactionType As String = "C_CO"
                    ProcessClaimsCoinsurance(con, oBusiness, oRequest.Claim.ClaimId, ksTransactionType, oRequest.BranchCode)

                    ' dont create any reinsurance lines if they have been specified as part of the data transfer
                    If Not oRequest.DataTransferClaimHasSpecifiedReinsurance Then
                        ' process reinsurance
                        ProcessClaimsReinsurance(con, oRequest.Claim.ClaimId, 0)
                    Dim oGetProductRiskOptionValueRequest As New BaseProductRiskOptionValueRequestType
                    Dim oGetProductRiskOptionValueResponse As New BaseProductRiskOptionValueResponseType
                    oGetProductRiskOptionValueRequest.BranchCode = oRequest.BranchCode
                    oGetProductRiskOptionValueRequest.ProductCode = oRequest.Claim.ProductCode
                    oGetProductRiskOptionValueRequest.RiskTypeOption = RiskTypeOptions.IsAutoReinsured
                    oGetProductRiskOptionValueRequest.ActionType = ProductConfigActionType.RiskTypeMaintenance
                    Dim dtRiskType As DataTable

                    If oRequest.Claim.RiskKey > 0 Then
                        Using cmd As SiriusCommand = SiriusCommand.FromText("select rt.code from risk r join risk_type rt on r.risk_type_id=rt.risk_type_id where risk_cnt=" + Convert.ToString(oRequest.Claim.RiskKey))
                            dtRiskType = con.ExecuteDataTable(cmd)
                        End Using
                        oGetProductRiskOptionValueRequest.RiskTypeCode = Convert.ToString(dtRiskType.Rows.Item(0)(0)).Trim()
                        oGetProductRiskOptionValueRequest.RiskTypeOptionSpecified = True
                        oGetProductRiskOptionValueResponse = GetProductRiskOptionValue(oGetProductRiskOptionValueRequest)
                    End If
                    If Not oRequest.DataTransferClaimHasSpecifiedReinsurance And (oGetProductRiskOptionValueResponse IsNot Nothing AndAlso oGetProductRiskOptionValueResponse.ProductRiskOptionValue = "1") Then
                        ' process reinsurance
                        ProcessClaimsReinsurance(con, oRequest.Claim.ClaimId, 0)
                    ElseIf oGetProductRiskOptionValueResponse Is Nothing Then
                        ProcessClaimsReinsurance(con, oRequest.Claim.ClaimId, 0)

                    End If
                End If
                If oRequest.Claim.ReserveOnly = False Then
                    ' finalise the claim details
                    FinaliseClaimDetails(con, oRequest.Claim.ClaimId, oRequest.Claim.ClaimVersionDescription)

                    ' create dme folder for the claim
                    CreateClaimsDMEFolder(con, oBusiness, oRequest)

                   
                    'Generate a default Sharepoint folder (if Sharepoint is enabled)
                    Dim Sharepoint As bSIRSharepoint.Business
                    Sharepoint = New bSIRSharepoint.Business

                    Sharepoint = New bSIRSharepoint.Business

                    SAMFunc.InitialiseSBOObject(oObject:=Sharepoint, siriusUser:=_SiriusUser, sObjectName:="bSIRSharepoint.Business")

                    Sharepoint.GenerateDefaultPath(oRequest.Claim.Client.PartyKey, 0, oRequest.Claim.ClaimId, 0)
                   



                    ' Update Insurance File System
                    UpdateInsuranceFileSystem(con, _SiriusUser.UserID,
                                                oRequest.Claim.InsuranceFileKey,
                                                    TransactionTypeCode.OpenClaim)

                    ' do not create any transactions for data transfer claims
                    ' these will be created by the data transfer
                    If Not oRequest.IsDataTransferClaim Then
                        ' Raise the transactions
                        RaiseTransactions(con, oRequest.Claim.ClaimId, _
                                            oRequest.Claim.TransactionTypeId, _
                                              TransactionTypeCode.OpenClaim, _
                                                oRequest.Claim.PaymentSuppressReserves, _
                                                 oRequest.Claim.CurrencyId)
                    End If
                    Sharepoint.Dispose()
                    Sharepoint = Nothing
                End If
            End If
            If oRequest.Claim.ReserveOnly = False Then

                ' create default claim event
                CreateDefaultClaimEvent(con, oRequest.Claim.InsuranceHolderCnt,
                                            oRequest.Claim.InsuranceFolderCnt,
                                             oRequest.Claim.InsuranceFileKey,
                                              oRequest.Claim.ClaimId,
                                               TransactionTypeCode.OpenClaim,
                                                _SiriusUser.UserID,
                                                 oRequest.Claim.ClaimVersionDescription)

                ' Update Claim Is Dirty Flag to indicate that the open claim process has completed
                UpdateClaimIsDirtyFlag(con, oRequest.Claim.ClaimId, InternalSAMConstants.kClaimProcessed)
            End If



            ' populate response object
            PopulateResponseObject(oBusiness, oRequest, oResponse)

            If oRequest.Claim.BaseCaseKey > 0 Then
                UpdateBaseCaseKey(con, oResponse.ClaimKey, oRequest.Claim.BaseCaseKey)
            End If
        Catch

            Throw

        End Try

    End Sub

