    Private Sub GetBaseClaimDetails(
    ByVal oRequest As BaseClaimMaintainRequestType,
    ByVal oSAMErrorCollection As SAMErrorCollection)

        ''' validate the core claim links
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Base_Claim_Details")

                cmd.AddInParameter("@base_claim_id", SqlDbType.Int).Value = oRequest.Claim.BaseClaimKey

                Dim dt As DataTable = con.ExecuteDataTable(cmd)

                If dt IsNot Nothing AndAlso dt.Rows.Count <> 0 Then

                    oRequest.Claim.InsuranceFileKey = Cast.ToInt32(dt.Rows(0).Item("insurance_file_cnt"), 0)
                    oRequest.Claim.PolicyNumber = Cast.ToStringTrim(dt.Rows(0).Item("insurance_ref"))
                    oRequest.Claim.RiskKey = Cast.ToInt32(dt.Rows(0).Item("risk_cnt"), 0)
                    oRequest.Claim.ClaimNumber = Cast.ToString(dt.Rows(0).Item("claim_number"))
                    oRequest.Claim.PreviousLossFromDate = Cast.ToDateTime(dt.Rows(0).Item("loss_from_date"), InternalSAMConstants.kDateInFuture)
                    oRequest.Claim.PreviousLossToDate = Cast.ToDateTime(dt.Rows(0).Item("loss_to_date"), InternalSAMConstants.kDateInFuture)
                    oRequest.Claim.PreviousInfoOnly = Cast.ToBoolean(dt.Rows(0).Item("info_only"), False)
                    oRequest.Claim.ClientAddressId = Cast.ToInt32(dt.Rows(0).Item("client_address"), 0)
                    oRequest.Claim.InsurerAddressId = Cast.ToInt32(dt.Rows(0).Item("insurer_address"), 0)
                    oRequest.Claim.CurrencyId = Cast.ToInt32(dt.Rows(0).Item("currency_id"), 0)
                    oRequest.Claim.CurrencyCode = Cast.ToString(dt.Rows(0).Item("currency_code"), String.Empty)
                    oRequest.Claim.ClientName = Cast.ToString(dt.Rows(0).Item("client_name"), String.Empty)
