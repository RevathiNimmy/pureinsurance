    ''' <summary>
    ''' Updates the coinsurance breakdown details for a claim in the database. This method is called from ProcessOpenClaim,
    ''' ProcessMaintainClaim,ProcessPayClaim and ProcessClaimReceipt methods.
    ''' </summary>
    ''' <param name="con">Sirius connection object</param>
    ''' <param name="oCoreBusiness">Object of CoreBusiness class</param>
    ''' <param name="lClaimId">Id of the claim under process</param>
    ''' <param name="sTransType">Transaction type code</param>
    ''' <param name="sBranchCode">Branch code</param>
    ''' <returns >A value of type Integer</returns>
    ''' <remarks></remarks>
    Private Function ProcessClaimsCoinsurance(ByVal con As SiriusConnection, ByVal oCoreBusiness As CoreBusiness,
    ByVal lClaimId As Integer, ByVal sTransType As String, ByVal sBranchCode As String) As Integer
        Const ksCoinsurerRequired As String = "1"
        Const ksCoinsurerRequiredWithStatistics As String = "2"

        Dim o_sOptionValue As String = String.Empty
        Dim oSAMErrorCollection As New SAMErrorCollection

        'Create GetProductRiskOptions request
        Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType

        'Get the product id
        Dim dsProductId As DataSet = Nothing
        Dim iProductId As Integer

        'Get the product id from insurance file count 
        GetInsFileCntProductId(con:=con,
                                lInsuranceFileCnt:=0,
                                dsProductId:=dsProductId,
                                lBaseClaimID:=lClaimId)
        If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
        AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso dsProductId.Tables(0).Rows(0).Item("product_id") IsNot Nothing AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
            iProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
        Else
            'Failed to get the product id from the given base claim key
            oSAMErrorCollection.AddInvalidData(
                                    SAMConstants.SAMInvalidData.GeneralFailure,
                                    "Failed to get product details for the given policy")

            oSAMErrorCollection.CheckForErrors()
        End If

        oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.InclusionOfCoInsurersOnClaims
        o_sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
        If String.IsNullOrEmpty(o_sOptionValue) Then
            o_sOptionValue = "0"
        End If

        If (o_sOptionValue = ksCoinsurerRequired OrElse o_sOptionValue = ksCoinsurerRequiredWithStatistics) Then

            ' Get the dme folder details 
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Coinsurance_Details_Update")

                cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = lClaimId
                cmd.AddInParameter("@transaction_type", SqlDbType.VarChar, 10).Value = sTransType

                con.ExecuteNonQuery(cmd)
            End Using
        End If
    End Function

    ''' <summary>
    ''' Gets the coinsurance breakdown details for a claim in the database. 
    ''' </summary>
    ''' <param name="oRequest">Object of SiriusFS.SAM.Structure.BaseImplementationTypes.BaseGetClaimCoinsurerRequestType class</param>
    ''' <returns >An object of type SiriusFS.SAM.Structure.BaseImplementationTypes.BaseGetClaimCoinsurerResponseType</returns>
    ''' <remarks></remarks>
    Public Function GetClaimCoinsurer(ByVal oRequest As BaseGetClaimCoinsurerRequestType) As BaseGetClaimCoinsurerResponseType

        Dim oResponse As New BaseImplementationTypes.BaseGetClaimCoinsurerResponseType
        Dim oCoreBusiness As New CoreBusiness(_SiriusUser)
        Dim oSAMErrorCollection As New SAMErrorCollection

        Dim lSourceId As Integer
        Dim eTypeOfPackage As enumTypeOfPackage

        If oRequest.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.GetClaimCoinsurerRequestType) Then
            eTypeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            oResponse = New SAMForInsuranceV2ImplementationTypes.GetClaimCoinsurerResponseType
        End If

        ' Structure Validation
        oRequest.Validate(CObj(oSAMErrorCollection))
        oSAMErrorCollection.CheckForErrors()

        ' Lookup Codes to ensure they are valid
        lSourceId = oCoreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, oRequest.BranchCode, "BranchCode", oSAMErrorCollection)
        oSAMErrorCollection.CheckForErrors()

        ' Dataset that will hold the returned results		
        Dim ds As DataSet = Nothing
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)

            ' Checking whether the claim key is valid
            Dim lClaimId As Integer
            lClaimId = GetAndValidateSpecifiedTableCode(con, "claim", "claim_id", "claim_id", oRequest.ClaimKey.ToString, oSAMErrorCollection, "ClaimKey")
            oSAMErrorCollection.CheckForErrors()

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Coinsurer_Details_Select")
                cmd.AddInParameter("@claim_id", SqlDbType.Int).Value = oRequest.ClaimKey
                ds = con.ExecuteDataSet(cmd, "Row")
            End Using
        End Using

        ds.DataSetName = "BaseGetClaimCoinsurerResponseTypeCoinsurers"

        If (ds.Tables(0).Rows.Count > 0) Then
            ' populate response set
            ' totalShare  = 100
            ' get claimnumber  from first entry in the dataset its “ClaimNumber” it will be same across all entries
            ' get  TotalCurrentShareValue from first entry in the dataset its “TotalReserve” it will be same across all entries
            oResponse.TotalShare = 100
            oResponse.ClaimNumber = Cast.ToString(ds.Tables(0).Rows(0).Item("ClaimNumber"), "")
            oResponse.TotalCurrentShareValue = Cast.ToDecimal(ds.Tables(0).Rows(0).Item("TotalCurrentShareValue"), 0)
        End If
        If oRequest.WCFSecurityToken = "" Then
        Dim xmlDoc As New System.Xml.XmlDocument
        xmlDoc.LoadXml(ds.GetXml)

        oResponse.ResultDataset = xmlDoc.DocumentElement()
        End If
        oResponse.ResultData = ds
        Return oResponse

    End Function

