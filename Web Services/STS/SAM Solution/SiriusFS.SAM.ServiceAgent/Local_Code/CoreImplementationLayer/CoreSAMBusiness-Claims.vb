    ''' <summary>
    ''' 
    ''' </summary>
    ''' <param name="Con"></param>
    ''' <param name="v_lOriginalClaimId"></param>
    ''' <param name="v_lCopyClaimId"></param>
    ''' <remarks></remarks>
    Private Sub CopyClaimGISWithVersions(ByVal Con As SiriusConnection,
                                                ByVal v_lOriginalClaimId As Integer,
                                                ByVal v_lCopyClaimId As Integer)

        Dim dsGisPolicyLink As DataSet = Nothing
        Dim lGisPolicyLinkId As Integer
        Dim sQuoteRefPassword As String = String.Empty
        Dim sDataModelCode As String = String.Empty
        Dim lNewGisPolicyLinkId As Integer

        GetGisPolicyLinkDetails(Con:=Con,
                                    v_lOriginalClaimId:=v_lOriginalClaimId,
                                    dsGetGisPolicyLink:=dsGisPolicyLink)

        If dsGisPolicyLink.Tables(0).Rows.Count > 0 Then

            lGisPolicyLinkId = Cast.ToInt32(dsGisPolicyLink.Tables(0).Rows(0).Item("Gis_Policy_Link_id"), 0)

            Dim EncryptedQuoteRefPassword As String = dsGisPolicyLink.Tables(0).Rows(0).Item("quote_ref_password").ToString

            ' SAMFunc.Decrypt the existing password before reusing it as 
            ' continued use will cause the SAMFunc.Encrypted password to reach 32 characters and therefore blow up
            ' as max size supported is 30 characters. ( SAMFunc.Encrypting - adds 2 characters to the string size)
            SAMFunc.Decrypt(EncryptedQuoteRefPassword, sQuoteRefPassword)

            GetClaimDataModelCode(Con:=Con,
                                    v_lOriginalClaimId:=v_lOriginalClaimId,
                                    r_sDataModelCode:=sDataModelCode)

            CopyGISDataSet(Con:=Con,
                           v_sDataModelCode:=sDataModelCode,
                           v_lOriginalGisPolicyLinkId:=lGisPolicyLinkId,
                           r_lNewGisPolicyLinkId:=lNewGisPolicyLinkId)

            UpdateGisPolicyLinkQuoteRef(Con:=Con,
                                            v_sQuoteRefPassword:=sQuoteRefPassword,
                                            v_sDataModelCode:=sDataModelCode,
                                            v_lGisPolicyLinkId:=lNewGisPolicyLinkId)

            CopyGISClaim(Con:=Con,
                            sDataModelCode:=sDataModelCode,
                            v_lOriginalClaimId:=v_lOriginalClaimId,
                            v_lCopyClaimId:=v_lCopyClaimId)

            UpdateGisPolicyLinkDetails(Con:=Con,
                                        v_lCopyClaimId:=v_lCopyClaimId,
                                        v_lGisPolicyLinkId:=lNewGisPolicyLinkId)
        End If

    End Sub

