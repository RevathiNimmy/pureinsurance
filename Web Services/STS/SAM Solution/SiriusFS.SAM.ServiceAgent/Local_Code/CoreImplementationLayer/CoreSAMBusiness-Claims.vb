    Private Function IsUserAuthorisedToMakePayment(
    ByVal con As SiriusConnection,
    ByVal oBusiness As CoreBusiness,
    ByVal oClaimPayment As BaseClaimPaymentType,
    Optional ByVal bIsTPASettleDirectly As Boolean = False) As Boolean

        Const OptionCheckAuthorisation As String = "1"

        Dim sCheckAuthorisationOption As String = String.Empty
        Dim dPaymentAmount As Decimal
        Dim dThisPaymentAmount As Decimal
        Dim lCurrencyId As Integer
        Dim dOriginalThisPaymentAmount As Decimal
        Dim lOriginalThisPaymentCurrencyId As Integer
        ' get the product option value for RunClaimAuthorisationScripts
        sCheckAuthorisationOption = oBusiness.GetProductOption(con, ProductOption.RunClaimsAuthorisationScript, oClaimPayment.SourceId, oClaimPayment.ClaimId)

        Dim bCheckAuthorisation As Boolean = False

        ' determine if the process needs to check authorisation
        If sCheckAuthorisationOption = OptionCheckAuthorisation Then
            bCheckAuthorisation = True
        End If

        Dim bUserAuthorised As Boolean = False

        ' if authorisation is not required or if there is no payment amount to process
        If Not bCheckAuthorisation OrElse
                oClaimPayment.TotCurrAmount = 0 Then

            ' the user is always authorised to make this payment
            bUserAuthorised = True
        Else

            ' get the actual payment amount
            GetPaymentAmount(Con:=con,
                                           lClaimId:=oClaimPayment.ClaimId,
                                           lUserId:=_SiriusUser.UserID,
                                           r_dPaymentAmount:=dPaymentAmount,
                                           r_dThisPaymentAmount:=dThisPaymentAmount,
                                           r_lCurrencyId:=lCurrencyId,
                                           r_dOriginalPaymentAmount:=dOriginalThisPaymentAmount,
                                           r_lOriginalCurrencyId:=lOriginalThisPaymentCurrencyId)

            ' determine whether the user has authority to make this payment 
            ' from the return value of the user defined - claim payment authorisation script
            CheckUserPaymentAuthority(Con:=con,
                                            lInsuranceFileCnt:=oClaimPayment.InsuranceFileCNT,
                                            lUserId:=_SiriusUser.UserID,
                                            sTransType:=TransactionTypeCode.PayClaim,
                                            lTotAmount:=dThisPaymentAmount,
                                            lCurrencyId:=oClaimPayment.CurrencyId,
                                            r_bUserAuthorised:=bUserAuthorised,
                                            dOriginalPaymentAmount:=dOriginalThisPaymentAmount,
                                            lOriginalCurrencyId:=lOriginalThisPaymentCurrencyId,
                                            lClaimID:=oClaimPayment.ClaimId)
        End If

        If bIsTPASettleDirectly = True Then
            Dim oUserAuthRequest As New BaseGetUserAuthorityValueRequestType
            Dim oUserAuthResponse As New BaseGetUserAuthorityValueResponseType

            oUserAuthRequest.BranchCode = "HeadOff"
            oUserAuthRequest.UserAuthorityOption = UserAuthorityOptions.HasClaimPaymentsAuthority
            oUserAuthRequest.UserCode = _SiriusUser.Username
            oUserAuthResponse = GetUserAuthorityValue(oUserAuthRequest)
            If oUserAuthResponse.UserAuthorityValue = "1" Then
                Dim iCurrencyId As Integer = Cast.ToInt32(oUserAuthResponse.UserAuthorityOptionalValue1, 0)
                Dim dAmount As Decimal = Cast.ToDecimal(oUserAuthResponse.UserAuthorityOptionalValue2, 0)
                Dim dRate As Decimal = 0
                If oClaimPayment.CurrencyId <> iCurrencyId Then
                    GetCurrencyToCurrencyExchangeRate(con, Date.Now, iCurrencyId, oClaimPayment.CurrencyId, 1, dRate)
                    dAmount = dAmount * dRate
                End If

                ' return the value indicating whether the user is authorised to make this payment
                Return dAmount >= dPaymentAmount
            End If
        Else
            ' return the value indicating whether the user is authorised to make this payment
            Return bUserAuthorised
        End If


        

    End Function

    ''' <summary>
    ''' adds the specified warning to the warning collection
    ''' </summary>
    ''' <param name="Warnings"></param>
    ''' <param name="Code"></param>
    ''' <param name="Description"></param>
    ''' <remarks></remarks>
    Private Sub AddWarning(ByVal oResponse As BaseClaimResponseType,
                           ByVal Code As Integer,
                           ByVal Description As String)

        Dim iUBound As Integer
        Dim oWarning As New BaseImplementationTypes.BaseClaimResponseTypeWarnings

        If oResponse.Warnings Is Nothing Then
            iUBound = 0
        Else
            iUBound = oResponse.Warnings.Length
        End If

        ' resize array
        Array.Resize(oResponse.Warnings, iUBound + 1)

        ' set warning values
        oWarning.Code = Code
        oWarning.Description = Description
        oResponse.Warnings(iUBound) = oWarning

    End Sub

    ''' <summary>
    ''' Checks duplicate claim check and override duplicated claims
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub OpenClaimValidateBusinessRules(
                        ByVal oBusiness As CoreBusiness,
                        ByRef OpenClaimRequest As BaseClaimOpenRequestType,
                        ByRef oSAMErrorCollection As SAMErrorCollection)

        ' if this is not a data transfer claim then
        If Not OpenClaimRequest.IsDataTransferClaim Then

            ' duplicate claims check
            Dim sOptionValue As String = String.Empty

            'Create GetProductRiskOptions request
            Dim oGetProductRiskOptionsRequest As New BaseProductRiskOptionValueRequestType

            'Get the product id
            Dim dsProductId As DataSet = Nothing
            Dim iProductId As Integer

            Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

                'Getting the product id from insurance file count 
                GetInsFileCntProductId(con:=con,
                                        lInsuranceFileCnt:=OpenClaimRequest.Claim.InsuranceFileKey,
                                        dsProductId:=dsProductId)

                If (dsProductId IsNot Nothing AndAlso dsProductId.Tables.Count > 0 _
                AndAlso dsProductId.Tables(0).Rows.Count > 0) AndAlso dsProductId.Tables(0).Rows(0).Item("product_id") IsNot Nothing AndAlso Cast.ToInt32(dsProductId.Tables(0).Rows(0).Item("product_id"), 0) <> 0 Then
                    iProductId = CInt(dsProductId.Tables(0).Rows(0).Item("product_id"))
                Else
                    'Failed to get the product id from the given base claim key
                    oSAMErrorCollection.AddInvalidData(
                                            SAMConstants.SAMInvalidData.GeneralFailure,
                                            "Failed to get product details for the given policy")

                    oSAMErrorCollection.CheckForErrors()
                End If

                If CheckClaimNumberAlreadyExist(OpenClaimRequest) <> 0 Then

                    oSAMErrorCollection.AddBusinessRule(
                             SAMBusinessErrors.ClaimNumberAlreadyExists,
                            SAMBusinessErrors.ClaimNumberAlreadyExists.ToString,
                            "Claim Number already exists")

                    oSAMErrorCollection.CheckForErrors()

                End If

                oGetProductRiskOptionsRequest.ProducRiskOption = ProductRiskOptions.IsDuplicateClaimCheckEnabled

                sOptionValue = GetProductRiskOptions(con, iProductId, oGetProductRiskOptionsRequest)
            End Using

            If Not String.IsNullOrEmpty(sOptionValue) Then

                ' if the option duplicate claim check option is switched on 
                If CType(sOptionValue, Integer) = 1 Then

                    '''--Start (Jigar Pandya) - (Tech Spec-UIIC WR24-OpenClaim-Duplicate Claims Check.doc) - (6.1.3.2.1.2)
                    Dim validOverrideUserDetailsProvided As Boolean

                    If Not String.IsNullOrEmpty(OpenClaimRequest.Claim.DuplicateClaimOverrideUserName) AndAlso
                        Not String.IsNullOrEmpty(OpenClaimRequest.Claim.DuplicateClaimOverrideUserPassword) Then

                    Dim encryptedPassword As String = String.Empty

                    If String.IsNullOrEmpty(OpenClaimRequest.Claim.DuplicateClaimOverrideUserName) Then
                        OpenClaimRequest.Claim.DuplicateClaimOverrideUserName = _SiriusUser.Username
                    End If
                    If String.IsNullOrEmpty(OpenClaimRequest.Claim.DuplicateClaimOverrideUserPassword) Then
                        'OpenClaimRequest.Claim.DuplicateClaimOverrideUserPassword = _SiriusUser.Password
                        'encryptedPassword = _SiriusUser.Password
                    Else
                        ' encypt password using SAMFun.Encrypt
                            Dim oValidateUserRequest As New ValidateUserRequestType
                            Dim oValidateUserResponse As New ValidateUserResponseType

                            oValidateUserRequest.LoginUserName = OpenClaimRequest.LoginUserName
                            oValidateUserRequest.BranchCode = OpenClaimRequest.BranchCode
                            oValidateUserRequest.WCFSecurityToken = OpenClaimRequest.WCFSecurityToken
                            oValidateUserRequest.UserName = OpenClaimRequest.Claim.DuplicateClaimOverrideUserName
                            oValidateUserResponse = ValidateUser(oValidateUserRequest)

                            SAMErrorCollection.CheckForErrorsFromSTS(oValidateUserResponse.STSError)
                            encryptedPassword = oValidateUserResponse.PasswordHash
                            'SAMFunc.Encrypt(OpenClaimRequest.Claim.DuplicateClaimOverrideUserPassword, encryptedPassword)
                    End If

                    Dim bCheckCurrentUserClaimOverrideAuthority As Boolean = ValidateCurrentUserClaimOverrideAuthority(OpenClaimRequest.UserName)

                    If Not bCheckCurrentUserClaimOverrideAuthority Then

                        ' check if the user has override duplicate claim authority
                        validOverrideUserDetailsProvided = ValidateDuplicateClaimOverrideUser(OpenClaimRequest.Claim.DuplicateClaimOverrideUserName, encryptedPassword)

                        If Not validOverrideUserDetailsProvided Then
                            ' do duplicate claim check
                                DuplicateClaimExists(OpenClaimRequest.Claim.InsuranceFileKey,
                                                    OpenClaimRequest.Claim.RiskKey,
                                                    OpenClaimRequest.Claim.LossFromDate,
                                                oSAMErrorCollection)

                            oSAMErrorCollection.CheckForErrors()
                        End If
                        End If
                        '''--End (Jigar Pandya) - (Tech Spec-UIIC WR24-OpenClaim-Duplicate Claims Check.doc) - (6.1.3.2.1.2)

                    End If
                End If
            End If
        End If
    End Sub
    '''<summary>
    '''Tech Spec-UIIC WR24-OpenClaim-FindInsuranceFile.doc,6.1.3.2.1.2
    '''Developed By: Jigar Pandya On: 08 May 2008
    '''</summary>
    '''<param name="userName">userName</param>
    '''<param name="password">Password</param>
    '''<remarks></remarks>
    Private Function ValidateDuplicateClaimOverrideUser(
    ByVal userName As String,
    ByVal password As String) As Boolean

        Dim returnVal As Boolean = False
        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                        _SiriusUser.Username, _SiriusUser.SourceID,
                                        _SiriusUser.LanguageID,
                                        SiriusUserDefaults.AppName)

                Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_Validate_Duplicate_Claim_Override_User_Details")  ' New SP
                    cmd.AddInParameter("@userName", SqlDbType.VarChar, 255).Value = userName
                cmd.AddInParameter("@password", SqlDbType.VarChar, 255).Value = password
                    cmd.AddOutParameter("@user_Id", SqlDbType.Int)
                    con.ExecuteNonQuery(cmd)
                If Not String.IsNullOrEmpty(cmd.Parameters.Item("@user_Id").Value.ToString) Then
                    returnVal = True
                End If
                End Using
            End Using
            Return returnVal
    End Function

