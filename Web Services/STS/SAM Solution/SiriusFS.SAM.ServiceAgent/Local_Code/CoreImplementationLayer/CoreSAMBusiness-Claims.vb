    ''' <summary>
    ''' runs the business rules
    ''' </summary>
    ''' <param name="oBusiness"></param>
    ''' <param name="OpenClaimRequest"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub CoreClaimValidateBusinessRules(
                ByVal oBusiness As CoreBusiness,
                ByVal oClaim As BaseClaimType,
                ByVal oSAMErrorCollection As SAMErrorCollection)

        'i.	Loss Date cannot be in the future
        'ii.	Loss Date cannot be after reported date
        'iii.	Loss Date cannot be after loss to date
        'iv. 	reported date cannot be in the future

        If oClaim.LossFromDate.Date > Date.Now Then
            oSAMErrorCollection.AddBusinessRule(
                                        SAMBusinessErrors.LossFromDataInFuture,
                                        SAMBusinessErrors.LossFromDataInFuture.ToString,
                                        "LossFromDate:" & oClaim.LossFromDate.ToString())
        End If

        If oClaim.LossFromDate.Date > oClaim.ReportedDate.Date Then
            oSAMErrorCollection.AddBusinessRule(
                                        SAMBusinessErrors.LossFromDateAfterReportedDate,
                                        SAMBusinessErrors.LossFromDateAfterReportedDate.ToString,
                                        "LossFromDate:" & oClaim.LossFromDate & vbCrLf &
                                        "ReportedDate:" & oClaim.ReportedDate)
        End If

        If oClaim.LossFromDate.Date > oClaim.LossToDate.Date Then
            oSAMErrorCollection.AddBusinessRule(
                                        SAMBusinessErrors.LossFromDateAfterLossToDate,
                                        SAMBusinessErrors.LossFromDateAfterLossToDate.ToString,
                                        "LossFromDate:" & oClaim.LossFromDate & vbCrLf &
                                        "LossToDate:" & oClaim.LossToDate)
        End If

        If oClaim.ReportedDate.Date > Date.Now Then
            oSAMErrorCollection.AddBusinessRule(
                                        SAMBusinessErrors.ReportedDateInFuture,
                                        SAMBusinessErrors.ReportedDateInFuture.ToString,
                                        "ReportedDate:" & oClaim.ReportedDate)
        End If

    End Sub

    ''' <summary>
    ''' determines if a duplicate claim exists for the details specified
    ''' </summary>
    ''' <param name="InsuranceFileCnt"></param>
    ''' <param name="RiskCnt"></param>
    ''' <param name="LossDate"></param>
    ''' <param name="oSAMErrorCollection"></param>
    ''' <remarks></remarks>
    Private Sub DuplicateClaimExists(ByVal InsuranceFileCnt As Integer,
                                          ByVal RiskCnt As Integer,
                                          ByVal LossDate As Date,
                                          ByRef oSAMErrorCollection As SAMErrorCollection)

        Using con As SiriusConnection = New SiriusConnectionPMDAO(
                                            _SiriusUser.Username, _SiriusUser.SourceID,
                                            _SiriusUser.LanguageID,
                                            SiriusUserDefaults.AppName)

            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_SAM_CLM_Get_Duplicate_Claims")

                cmd.AddInParameter("@insurance_file_cnt", SqlDbType.Int).Value = InsuranceFileCnt
                cmd.AddInParameter("@risk_cnt", SqlDbType.Int).Value = RiskCnt
                cmd.AddInParameter("@loss_date", SqlDbType.DateTime).Value = LossDate

                Dim ds As DataSet = Nothing

                ds = con.ExecuteDataSet(cmd, "DuplicateClaims")

                If ds.Tables.Count = 1 Then
                    If ds.Tables("DuplicateClaims").Rows.Count > 0 Then
                        oSAMErrorCollection.AddBusinessRule(
                                                SAMBusinessErrors.DuplicateClaimExists,
                                                SAMBusinessErrors.DuplicateClaimExists.ToString,
                                                "Duplicate Claim Exists - " &
                                                "Insurance File Key:" & InsuranceFileCnt &
                                                "RiskKey:" & RiskCnt &
                                                "LossFromDate:" & LossDate)
                        oSAMErrorCollection.CheckForErrors()
                    End If
                End If

            End Using
        End Using
    End Sub

