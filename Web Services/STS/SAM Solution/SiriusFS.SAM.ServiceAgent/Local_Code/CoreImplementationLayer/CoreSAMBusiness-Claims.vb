    Private Class TaxCalculationItem
        Inherits BaseImplementationTypes.BaseTaxCalculationItemType

        Public Sub Validate(
        ByVal oCoreSAMBusiness As CoreSAMBusiness,
        ByVal con As SiriusConnection,
        ByVal ClaimDetails As BaseAdditionalClaimRelatedDetails,
        ByVal ClaimReceipt As BaseClaimReceiptType)

            Dim oBusiness As New CoreBusiness
            Dim oSAMErrorCollection As New SAMErrorCollection

            Dim TaxArrayItemDefinition As String = String.Empty
            Dim FailureReason As String = String.Empty

            '' set up generic default message containing
            '' tax array item details in case of failure
            TaxArrayItemDefinition = "Validation of Tax Item Generated / Amended by Tax Script " & Me.TaxScriptName & " Failed." & vbCrLf &
                          "The tax array item details are as follows : - " & vbCrLf &
                          "Tax Group Id:=" & Me.TaxGroupId & vbCrLf &
                          "Tax Band Id:=" & Me.TaxBandId & vbCrLf &
                          "Currency Code:=" & Me.TaxCurrencyCode & vbCrLf &
                          "Tax Percenage:=" & Me.TaxPercentage & vbCrLf &
                          "Value:=" & Me.TaxValue & vbCrLf &
                          "Class Of Business Id:=" & Me.ClassOfBusinessId & vbCrLf &
                          "Is Value:=" & Me.IsValue

            'error message
            If Not String.IsNullOrEmpty(Me.ErrorMessage) Then
                FailureReason = FailureReason & Me.ErrorMessage & vbCrLf
            End If

            ' tax group id
            Dim TempTaxGroupId As Integer
            TempTaxGroupId = oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.TaxGroup, Me.TaxGroupId, "TaxGroupId", oSAMErrorCollection, "NOTPASSED", Me.TaxGroupCode)
            If TempTaxGroupId = SAMGetAndValidateListItemFromCodeReturnValues.ListItemNotFound Then
                ' build the actual error message for the error we want to raise
                FailureReason = FailureReason + "Invalid Tax Group Id Specified := " + Me.TaxGroupId.ToString() + vbCrLf
            End If

            ' tax band id
            Dim TempTaxBandId As Integer
            TempTaxBandId = oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.TaxBand, Me.TaxBandId, "TaxBandId", oSAMErrorCollection)
            If TempTaxBandId = SAMGetAndValidateListItemFromCodeReturnValues.ListItemNotFound Then
                ' build the actual error message for the error we want to raise
                FailureReason = FailureReason + "Invalid Tax Band Id Specified := " + Me.TaxBandId.ToString() + vbCrLf
            End If

            ' if its a percentage based tax 
            If IsValue = False Then

                '' validate that the percentage is a valid figure
                If Me.TaxPercentage < 0 OrElse Me.TaxPercentage > 100 Then

                    ' raise an error tax percentage invalid
                    ' build the actual error message for the error we want to raise
                    FailureReason = FailureReason + "Invalid TaxPercentage specified :" + Me.TaxPercentage.ToString() + vbCrLf

                End If

            End If

            If Me.ClassOfBusinessId > 0 Then
                ' class of business id
                Dim TempClassOfBusinessId As Integer
                TempClassOfBusinessId = oBusiness.GetAndValidateListItemFromId(Core.STSListType.PMLookup, PMLookupTable.ClassOfBusiness, Me.ClassOfBusinessId, "ClassOfBusinessId")
                If TempClassOfBusinessId = SAMGetAndValidateListItemFromCodeReturnValues.ListItemNotFound Then
                    ' build the actual error message for the error we want to raise
                    FailureReason = FailureReason + "Invalid Class Of Business Id specified. Class Of Business Id:= " + Me.ClassOfBusinessId.ToString() & " could not be found." + vbCrLf
                End If
            End If
            ''**********************************************
            ''* VALIDATE TAX GROUP / TAX BAND RELATIONSHIP *
            ''**********************************************

            Dim TaxGroupTaxBandDataView As DataView = ClaimDetails.TaxGroupTaxBandDetails

            ' Specify the Filter
            Dim sFilter As String = "tax_group_id = " + Me.TaxGroupId.ToString + " And tax_band_id = " + Me.TaxBandId.ToString

            ' Create a New Data View filtered by the ID
            Dim FilteredDataView As DataView = New DataView(TaxGroupTaxBandDataView.Table, sFilter, "", DataViewRowState.CurrentRows)

            If FilteredDataView Is Nothing Or FilteredDataView.Count = 0 Then
                FailureReason = FailureReason + "Invalid tax group / tax band relationship. " +
                            " No relationship could be found for tax group id = " + Me.TaxGroupId.ToString() +
                            " and tax band id = " + Me.TaxBandId.ToString() + "." + vbCrLf
            End If

            ''**************************
            ''* VALIDATE CURRENCY CODE *
            ''**************************

            ' currency code
            Dim TempCurrencyId As Integer
            TempCurrencyId = oBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Currency, Me.TaxCurrencyCode, "CurrencyCode", oSAMErrorCollection)
            If TempCurrencyId = SAMGetAndValidateListItemFromCodeReturnValues.ListItemNotFound Then
                ' build the actual error message for the error we want to raise
                FailureReason = FailureReason + "Invalid Currency Code specified. Currency Code :=" + Me.TaxCurrencyCode + " could not be found." + vbCrLf
            End If

            ' if there is a tax value 
            If Me.TaxValue <> 0 Then

                ' if the tax item has been returned in a currency other than
                ' the payment currency 
                If ClaimReceipt.CurrencyId <> TempCurrencyId Then

                    Dim TaxValueInPaymentCurrency As Decimal

                    Try

                        ' then the tax amount needs to be converted into the payment currency
                        oCoreSAMBusiness.CurrencyToCurrencyConversion(TempCurrencyId, Me.TaxValue, ClaimDetails.Source.SourceKey, ClaimReceipt.CurrencyId, TaxValueInPaymentCurrency, con)

                        Me.TaxCurrencyCode = ClaimReceipt.CurrencyCode
                        Me.CurrencyId = ClaimReceipt.CurrencyId
                        Me.TaxValue = TaxValueInPaymentCurrency

                    Catch ex As Exception

                        FailureReason = FailureReason + "Invalid Currency Code specified." +
                           "Unable to convert specified tax amount from Currency Code:=" + Me.TaxCurrencyCode +
                                        " to Payment Currency Code := " + ClaimReceipt.CurrencyCode

                        ' do not rethrow this exception 
                        ' the failure reason should be returned by the business rules error defined below

                    End Try

                End If
            End If

            '**************************************
            ' Throw the validation error here only 
            '**************************************

            If Not String.IsNullOrEmpty(FailureReason) Then

                ' override any existing errors in the collection
                ' and raise the more specific business rule validation error
                oSAMErrorCollection = New SAMErrorCollection
                oSAMErrorCollection.AddBusinessRule(
                    SAMBusinessErrors.ValidationOfScriptGeneratedTaxCalculationItemsFailed,
                    SAMBusinessErrors.ValidationOfScriptGeneratedTaxCalculationItemsFailed.ToString(),
                    TaxArrayItemDefinition + vbCrLf + ": Failure Reason/s:" + FailureReason)
                oSAMErrorCollection.CheckForErrors()

            End If

        End Sub

    End Class
    
    '''<summary>
    '''Tech Spec(Jigar Pandya)- UIIC WR24 - OpenClaim - Check Unpaid Premium.doc,7.1.2.2.3
    '''</summary>
    '''<param name="request">BaseCheckUnpaidPremiumRequestType</param>
    '''<remarks></remarks>
    Public Function CheckUnpaidPremium(ByVal request As BaseCheckUnpaidPremiumRequestType) As BaseCheckUnpaidPremiumResponseType

        Dim response As New BaseImplementationTypes.BaseCheckUnpaidPremiumResponseType
        Dim coreBusiness As New CoreBusiness(_SiriusUser)
        Dim samErrorsCollection As New SAMErrorCollection

        Dim sourceId As Integer
        Dim typeOfPackage As enumTypeOfPackage

        If request.GetType Is GetType(SAMForInsuranceV2ImplementationTypes.CheckUnpaidPremiumRequestType) Then
            typeOfPackage = enumTypeOfPackage.SAMForInsuranceV2Package
            response = New SAMForInsuranceV2ImplementationTypes.CheckUnpaidPremiumResponseType
        End If

        ' Structure Validation
        request.Validate(CObj(samErrorsCollection))
        samErrorsCollection.CheckForErrors()

        ' Lookup Codes to ensure they are valid
        sourceId = coreBusiness.GetAndValidateListItemFromCode(Core.STSListType.PMLookup, PMLookupTable.Source, request.BranchCode, "BranchCode", samErrorsCollection)

        samErrorsCollection.CheckForErrors()

        Dim dtPremiumStatus As DataTable = Nothing
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_Premium_Payment_Status")
                cmd.AddInParameter("@claim_number", SqlDbType.VarChar, 30).Value = request.ClaimNumber
                dtPremiumStatus = con.ExecuteDataTable(cmd)
            End Using
        End Using
        If dtPremiumStatus IsNot Nothing AndAlso dtPremiumStatus.Rows.Count > 0 Then
            response.InstalmentOverdue = CInt(dtPremiumStatus.Rows(0)("DefaultInstalmentCnt"))
        End If

        ' Dataset that will hold the returned results		
        Dim ds As DataSet = Nothing
        Using con As SiriusConnection = SiriusConnection.FromAny(connectionString:=SAMFunc.ConnectionString)
            Using cmd As SiriusCommand = SiriusCommand.FromProcedure("spu_get_Transactions_For_Policy")

                cmd.AddInParameter("@insurance_ref", SqlDbType.VarChar, 30).Value = request.InsuranceRef

                ds = con.ExecuteDataSet(cmd, "Row")

            End Using
        End Using

        ds.DataSetName = "BaseCheckUnpaidPremiumResponseTypeTransactions"

        If request.WCFSecurityToken = "" Then
        Dim xmlDoc As New System.Xml.XmlDocument
        xmlDoc.LoadXml(ds.GetXml)

        response.ResultDataset = xmlDoc.DocumentElement()
        End If

        response.ResultData = ds

        Return response

    End Function

