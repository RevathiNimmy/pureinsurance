                    cmd.AddInParameter("@tax_band_id", SqlDbType.Int).Value = dsTaxBandDet.Tables(0).Rows(taxBandsCNT).Item("tax_band_id")
                    cmd.AddInParameter("@premium", SqlDbType.Money).Value = oPaymentItem.CurrencyAmount
                    cmd.AddInParameter("@percentage", SqlDbType.Float).Value = Cast.ToDouble(dsTaxBandDet.Tables(0).Rows(taxBandsCNT).Item("percentage"), 0)
                    cmd.AddInParameter("@value", SqlDbType.Money).Value = Cast.ToDecimal(dsTaxBandDet.Tables(0).Rows(taxBandsCNT).Item("value"), 0)
