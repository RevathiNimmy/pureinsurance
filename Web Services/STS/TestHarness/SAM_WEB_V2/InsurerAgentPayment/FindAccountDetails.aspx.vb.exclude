    Public Sub total()
        Dim total1 As Double = 0
        Dim total2 As Double = 0

        For i As Integer = 0 To gvSearchResult.Rows.Count - 1
            total1 += Convert.ToDouble(gvSearchResult.Rows(i).Cells(9).Text)
            total2 += Convert.ToDouble(gvSearchResult.Rows(i).Cells(15).Text)
        Next
        'lbltotal.Text = total1
        'lbltotal2.Text = total2
        lblAccountBalance.Text = total1

    End Sub
