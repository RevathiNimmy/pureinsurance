    Protected Sub Page_Load(ByVal sender As Object, ByVal e As System.EventArgs) Handles Me.Load
        Dim UserToken As UsernameToken = GetUserToken("sirius", "sirius")

        mvGetAccountDetails.ActiveViewIndex = 1
        txtDocRef.Text = Session("DocRef")
        'set up the proxy object
        Dim oSAM As New SAMForInsuranceV2
        oSAM.SetClientCredential(UserToken)
        oSAM.SetPolicy("SamClientPolicy")
        lblAccountName.Text = Session("AccountCode")
        txtShortName.Text = Session("AccountCode")
        If Not Page.IsPostBack Then
            Try
                'Dim oFindPartyResponse As New BaseFindPartyResponseTypeRow
                'oFindPartyResponse = DirectCast(Session("FindPartyResponse"), BaseFindPartyResponseTypeRow)
                'lblAccountName.Text = oFindPartyResponse.ResolvedName
                'lblContactName.Text = oFindPartyResponse.ResolvedName
                'lblAccountCode.Text = oFindPartyResponse.ShortName
                'lblTele1.Text = oFindPartyResponse.ContactTelephoneNumber
                RadioButtonList1.Items(0).Enabled = True
                RadioButtonList2.Items(0).Enabled = True
                ' radOsBaseCurrency.Checked = True
                ' radTransactionCur.Checked = True
                chkShowOutstanding.Checked = True
                chkonlyfivehundred.Checked = True
                chkReverse.Checked = True


                BuildLists(oSAM, ddlBranch, STSListType.PMLookup, "SOURCE", "")
                BuildLists(oSAM, ddlDocGroup, STSListType.PMLookup, "DOCTYPEGROUP", "")
                BuildLists(oSAM, ddlDocType, STSListType.PMLookup, "DOCUMENTtYPE", "")
                BuildLists(oSAM, ddlCurrency, STSListType.PMLookup, "CURRENCY", "")
                BuildLists(oSAM, ddlDepartment, STSListType.PMLookup, "DEPARTMENT", "")


                'User defined Approach to bind the values
                PopulatePeriod()
                PopulateOperator()
                'Session("InsuranceFolderKey") = oResponse.InsuranceFolderKey
                'Session("InsuranceFileKey") = oResponse.InsuranceFileKey
                'Session("QuoteTimeStamp") = oResponse.QuoteTimeStamp
                'mvPolicyHeaders.ActiveViewIndex = 0


                'set up the proxy object

                oSAM.SetClientCredential(UserToken)
                oSAM.SetPolicy("SamClientPolicy")

                'txtDocRef.Text = Session("DocRef")
                Dim oFindAccountDetailsRequest As New GetAccountDetailsRequestType
                Dim oFindAccountDetailsResponse As New GetAccountDetailsResponseType

                With oFindAccountDetailsRequest

                    'Mandatory Input Fields
                   
                    .PartyCntSpecified = False
                    .AccountKeySpecified = False
                    '.PartyCnt = Convert.ToInt32(Session("PartyKey"))
                    .BranchCode = "HEADOFF"
                    .TransDetailKeys = Nothing
                    .DocumentKeySpecified = True
                    .DocumentRef = Session("DocRef")

                End With

                oFindAccountDetailsResponse = oSAM.GetAccountDetails(oFindAccountDetailsRequest)

                With oFindAccountDetailsResponse
                    If .Errors IsNot Nothing Then
                        'errors returned, so throw an exception
                        Throw New SamResponseException(.Errors)
                    End If
                End With
                ' lblTransactions.Text = "Transactions  Found : " & oFindAccountDetailsResponse.Transactions.Length
                gvSearchResult.DataSource = oFindAccountDetailsResponse.Transactions
                'oFindAccountDetailsResponse.Transactions(0).
                gvSearchResult.DataBind()
                total()
                'gv1.DataSource = oFindAccountDetailsResponse.Transactions
                'gv1.DataBind()
                lblAccountBalance.Text = totalCount

            Catch ex As Exception
                lblTransactions.Text = ex.Message
            End Try
        End If

    End Sub

