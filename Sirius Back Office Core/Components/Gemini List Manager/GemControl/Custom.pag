VERSION 5.00
Begin VB.PropertyPage Custom 
   Caption         =   "Custom"
   ClientHeight    =   3495
   ClientLeft      =   0
   ClientTop       =   0
   ClientWidth     =   5925
   PaletteMode     =   0  'Halftone
   ScaleHeight     =   3495
   ScaleWidth      =   5925
   Begin VB.CheckBox chkAutoCaption 
      Caption         =   "AutoCaption"
      Height          =   285
      Left            =   480
      TabIndex        =   1
      Top             =   1080
      Width           =   2700
   End
   Begin VB.CheckBox chkEnabled 
      Caption         =   "Enabled"
      Height          =   285
      Left            =   480
      TabIndex        =   0
      Top             =   720
      Width           =   2700
   End
End
Attribute VB_Name = "Custom"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = True
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = True
Private Sub chkAutoCaption_Click()
    Changed = True
End Sub


Private Sub chkEnabled_Click()
    Changed = True
End Sub


Private Sub PropertyPage_ApplyChanges()
    SelectedControls(0).AutoCaption = (chkAutoCaption.Value = vbChecked)
    SelectedControls(0).Enabled = (chkEnabled.Value = vbChecked)
End Sub


Private Sub PropertyPage_SelectionChanged()
    chkAutoCaption.Value = (SelectedControls(0).AutoCaption And vbChecked)
    chkEnabled.Value = (SelectedControls(0).Enabled And vbChecked)
End Sub


