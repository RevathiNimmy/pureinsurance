    Public Function LaunchIE() As Integer

        Dim result As Integer = 0
        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Spawn the default e-mail client so that the user can email PM
            m_lReturn = CType(ShellExecute(hwnd:=0, lpOperation:="open", lpFile:="http:\\www.insurancewindow.net", lpParameters:="", lpDirectory:=".", nShowCmd:=1), gPMConstants.PMEReturnCode)

            Return result

        Catch excep As System.Exception



            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            iPMFunc.LogMessage(iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="LaunchIE Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="LaunchIE", vErrNo:=Information.Err().Number, vErrDesc:=excep.Message, excep:=excep)

