    ' ***************************************************************** '
    '
    ' Name: FormLogic
    '
    ' Description:  Handles the logic when certain fields change
    '
    ' History: 17/08/2001 DD - Created.
    '
    ' ***************************************************************** '
    Private Sub FormLogic()


        Try

            Me.lblExample.Text = "= " & StringsHelper.Format(DateTime.Now, Me.txtDateFormat.Text)
            fraPath.Enabled = (chkDisableExport.CheckState = CheckState.Unchecked)
            fraFormat.Enabled = (chkDisableExport.CheckState = CheckState.Unchecked)

            For Each cnt As Control In ContainerHelper.Controls(Me)
                If (cnt.Parent.Name = fraPath.Name Or cnt.Parent.Name = fraFormat.Name) And Not (TypeOf cnt Is Label) Then
                    ControlHelper.SetEnabled(cnt, chkDisableExport.CheckState = CheckState.Unchecked)
                ElseIf (cnt.Parent.Name = fraPath.Name Or cnt.Parent.Name = fraFormat.Name) And TypeOf cnt Is Label Then
                    If chkDisableExport.CheckState = CheckState.Unchecked Then
                        CType(cnt, Label).ForeColor = Color.Black
                    Else
                        CType(cnt, Label).ForeColor = SystemColors.GrayText 'Disabled text colour
                    End If
                End If
            Next cnt

            Exit Sub



            ' Log Error Message
            iPMFunc.LogMessage(iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="FormLogic Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="FormLogic", vErrNo:=Information.Err().Number, vErrDesc:=Information.Err().Description)

        Catch exc As System.Exception
            NotUpgradedHelper.NotifyNotUpgradedElement("Resume in On-Error-Resume-Next Block")
        End Try


    End Sub
