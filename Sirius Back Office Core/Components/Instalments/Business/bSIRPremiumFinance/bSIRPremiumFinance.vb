                Return lReturn
            End If

            lReturn = .Parameters.Add(sName:="user_id", vValue:=gPMFunctions.ToSafeString(m_iUserID), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMInteger)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
