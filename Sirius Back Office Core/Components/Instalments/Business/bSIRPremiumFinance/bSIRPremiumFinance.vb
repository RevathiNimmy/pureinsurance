    Public Function ProcessMtaPF(ByVal v_lExistingInsuranceFileCnt As Integer, ByVal v_lInsuranceFileCnt As Integer, ByRef r_sErrorMessage As String) As Integer

        Dim result As Integer = 0
        Dim vTransArray(,) As Object = Nothing
        Dim vExistingPfArray As Object = Nothing
        Dim vNewPfArray As Array
        Dim vPfTransArray(,) As Object

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            r_sErrorMessage = ""

            m_oDatabase.Parameters.Clear()
            m_lReturn = m_oDatabase.Parameters.Add(sName:="InsuranceFileCnt", vValue:=gPMFunctions.ToSafeString(v_lInsuranceFileCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to add parameter InsuranceFileCnt", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessMtaPF")
                Return result
            End If
            m_lReturn = m_oDatabase.SQLSelect(sSQL:="spu_PFGetTransactionsFromInsuranceFile", sSQLName:="PFGetTransactionsFromInsuranceFile", bStoredProcedure:=True, vResultArray:=vTransArray)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed on SQLAction", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessMtaPF")
                Return result
            End If
            If Not Informations.IsArray(vTransArray) Then
                'No Transactions
                r_sErrorMessage = "No Transactions Found."
                Return result
            Else

                ReDim vPfTransArray(3, vTransArray.GetUpperBound(1))

                For lCount As Integer = 0 To vTransArray.GetUpperBound(1)

                    vPfTransArray(0, lCount) = vTransArray(0, lCount)

                    vPfTransArray(1, lCount) = vTransArray(1, lCount)

                    vPfTransArray(2, lCount) = vTransArray(2, lCount)

                    vPfTransArray(3, lCount) = vTransArray(4, lCount)
                Next lCount
            End If

            'Get Existing Plan to Modify
            m_lReturn = GetSingleFinancePlanFromInsFileCnt(v_lInsuranceFileCnt:=v_lExistingInsuranceFileCnt, r_vPFPremiumFinance:=vExistingPfArray)
            If m_lReturn = gPMConstants.PMEReturnCode.PMNotFound Then
                r_sErrorMessage = "Cannot Find Existing Pf Plan."
                Return result
            ElseIf (m_lReturn <> gPMConstants.PMEReturnCode.PMTrue) Then
                result = gPMConstants.PMEReturnCode.PMFalse
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed on GetSingleFinancePlanFromInsFileCnt.", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessMtaPF")
                Return result
            End If
            If Not Informations.IsArray(vExistingPfArray) Then
                r_sErrorMessage = "Cannot Find Existing Pf Plan."
                Return result
            End If
            vNewPfArray = vExistingPfArray

            If gPMFunctions.ToSafeDouble(vExistingPfArray(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) = bSIRPremFinConst.PFThirdParty Then

                m_lReturn = PostMTA_ThirdParty(vNewPfArray, vPfTransArray, vExistingPfArray)

                If m_lReturn = gPMConstants.PMEReturnCode.PMNotFound Then

                    r_sErrorMessage = "The Finance Plan does not have any rates setup for the premium been changed."

                ElseIf (m_lReturn <> gPMConstants.PMEReturnCode.PMTrue) Then

                    result = gPMConstants.PMEReturnCode.PMFalse
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed on PostMta_ThirdParty.", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessMtaPF")
                    Return result

                End If
            Else

                m_lReturn = PostMTA(vNewPfArray, vPfTransArray, vExistingPfArray)
                If m_lReturn = 9 Then
                    r_sErrorMessage = "Transactions do not meet the minimum mta amount"
                ElseIf m_lReturn = 99 Then
                    r_sErrorMessage = "Not enough instalments left to spread mta over"
                ElseIf m_lReturn = bSIRPremFinConst.k_PFPlanNoFinanceRate Then
                    r_sErrorMessage = "Finance Scheme does not offer MTA Instalments."
                ElseIf m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = gPMConstants.PMEReturnCode.PMFalse
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed on PostMta.", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessMtaPF")
                    Return result
                Else
                    vNewPfArray(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndLive
                    m_lReturn = UpdateExistingRecord(vNewPfArray, vNewPfArray(bSIRPremFinConst.k_PFPlanPFCnt, 0), vNewPfArray(bSIRPremFinConst.k_PFPlanPFVersion, 0))
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        result = gPMConstants.PMEReturnCode.PMFalse
                        bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed on UpdateExistingRecord.", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessMtaPF")
                        Return result
                    End If
                End If

            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="ProcessMtaPF Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessMtaPF", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

            Return result
        End Try
    End Function

    ' ***************************************************************** '
    ' Name: GetMtaInstalmentChange
    '
    ' Description: Calculates pf change, based on mta change.
    '
    ' History:
    '
    ' ***************************************************************** '
    Public Function GetMtaInstalmentChange(ByVal v_lPfPremFinanceCnt As Integer, ByVal v_lPfPremFinanceVersion As Integer, ByVal v_dblAdjustmentAmount As Double, ByRef r_dblTotal As Double, ByRef r_dblFirstInstalment As Double, ByRef r_dblOtherInstalments As Double, ByRef r_dblDeposit As Double) As Integer
        Dim result As Integer = 0
        Dim oACTInstalments As bACTInstalments.Business

        Dim vPremiumFinance As Object = Nothing
        Dim lPremiumFinanceCnt, lPremiumFinanceVersion As Integer
        Dim dtStartDate, dtEndDate As Date
        Dim lPartyCnt As Integer
        Dim vQuoteArray(,) As Object = Nothing
        Dim lInsuranceFileCnt As Integer
        Dim iDayOfWeek, iDayOfmonth As Integer
        Dim bHasProtection As Boolean

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            lPremiumFinanceCnt = v_lPfPremFinanceCnt
            lPremiumFinanceVersion = v_lPfPremFinanceVersion

            'Retrieve existing Plan

            m_lReturn = GetSingleFinancePlan(lPremiumFinanceCnt, lPremiumFinanceVersion, vPremiumFinance)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to Get Finance Plan", vApp:=ACApp, vClass:=ACClass, vMethod:="GetMtaInstalmentChange")
                Return result
            End If

            lInsuranceFileCnt = gPMFunctions.ToSafeLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0), 0)

            lPartyCnt = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanClientId, 0))
            bHasProtection = gPMFunctions.NullToDecimal(vPremiumFinance(bSIRPremFinConst.k_PFPlanCostOfProtection, 0)) > 0

            If gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0)) = "w" Then

                iDayOfWeek = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0))
            ElseIf gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0)) = "m" Then

                iDayOfmonth = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0))
            End If

            Dim cPlanOs, cTax, cOldTax, cFee, cOldFee, cAdjustment As Decimal
            If gPMFunctions.ToSafeDouble(vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) = bSIRPremFinConst.PFThirdParty Then

                'Third Party Instalments

                m_lReturn = Calculate_Quotes(gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanCompanyNo, 0)), "MTA", DateTime.Now, dtStartDate, dtEndDate, CDate("00:00:00"), iDayOfmonth, iDayOfWeek, v_dblAdjustmentAmount, bHasProtection, -1, False, lPartyCnt, vQuoteArray, v_lInsuranceFileCnt:=lInsuranceFileCnt, r_lPremFinanceCnt:=lPremiumFinanceCnt, r_lPremFinanceVer:=lPremiumFinanceVersion, v_bInHouse:=False)

                If Informations.IsArray(vQuoteArray) Then

                    For lCount As Integer = vQuoteArray.GetLowerBound(0) To vQuoteArray.GetUpperBound(0)

                        If gPMFunctions.ToSafeInteger(vQuoteArray(k_PFQuoteSchemeNo, lCount)) = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeNo, 0)) Then

                            r_dblTotal = gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteTotalInstalmentsAmount, lCount))

                            r_dblFirstInstalment = gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteFirstInstalmentAmount, lCount))

                            r_dblOtherInstalments = gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteOtherInstalmentAmount, lCount))

                            r_dblDeposit = gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteDepositAmount, lCount))

                            Exit For
                        End If
                    Next lCount
                End If
            Else

                'In-house Instalments

                lPremiumFinanceCnt = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0))

                lPremiumFinanceVersion = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))


                oACTInstalments = New bACTInstalments.Business
                m_lReturn = oACTInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

                m_lReturn = oACTInstalments.GetPlanOS(v_lPlanTransDetailID:=gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)), r_cOS:=cPlanOs)

                cTax = CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanTaxCost, 0))

                cOldTax = CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanTaxCost, 0))

                cFee = CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanInterestCost, 0))
                cOldFee = 0

                m_lReturn = GetMTAAdjustmentAmount(v_lPremFinanceCnt:=lPremiumFinanceCnt, v_lPremFinanceVersion:=lPremiumFinanceVersion, r_crAdjustmentAmount:=cAdjustment)

                m_lReturn = Calculate_Quotes(gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanCompanyNo, 0)), "MTA", DateTime.Now, dtStartDate, dtEndDate, CDate("00:00:00"), iDayOfmonth, iDayOfWeek, v_dblAdjustmentAmount + cAdjustment, bHasProtection, -1, False, lPartyCnt, vQuoteArray, v_lInsuranceFileCnt:=lInsuranceFileCnt, r_lPremFinanceCnt:=lPremiumFinanceCnt, r_lPremFinanceVer:=lPremiumFinanceVersion, v_bInHouse:=False)

                If Informations.IsArray(vQuoteArray) Then

                    For lCount As Integer = vQuoteArray.GetLowerBound(0) To vQuoteArray.GetUpperBound(0)

                        If gPMFunctions.ToSafeInteger(vQuoteArray(k_PFQuoteSchemeNo, lCount)) = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeNo, 0)) Then

                            r_dblTotal = gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteTotalInstalmentsAmount, lCount))

                            r_dblFirstInstalment = gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteFirstInstalmentAmount, lCount))

                            r_dblOtherInstalments = gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteOtherInstalmentAmount, lCount))

                            r_dblDeposit = gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteDepositAmount, lCount))

                            Exit For
                        End If
                    Next lCount
                End If

            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetMtaInstalmentChange Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetMtaInstalmentChange", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

            Return result
        End Try
    End Function

    Public Function GetValidSources(ByRef r_vUserSource(,) As Object) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "GetValidSources"

        Dim oPMUser As New Bpmuser.Business
        Dim oSource As New bPMSource.Business
        Dim sCode As String = String.Empty
        Dim sDesc As String = String.Empty
        Dim vValue As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Get instance of bPMUser.Business

            oPMUser = New Bpmuser.Business
            m_lReturn = oPMUser.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "sClassName:=bPMUser.Business", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get instance of bPMSource.Business

            oSource = New bPMSource.Business
            m_lReturn = oSource.Initialise(sUserName:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "sClassName:=bPMSource.Business", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Is this system a multi-ledger system

            bPMFunc.getProductOptionValue(v_sUsername:=m_sUsername, v_sPassword:=m_sPassword, v_iUserID:=m_iUserID, v_iMainSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_iCurrencyID:=m_iCurrencyID, v_iLogLevel:=m_iLogLevel, v_sCallingAppName:=m_sCallingAppName, v_vOptionNumber:=gPMConstants.SIRHiddenOptions.SIROPTMultiTreeAccounting, v_vBranch:=m_iSourceID, r_vUnderwriting:=vValue)
            If gPMFunctions.NullToString(vValue) = "1" Then
                'This is a multi-ledger system so only return the branch we are logged in under

                m_lReturn = oSource.GetDetails(vSourceID:=m_iSourceID)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("oSource.GetDetails", "vSourceId:=" & m_lSourceID, gPMConstants.PMELogLevel.PMLogError)
                End If

                m_lReturn = oSource.GetNext(vCode:=sCode, vDescription:=sDesc)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("oSource.GetNext", "vSourceId:=" & m_lSourceID, gPMConstants.PMELogLevel.PMLogError)
                End If

                ReDim r_vUserSource(2, 0)

                r_vUserSource(1, 1) = m_iSourceID

                r_vUserSource(2, 1) = sCode

                r_vUserSource(3, 1) = sDesc

            Else
                'This is a single-ledger system so return all sources allowed for the user

                m_lReturn = oPMUser.GetUserSources(r_vSourceArray:=r_vUserSource, v_vUserID:=m_iUserID)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("oPMUser.GetUserSources", "v_vUserID:=" & m_iUserID, gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            Return result
        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here

        Finally

            ' Do any tidy up, e.g. Set x = Nothing here
            If Not (oPMUser Is Nothing) Then

                oPMUser.Dispose()
                oPMUser = Nothing
            End If
            If Not (oSource Is Nothing) Then

                oSource.Dispose()
                oSource = Nothing
            End If


        End Try
        Return result
    End Function

