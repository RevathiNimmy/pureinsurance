        Return SettlePlanCalculate(v_vPremiumFinance:=v_vPremiumFinance, r_crSettlement:=r_crSettlement, r_crRefund:=r_crRefund, r_dtNextInstalmentDate:=r_dtNextInstalmentDate, r_dtNextInstalmentDatePlus1:=#12/30/1899#, r_dtLastInstalmentDate:=#12/30/1899#, r_dtLastPaidInstalmentDate:=#12/30/1899#, r_vSettlementFormatted:=Nothing)
