            m_lReturn = .Parameters.Add(sName:="Instance3", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
