        Return InsertNewVersion(v_vExistingPF:=v_vExistingPF, v_lPremiumFinanceCnt:=v_lPremiumFinanceCnt, v_lPremiumFinanceVersion:=v_lPremiumFinanceVersion, v_vPremiumFinanceMTA:=v_vPremiumFinanceMTA, v_dtNextPaymentDate:=v_dtNextPaymentDate, v_lInsuranceFileCnt:=0, v_lPlanTransID:=0)
