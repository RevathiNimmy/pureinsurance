                .Add("cardholder_address1", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanCardholderAddress1, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("cardholder_address2", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanCardholderAddress2, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("cardholder_address3", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanCardholderAddress3, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("cardholder_address4", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanCardholderAddress4, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("cardholder_postcode", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanCardholderPostcode, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("card_type", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanCardType, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("provider_collect_deposit", NullIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanProviderCollectDeposit, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("datebankdetailschanged", NullIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanDateBankDetailsChanged, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMDate)
                .Add("tax_group_id", NullIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanTaxGroupID, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                .Add("source_id", gPMFunctions.ToSafeInteger(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSource_ID, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                .Add("sub_branch_id", gPMFunctions.ToSafeInteger(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSubBranchID, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                .Add("batch_id", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong) '(RC) PLICO 9-10
                If Convert.IsDBNull(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSGSchemeType, 0)) Then
                    .Add("scheme_type", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                Else
                    .Add("scheme_type", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSGSchemeType, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                End If

                If Convert.IsDBNull(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSGSchemeType, 0)) Then
                    .Add("scheme_code", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                Else
                    .Add("scheme_code", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSGSchemeCode, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                End If
                .Add("sBusinessIdentifierCode", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.kBIC, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("sInternationalBankAccountNumber", BlankIfEmpty(r_vNewPFPlan(bSIRPremFinConst.kIBAN, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
                .Add("CardHolderCountry", Convert.ToString(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanCardholderCountryID, 0)).Trim(), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            End With

            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACAddNewPFPremiumFinanceversionSQL, sSQLName:=ACAddNewPFPremiumFinanceVersionName, bStoredProcedure:=ACAddNewPFPremiumFinanceVersionStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                nResult = m_lReturn
                m_lReturn = m_oDatabase.SQLRollbackTrans()
                Return nResult
            End If

            m_oDatabase.Parameters.Clear()
            m_oDatabase.Parameters.Add("PremiumFinanceCnt", v_lPremiumFinanceCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            m_oDatabase.Parameters.Add("PremiumFinanceVersion", nOldPlanVerNo, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            m_oDatabase.Parameters.Add("Status", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(bSIRPremFinConst.PFStatusIndSuperseded)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)

            'Mark the old version as superseded
            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACPFPremiumFinanceUpdateStatusSQL, sSQLName:=ACPFPremiumFinanceUpdateStatusName, bStoredProcedure:=ACPFPremiumFinanceUpdateStatusStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                nResult = m_lReturn
                m_lReturn = m_oDatabase.SQLRollbackTrans()
                Return nResult
            End If

            '=======================================================
            If IsSinglePlanParty(v_lPartyCnt:=m_lInsuranceFileCnt, r_vSinglePlanParty:=oSinglePlanParty) <> gPMConstants.PMEReturnCode.PMTrue Then
            End If

            If Informations.IsArray(oSinglePlanParty) Then
                If gPMFunctions.ToSafeBoolean(oSinglePlanParty(0, 0)) Then
                    m_bIsSinglePlanParty = True
                End If
            End If
            If m_bIsSinglePlanParty Then
                m_oDatabase.Parameters.Clear() '' PN 4241

                'm_lReturn = AddInputParameter(v_sName:="insurance_file_cnt", v_vValue:=m_lInsuranceFileCnt, v_iType:=gPMConstants.PMEDataType.PMLong)
                bPMAddParameter.AddParameterLite(m_oDatabase, "insurance_file_cnt", m_lInsuranceFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
                m_lReturn = m_oDatabase.SQLSelect(sSQL:=kGetLeadAgentSQL, sSQLName:=kGetLeadAgentName, bStoredProcedure:=True, vResultArray:=oLeadAgent)
                If Informations.IsArray(oLeadAgent) Then
                    bPMAddParameter.AddParameterLite(m_oDatabase, "pfprem_finance_cnt", v_lPremiumFinanceCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
                    bPMAddParameter.AddParameterLite(m_oDatabase, "pfprem_finance_version", nNewPlanVerNo, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                    bPMAddParameter.AddParameterLite(m_oDatabase, "agent_cnt", gPMFunctions.ToSafeInteger(oLeadAgent(0, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    m_lReturn = m_oDatabase.SQLAction(sSQL:=kPFPremiumFinanceAgentUpdSQL, sSQLName:=kPFPremiumFinanceAgentUpdName, bStoredProcedure:=True)

                    r_vNewPFPlan(bSIRPremFinConst.k_PFPlanAgentCnt, 0) = gPMFunctions.ToSafeInteger(oLeadAgent(0, 0))
                End If
                AddParameterLite(m_oDatabase, "pfprem_finance_cnt", CLng(v_lPremiumFinanceCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
                AddParameterLite(m_oDatabase, "pfprem_finance_version", nNewPlanVerNo, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                AddParameterLite(m_oDatabase, "insurance_file_cnt", m_lInsuranceFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                m_lReturn = m_oDatabase.SQLAction(
                        sSQL:=kPFTransactionidUpdSQL,
                        sSQLName:=kPFTransactionidUpdName,
                        bStoredProcedure:=True)
            End If
            '========================================================
            ' START CHANGES - Changed By: AAB  - Changed On: 13-Oct-2003 14:05
            '

            ' Now re-save the reference number and any other details

            ' The autogenerated plan reference is now simply the PFPrem_Finance_Cnt
            ' This is in order to reduce the size to be within the 12 character limit
            ' imposed by CC Processing and the 18 character limit imposed by BACS
            'r_vNewPFPlan(k_PFPlanAutoGenPlanRef, 0) = r_vNewPFPlan(k_PFPlanPFCnt, 0)

            'MKW190903 START

            r_vNewPFPlan(bSIRPremFinConst.k_PFPlanFinCollPlanRef, 0) = StringsHelper.Format(gPMFunctions.ToSafeInteger(sICCS), "0000") & StringsHelper.Format(gPMFunctions.ToSafeInteger(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanPFCnt, 0)), "0000") & StringsHelper.Format(gPMFunctions.ToSafeInteger(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanPFVersion, 0)), "00")
            'MKW190903 END

            'sw reset the status so that when the existing record is updated it will leave the
            'status as saved 03/07/2003

            r_vNewPFPlan(bSIRPremFinConst.k_PFPlanStatusInd, 0) = Nothing

            m_lReturn = UpdateExistingRecord(r_vNewPFPlan, r_vNewPFPlan(bSIRPremFinConst.k_PFPlanPFCnt, 0), r_vNewPFPlan(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                nResult = m_lReturn
                m_lReturn = m_oDatabase.SQLRollbackTrans()
                Return nResult
            End If
            Dim iBaseCurrencyID As Integer
            m_lReturn = m_oCurrencyConvert.GetBaseCurrency(v_lCompanyId:=gPMFunctions.ToSafeLong(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSource_ID, 0)), r_iBaseCurrencyID:=iBaseCurrencyID)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oCurrencyConvert.GetBaseCurrency", "v_lCompanyID:=" & gPMFunctions.ToSafeLong(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSource_ID, 0)), gPMConstants.PMELogLevel.PMLogError)
            End If
            m_lReturn = CalculateTax(lTaxGroupID:=gPMFunctions.ToSafeLong(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanTaxGroupID, 0)), iCurrencyID:=iBaseCurrencyID, crTaxableAmount:=gPMFunctions.ToSafeCurrency(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanFinanceCharge, 0)), r_crTaxAmount:=0, bCalculateOnly:=False, lInsuranceFileCnt:=gPMFunctions.ToSafeLong(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0)), lPFPremFinanceCnt:=v_lPremiumFinanceCnt, lPFPremFinanceVersion:=nNewPlanVerNo)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("CalculateTax", "lTaxGroupID:=" & gPMFunctions.ToSafeLong(r_vNewPFPlan(bSIRPremFinConst.k_PfPlanTaxGroupID, 0)), gPMConstants.PMELogLevel.PMLogError)
            End If
            'TR - Create the instalment records
            ' RAW 27/03/2003 : removed vPremiumFinanceTransactions argument

            If Val(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) <> bSIRPremFinConst.PFThirdParty AndAlso Val(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) <> bSIRPremFinConst.PFThirdPartyViaStargate AndAlso Convert.ToString(r_vNewPFPlan(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) <> "TP" Then 'MKW120903 PF 3rd Party MTA
                m_lReturn = SaveInstalments(r_vNewPFPlan)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    nResult = m_lReturn
                    m_lReturn = m_oDatabase.SQLRollbackTrans()
                    Return nResult
                End If

                ' RAW 13/11/2003 : CQ1765 : removed code to DeleteCancelledInstalments because instalments are needed by stats when cancelling the old plan version

            End If 'MKW120903 PF 3rd Party MTA

            m_lReturn = m_oDatabase.SQLCommitTrans()
            Return nResult

        Catch excep As System.Exception

            nResult = gPMConstants.PMEReturnCode.PMError
            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="InsertSupercedingPlan Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="InsertSupercedingPlan", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)
            Return nResult
        End Try
    End Function
