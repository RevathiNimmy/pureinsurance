    Public Function GenerateRenewalQuote(ByVal lRenewalInsuranceFileCnt As Integer) As Integer
        ' ---------------------------------------------------------------------------
        ' PROCEDURE NAME: GenerateRenewalQuote
        ' PURPOSE: Takes the Renewal Insurance File and generates an Instalments Quote
        ' for the Renewal based on the original plan
        ' AUTHOR: Danny Davis
        ' DATE: 16 December 2003, 11:26:14
        ' RETURNS: PMTrue for success
        ' CHANGES:
        ' ---------------------------------------------------------------------------

        Dim result As Integer = 0
        Dim lOldInsuranceFileCnt As Integer
        Dim vPFArray(,) As Object = Nothing
        Dim vPFRenArray(,) As Object = Nothing
        Dim cAmountToFinance As Decimal
        Dim lPartyCnt, lPremiumFinanceCnt, lPRemiumFinanceVer As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Get the original insurance file that is being renewed
            With m_oDatabase
                .Parameters.Clear()
                .Parameters.Add("renewal_insurance_file_cnt", gPMFunctions.ToSafeString(lRenewalInsuranceFileCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                .Parameters.Add("old_insurance_file_cnt", gPMFunctions.ToSafeString(DBNull.Value.ToString), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMLong)

                .Parameters.Add("party_cnt", gPMFunctions.ToSafeString(DBNull.Value.ToString), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMLong)

                .Parameters.Add("amount_to_finance", gPMFunctions.ToSafeString(DBNull.Value.ToString), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMCurrency)

                m_lReturn = .SQLSelect("spu_SIRRen_Get_Original_Insurance_File", "Select Original Insurance File from Renewal", True)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    ' Log Error.
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to get original insurance file cnt from renewal", vApp:=ACApp, vClass:=ACClass, vMethod:="GenerateRenewalQuote", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    result = gPMConstants.PMEReturnCode.PMFalse
                End If

                If Convert.IsDBNull(.Parameters.Item("old_insurance_file_cnt").Value) Or Informations.IsNothing(.Parameters.Item("old_insurance_file_cnt").Value) Then
                    'The Policy may not be on Instalments so we just quit here.
                    Return result
                End If
                lOldInsuranceFileCnt = .Parameters.Item("old_insurance_file_cnt").Value
                lPartyCnt = .Parameters.Item("party_cnt").Value
                cAmountToFinance = .Parameters.Item("amount_to_finance").Value
            End With

            'Make a copy of the original instalment plan
            m_lReturn = CopyInstalmentPlanForRenewals(lOldInsuranceFileCnt, lRenewalInsuranceFileCnt, lPartyCnt, lPremiumFinanceCnt, lPRemiumFinanceVer)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Or lPremiumFinanceCnt = 0 Then
                ' The Policy may not be on Instalments so we just quit here.
                ' Any problems will already be logged.
                Return result
            End If

            'Get the Plan from the Original Insurance File
            With m_oDatabase
                .Parameters.Clear()
                .Parameters.Add("InsuranceFileCnt", gPMFunctions.ToSafeString(lOldInsuranceFileCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                m_lReturn = .SQLSelect(ACGetPFGetPfFromInsuranceSingleSQL, ACGetPFGetPfFromInsuranceSingleName, ACGetPFGetPfFromInsuranceSingleStored,  , vPFArray)

                'TR - Make sure that this worked Ok. Cannot continue with this record
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to Get The Original " & "Plan record " & gPMFunctions.ToSafeString(lOldInsuranceFileCnt), ACApp, ACClass, "GenerateRenewalQuote")
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
            End With

            'Get the Plan for the Renewal Insurance File
            With m_oDatabase
                .Parameters.Clear()
                .Parameters.Add("InsuranceFileCnt", gPMFunctions.ToSafeString(lRenewalInsuranceFileCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                m_lReturn = .SQLSelect(ACGetPFGetPfFromInsuranceSingleSQL, ACGetPFGetPfFromInsuranceSingleName, ACGetPFGetPfFromInsuranceSingleStored,  , vPFRenArray)
                'TR - Make sure that this worked Ok. Cannot continue with this record
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to Get The Renewal " & "Plan record " & gPMFunctions.ToSafeString(lRenewalInsuranceFileCnt), ACApp, ACClass, "GenerateRenewalQuote")
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
            End With

            'Copy over the payment Informations
            For lCol As Integer = bSIRPremFinConst.k_PFPlanBankName To bSIRPremFinConst.k_PFPlanBrokerAddress4
                vPFRenArray(lCol, 0) = vPFArray(lCol, 0)
            Next lCol

            vPFRenArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0) = vPFArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0)
            For lCol As Integer = bSIRPremFinConst.k_PFPlanCCNumber To bSIRPremFinConst.k_PFPlanCCPin
                vPFRenArray(lCol, 0) = vPFArray(lCol, 0)
            Next lCol

            'Resave the Renewal Plan
            m_lReturn = UpdateExistingRecord(vPFRenArray, vPFRenArray(bSIRPremFinConst.k_PFPlanPFCnt, 0), vPFRenArray(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to resave the Renewal Plan", ACApp, ACClass, "GenerateRenewalQuote")
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'DC210206 PN26057 Check First Instalment Date Caters For Any Bank Details Previously Changed
            m_lReturn = CheckFirstInstalmentDateCorrect(vPFRenArray(bSIRPremFinConst.k_PFPlanPFCnt, 0), vPFRenArray(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to check payment date on Renewal Plan", ACApp, ACClass, "GenerateRenewalQuote")
                Return gPMConstants.PMEReturnCode.PMFalse
            End If
            Return result

            '----------------------------------------------------------------------------------------
            'Only for Debugging, the code will never execute this line
            '----------------------------------------------------------------------------------------


        Catch ex As Exception
            Select Case Informations.Err().Number
                Case Else
                    ' Log Error.
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="", vApp:=ACApp, vClass:=ACClass, vMethod:="GenerateRenewalQuote", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description, excep:=ex)

                    result = gPMConstants.PMEReturnCode.PMFalse
                    Return result
            End Select

        Finally

        End Try
        Return result
    End Function

