    '*********************************************************************************************
    ' Name : GetDocDetail
    '
    ' Desc : get document template id and document type id
    '
    ' Hist : Thinh Nguyen 29/11/2001 - Created
    '*********************************************************************************************
    Public Function GetDocDetail(ByVal v_lMode As Integer, ByVal v_lPremFinanceCnt As Integer, ByVal v_lPremFinanceVersion As Integer, ByRef r_lDocTemplateID As Integer, ByRef r_lDocTypeID As Integer) As Integer
        Return GetDocDetail(v_lMode:=v_lMode, v_lPremFinanceCnt:=v_lPremFinanceCnt, v_lPremFinanceVersion:=v_lPremFinanceVersion, r_lDocTemplateID:=r_lDocTemplateID, r_lDocTypeID:=r_lDocTypeID, r_sExpectedDocCode:="")
    End Function

    Public Function GetDocDetail(ByVal v_lMode As Integer, ByVal v_lPremFinanceCnt As Integer, ByVal v_lPremFinanceVersion As Integer, ByRef r_lDocTemplateID As Integer, ByRef r_lDocTypeID As Integer, ByRef r_sExpectedDocCode As String) As Integer

        Dim result As Integer = 0
        Dim vResultArray(,) As Object = Nothing
        Dim sSQL As String = String.Empty
        Dim sFieldName As String = String.Empty
        Dim sDocCode As New StringsHelper.FixedLengthString(10)
        Dim bRequery As Boolean
        Dim lInsuranceFileCnt, lInsuranceFolderCnt, lCount As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_oDatabase.Parameters.Clear()

            m_lReturn = m_oDatabase.Parameters.Add(sName:="PremFinanceCnt", vValue:=gPMFunctions.ToSafeString(v_lPremFinanceCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            m_lReturn = m_oDatabase.Parameters.Add(sName:="PremFinanceVersion", vValue:=gPMFunctions.ToSafeString(v_lPremFinanceVersion), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'which template do we want
            Select Case v_lMode
                ' HG22072003 - All The instalments docs still use the QuoteDocID field
                Case 1, 5, 6, 7, 8
                    sFieldName = "QuoteDocID"
                Case 2
                    sFieldName = "BankDocID"
                Case 3
                    sFieldName = "CreditDocID"
                Case 4
                    sFieldName = "ConfirmationDocID"
            End Select

            sSQL = "SELECT D.document_template_id, D.document_type_id, D.Code FROM PFScheme S, " &
                   "PFPremiumFinance F, Document_Template D " & Strings.ChrW(13) & Strings.ChrW(10) &
                   "WHERE F.pfprem_finance_cnt = {PremFinanceCnt} AND F.pfprem_finance_version = " &
                   "{PremFinanceVersion}" & Strings.ChrW(13) & Strings.ChrW(10) &
                   "AND F.CompanyNo = S.CompanyNo AND F.SchemeNo = S.SchemeNo AND F.SchemeVersion " &
                   "= S.SchemeVersion" & Strings.ChrW(13) & Strings.ChrW(10) &
                   "AND S." & sFieldName & " = D.document_template_id"

            m_lReturn = m_oDatabase.SQLSelect(sSQL:=sSQL, sSQLName:="Get Document Details", bStoredProcedure:=False, vResultArray:=vResultArray)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            If Not Informations.IsArray(vResultArray) Then
                Return gPMConstants.PMEReturnCode.PMNotFound
            End If

            r_lDocTemplateID = gPMFunctions.ToSafeInteger(vResultArray(0, 0))

            r_lDocTypeID = gPMFunctions.ToSafeInteger(vResultArray(1, 0))

            ' HG22072003 - Extract Document Code

            sDocCode.Value = gPMFunctions.ToSafeString(vResultArray(2, 0))

            ' HG22072003 - Using the document code returned, find the correct instalment
            '              document code (the current doc code with a specific string
            '              appended to it).

            bRequery = False

            'SJ 29/06/2004 - start
            If sDocCode.Value.ToUpper() = "PC_AGREEME" Then
                'This is the premium credit document, need to check if there are more
                'than three transactions.
                'If there are then use code "PC_AGREEM2"
                m_lReturn = GetPolicyID(v_lPfPremiumFinanceCnt:=v_lPremFinanceCnt, v_lPFPremiumFinanceVersion:=v_lPremFinanceVersion, r_lInsuranceFileCnt:=lInsuranceFileCnt, r_lInsuranceFolderCnt:=lInsuranceFolderCnt)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
                'Get a count of the number of transactions
                m_lReturn = GetTransactionCnt(v_lInsuranceFileCnt:=lInsuranceFileCnt, r_lCount:=lCount)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
                If lCount > 3 Then
                    sDocCode.Value = "PC_AGREEM2"
                    bRequery = True
                End If
            Else
                ' Find Plan Document
                Select Case v_lMode
                    Case 5
                        sDocCode.Value = sDocCode.Value.Trim() & "PLN"
                        bRequery = True
                    Case 6
                        sDocCode.Value = sDocCode.Value.Trim() & "CAN"
                        bRequery = True
                    Case 7
                        sDocCode.Value = sDocCode.Value.Trim() & "STL"
                        bRequery = True
                    Case 8
                        sDocCode.Value = sDocCode.Value.Trim() & "EDT"
                        bRequery = True
                End Select
            End If
            'SJ 29/06/2004 - end

            ' HG22072003 - Requery and find the correct document template id
            If bRequery Then

                ' HG22072003 - Return expected doc code (this can be used to if something
                '              goes wrong - e.g. does it exist?)
                r_sExpectedDocCode = sDocCode.Value.Trim()
                With m_oDatabase
                    .Parameters.Clear()

                    m_lReturn = .Parameters.Add(sName:="Code", vValue:=sDocCode.Value, iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMString)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return gPMConstants.PMEReturnCode.PMFalse
                    End If

                    m_lReturn = .Parameters.Add(sName:="document_template_id", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMLong)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return gPMConstants.PMEReturnCode.PMFalse
                    End If

                    'SJ 29/06/2004 - start
                    '            m_lReturn = .Parameters.Add(sName:="document_template_version_id", _
                    ''                    vValue:=0, _
                    ''                    idirection:=PMParamOutput, _
                    ''                    iDataType:=PMLong)
                    '
                    '            If m_lReturn <> PMTrue Then
                    '                GetDocDetail = PMFalse
                    '                Exit Function
                    '            End If
                    'SJ 29/06/2004 - end

                    m_lReturn = .Parameters.Add(sName:="document_type_id", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMLong)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return gPMConstants.PMEReturnCode.PMFalse
                    End If

                    m_lReturn = .Parameters.Add(sName:="Description", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMString)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return gPMConstants.PMEReturnCode.PMFalse
                    End If

                    ' HG22072003 - Get Document Template ID ..
                    m_lReturn = .SQLSelect(sSQL:=ACGetDocumentTemplateSQL, sSQLName:=ACGetDocumentTemplateName, bStoredProcedure:=ACGetDocumentTemplateStored, lNumberRecords:=gPMConstants.PMAllRecords, vResultArray:=vResultArray)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return gPMConstants.PMEReturnCode.PMFalse
                    End If

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return gPMConstants.PMEReturnCode.PMFalse
                    End If

                    ' HG 23072003 Get Results

                    If Convert.IsDBNull(m_oDatabase.Parameters.Item("document_template_id").Value) Or Informations.IsNothing(m_oDatabase.Parameters.Item("document_template_id").Value) Then
                        Return gPMConstants.PMEReturnCode.PMNotFound
                    Else
                        ' Return correct document template
                        r_lDocTemplateID = m_oDatabase.Parameters.Item("document_template_id").Value
                        r_lDocTypeID = m_oDatabase.Parameters.Item("document_type_id").Value
                    End If
                End With
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMFalse

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetDocDetail Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetDocDetail", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    '*********************************************************************************************
    ' Name : GetTaxBandsByTaxGroup
    '
    ' Desc : gets tax bands using tax group
    '
    ' Hist : Rahul Jaiswal 04/7/2005 - Created
    '*********************************************************************************************

    Public Function GetTaxBandsByTaxGroup(ByVal v_sTaxGroup As String, ByRef r_vTaxBands As Object) As Integer
        Dim result As Integer = 0
        Dim sSQL As String = ""

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_oDatabase.Parameters.Clear()

            m_lReturn = m_oDatabase.Parameters.Add(sName:="TaxGroup", vValue:=v_sTaxGroup, iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            sSQL = "SELECT  A.account_id, 'NOTA'+tb.code tax_account_code " &
                   "FROM Tax_group_tax_band tg  JOIN Tax_Band tb " & Strings.ChrW(13) & Strings.ChrW(10) &
                   "LEFT JOIN " &
                   "Account A ON A.short_code='NOTA'+TB.code " & Strings.ChrW(13) & Strings.ChrW(10) &
                   "ON tg.tax_band_id = tb.tax_band_id " &
                   "WHERE tg.tax_group_id = {TaxGroup}"

            m_lReturn = m_oDatabase.SQLSelect(sSQL:=sSQL, sSQLName:="Get Tax Bands by Tax Group", bStoredProcedure:=False, vResultArray:=r_vTaxBands)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMFalse

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetTaxBandsByTaxGroup Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetTaxBandsByTaxGroup", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

