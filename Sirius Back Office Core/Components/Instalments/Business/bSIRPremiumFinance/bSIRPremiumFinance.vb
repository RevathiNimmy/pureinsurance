            bPMAddParameter.AddParameterLite(m_oDatabase, "pfprem_finance_cnt", gPMFunctions.ToSafeLong(v_lPfPremFinanceCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
            bPMAddParameter.AddParameterLite(m_oDatabase, "pfprem_finance_version", gPMFunctions.ToSafeLong(v_lPfPremFinanceVersion), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
            bPMAddParameter.AddParameterLite(m_oDatabase, "batch_id", gPMFunctions.ToSafeLong(v_lBatchId), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)

            'Update existing record
            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACUpdatePFPremiumFinanceBatchIDSQL, sSQLName:=ACUpdatePFPremiumFinanceBatchIDName, bStoredProcedure:=ACUpdatePFPremiumFinanceBatchIDStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn

            End If

            Return gPMConstants.PMEReturnCode.PMTrue

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="UpdateBatchID Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="UpdateBatchID", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            m_oDatabase.SQLRollbackTrans()

            Return result

            Return result
        End Try
    End Function

