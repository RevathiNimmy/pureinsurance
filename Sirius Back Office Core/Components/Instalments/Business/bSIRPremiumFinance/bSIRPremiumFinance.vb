    ' Name: AllocateDeposit
    '
    ' Description: Allocate the cash/cheque deposit to the journal
    ' History: PN11263
    '
    ' ***************************************************************** '
    Public Function AllocateDeposit(ByVal lAccountId As Integer, ByVal vDepositDetails As Object) As Integer

        Dim result As Integer = 0
        Dim oAllocateManual As bACTAllocationManual.Business
        Dim vKeys, vDepositTransaction As Object

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ReDim vDepositTransaction(0)

            vDepositTransaction(0) = vDepositDetails

            'vParse = CStr(vDepositDetails).Split("|"c)

            'm_lAllocatedTransId = CInt(vParse(0))

            ReDim vKeys(1, 2)
            ' AccountID

            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 0) = ACTKeyNameAccountID

            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 0) = lAccountId

            ' Main Credit Transaction ID

            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 1) = ACTKeyNameTransDetailID

            'vKeys(vDepositDetails, gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1)
            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1) = m_vDepositJournal

            ' Matched Transactions

            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 2) = ACTKeyNameTransDetailIDs

            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 2) = vDepositTransaction

            ' Create an instance of the OrionLink business object


            oAllocateManual = New bACTAllocationManual.Business
            m_lReturn = oAllocateManual.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMError

                bPMFunc.LogMessage(m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to Initialise the manual alloction", vApp:=ACApp, vClass:=ACClass, vMethod:="AllocateDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                Return result
            End If

            m_lReturn = oAllocateManual.SetProcessModes(vTask:=gPMConstants.PMEComponentAction.PMEdit)

            ' Set the keys

            m_lReturn = oAllocateManual.SetKeys(vKeyArray:=vKeys)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                ' Log Error Message
                bPMFunc.LogMessage(m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to set navigator keys.", vApp:=ACApp, vClass:=ACClass, vMethod:="AllocateDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            ' Start it

            oAllocateManual.CompanyId = m_iSourceID

            m_lReturn = oAllocateManual.Start()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                ' Log Error Message
                bPMFunc.LogMessage(m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to start Allocation Manual.", vApp:=ACApp, vClass:=ACClass, vMethod:="AllocateDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            oAllocateManual.Dispose()
            Return result

        Catch excep As System.Exception

            ' Error.
            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="AllocateDeposit Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="AllocateDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function
    Private Function CalculateInstalmentDate4MonthlyPolicy(ByVal v_dtLastInstalmentDate As Date, ByVal v_iCustomerPreferredDay As Integer, ByVal v_DaysDelay As Integer, ByVal v_lStartLimit As Integer, ByRef r_dtOutputDate As Date) As Integer

        Dim result As Integer = 0


        Dim dtDelayDate, dtInstalmentDate, dtPreferredDate As Date
        Dim iDayNum As Integer

        result = gPMConstants.PMEReturnCode.PMTrue

        ' find the earliest date we can use

        If m_dtStartDate >= DateTime.Parse(DateTime.Now) Then
            ' use policy start date + daysdelay
            dtDelayDate = m_dtStartDate.AddDays(v_DaysDelay)
        Else
            ' this a back-dated policy so use todays date + daysdelay

            dtDelayDate = DateTime.Parse(DateTime.Now).AddDays(v_DaysDelay)
        End If

        ' get the customer's preferred date
        dtPreferredDate = m_dtStartDate
        iDayNum = Informations.DatePart("d", dtPreferredDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
        Do Until (iDayNum = v_iCustomerPreferredDay Or dtPreferredDate = m_dtEndDate)
            If dtPreferredDate < m_dtEndDate Then
                ' we haven't reached the policy enddate
                dtPreferredDate = dtPreferredDate.AddDays(1)

                ' does the preferred day actually exist in the current month
                If (v_iCustomerPreferredDay > 28) And (Informations.DatePart("d", dtPreferredDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1) < iDayNum) Then
                    ' no so use the 1st day of the next month
                    Exit Do
                Else
                    iDayNum = Informations.DatePart("d", dtPreferredDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
                End If
            End If
        Loop

        Dim dbNumericTemp As Double
        If Not Double.TryParse(gPMFunctions.ToSafeString(v_lStartLimit), NumberStyles.Number, CultureInfo.CurrentCulture.NumberFormat, dbNumericTemp) Then
            v_lStartLimit = 0
        End If

        ' use the preferred date only if it lies within the
        ' start & end range of the days delay
        If (dtPreferredDate >= dtDelayDate) And (v_DaysDelay + v_lStartLimit = 0) Then
            dtInstalmentDate = dtPreferredDate
        ElseIf (dtPreferredDate >= dtDelayDate) And (dtPreferredDate <= dtDelayDate.AddDays(v_lStartLimit)) Then
            dtInstalmentDate = dtPreferredDate
        Else
            dtInstalmentDate = dtDelayDate
        End If

        ' make sure this date is not before the last instalment date
        If m_dtLastInstalmentDate > dtInstalmentDate Then
            r_dtOutputDate = m_dtLastInstalmentDate
        Else
            r_dtOutputDate = dtInstalmentDate
        End If

        Return result

    End Function

    Private Function BankDetailsHaveChanged(ByRef v_vPreviousPlan(,) As Object, ByRef v_vNewPlan(,) As Object, ByRef r_bResult As Boolean) As Integer
        Dim result As Integer = 0

        Dim bDifferent As Boolean

        If Not Informations.IsArray(v_vPreviousPlan) Or Not Informations.IsArray(v_vNewPlan) Then
            bPMFunc.LogMessage(m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Supplied parameters are invalid", vApp:=ACApp, vClass:=ACClass, vMethod:="BankDetailsHaveChanged", vErrNo:=0, vErrDesc:="Supplied parameters are invalid")

        End If

        ' check bank details
        For iCnt As Integer = bSIRPremFinConst.k_PFPlanBankSortCode To bSIRPremFinConst.k_PFPlanBankAccountName

            If gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vPreviousPlan(iCnt, 0)).Trim()) <> gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vNewPlan(iCnt, 0)).Trim()) Then
                bDifferent = True
                Exit For
            End If
        Next iCnt

        ' check credit card details
        If Not bDifferent Then
            For iCnt As Integer = bSIRPremFinConst.k_PFPlanCCNumber To bSIRPremFinConst.k_PFPlanCCPin

                If iCnt = bSIRPremFinConst.k_PFPlanCCIssue Then

                    If gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vPreviousPlan(iCnt, 0)).Trim()) <> gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vNewPlan(iCnt, 0)).Trim()) Then

                        If (gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vPreviousPlan(iCnt, 0)).Trim()) = "0" And gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vNewPlan(iCnt, 0)).Trim()) = "") Or (gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vPreviousPlan(iCnt, 0)).Trim()) = "" And gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vNewPlan(iCnt, 0)).Trim()) = "0") Then
                            ' do nothing just different default values
                        Else
                            bDifferent = True
                            Exit For
                        End If
                    End If

                ElseIf gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vPreviousPlan(iCnt, 0)).Trim()) <> gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vNewPlan(iCnt, 0)).Trim()) Then
                    bDifferent = True
                    Exit For
                End If
            Next iCnt
        End If

        r_bResult = bDifferent

        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    Public Function GetSchemeCurrency(ByVal lPremiumFinanceCnt As Integer, ByVal lPremiumFinanceVersion As Integer, ByRef r_iCurrencyID As Integer, ByRef r_XRate As Double) As Integer
        ' ---------------------------------------------------------------------------
        ' PROCEDURE NAME: GetSchemeCurrency
        ' PURPOSE: Returns the Base Currency used by the Finance Scheme
        ' AUTHOR: Danny Davis
        ' DATE: 04 August 2004, 09:50 AM
        ' RETURNS: PMTrue for success
        ' CHANGES:
        ' ---------------------------------------------------------------------------

        Dim result As Integer = 0

        Try


            result = gPMConstants.PMEReturnCode.PMFalse
            Dim vResultArray As Object(,) = Nothing
            r_iCurrencyID = 0
            r_XRate = 1

            With m_oDatabase

                .Parameters.Clear()
                m_lReturn = .Parameters.Add(sName:="pfprem_finance_cnt", vValue:=gPMFunctions.ToSafeString(lPremiumFinanceCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return result
                End If

                m_lReturn = .Parameters.Add(sName:="pfprem_finance_version", vValue:=gPMFunctions.ToSafeString(lPremiumFinanceVersion), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return result
                End If

                m_lReturn = .SQLSelect(sSQL:="spu_PFScheme_GetCurrency", sSQLName:="spu_PFScheme_GetCurrency", bStoredProcedure:=True, vResultArray:=vResultArray)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return result
                End If

                If Informations.IsArray(vResultArray) Then
                    r_iCurrencyID = ToSafeInteger(vResultArray(5, 0))

                    If ToSafeInteger(vResultArray(2, 0)) = 1 Then
                        r_iCurrencyID = ToSafeInteger(vResultArray(0, 0))
                        r_XRate = ToSafeDouble(vResultArray(1, 0))
                    End If
                End If

            End With

            result = gPMConstants.PMEReturnCode.PMTrue

            Return result


        Catch ex As Exception
            Select Case Informations.Err().Number
                Case Else
                    ' Log Error.
                    bPMFunc.LogMessage(m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="", vApp:=ACApp, vClass:=ACClass, vMethod:="GetSchemeCurrency", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description, excep:=ex)

                    result = gPMConstants.PMEReturnCode.PMFalse

                    Return result
            End Select
        Finally

        End Try

        Return result

    End Function

