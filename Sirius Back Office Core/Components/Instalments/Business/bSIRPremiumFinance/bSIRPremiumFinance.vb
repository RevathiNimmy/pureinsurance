    Private Function GetPaidFinanceAmount(ByRef vFinancePlanArray(,) As Object) As Double
        'BE 4/9/2003 CQ345 - accumulate Financed amount paid to date.
        Dim dAmount As Double

        Dim iCount As Integer = vFinancePlanArray.GetUpperBound(1)

        For iIndex As Integer = 0 To iCount

            If gPMFunctions.ToSafeDouble(vFinancePlanArray(7, iIndex)) = 3 Then
                'Status = 3 (collected)
                'Financed amount paid = transaction amount - fee - tax - commission

                dAmount += (gPMFunctions.ToSafeDouble(gPMFunctions.ToSafeDouble(gPMFunctions.ToSafeDouble(gPMFunctions.ToSafeDouble(vFinancePlanArray(5, iIndex)) - gPMFunctions.ToSafeDouble(vFinancePlanArray(4, iIndex))) - gPMFunctions.ToSafeDouble(vFinancePlanArray(14, iIndex))) - gPMFunctions.ToSafeDouble(vFinancePlanArray(15, iIndex))))
            End If
        Next iIndex

        Return dAmount

    End Function

