            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACAddNewPFPremiumFinanceversionSQL, sSQLName:=ACAddNewPFPremiumFinanceVersionName, bStoredProcedure:=ACAddNewPFPremiumFinanceVersionStored)
            If m_lReturn <> PMEReturnCode.PMTrue Then
                nResult = m_lReturn
