    '*************************************************************************
    ' Name:         ReleasePlan
    ' Description:  For a given plan, changes status to Live (released) but
    '               only if the status was OnHold
    ' Note:         This is implemented as a seperate procedure to allow expansion
    '               to include any amendments to instalments that may be required.
    ' History :     Tracy Richards 17/07/03 - Changes status of Individual
    '               Instalments from Hold to New
    '*************************************************************************
    Public Function ReleasePlan(ByVal v_lPremiumFinanceCnt As Integer, ByVal v_lPremiumFinanceVersion As Integer) As Integer

        Dim result As Integer = 0
        Dim sSqlString As String

        Const k_sFunctionName As String = "ReleasePlan"

        Try

            'Tracy Richards 17/07/03 - Change status of Instalments from Hold to New
            ' Start a transaction because we are updating two tables now
            m_lReturn = m_oDatabase.SQLBeginTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = m_lReturn
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to begin transaction", ACApp, ACClass, k_sFunctionName)
                Return result
            End If

            'TR - SQL string to update PFPremiumFinance
            sSqlString = "UPDATE PFPremiumFinance SET statusind = '" & bSIRPremFinConst.PFStatusIndLive & "' WHERE statusind = '" & bSIRPremFinConst.PFStatusIndOnHold & "' AND pfprem_finance_cnt = " & gPMFunctions.ToSafeString(v_lPremiumFinanceCnt) &
                " AND pfprem_finance_Version = " & gPMFunctions.ToSafeString(v_lPremiumFinanceVersion)

            'TR - Run the Update
            m_lReturn = m_oDatabase.SQLAction(sSqlString, k_sFunctionName, False)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = m_lReturn
                m_lReturn = m_oDatabase.SQLRollbackTrans()
                Return result
            End If

            'Tracy Richards 17/07/03 - Change status of Instalments from Hold to New
            With m_oDatabase.Parameters
                .Clear()
                .Add("pfprem_finance_cnt", gPMFunctions.ToSafeString(v_lPremiumFinanceCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                .Add("pfprem_finance_Version", gPMFunctions.ToSafeString(v_lPremiumFinanceVersion), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            End With

            'PSL 16/05/2003 Issue 3849
            ' Set the instalments to New from on hold
            m_lReturn = m_oDatabase.SQLAction(ACReleasePFInstalmentsSQL, ACReleasePFInstalmentsName, ACReleasePFInstalmentsStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = m_lReturn
                m_lReturn = m_oDatabase.SQLRollbackTrans()
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to release Instalments", ACApp, ACClass, k_sFunctionName)
                Return result
            End If

            m_lReturn = m_oDatabase.SQLCommitTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = m_lReturn
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to commit transaction", ACApp, ACClass, k_sFunctionName)
                Return result
            End If

            Return gPMConstants.PMEReturnCode.PMTrue

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError
            bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "ReleasePlan Failed", ACApp, ACClass, k_sFunctionName, Informations.Err().Number, excep.Message, excep:=excep)
            Return result

        End Try
    End Function

