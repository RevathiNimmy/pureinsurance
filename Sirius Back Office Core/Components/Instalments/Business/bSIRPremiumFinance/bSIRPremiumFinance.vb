                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to add parameter SchemeNo", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessPF")
                Return result
            End If
            m_lReturn = m_oDatabase.SQLSelect(sSQL:="spu_PFPremiumFinance_GetSchemeVersionForSchemeNo", sSQLName:="spu_PFPremiumFinance_GetSchemeVersionForSchemeNo", bStoredProcedure:=True, vResultArray:=vSchemeArray)
