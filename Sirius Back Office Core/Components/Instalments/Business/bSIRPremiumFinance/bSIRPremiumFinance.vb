    Public Function OverrideSGRate(ByVal v_lQuoteIndex As Integer, ByRef v_vQuoteArray(,) As Object, ByVal v_dNewRate As Double) As Integer
        Dim result As Integer = 0
        Try

            Dim oObject As bSIRPFSubmit.Application
            Dim vArray(,) As Object = Nothing
            Dim lSchemeID As Integer
            Dim vTmpArray(,) As Object
            Dim sTmp As String = ""
            Dim bCalcAPR As Boolean

            result = gPMConstants.PMEReturnCode.PMTrue

            If gPMFunctions.ToSafeString(v_vQuoteArray(k_PFQuoteSchemeName, v_lQuoteIndex)) = "CLOSEIP" Then

                v_vQuoteArray(k_PFQuoteInterestRate, v_lQuoteIndex) = v_dNewRate
                bCalcAPR = True
            Else

                m_lReturn = GetAllPFRFs(vArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception()
                End If

                'get an instance of our submit component
                ' Replace use of ObjectManager when creating objects. PN23065.

                oObject = New bSIRPFSubmit.Application
                m_lReturn = oObject.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception()
                End If

                If Not (Informations.IsArray(vArray)) Then
                    Throw New Exception()
                End If

                lSchemeID = -1

                For x As Integer = vArray.GetLowerBound(1) To vArray.GetUpperBound(1)

                    If gPMFunctions.ToSafeDouble(vArray(2, x)) = gPMFunctions.ToSafeInteger(v_vQuoteArray(k_PFQuoteSchemeNo, v_lQuoteIndex)) Then
                        lSchemeID = x
                    End If
                Next x

                If lSchemeID = -1 Then
                    Throw New Exception()
                End If

                With oObject

                    .BrokerID = GetSGBrokerID(vArray, lSchemeID, m_crChangeToFinanceAmount)

                    .url = gPMFunctions.NullToString(vArray(64, lSchemeID))

                    .PartyCnt = m_lPartyCnt

                    .ProviderCode = gPMFunctions.ToSafeString(vArray(65, lSchemeID)).Trim()

                    .UserName = gPMFunctions.NullToString(vArray(66, lSchemeID))

                    .Password = gPMFunctions.NullToString(vArray(67, lSchemeID))

                    .Premium = m_crChangeToFinanceAmount

                    .MessageType = 4 'GetRates

                    .Timeout = gPMFunctions.NullToLong(vArray(69, lSchemeID))

                    .Instalments = gPMFunctions.NullToLong(v_vQuoteArray(k_PFQuoteInstalmentsToPay, v_lQuoteIndex))

                    .Terms = gPMFunctions.NullToLong(v_vQuoteArray(k_PFSGTerms, v_lQuoteIndex))

                    .Percentage = gPMFunctions.NullToDouble(v_vQuoteArray(k_PFOriginalRate, v_lQuoteIndex))

                    .OverrideRate = v_dNewRate

                    .InsuranceFileCnt = m_lInsuranceFileCnt

                    'and submit the quotes!

                    m_lReturn = .Submit()
                    If m_lReturn = gPMConstants.PMEReturnCode.PMError Then

                        m_sErrorText = .ErrorText
                        Return gPMConstants.PMEReturnCode.PMError
                    ElseIf m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Throw New Exception()
                    End If

                    'now fetch the result array from the component and add it to
                    'the quote array

                    vTmpArray = .RateArray
                End With

                'check that a rate exists
                If Not (Informations.IsArray(vTmpArray)) Then
                    Throw New Exception()
                End If

                'now we need to repopulate the quote array with the new data

                v_vQuoteArray(k_PFQuoteInstalmentsToPay, v_lQuoteIndex) = vTmpArray(2, 0)

                v_vQuoteArray(k_PFQuoteInterestRate, v_lQuoteIndex) = vTmpArray(3, 0)

                v_vQuoteArray(k_PFQuoteDepositAmount, v_lQuoteIndex) = vTmpArray(5, 0)

                v_vQuoteArray(k_PFQuoteAprRate, v_lQuoteIndex) = vTmpArray(6, 0)

                v_vQuoteArray(k_PFSGTerms, v_lQuoteIndex) = vTmpArray(7, 0)
                bCalcAPR = False
            End If

            m_lReturn = DoCalculation(v_lQuoteIndex, gPMFunctions.ToSafeDouble(v_vQuoteArray(k_PFQuoteInterestRate, v_lQuoteIndex)), 0, 0, AlignPremiumToOptions.AlignWithClientPreference, 0, CalculationType.CalculationTypeAmount, gPMFunctions.ToSafeDouble(v_vQuoteArray(k_PFQuoteDepositAmount, v_lQuoteIndex)), 0, CalculationType.CalculationTypeAmount, 0, CalculationType.CalculationTypeAmount, 0, 0, 0, 0, 0, v_vQuoteArray, , , bCalcAPR, gPMFunctions.ToSafeDouble(v_vQuoteArray(k_PFQuoteAprRate, v_lQuoteIndex)), gPMFunctions.ToSafeInteger(v_vQuoteArray(k_PFQuoteInstalmentsToPay, v_lQuoteIndex)), (DateTime.Today).Day)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception()
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to override rate", vApp:=ACApp, vClass:=ACClass, vMethod:="OverrideSGRate", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result
        End Try
    End Function

