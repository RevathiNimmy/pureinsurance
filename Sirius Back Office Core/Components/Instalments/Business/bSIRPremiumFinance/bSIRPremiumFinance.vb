    Public Function UpdateRenewedFinancePlanBankDetails(ByVal v_lOriginalInsuranceFileCnt As Long,
                                                      ByVal v_lRenewedInsuranceFileCnt As Long,
                                                      ByVal v_lPartyCnt As Long) As Integer


        Dim vResultArray(,) As Object = Nothing
        Dim vOriginalFinancePlan As Object = Nothing
        Dim vRenewalFinancePlan As Object = Nothing
        Dim lPremiumFinanceVer As Long
        Dim lPremiumFinanceCnt As Long
        Dim dtStartDate As Date
        Dim dtEndDate As Date
        Dim iDayOfWeekOrMonth As Integer

        Dim crAmountToFinance As Decimal
        Dim bHasProtection As Boolean
        Dim bProductChangedAtREN As Boolean
        Dim vQuoteArray(,) As Object = Nothing

        Dim lSelectedQuoteIndex As Integer
        Dim vPFPlanArray(,) As Object = Nothing
        Dim lSourceID As Long
        Dim lSubBranchID As Integer
        Dim Result As Integer

        Try

            Result = gPMConstants.PMEReturnCode.PMTrue

            m_oDatabase.Parameters.Clear()

            m_lReturn = GetSingleFinancePlanFromInsFileCnt(v_lRenewedInsuranceFileCnt, vRenewalFinancePlan)

            lPremiumFinanceCnt = ToSafeLong(vRenewalFinancePlan(k_PFPlanPFCnt, 0))
            lPremiumFinanceVer = ToSafeLong(vRenewalFinancePlan(k_PFPlanPFVersion, 0))

            If lPremiumFinanceVer = 1 Then
                m_lReturn = GetSingleFinancePlanFromInsFileCnt(v_lOriginalInsuranceFileCnt, vOriginalFinancePlan)
            Else
                m_lReturn = GetSingleFinancePlan(lPremiumFinanceCnt, lPremiumFinanceVer - 1, vOriginalFinancePlan)
            End If
            vRenewalFinancePlan(k_PFPlanBankName, 0) = vOriginalFinancePlan(k_PFPlanBankName, 0)
            vRenewalFinancePlan(k_PFPlanBankSortCode, 0) = vOriginalFinancePlan(k_PFPlanBankSortCode, 0)
            vRenewalFinancePlan(k_PFPlanBankAccountNo, 0) = vOriginalFinancePlan(k_PFPlanBankAccountNo, 0)
            vRenewalFinancePlan(k_PFPlanBankAccountName, 0) = vOriginalFinancePlan(k_PFPlanBankAccountName, 0)
            vRenewalFinancePlan(bSIRPremFinConst.kBIC, 0) = vOriginalFinancePlan(bSIRPremFinConst.kBIC, 0)
            vRenewalFinancePlan(bSIRPremFinConst.kIBAN, 0) = vOriginalFinancePlan(bSIRPremFinConst.kIBAN, 0)
            vRenewalFinancePlan(k_PFPlanBankBranch, 0) = vOriginalFinancePlan(k_PFPlanBankBranch, 0)
            vRenewalFinancePlan(k_PFPlanBankAddress1, 0) = vOriginalFinancePlan(k_PFPlanBankAddress1, 0)
            vRenewalFinancePlan(k_PFPlanBankAddress2, 0) = vOriginalFinancePlan(k_PFPlanBankAddress2, 0)
            vRenewalFinancePlan(k_PFPlanBankAddress3, 0) = vOriginalFinancePlan(k_PFPlanBankAddress3, 0)
            vRenewalFinancePlan(k_PFPlanBankTown, 0) = vOriginalFinancePlan(k_PFPlanBankTown, 0)
            vRenewalFinancePlan(k_PFPlanBankAddress4, 0) = vOriginalFinancePlan(k_PFPlanBankAddress4, 0)
            vRenewalFinancePlan(k_PFPlanBankPostcode, 0) = vOriginalFinancePlan(k_PFPlanBankPostcode, 0)
            vRenewalFinancePlan(k_PFPlanBankCountry, 0) = vOriginalFinancePlan(k_PFPlanBankCountry, 0)
            vRenewalFinancePlan(k_PFPlanBankAreaCode, 0) = vOriginalFinancePlan(k_PFPlanBankAreaCode, 0)
            vRenewalFinancePlan(k_PFPlanBankPhone, 0) = vOriginalFinancePlan(k_PFPlanBankPhone, 0)
            vRenewalFinancePlan(k_PFPlanBankExtn, 0) = vOriginalFinancePlan(k_PFPlanBankExtn, 0)
            vRenewalFinancePlan(k_PFPlanBankFaxCode, 0) = vOriginalFinancePlan(k_PFPlanBankFaxCode, 0)
            vRenewalFinancePlan(k_PFPlanBankFax, 0) = vOriginalFinancePlan(k_PFPlanBankFax, 0)

            dtStartDate = ToSafeDate(vRenewalFinancePlan(k_PFPlanStartDate, 0))
            dtEndDate = ToSafeDate(vRenewalFinancePlan(k_PFPlanEndDate, 0))
            iDayOfWeekOrMonth = ToSafeInteger(vRenewalFinancePlan(k_PFPlanDayOfWeekOrMonth, 0))

            crAmountToFinance = ToSafeDouble(vRenewalFinancePlan(k_PFPlanAmountToFinance, 0))
            bHasProtection = NullToDecimal(vRenewalFinancePlan(
                             k_PFPlanCostOfProtection, 0)) > 0


            bProductChangedAtREN = True

            m_lReturn = Calculate_Quotes(0, "REN", DateTime.Now, dtStartDate, dtEndDate,
                        "00:00:00", iDayOfWeekOrMonth, iDayOfWeekOrMonth,
                        crAmountToFinance, bHasProtection, False, False, v_lPartyCnt,
                        vQuoteArray, v_lInsuranceFileCnt:=v_lRenewedInsuranceFileCnt,
                        v_lRenewalInsFileCnt:=v_lOriginalInsuranceFileCnt,
                        v_bIsProductChangedAtREN:=bProductChangedAtREN)

            m_lReturn = GetSourceIDFromTransdetailID(
                        v_lTransdetailID:=0,
                        r_lSourceID:=lSourceID,
                        r_lSubBranchId:=lSubBranchID)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Result = gPMConstants.PMEReturnCode.PMFalse
            End If

            m_lReturn = ConvertQuoteToPlanArray(
                        v_vQuoteArray:=vQuoteArray,
                        v_lSelectedQuoteIndex:=lSelectedQuoteIndex,
                        r_vPFPlanArray:=vPFPlanArray,
                        v_vOriginalPlanArray:=vRenewalFinancePlan,
                        v_lSourceID:=lSourceID,
                        v_lSubBranchId:=lSubBranchID)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Result = gPMConstants.PMEReturnCode.PMFalse
            End If

            m_lReturn = UpdateExistingRecord(vPFPlanArray, lPremiumFinanceCnt, lPremiumFinanceVer)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Result = gPMConstants.PMEReturnCode.PMFalse
            End If


            Return Result


        Catch excep As System.Exception

            Result = gPMConstants.PMEReturnCode.PMFalse

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="UpdateRenewedFinancePlanBankDetails Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="UpdateRenewedFinancePlanBankDetails", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return Result
        End Try
