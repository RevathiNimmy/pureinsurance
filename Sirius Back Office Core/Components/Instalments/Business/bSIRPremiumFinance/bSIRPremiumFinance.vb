                                                ByVal v_lPremiumFinancePlanVer As Integer,
                                                ByRef r_vPlanArray(,) As Object,
                                                Optional ByVal bAddExistingFinaceAMT As Boolean = False) As Integer

        Dim nResult As Integer = PMEReturnCode.PMTrue
        Dim vExistingPlanDetails(,) As Object = Nothing

        If Not Informations.IsArray(r_vPlanArray) Then
            gPMFunctions.RaiseError("Informations.IsArray(r_vPlanArray)", "No input array provided", PMELogLevel.PMLogError)
        End If

        bPMAddParameter.AddParameterLite(m_oDatabase, "FinancePlanCnt", v_lPremiumFinanceCnt, PMEParameterDirection.PMParamInput, PMEDataType.PMLong, True)
        bPMAddParameter.AddParameterLite(m_oDatabase, "FinancePlanVersion", v_lPremiumFinancePlanVer, PMEParameterDirection.PMParamInput, PMEDataType.PMLong)

        m_lReturn = m_oDatabase.SQLSelect(sSQL:=ACGetExisitingPlanDetailsSQL, sSQLName:=ACGetExisitingPlanDetailsName, bStoredProcedure:=ACGetExisitingPlanDetailsStored, vResultArray:=vExistingPlanDetails)
