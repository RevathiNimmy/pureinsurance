    '*************************************************************************
    'Name :         CopyInstalmentPlanForRenewals
    'Description :  Generates automatic quote for Renewals and stores it in the
    '               PFPremFinance table. Based on same mediaType and
    '               Frequency as previous (existing) policy
    ' History:      07/02/2002 DD - Created.
    '               04/03/2003 TR - Renamed from BuildAutoQuote. Re-wrote to
    '                               work with new instalments
    '*************************************************************************
    Public Function CopyInstalmentPlanForRenewals(ByVal v_lOriginalInsuranceFileCnt As Integer, ByVal v_lRenewalInsuranceFileCnt As Integer, ByVal v_lPartyCnt As Integer, ByRef r_lPremiumFinanceCnt As Integer, ByRef r_lPremiumFinanceVer As Integer) As Integer

        Dim result As Integer = 0
        Const k_sFUNCTION_NAME As String = "CopyInstalmentPlanForRenewals"

        Dim vQuoteArray(,) As Object = Nothing
        Dim vPFPremiumFinance As Object = Nothing
        Dim vResultArray(,) As Object = Nothing
        Dim dtStartDate, dtEndDate As Date
        Dim crAmountToFinance As Decimal
        Dim iDayOfWeekOrMonth As Integer
        Dim bHasProtection, bFoundExactCopy As Boolean
        Dim lCount, lPartyCnt As Integer
        Dim vAmountToFinance(,) As Object = Nothing
        Dim lReturn As gPMConstants.PMEReturnCode
        Dim oRITax As bSIRRITax.Business
        Dim cTaxNotApplied As Decimal
        Dim bProductChangedAtREN As Boolean

        Try

            'TR - Assume success
            result = gPMConstants.PMEReturnCode.PMTrue

            'TR - Get the Informations from the Original Insurance File
            With m_oDatabase
                .Parameters.Clear()
                .Parameters.Add("Insurance_File_Cnt", gPMFunctions.ToSafeString(v_lRenewalInsuranceFileCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                m_lReturn = .SQLSelect(ACGetInsuranceFileSQL, ACGetInsuranceFileName, ACGetInsuranceFileStored,  , vResultArray)
                'TR - Make sure that this worked Ok. Cannot continue with this record
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to Get The Renewal " & "Insurance File record " & gPMFunctions.ToSafeString(v_lRenewalInsuranceFileCnt), ACApp, ACClass, k_sFUNCTION_NAME)
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
            End With

            'TR - Get the Info from the Renewal Insurance FIle

            crAmountToFinance = CDec(vResultArray(61, 0))
            ' Alix Bergeret - 21/03/2003 - Issue 2428
            ' We also need to add the tax!
            'If IsNumeric(vResultArray(67, 0)) Then
            '    crAmountToFinance = crAmountToFinance + vResultArray(67, 0)
            'End If
            ' /Alix

            dtStartDate = CDate(vResultArray(21, 0))

            dtEndDate = CDate(vResultArray(22, 0))
            ' Alix Bergeret - 20/03/2003 - Issue 2428
            ' If partycnt was NOT passed in, we get it from the insurance file array
            lPartyCnt = v_lPartyCnt
            If lPartyCnt = 0 Then

                lPartyCnt = gPMFunctions.ToSafeInteger(vResultArray(13, 0))
            End If

            '1.12 wr25
            Dim auxVar As Object = vResultArray(117, 0)

            bProductChangedAtREN = gPMFunctions.ToSafeLong(vResultArray(8, 0)) <> gPMFunctions.ToSafeLong(vResultArray(117, 0)) And Not (Convert.IsDBNull(auxVar) Or Informations.IsNothing(auxVar))


            oRITax = New bSIRRITax.Business
            lReturn = oRITax.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New System.Exception(m_lReturn.ToString() + ", " + +", Failed to get instance of bSIRRITax.Business")
            End If

            'Get the total amount of tax which is not applicable

            m_lReturn = oRITax.GetTaxNotAppliedToClient(v_lRenewalInsuranceFileCnt, cTaxNotApplied)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New System.Exception(m_lReturn.ToString() + ", " + +", Call to GetTaxNotAppliedToClient failed.")
            End If

            lReturn = CType(GetRenewalAmountToFinance(v_lInsuranceFileCnt:=v_lRenewalInsuranceFileCnt, r_vResults:=vAmountToFinance), gPMConstants.PMEReturnCode)

            If lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                If Informations.IsArray(vAmountToFinance) Then

                    crAmountToFinance = gPMFunctions.ToSafeCurrency((vAmountToFinance(0, 0)), 0)
                Else
                    bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "No data returned from " &
                                       "GetRenewalAmountToFinance", ACApp, ACClass, k_sFUNCTION_NAME)
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
            Else
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "GetRenewalAmountToFinance Failed", ACApp, ACClass, k_sFUNCTION_NAME)
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            oRITax.Dispose()
            oRITax = Nothing

            ' SET 16/08/2004 ISS13752 - round the result
            crAmountToFinance = gPMMaths.PMRoundupValueCurrency(crAmountToFinance, gPMConstants.PMECurrencyNoOfDP.pmeCurDPTwo, gPMConstants.PMERoundupFactor.pmeRFactor50Up)

            m_lReturn = GetSingleFinancePlanFromInsFileCnt(v_lOriginalInsuranceFileCnt, vPFPremiumFinance)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                ' Alix Bergeret - 25/03/2003
                ' If no plans, we dont crash! We simply dont copy anything...
                If m_lReturn = gPMConstants.PMEReturnCode.PMNotFound Then
                    'Call Logmessage(m_sUsername, PMLogOnError, "Failed to get any finance plan for this insurance file cnt:" & gPMFunctions.ToSafeString(v_lOriginalInsuranceFileCnt), _
                    'ACApp, ACClass, k_sFUNCTION_NAME)
                    Return result
                End If
                ' /Alix
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to get the Premium " & "Finance Plan record for the Original Insurance File", ACApp, ACClass, k_sFUNCTION_NAME)
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            ' Cancelled Instalment plan can also be used for generating renewals on Installments
            'If vPFPremiumFinance(k_PFPlanStatusInd, 0) = PFStatusIndCancelled Then
            '    Exit Function
            'End If

            'TR - Get some info from previous Plan
            iDayOfWeekOrMonth = gPMFunctions.NullToInteger(vPFPremiumFinance(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0))
            bHasProtection = gPMFunctions.NullToDecimal(vPFPremiumFinance(bSIRPremFinConst.k_PFPlanCostOfProtection, 0)) > 0

            'Set the current scheme to ensure the correct quote is chosen
            m_lCompanyNo = gPMFunctions.NullToLong(vPFPremiumFinance(bSIRPremFinConst.k_PFPlanCompanyNo, 0))
            m_lSchemeNo = gPMFunctions.NullToLong(vPFPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeNo, 0))
            m_lSchemeVer = gPMFunctions.NullToLong(vPFPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeVersion, 0))

            'TR - Peform the Quote calculations
            m_lReturn = Calculate_Quotes(0, "REN", DateTime.Now, dtStartDate, dtEndDate, CDate("00:00:00"), iDayOfWeekOrMonth, iDayOfWeekOrMonth, crAmountToFinance, bHasProtection, -1, False, lPartyCnt, vQuoteArray, v_lInsuranceFileCnt:=v_lOriginalInsuranceFileCnt, v_lRenewalInsFileCnt:=v_lRenewalInsuranceFileCnt)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Or Not Informations.IsArray(vQuoteArray) Then
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to calculate the Quotes " & "for this renewal: " & gPMFunctions.ToSafeString(v_lRenewalInsuranceFileCnt), ACApp, ACClass, k_sFUNCTION_NAME)
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'TR - Loop through the Quotes and determine which was for the same
            'Frequency/medi as the previous years (already been highlighted by
            'the Calculate_Quotes function)
            'TR - 24/03/03 - TS17 Recovery By Instalments changes
            'SMJB 17/10/03: Change made on behalf of Ashley Cottle

            For lCount = vQuoteArray.GetLowerBound(0) To vQuoteArray.GetUpperBound(1)
                'TR - See if the HighlightCell property is set to true - this
                'signifies that this is the same scheme as used last time

                If CBool(vQuoteArray(k_PFQuoteHighlightCell, lCount)) Then
                    bFoundExactCopy = True
                    Exit For
                End If
            Next lCount
            vPFPremiumFinance(bSIRPremFinConst.k_PFPlanDDCancelled, 0) = DBNull.Value
            vPFPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndSaved

            'TR - If we've found an exact match for Frequency and media type,
            'save this as the chosen Premium Finance Plan
            If bFoundExactCopy Then

                m_lReturn = InsertOrUpdatePremiumFinance(vQuoteArray, lCount, "", r_lPremiumFinanceCnt, r_lPremiumFinanceVer, bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread, vPFPremiumFinance)
                'TR - Cannot find the exact same plan, so return PMNotFound
            ElseIf Not bFoundExactCopy And bProductChangedAtREN Then

                m_lReturn = Calculate_Quotes(0, "REN", DateTime.Now, dtStartDate, dtEndDate, CDate("00:00:00"), iDayOfWeekOrMonth, iDayOfWeekOrMonth, crAmountToFinance, bHasProtection, False, False, lPartyCnt, vQuoteArray, v_lInsuranceFileCnt:=v_lOriginalInsuranceFileCnt, v_lRenewalInsFileCnt:=v_lRenewalInsuranceFileCnt, v_bIsProductChangedAtREN:=bProductChangedAtREN)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Or Not Informations.IsArray(vQuoteArray) Then
                    bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "Failed to calculate the Quotes " & "for this renewal: " & gPMFunctions.ToSafeString(v_lRenewalInsuranceFileCnt), ACApp, ACClass, k_sFUNCTION_NAME)
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If

                ' Select the first from the list and then insert

                vQuoteArray(k_PFQuoteHighlightCell, 0) = True

                m_lReturn = InsertOrUpdatePremiumFinance(vQuoteArray, 0, "", r_lPremiumFinanceCnt, r_lPremiumFinanceVer, bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread, vPFPremiumFinance)

            Else
                'TR - don't stop processing. If there is no matching scheme this
                'year, then log a message and continue. This will become an
                'invoice paid policy
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogWarning, "Instalment Plan not copied over " & "for policy " & gPMFunctions.ToSafeString(v_lRenewalInsuranceFileCnt) & ", this " & "policy will proceed as Invoice Paid", ACApp, ACClass, k_sFUNCTION_NAME)
                m_lReturn = gPMConstants.PMEReturnCode.PMNotFound
            End If
            m_lReturn = UpdateCreditCardFromPreviosVersion(v_nInsuranceFileCnt:=v_lRenewalInsuranceFileCnt)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New System.Exception(m_lReturn.ToString() + ", " + +", UpdateCreditCardFromPreviosVersion failed.")
            End If
            'TR - Return value
            Return m_lReturn

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError
            bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "CopyInstalmentPlanForRenewals Failed", ACApp, ACClass, k_sFUNCTION_NAME, Informations.Err().Number, excep.Message, excep:=excep)
            Return result
        End Try
    End Function


    ' ***************************************************************** '
    '
    ' Name: TranslateSchemeToPlan
    '
    ' Description:  Translates the Scheme Array into a Plan Array
    '
    ' History: 07/02/2002 DD - Created.
    '
    ' ***************************************************************** '
    Public Function TranslateSchemeToPlan(ByVal v_vSchemeArray(,) As Object, ByVal v_lPartyCnt As Integer, ByVal v_sShortName As String, ByVal v_sInsuranceRef As String, ByVal v_dStartDate As Date, ByVal v_cAmountToFinance As Decimal, ByVal v_lTransactionCount As Integer, ByVal v_sTransactionType As String, ByRef r_vPlanArray(,) As Object) As Integer

        Dim result As Integer = 0

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ReDim r_vPlanArray(bSIRPremFinConst.k_PFPlanCountOfFields, v_vSchemeArray.GetUpperBound(1))

            For iSelScheme As Integer = v_vSchemeArray.GetLowerBound(1) To v_vSchemeArray.GetUpperBound(1)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanCompanyNo, iSelScheme) = v_vSchemeArray(0, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanSchemeNo, iSelScheme) = v_vSchemeArray(1, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanSchemeVersion, iSelScheme) = v_vSchemeArray(2, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanStartDate, iSelScheme) = v_dStartDate
                'CHECK_PSL
                'r_vPlanArray(k_PFPlanIsInHouse, iSelScheme) = v_vSchemeArray(28, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanAmountToFinance, iSelScheme) = v_cAmountToFinance

                r_vPlanArray(bSIRPremFinConst.k_PFPlanNoOfInstalments, iSelScheme) = v_vSchemeArray(26, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanTransactionCount, iSelScheme) = v_lTransactionCount

                r_vPlanArray(bSIRPremFinConst.k_PFPlanProductClass, iSelScheme) = v_vSchemeArray(12, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanNBInd, iSelScheme) = v_vSchemeArray(13, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanMTAInd, iSelScheme) = v_vSchemeArray(14, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanRNWLInd, iSelScheme) = v_vSchemeArray(15, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanCNCLInd, iSelScheme) = v_vSchemeArray(16, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanPPInd, iSelScheme) = v_vSchemeArray(17, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanCompanyName, iSelScheme) = v_vSchemeArray(27, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanSchemeName, iSelScheme) = v_vSchemeArray(9, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanTransactionType, iSelScheme) = v_sTransactionType

                r_vPlanArray(bSIRPremFinConst.k_PFPlanEndDate, iSelScheme) = v_vSchemeArray(6, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanClientId, iSelScheme) = v_lPartyCnt

                r_vPlanArray(bSIRPremFinConst.k_PFPlanClientCode, iSelScheme) = v_sShortName

                r_vPlanArray(bSIRPremFinConst.k_PFPlanSystemTag, iSelScheme) = v_vSchemeArray(8, iSelScheme)

                r_vPlanArray(bSIRPremFinConst.k_PFPlanFinCollPlanRef, iSelScheme) = v_sInsuranceRef

                r_vPlanArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, iSelScheme) = ""

                r_vPlanArray(bSIRPremFinConst.k_PFPlanFinCollPlanRef, iSelScheme) = "" 'MKW190903

                r_vPlanArray(bSIRPremFinConst.k_PFPlanPolicyCnt, iSelScheme) = ""

                r_vPlanArray(bSIRPremFinConst.k_PFPlanInterestFree, iSelScheme) = "N"

            Next iSelScheme

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="TranslateSchemeToPlan Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="TranslateSchemeToPlan", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ***************************************************************** '
    '
    ' Name: TranslateQuoteToPlan
    '
    ' Description: Converts an existing Quote to a Plan with associated
    '              Orion transactions.
    '
    ' History: 08/02/2002 DD - Created.
    '
    ' ***************************************************************** '
    Public Function TranslateQuoteToPlan(ByRef r_vPlanArray As Array, ByVal v_vTransArray(,) As Object) As Integer

        Dim result As Integer = 0
        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Insert the Orion Transactions

            m_lReturn = InsertPFTransID(gPMFunctions.ToSafeInteger(r_vPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0)), gPMFunctions.ToSafeInteger(r_vPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0)), v_vTransArray)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'Mark the Plan as a Quote

            r_vPlanArray(bSIRPremFinConst.k_PFPlanIsQuote, 0) = False

            r_vPlanArray(bSIRPremFinConst.k_PFPlanTransactionCount, 0) = v_vTransArray.GetUpperBound(1) + 1
            UpdateExistingRecord(r_vPlanArray, r_vPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0), r_vPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0))

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="TranslateQuoteToPlan Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="TranslateQuoteToPlan", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    '************************************************************************************
    ' Name : GetAgentAndClient
    '
    ' Desc : Get Lead agent count for policy (return 0 if no lead agent)
    '
    ' Hist : Thinh Nguyen 18/02/2002 (created)
    '************************************************************************************
    Public Function GetAgentAndClient(ByVal v_lPremFinanceCnt As Integer, ByVal v_lPremFinanceVersion As Integer, ByRef r_lLeadAgentCnt As Integer, ByRef r_lClientCnt As Integer) As Integer

        Dim result As Integer = 0
        Dim vResultArray(,) As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_oDatabase.Parameters.Clear()

            If m_oDatabase.Parameters.Add(sName:="PremFinanceCnt", vValue:=gPMFunctions.ToSafeString(v_lPremFinanceCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong) <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            If m_oDatabase.Parameters.Add(sName:="PremFinanceVersion", vValue:=gPMFunctions.ToSafeString(v_lPremFinanceVersion), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong) <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            If m_oDatabase.SQLSelect(sSQL:=ACGetAgentAndClientSQL, sSQLName:=ACGetAgentAndClientName, bStoredProcedure:=ACGetAgentAndClientStored, vResultArray:=vResultArray) <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            '    If Not Informations.IsArray(vResultArray) Then
            '        GetAgentAndClient = PMNotFound
            '        Exit Function
            '    End If

            If Informations.IsArray(vResultArray) Then
                Dim auxVar As Object = vResultArray(0, 0)

                If Not (Convert.IsDBNull(auxVar) Or Informations.IsNothing(auxVar)) Then

                    If gPMFunctions.ToSafeString(vResultArray(0, 0)) <> "" Then

                        r_lLeadAgentCnt = gPMFunctions.ToSafeInteger(vResultArray(0, 0))
                    End If

                    r_lClientCnt = gPMFunctions.ToSafeInteger(vResultArray(1, 0))
                End If
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetAgentAndClient Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetAgentAndClient", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    '*************************************************************************
    ' Name :        GetAgentAndType
    ' Description : Gets the Lead agent count for policy, and if there is one gets
    '               the Agent Type (Commission or Broker) as well
    ' Created :     Tracy Richards 15/07/03
    ' History :
    '*************************************************************************
    Public Function GetAgentAndType(ByVal v_lPremFinanceCnt As Integer, ByVal v_lPremFinanceVersion As Integer, ByRef r_lLeadAgentCnt As Integer, ByRef r_lAgentType As Integer) As Integer

        Dim result As Integer = 0
        Dim vResultArray(,) As Object = Nothing

        Try

            'TR - Assume Succes
            result = gPMConstants.PMEReturnCode.PMTrue

            'TR - Use the DB object
            With m_oDatabase
                'TR - Clear existing data
                .Parameters.Clear()
                'TR - Set our parameters
                If .Parameters.Add(sName:="PremiumFinanceCnt", vValue:=gPMFunctions.ToSafeString(v_lPremFinanceCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong) <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
                If .Parameters.Add(sName:="PremiumFinanceVersion", vValue:=gPMFunctions.ToSafeString(v_lPremFinanceVersion), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong) <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
                'TR - Get the Agent & Type
                If .SQLSelect(sSQL:=ACGetAgentAndTypeSQL, sSQLName:=ACGetAgentAndTypeName, bStoredProcedure:=ACGetAgentAndTypeStored, vResultArray:=vResultArray) <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
            End With

            'TR - Return zeros if no result set (direct business etc)
            If Not Informations.IsArray(vResultArray) Then
                r_lLeadAgentCnt = 0
                r_lAgentType = 0
            Else
                'TR - only populate the results if an Agent exists
                Dim auxVar As Object = vResultArray(0, 0)

                If Not (Convert.IsDBNull(auxVar) Or Informations.IsNothing(auxVar)) Then

                    If gPMFunctions.ToSafeString(vResultArray(0, 0)) <> "" Then
                        r_lLeadAgentCnt = gPMFunctions.NullToLong(vResultArray(0, 0))
                    End If

                    If gPMFunctions.ToSafeString(vResultArray(1, 0)) <> "" Then
                        r_lAgentType = gPMFunctions.NullToLong(vResultArray(1, 0))
                    End If
                End If
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError
            bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "GetAgentAndType Failed", ACApp, ACClass, "GetAgentAndType", Informations.Err().Number, excep.Message, excep:=excep)
            Return result

        End Try
    End Function

