    ' Name: AddCreditControlItem
    '
    ' Description: Add the Credit Control items for an Insurance File
    '
    ' History:
    ' AAB 25/03/2003 : Created
    ' ***************************************************************** '
    Private Function AddCreditControlItem(ByVal v_sTransactionType As String) As Integer

        Dim result As Integer = 0
        Dim sErrorMessage As String = ""


        Dim lReturn As Integer

        result = gPMConstants.PMEReturnCode.PMTrue

        With m_oDatabase

            .Parameters.Clear()

            'Add Insurance File Cnt to the stored proc
            lReturn = .Parameters.Add(sName:="insurance_file_cnt", vValue:=gPMFunctions.ToSafeString(m_lInsuranceFileCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = lReturn
                sErrorMessage = "AddCreditControlItem failed to add Insurance_File_cnt to the " &
                                    "stroed proc"
                Throw New Exception()
            End If

            Select Case v_sTransactionType
                Case "NB", "EDIT", "REN", "MTR"

                    lReturn = .Parameters.Add("MTAType", gPMFunctions.ToSafeString(DBNull.Value.ToString), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                Case "MTA", "M"
                    lReturn = .Parameters.Add(sName:="MTAType", vValue:=gPMFunctions.ToSafeString(m_iInstalmentsMTAType), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
                Case Else

                    lReturn = .Parameters.Add("MTAType", gPMFunctions.ToSafeString(DBNull.Value.ToString), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            End Select
            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = lReturn
                sErrorMessage = "AddCreditControlItem failed to add MTAType to the " &
                                    "stroed proc"
                Throw New Exception()
            End If

            lReturn = .SQLAction(sSQL:=ACAddCreditControlItemInstalmentsInsuranceFileSQL, sSQLName:=ACAddCreditControlItemInstalmentsInsuranceFileName, bStoredProcedure:=ACAddCreditControlItemInstalmentsInsuranceFileStored)
            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = lReturn
                sErrorMessage = "AddCreditControlItem failed to run " &
                                    "ACAddCreditControlItemInstalmentsInsuranceFileSQL"
                Throw New Exception()
            End If

        End With

        Return result

    End Function

