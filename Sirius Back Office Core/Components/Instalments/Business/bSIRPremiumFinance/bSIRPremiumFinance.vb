    Public Function GetFinanceProviderDetails(ByVal v_lCompanyNo As Integer, ByVal v_lSchemeNo As Integer, ByVal v_lSchemeVersion As Integer, ByRef r_lPartyCnt As Integer, ByRef r_sShortName As String) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "GetFinanceProviderDetails"

        Dim sSQL As String = ""
        Dim vResult(,) As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Get ClientId from the Party Table
            sSQL = ""
            sSQL = sSQL & "SELECT" & Strings.ChrW(13) & Strings.ChrW(10)
            sSQL = sSQL & "    p.party_cnt," & Strings.ChrW(13) & Strings.ChrW(10)
            sSQL = sSQL & "    p.shortname" & Strings.ChrW(13) & Strings.ChrW(10)
            sSQL = sSQL & "FROM pfscheme s" & Strings.ChrW(13) & Strings.ChrW(10)
            sSQL = sSQL & "JOIN party p" & Strings.ChrW(13) & Strings.ChrW(10)
            sSQL = sSQL & "    ON p.party_cnt = s.party_cnt" & Strings.ChrW(13) & Strings.ChrW(10)
            sSQL = sSQL & "WHERE s.CompanyNo = " & gPMFunctions.ToSafeString(v_lCompanyNo) & Strings.ChrW(13) & Strings.ChrW(10)
            sSQL = sSQL & "AND s.SchemeNo = " & gPMFunctions.ToSafeString(v_lSchemeNo) & Strings.ChrW(13) & Strings.ChrW(10)
            sSQL = sSQL & "AND s.SchemeVersion = " & gPMFunctions.ToSafeString(v_lSchemeVersion) & Strings.ChrW(13) & Strings.ChrW(10)

            m_lReturn = m_oDatabase.SQLSelect(sSQL:=sSQL, sSQLName:="GetFinanceProviderCnt", bStoredProcedure:=False, vResultArray:=vResult)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oDatabase.SQLSelect", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            If Informations.IsArray(vResult) Then
                r_lPartyCnt = gPMFunctions.ToSafeLong(vResult(0, 0))
                r_sShortName = gPMFunctions.ToSafeString(vResult(1, 0)).Trim()
            End If

            Return result

        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here

            ' Do any tidy up, e.g. Set x = Nothing here

            Return result
        End Try
    End Function

