    Public Function CreateInstalmentEvent(ByVal v_sInstalmentPlanRef As String, ByVal v_lInstalmentNumber As Integer, ByVal v_dtOriginalDueDate As Date, ByVal v_dtNewDueDate As Date, ByVal v_lInsuranceFileCnt As Integer, ByVal v_lInsuranceFolderCnt As Integer, ByVal v_lPartycnt As Integer) As Integer

        Dim result As Integer = 0
        Dim lEventID As Integer
        Dim sDescription As String
        Dim lEventTypeID As Integer
        Dim m_oEvent As bSIREvent.Business
        Dim vInstalmentPlanRef As String
        Dim vlInstalmentNumber As Integer = 0
        m_oEvent = New bSIREvent.Business()
        Try
            result = gPMConstants.PMEReturnCode.PMTrue

            If v_sInstalmentPlanRef IsNot Nothing AndAlso v_sInstalmentPlanRef.Trim.Length <> 0 Then
                vInstalmentPlanRef = v_sInstalmentPlanRef
            Else
                vInstalmentPlanRef = ""
            End If
            If v_lInstalmentNumber > 0 Then
                vlInstalmentNumber = v_lInstalmentNumber
            End If


            sDescription = "Instalment Plan Ref " & vInstalmentPlanRef & " Instalment Number " & vlInstalmentNumber & " due date changed from " & StringsHelper.Format(v_dtOriginalDueDate, "Short Date") & " to " & StringsHelper.Format(v_dtNewDueDate, "Short Date") & "."

            result = GetEventtype("INSCHANGE", lEventTypeID)
            If result <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse

                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Failed to initialise the event object", vApp:=ACApp, vClass:=ACClass, vMethod:="CreateInstalmentEvent", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                Return result
            End If

            m_lReturn = m_oEvent.Initialise(m_sUsername, m_sPassword, m_iUserID, m_iSourceID, m_iLanguageID, m_iCurrencyID, m_iLogLevel, MainModule.ACApp, vDatabase:=m_oDatabase)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse

                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Failed to initialise the event object", vApp:=ACApp, vClass:=ACClass, vMethod:="CreateInstalmentEvent", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                Return result
            End If


            result = m_oEvent.DirectAdd(vEventCnt:=lEventID, vPartyCnt:=v_lPartycnt, vInsuranceFolderCnt:=v_lInsuranceFolderCnt, vInsuranceFileCnt:=v_lInsuranceFileCnt, vClaimCnt:=DBNull.Value, vDocumentCnt:=DBNull.Value, vOldAddressCnt:=DBNull.Value, vNewAddressCnt:=DBNull.Value, vCampaignId:=DBNull.Value, vDocumentType:=DBNull.Value, vReportType:=DBNull.Value, vEventType:=lEventTypeID, vUserId:=m_iUserID, vEventDate:=DateTime.Today, vDescription:=sDescription)

            If result <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse

                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Failed to add the event", vApp:=ACApp, vClass:=ACClass, vMethod:="CreateInstalmentEvent", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                Return result
            End If

            m_oEvent = Nothing

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMFalse

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Failed to crerate event", vApp:=ACApp, vClass:=ACClass, vMethod:="CreateInstalmentEvent", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message)

            Return result
        End Try
    End Function

