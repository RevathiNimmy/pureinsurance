    '*************************************************************************
    'Name:          CalculateLastInstalmentDate
    'Description:   Using the First Instalment Date, and working forward by
    '               adding the Frequency, looks for a Last Date prior to or on
    '               the End Date, of the same Day Of the month or week as the First Date
    'History:       TR071102 - Created as per TS23
    '*************************************************************************
    Private Function CalculateLastInstalmentDate(ByVal v_enAlignPremiumTo As AlignPremiumToOptions, ByVal v_dtFirstInstalmentDate As Date, ByVal v_iFrequencyAmount As Integer, ByRef r_dtResultingDate As Date, ByVal v_bPremiumFinance As Boolean, Optional ByVal v_lInstalments As Integer = -1, Optional ByVal v_iSingleInstalmentPerMonth As Integer = 0) As Integer

        'TR - Declare local variables
        Dim result As Integer = 0
        Dim dtDate, dtLastDate As Date
        Dim lCount As Integer
        Dim dtEndDate As Date



        If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
            'If prefered day is greater than 1st instalment day then pull it back by one month
            If m_sVBFrequencyInterval = "m" Then 'And v_iFrequencyAmount = 1 Then
                If m_iDayOfWeekOrMonth > v_dtFirstInstalmentDate.Day AndAlso (v_iSingleInstalmentPerMonth <> 1 OrElse m_iDayOfWeekOrMonth > System.DateTime.DaysInMonth((v_dtFirstInstalmentDate.Year.ToString), (v_dtFirstInstalmentDate.AddMonths(-1).Month.ToString))) Then
                    v_dtFirstInstalmentDate = v_dtFirstInstalmentDate.AddMonths(-1)
                End If
            End If
        End If

        'ACR 03-02-05 See if we have an end date passed in
        If v_lInstalments <= 0 Then
            dtEndDate = m_dtEndDate
        Else
            'we do so fool the calculations into thinking the end date
            'is todays date + the amount of instalments
            dtEndDate = v_dtFirstInstalmentDate.AddMonths(v_lInstalments)
        End If

        'TR - Assume failure
        result = gPMConstants.PMEReturnCode.PMFail

        'TR - Make sure that the first Date is Earlier than the last Date
        If v_dtFirstInstalmentDate > dtEndDate Then
            result = gPMConstants.PMEReturnCode.PMTrue
            r_dtResultingDate = v_dtFirstInstalmentDate
            '        CalculateLastInstalmentDate = PMFail
            Return result
        End If

        'TR - Loop through forward from the First Date, by the frequency
        'period, until the EndDate is reached. Get the nearest prior date
        'to the End Date with the same day of the month as the start date

        dtDate = v_dtFirstInstalmentDate 'changed to have date of second instalment
        lCount = 0
        If m_lMaXNoOfInstalments > ACNoMaxNoOfInstalmentsSet Then 'We have set up a maximum # of instalments
            'DD 24/06/2003: Always give a fixed number of instalments for
            'Premium Finance.
            'now we are calculating last date from the second instalment date
            'so decreasing the MaxNoofInstalment by 1
            Do Until (dtDate >= m_dtEndDate) Or (lCount + 1 > m_lMaXNoOfInstalments - 1)
                dtLastDate = dtDate
                CalculateNextOrPrevInstalment(v_dtFirstInstalmentDate, v_iFrequencyAmount * (lCount + 1), WhichDirection.MovingForwards, dtDate, v_enAlignPremiumTo, True, v_iSingleInstalmentPerMonth)
                lCount += 1
            Loop
        Else
            'We calculate as usual
            Do Until dtDate >= m_dtEndDate
                dtLastDate = dtDate
                CalculateNextOrPrevInstalment(v_dtFirstInstalmentDate, v_iFrequencyAmount * (lCount + 1), WhichDirection.MovingForwards, dtDate, v_enAlignPremiumTo, True, v_iSingleInstalmentPerMonth)

                lCount += 1
            Loop
        End If
        If Not dtLastDate = DateTime.MinValue Then
            If (dtLastDate).Day <> (m_dtCoverStartDate).Day AndAlso v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithPolicyRenewalDate Then
                If (dtLastDate).Day = 1 Then
                    dtLastDate = dtLastDate.AddDays(-1)
                    If (dtLastDate).Day <> (m_dtCoverStartDate).Day Then
                        dtLastDate = dtLastDate.AddDays(1)
                    End If
                End If
            End If
        End If
        If dtDate >= m_dtEndDate Then
            dtDate = dtLastDate
        End If

        'TR - Return the last date
        r_dtResultingDate = dtLastDate

        'TR - Success

        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    '*************************************************************************
    'Name:          CalculateNoOfInstalments
    'Description:   Using an Earlier Date and Later Date calculates the number
    '               of instalments in-between by adding the Frequency Period
    '               to Earlier Date for Forward Drirection, and Subtracting the
    '               Frequency Period from Later Date for Backwards Direction.
    '               Excludes count of Intalments on 2 provided dates.
    '               Also supplies the First or Last Date as appropriate, with
    '               corresponding day of week or month.
    'History:       TR071102 - Created as per TS23
    '*************************************************************************

    Private Function CalculateNoOfInstalments(ByVal v_dtEarlierDate As Date, ByVal v_dtLaterDate As Date, ByVal v_iFrequencyAmount As Integer,
                                              ByVal v_enWhichDirection As WhichDirection, ByRef r_iNoOfInstalments As Integer, ByVal v_enAlignPremiumTo As AlignPremiumToOptions,
                                              Optional ByRef r_dtReturnDate As Object = "00:00:00",
                                              Optional ByVal v_iSingleInstalmentPerMonth As Integer = 0) As Integer

        'TR - Declare local variables
        Dim result As Integer = 0
        Dim iCount As Integer
        Dim dtDateToStartFrom, dtDateToFinishOn, dtLastDate, dtDate As Date



        'TR - Assume failure
        result = gPMConstants.PMEReturnCode.PMFail

        'TR - Make sure that the earlier date is Earlier
        If v_dtEarlierDate > v_dtLaterDate Or v_dtLaterDate > m_dtEndDate Then
            r_iNoOfInstalments = 0
            Return gPMConstants.PMEReturnCode.PMTrue
        End If

        'TR - Work out which date to start and finish on
        If v_enWhichDirection = Business.WhichDirection.MovingForwards Then
            dtDateToStartFrom = v_dtEarlierDate
            dtDateToFinishOn = v_dtLaterDate
        ElseIf v_enWhichDirection = Business.WhichDirection.MovingBackwards Then
            dtDateToStartFrom = v_dtLaterDate
            dtDateToFinishOn = v_dtEarlierDate
        End If

        'TR - Initialise variables
        iCount = 0
        dtDate = dtDateToStartFrom

        'If prefered day is greater than 1st instalment day
        If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
            If m_sVBFrequencyInterval = "m" And v_iFrequencyAmount = 1 Then
                If v_enWhichDirection = Business.WhichDirection.MovingForwards Then
                    If m_iDayOfWeekOrMonth > dtDate.Day Then
                        If v_iSingleInstalmentPerMonth = 0 OrElse m_iDayOfWeekOrMonth > System.DateTime.DaysInMonth((dtDate.Year.ToString), (dtDate.AddMonths(-1).Month.ToString)) Then
                            dtDate = dtDate.AddMonths(-1)
                        End If
                    End If
                Else
                    If m_iDayOfWeekOrMonth < dtDate.Day Then
                        dtDate = dtDate.AddMonths(1)
                    End If
                End If
            End If
        End If

        dtLastDate = dtDate
        'TR - Loop through instalments
        Do
            CalculateNextOrPrevInstalment(dtLastDate, v_iFrequencyAmount * (iCount + 1), v_enWhichDirection, dtDate, v_enAlignPremiumTo, True, v_iSingleInstalmentPerMonth)
            If v_enWhichDirection = Business.WhichDirection.MovingForwards Then
                If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
                    If (m_iDayInMonth <= dtDate.Day And dtDate.Month = dtDateToFinishOn.Month And dtDate.Year = dtDateToFinishOn.Year AndAlso m_sVBFrequencyInterval <> "ww") Or dtDate >= dtDateToFinishOn Then
                        Exit Do
                    End If
                ElseIf dtDate >= dtDateToFinishOn Then
                    Exit Do
                End If
            Else
                If m_iDayOfWeekOrMonth = m_dtStartDate.Day And (m_lMaXNoOfInstalments = 12 Or m_lMaXNoOfInstalments = 24) Then
                    If dtDate <= dtDateToFinishOn Then
                        Exit Do
                    End If
                Else
                    If dtDate <= dtDateToFinishOn Then
                        Exit Do
                    End If
                End If

            End If
            iCount += 1
        Loop

        'TR - Return the last date
        r_iNoOfInstalments = iCount
        r_dtReturnDate = dtLastDate

        'TR - Success
        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    '*************************************************************************
    'Name:          CalculateNextOrPrevInstalment
    'Description:   Using any Date passed in (not necessarily a valid
    '               Instalment Date), gets the Next or Previous Valid
    '               instalment Date falling on the User's chosen Day of Week
    '               or Month
    'History:       TR071102 - Created as per TS23
    '*************************************************************************
    Private Function CalculateNextOrPrevInstalment(ByVal v_dtInputDate As Date,
                                                   ByVal v_iFrequencyAmount As Integer,
                                                   ByVal v_enWhichDirection As WhichDirection,
                                                   ByRef r_dtOutputDate As Date,
                                                   Optional ByVal v_enAlignPremiumTo As AlignPremiumToOptions = AlignPremiumToOptions.AlignWithClientPreference,
                                                   Optional ByVal v_bCalculatingNoOfInsalments As Boolean = False,
                                                   Optional ByVal v_iSingleInstalmentPerMonth As Integer = 0) As Integer

        Dim result As Integer = 0
        Dim iDayOfmonth, iInputDayOfWeek, iTargetDay As Integer

        Dim dtStartDate As Date

        If m_sTransType = "MTA" Then
            dtStartDate = m_dtCoverStartDate
        Else
            dtStartDate = m_dtStartDate
        End If

        'TR - Make sure required parameters are passed in
        If v_iFrequencyAmount <= 0 Then
            Return gPMConstants.PMEReturnCode.PMFail
        Else
            'TR - Assume Success
            result = gPMConstants.PMEReturnCode.PMTrue
        End If

        '*******************
        'Monthly Frequencies
        '*******************
        'TR - Which Frequency first
        If m_sVBFrequencyInterval = "m" Then

            'TR - Next Month or Previous Month?
            If v_enWhichDirection = Business.WhichDirection.MovingBackwards Then
                r_dtOutputDate = v_dtInputDate.AddMonths(-v_iFrequencyAmount)
                'Start - Sankar - PN 61404
                If dtStartDate.Day = 31 AndAlso (Informations.DateAdd("d", -1, r_dtOutputDate)).Day = 31 Then
                    r_dtOutputDate = Informations.DateAdd("d", -1, r_dtOutputDate)
                End If
                ' Alix Bergeret - 27/03/2003
                If Not v_bCalculatingNoOfInsalments Then
                    ' SET 12/05/2004 ISS11906 - is the proposed date before the start of the policy
                    If r_dtOutputDate < m_dtStartDate Then
                        ' yes so use the v_dtInputDate parameter
                        r_dtOutputDate = v_dtInputDate 'm_dtEndDate '
                    End If
                End If
                If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
                    'TR - Now match the actual day of the month
                    iDayOfmonth = Informations.DatePart("d", r_dtOutputDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
                    'TR - Check that this is the required date
                    If iDayOfmonth <> m_iDayOfWeekOrMonth Then
                        If iDayOfmonth > m_iDayOfWeekOrMonth Then
                            Do Until iDayOfmonth <= m_iDayOfWeekOrMonth Or r_dtOutputDate.Month <> r_dtOutputDate.AddDays(-1).Month
                                r_dtOutputDate = r_dtOutputDate.AddDays(-1)
                                iDayOfmonth = Informations.DatePart("d", r_dtOutputDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
                            Loop
                        Else
                            Do Until iDayOfmonth >= m_iDayOfWeekOrMonth Or r_dtOutputDate.Month <> r_dtOutputDate.AddDays(1).Month
                                r_dtOutputDate = r_dtOutputDate.AddDays(1)
                                iDayOfmonth = Informations.DatePart("d", r_dtOutputDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
                            Loop
                        End If
                    End If
                End If
            ElseIf v_enWhichDirection = Business.WhichDirection.MovingForwards Then
                r_dtOutputDate = v_dtInputDate.AddMonths(v_iFrequencyAmount)

                If m_sTransType <> "MTA" Then
                    dtStartDate = v_dtInputDate
                End If

                'Move forward if days are different
                'Start - Sankar - PN 61404
                If (r_dtOutputDate).Day <> (v_dtInputDate).Day AndAlso dtStartDate.AddDays(1).Month <> dtStartDate.Month Then
                    If v_enAlignPremiumTo = AlignPremiumToOptions.AlignWithClientPreference Then
                        Dim iDayinMonth As Integer = DateTime.DaysInMonth((r_dtOutputDate).Year, (r_dtOutputDate).Month)
                        If iDayinMonth > (r_dtOutputDate).Day Then
                            r_dtOutputDate = Informations.DateAdd("d", 1, r_dtOutputDate)
                        End If
                    Else
                        r_dtOutputDate = Informations.DateAdd("d", 1, r_dtOutputDate)
                    End If
                ElseIf (m_dtCoverStartDate).Day <> (v_dtInputDate).Day AndAlso v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithPolicyRenewalDate _
                        AndAlso (m_dtCoverStartDate).Day <= Date.DaysInMonth((r_dtOutputDate).Year, If(((r_dtOutputDate).Month - 1) = 0, 12, ((r_dtOutputDate).Month - 1))) Then
                    'This condition introduced to handle Feb month based calculation which created wrong instament date in case of 29,30,31 Decemeber inception
                    'date as feb doesnt have these days and it moves instalment to 1st March which results in incorrect subsequent instalment dates.
                    'PM048827(TFS-21798)
                    Do Until (r_dtOutputDate).Day = (m_dtCoverStartDate).Day
                        r_dtOutputDate = Informations.DateAdd("d", -1, r_dtOutputDate)
                    Loop
                End If
                'End - Sankar - PN 61404

                If Not v_bCalculatingNoOfInsalments Then
                    ' SET 12/05/2004 ISS11906 - is the proposed date before the start of the policy
                    If r_dtOutputDate > m_dtEndDate Then
                        ' yes so use the v_dtInputDate parameter
                        r_dtOutputDate = m_dtEndDate
                    End If

                    ' SET 12/05/2004 ISS11906 - is the proposed date before the start of the policy
                    If r_dtOutputDate < m_dtStartDate AndAlso Business.AlignPremiumToOptions.AlignWithClientPreference AndAlso m_sProductCode <> "MTA" Then
                        ' Set to the prefered date of that falls in the next month.
                        r_dtOutputDate = r_dtOutputDate.AddMonths(1)
                    End If
                End If
                If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
                    'TR - Now match the actual day of the month
                    iDayOfmonth = Informations.DatePart("d", r_dtOutputDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
                    'TR - Check that this is the required date
                    If iDayOfmonth <> m_iDayOfWeekOrMonth Then
                        If iDayOfmonth > m_iDayOfWeekOrMonth Then
                            Do Until iDayOfmonth <= m_iDayOfWeekOrMonth Or r_dtOutputDate.Month <> r_dtOutputDate.AddDays(-1).Month
                                r_dtOutputDate = r_dtOutputDate.AddDays(-1)
                                iDayOfmonth = Informations.DatePart("d", r_dtOutputDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
                            Loop
                        Else
                            Do Until iDayOfmonth >= m_iDayOfWeekOrMonth Or r_dtOutputDate.Month <> r_dtOutputDate.AddDays(1).Month
                                r_dtOutputDate = r_dtOutputDate.AddDays(1)
                                iDayOfmonth = Informations.DatePart("d", r_dtOutputDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
                            Loop
                            'If preferred day in Month does not exists in a month then the ins date will be 1st of next month
                            If v_iSingleInstalmentPerMonth <> 1 Andalso (iDayOfmonth < m_iDayOfWeekOrMonth) And (r_dtOutputDate.Month + 1 = r_dtOutputDate.AddDays(1).Month) AndAlso (v_iSingleInstalmentPerMonth <> 1 OrElse m_iDayOfWeekOrMonth > System.DateTime.DaysInMonth((r_dtOutputDate.Year.ToString), (r_dtOutputDate.Month.ToString))) Then
                                r_dtOutputDate = r_dtOutputDate.AddDays(1)
                            End If
                        End If
                    End If
                End If
            End If

            '******************
            'Weekly Frequencies
            '******************
        ElseIf m_sVBFrequencyInterval = "ww" Then

            'TR - Find out what day of the week the Input Date falls on
            iInputDayOfWeek = Informations.Weekday(v_dtInputDate, DayOfWeek.Monday)

            ' Alix
            If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
                iTargetDay = m_iDayOfWeekOrMonth
            Else
                iTargetDay = Informations.Weekday(m_dtStartDate, DayOfWeek.Monday)
            End If

            'TR - Next Week or Previous Week?
            If v_enWhichDirection = Business.WhichDirection.MovingBackwards Then
                'TR - Work out the actual date
                If iInputDayOfWeek > iTargetDay Then
                    r_dtOutputDate = v_dtInputDate.AddDays(iTargetDay).AddDays(-iInputDayOfWeek).AddDays(-(7 * (v_iFrequencyAmount - 1)))
                Else
                    r_dtOutputDate = v_dtInputDate.AddDays(-(7 * v_iFrequencyAmount)).AddDays(iTargetDay).AddDays(-iInputDayOfWeek)
                End If

            ElseIf v_enWhichDirection = Business.WhichDirection.MovingForwards Then
                'TR - Work out the actual date
                If iInputDayOfWeek >= iTargetDay Then
                    r_dtOutputDate = v_dtInputDate.AddDays(7 * v_iFrequencyAmount).AddDays(iTargetDay).AddDays(-iInputDayOfWeek)
                Else
                    r_dtOutputDate = v_dtInputDate.AddDays(iTargetDay).AddDays(-iInputDayOfWeek).AddDays(7 * (v_iFrequencyAmount - 1))
                End If
                If (m_sProductCode = "REN" AndAlso r_dtOutputDate < m_dtStartDate) Then
                    r_dtOutputDate = m_dtStartDate
                    'TR - Find out what day of the week the Input Date falls on
                    iInputDayOfWeek = Informations.Weekday(r_dtOutputDate, DayOfWeek.Monday)
                    r_dtOutputDate = m_dtStartDate.AddDays(7 * v_iFrequencyAmount).AddDays(iTargetDay).AddDays(-iInputDayOfWeek)
                End If
            End If
        End If

        'TR - Success

        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    '*************************************************************************
    'Name:          GetSingleFinancePlan
    'Description:   Gets a Single Finance Plan from Keys, Count and Version.
    '               Using stored procedure "spu_PFPremiumFinance_sel_single"
    'History:       TR111102 - Created as per TS23
    '*************************************************************************
    Public Function GetSingleFinancePlan(ByVal v_lFinanceCount As Integer, ByVal v_lFinanceVersion As Integer, ByRef r_vPFPremiumFinance(,) As Object) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "GetSingleFinancePlan"

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            bPMAddParameter.AddParameterLite(m_oDatabase, "financeplancnt", v_lFinanceCount, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
            bPMAddParameter.AddParameterLite(m_oDatabase, "financeplanversion", v_lFinanceVersion, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

            m_lReturn = m_oDatabase.SQLSelect(sSQL:=ACGetPFPremiumFinanceSingleSQL, sSQLName:=ACGetPFPremiumFinanceSingleName, bStoredProcedure:=ACGetPFPremiumFinanceSingleStored, vResultArray:=r_vPFPremiumFinance)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oDatabase.SQLSelect", "sSQL:=ACGetPFPremiumFinanceSingleSQL", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Check that at least one Premium Finanace Plan was found
            If Not Informations.IsArray(r_vPFPremiumFinance) Then
                result = gPMConstants.PMEReturnCode.PMNotFound
                Return result
            End If

            Return result
        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here

        Finally

            ' Do any tidy up, e.g. Set x = Nothing here

            '		Return result

            ' This is for debugging only
            '		Resume 

            '		Return result
        End Try
        Return result
    End Function
    '*************************************************************************
    'Name:          GetSingleFinancePlanFromInsFileCnt
    'Description:   Gets a Single Finance Plan from just the InsuranceFileCnt
    '               Using stored procedure "spu_PFPremiumFinance_sel_single"
    'History:       TR111102 - Created as per TS23
    '*************************************************************************
    Public Function GetSingleFinancePlanFromInsFileCnt(ByVal v_lInsuranceFileCnt As Integer, ByRef r_vPFPremiumFinance(,) As Object) As Integer

        Dim result As Integer = 0
        Const k_sFunctionName As String = "GetSingleFinancePlanFromInsFileCnt"

        Try

            'TR - Assume Failure
            result = gPMConstants.PMEReturnCode.PMFail

            'TR - Use the database Object
            With m_oDatabase
                'TR - Clear existing parameters
                .Parameters.Clear()
                'TR - Set passed in parmeters
