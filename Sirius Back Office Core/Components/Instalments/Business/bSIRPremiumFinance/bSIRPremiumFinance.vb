    ' ***************************************************************** '
    ' Name: CheckFirstInstalmentDateCorrect
    '
    ' Description:
    '
    ' Check If Any Changes Done To Bank Details Prior To Renewal, So As To
    ' Reset Instalment Date To Allow Time For Details To Be Changed
    '
    ' History:
    ' ***************************************************************** '

    Public Function CheckFirstInstalmentDateCorrect(ByRef vPremiumFinanceCnt As Object, ByRef vPremiumFinanceVersion As Object) As Integer

        Dim result As Integer = 0
        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Start a transaction so we can rollback any errors.
            m_lReturn = m_oDatabase.SQLBeginTrans()

            ' Build Parameters Here!
            With m_oDatabase.Parameters
                .Clear()

                m_lReturn = .Add("FinancePlanCnt", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(vPremiumFinanceCnt)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                m_lReturn = .Add("FinancePlanVersion", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(vPremiumFinanceVersion)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            End With

            ' Update existing record
            m_lReturn = m_oDatabase.SQLAction(ACCheckFirstInstalmentCatersForBankChangesSQL, ACCheckFirstInstalmentCatersForBankChangesName, ACCheckFirstInstalmentCatersForBankChangesStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = m_lReturn
                m_lReturn = m_oDatabase.SQLRollbackTrans()
                Return result
            End If

            m_lReturn = m_oDatabase.SQLCommitTrans()

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CheckFirstInstalmentDateCorrect Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="UpdateExistingRecord", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            m_lReturn = m_oDatabase.SQLRollbackTrans()

            Return result
        End Try
    End Function

