    ' ***************************************************************** '
    ' Name: ProcessInstalmentsDeposit (Private)
    '
    ' Description: we need to create a posting for the deposit, so we can
    '              do cashlist allocation later on.
    '
    ' PSL 07/03/2003
    '
    ' AAB 03/24/2003  I moved this here per conversation with Danny Davis.
    ' ***************************************************************** '
    Function ProcessInstalmentsDeposit(ByRef r_lTransactionExportFolderCnt As Integer) As Integer
        '====================================================================
        '   Class/Module: Business
        '   Description :
        '
        '====================================================================
        '   Maintenance History
        '
        '    04/06/2003    Danny Davis    Created.
        '
        '====================================================================

        Dim result As Integer = 0
        Try

            Dim lReturn, lStatsFolderCnt, lTransactionExportFolderCnt As Integer

            result = gPMConstants.PMEReturnCode.PMTrue

            'DD 04/06/2003: Underwriting method

            ' Create the Stats tables
            lReturn = CreateDepositStats(lStatsFolderCnt:=lStatsFolderCnt)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'm_sMessage = "Failed to create Deposit Statistics"
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'There was no PF so don't proceed (this is not an error)
            If lStatsFolderCnt = 0 Then Return result

            lReturn = TransferStatsToExport(lStatsFolderCnt:=lStatsFolderCnt, lTransactionExportFolderCnt:=lTransactionExportFolderCnt)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'm_sMessage = "Failed to create Deposit Transactions"
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'Call the routine to post the transaction to the Orion
            lReturn = PostDocument(v_lTransactionExportFolderCnt:=lTransactionExportFolderCnt)
            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'm_sMessage = "Failed to post deposit Transactions to Orion"
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'Return the new folder
            r_lTransactionExportFolderCnt = lTransactionExportFolderCnt

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="ProcessInstalmentsDeposit Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessInstalmentsDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result
        End Try
    End Function

    Private Function PostDocument(ByVal v_lTransactionExportFolderCnt As Integer) As Integer

        Dim oTransactionBusiness As bPMBTransactions.Automated
        Dim lReturn As Integer



        'Create an instance of PMBTransaction

        oTransactionBusiness = New bPMBTransactions.Automated
        lReturn = oTransactionBusiness.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

        'Set the process modes

        lReturn = oTransactionBusiness.SetProcessModes(m_iTask, m_lNavigate, m_lProcessMode, m_sTransactionType, m_dtEffectiveDate)

        'Call the function to Send the Transaction to Orion

        lReturn = oTransactionBusiness.SendToOrion(v_lTransactionExportFolderCnt)

        Return lReturn

    End Function

    ' ***************************************************************** '
    ' Name: TransferStatsToExport (Private)
    '
    ' Description: Create transaction export info from Stats folder
    '
    ' PSL 07/03/2003
    ' ***************************************************************** '
    Private Function TransferStatsToExport(ByRef lStatsFolderCnt As Integer, ByRef lTransactionExportFolderCnt As Integer) As Integer

        Dim result As Integer = 0


        Dim lReturn As Integer

        result = gPMConstants.PMEReturnCode.PMTrue

        'Same as normal export folder
        lReturn = TransferStatsFolder(lStatsFolderCnt:=lStatsFolderCnt, lTransactionExportFolderCnt:=lTransactionExportFolderCnt)

        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            Return lReturn
        End If

        'Check to ensure we created a Export Folder
        If Not (lStatsFolderCnt > 0) Then
            Return gPMConstants.PMEReturnCode.PMFalse
        End If

        'different export details for deposit
        lReturn = TransferStatsDetails(lStatsFolderCnt:=lStatsFolderCnt, lTransactionExportFolderCnt:=lTransactionExportFolderCnt)

        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            Return lReturn
        End If

        Return result

    End Function

    ' ***************************************************************** '
    ' Name: TransferStatsDetails (Private)
    '
    ' Description: create 2 journal details into and out of client account
    '
    ' PSL 07/03/2003
    ' ***************************************************************** '
    Private Function TransferStatsDetails(ByRef lStatsFolderCnt As Integer, ByRef lTransactionExportFolderCnt As Integer) As Integer

        Dim result As Integer = 0
        Dim lReturn, lRecordsAffected As Integer



        result = gPMConstants.PMEReturnCode.PMTrue

        ' Clear the Database Parameters Collection
        m_oDatabase.Parameters.Clear()

        With m_oDatabase

            ' Add the Input Params
            lReturn = .Parameters.Add(sName:="stats_folder_cnt", vValue:=gPMFunctions.ToSafeString(lStatsFolderCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return lReturn
            End If

            ' Add ExportFolderCnt as an INPUT param for an insert
            lReturn = .Parameters.Add(sName:="transaction_export_folder_cnt", vValue:=gPMFunctions.ToSafeString(lTransactionExportFolderCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return lReturn
            End If

        End With

        ' Execute Add Trans Export Details SQL Statement
        lReturn = m_oDatabase.SQLAction(sSQL:=ACAddTransDetailsDepositSQL, sSQLName:=ACAddTransDetailsDepositName, bStoredProcedure:=ACAddTransDetailsDepositStored, lRecordsAffected:=lRecordsAffected)

        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            Return lReturn
        End If

        Return result

    End Function

    ' ***************************************************************** '
    ' Name: TransferStatsFolder (Private)
    '
    ' Description:
    '
    ' ***************************************************************** '
    Private Function TransferStatsFolder(ByRef lStatsFolderCnt As Integer, ByRef lTransactionExportFolderCnt As Integer) As Integer

        Dim result As Integer = 0
        Dim lRecordsAffected, lReturn As Integer



        result = gPMConstants.PMEReturnCode.PMTrue

        ' Clear the Database Parameters Collection
        m_oDatabase.Parameters.Clear()

        With m_oDatabase

            ' Add the Input Params
            lReturn = .Parameters.Add(sName:="stats_folder_cnt", vValue:=gPMFunctions.ToSafeString(lStatsFolderCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return lReturn
            End If

            ' Add ExportFolderCnt as an OUTPUT param for an insert
            lReturn = .Parameters.Add(sName:="transaction_export_folder_cnt", vValue:=gPMFunctions.ToSafeString(lTransactionExportFolderCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMLong)

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return lReturn
            End If

        End With

        ' Execute Add Trans Export Folder SQL Statement
        lReturn = m_oDatabase.SQLAction(sSQL:=ACAddExportFolderSQL, sSQLName:=ACAddExportFolderName, bStoredProcedure:=ACAddExportFolderStored, lRecordsAffected:=lRecordsAffected)

        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            Return lReturn
        End If

        ' Get the Cnt of the record inserted
        lTransactionExportFolderCnt = m_oDatabase.Parameters.Item("transaction_export_folder_cnt").Value
        If lTransactionExportFolderCnt < 1 Then
            Return gPMConstants.PMEReturnCode.PMFalse
        End If

        Return result

    End Function

