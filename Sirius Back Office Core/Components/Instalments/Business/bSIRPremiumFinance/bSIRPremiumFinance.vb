    Private Function GetSGBrokerID(ByVal v_vArrayOfValidPFRFs(,) As Object, ByVal v_lCountOfPFRFs As Integer, ByVal v_crFinanceAmount As Decimal) As String
        Dim sRet As String = ""

        If gPMFunctions.ToSafeString(v_vArrayOfValidPFRFs(70, v_lCountOfPFRFs)).Trim() <> "" Then
            'commercial/personal selection based on threshold value
            If v_crFinanceAmount < v_vArrayOfValidPFRFs(72, v_lCountOfPFRFs) Then
                sRet = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(70, v_lCountOfPFRFs))
            Else
                sRet = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(71, v_lCountOfPFRFs))
            End If
        Else
            If gPMFunctions.NullToDouble(v_vArrayOfValidPFRFs(72, v_lCountOfPFRFs)) > 0 Then
                If v_crFinanceAmount < v_vArrayOfValidPFRFs(72, v_lCountOfPFRFs) Then
                    sRet = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(68, v_lCountOfPFRFs))
                Else
                    sRet = "-"
                End If
            Else
                sRet = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(68, v_lCountOfPFRFs))
            End If
        End If

        Return sRet
    End Function

