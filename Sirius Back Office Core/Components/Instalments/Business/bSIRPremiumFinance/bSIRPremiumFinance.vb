    ''' </summary>
    ''' <param name="nPremFinanceCnt"></param>
    ''' <param name="nPremFinanceVersion"></param>
    ''' <param name="r_oSubAgents"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function GetSubAgents(ByVal nPremFinanceCnt As Integer,
                                ByVal nPremFinanceVersion As Integer,
                                ByRef r_oSubAgents As Object) _
                                As Integer

        Const sMethodName As String = "GetSubAgents"
        Dim nReturn As Integer


        Try
            'TR - Assume Succes
            GetSubAgents = gPMConstants.PMEReturnCode.PMTrue

            'TR - Use the DB object
            With m_oDatabase
                'TR - Clear existing data
                .Parameters.Clear()
                'TR - Set our parameters
                If .Parameters.Add(sName:="nPremiumFinanceCnt",
                    vValue:=nPremFinanceCnt, iDirection:=gPMConstants.PMEParameterDirection.PMParamInput,
                        iDataType:=gPMConstants.PMEDataType.PMInteger) <> gPMConstants.PMEReturnCode.PMTrue Then
                    GetSubAgents = gPMConstants.PMEReturnCode.PMFalse
                    Exit Function
                End If
                If .Parameters.Add(sName:="nPremiumFinanceVersion",
                        vValue:=nPremFinanceVersion, iDirection:=gPMConstants.PMEParameterDirection.PMParamInput,
                        iDataType:=gPMConstants.PMEDataType.PMInteger) <> gPMConstants.PMEReturnCode.PMTrue Then
                    GetSubAgents = gPMConstants.PMEReturnCode.PMFalse
                    Exit Function
                End If
                'TR - Get the SubAgent
                nReturn = .SQLSelect(sSQL:=ksACGetSubAgentSQL,
                        sSQLName:=ksACGetSubAgentName,
                        bStoredProcedure:=kbACGetSubAgentStored,
                        vResultArray:=r_oSubAgents)

            End With

            If nReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                RaiseError(sMethodName, "GetSubAgents Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            Return nReturn

        Catch ex As System.Exception
            bPMFunc.LogMessage(sUsername:=m_sUsername,
                                                   iType:=gPMConstants.PMELogLevel.PMLogOnError,
                                                   sMsg:=sMethodName & " Failed.",
                                                   vApp:=ACApp, vClass:=ACClass,
                                                   vMethod:=sMethodName,
                                                   vErrNo:=Informations.Err().Number,
                                                   vErrDesc:=Informations.Err().Description, excep:=ex)
            ' If you want to rollback a transaction or something, do it here
            nReturn = gPMConstants.PMEReturnCode.PMFalse
        End Try
        Return nReturn
    End Function
