    ' ***************************************************************** '
    ' Name: CancelPolicies
    ' ***************************************************************** '
    Public Function CancelPolicies(ByRef r_vPremiumFinance As Array, ByRef r_sErrors As String, ByVal v_vCredits As Object, ByVal v_vDebits As Object, ByVal v_bWriteOff As Boolean, ByVal v_bSpoolDocument As Boolean, ByVal v_lLapseReasonId As Integer, ByVal v_dPolicyLapseDate As Date, Optional r_vDocumentArray() As Object = Nothing) As Integer
        Dim result As Integer = 0

        Const kMethodName As String = "CancelPolicies"

        Dim oAutoMTA As Object = Nothing
        Dim lReturn As Integer
        Dim vResults As Object = Nothing
        Dim nLower, nUpper As Integer
        Dim vPolicyListArray(,) As Object = Nothing
        Dim vPolicyPaidToDate As Object = Nothing

        Dim dLapsedDate As Date
        Dim vCancelQuoteArray(,) As Object
        Dim lPolicyCount, nCancelQuoteCount As Integer
        Dim lNewInsuranceFileCnt As Object
        Dim sFailureMessage As Object = ""

        Dim vArray(,) As Object
        Dim lInsuranceFolder, lPartyCnt As Integer
        Dim vTransactionArray As Object
        Dim cWriteOffAmount As Decimal
        Dim oDocument As bACTDocument.Form
        Dim vDocumentId As Integer
        Dim sDocumentRef As String = ""
        Dim lAccountId, lWriteOffTransactionId As Integer
        Dim oAllocation As  bACTAllocationManual.Business
        Dim lDocumentTypeId As Integer
        Dim sAccountShortCode As String = ""
        Dim lWriteOffAccountId As Integer
        Dim iSourceID As Integer
        Dim lDocumentId, lTransDetailId, lInsuranceFileCnt As Integer
        Dim vMatchTrans As Object
        Dim lWriteOffTransactionIdPlanOwner As Integer
        Dim oPolicyTransactionArray As Object = Nothing
        Dim nTransactionArrayCount As Integer = 0


        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ReDim vCancelQuoteArray(3, 0)
            ReDim vTransactionArray(1, 0)

            ReDim r_vDocumentArray(0)
            vDocumentId = 0
            'oAutoMTA = New bSIRAutoMTA.Business()

            m_lReturn = gPMComponentServices.CreateBusinessObject(r_oObject:=oAutoMTA, v_sClassName:="bSIRAutoMTA.Business", v_sCallingAppName:=ACApp, v_sUsername:=m_sUsername, v_sPassword:=m_sPassword, v_iUserID:=m_iUserID, v_iSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_iCurrencyID:=m_iCurrencyID, v_iLogLevel:=m_iLogLevel, v_oDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception()
            End If



            oAutoMTA.IsSingleInstalmentPlan = m_bIsSingleInstalmentPlan
            ' lReturn = CType(oAutoMTA, SSP.S4I.Interfaces.IBusiness).Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=m_sCallingAppName)

            lReturn = GetPolicyList(v_lPlanPFCnt:=gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), r_vPolicyListArray:=vPolicyListArray, v_lPlanPFVersion:=gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)))

            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError(kMethodName, "GetPolicyList" & " Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Loop through the policy list
            If Informations.IsArray(vPolicyListArray) Then

                nLower = vPolicyListArray.GetLowerBound(1)

                nUpper = vPolicyListArray.GetUpperBound(1)
                For nCount As Integer = nLower To nUpper

                    'get a policy having more than one instalment plan

                    lReturn = GetPolicyCount(v_lInsuranceFileCnt:=gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0)), r_lPolicyCount:=lPolicyCount)
                    If lPolicyCount > 1 Then

                        r_sErrors = r_sErrors & ";" & gPMFunctions.ToSafeString(vPolicyListArray(0, nCount))
                    Else
                        If v_dPolicyLapseDate < ToSafeDate(vPolicyListArray(9, nCount)) AndAlso m_bIsSingleInstalmentPlan Then
                            dLapsedDate = ToSafeDate(vPolicyListArray(9, nCount))
                        Else
                            dLapsedDate = v_dPolicyLapseDate
                        End If

                        lNewInsuranceFileCnt = 0

                        lReturn = oAutoMTA.QuoteCancellation(v_lPartyCnt:=gPMFunctions.ToSafeInteger(vPolicyListArray(5, nCount)), v_lInsuranceFolderCnt:=gPMFunctions.ToSafeInteger(vPolicyListArray(6, nCount)), v_dtEffectiveDate:=ToSafeDate(dLapsedDate), r_lNewInsuranceFileCnt:=lNewInsuranceFileCnt, r_sFailureMessage:=sFailureMessage, bUpdateStats:=False)

                        If lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                            ReDim Preserve vCancelQuoteArray(3, nCancelQuoteCount)

                            vCancelQuoteArray(0, nCancelQuoteCount) = lNewInsuranceFileCnt
                            vCancelQuoteArray(1, nCancelQuoteCount) = sFailureMessage
                            vCancelQuoteArray(2, nCancelQuoteCount) = vPolicyListArray(5, nCount)
                            vCancelQuoteArray(3, nCancelQuoteCount) = vPolicyListArray(6, nCount)
                            nCancelQuoteCount += 1
                        End If
                    End If
                Next
            End If

            If Informations.IsArray(vCancelQuoteArray) Then

                nLower = vCancelQuoteArray.GetLowerBound(1)

                nUpper = vCancelQuoteArray.GetUpperBound(1)

                lReturn = oAutoMTA.TransactPolicyVersions(v_lNewInsuranceFileCnt:=gPMFunctions.ToSafeInteger(vCancelQuoteArray(0, 0)), v_bIsPostStatsForLapsedPolicy:=True)
                For nCount As Integer = nLower To nUpper

                    If gPMFunctions.ToSafeString(vCancelQuoteArray(1, nCount)) = "" Then
                        If v_bSpoolDocument Then
                            Dim vKeyArray(,) As Object = Nothing

                            m_lReturn = GenerateDocument(ACDocTypeSchedule, ACSpoolSilentMode, gPMFunctions.ToSafeInteger(vCancelQuoteArray(0, nCount)), lInsuranceFolder, lPartyCnt, "Cancellation - Schedule Document", r_vKeyArray:=vKeyArray)

                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                gPMFunctions.RaiseError(kMethodName, "GenerateDocument" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                            End If

                            If Informations.IsArray(vKeyArray) Then
                                If r_vDocumentArray(r_vDocumentArray.GetUpperBound(0)) IsNot Nothing Then
                                    ReDim Preserve r_vDocumentArray(r_vDocumentArray.GetUpperBound(0) + 1)
                                End If
                                r_vDocumentArray(r_vDocumentArray.GetUpperBound(0)) = vKeyArray

                            End If

                        End If

                        lReturn = UpdateLapseReason(v_lLapseReasonId:=v_lLapseReasonId, v_lInsuranceFileCnt:=gPMFunctions.ToSafeInteger(vCancelQuoteArray(0, nCount)))

                        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            gPMFunctions.RaiseError(kMethodName, "UpdateLapseReason" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                        End If

                        r_vPremiumFinance(bSIRPremFinConst.k_PFIsCancelPolicyRun, 0) = 1

                        r_vPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndCancelled
                        lReturn = UpdateExistingRecord(r_vPremiumFinance, r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0), r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))
                        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            gPMFunctions.RaiseError(kMethodName, "UpdateExistingRecord" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                        End If

                    Else
                        ReDim vArray(0, 0)

                        vArray(0, 0) = vCancelQuoteArray(0, nCount)

                        lReturn = oAutoMTA.DeletePolicyVersions(CType(vArray, Object))
                    End If
                Next
            End If

            If Informations.IsArray(vCancelQuoteArray) Then
                nLower = vCancelQuoteArray.GetLowerBound(1)
                nUpper = vCancelQuoteArray.GetUpperBound(1)

                For nCount As Integer = nLower To nUpper
                    lReturn = GetPolicyTransaction(v_lInsuranceFileCnt:=vCancelQuoteArray(0, nCount),
                        r_vPolicyTransaction:=oPolicyTransactionArray)

                    If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError(kMethodName, "GetPolicyTransaction" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                    End If

                    If Informations.IsArray(oPolicyTransactionArray) Then
                        For nCountTransaction As Integer = LBound(oPolicyTransactionArray, 2) To UBound(oPolicyTransactionArray, 2)
                            ReDim Preserve vTransactionArray(1, nTransactionArrayCount)
                            If nCount = nUpper Then
                                If nCountTransaction = UBound(oPolicyTransactionArray, 2) Then
                                    vTransactionArray(0, nTransactionArrayCount) = oPolicyTransactionArray(1, 0)
                                    vTransactionArray(1, nTransactionArrayCount) = oPolicyTransactionArray(2, 0)
                                Else
                                    vTransactionArray(0, nTransactionArrayCount) = oPolicyTransactionArray(1, nCountTransaction + 1)
                                    vTransactionArray(1, nTransactionArrayCount) = oPolicyTransactionArray(2, nCountTransaction + 1)
                                End If
                            Else
                                vTransactionArray(0, nTransactionArrayCount) = oPolicyTransactionArray(1, nCountTransaction)
                                vTransactionArray(1, nTransactionArrayCount) = oPolicyTransactionArray(2, nCountTransaction)
                            End If
                            lAccountId = oPolicyTransactionArray(0, nCountTransaction)
                            nTransactionArrayCount = nTransactionArrayCount + 1
                        Next
                    End If
                Next
            End If

            If Informations.IsArray(vTransactionArray) Then
                nLower = LBound(vTransactionArray, 2)
                nUpper = UBound(vTransactionArray, 2)
                For iCount As Integer = nLower To nUpper
                    cWriteOffAmount = cWriteOffAmount + Val(vTransactionArray(1, iCount))
                Next
            End If

            If m_bIsSingleInstalmentPlan Then
                lReturn = AutoAllocate(CInt(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), lAccountId, cWriteOffAmount, lDocumentId, lTransDetailId, lInsuranceFileCnt)
                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "AutoAllocate" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            If cWriteOffAmount <> 0 And lDocumentId <> 0 Then
                lReturn = InsertCreditControlItemTrans(lAccountId, lDocumentId, cWriteOffAmount, lInsuranceFileCnt, CInt(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)))

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception
                End If
            End If
            If lTransDetailId <> 0 And lDocumentId <> 0 Then
                lReturn = UpdateTransactionID(lDocumentId, lTransDetailId)
                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "UpdateTransactionID" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If
            End If
            If v_bWriteOff And cWriteOffAmount <> 0 Then

                'Get the system option value for option "WriteOff Account"
                lReturn = GetSystemOptionLite(v_iOptionNumber:=5061, r_sOptionValue:=sAccountShortCode, v_iSourceID:=1)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception
                End If

                lReturn = GetAccountIdFromShortCode(sAccountShortCode, lWriteOffAccountId, iSourceID)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception
                End If

                lReturn = GetDocumentType("SWD", lDocumentTypeId)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "GetDocumentType" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                lReturn = GetDocumentReference(lDocumentTypeId, m_iSourceID, sDocumentRef)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception
                End If


                oDocument = New bACTDocument.Form
                m_lReturn = oDocument.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception
                End If

                lReturn = oDocument.DirectAdd(vDocumentID:=vDocumentId, vCompanyID:=iSourceID, vPostingstatusID:=3, vDocumenttypeID:=lDocumentTypeId, vAuditsetID:=0, vBatchID:=0, vDocumentRef:=sDocumentRef, vDocumentDate:=DateTime.Now, vCreatedDate:=DateTime.Now, vAuthorisedDate:=DateTime.Now, vComment:="", vWriteOffReasonID:=0, vInsuranceFileCnt:=0, vReason:="", vSubBranchID:=0, vClaimID:=0, v_vTermsOfPaymentId:=0, v_vPaymentDueDate:=DateTime.Now)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "oDocument.DirectAdd" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                lReturn = PrepareTransDetailItem(lAccountId, vDocumentId, 1, -1 * cWriteOffAmount, lWriteOffTransactionIdPlanOwner)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "PrepareTransDetailItem" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                If lWriteOffAccountId <> 0 Then
                    lReturn = PrepareTransDetailItem(lWriteOffAccountId, vDocumentId, 2, cWriteOffAmount, lWriteOffTransactionId)

                    If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Throw New Exception
                    End If
                End If

                If cWriteOffAmount <> 0 Then
                    If oAllocation Is Nothing Then
                        'Get Instance of Allocation Manual

                        oAllocation = New bACTAllocationManual.Business
                        m_lReturn = oAllocation.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp)

                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            Throw New Exception
                        End If
                    End If

                    'Set keys for the AllocationManual component
                    'vKeyArray = Array.CreateInstance(GetType(Object), New Integer() {gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue - gPMConstants.PMENavLetGetKeyColPosition.PMKeyName + 1, 2}, New Integer() {gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 0})
                    Dim vKeys(1, 2) As Object
                    ReDim vMatchTrans(0)

                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 0) = ACTKeyNameAccountID
                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 1) = ACTKeyNameTransDetailID
                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 2) = ACTKeyNameTransDetailIDs
                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 0) = lAccountId
                    'vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1) = Convert.ToString(lTransDetailId) & "|" & Convert.ToString(cWriteOffAmount)
                    vMatchTrans(0) = CStr(lWriteOffTransactionIdPlanOwner) & "|" & CStr(cWriteOffAmount * -1)
                    If lTransDetailId <> 0 Then
                        vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1) = CStr(lTransDetailId) & "|" & CStr(cWriteOffAmount)
                    Else
                        vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1) = vTransactionArray(0, 1) & "|" & CStr(cWriteOffAmount)
                    End If
                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 2) = vMatchTrans

                    'Perform the allocation
                    If oAllocation.SetKeys(vKeyArray:=vKeys) <> gPMConstants.PMEReturnCode.PMTrue Then
                        Throw New Exception
                    End If

                    If oAllocation.Start() <> gPMConstants.PMEReturnCode.PMTrue Then
                        Throw New Exception
                    End If

                End If

                If Not (oAllocation Is Nothing) Then

                    oAllocation.Dispose()
                    oAllocation = Nothing
                End If

                If r_sErrors <> "" Then
                    result = gPMConstants.PMEReturnCode.PMFail
                End If

            End If
            Return result
        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here

        Finally
            If Not oAutoMTA Is Nothing Then
                oAutoMTA.Dispose()
                oAutoMTA = Nothing
            End If
        End Try
        Return result
    End Function
