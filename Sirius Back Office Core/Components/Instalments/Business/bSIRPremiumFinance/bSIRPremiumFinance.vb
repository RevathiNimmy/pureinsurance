    ''' <summary>
    ''' InsertNewVersion
    ''' </summary>
    ''' <param name="v_vExistingPF"></param>
    ''' <param name="v_lPremiumFinanceCnt"></param>
    ''' <param name="v_lPremiumFinanceVersion"></param>
    ''' <param name="v_vPremiumFinanceMTA"></param>
    ''' <param name="v_dtNextPaymentDate"></param>
    ''' <param name="v_lInsuranceFileCnt"></param>
    ''' <param name="v_lPlanTransID"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function InsertNewVersion(ByVal v_vExistingPF(,) As Object,
                                     ByVal v_lPremiumFinanceCnt As Integer,
                                     ByRef v_lPremiumFinanceVersion As Integer,
                                     ByVal v_vPremiumFinanceMTA(,) As Object,
                                     ByRef v_dtNextPaymentDate As Object,
                                     ByVal v_lInsuranceFileCnt As Integer,
                                     ByVal v_lPlanTransID As Integer) As Integer

        Dim nResult As Integer = 0
        Dim sSqlString As String = ""
        Dim vTransArray(,) As Object = Nothing
        Dim lLBound, lUBound, lOldVersionNumber As Integer

        Try

            'TR - Make sure that the array is populated
            If Not Informations.IsArray(v_vExistingPF) Then
                Return PMEReturnCode.PMFail
            Else
                'TR - Assume success
                nResult = PMEReturnCode.PMTrue
            End If

            'TR - Increment the version number
            lOldVersionNumber = v_lPremiumFinanceVersion
            v_lPremiumFinanceVersion += 1

            If Informations.IsArray(v_vPremiumFinanceMTA) Then

                'TR - Loop through the Array of mTAs??? passed in
                lLBound = v_vPremiumFinanceMTA.GetLowerBound(1)
                lUBound = v_vPremiumFinanceMTA.GetUpperBound(1)
                For lRowIndex As Integer = lLBound To lUBound
                    'TR - First time in the loop, create our local array
                    If Not Informations.IsArray(vTransArray) Then
                        ReDim vTransArray(0, 0)
                    Else
                        'TR - Successuive time in loop, just increase size of array

                        ReDim Preserve vTransArray(0, vTransArray.GetUpperBound(1) + 1)
                    End If
                    'TR - Add a new column to the array and populate it with
                    'corresponding column from passed in array

                    vTransArray(0, vTransArray.GetUpperBound(1)) = v_vPremiumFinanceMTA(0, lRowIndex)
                Next lRowIndex

                m_lReturn = m_oDatabase.SQLBeginTrans()
                If m_lReturn <> PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                'TR - Insert the records joining the PFs to the instalments
                m_lReturn = InsertPFTransID(v_lPremiumFinanceCnt, v_lPremiumFinanceVersion, v_vPremiumFinanceMTA)
                If m_lReturn <> PMEReturnCode.PMTrue Then
                    nResult = m_lReturn
                    m_lReturn = m_oDatabase.SQLRollbackTrans()
                    Return nResult
                End If
            End If

            'Build Parameters Here!
            With m_oDatabase.Parameters
                .Clear()
                .Add("FinancePlanCnt", gPMFunctions.ToSafeString(v_lPremiumFinanceCnt), PMEParameterDirection.PMParamInput, PMEDataType.PMLong)
                .Add("FinancePlanVersion", gPMFunctions.ToSafeString(v_lPremiumFinanceVersion), PMEParameterDirection.PMParamInput, PMEDataType.PMLong)
                .Add("ClientID", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(v_vExistingPF(bSIRPremFinConst.k_PFPlanClientId, 0))), PMEParameterDirection.PMParamInput, PMEDataType.PMLong)
                .Add("CompanyNo", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(v_vExistingPF(bSIRPremFinConst.k_PFPlanCompanyNo, 0))), PMEParameterDirection.PMParamInput, PMEDataType.PMLong)
                .Add("SchemeNo", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(v_vExistingPF(bSIRPremFinConst.k_PFPlanSchemeNo, 0))), PMEParameterDirection.PMParamInput, PMEDataType.PMLong)
                .Add("SchemeVer", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(v_vExistingPF(bSIRPremFinConst.k_PFPlanSchemeVersion, 0))), PMEParameterDirection.PMParamInput, PMEDataType.PMLong)
                .Add("StartDate", DateTime.Today, PMEParameterDirection.PMParamInput, PMEDataType.PMDate)
                .Add("EndDate", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanEndDate, 0)), PMEParameterDirection.PMParamInput, PMEDataType.PMDate)
                .Add("SystemTag", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanSystemTag, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("CompanyName", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanCompanyName, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("SchemeName", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanSchemeName, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("ProductClass", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanProductClass, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("TransType", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanTransactionType, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("AmtToFinance", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("APR", gPMFunctions.ToSafeString(Math.Round(gPMFunctions.ToSafeDouble(v_vExistingPF(bSIRPremFinConst.k_PFPlanAPR, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMDouble)
                .Add("InterestRate", gPMFunctions.ToSafeString(Math.Round(gPMFunctions.ToSafeDouble(v_vExistingPF(bSIRPremFinConst.k_PFPlanInterestRate, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMDouble)
                .Add("DaysDelay", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(v_vExistingPF(bSIRPremFinConst.k_PFPlanDaysDelay, 0))), PMEParameterDirection.PMParamInput, PMEDataType.PMInteger)
                .Add("NoOfInstalments", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(v_vExistingPF(bSIRPremFinConst.k_PFPlanNoOfInstalments, 0))), PMEParameterDirection.PMParamInput, PMEDataType.PMInteger)
                .Add("FirstInstalment", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanFirstInstalment, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("OtherInstalments", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanOtherInstalments, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("CostOfProtection", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanCostOfProtection, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("Deposit", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanDeposit, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("NetAmount", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanNetAmount, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("TotalCost", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanTotalCost, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("InterestCost", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanInterestCost, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("MinFinanceCharge", gPMFunctions.ToSafeString(Math.Round(CDec(v_vExistingPF(bSIRPremFinConst.k_PFPlanMinFinanceCharge, 0)), 2)), PMEParameterDirection.PMParamInput, PMEDataType.PMCurrency)
                .Add("PayProtect", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanPayProtection, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("ClientName", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanClientName, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("ClientAddr1", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanClientAddress1, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("ClientAddr2", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanClientAddress2, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("ClientAddr3", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanClientAddress3, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
                .Add("ClientPCode", gPMFunctions.ToSafeString(v_vExistingPF(bSIRPremFinConst.k_PFPlanClientPostcode, 0)).Trim(), PMEParameterDirection.PMParamInput, PMEDataType.PMString)
