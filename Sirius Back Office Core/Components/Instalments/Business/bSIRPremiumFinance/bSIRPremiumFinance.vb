            End If

            lReturn = .Parameters.Add(sName:="user_name", vValue:=m_sUsername.Trim(), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMString)
            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return lReturn
            End If

            'sj 03/04/2003 - start
            lReturn = .Parameters.Add(sName:="next_orion_doc_ref", vValue:=gPMFunctions.ToSafeString(m_lNextOrionDocRefForInstalment), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMString)
            'sj 03/04/2003 - end
        End With

        ' Execute Add Stats Folder deposit SQL Statement

        lReturn = m_oDatabase.SQLAction(sSQL:="spu_add_stats_folder_Deposit", sSQLName:="add_stats_folder_Deposit", bStoredProcedure:=True, lRecordsAffected:=lRecordsAffected)

        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            Return lReturn
        End If

        ' Get the Cnt of the record inserted
