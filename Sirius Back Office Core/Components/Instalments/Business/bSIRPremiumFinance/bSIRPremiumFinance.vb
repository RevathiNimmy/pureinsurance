    ''' <summary>
    ''' This  insert a record into PFTransactionID on the basis of nInsuranceFileCntIndexinArray
    ''' If there is any confusion for insurance file count position you need to pass that position to this method depending upon the scenario
    ''' </summary>
    ''' <param name="v_lPremFinanceCnt"></param>
    ''' <param name="v_lPremFinanceVersion"></param>
    ''' <param name="v_vPFTransArray"></param>
    ''' <param name="nInsuranceFileCntIndexinArray"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Overloads Function InsertPFTransID(ByVal v_lPremFinanceCnt As Integer,
                                  ByVal v_lPremFinanceVersion As Integer,
                                  ByVal v_vPFTransArray(,) As Object, ByVal nInsuranceFileCntIndexinArray As Integer) As Integer

        Dim nResult As Integer = 0
        Dim sSqlString As String = String.Empty

        Try

            nResult = gPMConstants.PMEReturnCode.PMTrue

            'TR - Only attempt this if the TransArray is populated
            If Informations.IsArray(v_vPFTransArray) Then
                'InsuranceFileCntIndexinArray = v_vPFTransArray.GetUpperBound(0)
                ' InsuranceFileCnt is on 4th index in array, if array size increase then Upperbound is not always eqal to 4
                ' Roll back PN 5299


                'Putting InsuranceFileCnt=4 is not a generic condition sometimes  insurance_cnt is on 3 index hence in suc condition systems gets fails
                'i used this condition so that the case for 4 index would not affect.

                For lRowIndex As Integer = v_vPFTransArray.GetLowerBound(1) To _
                v_vPFTransArray.GetUpperBound(1)
                    'TR - Add a record into the Transaction_ID table, linking the
                    'Transaction to the PremiumFinance

                    bPMAddParameter.AddParameterLite(m_oDatabase, "pfprem_finance_cnt", v_lPremFinanceCnt,
                                                     gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
                    bPMAddParameter.AddParameterLite(m_oDatabase, "pfprem_finance_version", v_lPremFinanceVersion,
                                                     gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                    bPMAddParameter.AddParameterLite(m_oDatabase, "pftransaction_id", gPMFunctions.ToSafeInteger(
                                                     v_vPFTransArray(0, lRowIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    If gPMFunctions.ToSafeLong(v_vPFTransArray(nInsuranceFileCntIndexinArray, lRowIndex)) = 0 Then

                        bPMAddParameter.AddParameterLite(m_oDatabase, "insurance_file_cnt", DBNull.Value,
                                                         gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    Else
                        bPMAddParameter.AddParameterLite(m_oDatabase, "insurance_file_cnt", gPMFunctions.ToSafeLong(
                                                         v_vPFTransArray(nInsuranceFileCntIndexinArray, lRowIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    End If
                    m_lReturn = m_oDatabase.SQLAction(sSQL:=ACInsertPFTransIDSQL, sSQLName:=ACInsertPFTransIDName,
                                                      bStoredProcedure:=ACInsertPFTransIDStored)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return m_lReturn
                    End If
                Next
            End If
            Return nResult

        Catch excep As System.Exception
            nResult = gPMConstants.PMEReturnCode.PMError
            bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError,
                               "InsertPFTransID Failed", ACApp, ACClass, "InsertPFTransID", Informations.Err().Number, excep.Message, excep)
            Return nResult

        End Try
    End Function
    ''' <summary>
    ''' GenerateWriteOffAndAutoAllocate
    ''' </summary>
    ''' <param name="nAccountID"></param>
    ''' <param name="crWriteOffAmount"></param>
    ''' <param name="oOutStandingTransactionArray"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function GenerateWriteOffAndAutoAllocate(ByVal nAccountID As Integer,
                                                    ByVal crWriteOffAmount As Decimal,
                                                    ByVal oOutStandingTransactionArray As Object) As Integer

        'oOutStandingTransactionArray array format should be same as 
        'returned by spu_ACT_Get_Outstanding_Transactions_For_Insurance_Folder

        Dim nResult As Long
        Const kMethodName As String = "GenerateWriteOff"
        Dim oUserAuthority As Object = Nothing

        Try

            nResult = gPMConstants.PMEReturnCode.PMTrue
            Dim sAccountShortCode As String = String.Empty
            Dim nWriteOffAccountId As Integer
            Dim nSourceID As Integer
            Dim nDocumentId As Integer = 0
            Dim nTransDetailId As Integer = 0
            Dim nInsuranceFileCnt As Integer = 0
            Dim nWriteOffTransactionId As Integer = 0
            Dim oAllocation As Object = Nothing
            Dim nDocumentTypeId As Integer = 0
            Dim sDocumentRef As String = String.Empty
            Dim oDocument As Object = Nothing
            Dim nWriteOffTransactionIdPlanOwner As Integer = 0
            Dim bWriteOffTransaction As Boolean = False

            If crWriteOffAmount <> CDec(0) Then
                'Get the system option value for option "WriteOff Account"
                nResult = GetSystemOptionLite(v_iOptionNumber:=5061, r_sOptionValue:=sAccountShortCode, v_iSourceID:=1)

                If nResult <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "GetSystemOptionLite" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                nResult = GetAccountIdFromShortCode(sAccountShortCode, nWriteOffAccountId, nSourceID)

                If nResult <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "GetAccountIdFromShortCode" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                nResult = GetDocumentType("SWD", nDocumentTypeId)

                If nResult <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "GetDocumentType" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                nResult = GetDocumentReference(nDocumentTypeId, m_iSourceID, sDocumentRef)

                If nResult <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "GetDocumentReference" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                m_lReturn = gPMComponentServices.CreateBusinessObject(r_oObject:=oDocument,
                                                                      v_sClassName:="bACTDocument.Form",
                                                                      v_sCallingAppName:=ACApp,
                                                                      v_sUsername:=m_sUsername,
                                                                      v_sPassword:=m_sPassword,
                                                                      v_iUserID:=m_iUserID,
                                                                      v_iSourceID:=m_iSourceID,
                                                                      v_iLanguageID:=m_iLanguageID,
                                                                      v_iCurrencyID:=m_iCurrencyID,
                                                                      v_iLogLevel:=m_iLogLevel,
                                                                      v_oDatabase:=m_oDatabase)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "CreateBusinessObject" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                nResult = oDocument.DirectAdd(vDocumentId:=ToSafeInteger(nDocumentId),
                                              vCompanyID:=ToSafeInteger(nSourceID),
                                              vPostingstatusID:=3,
                                              vDocumenttypeID:=ToSafeInteger(nDocumentTypeId),
                                              vAuditsetID:=0,
                                              vBatchID:=0,
                                              vDocumentRef:=ToSafeString(sDocumentRef),
                                              vDocumentDate:=DateTime.Now,
                                              vCreatedDate:=DateTime.Now,
                                              vAuthorisedDate:=DateTime.Now,
                                              vComment:="",
                                              vWriteOffReasonID:=0,
                                              vInsuranceFileCnt:=0,
                                              vReason:="",
                                              vSubBranchID:=0,
                                              vClaimID:=0,
                                              v_vTermsOfPaymentId:=0,
                                              v_vPaymentDueDate:=DateTime.Now)

                If nResult <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "oDocument.DirectAdd" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                nResult = PrepareTransDetailItem(nAccountID, nDocumentId, 1, -1 * crWriteOffAmount, nWriteOffTransactionIdPlanOwner)

                If nResult <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "PrepareTransDetailItem" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                If nWriteOffAccountId <> 0 Then
                    nResult = PrepareTransDetailItem(nWriteOffAccountId, nDocumentId, 2, crWriteOffAmount, nWriteOffTransactionId)

                    If nResult <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError(kMethodName, "UpdateTransactionID" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                    End If
                End If
                bWriteOffTransaction = True
            End If


            If oOutStandingTransactionArray IsNot Nothing Then

                Dim oMatchTrans(oOutStandingTransactionArray.GetUpperBound(1) - 1)
                'If no SWD is generated, one trsanction will go in oKeys rest in oMatchTrans

                Dim vKeys(1, 2) As Object
                Dim nMatchRow As Integer = 0

                Dim nMainRow As Boolean = False
                If (bWriteOffTransaction AndAlso Not nMainRow) Then
                    'As write off not part of oOutStandingTransactionArray
                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 1) = PMNavKeyConst.ACTKeyNameTransDetailID
                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1) = CStr(nWriteOffTransactionIdPlanOwner) & "|" _
                    & Val(CStr(crWriteOffAmount * (-1)))
                    nMainRow = True

                    ReDim oMatchTrans(oOutStandingTransactionArray.GetUpperBound(1)) 'All entries will go in oMatchTrans
                End If

                For nRow As Integer = LBound(oOutStandingTransactionArray, 2) To UBound(oOutStandingTransactionArray, 2)

                    'If we have a write-off row then this is treated as the main transaction
                    'else the first credit transaction is treated as the main transaction
                    If (oOutStandingTransactionArray(2, nRow) < 0 AndAlso Not nMainRow) Then
                        vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 1) = PMNavKeyConst.ACTKeyNameTransDetailID

                        vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1) = CStr(oOutStandingTransactionArray(1, nRow)) & "|" &
                        Val(CStr(oOutStandingTransactionArray(2, nRow)))

                        nMainRow = True
                    Else
                        oMatchTrans(nMatchRow) = CStr(oOutStandingTransactionArray(1, nRow)) & "|" &
                        Val(CStr(oOutStandingTransactionArray(2, nRow)))

                        nMatchRow += 1
                    End If
                Next nRow

                vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 0) = ACTKeyNameAccountID
                vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 1) = ACTKeyNameTransDetailID
                vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 2) = ACTKeyNameTransDetailIDs
                vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 0) = nAccountID
                vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 2) = oMatchTrans

                If oAllocation Is Nothing Then
                    m_lReturn = gPMComponentServices.CreateBusinessObject(r_oObject:=oAllocation,
                                                                          v_sClassName:="bACTAllocationManual.Business",
                                                                          v_sCallingAppName:=ACApp,
                                                                          v_sUsername:=m_sUsername,
                                                                          v_sPassword:=m_sPassword,
                                                                          v_iUserID:=m_iUserID,
                                                                          v_iSourceID:=m_iSourceID,
                                                                          v_iLanguageID:=m_iLanguageID,
                                                                          v_iCurrencyID:=m_iCurrencyID,
                                                                          v_iLogLevel:=m_iLogLevel)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError(kMethodName, "UpdateTransactionID" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                    End If
                End If




                If oAllocation.SetKeys(vKeyArray:=CType(vKeys, Object)) <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "UpdateTransactionID" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                If oAllocation.Start() <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError(kMethodName, "UpdateTransactionID" & " Failed", gPMConstants.PMELogLevel.PMLogError)
                End If


                If Not (oAllocation Is Nothing) Then
                    oAllocation.Dispose()
                    oAllocation = Nothing
                End If

            End If

        Catch ex As Exception
            bPMFunc.LogMessage(sUsername:=m_sUsername,
                               iType:=gPMConstants.PMELogLevel.PMLogOnError,
                               sMsg:="GenerateWriteOff Failed",
                               vApp:=ACApp,
                               vClass:=ACClass,
                               vMethod:="GenerateWriteOff",
                               vErrNo:=Informations.Err().Number, vErrDesc:=ex.Message)
            nResult = gPMConstants.PMEReturnCode.PMFail
        Finally
            oUserAuthority = Nothing

        End Try
        Return nResult

    End Function

