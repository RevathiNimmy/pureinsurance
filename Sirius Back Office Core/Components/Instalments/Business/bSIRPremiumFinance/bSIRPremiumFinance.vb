    ' ***************************************************************** '
    ' Name: SaveInstalments
    '
    ' Description: Transact an in house finance plan
    '
    ' History:
    ' RAW 07/03/2003 : added function
    ' RAW 27/03/2003 : removed vPremiumFinanceTransactions parameter
    ' ***************************************************************** '
    Private Function SaveInstalments(ByVal vPremiumFinance As Array) As Integer

        Dim result As Integer = 0
        Dim oInstalments As bSIRPFInstalments.Business
        Dim vSinglePFRFArray(,) As Object = Nothing
        Dim bChargeTaxToFirstInstalment, bChargeFeeToFirstInstalment As Boolean
        Dim lPremiumFinanceCnt, lPRemiumFinanceVer As Integer
        Dim iAlignTo As Integer
        Dim bCreateDDM As Boolean
        Dim vPreviousPlan As Object = Nothing
        Dim lOldInsuranceFileCnt As Integer
        Dim iNoOfPreviousInstalments As Integer
        Dim dtStartDate As Date

        Try

            result = gPMConstants.PMEReturnCode.PMTrue


            oInstalments = New bSIRPFInstalments.Business
            m_lReturn = oInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            m_lReturn = oInstalments.SetProcessModes(m_iTask, m_lNavigate, m_lProcessMode, m_sTransactionType, m_dtEffectiveDate)

            'TR - Get the Premium Finance Count & Version

            lPremiumFinanceCnt = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0))

            lPRemiumFinanceVer = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))

            'TR - Get the PFRF info

            m_lReturn = GetSinglePFRF(gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFRF_ID, 0)), vSinglePFRFArray)

            'TR - Make sure that this worked OK
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            'TR - Now get the info from the rates record.
            bChargeTaxToFirstInstalment = gPMFunctions.NullToInteger(vSinglePFRFArray(42, 0))
            bChargeFeeToFirstInstalment = gPMFunctions.NullToInteger(vSinglePFRFArray(43, 0))
            Dim iSingleInstalmentPerMonth As Integer = gPMFunctions.ToSafeInteger(vSinglePFRFArray(71, 0))
            Dim iFirstInstalmentDateAlignWithDayInMonth As Integer = gPMFunctions.ToSafeInteger(vSinglePFRFArray(72, 0))

            ' Alix Bergeret - 31/03/2003 - Issue 2914
            ' Do we align dates to policy anniversary or client prefs?
            iAlignTo = gPMFunctions.NullToInteger(vSinglePFRFArray(6, 0))

            ' SET 11/08/2004 ISS13980 - do we need to create a new direct debit
            'mandate?  default to yes
            bCreateDDM = True

            If (Convert.ToString(vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)).ToUpper() = "MTA" OrElse Convert.ToString(vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)).ToUpper() = "REN") AndAlso gPMFunctions.NullToString(Convert.ToString(vPremiumFinance(bSIRPremFinConst.k_PFPlanMediaTypeValidation, 0)).Trim()) = "BANK" AndAlso gPMFunctions.NullToString(Convert.ToString(vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeTypeCode, 0)).Trim()) = "IH" Then

                'Get the original insurance file that is being renewed
                With m_oDatabase
                    .Parameters.Clear()
                    .Parameters.Add("renewal_insurance_file_cnt", gPMFunctions.ToSafeString(gPMFunctions.NullToLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0))), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                    .Parameters.Add("old_insurance_file_cnt", gPMFunctions.ToSafeString(DBNull.Value.ToString), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMLong)

                    .Parameters.Add("party_cnt", gPMFunctions.ToSafeString(DBNull.Value.ToString), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMLong)

                    .Parameters.Add("amount_to_finance", gPMFunctions.ToSafeString(DBNull.Value.ToString), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMCurrency)

                    m_lReturn = .SQLSelect("spu_SIRRen_Get_Original_Insurance_File", "Select Original Insurance File from Renewal", True)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        ' Log Error.
                        bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to get original insurance file cnt from renewal", vApp:=ACApp, vClass:=ACClass, vMethod:="SaveInstalments", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                        result = gPMConstants.PMEReturnCode.PMFalse
                    End If
                    lOldInsuranceFileCnt = gPMFunctions.NullToLong(.Parameters.Item("old_insurance_file_cnt").Value)
                End With

                m_lReturn = GetSingleFinancePlanFromInsFileCnt(lOldInsuranceFileCnt, vPreviousPlan)

                If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                    ' compare the bank details for the old & new plans
                    If vPremiumFinance(k_PFPlanTransactionType, 0) = "REN" Then
                        bCreateDDM = False 'If the product is changed during renewal (uploading policies)( it creates seperates 0N)
                    Else
                        m_lReturn = BankDetailsHaveChanged(v_vPreviousPlan:=vPreviousPlan, v_vNewPlan:=vPremiumFinance, r_bResult:=bCreateDDM)
                    End If

                End If
            End If

            ' Create the instalment plan
            'Change made on Behalf of Simon Baynes
            'AAB-06-Oct-2003 13:59 - Added CreateDepositRecord and DepositAmount to support
            '                        RI/COM/TAX dripping

            m_lReturn = oInstalments.CreateInstalments(v_lPremFinanceCnt:=lPremiumFinanceCnt, v_lPremFinanceVersion:=lPRemiumFinanceVer,
                                                       v_dFirstInstalmentDate:=CDate(vPremiumFinance(bSIRPremFinConst.k_PFPlanFirstInstalmentdate, 0)),
                                                       v_cFirstInstalmentAmount:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanFirstInstalment, 0)),
                                                       v_dNextInstalmentDate:=CDate(vPremiumFinance(bSIRPremFinConst.k_PFPlanNextInstalmentdate, 0)),
                                                       v_cNextInstalmentAmount:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanOtherInstalments, 0)),
                                                       v_dLastInstalmentDate:=CDate(vPremiumFinance(bSIRPremFinConst.k_PFPlanLastInstalmentdate, 0)),
                                                       v_cTax:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanTaxCost, 0)), v_cInterest:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanInterestCost, 0)),
                                                       v_cFee:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanFinanceCharge, 0)), v_cCommission:=0,
                                                       v_cTotalAmount:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanTotalCost, 0)),
                                                       v_sMediaTypeValidationCode:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanMediaTypeValidation, 0)),
                                                       v_sPFSchemeTypeCode:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeTypeCode, 0)),
                                                       v_iDayOfWeekOrMonth:=gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0)),
                                                       v_iFrequencyAmount:=gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyAmount, 0)),
                                                       v_sFrequencyInterval:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0)),
                                                       v_bChargeTaxToFirstInstalment:=bChargeTaxToFirstInstalment, v_bChargeFeeToFirstInstalment:=bChargeFeeToFirstInstalment,
                                                       v_iAlignDateTo:=iAlignTo, v_cDepositAmount:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0)),
                                                       v_bCreateDepositRecord:=CBool(vPremiumFinance(bSIRPremFinConst.k_PFPlanDepositAsInstalment, 0)),
                                                       v_bCreateDirectDebitMandate:=bCreateDDM, v_sTransactionType:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)),
                                                       v_iSingleInstalmentPerMonth:=iSingleInstalmentPerMonth, v_iFirstInstalmentDateAlignWithDayInMonth:=iFirstInstalmentDateAlignWithDayInMonth)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = m_lReturn
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="SaveInstalments Failed CreateInstalments", vApp:=ACApp, vClass:=ACClass, vMethod:="SaveInstalments", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return result
            End If

            ' if the instalment plan is on hold

            If gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0)) = bSIRPremFinConst.PFStatusIndOnHold AndAlso Convert.ToString(vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)).ToUpper() <> "REN" Then

                ' update all instalments on the plan to share the on hold status
                m_lReturn = UpdateInstalmentStatusForPlan(lPremiumFinanceCnt, lPRemiumFinanceVer, "H")
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = m_lReturn
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to update the status of instalments on plan cnt: " & lPremiumFinanceCnt & " version: " & gPMFunctions.ToSafeString(lPRemiumFinanceVer) & " to status 'OnHold'", vApp:=ACApp, vClass:=ACClass, vMethod:="SaveInstalments", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                End If

            End If
            If m_bIsSinglePlanParty And m_bMakeLiveSingleInstalmentPlan Then
                m_lReturn = GetPreviousInstalments(v_lpfprem_finance_cnt:=m_lPremFinanceCnt,
                                                   v_lpfprem_finance_version:=m_lPremFinanceVer,
                                                   v_dDueDate:=m_dtStartDate,
                                                   r_iNoPreviousInstalments:=iNoOfPreviousInstalments)

                If iNoOfPreviousInstalments >= ToSafeInteger(vPremiumFinance(k_PFPlanNoOfInstalments, 0)) Then
                    dtStartDate = m_dtCoverStartDate
                Else
                    dtStartDate = m_dtStartDate
                End If
                m_lReturn = UpdateInstalments(lPremiumFinanceCnt, lPRemiumFinanceVer, m_dtStartDate)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = m_lReturn
                    bPMFunc.LogMessage(sUsername:=m_sUsername,
                        iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to update the instalments on plan cnt: " & lPremiumFinanceCnt & " version: " & lPRemiumFinanceVer,
                        vApp:=ACApp, vClass:=ACClass,
                        vMethod:="SaveInstalments", vErrNo:=Informations.Err.Number, vErrDesc:=Informations.Err.Description)
                End If
            End If

            Return result

        Catch excep As System.Exception

            result = Informations.Err().Number
            m_lReturn = m_oDatabase.SQLRollbackTrans()
            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="SaveInstalments Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="SaveInstalments", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ***************************************************************** '
    ' Name: DeletePlan
    '
    ' Description:  Deletes a Premium Finance Plan.
    '
    ' History:
    '   PF260901 - created
    ' ***************************************************************** '
    Public Function DeletePlan(ByVal v_lPremiumFinanceCnt As Integer, ByVal v_lPremiumFinanceVersion As Integer, ByVal v_sStatusInd As String) As Integer

        Dim result As Integer = 0
        Dim lReturnState As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Validate plan version & status
            If v_lPremiumFinanceVersion > 1 Then
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Plan is not version 1", vApp:=ACApp, vClass:=ACClass, vMethod:="DeletePlan", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            ' Validate plan version & status
            If v_sStatusInd >= bSIRPremFinConst.PFStatusIndLive Then
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Plan is not pre-live", vApp:=ACApp, vClass:=ACClass, vMethod:="DeletePlan", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            ' Happy, we can now delete, send this direct to stored procedure
            m_oDatabase.Parameters.Clear()

            m_lReturn = m_oDatabase.Parameters.Add(sName:="pfprem_finance_cnt", vValue:=gPMFunctions.ToSafeString(v_lPremiumFinanceCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            m_lReturn = m_oDatabase.Parameters.Add(sName:="pfprem_finance_version", vValue:=gPMFunctions.ToSafeString(v_lPremiumFinanceVersion), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

            m_lReturn = m_oDatabase.Parameters.Add(sName:="returnstate", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMString)

            ' Send the command
            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACDeletePFPremiumFinanceSQL, sSQLName:=ACDeletePFPremiumFinanceName, bStoredProcedure:=ACDeletePFPremiumFinanceStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Check the return state
            lReturnState = m_oDatabase.Parameters.Item("returnstate").Value
            If lReturnState <> gPMConstants.PMEReturnCode.PMTrue Then
                Return lReturnState
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="DeletePlan Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="DeletePlan", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ''' <summary>
    ''' Converts a Quote Array into a Plan Array for insertion into DB as a New PFPlan
    ''' </summary>
    ''' <param name="v_vQuoteArray"></param>
    ''' <param name="v_lSelectedQuoteIndex"></param>
    ''' <param name="r_vPFPlanArray"></param>
    ''' <param name="v_vOriginalPlanArray"></param>
    ''' <param name="v_lSourceID"></param>
    ''' <param name="v_lSubBranchId"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function ConvertQuoteToPlanArray(ByVal v_vQuoteArray(,) As Object,
                                             ByVal v_lSelectedQuoteIndex As Integer,
                                             ByRef r_vPFPlanArray(,) As Object,
                                             ByVal v_vOriginalPlanArray(,) As Object,
                                             ByVal v_lSourceID As Integer,
                                             ByVal v_lSubBranchId As Integer) As Integer

        Dim nResult As Integer = PMEReturnCode.PMTrue
        Dim vClientDetailsArray(,) As Object = Nothing

        ' RAW 27/02/2003 : ISS2487 : added
        ' Validate incoming parameters
        If Not Informations.IsArray(v_vQuoteArray) Then
            nResult = gPMConstants.PMEReturnCode.PMFalse
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Quote array is not an array", vApp:=ACApp, vClass:=ACClass, vMethod:="ConvertQuoteToPlanArray")
            Return nResult
        End If

        'TR - Create the correct shape PFPlan array for one record
        ReDim r_vPFPlanArray(bSIRPremFinConst.kUseTransactionCurrency, 0)
        ReDim r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderCountryID, 0)

        'The Keys to the Premium Finance depend on whether this record is being updated or inserted. For now set them to zero

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0) = 0

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0) = 0

        r_vPFPlanArray(bSIRPremFinConst.kUseTransactionCurrency, 0) = ToSafeInteger(m_iUseTransCurrency)

        'Changes done as per VB code
        'If Not False Then
        If Not Informations.IsNothing(v_vOriginalPlanArray) Then
            'Set to on hold if previously on hold otherwise set to saved status

            If gPMFunctions.ToSafeString(v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanStatusInd, 0)) = bSIRPremFinConst.PFStatusIndOnHold Then

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndOnHold
            Else

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndSaved
            End If
        Else

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndSaved
        End If

        'Transfer data over from QuoteArray

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSchemeNo, 0) = v_vQuoteArray(k_PFQuoteSchemeNo, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCompanyNo, 0) = v_vQuoteArray(k_PFQuoteCompanyNo, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCompanyName, 0) = v_vQuoteArray(k_PFQuoteCompanyName, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSchemeVersion, 0) = v_vQuoteArray(k_PFQuoteSchemeVersion, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSchemeName, 0) = v_vQuoteArray(k_PFQuoteSchemeName, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPfFrequency_ID, 0) = v_vQuoteArray(k_PFQuoteFrequencyID, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanMediaType_ID, 0) = v_vQuoteArray(k_PFQuoteMediaTypeID, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanProductClass, 0) = v_vQuoteArray(k_PFQuoteProductClass, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0) = v_vQuoteArray(k_PFQuoteTotalAmountInput, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanNoOfInstalments, 0) = v_vQuoteArray(k_PFQuoteInstalmentsToPay, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanFirstInstalmentdate, 0) = v_vQuoteArray(k_PFQuoteFirstInstalmentDate, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanNextInstalmentdate, 0) = v_vQuoteArray(k_PFQuoteNextInstalmentDate, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanLastInstalmentdate, 0) = v_vQuoteArray(k_PFQuoteLastInstalmentDate, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanFirstInstalment, 0) = v_vQuoteArray(k_PFQuoteFirstInstalmentAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanOtherInstalments, 0) = v_vQuoteArray(k_PFQuoteOtherInstalmentAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanTotalCost, 0) = v_vQuoteArray(k_PFQuoteTotalInstalmentsAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAPR, 0) = v_vQuoteArray(k_PFQuoteAprRate, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanInterestRate, 0) = v_vQuoteArray(k_PFQuoteInterestRate, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanOriginalRate, 0) = v_vQuoteArray(k_PFOriginalRate, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanDeposit, 0) = v_vQuoteArray(k_PFQuoteDepositAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanInterestCost, 0) = v_vQuoteArray(k_PFQuoteInterestAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanNetAmount, 0) = gPMFunctions.ToSafeDouble(v_vQuoteArray(k_PFQuoteTotalAmountInput, v_lSelectedQuoteIndex)) - gPMFunctions.ToSafeDouble(v_vQuoteArray(k_PFQuoteDepositAmount, v_lSelectedQuoteIndex))

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanTaxCost, 0) = v_vQuoteArray(k_PFQuoteTaxAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCostOfProtection, 0) = v_vQuoteArray(k_PFQuoteProtectionAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanDaysDelay, 0) = v_vQuoteArray(k_PFQuoteDaysDelay, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanMediaTypeValidation, 0) = v_vQuoteArray(k_PFQuoteMediaTypeValidation, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0) = v_vQuoteArray(k_PFQuoteSchemeTypeCode, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFRF_ID, 0) = v_vQuoteArray(k_PFQuotePFRF_ID, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanFinanceCharge, 0) = v_vQuoteArray(k_PFQuoteFinanceCharge, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0) = v_vQuoteArray(k_PFQuoteFrequencyPeriod, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanFrequencyAmount, 0) = v_vQuoteArray(k_PFQuoteFrequencyAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanOriginalAmount, 0) = v_vQuoteArray(k_PFQuoteOriginalAmount, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClaimDebtID, 0) = v_vQuoteArray(k_PFQuoteClaimDebtID, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanUserID, 0) = v_vQuoteArray(k_PFQuoteUserID, v_lSelectedQuoteIndex)

        'PN 50319

        If gPMFunctions.ToSafeDouble(m_vAgentCnt) > 0 Then

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAgentCnt, 0) = m_vAgentCnt
        Else

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAgentCnt, 0) = v_vQuoteArray(k_PFQuoteAgentCnt, v_lSelectedQuoteIndex)
        End If

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAgentRef, 0) = v_vQuoteArray(k_PFQuoteAgentRef, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSource_ID, 0) = v_lSourceID

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSubBranchID, 0) = v_lSubBranchId
        'r_vPFPlanArray(k_PFPlanBatchID, 0) = v_lSubBranchID  '(RC) PLICO 9-10

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanProduct_ID, 0) = m_lProductID
        If m_sProductCode.ToUpper() = "REN" And Business.AlignPremiumToOptions.AlignWithClientPreference = Business.AlignPremiumToOptions.AlignWithPolicyRenewalDate Then

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanStartDate, 0) = m_dtStartDate
        Else

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanStartDate, 0) = v_vQuoteArray(k_PFQuoteFirstInstalmentDate, v_lSelectedQuoteIndex)
        End If

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanEndDate, 0) = m_dtEndDate

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanTransactionType, 0) = v_vQuoteArray(k_PFQuoteProductCode, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0) = m_lInsuranceFileCnt

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientId, 0) = m_lPartyCnt

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanIsQuote, 0) = 1

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanInterestFree, 0) = "N"
        'We need to pass the day of the week OR month, depending on the frequency of the chosen quote.

        If gPMFunctions.ToSafeString(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0)) = "w" Then

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0) = m_iDayOfWeek
        ElseIf gPMFunctions.ToSafeString(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0)) = "m" Then

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0) = m_iDayInMonth
        End If

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanTerms, 0) = v_vQuoteArray(k_PFSGTerms, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanReference, 0) = v_vQuoteArray(k_PFSGRef, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanRefundType, 0) = v_vQuoteArray(k_PFQuoteRefundType, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PfPlanTaxGroupID, 0) = v_vQuoteArray(k_PFQuoteTaxGroupID, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanXSLCode, 0) = v_vQuoteArray(k_PFQuoteXSLCode, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSGSchemeType, 0) = v_vQuoteArray(k_PFSGSchemeType, v_lSelectedQuoteIndex)

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSGSchemeCode, 0) = v_vQuoteArray(k_PFSGRef, v_lSelectedQuoteIndex)

        PopulateClientDetails(vClientDetailsArray, m_lPartyCnt)
        If Informations.IsArray(vClientDetailsArray) Then

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientCode, 0) = vClientDetailsArray(1, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientName, 0) = vClientDetailsArray(6, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientAddress1, 0) = vClientDetailsArray(7, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientAddress2, 0) = vClientDetailsArray(8, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientAddress3, 0) = vClientDetailsArray(9, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientAddress4, 0) = vClientDetailsArray(10, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientPostcode, 0) = vClientDetailsArray(11, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientAreaCode, 0) = vClientDetailsArray(12, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientPhone, 0) = vClientDetailsArray(13, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientExtn, 0) = vClientDetailsArray(14, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientCountry_ID, 0) = vClientDetailsArray(15, 0)

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanClientPartyType, 0) = vClientDetailsArray(16, 0)
        End If

        'Copy any original Informations that needs to be kept
        If Not False Then
            If Informations.IsArray(v_vOriginalPlanArray) Then
                'Bank

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankName, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankName, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankSortCode, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankSortCode, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankAccountNo, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankAccountNo, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankAccountName, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankAccountName, 0)

                r_vPFPlanArray(bSIRPremFinConst.kBIC, 0) = v_vOriginalPlanArray(bSIRPremFinConst.kBIC, 0)

                r_vPFPlanArray(bSIRPremFinConst.kIBAN, 0) = v_vOriginalPlanArray(bSIRPremFinConst.kIBAN, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankBranch, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankBranch, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankAddress1, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankAddress1, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankAddress2, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankAddress2, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankAddress3, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankAddress3, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankTown, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankTown, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankAddress4, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankAddress4, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankPostcode, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankPostcode, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankCountry, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankCountry, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankAreaCode, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankAreaCode, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankPhone, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankPhone, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankExtn, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankExtn, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankFaxCode, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankFaxCode, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankFax, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankFax, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBankCountry_ID, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanBankCountry_ID, 0)

                'Credit Card

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCCNumber, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanCCNumber, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCCExpiryDate, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanCCExpiryDate, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCCStartDate, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanCCStartDate, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCCIssue, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanCCIssue, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCCPin, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanCCPin, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPartyBankIdSel, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanPartyBankIdSel, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderName, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PfPlanCardholderName, 0)
                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCardType, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanCardType, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderCountryID, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PfPlanCardholderCountryID, 0)

                'Original Reference

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0)

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAuthCode, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanAuthCode, 0)
            End If
        End If

        If Not False Then
            If Informations.IsArray(v_vOriginalPlanArray) Then
                If v_vOriginalPlanArray.GetUpperBound(0) >= bSIRPremFinConst.k_PFPlanCCCancelled Then

                    r_vPFPlanArray(bSIRPremFinConst.k_PFPlanDDCancelled, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanDDCancelled, 0)

                    r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCCCancelled, 0) = v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanCCCancelled, 0)
                End If
            Else

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanDDCancelled, 0) = DBNull.Value

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCCCancelled, 0) = DBNull.Value
            End If
        Else

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanDDCancelled, 0) = DBNull.Value

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCCCancelled, 0) = DBNull.Value
        End If

        r_vPFPlanArray(bSIRPremFinConst.k_PFPlanDepositAsInstalment, 0) = v_vQuoteArray(k_PFDepositAsInstalment, v_lSelectedQuoteIndex)

        Return nResult

    End Function

    '*************************************************************************
    'Name:          InsertOrUpdatePremiumFinance
    'Description:   Called from the User control, which only has the plan data
    '               in a Quote Array format. This calls a convert function to
    '               change this to a PFPlan Array. Then works out whether to
    '               insert a new Premium Finance or Update an existing one
    'History:       25/11/2002 - TR - Created
    '*************************************************************************
    Public Function InsertOrUpdatePremiumFinance(ByVal v_vQuoteArray As Object, ByVal v_lSelectedQuoteIndex As Integer, ByVal v_vPFTransArray As Object, ByRef r_lPremiumFinanceCnt As Integer, ByRef r_lPremiumFinanceVer As Integer) As Integer
        Return InsertOrUpdatePremiumFinance(v_vQuoteArray:=v_vQuoteArray, v_lSelectedQuoteIndex:=v_lSelectedQuoteIndex, v_vPFTransArray:=v_vPFTransArray, r_lPremiumFinanceCnt:=r_lPremiumFinanceCnt, r_lPremiumFinanceVer:=r_lPremiumFinanceVer, v_iMTAType:=bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread, v_vOriginalPlanArray:=Nothing)
    End Function

    Public Function InsertOrUpdatePremiumFinance(ByVal v_vQuoteArray As Object, ByVal v_lSelectedQuoteIndex As Integer, ByVal v_vPFTransArray As Object, ByRef r_lPremiumFinanceCnt As Integer, ByRef r_lPremiumFinanceVer As Integer, ByVal v_iMTAType As Integer) As Integer
        Return InsertOrUpdatePremiumFinance(v_vQuoteArray:=v_vQuoteArray, v_lSelectedQuoteIndex:=v_lSelectedQuoteIndex, v_vPFTransArray:=v_vPFTransArray, r_lPremiumFinanceCnt:=r_lPremiumFinanceCnt, r_lPremiumFinanceVer:=r_lPremiumFinanceVer, v_iMTAType:=v_iMTAType, v_vOriginalPlanArray:=Nothing)
    End Function


    Public Function InsertOrUpdatePremiumFinance(ByVal v_vQuoteArray As Object, ByVal v_lSelectedQuoteIndex As Integer, ByVal v_vPFTransArray As Object, ByRef r_lPremiumFinanceCnt As Integer, ByRef r_lPremiumFinanceVer As Integer, ByVal v_iMTAType As Integer, ByVal v_vOriginalPlanArray As Object) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "InsertOrUpdatePremiumFinance"

        Dim vPFPlanArray(,) As Object = Nothing
        Dim vPfTransArray As Object = Nothing
        Dim bNewPlanHasSinglePolicy As Boolean
        Dim lSourceId, lSubBranchID As Integer
        Dim sOriginalAutoGeneratedPlanRef As String = ""
        Dim vOriginalPlanArray As Object = Nothing
        Dim vArrayOfInsuranceFile As Object = Nothing
        Dim lAgentPartyCnt As Integer
        Dim vResultArray(,) As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Make sure there is a valid array of transactions passed in. If not try and get one
            If Informations.IsArray(v_vPFTransArray) Then

                vPfTransArray = v_vPFTransArray
            Else
                m_lReturn = GetTransactions(v_lPfPremiumFinanceCnt:=r_lPremiumFinanceCnt, v_lPFPremiumFinanceVer:=r_lPremiumFinanceVer, r_vArrayOfTransactions:=vPfTransArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetTransactions", "Failed", gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            If Informations.IsArray(vPfTransArray) Then

                m_lReturn = GetNewPlanHasSinglePolicy(v_vPFTransArray:=vPfTransArray, r_bNewPlanHasSinglePolicy:=bNewPlanHasSinglePolicy)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetIsNewPlanMultiPolicy", "Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                If Not bNewPlanHasSinglePolicy And Not m_bIsSinglePlanParty Then
                    m_lInsuranceFileCnt = 0
                End If

                m_lReturn = GetSourceIDFromTransdetailID(v_lTransdetailID:=vPfTransArray(0, 0), r_lSourceID:=lSourceId, r_lSubBranchId:=lSubBranchID)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                    gPMFunctions.RaiseError("GetSourceIDFromTransdetailID", "v_lTransdetailID:=" & gPMFunctions.ToSafeString(vPfTransArray(0, 0)), gPMConstants.PMELogLevel.PMLogError)
                End If
            Else
                m_lReturn = GetSourceIDFromTransdetailID(v_lTransdetailID:=0, r_lSourceID:=lSourceId, r_lSubBranchId:=lSubBranchID)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                    gPMFunctions.RaiseError("GetSourceIDFromTransdetailID", "v_lTransdetailID:=" & gPMFunctions.ToSafeString(vPfTransArray(0, 0)), gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            If m_iTask = gPMConstants.PMEComponentAction.PMEdit And m_sProductCode.ToUpper() = "REN" And r_lPremiumFinanceCnt <> 0 Then
                'We are going to update already copied plan through manual ren amendment
                'fetch bank details, if missing, to copy over
                If Not Informations.IsArray(v_vOriginalPlanArray) Then

                    m_lReturn = GetSingleFinancePlan(v_lFinanceCount:=r_lPremiumFinanceCnt, v_lFinanceVersion:=r_lPremiumFinanceVer, r_vPFPremiumFinance:=vOriginalPlanArray)
                    If m_lReturn = gPMConstants.PMEReturnCode.PMTrue And Informations.IsArray(vOriginalPlanArray) Then
                        'Assign originally copied details

                        v_vOriginalPlanArray = vOriginalPlanArray
                    End If
                End If
            End If

            If m_sTransType = "G_NB" And gPMFunctions.ToSafeLong(m_vAgentCnt) = 0 Then
                ' check for missing data
                If m_lInsuranceFileCnt > 0 Then

                    m_lReturn = m_oInsuranceFile.GetDetails(vInsuranceFileCnt:=m_lInsuranceFileCnt)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("m_oInsuranceFile.GetDetails", "vInsuranceFileCnt:=" & m_lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                    End If

                    m_lReturn = m_oInsuranceFile.GetNext(vArrayOfInsuranceFile)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("m_oInsuranceFile.GetNext", "Failed", gPMConstants.PMELogLevel.PMLogError)
                    End If

                    m_dCurrencyXRate = gPMFunctions.ToSafeDouble(vArrayOfInsuranceFile(InsuranceFileConst.ACCurrencyToBaseXRate), 1)

                    If gPMFunctions.ToSafeLong(vArrayOfInsuranceFile(InsuranceFileConst.ACLeadAgentCnt)) > 0 Then
                        lAgentPartyCnt = gPMFunctions.ToSafeLong(vArrayOfInsuranceFile(InsuranceFileConst.ACLeadAgentCnt))
                        With m_oDatabase
                            .Parameters.Clear()
                            m_lReturn = .Parameters.Add(sName:="party_cnt", vValue:=gPMFunctions.ToSafeString(lAgentPartyCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                gPMFunctions.RaiseError("Add Parameter party_cnt", "Failed", gPMConstants.PMELogLevel.PMLogError)
                            End If

                            m_lReturn = .SQLSelect(sSQL:=kGetAgentPartyBrokerSQL, sSQLName:=kGetAgentPartyBrokerName, bStoredProcedure:=True, vResultArray:=vResultArray)

                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                gPMFunctions.RaiseError("InsertOrUpdatePremiumFinance Failed to process Stored Proc", "kGetAgentPartyBrokerName", gPMConstants.PMELogLevel.PMLogError)
                            End If
                        End With

                        If Informations.IsArray(vResultArray) And gPMFunctions.ToSafeLong(vArrayOfInsuranceFile(InsuranceFileConst.ACLeadAgentCnt)) > 0 Then
                            ' only when type is Broker Agent

                            m_vAgentCnt = gPMFunctions.NullToLong(vArrayOfInsuranceFile(InsuranceFileConst.ACLeadAgentCnt))
                        Else

                            m_vAgentCnt = DBNull.Value
                        End If
                    End If
                End If
            End If

            'First convert the QuoteArray into a PFPlanArray

            m_lReturn = ConvertQuoteToPlanArray(v_vQuoteArray:=v_vQuoteArray, v_lSelectedQuoteIndex:=v_lSelectedQuoteIndex, r_vPFPlanArray:=vPFPlanArray, v_vOriginalPlanArray:=v_vOriginalPlanArray, v_lSourceID:=lSourceId, v_lSubBranchId:=lSubBranchID)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("ConvertQuoteToPlanArray", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Insert New Premium Finance? or Update an existing one?
            If m_sProductCode.ToUpper() = "MTA" Then

                If v_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddToNewPlan Then

                    m_lReturn = InsertNewPremiumFinance(v_vPFPlanArray:=vPFPlanArray, v_vPFTransArray:=vPfTransArray, r_lPremiumFinanceCnt:=r_lPremiumFinanceCnt, r_lPremiumFinanceVer:=r_lPremiumFinanceVer)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("InsertNewPremiumFinance", "Failed", gPMConstants.PMELogLevel.PMLogError)
                    End If

                Else

                    vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0) = r_lPremiumFinanceCnt

                    vPFPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0) = r_lPremiumFinanceVer

                    vPFPlanArray(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndSaved

                    'Insert new version of existing PF

                    m_lReturn = InsertSupercedingPlan(r_vNewPFPlan:=vPFPlanArray, v_lPremiumFinanceCnt:=r_lPremiumFinanceCnt, r_lPremiumFinanceVersion:=r_lPremiumFinanceVer, v_vTransDetailArray:=vPfTransArray, nMTAType:=v_iMTAType)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("InsertSupercedingPlan", "v_lPremiumFinanceCnt:=" & r_lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                    End If
                End If

            ElseIf (m_sProductCode.ToUpper() = "REN" And r_lPremiumFinanceCnt <> 0) And Not (m_sPolicyTypeDesc.ToUpper() = "GENERAL") And m_sTransType <> "G_NB" Then

                'We amend the existing plan (since its ID was passed in)

                m_lReturn = UpdateExistingRecord(vExistingRecord:=vPFPlanArray, vPremiumFinanceCnt:=r_lPremiumFinanceCnt, vPremiumFinanceVersion:=r_lPremiumFinanceVer)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("UpdateExistingRecord", "vPremiumFinanceCnt:=" & r_lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                End If

            Else

                If m_sProductCode.ToUpper() = "REN" And m_sTransType <> "G_NB" And r_lPremiumFinanceCnt <> 0 Then
                    m_lReturn = DeletePlan(v_lPremiumFinanceCnt:=r_lPremiumFinanceCnt, v_lPremiumFinanceVersion:=r_lPremiumFinanceVer, v_sStatusInd:="")

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("DeletePlan", "v_lPremiumFinanceCnt:=" & r_lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                    End If
                End If

                ' if we have an original plan reference pass it through
                If Informations.IsArray(v_vOriginalPlanArray) Then
                    sOriginalAutoGeneratedPlanRef = gPMFunctions.ToSafeString(v_vOriginalPlanArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0), "")
                Else
                    sOriginalAutoGeneratedPlanRef = ""
                End If

                'If it's not an MTA then it MUST be a new PF

                m_lReturn = InsertNewPremiumFinance(v_vPFPlanArray:=vPFPlanArray, v_vPFTransArray:=vPfTransArray, r_lPremiumFinanceCnt:=r_lPremiumFinanceCnt, r_lPremiumFinanceVer:=r_lPremiumFinanceVer, v_sRenewalPreviousAutoGeneratedPlanRef:=sOriginalAutoGeneratedPlanRef)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("InsertNewPremiumFinance", "Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

            End If


        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here

        Finally

            ' Do any tidy up, e.g. Set x = Nothing here

            '        Return result

            ' This is for debugging only
            '        Resume

            '        Return result
        End Try
        Return result
    End Function

    '*************************************************************************
    'Name:          InsertNewPremiumFinance
    'Description:   Saves the new PFPlan
    'History:       25/11/2002 - TR - Created
    '*************************************************************************
    Public Function InsertNewPremiumFinance(ByVal v_vPFPlanArray(,) As Object, ByVal v_vPFTransArray(,) As Object, ByRef r_lPremiumFinanceCnt As Integer, ByRef r_lPremiumFinanceVer As Integer) As Integer
        Return InsertNewPremiumFinance(v_vPFPlanArray:=v_vPFPlanArray, v_vPFTransArray:=v_vPFTransArray, r_lPremiumFinanceCnt:=r_lPremiumFinanceCnt, r_lPremiumFinanceVer:=r_lPremiumFinanceVer, v_sRenewalPreviousAutoGeneratedPlanRef:="")
    End Function

    Public Function InsertNewPremiumFinance(ByVal v_vPFPlanArray(,) As Object, ByVal v_vPFTransArray(,) As Object, ByRef r_lPremiumFinanceCnt As Integer, ByRef r_lPremiumFinanceVer As Integer, ByVal v_sRenewalPreviousAutoGeneratedPlanRef As String) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "InsertNewPremiumFinance"

        Dim bRollback As Boolean
        Dim iBaseCurrencyID As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_lReturn = m_oDatabase.SQLBeginTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oDatabase.SQLBeginTrans", "Failed", gPMConstants.PMELogLevel.PMLogError)
            Else
                bRollback = True
            End If

            'First Insert the Quote as an Instalment Quotation
            m_lReturn = InsertNewPFPlan(v_vPFPlanArray, 0, v_sRenewalPreviousAutoGeneratedPlanRef)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("InsertNewPFPlan", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get the unique ID from this new Premium Finance

            r_lPremiumFinanceCnt = gPMFunctions.ToSafeInteger(v_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0))

            r_lPremiumFinanceVer = gPMFunctions.ToSafeInteger(v_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0))

            'Now save the Premium Finances transaction

            m_lReturn = InsertPFTransID(v_lPremFinanceCnt:=r_lPremiumFinanceCnt, v_lPremFinanceVersion:=r_lPremiumFinanceVer, v_vPFTransArray:=v_vPFTransArray)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("InsertPFTransID", "v_lPremFinanceCnt:=" & r_lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            m_lReturn = m_oCurrencyConvert.GetBaseCurrency(v_lCompanyId:=gPMFunctions.ToSafeLong(v_vPFPlanArray(bSIRPremFinConst.k_PFPlanSource_ID, 0)), r_iBaseCurrencyID:=iBaseCurrencyID)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oCurrencyConvert.GetBaseCurrency", "v_lCompanyID:=" & gPMFunctions.ToSafeLong(v_vPFPlanArray(bSIRPremFinConst.k_PFPlanSource_ID, 0)), gPMConstants.PMELogLevel.PMLogError)
            End If

            'Save the related Tax Informations

            m_lReturn = CalculateTax(lTaxGroupID:=gPMFunctions.ToSafeLong(v_vPFPlanArray(bSIRPremFinConst.k_PfPlanTaxGroupID, 0)), iCurrencyID:=iBaseCurrencyID, crTaxableAmount:=gPMFunctions.ToSafeCurrency(gPMFunctions.ToSafeInteger(gPMFunctions.ToSafeDouble(gPMFunctions.ToSafeDouble(v_vPFPlanArray(bSIRPremFinConst.k_PFPlanTotalCost, 0)) - gPMFunctions.ToSafeDouble(v_vPFPlanArray(bSIRPremFinConst.k_PFPlanNetAmount, 0))) - gPMFunctions.ToSafeDouble(v_vPFPlanArray(bSIRPremFinConst.k_PFPlanTaxCost, 0)))), r_crTaxAmount:=0, bCalculateOnly:=False, lInsuranceFileCnt:=gPMFunctions.ToSafeLong(v_vPFPlanArray(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0)), lPFPremFinanceCnt:=r_lPremiumFinanceCnt, lPFPremFinanceVersion:=r_lPremiumFinanceVer)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("CalculateTax", "lTaxGroupID:=" & gPMFunctions.ToSafeLong(v_vPFPlanArray(bSIRPremFinConst.k_PfPlanTaxGroupID, 0)), gPMConstants.PMELogLevel.PMLogError)
            End If

            m_lReturn = m_oDatabase.SQLCommitTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oDatabase.SQLCommitTrans", "Failed", gPMConstants.PMELogLevel.PMLogError)
            Else
                bRollback = False
            End If


        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here
            If bRollback Then
                m_oDatabase.SQLRollbackTrans()
            End If

        Finally

            ' Do any tidy up, e.g. Set x = Nothing here

            '		Return result

            ' This is for debugging only
            '		Resume 
            '		Return result
        End Try
        Return result
    End Function

