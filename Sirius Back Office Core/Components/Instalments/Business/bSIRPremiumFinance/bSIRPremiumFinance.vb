    End Function

    Public Function PopulateClientDetails(ByRef vReturnedClientDetails(,) As Object, ByRef v_vPartycnt As Object, ByRef v_vClientName As Object) As Integer
        Dim result As Integer = 0
        Dim oParty As bSIRParty.Services

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            oParty = New bSIRParty.Services
            m_lReturn = oParty.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMError

                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to Initialise bSIRParty.Services", vApp:=ACApp, vClass:=ACClass, vMethod:="PopulateClientDetails", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return result
            End If
            With oParty

                .PartyCnt = gPMFunctions.ToSafeInteger(v_vPartycnt)

                .GetDetails()
                ReDim vReturnedClientDetails(16, 0)

                vReturnedClientDetails(0, 0) = .SourceID

                vReturnedClientDetails(1, 0) = .Shortname

                vReturnedClientDetails(2, 0) = .PartyType

                vReturnedClientDetails(3, 0) = .PartyID

                vReturnedClientDetails(4, 0) = .Name

                vReturnedClientDetails(5, 0) = .CurrencyID

                vReturnedClientDetails(6, 0) = .ResolvedName

                If gPMFunctions.ToSafeString(vReturnedClientDetails(6, 0)) = "" Then

                    vReturnedClientDetails(6, 0) = (.Initials & " " & .Name).Trim()
                End If

                vReturnedClientDetails(7, 0) = .Address1

                vReturnedClientDetails(8, 0) = .Address2

                vReturnedClientDetails(9, 0) = .Address3

                vReturnedClientDetails(10, 0) = .Address4

                vReturnedClientDetails(11, 0) = .PostalCode

                vReturnedClientDetails(12, 0) = .AreaCode

                vReturnedClientDetails(13, 0) = .Number

                vReturnedClientDetails(14, 0) = .Extension

                vReturnedClientDetails(15, 0) = .CountryId  ' RAW 05/11/2003 : CQ2912, 2976 : added

                vReturnedClientDetails(16, 0) = .SolutionPartyType 'MKW 150604 PN12507
            End With

            ' Destroy Party object

            oParty.Dispose()
            oParty = Nothing

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="PopulateClientDetails Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="PopulateClientDetails", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ***************************************************************** '
    ' Name: RemoveArrayRow
    '
    ' Description: Removes a single row from a 2D array
    '
    ' History: 27/09/2001 DD - Created.
    ' ***************************************************************** '
    Private Function RemoveArrayRow(ByRef vArray(,) As Object, ByRef nRow As Integer) As Object
        Dim result As Object = Nothing
        Dim nNewRow As Integer

        Dim vResult As Object



        ReDim vResult(vArray.GetUpperBound(0), vArray.GetUpperBound(1) - 1)
        nNewRow = 0

        'Build the new array

        For nCurrentRow As Integer = vArray.GetLowerBound(1) To vArray.GetUpperBound(1)
            If nCurrentRow <> nRow Then

                For nCurrentCol As Integer = vArray.GetLowerBound(0) To vArray.GetUpperBound(0)

                    vResult(nCurrentCol, nNewRow) = vArray(nCurrentCol, nCurrentRow)
                Next nCurrentCol
                nNewRow += 1
            End If
        Next nCurrentRow

        'Return it

        Return vResult

    End Function

    ' ***************************************************************** '
    '
    ' Name: CancelPlanInHouse
    '
    ' Description:  Cancels and In-House plan and returns any overpayment
    '
    ' History: 28/09/2001 DD - Created.
    '
    ' ***************************************************************** '
    Public Function CancelPlanInHouse(ByVal vPremiumFinance(,) As Object, ByVal dRefund As Double) As Integer
        Return CancelPlanInHouse(vPremiumFinance:=vPremiumFinance, dRefund:=dRefund, r_vCreditTransDetail:=Nothing, r_vDebitTransDetail:=Nothing)
    End Function

    Public Function CancelPlanInHouse(ByVal vPremiumFinance(,) As Object, ByVal dRefund As Double, ByRef r_vDebitTransDetail As Object) As Integer
        Return CancelPlanInHouse(vPremiumFinance:=vPremiumFinance, dRefund:=dRefund, r_vCreditTransDetail:=Nothing, r_vDebitTransDetail:=r_vDebitTransDetail)
    End Function

    Public Function CancelPlanInHouse(ByVal vPremiumFinance(,) As Object, ByVal dRefund As Double, ByRef r_vCreditTransDetail As Object, ByRef r_vDebitTransDetail As Object) As Integer

        Dim result As Integer = 0
        Dim oACTInstalments As bACTInstalments.Business
        Dim lPFPaymentMethod_cnt, lInsuranceFileCnt, lReturn As Integer
        Dim sCreditControlEnabled As String = ""
        Dim bPlanHasSinglePolicy As Boolean
        Dim lOldMediatypeHistoryid, lCurrentMediatypeHistoryid As Integer
        Dim sSchemeType As String = String.Empty

        Try

            'Hook up to Orion
            'SD 31/07/2002 Scalability changes

            oACTInstalments = New bACTInstalments.Business
            m_lReturn = oACTInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            m_lReturn = GetMediaHistoryId(gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)), lOldMediatypeHistoryid, lCurrentMediatypeHistoryid)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            m_oDatabase.SQLBeginTrans()

            'Get the Payment Method for this Plan

            m_lReturn = CheckSchemeType(v_lFinancePlanCnt:=gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), v_lFinancePlanVersion:=gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)), r_sSchemeType:=sSchemeType, r_lPFPaymentMethod_cnt:=lPFPaymentMethod_cnt)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            bPlanHasSinglePolicy = gPMFunctions.ToSafeLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0), 0) <> 0

            'Cancel the plan in Orion

            If Val(gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0))) > 0 Then

                m_lReturn = oACTInstalments.CancelPlan(v_lPlanTransDetailID:=vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0), v_cAmount:=dRefund, v_lPremiumFinanceCnt:=vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0), v_lPremiumFinanceVersion:=vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0), v_cTax:=vPremiumFinance(bSIRPremFinConst.k_PFPlanTaxCost, 0), r_vCreditTransDetail:=r_vCreditTransDetail, r_vDebitTransDetail:=r_vDebitTransDetail, v_bPlanHasSinglePolicy:=bPlanHasSinglePolicy, v_iIsThirdPartyPlan:=If(sSchemeType = "TP", 1, 0))
            End If

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            If gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanMediaTypeValidation, 0)).Trim() = "BANK" Then

                CreateInstalmentNotification(gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)), "0C", lCurrentMediatypeHistoryid)
            End If

            If gPMFunctions.ToSafeLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0), 0) <> 0 Then
                ' get the InsuranceFileCnt needed for the new calls below

                lInsuranceFileCnt = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0))

                ' get the sytem option value for option "credit control enabled"
                lReturn = GetSystemOptionLite(v_iOptionNumber:=kSystemOptionCreditControlEnabled, r_sOptionValue:=sCreditControlEnabled, v_iSourceID:=1)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetSystemOptionLite Failed to get value for system option " & kSystemOptionCreditControlEnabled, vApp:=ACApp, vClass:=ACClass, vMethod:="TransactPlanInHouse")

                    m_oDatabase.SQLRollbackTrans()
                    Return lReturn
                Else
                    ' if credit control enabled
                    If sCreditControlEnabled = "1" Then

                        ' delete any credit control items associated
                        ' with the policy version (insurance file cnt)

                        lReturn = AddCreditControlItemForCancelledPlan(v_lInsuranceFileCnt:=lInsuranceFileCnt, v_sBusinessType:="NB", v_lTransdetailID:=gPMFunctions.ToSafeInteger(r_vDebitTransDetail))

                        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="DeleteCreditControlItem Failed for Insurance File Cnt " & lInsuranceFileCnt, vApp:=ACApp, vClass:=ACClass, vMethod:="TransactPlanInHouse")

                            m_oDatabase.SQLRollbackTrans()
                            Return lReturn
                        End If

                    End If

                End If
            End If

            'Change the plan status
            m_lReturn = StatusUpdate(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0), vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0), bSIRPremFinConst.PFStatusIndCancelled)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            m_oDatabase.SQLCommitTrans()

            'Clean up

            oACTInstalments.Dispose()
            oACTInstalments = Nothing

            Return gPMConstants.PMEReturnCode.PMTrue

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CancelPlanInHouse Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="CancelPlanInHouse", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            m_oDatabase.SQLRollbackTrans()

            Return result

            Return result
        End Try
    End Function

