    '*************************************************************************
    Public Function GetPartyTypeCode(ByVal v_lParty_Type_ID As Integer, ByRef r_sParty_Type_Code As String) As Integer

        Dim result As Integer = 0
        Dim vResultArray(,) As Object = Nothing

        Try

            'TR - Assume success
            result = gPMConstants.PMEReturnCode.PMTrue

            ' MEvans : 11-07-2003 : SR31 bug
            ' parameters not being cleared down
            m_oDatabase.Parameters.Clear()

            'TR - Set the input parameters
            m_lReturn = m_oDatabase.Parameters.Add("party_type_id", gPMFunctions.ToSafeString(v_lParty_Type_ID), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogError, "Could not set Parameter in " & "GetPartyTypeCode", ACApp, ACClass, "GetPartyTypeCode")
                Return result
            End If

            'TR - Run the script
            m_lReturn = m_oDatabase.SQLSelect(ACGetPartyTypeCodeSQL, ACGetPartyTypeCodeName, ACGetPartyTypeCodeStored, 0, vResultArray:=vResultArray)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogError, "Could not run script in " & "GetPartyTypeCode", ACApp, ACClass, "GetPartyTypeCode")
                Return result
            End If

            'TR - Make sure a record was returned
            If Informations.IsArray(vResultArray) Then
                r_sParty_Type_Code = gPMFunctions.NullToString(vResultArray(0, 0)).Trim()
            Else
                result = gPMConstants.PMEReturnCode.PMNotFound
            End If

            Return result

        Catch excep As System.Exception

            bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "GetPartyTypeCode Failed", ACApp, ACClass, "GetPartyTypeCode", Informations.Err().Number, excep.Message, excep:=excep)
