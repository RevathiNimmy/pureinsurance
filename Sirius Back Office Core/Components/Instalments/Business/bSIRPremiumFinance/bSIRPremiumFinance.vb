    ' Name: ProcessPF
    '
    ' Description: Process Premium Finance Plan.
    '
    ' History:
    '
    ' ***************************************************************** '
    Public Function ProcessPF(ByVal v_lInsuranceFileCnt As Integer, ByVal v_lFinancePlanSchemeNo As Integer) As Integer

        Dim result As Integer = 0
        Dim vArrayOfScheme As Object = Nothing
        Dim lCompanyNo, lSchemeVersion, lSubBranchID, lMode As Integer

        Dim vPremiumFinanceArray(,) As Object = Nothing
        Dim vTransArray(,) As Object = Nothing
        Dim vArrayOfInsuranceFile As Object = Nothing
        Dim crAmountToFinance As Decimal
        Dim vPfTransArray(,) As Object

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Get InsuranceFile Details
            m_lInsuranceFileCnt = v_lInsuranceFileCnt

            m_lReturn = m_oInsuranceFile.GetDetails(vInsuranceFileCnt:=m_lInsuranceFileCnt)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oInsuranceFile.GetDetails", "vInsuranceFileCnt:=" & m_lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            m_lReturn = m_oInsuranceFile.GetNext(vArrayOfInsuranceFile)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oInsuranceFile.GetNext", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            m_dCurrencyXRate = gPMFunctions.ToSafeDouble(vArrayOfInsuranceFile(InsuranceFileConst.ACCurrencyToBaseXRate), 1)

            'm_lReturn = m_oInsuranceFile.GetOtherDetails( _
            ''    Null, vInsurerName, _
            ''    Null, vBrokerName, Null, vRiskDesc, _
            ''    vRiskGroupId, Null, vAnalysisDesc, _
            ''    Null, vHandlerName, Null, vAgentName, _
            ''    vArrayOfInsuranceFile(1), vRelatedPolicyCnt, vRelatedPolicyCode, _
            ''    vRelationshipType, vArrayOfInsuranceFile(ACPolicyTypeId), vPolicyTypeDesc, _
            ''    vSchemeId, vSchemeDesc)
            'If m_lReturn <> PMTrue Then
            '    RaiseError "m_oInsuranceFile.GetOtherDetails", "Failed", PMLogError
            'End If

            m_sPolicyTypeDesc = ""

            'Now store these details locally, but do not overwrite ones that have been passed in populated
            If m_dtStartDate = CDate("00:00:00") Then
                m_dtStartDate = gPMFunctions.NullToDate(vArrayOfInsuranceFile(InsuranceFileConst.ACCoverStartDate))
            End If
            If m_dtEndDate = CDate("00:00:00") Then
                m_dtEndDate = gPMFunctions.NullToDate(vArrayOfInsuranceFile(InsuranceFileConst.ACExpiryDate))
            End If
            If m_dtQuoteDate = CDate("00:00:00") Then
                m_dtQuoteDate = CDate(DateTime.Now.ToString("yyyy/MM/dd"))
            End If
            If m_sProductCode = "" Then
                m_sProductCode = "NB"
            End If
            If m_lProductID = 0 Then
                m_lProductID = gPMFunctions.NullToLong(vArrayOfInsuranceFile(InsuranceFileConst.ACProductID))
            End If
            If m_lSourceID = 0 Then
                m_lSourceID = gPMFunctions.NullToLong(vArrayOfInsuranceFile(InsuranceFileConst.ACSourceID))
            End If
            If m_lPartyCnt = 0 Then
                m_lPartyCnt = gPMFunctions.NullToLong(vArrayOfInsuranceFile(InsuranceFileConst.ACInsuredCnt))
            End If

            'Get Transaction Details
            m_oDatabase.Parameters.Clear()
            m_lReturn = m_oDatabase.Parameters.Add(sName:="InsuranceFileCnt", vValue:=gPMFunctions.ToSafeString(v_lInsuranceFileCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
