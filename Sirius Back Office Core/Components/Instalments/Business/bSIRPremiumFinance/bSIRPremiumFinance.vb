    Public Function TransactPlanInHouse(ByVal vPremiumFinance(,) As Object,
                                        ByVal vPremiumFinanceTransactions(,) As Object,
                                        ByRef lPlanTransDetailID As Integer,
                                        ByRef vDepositTransID As Object,
                                        ByRef vDepositJournal As Object,
                                        ByVal v_lAccountId As Integer) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "TransactPlanInHouse"

        Dim oACTAutoNumber As Object = Nothing
        Dim oACTInstalments As New bACTInstalments.Business
        Dim vPFTransArrayForPosting() As Object = Nothing
        Dim vPfTransArray(,) As Object = Nothing
        Dim lLeadAgentCnt, lAgentType, lPremiumFinanceCnt, lPRemiumFinanceVer, lInsuranceFileCnt As Integer

        Dim vValue As Object = Nothing
        Dim oControlTrans As Object = Nothing
        Dim vResults As Object = Nothing

        Dim bCommissionSpread As Boolean
        Dim vStatsFolderCheck As Object = Nothing
        Dim lReturn As gPMConstants.PMEReturnCode
        Dim sCreditControlEnabled As String = ""
        Dim bRollback As Boolean
        Dim cCommissionAmt As Decimal
        'Dim bLeadAgentCommissionSpread As Boolean
        Dim bSubAgentCommissionSpread As Boolean
        Dim oSubAgents As Object = Nothing
        Dim oSinglePlanParty As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_lReturn = m_oDatabase.SQLBeginTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oDatabase.SQLBeginTrans", "Failed", gPMConstants.PMELogLevel.PMLogError)
            Else
                bRollback = True
            End If

            'Using the module level InsuranceFileCnt needed for the new calls below
            m_lInsuranceFileCnt = gPMFunctions.ToSafeLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0), 0)

            ' Save Instalments
            m_lReturn = SaveInstalments(vPremiumFinance:=vPremiumFinance)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("SaveInstalments", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get the Premium Finance Count & Version

            lPremiumFinanceCnt = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0))

            lPRemiumFinanceVer = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            lInsuranceFileCnt = gPMFunctions.ToSafeLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0), 0)

            'Make sure there is a valid array of transactions passed in. If not try and get one
            If Informations.IsArray(vPremiumFinanceTransactions) Then

                vPfTransArray = vPremiumFinanceTransactions
            Else
                m_lReturn = GetTransactions(v_lPfPremiumFinanceCnt:=lPremiumFinanceCnt, v_lPFPremiumFinanceVer:=lPRemiumFinanceVer, r_vArrayOfTransactions:=vPfTransArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetTransactions", "v_lPFPremiumFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            m_lReturn = gPMComponentServices.CreateBusinessObject(r_oObject:=oACTInstalments,
                                                                  v_sClassName:="bACTInstalments.Business",
                                                                  v_sCallingAppName:=ACApp, v_sUsername:=m_sUsername,
                                                                  v_sPassword:=m_sPassword, v_iUserID:=m_iUserID,
                                                                  v_iSourceID:=m_iSourceID,
                                                                  v_iLanguageID:=m_iLanguageID,
                                                                  v_iCurrencyID:=m_iCurrencyID,
                                                                  v_iLogLevel:=m_iLogLevel, v_oDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bACTInstalments.Business", gPMConstants.PMELogLevel.PMLogError)
            End If

            'If Informations.IsArray(vPfTransArray) Then
            '    ReDim vPFTransArrayForPosting(vPfTransArray.GetUpperBound(1))
            '    For lCount As Integer = vPFTransArrayForPosting.GetLowerBound(0) To vPFTransArrayForPosting.GetUpperBound(0)
            '        vPFTransArrayForPosting(lCount) = vPfTransArray(0, lCount)
            '    Next
            'End If
            If Informations.IsArray(oSinglePlanParty) Then
                If ToSafeBoolean(oSinglePlanParty(0, 0)) Then
                    m_bIsSinglePlanParty = True
                End If
            End If
            oACTInstalments.IsSinglePlanParty = m_bIsSinglePlanParty
            If Informations.IsArray(vPfTransArray) Then

                ReDim vPFTransArrayForPosting(vPfTransArray.GetUpperBound(1))

                For lCount As Integer = vPFTransArrayForPosting.GetLowerBound(0) To _
                    vPFTransArrayForPosting.GetUpperBound(0)

                    vPFTransArrayForPosting.SetValue(vPfTransArray.GetValue(0, lCount), lCount)
                Next
            End If

            'DD 04/06/2003: Simplified. If we have not transacted yet then
            'only do the transactions if they have not already been done
            'during the stats process. This caters for Broking solutions

            Dim dbNumericTemp As Double

            If Not Double.TryParse(gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)), NumberStyles.Number, CultureInfo.CurrentCulture.NumberFormat, dbNumericTemp) OrElse Val(vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)) <= 0 Then

                'Tracy Richards 15/07/03 - Adding Support for Broker Agents
                'Does this Plan have it's Commission spread or not?
                bCommissionSpread = gPMFunctions.NullToLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanCommissionSpread, 0)) = 1

                'Need Agent type to support Instalments for Broker Agents
                m_lReturn = GetAgentAndType(v_lPremFinanceCnt:=lPremiumFinanceCnt, v_lPremFinanceVersion:=lPRemiumFinanceVer, r_lLeadAgentCnt:=lLeadAgentCnt, r_lAgentType:=lAgentType)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetAgentAndType", "v_lPremFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                End If


                If NullToLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanSubAgentCommissionSpread, 0)) = 1 Then
                    bSubAgentCommissionSpread = True
                Else
                    bSubAgentCommissionSpread = False
                End If

                m_lReturn = GetSubAgents(lPremiumFinanceCnt, lPRemiumFinanceVer, oSubAgents)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetSubAgents", "v_lPremFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                End If

                If CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanTotalCost, 0)) + CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0)) <> 0 Then

                    ' Start - Sankar - PN 54265
                    m_lReturn = GetCommissionAmount(cCommissionAmt)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("GetCommissionAmount", "bSIRPremiumFinance.Business", gPMConstants.PMELogLevel.PMLogError)
                    End If
                    ' End - Sankar - PN 54265
                    ' Added an optional parameter cCommissionAmt - PN 54265

                    m_lReturn = oACTInstalments.PostPlan(v_lPartyCnt:=vPremiumFinance(bSIRPremFinConst.k_PFPlanClientId, 0), v_sInstalmentRef:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0)).Trim(), v_cAmount:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanTotalCost, 0)) + CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0)), v_cDeposit:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0)), v_vFinanceTransIds:=vPFTransArrayForPosting, v_lPlanTransDetailID:=lPlanTransDetailID, vDepositTransID:=vDepositTransID, v_lPremiumFinanceCnt:=lPremiumFinanceCnt, v_lPremiumFinanceVersion:=lPRemiumFinanceVer, v_lInsuranceFileCnt:=lInsuranceFileCnt, v_lAgentCnt:=lLeadAgentCnt, v_lAgentType:=lAgentType, v_bCommissionSpread:=bCommissionSpread, v_bProcessDeposit:=Not CBool(vPremiumFinance(bSIRPremFinConst.k_PFPlanDepositAsInstalment, 0)), v_vDepositJournal:=m_vDepositJournal, v_cTax:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanTaxCost, 0)), v_cCommissionAmount:=cCommissionAmt, bSubAgentCommissionSpread:=bSubAgentCommissionSpread, oSubAgent:=oSubAgents)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                        gPMFunctions.RaiseError("oACTInstalments.PostPlan", "v_sInstalmentRef:=" & gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0)).Trim(), gPMConstants.PMELogLevel.PMLogError)
                    End If

                    vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0) = lPlanTransDetailID
                End If

            End If

            ' if the plan is not on hold

            If gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0)) <> bSIRPremFinConst.PFStatusIndOnHold Then
                ' make it live

                vPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndLive
            End If

            m_lReturn = UpdateExistingRecord(vExistingRecord:=vPremiumFinance, vPremiumFinanceCnt:=lPremiumFinanceCnt, vPremiumFinanceVersion:=lPRemiumFinanceVer)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("UpdateExistingRecord", "vPremiumFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            ' get the sytem option value for option "credit control enabled"
            lReturn = CType(GetSystemOptionLite(v_iOptionNumber:=kSystemOptionCreditControlEnabled, r_sOptionValue:=sCreditControlEnabled, v_iSourceID:=1), gPMConstants.PMEReturnCode)
            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetSystemOptionLite", "v_iOptionNumber:=kSystemOptionCreditControlEnabled", gPMConstants.PMELogLevel.PMLogError)
            End If

            'If credit control enabled
            If sCreditControlEnabled = "1" Then

                ' delete any credit control items associated
                ' with the policy version (insurance file cnt)
                lReturn = CType(DeleteCreditControlItem(v_lInsuranceFileCnt:=lInsuranceFileCnt), gPMConstants.PMEReturnCode)
                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("DeleteCreditControlItem", "v_lInsuranceFileCnt:=" & lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                End If

                'Get the product option

                bPMFunc.getProductOptionValue(v_sUsername:=m_sUsername, v_sPassword:=m_sPassword, v_iUserID:=m_iUserID, v_iMainSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_iCurrencyID:=m_iCurrencyID, v_iLogLevel:=m_iLogLevel, v_sCallingAppName:=m_sCallingAppName, v_vOptionNumber:=gPMConstants.SIRHiddenOptions.SIROPTGenerateAdvanceCreditControlForInstalments, v_vBranch:=m_iSourceID, r_vUnderwriting:=vValue)

                If gPMFunctions.NullToString(vValue) = "1" Then
                    ' Last Step create CreditControlItem records...

                    m_lReturn = ProcessCreditControl(sTransactionType:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)).Trim(), lPremiumFinanceCnt:=lPremiumFinanceCnt, lPRemiumFinanceVer:=lPRemiumFinanceVer)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("ProcessCreditControl", "lPremiumFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                    End If
                End If

            End If

            m_lReturn = m_oDatabase.SQLCommitTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oDatabase.SQLCommitTrans", "Failed", gPMConstants.PMELogLevel.PMLogError)
            Else
                bRollback = False
            End If

            Return result
        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here
            If bRollback Then
                m_oDatabase.SQLRollbackTrans()
            End If

        Finally

            ' Do any tidy up, e.g. Set x = Nothing here
            If Not (oACTInstalments Is Nothing) Then

                oACTInstalments.Dispose()
                oACTInstalments = Nothing
            End If

            '        Return result

            ' This is for debugging only
            '        Resume

            '        Return result
        End Try
        Return result
    End Function

    ' Start - Sankar - PN 54265
    Public Function GetCommissionAmount(ByRef cCommissionAmt As Decimal) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "GetCommissionAmount"

        'refer Developer Guide No. 101 (guide)
        Dim r_vPFPremiumScheme(,) As Object = Nothing

        result = gPMConstants.PMEReturnCode.PMTrue

        m_lReturn = GetSingleFinancePlanFromInsFileCnt(v_lInsuranceFileCnt:=m_lInsuranceFileCnt, r_vPFPremiumFinance:=r_vPFPremiumScheme)
        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            gPMFunctions.RaiseError("GetSingleFinancePlanFromInsFileCnt", "v_sClassName:=bSIRPremiumFinance.Business", gPMConstants.PMELogLevel.PMLogError)
        End If

        If Informations.IsArray(r_vPFPremiumScheme) Then

            If gPMFunctions.ToSafeDouble(r_vPFPremiumScheme(bSIRPremFinConst.kFinanceNetCommission, 0)) = 1 Then
                m_lReturn = GetAgentCommission(v_lInsuranceFileCnt:=m_lInsuranceFileCnt, r_crCommissionAmount:=cCommissionAmt)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetAgentCommission", "v_sClassName:=bSIRPremiumFinance.Business", gPMConstants.PMELogLevel.PMLogError)
                End If
            End If
        End If

        Return result

        ' DO Not Call any functions before here or the error will be lost
        bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result)

        Return result
    End Function
    ' End - Sankar - PN 54265
    Public Function TransactPlanInHouseForMTA(ByRef r_vPremiumFinance(,) As Object, ByVal vPremiumFinanceTransactions(,) As Object, ByRef lPlanTransDetailID As Integer) As Integer
        Return TransactPlanInHouseForMTA(r_vPremiumFinance:=r_vPremiumFinance, vPremiumFinanceTransactions:=vPremiumFinanceTransactions, lPlanTransDetailID:=lPlanTransDetailID, vDepositTransID:=Nothing, v_lAccountId:=0)
    End Function

    Public Function TransactPlanInHouseForMTA(ByRef r_vPremiumFinance(,) As Object, ByVal vPremiumFinanceTransactions(,) As Object, ByRef lPlanTransDetailID As Integer, ByRef vDepositTransID As Object, ByVal v_lAccountId As Integer) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "TransactPlanInHouseForMTA"
        'const kFinanceNetCommission As Integer = 179

        Dim oACTInstalments As New bACTInstalments.Business
        Dim vOriginalPlan As Object = Nothing
        Dim oPFExport As Object = Nothing
        Dim vTransArray(,) As Object = Nothing
        Dim cTransAmount As Decimal
        Dim vOrionTransactions As Object = Nothing
        Dim vInstalmentsArray(,) As Object = Nothing
        Dim vSchemeArray(,) As Object = Nothing
        Dim lNewVersion As Object = Nothing
        Dim lLeadAgentCnt, lClientCnt, lNewPlanTransID, lInstalmentsToGo, lInstalmentsprocessed, lPremiumFinanceCnt, lPremiumFinanceVersion, lSchemeNo, lSchemeVer, lCompanyNo, lRemainingInstalments As Integer
        Dim cPlanOs As Decimal
        Dim vValue As Object = Nothing
        Dim lDepositExportFolderCnt As Integer

        Dim lPlanTransDetailID_FromDeposit As Integer
        Dim sCreditControlEnabled As String = ""
        Dim bRollback, bCommissionSpread As Boolean
        Dim vSinglePlanParty As Object = Nothing
        Dim cCommissionAmt As Decimal
        Dim cDepositAmount As Decimal
        Dim cOldFee As Decimal
        Dim dAdjustment As Decimal = 0
        Dim bSubAgentCommissionSpread As Boolean
        Dim vSubAgents As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_lReturn = m_oDatabase.SQLBeginTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oDatabase.SQLBeginTrans", "Failed", gPMConstants.PMELogLevel.PMLogError)
            Else
                bRollback = True
            End If

            'Using the module level InsuranceFileCnt needed for the new calls below

            m_lInsuranceFileCnt = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0))

            'DD 04/06/2003: This section is only done for Underwriting.
            'Underwriting will require the transactions pushed through via
            'Stats so that they are in sync with Accounts

            'DD 10/03/2003: Added this to make the Instalment Plan Live
            'this SP will locate the debt on the client, the suspended commission
            'and mark the plan as live
            m_lReturn = MakeInstalmentPlanLive(v_lInsuranceFileCnt:=m_lInsuranceFileCnt, lDepositExportFolderCnt:=lDepositExportFolderCnt, r_lPlanTransDetailID:=lPlanTransDetailID_FromDeposit)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("MakeInstalmentPlanLive", "v_lInsuranceFileCnt:=" & m_lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0) = lPlanTransDetailID_FromDeposit

            'TR - Initalise important variables

            lPremiumFinanceCnt = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0))

            lPremiumFinanceVersion = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))

            lSchemeNo = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeNo, 0))

            lSchemeVer = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeVersion, 0))

            lCompanyNo = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanCompanyNo, 0))

            m_lReturn = GetMTAAdjustmentAmount(v_lPremFinanceCnt:=lPremiumFinanceCnt, v_lPremFinanceVersion:=lPremiumFinanceVersion, r_crAdjustmentAmount:=dAdjustment)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetMTAAdjustmentAmount", "v_lPremFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            If Informations.IsArray(vPremiumFinanceTransactions) Then

                vTransArray = vPremiumFinanceTransactions
            Else
                m_lReturn = GetTransactions(v_lPfPremiumFinanceCnt:=lPremiumFinanceCnt, v_lPFPremiumFinanceVer:=lPremiumFinanceVersion, r_vArrayOfTransactions:=vTransArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("MakeInstalmentPlanLive", "v_lInsuranceFileCnt:=" & m_lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            Dim iCurrencyID As Integer
            Dim dXRate As Double = 0

            m_lReturn = GetSchemeCurrency(lPremiumFinanceCnt:=lPremiumFinanceCnt, lPremiumFinanceVersion:=lPremiumFinanceVersion, r_iCurrencyID:=iCurrencyID, r_XRate:=dXRate)

            If dXRate = 0 Then
                dXRate = 1
            End If

            For lCount As Integer = vTransArray.GetLowerBound(1) To vTransArray.GetUpperBound(1)
                cTransAmount += CDec(vTransArray(2, lCount))
            Next lCount

            'Start - Sankar - PN 54265
            m_lReturn = GetCommissionAmount(cCommissionAmt)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetCommissionAmount", "bSIRPremiumFinance.Business", gPMConstants.PMELogLevel.PMLogError)
            End If
            cTransAmount -= cCommissionAmt ' - Commission Amount
            'End - Sankar - PN 54265

            If m_oPFInstalments Is Nothing Then

                m_oPFInstalments = New bSIRPFInstalments.Business
                m_lReturn = m_oPFInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bSIRPFInstalments.Business", gPMConstants.PMELogLevel.PMLogError)
                End If
            End If


            oACTInstalments = New bACTInstalments.Business
            m_lReturn = oACTInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bACTInstalments.Business", gPMConstants.PMELogLevel.PMLogError)
            End If

            m_lReturn = gPMComponentServices.CreateBusinessObject(r_oObject:=oPFExport, v_sClassName:="bSIRPFExport.Business", v_sCallingAppName:=ACApp, v_sUsername:=m_sUsername, v_sPassword:=m_sPassword, v_iUserID:=m_iUserID, v_iSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_iCurrencyID:=m_iCurrencyID, v_iLogLevel:=m_iLogLevel, v_oDatabase:=m_oDatabase)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bSIRPFExport.Business", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get the previous version
            m_lReturn = GetSingleFinancePlan(v_lFinanceCount:=lPremiumFinanceCnt, v_lFinanceVersion:=lPremiumFinanceVersion - 1, r_vPFPremiumFinance:=vOriginalPlan)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetSingleFinancePlan", "v_lFinanceCount:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If
            'Get the Details of the existing instalments. Only intersted
            'in No. of outstanding and paid, not in Instalments Array

            m_lReturn = m_oPFInstalments.GetDetails(v_vpfprem_finance_cnt:=vOriginalPlan(bSIRPremFinConst.k_PFPlanPFCnt, 0), v_vpfprem_finance_version:=vOriginalPlan(bSIRPremFinConst.k_PFPlanPFVersion, 0), r_vDetailsArray:=vInstalmentsArray, r_lInstalmentsToGo:=lInstalmentsToGo, r_lInstalmentsProcessed:=lInstalmentsprocessed, r_vFilter:=0, r_lRemainingInstalments:=lRemainingInstalments)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                gPMFunctions.RaiseError("m_oPFInstalments.GetDetails", "v_vpfprem_finance_cnt:=" & gPMFunctions.ToSafeString(vOriginalPlan(bSIRPremFinConst.k_PFPlanPFCnt, 0)), gPMConstants.PMELogLevel.PMLogError)
            End If

            'TR - Get the outstanding amount due

            m_lReturn = oACTInstalments.GetPlanOS(v_lPlanTransDetailID:=vOriginalPlan(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0), r_cOS:=cPlanOs)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                gPMFunctions.RaiseError("oACTInstalments.GetPlanOS", "v_lPlanTransDetailID:=" & gPMFunctions.ToSafeInteger(vOriginalPlan(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)), gPMConstants.PMELogLevel.PMLogError)
            End If

            'convert the trans amount
            If dXRate <> 1 Then
                m_lReturn = m_oCurrencyConvert.ConvertBaseToCurrency(lCurrencyID:=iCurrencyID, lCompanyID:=lCompanyNo,
                                                                     cBaseAmount:=cTransAmount, cCurrencyAmount:=cTransAmount, vConversionDate:=Nothing, vConversionRate:=dXRate)
            End If

            If (cTransAmount + cPlanOs) < 0 Then
                m_oDatabase.SQLRollbackTrans()
                result = 998
                Return result
            End If

            'Recalculate for the MTA amount

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0) = "MTA"

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0) = cTransAmount

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanNoOfInstalments, 0) = lRemainingInstalments

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0) = vTransArray(0, 0)

            If lInstalmentsToGo < MinMTAInstalments Then
                'too few instalments left
                m_oDatabase.SQLRollbackTrans()
                result = 99
                Return result
            End If

            'Update the new version with the new figures

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanAmountToFinance, 0))

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanCostOfProtection, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanCostOfProtection, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanCostOfProtection, 0))
            cDepositAmount = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0))
            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanDeposit, 0))

            ' START CHANGES - Changed By: AAB  - Changed On: 17-Oct-2003 10:39
            ' Based on conversation with Danny Davis we need to update
            ' k_PFPlanNetAmount & k_PFPlanTaxCost &

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanNetAmount, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanNetAmount, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanNetAmount, 0))

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTaxCost, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTaxCost, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanTaxCost, 0))

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanFinanceCharge, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanFinanceCharge, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanFinanceCharge, 0))
            ' END CHANGES - Changed By: AAB  - Changed On: 17-Oct-2003 10:39

            'Get the PFScheme for this PremiumFinance
            m_lReturn = GetSingleScheme(v_lCompanyNo:=lCompanyNo, v_lSchemeNo:=lSchemeNo, v_lSchemeVersion:=lSchemeVer, r_vArrayOfScheme:=vSchemeArray)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetSingleScheme", "v_lSchemeNo:=" & lSchemeNo, gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get the Bank Code for this PFScheme

            oACTInstalments.BankCode = vSchemeArray(36, 0)

            'Reverse what is left on instalments and repost with new amount

            ReDim vOrionTransactions(vTransArray.GetUpperBound(1))

            For lCount As Integer = vTransArray.GetLowerBound(1) To vTransArray.GetUpperBound(1)

                vOrionTransactions(lCount) = gPMFunctions.ToSafeString(vTransArray(0, lCount)) & "|" & gPMFunctions.ToSafeString(vTransArray(2, lCount))
            Next

            m_lReturn = GetAgentAndClient(v_lPremFinanceCnt:=lPremiumFinanceCnt, v_lPremFinanceVersion:=lPremiumFinanceVersion, r_lLeadAgentCnt:=lLeadAgentCnt, r_lClientCnt:=lClientCnt)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetAgentAndClient", "v_lPremFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            bCommissionSpread = gPMFunctions.NullToLong(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanCommissionSpread, 0)) = 1


            If NullToLong(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanSubAgentCommissionSpread, 0)) = 1 Then
                bSubAgentCommissionSpread = True
            Else
                bSubAgentCommissionSpread = False
            End If


            m_lReturn = GetSubAgents(lPremiumFinanceCnt, lPremiumFinanceVersion, vSubAgents)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetAgentAndClient", "v_lPremFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            bCommissionSpread = gPMFunctions.NullToLong(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanCommissionSpread, 0)) = 1
            cOldFee = ToSafeDouble(vOriginalPlan(k_PFPlanFinanceCharge, 0)) + ToSafeDouble(vOriginalPlan(bSIRPremFinConst.k_PFPlanCostOfProtection, 0))
            m_lReturn = oACTInstalments.PostMTAAdjustment(r_lNewPlanTransID:=lNewPlanTransID,
                                                          v_lPlanTransDetailID:=gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)),
                                                          v_vFinanceTrans:=vOrionTransactions,
                                                          v_cAdjustment:=dAdjustment,
                                                          v_cFee:=CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTotalCost, 0)) - cPlanOs - cTransAmount + (CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0)) - CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanDeposit, 0))),
                                                          v_cTax:=CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTaxCost, 0)) - CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanTaxCost, 0)), v_cOSAmount:=cPlanOs, v_lPremiumFinanceCnt:=lPremiumFinanceCnt,
                                                          v_lPremiumFinanceVersion:=lPremiumFinanceVersion, v_lLeadAgentCnt:=lLeadAgentCnt, v_lOrigianlPlanTransDetailID:=gPMFunctions.ToSafeInteger(vOriginalPlan(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)),
                                                          v_bCommissionSpread:=bCommissionSpread,
                                                          v_cNewPlanAmount:=CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTotalCost, 0)),
                                                          v_cDeposit:=cDepositAmount,
                                                          v_bProcessDeposit:=Not CBool(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanDepositAsInstalment, 0)),
                                                          v_vDepositJournal:=m_vDepositJournal,
                                                          v_lPartyCnt:=r_vPremiumFinance(bSIRPremFinConst.k_PFPlanClientId, 0), v_cOldFee:=cOldFee, v_bSubAgentCommissionSpread:=bSubAgentCommissionSpread, v_vSubAgent:=vSubAgents)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("oACTInstalments.PostMTAAdjustment", "v_lPremiumFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            'DC180106 PN26848 do not set to live if on hold
            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0) = lNewPlanTransID

            If gPMFunctions.ToSafeString(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0)) <> bSIRPremFinConst.PFStatusIndOnHold Then

                r_vPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndLive
            End If

            'r_vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0) = cDepositAmount
            m_lReturn = UpdateExistingRecord(vExistingRecord:=r_vPremiumFinance, vPremiumFinanceCnt:=lPremiumFinanceCnt, vPremiumFinanceVersion:=lPremiumFinanceVersion)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("UpdateExistingRecord", "vPremiumFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get the system option value for option "credit control enabled"
            m_lReturn = GetSystemOptionLite(v_iOptionNumber:=kSystemOptionCreditControlEnabled, r_sOptionValue:=sCreditControlEnabled, v_iSourceID:=1)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetSystemOptionLite", "v_iOptionNumber:=kSystemOptionCreditControlEnabled", gPMConstants.PMELogLevel.PMLogError)
            End If

            If sCreditControlEnabled = "1" Then

                ' delete any credit control items associated
                ' with the policy version (insurance file cnt)
                m_lReturn = DeleteCreditControlItem(v_lInsuranceFileCnt:=m_lInsuranceFileCnt)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("DeleteCreditControlItem", "v_lInsuranceFileCnt:=" & m_lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                End If

                'Get the product option

                'Developer Guide No. 98
                bPMFunc.getProductOptionValue(v_sUsername:=m_sUsername, v_sPassword:=m_sPassword, v_iUserID:=m_iUserID, v_iMainSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_iCurrencyID:=m_iCurrencyID, v_iLogLevel:=m_iLogLevel, v_sCallingAppName:=m_sCallingAppName, v_vOptionNumber:=gPMConstants.SIRHiddenOptions.SIROPTGenerateAdvanceCreditControlForInstalments, v_vBranch:=m_iSourceID, r_vUnderwriting:=vValue)

                If gPMFunctions.NullToString(vValue) = "1" Then
                    ' Last Step create CreditControlItems records...
                    ' To Support 1.9 Instalments integration

                    m_lReturn = ProcessCreditControl(sTransactionType:=gPMFunctions.ToSafeString(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)).Trim(), lPremiumFinanceCnt:=lPremiumFinanceCnt, lPRemiumFinanceVer:=lPremiumFinanceVersion)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("ProcessCreditControl", "lPremiumFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                    End If
                End If

            End If
            If Not Informations.IsNothing(m_vDepositJournal) Then
                vDepositTransID = CInt(Mid(m_vDepositJournal, 1, m_vDepositJournal.IndexOf("|"c)))
            End If
            m_lReturn = m_oDatabase.SQLCommitTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oDatabase.SQLCommitTrans", "Failed", gPMConstants.PMELogLevel.PMLogError)
            Else
                bRollback = False
            End If
            Return result

        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here
            If bRollback Then
                m_oDatabase.SQLRollbackTrans()
            End If

        Finally

            ' Do any tidy up, e.g. Set x = Nothing here
            If Not (oACTInstalments Is Nothing) Then
                oACTInstalments = Nothing
            End If

        End Try
        Return result
    End Function

    ' ---------------------------------------------------------------------------
    ' PROCEDURE NAME: MakeInstalmentPlanLive
    ' PURPOSE: Makes the Instalment Plan associated with the Insurance File Live
    ' AUTHOR: Danny Davis
    ' DATE: 10/03/2003, 11:16
    ' RETURNS: PMTrue for success
    ' CHANGES:
    ' ---------------------------------------------------------------------------
    Private Function MakeInstalmentPlanLive(ByVal v_lInsuranceFileCnt As Integer, ByVal lDepositExportFolderCnt As Integer, ByRef r_lPlanTransDetailID As Integer) As Integer

        Dim result As Integer = 0

        Try


            Dim lAccountId, lPlanTransDetailID As Integer
            Dim vDepositArray(0) As Object
            Dim vKeyArray(1, 3) As Object
            Dim oAllocationManual As bACTAllocationManual.Business

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Clear the Database Parameters Collection
            m_oDatabase.Parameters.Clear()

            With m_oDatabase

                ' Add ExportFolderCnt as an INPUT param
                ' Alix - 15/05/2003
                ' Pass insurance folder cnt instead of export folder cnt
                m_lReturn = .Parameters.Add(sName:="InsuranceFileCnt", vValue:=gPMFunctions.ToSafeString(v_lInsuranceFileCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                ' Add Deposit ExportFolderCnt as an INPUT param
                m_lReturn = .Parameters.Add(sName:="DepositExportFolderCnt", vValue:=gPMFunctions.ToSafeString(lDepositExportFolderCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                ' Add AccountID as an INPUT param
                m_lReturn = .Parameters.Add(sName:="AccountID", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                ' Add ExportFolderCnt as an INPUT param
                m_lReturn = .Parameters.Add(sName:="PlanTransDetailID", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                ' Add Deposit ExportFolderCnt as an INPUT param
                m_lReturn = .Parameters.Add(sName:="DepositCreditTransDetailID", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                ' Add Deposit ExportFolderCnt as an INPUT param
                m_lReturn = .Parameters.Add(sName:="Amount", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMCurrency)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                ' Add Deposit ExportFolderCnt as an INPUT param
                m_lReturn = .Parameters.Add(sName:="CurrencyAmount", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMCurrency)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                ' Execute Add Trans Export Details SQL Statement
                m_lReturn = .SQLAction(sSQL:=ACMakeLiveAfterStatsSQL, sSQLName:=ACMakeLiveAfterStatsName, bStoredProcedure:=ACMakeLiveAfterStatsStored)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If

                'DD 05/09/2003: Return the Instalment Transaction
                lPlanTransDetailID = .Parameters.Item("PlanTransDetailID").Value
                'Assign the value to this to the return value
                r_lPlanTransDetailID = lPlanTransDetailID

                'If there was a deposit then allocate the deposit to the
                'original plan debt (the remaining debt will be the total instalments)
                If lDepositExportFolderCnt > 0 Then
                    'Get the returned parameters
                    lAccountId = .Parameters.Item("AccountID").Value
                    'Use the bACTAllocationManual component to do the allocation
                    oAllocationManual = New bACTAllocationManual.Business
                    If oAllocationManual.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase) <> gPMConstants.PMEReturnCode.PMTrue Then

                        bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to create bACTAllocationManual", vApp:=ACApp, vClass:=ACClass, vMethod:="MakeInstalmentPlanLive", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                        Return gPMConstants.PMEReturnCode.PMFalse
                    End If

                    'Format the Outstanding transactions for use with Manual Allocation

                    vDepositArray(0) = .Parameters.Item("DepositCreditTransDetailID").Value

                    vDepositArray(0) = gPMFunctions.ToSafeString(vDepositArray(0)) & "|" &
                       .Parameters.Item("CurrencyAmount").Value

                    vKeyArray(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 0) = ACTKeyNameAccountID

                    vKeyArray(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 1) = ACTKeyNameTransDetailID

                    vKeyArray(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 2) = ACTKeyNameTransDetailIDs

                    vKeyArray(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 0) = lAccountId

                    vKeyArray(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1) = gPMFunctions.ToSafeString(lPlanTransDetailID) & "|" &
                                                                       .Parameters.Item("CurrencyAmount").Value

                    vKeyArray(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 2) = vDepositArray

                    'Perform the allocation
                    With oAllocationManual
                        'Override commission option here because no
                        'commission will be released here.

                        .CommissionOption = "0"

                        If .SetKeys(vKeyArray:=vKeyArray) <> gPMConstants.PMEReturnCode.PMTrue Then
                            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Allocation Manual Failed with Set Keys", vApp:=ACApp, vClass:=ACClass, vMethod:="MakeInstalmentPlanLive", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                            Return gPMConstants.PMEReturnCode.PMFalse
                        End If

                        If .Start() <> gPMConstants.PMEReturnCode.PMTrue Then
                            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed with Deposit allocation", vApp:=ACApp, vClass:=ACClass, vMethod:="MakeInstalmentPlanLive", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                            Return gPMConstants.PMEReturnCode.PMFalse
                        End If

                        .Dispose()
                    End With
                    oAllocationManual = Nothing
                End If
            End With

            Return result

            '----------------------------------------------------------------------------------------
            'Only for Debugging, the code will never execute this line
            '----------------------------------------------------------------------------------------

        Catch ex As Exception
            Select Case Informations.Err().Number
                Case Else
                    ' Log Error.
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="", vApp:=ACApp, vClass:=ACClass, vMethod:="MakeInstalmentPlanLive", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description, excep:=ex)

                    result = gPMConstants.PMEReturnCode.PMFalse

                    Return result
            End Select
        Finally

        End Try
        Return result

    End Function

