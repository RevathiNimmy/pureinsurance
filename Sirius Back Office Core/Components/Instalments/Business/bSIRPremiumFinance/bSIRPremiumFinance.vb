    Private Function CheckForSGRenewal(ByRef r_vFinancePlanArray(,) As Object) As Integer
        Dim lReturn As gPMConstants.PMEReturnCode
        Try

            Dim sSQL As String = ""
            Dim vArray(,) As Object = Nothing
            Dim vTmpPlan As Object = Nothing
            Dim lDiff As Integer

            sSQL = "SELECT pfprem_finance_cnt, startdate, schemeversion, clientid FROM pfpremiumfinance ORDER BY startdate"

            lReturn = m_oDatabase.SQLSelect(sSQL:=sSQL, sSQLName:="GetFinancePlanDates", bStoredProcedure:=False, vResultArray:=vArray)
            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception()
            End If

            If Informations.IsArray(vArray) Then

                For x As Integer = 0 To vArray.GetUpperBound(1)

                    lDiff = Informations.DateDiff("d", CDate(vArray(1, x)), DateTime.Now, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)

                    If lDiff >= 335 And lDiff <= 365 Then

                        If gPMFunctions.ToSafeInteger(vArray(3, x)) = gPMFunctions.ToSafeDouble(r_vFinancePlanArray(bSIRPremFinConst.k_PFPlanClientId, 0)) Then

                            'this is our renewal!

                            lReturn = CType(GetSingleFinancePlan(gPMFunctions.ToSafeInteger(vArray(0, x)), 1, vTmpPlan), gPMConstants.PMEReturnCode)
                            If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                Throw New Exception()
                            End If

                            r_vFinancePlanArray(bSIRPremFinConst.k_PFPlanBankAccountName, 0) = vTmpPlan(bSIRPremFinConst.k_PFPlanBankAccountName, 0)

                            r_vFinancePlanArray(bSIRPremFinConst.k_PFPlanBankAccountNo, 0) = vTmpPlan(bSIRPremFinConst.k_PFPlanBankAccountNo, 0)

                            r_vFinancePlanArray(bSIRPremFinConst.k_PFPlanBankSortCode, 0) = vTmpPlan(bSIRPremFinConst.k_PFPlanBankSortCode, 0)

                            r_vFinancePlanArray(bSIRPremFinConst.k_PFPlanBankBranch, 0) = vTmpPlan(bSIRPremFinConst.k_PFPlanBankBranch, 0)

                            Exit For
                        End If
                    End If
                Next x
            End If

        Catch
        End Try
        Return lReturn
    End Function

    Private Function GetPartyType(ByVal v_lPartyCnt As Integer, ByRef r_sPartyTypeCode As String) As Integer

        Dim result As Integer = 0

        Dim sSQL As String = ""
        Dim vArray(,) As Object = Nothing
        Dim lUpper As Integer

        result = gPMConstants.PMEReturnCode.PMTrue

        sSQL = "SELECT code FROM party_type WHERE party_type_id = (SELECT party_type_id FROM party WHERE party_cnt = " & v_lPartyCnt & ")"
        m_lReturn = m_oDatabase.SQLSelect(sSQL, "GetPartyTypeID", False, , vArray)
        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            GoTo Err_GetPartyType
        End If

        lUpper = -1
        Try

            lUpper = vArray.GetUpperBound(1)

        Catch
        End Try

        If lUpper > -1 Then

            r_sPartyTypeCode = gPMFunctions.ToSafeString(vArray(0, 0)).Trim()
        End If

        Return result
Err_GetPartyType:

        Return gPMConstants.PMEReturnCode.PMError

    End Function

