    '*************************************************************************
    'Name:          CalculateSingleQuote
    'Description:   Calculate a single quote, using a rate matching the given
    '               parameters, ie v_lMediaTypeID and v_lPFFrequencyID
    'History:       02/04/2003 - Created by Alix Bergeret
    '               11-07-2003 - ProductCode added to the interface
    '*************************************************************************
    Public Function CalculateSingleQuote(ByVal v_dtPreferredDate As Date, ByVal v_iDayInMonth As Integer, ByVal v_iDayInWeek As Integer, ByVal v_lMediaTypeId As Integer, ByVal v_lPFFrequencyID As Integer, ByVal v_cTotalAmount As Decimal, ByVal v_cInstalmentAmount As Decimal, ByVal v_sProductCode As String, ByRef r_vQuoteArray(,) As Object) As Integer

        Dim result As Integer = 0
        Dim iNumberOfInstalments As Integer
        Dim vPfrfArray(,) As Object = Nothing
        Dim iDelay As Integer
        Dim dInterestRate As Double
        Dim iRemainderAmountAtEnd As Integer
        Dim enDepositType As CalculationType
        Dim dDepositAmountOrPecentage As Double
        Dim iDepositChargedTo As Integer
        Dim enProtectionType As CalculationType
        Dim dProtectionAmntOrPercentage As Double
        Dim enFeesType As CalculationType
        Dim dFeesAmountOrPercentage As Double
        Dim dtFirstInstalmentDate, dtSecondInstalmentDate, dtLastInstalmentDate As Date
        Dim enAlignPremiumTo As AlignPremiumToOptions
        Dim iCount, iLoop As Integer
        Dim dtDateTemp, dtExtraDate As Date

        Dim cRemainderAmountThreshhold, cAmountToBeSpread, cInterestAmount, cTaxOnInterest, cRemainder, cFirstInstalmentAmount, cLastInstalmentAmount, cDepositAmount, cProtectionAmount, cFeesAmount As Decimal

        Dim cMinimumInterestAmount As Decimal 'mkw090604 PN12381

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            '***************
            ' MEvans : 11-07-2003 : 223 Bug
            ' product code is required to determine valid rates
            ' but wasnt being passed through
            m_sProductCode = v_sProductCode
            '***************

            ' Check that instalment amount greater than total amount!
            If v_cTotalAmount < v_cInstalmentAmount Then
                result = gPMConstants.PMEReturnCode.PMFail
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="The instalment amount to be paid " &
                                   "everymonth must be lesser than the total amount.", vApp:=ACApp, vClass:=ACClass, vMethod:="CalculateSingleQuote", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return result
            End If

            ' Select valid rate (should only be one)
            m_lReturn = GetValidPFRF(v_lMediaTypeId:=v_lMediaTypeId, v_lFrequencyID:=v_lPFFrequencyID, v_dtDate:=v_dtPreferredDate, r_vPFRFArray:=vPfrfArray)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFail
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to find a valid rate for the " &
                                   "given paramters.", vApp:=ACApp, vClass:=ACClass, vMethod:="CalculateSingleQuote", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return result
            End If

            ' Insert RATE related fields into the quote array
            ReDim r_vQuoteArray(k_PFQuoteUBound, 0)

            r_vQuoteArray(k_PFQuoteFrequencyPeriod, 0) = gPMFunctions.NullToString(gPMFunctions.ToSafeString(vPfrfArray(7, 0)).ToLower())

            r_vQuoteArray(k_PFQuoteFrequencyAmount, 0) = gPMFunctions.NullToLong(vPfrfArray(54, 0))

            r_vQuoteArray(k_PFQuotePFRF_ID, 0) = gPMFunctions.NullToLong(vPfrfArray(11, 0))

            r_vQuoteArray(k_PFQuoteFrequencyPerYear, 0) = gPMFunctions.NullToInteger(vPfrfArray(0, 0))

            r_vQuoteArray(k_PFQuoteCompanyNo, 0) = gPMFunctions.NullToLong(vPfrfArray(1, 0))

            r_vQuoteArray(k_PFQuoteCompanyName, 0) = gPMFunctions.NullToString(vPfrfArray(53, 0)).Trim()

            r_vQuoteArray(k_PFQuoteSchemeNo, 0) = gPMFunctions.NullToLong(vPfrfArray(2, 0))

            r_vQuoteArray(k_PFQuoteSchemeVersion, 0) = gPMFunctions.NullToLong(vPfrfArray(3, 0))

            r_vQuoteArray(k_PFQuoteSchemeName, 0) = gPMFunctions.NullToString(vPfrfArray(45, 0)).Trim()

            r_vQuoteArray(k_PFQuoteFrequencyID, 0) = gPMFunctions.NullToInteger(vPfrfArray(46, 0))

            r_vQuoteArray(k_PFQuoteFrequencyDescription, 0) = gPMFunctions.NullToString(vPfrfArray(47, 0)).Trim()

            r_vQuoteArray(k_PFQuoteMediaTypeID, 0) = v_lMediaTypeId

            r_vQuoteArray(k_PFQuoteMediaTypeDescription, 0) = gPMFunctions.NullToString(vPfrfArray(49, 0)).Trim()

            r_vQuoteArray(k_PFQuoteProductClass, 0) = gPMFunctions.NullToString(vPfrfArray(50, 0)).Trim()

            r_vQuoteArray(k_PFQuoteProductCode, 0) = gPMFunctions.NullToString(vPfrfArray(50, 0)).Trim()

            r_vQuoteArray(k_PFQuoteTotalAmountInput, 0) = v_cTotalAmount

            r_vQuoteArray(k_PFQuoteSchemeTypeCode, 0) = gPMFunctions.NullToString(vPfrfArray(51, 0)).Trim()

            r_vQuoteArray(k_PFQuoteMediaTypeValidation, 0) = gPMFunctions.NullToString(vPfrfArray(52, 0)).Trim()

            r_vQuoteArray(k_PFQuoteHighlightCell, 0) = False

            ' Get other values from rate
            iDelay = gPMFunctions.NullToInteger(vPfrfArray(4, 0))
            cRemainderAmountThreshhold = gPMFunctions.NullToDouble(vPfrfArray(55, 0))
            iRemainderAmountAtEnd = gPMFunctions.NullToInteger(vPfrfArray(56, 0))
            enDepositType = gPMFunctions.NullToInteger(vPfrfArray(8, 0))
            dDepositAmountOrPecentage = gPMFunctions.NullToDouble(vPfrfArray(9, 0))
            iDepositChargedTo = gPMFunctions.NullToInteger(vPfrfArray(10, 0))
            enProtectionType = gPMFunctions.NullToInteger(vPfrfArray(13, 0))
            dProtectionAmntOrPercentage = gPMFunctions.NullToDouble(vPfrfArray(14, 0))
            enFeesType = gPMFunctions.NullToInteger(vPfrfArray(40, 0))
            dFeesAmountOrPercentage = gPMFunctions.NullToDouble(vPfrfArray(41, 0))
            enAlignPremiumTo = gPMFunctions.NullToInteger(vPfrfArray(6, 0))

            ' Then calculate the deposit amount
            If crTaxIncludedAndNotSpreadAcrossInInstalment > 0 And dDepositAmountOrPecentage > 0 Then

                m_lReturn = CalculateDeposit(v_crAmount:=v_cTotalAmount - crTaxIncludedAndNotSpreadAcrossInInstalment,
                      v_enDepositType:=enDepositType,
                      v_dDepositAmountOrPecentage:=dDepositAmountOrPecentage,
                      r_crDepositAmount:=cDepositAmount)

                cDepositAmount = cDepositAmount + crTaxIncludedAndNotSpreadAcrossInInstalment

            Else
                m_lReturn = CalculateDeposit(v_crAmount:=v_cTotalAmount, v_enDepositType:=enDepositType, v_dDepositAmountOrPecentage:=dDepositAmountOrPecentage, r_crDepositAmount:=cDepositAmount)
            End If
            ' Then get the right interest rate for our total amount
            m_dInterestOverrideRate = -1
            m_crNewTotalFinanceAmount = v_cTotalAmount
            m_bOverrideCommission = False
            ' RAW 13/11/2003 : CQ1765 : add v_crFinanceAmount param

            m_lReturn = CalculateInterestRate(v_crFinanceAmount:=v_cTotalAmount, v_vArrayOfPFRFs:=vPfrfArray, v_lPFRFIndex:=0, r_dInterestRate:=dInterestRate)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFail
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to get a valid interest rate.", vApp:=ACApp, vClass:=ACClass, vMethod:="CalculateSingleQuote", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return result
            End If

            ' Calculate interest amount
            m_lReturn = CalculateInterest(v_crFinanceAmount:=v_cTotalAmount, v_dInterestRate:=dInterestRate, v_iDepositChargedTo:=iDepositChargedTo, v_crDepositAmount:=cDepositAmount, r_crInterestAmount:=cInterestAmount)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFail
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to calculate interest amount.", vApp:=ACApp, vClass:=ACClass, vMethod:="CalculateSingleQuote", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return result
            End If

            'mkw 090604 PN12381 Check interest amount against minimum interest amount START
            cMinimumInterestAmount = gPMFunctions.NullToCurrency(vPfrfArray(12, 0))
            If cInterestAmount < cMinimumInterestAmount Then
                cInterestAmount = cMinimumInterestAmount

                'caclulate interest rate
                If iDepositChargedTo = 1 Then
                    dInterestRate = (cMinimumInterestAmount / (v_cTotalAmount - cDepositAmount)) * 100
                Else
                    dInterestRate = (cMinimumInterestAmount / v_cTotalAmount) * 100
                End If
                dInterestRate = gPMFunctions.ToSafeDouble(StringsHelper.Format(dInterestRate, "0.00"))
            End If
            'mkw 090604 PN12381 END

            ' Calculate tax on interest amount (not yet supported)
            cTaxOnInterest = 0

            ' Calculate payment protection
            ' DEBUG
            'm_bPaymentProtection = True
            ' /DEBUG
            m_lReturn = CalculatePaymentProtection(v_crAmountForProtection:=(m_crNewTotalFinanceAmount - cDepositAmount + cInterestAmount + cTaxOnInterest), v_enProtectionType:=enProtectionType, v_dProtectionAmountOrPercentage:=dProtectionAmntOrPercentage, r_crProtectionAmount:=cProtectionAmount)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFail
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to calculate payment protection " &
                                   "amount.", vApp:=ACApp, vClass:=ACClass, vMethod:="CalculateSingleQuote", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return result
            End If

            ' Calculate amount of Fees
            m_lReturn = CalculateFees(v_crFinanceAmount:=m_crNewTotalFinanceAmount, v_enFeeType:=enFeesType, v_dFeeAmountOrPercentage:=dFeesAmountOrPercentage, r_crFeesAmount:=cFeesAmount)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFail
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to calculate fees.", vApp:=ACApp, vClass:=ACClass, vMethod:="CalculateSingleQuote", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)
                Return result
            End If

            ' Calculate total amount due including all fees and minus deposit
            cAmountToBeSpread = v_cTotalAmount - cDepositAmount + cInterestAmount + cTaxOnInterest + cProtectionAmount + cFeesAmount
            If crTaxIncludedAndNotSpreadAcrossInInstalment > 0 And cDepositAmount = 0 Then
                cAmountToBeSpread = cAmountToBeSpread - crTaxIncludedAndNotSpreadAcrossInInstalment
            End If

            ' Work out number of instalments
            iNumberOfInstalments = cAmountToBeSpread \ v_cInstalmentAmount

            ' Calculate remainder
            cRemainder = cAmountToBeSpread - (iNumberOfInstalments * v_cInstalmentAmount)

            ' Work out dates
            dtFirstInstalmentDate = v_dtPreferredDate.AddDays(iDelay)

            If gPMFunctions.ToSafeString(r_vQuoteArray(k_PFQuoteFrequencyPeriod, 0)).Trim.ToUpper = "M" Then
                m_sVBFrequencyInterval = "m"
                m_iDayOfWeekOrMonth = v_iDayInMonth
            Else
                m_sVBFrequencyInterval = "ww"
                m_iDayOfWeekOrMonth = v_iDayInWeek
            End If
            iCount = 1
            iLoop = 1
            Do While iCount <= iNumberOfInstalments

                CalculateNextOrPrevInstalment(v_dtPreferredDate, iLoop * gPMFunctions.ToSafeDouble(r_vQuoteArray(k_PFQuoteFrequencyAmount, 0)), WhichDirection.MovingForwards, dtDateTemp, enAlignPremiumTo)
                iCount += 1
                iLoop += 1

                ' Get second instalment date
                If iCount = 2 Then
                    If dtDateTemp > dtFirstInstalmentDate Then
                        dtSecondInstalmentDate = dtDateTemp
                    Else
                        iCount -= 1
                    End If
                End If
                ' Get last instalment date
                If iCount = iNumberOfInstalments Then
                    dtLastInstalmentDate = dtDateTemp
                End If
            Loop
            ' Get the next date AFTER date of last instalment, in case of we need to add
            ' an instalment for the remainder
            dtExtraDate = dtDateTemp

            ' Work out what we do with the remainder
            cFirstInstalmentAmount = v_cInstalmentAmount
            cLastInstalmentAmount = v_cInstalmentAmount
            If cRemainder > 0 Then
                ' Addreminder as last or first instalment?
                If iRemainderAmountAtEnd = 1 Then
                    If cRemainder > cRemainderAmountThreshhold Then
                        ' Set the last instalment to be the remainder
                        cLastInstalmentAmount = cRemainder
                        ' Increment the number of instalments
                        iNumberOfInstalments += 1
                        ' Advance the last instalment date
                        dtLastInstalmentDate = dtExtraDate
                    Else
                        ' Add remainder to last instalment
                        cLastInstalmentAmount += cRemainder
                    End If
                Else
                    If cRemainder > cRemainderAmountThreshhold Then
                        ' Set the first instalment to be the remainder
                        cFirstInstalmentAmount = cRemainder
                        ' Increment number of instalments
                        iNumberOfInstalments += 1
                        ' Advance the last instalment date
                        dtLastInstalmentDate = dtExtraDate
                    Else
                        ' Add remainder to first instalment
                        cFirstInstalmentAmount += cRemainder
                    End If
                End If
            End If

            If crTaxIncludedAndNotSpreadAcrossInInstalment > 0 And cDepositAmount = 0 Then
                cFirstInstalmentAmount = cFirstInstalmentAmount + crTaxIncludedAndNotSpreadAcrossInInstalment
            End If
            ' Insert other fields in quote

            r_vQuoteArray(k_PFQuoteInstalmentsToPay, 0) = iNumberOfInstalments

            r_vQuoteArray(k_PFQuoteFirstInstalmentDate, 0) = dtFirstInstalmentDate

            r_vQuoteArray(k_PFQuoteLastInstalmentDate, 0) = dtLastInstalmentDate

            r_vQuoteArray(k_PFQuoteNextInstalmentDate, 0) = dtSecondInstalmentDate

            r_vQuoteArray(k_PFQuoteFirstInstalmentAmount, 0) = cFirstInstalmentAmount

            r_vQuoteArray(k_PFQuoteLastInstalmentAmount, 0) = cLastInstalmentAmount

            r_vQuoteArray(k_PFQuoteOtherInstalmentAmount, 0) = v_cInstalmentAmount
            ' Gaurav

            r_vQuoteArray(k_PFQuoteTotalInstalmentsAmount, 0) = cAmountToBeSpread

            r_vQuoteArray(k_PFQuoteAprRate, 0) = cInterestAmount

            r_vQuoteArray(k_PFQuoteInterestRate, 0) = dInterestRate

            r_vQuoteArray(bSIRPremFinConst.k_PFPlanOriginalRate, 0) = dInterestRate

            r_vQuoteArray(k_PFQuoteDaysDelay, 0) = iDelay

            r_vQuoteArray(k_PFQuoteDepositAmount, 0) = cDepositAmount

            r_vQuoteArray(k_PFQuoteInterestAmount, 0) = cInterestAmount

            r_vQuoteArray(k_PFQuoteTaxAmount, 0) = cTaxOnInterest

            r_vQuoteArray(k_PFQuoteFinanceCharge, 0) = cFeesAmount

            r_vQuoteArray(k_PFQuoteProtectionAmount, 0) = cProtectionAmount

            r_vQuoteArray(k_PFQuoteOriginalOtherInstalmentAmount, 0) = 0

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMFail
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Error during CalculateSingleQuote", vApp:=ACApp, vClass:=ACClass, vMethod:="CalculateSingleQuote", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result
        End Try
    End Function

