    Public Function UpdateExistingRecord(ByVal vExistingRecord As Array, ByVal vPremiumFinanceCnt As Object, ByVal vPremiumFinanceVersion As Object) As Integer
        Return UpdateExistingRecord(vExistingRecord:=vExistingRecord, vPremiumFinanceCnt:=vPremiumFinanceCnt, vPremiumFinanceVersion:=vPremiumFinanceVersion, nArrayIndex:=0, vPremiumFinanceMTA:=Nothing, iCreatePartyBankRecord:=0)
    End Function

    Public Function UpdateExistingRecord(ByVal vExistingRecord As Array, ByVal vPremiumFinanceCnt As Object, ByVal vPremiumFinanceVersion As Object, ByRef nArrayIndex As Integer) As Integer
        Return UpdateExistingRecord(vExistingRecord:=vExistingRecord, vPremiumFinanceCnt:=vPremiumFinanceCnt, vPremiumFinanceVersion:=vPremiumFinanceVersion, nArrayIndex:=nArrayIndex, vPremiumFinanceMTA:=Nothing, iCreatePartyBankRecord:=0)
    End Function

    Public Function UpdateExistingRecord(ByVal vExistingRecord As Array, ByVal vPremiumFinanceCnt As Object, ByVal vPremiumFinanceVersion As Object, ByRef nArrayIndex As Integer, ByRef vPremiumFinanceMTA(,) As Object) As Integer
        Return UpdateExistingRecord(vExistingRecord:=vExistingRecord, vPremiumFinanceCnt:=vPremiumFinanceCnt, vPremiumFinanceVersion:=vPremiumFinanceVersion, nArrayIndex:=nArrayIndex, vPremiumFinanceMTA:=vPremiumFinanceMTA, iCreatePartyBankRecord:=0)
    End Function

    Public Function UpdateExistingRecord(ByVal vExistingRecord As Array, ByVal vPremiumFinanceCnt As Object, ByVal vPremiumFinanceVersion As Object, ByRef nArrayIndex As Integer, ByRef vPremiumFinanceMTA(,) As Object, ByRef iCreatePartyBankRecord As Integer) As Integer

        Dim result As Integer = 0
        Dim vFinancePlanTransactionArray(,) As Object = Nothing
        Dim cMTAAmount As Decimal
        Dim oPremiumFinancePlan As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Start a transaction so we can rollback any errors.
            m_lReturn = m_oDatabase.SQLBeginTrans()

            ' Check for mta transaction array

            If Not Informations.IsNothing(vPremiumFinanceMTA) Then
                If Informations.IsArray(vPremiumFinanceMTA) Then
                    For lRow As Integer = vPremiumFinanceMTA.GetLowerBound(1) To vPremiumFinanceMTA.GetUpperBound(1)
                        If Not Informations.IsArray(vFinancePlanTransactionArray) Then
                            ReDim vFinancePlanTransactionArray(0, 0)
                        Else

                            ReDim Preserve vFinancePlanTransactionArray(0, vFinancePlanTransactionArray.GetUpperBound(1) + 1)
                        End If

                        vFinancePlanTransactionArray(0, vFinancePlanTransactionArray.GetUpperBound(1)) = vPremiumFinanceMTA(0, lRow)

                        cMTAAmount += CDec(vPremiumFinanceMTA(2, lRow))
                    Next lRow
                End If
            End If

            If gPMFunctions.ToSafeDouble(vPremiumFinanceCnt) > 0 AndAlso
                gPMFunctions.ToSafeDouble(vPremiumFinanceVersion) > 0 AndAlso
                Not Object.Equals(vExistingRecord.GetValue(bSIRPremFinConst.k_PFPlanStatusInd, nArrayIndex), Nothing) _
                Then
                m_lReturn = GetSingleFinancePlan(v_lFinanceCount:=vPremiumFinanceCnt,
                                                 v_lFinanceVersion:=vPremiumFinanceVersion,
                                                 r_vPFPremiumFinance:=oPremiumFinancePlan)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("UpdateExistingRecord", "sName:=GetSingleFinancePlan Failed",
                                            gPMConstants.PMELogLevel.PMLogError)
                End If

                If Informations.IsArray(oPremiumFinancePlan) AndAlso
                    gPMFunctions.ToSafeString(oPremiumFinancePlan.GetValue(bSIRPremFinConst.k_PFPlanStatusInd, 0)) <> "" AndAlso
                    (
                    (gPMFunctions.ToSafeString(vExistingRecord.GetValue(bSIRPremFinConst.k_PFPlanStatusInd, nArrayIndex)) <>
                    bSIRPremFinConst.PFStatusIndLive) AndAlso
                    (gPMFunctions.ToSafeString(vExistingRecord.GetValue(bSIRPremFinConst.k_PFPlanStatusInd, nArrayIndex)) <>
                    bSIRPremFinConst.PFStatusIndOnHold)
                    ) Then
                    vExistingRecord.SetValue(oPremiumFinancePlan.GetValue(bSIRPremFinConst.k_PFPlanStatusInd, 0),
                     bSIRPremFinConst.k_PFPlanStatusInd, nArrayIndex)
                End If
            End If

            If Convert.ToString(vExistingRecord(k_PFPlanStatusInd, nArrayIndex)).Trim() = PFStatusIndSaved Then
                vExistingRecord(k_PFPlanStatusInd, nArrayIndex) = PFStatusIndUpdated
            ElseIf Convert.ToString(vExistingRecord(k_PFPlanStatusInd, nArrayIndex)).Trim() = "" Then
                vExistingRecord(k_PFPlanStatusInd, nArrayIndex) = PFStatusIndSaved
            End If


            ' Build Parameters Here!
            m_oDatabase.Parameters.Clear()
            m_oDatabase.Parameters.Add("FinancePlanCnt", gPMFunctions.ToSafeInteger(vPremiumFinanceCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

            m_oDatabase.Parameters.Add("FinancePlanVersion", gPMFunctions.ToSafeInteger(vPremiumFinanceVersion), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

            m_oDatabase.Parameters.Add("ClientID", Convert.ToString(vExistingRecord(bSIRPremFinConst.k_PFPlanClientId, nArrayIndex)).Trim(), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

            m_oDatabase.Parameters.Add("AmountToFinance", Math.Round(CDec(vExistingRecord(bSIRPremFinConst.k_PFPlanAmountToFinance, nArrayIndex)) + cMTAAmount, 2), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMCurrency)

            m_oDatabase.Parameters.Add("StartDate", Convert.ToString(vExistingRecord(bSIRPremFinConst.k_PFPlanStartDate, nArrayIndex)).Trim(), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMDate)
            m_oDatabase.Parameters.Add("ClientName", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientName, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientAddr1", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientAddress1, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientAddr2", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientAddress2, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientAddr3", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientAddress3, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientTown", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientTown, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientAddr4", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientAddress4, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientPCode", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientPostcode, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientCountry", NullIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientCountry_ID, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger)
            m_oDatabase.Parameters.Add("ClientAreaCode", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientAreaCode, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientPhone", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientPhone, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientExtn", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientExtn, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientFaxCode", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientFaxCode, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("ClientFaxNo", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanClientFax, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankName", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankName, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("SortCode", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankSortCode, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("AccountNo", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankAccountNo, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("AccountName", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankAccountName, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("Branch", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankBranch, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankAddr1", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankAddress1, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankAddr2", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankAddress2, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankAddr3", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankAddress3, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankTown", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankTown, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankAddr4", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankAddress4, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankPCode", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankPostcode, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankCountry", NullIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankCountry_ID, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger)
            m_oDatabase.Parameters.Add("BankAreaCode", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankAreaCode, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankPhoneNo", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankPhone, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankPhoneExtn", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankExtn, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankFaxCode", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankFaxCode, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("BankFaxNo", BlankIfEmpty(vExistingRecord(bSIRPremFinConst.k_PFPlanBankFax, nArrayIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)

