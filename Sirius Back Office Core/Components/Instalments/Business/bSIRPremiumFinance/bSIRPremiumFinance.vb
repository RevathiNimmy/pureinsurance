            m_oDatabase.Parameters.Add("limitedcompany", NullIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanLimitedCompany, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            m_oDatabase.Parameters.Add("is_cardholder", NullIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanIsCardholder, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger)
            m_oDatabase.Parameters.Add("cardholder_name", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderName, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("cardholder_address1", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderAddress1, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("cardholder_address2", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderAddress2, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("cardholder_address3", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderAddress3, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("cardholder_address4", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderAddress4, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("cardholder_postcode", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PfPlanCardholderPostcode, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("card_type", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanCardType, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("provider_collect_deposit", NullIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanProviderCollectDeposit, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            m_oDatabase.Parameters.Add("datebankdetailschanged", NullIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PfPlanDateBankDetailsChanged, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMDate)
            m_oDatabase.Parameters.Add("tax_group_id", NullIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PfPlanTaxGroupID, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            m_oDatabase.Parameters.Add("source_id", gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSource_ID, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            m_oDatabase.Parameters.Add("sub_branch_id", gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSubBranchID, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            m_oDatabase.Parameters.Add("batch_id", gPMFunctions.ToSafeLong(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanBatchID, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong) '(RC) PLICO 9-10

            If Convert.IsDBNull(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSGSchemeType, 0)) Then
                m_oDatabase.Parameters.Add("scheme_type", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            Else
                m_oDatabase.Parameters.Add("scheme_type", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSGSchemeType, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            End If

            If Convert.IsDBNull(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSGSchemeCode, 0)) Then
                m_oDatabase.Parameters.Add("scheme_code", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            Else
                m_oDatabase.Parameters.Add("scheme_code", BlankIfEmpty(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanSGSchemeCode, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            End If
            m_oDatabase.Parameters.Add("deposit_cc_tracking_number", NullIfEmpty(m_sDepositCCTrackingNumber), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)

            m_oDatabase.Parameters.Add("use_trans_currency",
                                       If(gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.kUseTransactionCurrency, 0)) = -1, DBNull.Value, gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.kUseTransactionCurrency, 0))),
                                       gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger)

            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACAddNewPFPremiumFinanceSQL, sSQLName:=ACAddNewPFPremiumFinanceName, bStoredProcedure:=ACAddNewPFPremiumFinanceStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Update array

            If (m_oDatabase.Parameters.Item("FinancePlanCnt").Value) Is Nothing Then
                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0) = 0
            Else
                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0) = m_oDatabase.Parameters.Item("FinancePlanCnt").Value
            End If
            If (m_oDatabase.Parameters.Item("FinancePlanVersion").Value) Is Nothing Then
                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0) = 0
            Else
                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0) = m_oDatabase.Parameters.Item("FinancePlanVersion").Value
            End If

            If (m_oDatabase.Parameters.Item("FinancePlanVersion").Value) Is Nothing Then
                m_lPremFinanceVer = 0
            Else
                m_lPremFinanceVer = m_oDatabase.Parameters.Item("FinancePlanVersion").Value
            End If

            If (m_oDatabase.Parameters.Item("FinancePlanCnt").Value) Is Nothing Then
                m_lPremFinanceCnt = 0
            Else
                m_lPremFinanceCnt = m_oDatabase.Parameters.Item("FinancePlanCnt").Value
            End If

            '=======================================================
            If IsSinglePlanParty(v_lPartyCnt:=m_lInsuranceFileCnt, r_vSinglePlanParty:=vSinglePlanParty) <> gPMConstants.PMEReturnCode.PMTrue Then
            End If

            If Informations.IsArray(vSinglePlanParty) Then
                If gPMFunctions.ToSafeBoolean(vSinglePlanParty(0, 0)) Then
                    m_bIsSinglePlanParty = True
                End If
            End If
            If m_bIsSinglePlanParty Then
                m_oDatabase.Parameters.Clear() ''PN 4241

                m_lReturn = AddInputParameter(v_sName:="insurance_file_cnt", v_vValue:=gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0)), v_iType:=gPMConstants.PMEDataType.PMLong)  ''PN4241

                'm_oDatabase.Parameters.Add("insurance_file_cnt", gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                m_lReturn = m_oDatabase.SQLSelect(sSQL:=kGetLeadAgentSQL, sSQLName:=kGetLeadAgentName, bStoredProcedure:=True, vResultArray:=vLeadAgent)
                If Informations.IsArray(vLeadAgent) Then
                    m_oDatabase.Parameters.Clear() ''PN 4241
                    m_oDatabase.Parameters.Add("pfprem_finance_cnt", m_lPremFinanceCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    m_oDatabase.Parameters.Add("pfprem_finance_version", m_lPremFinanceVer, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                    m_oDatabase.Parameters.Add("agent_cnt", gPMFunctions.ToSafeInteger(vLeadAgent(0, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    m_lReturn = m_oDatabase.SQLAction(sSQL:=kPFPremiumFinanceAgentUpdSQL, sSQLName:=kPFPremiumFinanceAgentUpdName, bStoredProcedure:=True)

                    r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAgentCnt, 0) = gPMFunctions.ToSafeInteger(vLeadAgent(0, 0))
                End If
            End If
            '=========================================================
            'ACR 15-12-2005 for PCLPSG quotes we need to create a reference for this plan
            'from the policy number..

            If Not (r_vPFPlanArray(bSIRPremFinConst.k_PFPlanXSLCode, 0)) Is Nothing AndAlso gPMFunctions.ToSafeString(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanXSLCode, 0)).Trim() = "PCLPSG" Then

                m_lReturn = GetInsuranceMediaRef(gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0)), sRef)
                'lose any trailing spaces
                sRef = sRef.Trim()

                If m_lReturn = gPMConstants.PMEReturnCode.PMTrue And sRef <> "" Then
                    If sRef.Length > 16 Then
                        sRef = Mid(sRef, sRef.Length - 15, 16)
                    End If

                    r_vPFPlanArray(bSIRPremFinConst.k_PFPlanReference, 0) = sRef

                    r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0) = sRef
                Else

                    r_vPFPlanArray(bSIRPremFinConst.k_PFPlanReference, 0) = ""
                End If
            End If

            ' if this is a renewal and its true monthly policy
            ' use the existing autogenerated plan reference.....

            If v_sOriginalAutoGeneratedPlanRef.Trim() <> "" And gPMFunctions.ToSafeString(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanTransactionType, 0)).Trim() = "REN" And bIsTrueMonthlyPolicy Then
                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0) = v_sOriginalAutoGeneratedPlanRef.Trim()
            Else
                ' for all other scenarios use the new style
                ' The autogenerated plan reference is now simply the PFPrem_Finance_Cnt
                ' This is in order to reduce the size to be within the 12 character limit
                ' imposed by CC Processing and the 18 character limit imposed by BACS
                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0) = r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0)
            End If

            '    ' Now re-save the reference number and any other details
            '    'TODO:  this section should be if not (renewals and bIsTrueMonthlyPolicy And Not (bIsAnniversaryPolicy))
            '    If Not (Trim$(r_vPFPlanArray(k_PFPlanTransactionType, 0)) = "REN" And bIsTrueMonthlyPolicy And bIsAnniversaryCopy) Then

            '        r_vPFPlanArray(k_PFPlanAutoGenPlanRef, 0) = r_vPFPlanArray(k_PFPlanPFCnt, 0)
            '    Else
            '        ' get the plan reference from the anniversary copy of the plan
            '        r_vPFPlanArray(k_PFPlanAutoGenPlanRef, 0) = _
            ''        Trim(r_vPFPlanArray(k_PFPlanClientCode, 0)) & "/" & r_vPFPlanArray(k_PFPlanPFCnt, 0)
            '    End If

            r_vPFPlanArray(bSIRPremFinConst.k_PFPlanFinCollPlanRef, 0) = StringsHelper.Format(gPMFunctions.ToSafeInteger(sICCS), "0000") & StringsHelper.Format(gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0)), "0000") & StringsHelper.Format(gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0)), "00")

            ' RDT 25042007 - Leave the status if this is underwriting and the status is completed, as this is use by data transfers.

            If (gPMFunctions.ToSafeString(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanStatusInd, 0)) <> bSIRPremFinConst.PFStatusIndCompleted) And (gPMFunctions.ToSafeString(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanStatusInd, 0)) <> bSIRPremFinConst.PFStatusIndOnHold) Then
                'sw reset the status so that when the existing record is updated it will leave the
                'status as saved 03/07/2003

                r_vPFPlanArray(bSIRPremFinConst.k_PFPlanStatusInd, 0) = Nothing
            End If

            m_lReturn = UpdateExistingRecord(vExistingRecord:=r_vPFPlanArray, vPremiumFinanceCnt:=r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0), vPremiumFinanceVersion:=r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            r_lPFPlanCnt = gPMFunctions.ToSafeInteger(r_vPFPlanArray(bSIRPremFinConst.k_PFPlanPFCnt, 0))

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="InsertNewPFPlan Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="InsertNewPFPlan", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)
            Return result

            Return result
        End Try
    End Function

