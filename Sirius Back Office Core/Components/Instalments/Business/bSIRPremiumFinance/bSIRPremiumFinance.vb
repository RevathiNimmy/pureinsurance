    ' ***************************************************************** '
    ' Name: GetDocumentReference
    ' ***************************************************************** '
    Private Function GetDocumentReference(ByVal v_lDocumentTypeId As Integer, ByVal v_lDocumentSourceId As Integer, ByRef r_sDocumentRef As String) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "GetDocumentReference"

        Dim lReturn As gPMConstants.PMEReturnCode
        Dim sGroupCode As String = String.Empty
        Dim sRangeCode As String = String.Empty
        Dim sReference As String = String.Empty

        Dim oDocumentObject As bACTDocument.Form


        result = gPMConstants.PMEReturnCode.PMTrue

        oDocumentObject = New bACTDocument.Form()

        lReturn = (oDocumentObject).Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=m_sCallingAppName)

        ' get the group and range code for the document type
        lReturn = oDocumentObject.GetAutoNumValues(v_iDocumenttypeID:=v_lDocumentTypeId, r_sGroupCode:=sGroupCode, r_sRangeCode:=sRangeCode)

        If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            gPMFunctions.RaiseError("bACTDocument.Form.GetAutoNumValues", "Function failed", gPMConstants.PMELogLevel.PMLogError)
        End If

        ' get the document ref number
        'Start-(Arul Stephen)-(Tech Spec -WPR78_Unique_Document_Reference_Number)
        lReturn = oDocumentObject.GenerateDocumentReferenceNumber(v_sGroupCode:=sGroupCode, v_sRangeCode:=sRangeCode, v_iUserID:=m_iUserID, v_iCompanyID:=m_iSourceID, r_sDocumentRef:=sReference)
        'End-(Arul Stephen)-(Tech Spec -WPR78_Unique_Document_Reference_Number)
        If lReturn = gPMConstants.PMEReturnCode.PMTrue And sReference.Trim() <> "" Then

            ' Prefix a few zeros
            '(Arul Stephen)-(Tech Spec -WPR78_Unique_Document_Reference_Number)
            sReference = sRangeCode & sReference
            r_sDocumentRef = sReference

        Else
            gPMFunctions.RaiseError(kMethodName, "bACTDocument.Form.GenerateNumber Failed", gPMConstants.PMELogLevel.PMLogError)
        End If
        oDocumentObject.Dispose()
        oDocumentObject = Nothing
        Return result
    End Function

