                Return nResult
            End If

            m_oDatabase.Parameters.Clear()
            m_oDatabase.Parameters.Add("PremiumFinanceCnt", gPMFunctions.ToSafeString(v_lPremiumFinanceCnt), PMEParameterDirection.PMParamInput, PMEDataType.PMLong)
