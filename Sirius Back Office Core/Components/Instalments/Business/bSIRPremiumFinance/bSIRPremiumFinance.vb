    ''' <summary>
    ''' Get default payment term
    ''' </summary>
    ''' <param name="nInsuranceFileCnt"></param>
    ''' <param name="sDefaultPaymentMethod"></param>
    ''' <param name="nDefaultInstalmentPlan"></param>
    ''' <param name="nDefaultInstalmentPlanVersion"></param>
    ''' <param name="nDefaultSchemeNumber"></param>
    ''' <param name="nDefaultSchemeVersion"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function GetDefaultPaymentTerms(ByVal nInsuranceFileCnt As Integer, ByRef sDefaultPaymentMethod As String,
   ByRef nDefaultInstalmentPlan As Integer, ByRef nDefaultInstalmentPlanVersion As Integer, ByRef nDefaultSchemeNumber As Integer, ByRef nDefaultSchemeVersion As Integer) As Integer

        Dim aoResultArray As Object = Nothing

        Try

            m_oDatabase.Parameters.Clear()

            m_lReturn = m_oDatabase.Parameters.Add(sName:="nInsuranceFileCnt", vValue:=nInsuranceFileCnt, iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMInteger)

            If m_oDatabase.SQLSelect(sSQL:=kGetDefaultPaymentTermsSQL, sSQLName:=kGetDefaultPaymentTermsName,
                                     bStoredProcedure:=True, vResultArray:=aoResultArray,
                                     bKeepNulls:=True, lNumberRecords:=gPMConstants.PMAllRecords) <> gPMConstants.PMEReturnCode.PMTrue Then

                Throw New ApplicationException("Failed to execute kGetDefaultPaymentTermsSQL")
            End If

            If Informations.IsArray(aoResultArray) Then
                sDefaultPaymentMethod = aoResultArray(0, 0) ' Get Default payment method
                nDefaultInstalmentPlan = aoResultArray(1, 0) ' Get Plan no
