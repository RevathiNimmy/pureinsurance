    End Function

    Public Function CheckIsSchemeInHouse(ByVal v_lFinancePlanCnt As Integer, ByVal v_lFinancePlanVersion As Integer, ByRef r_bSchemeIsInHouse As Boolean) As Integer
        Return CheckIsSchemeInHouse(v_lFinancePlanCnt:=v_lFinancePlanCnt, v_lFinancePlanVersion:=v_lFinancePlanVersion, r_bSchemeIsInHouse:=r_bSchemeIsInHouse, r_lPFPaymentMethod_cnt:=0)
    End Function

    Public Function CheckIsSchemeInHouse(ByVal v_lFinancePlanCnt As Integer, ByVal v_lFinancePlanVersion As Integer, ByRef r_bSchemeIsInHouse As Boolean, ByRef r_lPFPaymentMethod_cnt As Integer) As Integer

        Dim result As Integer = 0
        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Retrieve in house status for associated scheme
            m_oDatabase.Parameters.Clear()

            ' Finance plan cnt
            m_lReturn = m_oDatabase.Parameters.Add(sName:="financeplancnt", vValue:=gPMFunctions.ToSafeString(v_lFinancePlanCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Finance plan version
            m_lReturn = m_oDatabase.Parameters.Add(sName:="financeplanversion", vValue:=gPMFunctions.ToSafeString(v_lFinancePlanVersion), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Is in house, return value
            m_lReturn = m_oDatabase.Parameters.Add(sName:="isinhouse", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMLong)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Is in house, return value
            m_lReturn = m_oDatabase.Parameters.Add(sName:="PFPaymentMethod_cnt", vValue:=gPMFunctions.ToSafeString(0), iDirection:=gPMConstants.PMEParameterDirection.PMParamOutput, iDataType:=gPMConstants.PMEDataType.PMLong)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Execute the procedure
            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACCheckIsInHouseSQL, sSQLName:=ACCheckIsInHouseName, bStoredProcedure:=ACCheckIsInHouseStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Retrieve the return value
            r_bSchemeIsInHouse = m_oDatabase.Parameters.Item("isinhouse").Value
            r_lPFPaymentMethod_cnt = m_oDatabase.Parameters.Item("PFPaymentMethod_cnt").Value

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CheckIsSchemeInHouse Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="CheckIsSchemeInHouse", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ***************************************************************** '
    '
    ' Name: JoinParentPlan
    '
    ' Description:  Joins an existing plan to a parent plan
    '
    ' History: 05/10/2001 DD - Created.
    '
    ' ***************************************************************** '
    Public Function JoinParentPlan(ByRef vParentPlan(,) As Object, ByRef vChildPlan As Array) As Integer
        Dim result As Integer = 0
        Dim oPFInstalments As bSIRPFInstalments.Business

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_oDatabase.SQLBeginTrans()

            'Point the child to the parent

            vChildPlan(bSIRPremFinConst.k_PFPlanIsParentPlan, 0) = 0

            vChildPlan(bSIRPremFinConst.k_PFPlanParentPlanCnt, 0) = vParentPlan(bSIRPremFinConst.k_PFPlanPFCnt, 0)

            vChildPlan(bSIRPremFinConst.k_PFPlanParentPlanVersion, 0) = vParentPlan(bSIRPremFinConst.k_PFPlanPFVersion, 0)

            'and save it
            m_lReturn = UpdateExistingRecord(vChildPlan, vChildPlan(bSIRPremFinConst.k_PFPlanPFCnt, 0), vChildPlan(bSIRPremFinConst.k_PFPlanPFVersion, 0), 0)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'rollback the changes
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            'now update the instalments tree
            'SD 31/07/2002 Scalability changes
            oPFInstalments = New bSIRPFInstalments.Business
            m_lReturn = oPFInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

            m_lReturn = oPFInstalments.MergeInstalments(vParentPlan(bSIRPremFinConst.k_PFPlanPFCnt, 0), vParentPlan(bSIRPremFinConst.k_PFPlanPFVersion, 0))

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'rollback the changes
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            'Close up
            oPFInstalments = Nothing

            'Commit the changes
            m_oDatabase.SQLCommitTrans()

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="JoinParentPlan Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="JoinParentPlan", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ***************************************************************** '
    '
    ' Name: CreateParentPlan
    '
    ' Description:  Generates a parent plan and turns the passed
    '               plans into children. Merges Instalments into parent.
    '               CopyFrom parameter contains the array index for the
    '               child array identifying the entry to use as the
    '               template for the parent.
    '
    ' History: 21/08/2001 DD - Created.
    '           12/12/2001 DD - changes vChildPlans parameter to ByRef
    '
    ' ***************************************************************** '
    Public Function CreateParentPlan(ByRef vChildPlans As Array, ByRef lCopyFrom As Integer) As Integer
        Dim result As Integer = 0
        Dim oPFInstalments As bSIRPFInstalments.Business
        Dim vNewRecord As Object
        Dim nPFCount, nEnd As Integer

        Try

            m_oDatabase.SQLBeginTrans()

            nEnd = vChildPlans.GetUpperBound(0)
            ReDim vNewRecord(nEnd, 0)

            'Copy the details from the indexed Child Plan
            For nItem As Integer = 0 To nEnd

                vNewRecord(nItem, 0) = vChildPlans(nItem, lCopyFrom)
            Next nItem

            'Now mark the new record as a parent

            vNewRecord(bSIRPremFinConst.k_PFPlanIsParentPlan, 0) = 1

            vNewRecord(bSIRPremFinConst.k_PFPlanParentPlanCnt, 0) = ""

            vNewRecord(bSIRPremFinConst.k_PFPlanParentPlanVersion, 0) = ""

            'Set the parent status as live

            vNewRecord(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndLive

            vNewRecord(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0) = 0

            'Save the Parent

            m_lReturn = InsertNewPFPlan(vNewRecord, nPFCount)

            'Now mark the children pointing to the parent
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'rollback the changes
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            nEnd = vChildPlans.GetUpperBound(1)
            For nItem As Integer = 0 To nEnd

                vChildPlans(bSIRPremFinConst.k_PFPlanIsParentPlan, nItem) = 0

                vChildPlans(bSIRPremFinConst.k_PFPlanParentPlanCnt, nItem) = vNewRecord(bSIRPremFinConst.k_PFPlanPFCnt, 0)

                vChildPlans(bSIRPremFinConst.k_PFPlanParentPlanVersion, nItem) = vNewRecord(bSIRPremFinConst.k_PFPlanPFVersion, 0)

                'and save them
                m_lReturn = UpdateExistingRecord(vChildPlans, vChildPlans(bSIRPremFinConst.k_PFPlanPFCnt, nItem), vChildPlans(bSIRPremFinConst.k_PFPlanPFVersion, nItem), nItem)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    'rollback the changes
                    m_oDatabase.SQLRollbackTrans()
                    Return m_lReturn
                End If
            Next nItem

            'Finally merge the instalments
            'SD 31/07/2002 Scalability changes
            oPFInstalments = New bSIRPFInstalments.Business
            m_lReturn = oPFInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

            m_lReturn = oPFInstalments.MergeInstalments(vNewRecord(bSIRPremFinConst.k_PFPlanPFCnt, 0), vNewRecord(bSIRPremFinConst.k_PFPlanPFVersion, 0))

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'rollback the changes
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            'Close up
            oPFInstalments = Nothing

            'Commit the changes
            m_oDatabase.SQLCommitTrans()

            Return gPMConstants.PMEReturnCode.PMTrue

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CreateParentPlan Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="CreateParentPlan", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            'rollback the changes
            m_oDatabase.SQLRollbackTrans()

            Return result

        End Try
    End Function

    '*************************************************************************
    ' Name:         ProcessMTA
    ' Description:  Processes an MTA on the plan passed in
    ' History:      01/10/2001 DD - Created.
    '               Thinh Nguyen 21/02/2002 add insurance file cnt for mta version
    '               TR131202 - TS23 changed
    '*************************************************************************
    Public Function ProcessMTA(ByRef r_vPremiumFinance(,) As Object, ByVal v_vTransArray(,) As Object) As Integer
        Return ProcessMTA(r_vPremiumFinance:=r_vPremiumFinance, v_vTransArray:=v_vTransArray, v_lInsuranceFileCnt:=0)
    End Function

    Public Function ProcessMTA(ByRef r_vPremiumFinance(,) As Object, ByVal v_vTransArray(,) As Object, ByVal v_lInsuranceFileCnt As Integer) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "ProcessMTA"

        Dim oACTInstalments As New bACTInstalments.Business
        Dim oPFExport As Object = Nothing
        Dim cTransAmount As Decimal
        Dim vOriginalPlan As Object = Nothing
        Dim vOrionTransactions As Object = Nothing
        Dim vInstalmentsArray As Object = Nothing
        Dim vSchemeArray(,) As Object = Nothing
        Dim vTransArray(,) As Object = Nothing
        Dim lNewVersion As Object = Nothing
        Dim lLeadAgentCnt, lClientCnt, lNewPlanTransID, lInstalmentsToGo, lInstalmentsprocessed, lPremiumFinanceCnt, lPremiumFinanceVersion, lSchemeNo, lSchemeVer, lCompanyNo As Integer
        Dim cPlanOs As Decimal

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Initalise important variables

            lPremiumFinanceCnt = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0))

            lPremiumFinanceVersion = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))

            lSchemeNo = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeNo, 0))

            lSchemeVer = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeVersion, 0))

            lCompanyNo = gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanCompanyNo, 0))

            'Make sure there is a valid array of transactions
            If Informations.IsArray(v_vTransArray) Then

                vTransArray = v_vTransArray
            Else
                m_lReturn = GetTransactions(v_lPfPremiumFinanceCnt:=lPremiumFinanceCnt, v_lPFPremiumFinanceVer:=lPremiumFinanceVersion, r_vArrayOfTransactions:=vTransArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetTransactions", "v_lPFPremiumFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            'Make sure that has worked
            If Not Informations.IsArray(vTransArray) Then
                gPMFunctions.RaiseError("Informations.IsArray(vTransArray)", "No transactions to process.", gPMConstants.PMELogLevel.PMLogError)
            End If

            'First check the Transaction total by looping thru all the transactions passed in

            For lCount As Integer = vTransArray.GetLowerBound(1) To vTransArray.GetUpperBound(1)

                cTransAmount += CDec(vTransArray(2, lCount))
            Next

            'Create the instalments object if not already created
            If m_oPFInstalments Is Nothing Then


                m_oPFInstalments = New bSIRPFInstalments.Business
                m_lReturn = m_oPFInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bSIRPFInstalments.Business", gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            'Create an object for Orion


            oACTInstalments = New bACTInstalments.Business
            m_lReturn = oACTInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bACTInstalments.Business", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Create an object for PFExport/Payment Method
            m_lReturn = gPMComponentServices.CreateBusinessObject(r_oObject:=oPFExport, v_sClassName:="bSIRPFExport.Business", v_sCallingAppName:=ACApp, v_sUsername:=m_sUsername, v_sPassword:=m_sPassword, v_iUserID:=m_iUserID, v_iSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_iCurrencyID:=m_iCurrencyID, v_iLogLevel:=m_iLogLevel, v_oDatabase:=m_oDatabase)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bSIRPFExport.Business", gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get the Details of the existing instalments. Only intersted
            'in No. of outstanding and paid, not in Instalments Array

            m_lReturn = m_oPFInstalments.GetDetails(v_vpfprem_finance_cnt:=lPremiumFinanceCnt, v_vpfprem_finance_version:=lPremiumFinanceVersion, r_vDetailsArray:=vInstalmentsArray, r_lInstalmentsToGo:=lInstalmentsToGo, r_lInstalmentsProcessed:=lInstalmentsprocessed, r_vFilter:=0)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oPFInstalments.GetDetails", "v_vpfprem_finance_cnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get the outstanding amount due

            m_lReturn = oACTInstalments.GetPlanOS(v_lPlanTransDetailID:=r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0), r_cOS:=cPlanOs)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                gPMFunctions.RaiseError("oACTInstalments.GetPlanOS", "v_lPlanTransDetailID:=" & gPMFunctions.ToSafeInteger(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)), gPMConstants.PMELogLevel.PMLogError)
            End If

            If (cTransAmount + cPlanOs) <= 0 Then
                result = 998
                Return result
            End If

            'Make a copy of the original plan for later

            vOriginalPlan = (r_vPremiumFinance).Clone()

            'Recalculate for the MTA amount

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0) = "MTA"

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0) = cTransAmount

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanNoOfInstalments, 0) = lInstalmentsToGo - lInstalmentsprocessed

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0) = vTransArray.GetValue(0, 0)

            If lInstalmentsToGo < MinMTAInstalments Then
                'too few instalments left
                result = 99
                Return result
            End If

            If cTransAmount < MinMTA Then
                'MTA not enough
                result = 9
                Return result
            End If

            'Update the new version with the new figures

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanAmountToFinance, 0))

            'Have we paid any instalments?
            If lInstalmentsprocessed > 0 Then

                r_vPremiumFinance(bSIRPremFinConst.k_PFPlanFirstInstalment, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanFirstInstalment, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanOtherInstalments, 0))
            Else

                r_vPremiumFinance(bSIRPremFinConst.k_PFPlanFirstInstalment, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanFirstInstalment, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanFirstInstalment, 0))
            End If

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanOtherInstalments, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanOtherInstalments, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanOtherInstalments, 0))

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanCostOfProtection, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanCostOfProtection, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanCostOfProtection, 0))

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTotalCost, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTotalCost, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanTotalCost, 0))

            r_vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0) = CDec(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0)) + CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanDeposit, 0))

            ' Get the PFScheme for this PremiumFinance
            m_lReturn = GetSingleScheme(v_lCompanyNo:=lCompanyNo, v_lSchemeNo:=lSchemeNo, v_lSchemeVersion:=lSchemeVer, r_vArrayOfScheme:=vSchemeArray)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetSingleScheme", "v_lSchemeNo:=" & lSchemeNo, gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get the Bank Code for this PFScheme

            oACTInstalments.BankCode = vSchemeArray(36, 0)

            'Reverse what is left on instalments and repost with new amount

            ReDim vOrionTransactions(vTransArray.GetUpperBound(1))

            For lCount As Integer = vTransArray.GetLowerBound(1) To vTransArray.GetUpperBound(1)

                vOrionTransactions(lCount) = gPMFunctions.ToSafeString(vTransArray(0, lCount)) & "|" & gPMFunctions.ToSafeString(vTransArray(2, lCount))
            Next

            m_lReturn = GetAgentAndClient(v_lPremFinanceCnt:=lPremiumFinanceCnt, v_lPremFinanceVersion:=lPremiumFinanceVersion, r_lLeadAgentCnt:=lLeadAgentCnt, r_lClientCnt:=lClientCnt)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetAgentAndClient", "v_lPremFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            m_lReturn = oACTInstalments.PostUWAdjustment(r_lNewPlanTransID:=lNewPlanTransID, v_lPlanTransDetailID:=r_vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0), v_vFinanceTrans:=vOrionTransactions, v_cAdjustment:=cTransAmount, v_cFee:=gPMFunctions.ToSafeDouble(gPMFunctions.ToSafeDouble(r_vPremiumFinance(bSIRPremFinConst.k_PFPlanTotalCost, 0)) - CDec(vOriginalPlan(bSIRPremFinConst.k_PFPlanTotalCost, 0))) - cTransAmount, v_cOSAmount:=cPlanOs, v_lPremiumFinanceCnt:=lPremiumFinanceCnt, v_lPremiumFinanceVersion:=lPremiumFinanceVersion, v_lLeadAgentCnt:=lLeadAgentCnt)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("oACTInstalments.PostUWAdjustment", "v_lPremiumFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If
            Return result

        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)

            ' If you want to rollback a transaction or something, do it here

        Finally

            ' Do any tidy up, e.g. Set x = Nothing here
            If Not (oACTInstalments Is Nothing) Then

                oACTInstalments.Dispose()
                oACTInstalments = Nothing
            End If
            If Not (oPFExport Is Nothing) Then

                oPFExport.Dispose()
                oPFExport = Nothing
            End If

        End Try
        Return result
    End Function

    ' ***************************************************************** '
    ' Name: ProcessPlan
    '
    ' Description:  This method performs actions on a plan. Mode determines
    '               the actions taken:
    '               0 - Print all documents (Plan, DDM and cover letter)
    '               1 - Print only the finance plan
    '               2 - Resend EDI message
    '               3 - Transact New Business/Renewal (also prints all docs)
    '               4 - Transact MTA (prints just plan)
    '               5 - Save to PFInstalments
    '
    ' History:
    '   Peter Finney 13/12/2001 All printing removed
    ' RAW 07/03/2003 : added mode 5 (in-house only)
    ' ***************************************************************** '
    Public Function ProcessPlan(ByVal lMode As Integer, ByVal v_vPremiumFinanceArray As Array, ByVal v_vTransArray(,) As Object) As Integer
        Return ProcessPlan(lMode:=lMode, v_vPremiumFinanceArray:=v_vPremiumFinanceArray, v_vTransArray:=v_vTransArray, lPlanTransDetailID:=0, bDeposit:=False, lDepositTransID:=Nothing, v_iMTAType:=-1, v_lAccountId:=0)
    End Function

    Public Function ProcessPlan(ByVal lMode As Integer, ByVal v_vPremiumFinanceArray As Array, ByVal v_vTransArray(,) As Object, ByVal bDeposit As Boolean) As Integer
        Return ProcessPlan(lMode:=lMode, v_vPremiumFinanceArray:=v_vPremiumFinanceArray, v_vTransArray:=v_vTransArray, lPlanTransDetailID:=0, bDeposit:=bDeposit, lDepositTransID:=Nothing, v_iMTAType:=-1, v_lAccountId:=0)
    End Function

    Public Function ProcessPlan(ByVal lMode As Integer, ByVal v_vPremiumFinanceArray As Array, ByVal v_vTransArray(,) As Object, ByRef v_iMTAType As Integer) As Integer
        Return ProcessPlan(lMode:=lMode, v_vPremiumFinanceArray:=v_vPremiumFinanceArray, v_vTransArray:=v_vTransArray, lPlanTransDetailID:=0, bDeposit:=False, lDepositTransID:=Nothing, v_iMTAType:=v_iMTAType, v_lAccountId:=0)
    End Function

    Public Function ProcessPlan(ByVal lMode As Integer, ByVal v_vPremiumFinanceArray As Array, ByVal v_vTransArray(,) As Object, ByRef v_iMTAType As Integer, ByVal v_lAccountId As Integer) As Integer
        Return ProcessPlan(lMode:=lMode, v_vPremiumFinanceArray:=v_vPremiumFinanceArray, v_vTransArray:=v_vTransArray, lPlanTransDetailID:=0, bDeposit:=False, lDepositTransID:=Nothing, v_iMTAType:=v_iMTAType, v_lAccountId:=v_lAccountId)
    End Function

    Public Function ProcessPlan(ByVal lMode As Integer, ByVal v_vPremiumFinanceArray As Array, ByVal v_vTransArray(,) As Object, ByRef lPlanTransDetailID As Integer, ByVal bDeposit As Boolean, ByRef lDepositTransID As Object, ByRef v_iMTAType As Integer) As Integer
        Return ProcessPlan(lMode:=lMode, v_vPremiumFinanceArray:=v_vPremiumFinanceArray, v_vTransArray:=v_vTransArray, lPlanTransDetailID:=lPlanTransDetailID, bDeposit:=bDeposit, lDepositTransID:=lDepositTransID, v_iMTAType:=v_iMTAType, v_lAccountId:=0)
    End Function

    Public Function ProcessPlan(ByVal lMode As Integer, ByVal v_vPremiumFinanceArray As Array, ByVal v_vTransArray(,) As Object, ByRef lPlanTransDetailID As Integer, ByVal bDeposit As Boolean, ByRef lDepositTransID As Object, ByRef v_iMTAType As Integer, ByVal v_lAccountId As Integer) As Integer

        Dim result As Integer = 0
        Dim vEdiArray As Array
        Dim bInHouse As Boolean

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_iInstalmentsMTAType = v_iMTAType

            ' Check for in-house plan
            'Thinh Nguyen 29/11/2001

            If gPMFunctions.ToSafeDouble(v_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) <> bSIRPremFinConst.PFThirdParty And gPMFunctions.ToSafeDouble(v_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) <> bSIRPremFinConst.PFThirdPartyViaStargate Then

                bInHouse = gPMFunctions.ToSafeDouble(v_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) <> bSIRPremFinConst.PFThirdParty
            End If


            If gPMFunctions.ToSafeString(v_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) = "TP" Then
                bInHouse = False
            End If

            If bInHouse Then
                ' Pass call on
                result = ProcessPlanInHouse(lMode, v_vPremiumFinanceArray, v_vTransArray, lPlanTransDetailID, lDepositTransID, v_lAccountId:=v_lAccountId)
            Else
                Select Case lMode
                    Case 0, 1
                        'Thinh Nguyen 03/12/2001 - printing are now moved to interface

                        ' Re-send EDI Message
                    Case 2
                        m_lReturn = ProduceEDIMessage(v_vPremiumFinanceArray, "Y")
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            Return m_lReturn
                        End If

                        'Transact NewBusiness/Renewal
                    Case 3

                        If gPMFunctions.ToSafeString(v_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanProductClass, 0)).Trim().ToUpper() = "SG" Then
                            If v_iMTAType <> bSIRPremFinConst.m_klInstalmentMTAType_SGNoProcessTransact Then
                                m_lReturn = TransactXML(v_vPremiumFinanceArray, v_vTransArray, v_iMTAType)
                                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                    Return m_lReturn
                                End If
                            End If
                        Else
                            m_lReturn = ProduceEDIMessage(v_vPremiumFinanceArray, "")
                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                Return m_lReturn
                            End If
                        End If

                        m_lReturn = TransactPlanThirdParty(v_vPremiumFinanceArray, v_vTransArray, lDepositTransID)

                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            Return m_lReturn
                        End If

                        'Transact MTA
                    Case 4, 5
                        vEdiArray = v_vPremiumFinanceArray
                        m_lReturn = gPMFunctions.FlipArray(vEdiArray)

                        m_lReturn = ProduceEDIMessage(vEdiArray, "")
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            Return m_lReturn
                        End If

                        m_lReturn = TransactPlanThirdParty(v_vPremiumFinanceArray, v_vTransArray, lDepositTransID)

                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            Return m_lReturn
                        End If

                End Select
            End If

            Return result

        Catch excep As System.Exception



            result = Informations.Err().Number

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="ProcessPlan Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessPlan", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function


    ' ***************************************************************** '
    ' Name: ProcessPlanInHouse
    '
    ' Description:  This method performs actions on a plan. Mode determines
    '               the actions taken:
    '               0 - Print all documents (Plan, DDM and cover letter)
    '               1 - Print only the finance plan
    '               2 - Resend EDI message (Not necessary for in house)
    '               3 - Transact New Business/Renewal (also prints all docs)
    '               4 - Transact MTA (prints just plan)
    '               5 - Save to PFInstalments
    '
    ' History:
    '   PF240901 - Branched to provide seperate processing for in-house plans
    ' RAW 07/03/2003 : added mode 5
    ' sj 25/09/2002 - Add extra parameter vDepositTransID
    ' ***************************************************************** '
    Public Function ProcessPlanInHouse(ByVal lMode As Integer, ByVal vPremiumFinance As Array, ByVal vPremiumFinanceTransactions(,) As Object, ByRef lPlanTransDetailID As Integer) As Integer
        Return ProcessPlanInHouse(lMode:=lMode, vPremiumFinance:=vPremiumFinance, vPremiumFinanceTransactions:=vPremiumFinanceTransactions, lPlanTransDetailID:=lPlanTransDetailID, vDepositTransID:=Nothing, v_lAccountId:=0)
    End Function

    Public Function ProcessPlanInHouse(ByVal lMode As Integer, ByVal vPremiumFinance As Array, ByVal vPremiumFinanceTransactions(,) As Object, ByRef lPlanTransDetailID As Integer, ByRef vDepositTransID As Object) As Integer
        Return ProcessPlanInHouse(lMode:=lMode, vPremiumFinance:=vPremiumFinance, vPremiumFinanceTransactions:=vPremiumFinanceTransactions, lPlanTransDetailID:=lPlanTransDetailID, vDepositTransID:=vDepositTransID, v_lAccountId:=0)
    End Function

    Public Function ProcessPlanInHouse(ByVal lMode As Integer, ByVal vPremiumFinance As Array, ByVal vPremiumFinanceTransactions(,) As Object, ByRef lPlanTransDetailID As Integer, ByVal v_lAccountId As Integer) As Integer
        Return ProcessPlanInHouse(lMode:=lMode, vPremiumFinance:=vPremiumFinance, vPremiumFinanceTransactions:=vPremiumFinanceTransactions, lPlanTransDetailID:=lPlanTransDetailID, vDepositTransID:=Nothing, v_lAccountId:=v_lAccountId)
    End Function

    Public Function ProcessPlanInHouse(ByVal lMode As Integer, ByVal vPremiumFinance As Array, ByVal vPremiumFinanceTransactions(,) As Object, ByRef lPlanTransDetailID As Integer, ByRef vDepositTransID As Object, ByVal v_lAccountId As Integer) As Integer

        Dim result As Integer = 0
        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            Select Case lMode
                Case 0, 1
                    'Thinh Nguyen 03/12/2001 - printing are now moved to interface
                Case 2
                    ' Re-send EDI Message (Not necessary for in-house)

                Case 3, 4
                    'Thinh Nguyen 03/12/2001 - printing are now moved to interface
                    'Transact NewBusiness/Renewal/MTA
                    'sj 25/09/2002 - Add extra parameter vDepositTransID



                    Select Case gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)).Trim()
                        Case "MTA", "M"

                            If m_iInstalmentsMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddToNewPlan Then

                                m_lReturn = TransactPlanInHouse(vPremiumFinance:=vPremiumFinance, vPremiumFinanceTransactions:=vPremiumFinanceTransactions, lPlanTransDetailID:=lPlanTransDetailID, vDepositTransID:=vDepositTransID, v_lAccountId:=v_lAccountId)

                            Else

                                m_lReturn = TransactPlanInHouseForMTA(r_vPremiumFinance:=vPremiumFinance, vPremiumFinanceTransactions:=vPremiumFinanceTransactions, lPlanTransDetailID:=lPlanTransDetailID, vDepositTransID:=vDepositTransID, v_lAccountId:=v_lAccountId)
                            End If

                        Case Else

                            m_lReturn = TransactPlanInHouse(vPremiumFinance:=vPremiumFinance, vPremiumFinanceTransactions:=vPremiumFinanceTransactions, lPlanTransDetailID:=lPlanTransDetailID, vDepositTransID:=vDepositTransID, v_lAccountId:=v_lAccountId)
                    End Select

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return m_lReturn
                    End If

                    ' RAW 07/03/2003 : added mode 5
                Case 5
                    ' RAW 27/03/2003 : removed vPremiumFinanceTransactions argument
                    m_lReturn = SaveInstalments(vPremiumFinance:=vPremiumFinance)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return m_lReturn
                    End If

            End Select

            Return result

        Catch excep As System.Exception



            result = Informations.Err().Number

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="ProcessPlanInHouse Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessPlanInHouse", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function



    ' ***************************************************************** '
    ' Name: TransactPlanThirdParty
    '
    ' Description: Transact a 3rd party finance plan
    '
    ' History:
    '   DD210801 - added check for IsQuote flag
    ' ***************************************************************** '
    Public Function TransactPlanThirdParty(ByVal vPremiumFinance As Array, ByVal vPremiumFinanceTransactions As Object) As Integer
        Return TransactPlanThirdParty(vPremiumFinance:=vPremiumFinance, vPremiumFinanceTransactions:=vPremiumFinanceTransactions, lDepositTransID:=Nothing)
    End Function

    Public Function TransactPlanThirdParty(ByVal vPremiumFinance As Array, ByVal vPremiumFinanceTransactions As Object, ByRef lDepositTransID As Object) As Integer

        Dim result As Integer = 0
        Dim lSalesID, lPremiumFinanceID As Integer

        Dim lPartyCnt, lPremiumFinanceCnt, nPremiumFinanceVer, nLeadAgentCnt, nAgentType As Integer

        Dim iDaysDelay, iInstalments As Integer
        Dim cDeposit As Decimal
        Dim lDepositTrans As Integer
        Dim vValue As Object = Nothing
        Dim iSourceID As Integer
        Dim lTransDetailID As Integer
        Dim sProviderCode As String = ""

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'MKW 141004 PN15800 Get Policy SourceID (to post to) for non-multicompany broking sites
            iSourceID = m_iSourceID

            bPMFunc.getProductOptionValue(v_sUsername:=m_sUsername, v_sPassword:=m_sPassword, v_iUserID:=m_iUserID, v_iMainSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_iCurrencyID:=m_iCurrencyID, v_iLogLevel:=m_iLogLevel, v_sCallingAppName:=m_sCallingAppName, v_vOptionNumber:=gPMConstants.SIRHiddenOptions.SIROPTMultiTreeAccounting, v_vBranch:=m_iSourceID, r_vUnderwriting:=vValue)

            ' Create an instance of the OrionLink business object

            m_oOrionLink = New bSirOrionLink.Form
            m_lReturn = m_oOrionLink.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMError

                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to Initialise the Sirius/Orion Link", vApp:=ACApp, vClass:=ACClass, vMethod:="SendToOrion", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                Return result
            End If


            m_oPremiumFinance = New bACTPremiumFinance.Business
            m_lReturn = m_oPremiumFinance.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDataBaseOrion)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMError

                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to Initialise the orion Premium Finance component", vApp:=ACApp, vClass:=ACClass, vMethod:="SendToOrion", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                Return result
            End If

            lPartyCnt = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanClientId, 0))

            iDaysDelay = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanDaysDelay, 0))

            iInstalments = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanNoOfInstalments, 0))

            cDeposit = CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanDeposit, 0))

            'DD 06/06/2003: Get the AccountID of the main Party
            With m_oDatabase
                .Parameters.Clear()
                'PN6169
                .Parameters.Add("v_iCompanyId", gPMFunctions.ToSafeString(m_iSourceID), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                '
                .Parameters.Add("v_iPartyCnt", gPMFunctions.ToSafeString(lPartyCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                m_lReturn = .SQLSelect(ACGetAccountIDFromPartyCntSQL, ACGetAccountIDFromPartyCntName, ACGetAccountIDFromPartyCntStored)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = gPMConstants.PMEReturnCode.PMError

                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to run " & ACGetAccountIDFromPartyCntName, vApp:=ACApp, vClass:=ACClass, vMethod:="SendToOrion", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    Return result
                End If

                lSalesID = .Records.Item(0).Fields(0)
            End With

            m_lReturn = GetFinanceProviderDetails(v_lCompanyNo:=gPMFunctions.ToSafeLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanCompanyNo, 0)), v_lSchemeNo:=gPMFunctions.ToSafeLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeNo, 0)), v_lSchemeVersion:=gPMFunctions.ToSafeLong(vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeVersion, 0)), r_lPartyCnt:=lPremiumFinanceCnt, r_sShortName:=sProviderCode)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            'DD 06/06/2003: Get the AccountID for the Finance Provider
            With m_oDatabase
                .Parameters.Clear()
                .Parameters.Add("v_iCompanyId", gPMFunctions.ToSafeString(m_iSourceID), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                .Parameters.Add("v_iPartyCnt", gPMFunctions.ToSafeString(lPremiumFinanceCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                m_lReturn = .SQLSelect(ACGetAccountIDFromPartyCntSQL, ACGetAccountIDFromPartyCntName, ACGetAccountIDFromPartyCntStored)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = gPMConstants.PMEReturnCode.PMError

                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to run " & ACGetAccountIDFromPartyCntName, vApp:=ACApp, vClass:=ACClass, vMethod:="SendToOrion", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    Return result
                End If

                If .Records.Count() > 0 Then

                    lPremiumFinanceID = .Records.Item(0).Fields(0)
                Else
                    lPremiumFinanceID = 0
                End If
            End With

            'need to create an account for Premium Finance provider
            If lPremiumFinanceID = 0 Then

                m_lReturn = m_oOrionLink.CreateOrionAccounts(r_lAccountID:=lPremiumFinanceID, v_sLedgerFlag:=gSIRLibrary.SIRACTPremiumFinanceLedgerShortName, v_lPartyCnt:=lPremiumFinanceCnt)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If
                'MKW PN16846 Commit Created Account, otherwise transaction process timesout
                m_lReturn = m_oDatabase.SQLCommitTrans()
                m_lReturn = m_oDatabase.SQLBeginTrans()
            End If

            'MKW120903 PF 3rd Party MTA START
            'If Third Party MTA do not post deposit (as previously already posted).

            If (gPMFunctions.ToSafeDouble(vPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) = bSIRPremFinConst.PFThirdParty) And (gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)) = "M") Then
                cDeposit = 0
            End If
            'MKW120903 PF 3rd Party MTA END

            'ACR 05/06/07 - added to stop a client debit being raised for a provider-collected deposit

            If (sProviderCode = "CLOSEIP") And (gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanProviderCollectDeposit, 0)) = "1") Then
                cDeposit = 0
            End If

            m_oPremiumFinance = New bACTPremiumFinance.Business
            m_lReturn = m_oPremiumFinance.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bACTPremiumFinance.Business", gPMConstants.PMELogLevel.PMLogError)
            End If

            lPremiumFinanceCnt = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0))
            nPremiumFinanceVer = gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            'Need Agent type to support Instalments for Broker Agents
            m_lReturn = GetAgentAndType(v_lPremFinanceCnt:=lPremiumFinanceCnt, v_lPremFinanceVersion:=nPremiumFinanceVer, r_lLeadAgentCnt:=nLeadAgentCnt, r_lAgentType:=nAgentType)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetAgentAndType", "v_lPremFinanceCnt:=" & lPremiumFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            m_lReturn = m_oPremiumFinance.TransactPremiumFinance(v_lClientAccount:=lSalesID, v_lPremFinanceAccount:=lPremiumFinanceID, v_cFinanceAmount:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)), v_vTransactionIDs:=vPremiumFinanceTransactions, v_iCompanyID:=iSourceID, v_iDaysDelay:=iDaysDelay, v_iInstallments:=iInstalments, v_cDeposit:=cDeposit, v_lDepositTransId:=lDepositTrans, v_vInterestCost:=CDec(vPremiumFinance(bSIRPremFinConst.k_PFPlanInterestCost, 0)), v_sPlanReference:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0)).Trim(), r_lProviderTransDetailID:=lTransDetailID, v_lAgentCnt:=nLeadAgentCnt, v_lAgentType:=nAgentType, v_sPlanTransType:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanTransactionType, 0)).Trim())

            'Store the Finance Provider transaction in the plan

            vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0) = lTransDetailID

            vPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0) = bSIRPremFinConst.PFStatusIndLive

            m_lReturn = UpdateExistingRecord(vPremiumFinance, vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0), vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))

            Return m_lReturn

        Catch excep As System.Exception

            result = Informations.Err().Number

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="TransactPlanThirdParty Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="TransactPlanThirdParty", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

