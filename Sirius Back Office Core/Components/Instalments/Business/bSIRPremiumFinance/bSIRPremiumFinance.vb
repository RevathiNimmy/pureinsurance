            gPMFunctions.RaiseError("m_oDatabase.SQLSelect", "sSQL:=ACGetExisitingPlanDetailsSQL", PMELogLevel.PMLogError)
        End If

        If Not Informations.IsArray(vExistingPlanDetails) Then
            gPMFunctions.RaiseError("Informations.IsArray(vExistingPlanDetails)", "No Existing Details Found.", PMELogLevel.PMLogError)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(0, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankName, 0) = vExistingPlanDetails(0, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(1, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankSortCode, 0) = vExistingPlanDetails(1, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(2, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankAccountNo, 0) = vExistingPlanDetails(2, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(3, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankBranch, 0) = vExistingPlanDetails(3, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(4, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankAddress1, 0) = vExistingPlanDetails(4, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(5, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankAddress2, 0) = vExistingPlanDetails(5, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(6, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankAddress3, 0) = vExistingPlanDetails(6, 0)
        End If
        'Field BankRegion in the DB goes into Address4 as InsertSupercedingPlan puts
        'the contents of Address4 into BankRegion (there is no Address4 in the DB)
        If gPMFunctions.NullToString(vExistingPlanDetails(7, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankAddress4, 0) = vExistingPlanDetails(7, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(8, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankTown, 0) = vExistingPlanDetails(8, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(9, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankPostcode, 0) = vExistingPlanDetails(9, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(10, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankCountry, 0) = vExistingPlanDetails(10, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(11, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankAreaCode, 0) = vExistingPlanDetails(11, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(12, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankPhone, 0) = vExistingPlanDetails(12, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(13, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankExtn, 0) = vExistingPlanDetails(13, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(14, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankFaxCode, 0) = vExistingPlanDetails(14, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(15, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankFax, 0) = vExistingPlanDetails(15, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(16, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankAccountName, 0) = vExistingPlanDetails(16, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(17, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanCCNumber, 0) = vExistingPlanDetails(17, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(18, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanCCExpiryDate, 0) = vExistingPlanDetails(18, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(19, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanCCStartDate, 0) = vExistingPlanDetails(19, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(20, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanCCIssue, 0) = vExistingPlanDetails(20, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(21, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanCCPin, 0) = vExistingPlanDetails(21, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(22, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanClientCountry_ID, 0) = vExistingPlanDetails(22, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(23, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanBankCountry_ID, 0) = vExistingPlanDetails(23, 0)
        End If
        If gPMFunctions.NullToString(vExistingPlanDetails(29, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanPartyBankIdSel, 0) = vExistingPlanDetails(29, 0)
        End If
        If m_bIsSingleInstalmentPlan Then
            If ToSafeDouble(gPMFunctions.ToSafeString(gPMFunctions.NullToDouble(vExistingPlanDetails(30, 0))).Trim()) <> 0 Then
                r_vPlanArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0) = gPMFunctions.ToSafeDouble(r_vPlanArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)) + gPMFunctions.ToSafeDouble(vExistingPlanDetails(30, 0))
            End If
        Else
            'Check if any additionally transaction is being added then add existing finance amount witn new one to update both Finance Amount column.
            If bAddExistingFinaceAMT Then
                If ToSafeDouble(gPMFunctions.ToSafeString(gPMFunctions.NullToDouble(vExistingPlanDetails.GetValue(30, 0))).Trim()) <> 0 Then
                    r_vPlanArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0) = gPMFunctions.ToSafeDouble(r_vPlanArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)) + gPMFunctions.ToSafeDouble(vExistingPlanDetails.GetValue(30, 0))
                End If
            End If
        End If
        'When adding a superceding plan, if the original plan was for a different policy then this one is now a multi policy plan.
        If m_sUnderwriting.ToUpper() = "A" Then
            If gPMFunctions.ToSafeLong(vExistingPlanDetails(24, 0), 0) <> m_lInsuranceFileCnt Then
                m_lInsuranceFileCnt = 0

                r_vPlanArray(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0) = 0
            End If
        End If

        'When adding a superceding plan, if the original plan was multi policy then so is this one.
        If gPMFunctions.ToSafeLong(vExistingPlanDetails(24, 0), 0) = 0 Then
            m_lInsuranceFileCnt = 0

            r_vPlanArray(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0) = 0
        End If

        r_vPlanArray(bSIRPremFinConst.k_PFPlanSource_ID, 0) = gPMFunctions.ToSafeLong(vExistingPlanDetails(25, 0), 0)

        r_vPlanArray(bSIRPremFinConst.k_PFPlanSubBranchID, 0) = gPMFunctions.ToSafeLong(vExistingPlanDetails(26, 0), 0)

        r_vPlanArray(bSIRPremFinConst.k_PFPlanBatchID, 0) = gPMFunctions.ToSafeLong(vExistingPlanDetails(27, 0), 0) '(RC) PLICO 9-10

        If gPMFunctions.NullToString(vExistingPlanDetails(28, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(28, 0)).Trim()
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(31, 0)).Trim() <> "" Then
            r_vPlanArray(bSIRPremFinConst.kBIC, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(31, 0)).Trim()
        End If
        'Copy the Exiting AuthCode as behaving the other values of the PFPlan.
        If gPMFunctions.NullToString(vExistingPlanDetails(31, 0)).Trim() <> "" Then
            r_vPlanArray(bSIRPremFinConst.k_PFPlanAuthCode, 0) = vExistingPlanDetails(31, 0)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(32, 0)).Trim() <> "" Then
            r_vPlanArray(bSIRPremFinConst.kIBAN, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(32, 0), 0)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(33, 0)).Trim() <> "" Then
            r_vPlanArray(bSIRPremFinConst.k_PFPlanCardType, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(33, 0)).Trim()
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(34, 0)).Trim() <> "" Then
            r_vPlanArray(bSIRPremFinConst.k_PfPlanCardholderName, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(34, 0)).Trim()
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(35, 0)).Trim() <> "" Then
            r_vPlanArray(bSIRPremFinConst.k_PFPlanIsCardholder, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(35, 0), 0)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(36, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PfPlanCardholderAddress1, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(36, 0), 0)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(37, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PfPlanCardholderAddress2, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(37, 0), 0)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(38, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PfPlanCardholderAddress3, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(38, 0), 0)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(39, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PfPlanCardholderAddress4, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(39, 0), 0)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(40, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PfPlanCardholderPostcode, 0) = gPMFunctions.ToSafeString(vExistingPlanDetails(40, 0), 0)
        End If

        If gPMFunctions.NullToString(vExistingPlanDetails(41, 0)).Trim() <> "" Then

            r_vPlanArray(bSIRPremFinConst.k_PfPlanCardholderCountryID, 0) = gPMFunctions.ToSafeInteger(vExistingPlanDetails(41, 0), 0)
        End If


        Return nResult
    End Function
    '==============
    'PUBLIC METHODS
    '==============
    '*************************************************************************
    ' Name:         Calculate_Quotes
    ' Description:  Loops through all the Instalment schemes available to a
    '               Source/ProductCode/Date combination, and calculates Quotes
    '               for each.
    ' History:      TR071102 - Created as per TS23 Section 4.2.1
    ' RAM20030403   : 1. Code changes for Issue 2915
    '                 2. Added the v_vUseExistingPaymentDetails Parameter
    'PN11684 Added optional In house parameter
    'PN12144 Added option Override Deposit
    '*************************************************************************
    ' Gaurav

    Public Function Calculate_Quotes(ByVal v_lSourceID As Integer,
                                     ByVal v_sProductCode As String,
                                     ByVal v_dtQuoteDate As Date,
                                     ByVal v_dtStartDate As Date,
                                     ByVal v_dtEndDate As Date,
                                     ByVal v_dtPreferredDate As Date,
                                     ByVal v_iDayInMonth As Integer,
                                     ByVal v_iDayInWeek As Integer,
                                     ByVal v_crAmountToFinance As Decimal,
                                     ByVal v_bPaymentProtection As Boolean,
                                     ByVal v_dInterestOverrideRate As Double,
                                     ByVal v_bOverrideCommission As Boolean,
                                     ByVal v_lPartyCnt As Integer,
                                     ByRef r_vQuoteArray As Object, Optional ByVal v_lProductID As Integer = 0,
                                     Optional ByRef r_lPremFinanceCnt As Integer = 0, Optional ByRef r_lPremFinanceVer As Integer = 0,
                                     Optional ByVal v_iMTAType As Integer = bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread,
                                     Optional ByVal v_vPFTransArray As Object = Nothing, Optional ByVal v_lInsuranceFileCnt As Integer = 0,
                                     Optional ByVal v_lBackDatedMTAType As Integer = 0, Optional ByVal v_lRenewalInsFileCnt As Integer = 0, Optional ByVal v_vUseExistingPaymentDetails As Object = Nothing, Optional ByVal v_bInHouse As Boolean = False,
                                     Optional ByVal v_dOverrideDeposit As Double = -1, Optional ByVal v_bIsProductChangedAtREN As Boolean = False,
                                     Optional ByRef r_sSchemeName As String = "", Optional ByRef r_sTransType As String = "",
                                     Optional ByVal bDayOfMonthIsValid As Boolean = False, Optional ByVal bIsCallingFromSAM As Boolean = False) As Integer

        Dim nResult As Integer = 0
        Const kMethodName As String = "Calculate_Quotes"

        Dim nOriginalSchemeId As Integer
        Dim nFrequencyID As Integer
        Dim nOriginalNumberOfInstalmentsRemaining As Integer
        Dim nMediaTypeID As Integer
        Dim dtRenewalLastInstalmentDate As Date
        'Dim nRenewalAmount As Integer
        Dim nFrequencyAmount As Integer
        Dim oPFPremiumFinance As Object = Nothing
        Dim oArrayOfPFRFs As Object = Nothing
        Dim oSinglePlanParty As Object = Nothing
        'Dim bIsSinglePlanParty As Boolean

        Try
            nResult = gPMConstants.PMEReturnCode.PMTrue

            'Save the passed in values locally
            m_lSourceID = v_lSourceID
            m_sProductCode = v_sProductCode
            m_dtQuoteDate = v_dtQuoteDate
            m_dtStartDate = v_dtStartDate
            m_dtEndDate = v_dtEndDate
            m_dtPreferredDate = v_dtPreferredDate
            m_iDayInMonth = v_iDayInMonth
            m_iDayOfWeek = v_iDayInWeek
            m_crChangeToFinanceAmount = v_crAmountToFinance
            m_bPaymentProtection = v_bPaymentProtection
            m_dInterestOverrideRate = v_dInterestOverrideRate
            m_bOverrideCommission = v_bOverrideCommission
            m_lPartyCnt = v_lPartyCnt
            m_lProductID = v_lProductID
            m_lPremFinanceCnt = r_lPremFinanceCnt
            m_lPremFinanceVer = r_lPremFinanceVer
            m_iMTAType = v_iMTAType
            m_lInsuranceFileCnt = v_lInsuranceFileCnt
            m_lBackDatedMTAType = v_lBackDatedMTAType
            m_dOverrideDeposit = v_dOverrideDeposit

            'If renewal or MTA, we need the renewed policy cnt as well as the old policy cnt
            If m_sProductCode = "REN" OrElse m_sProductCode = "MTA" Then

                'Save the InsuranceFileCnt passed in as that of the ORIGINAL policy
                m_lOriginalInsuranceFileCnt = m_lInsuranceFileCnt

                ' Get the cnt of the renewed policy
                If v_lRenewalInsFileCnt <> 0 Then
                    m_lInsuranceFileCnt = v_lRenewalInsFileCnt
                End If

            End If

            'Get the finance plan here if we have the plan id.
            If m_lPremFinanceCnt > 0 Then

                m_lReturn = GetSingleFinancePlan(v_lFinanceCount:=m_lPremFinanceCnt,
                                                 v_lFinanceVersion:=m_lPremFinanceVer,
                                                 r_vPFPremiumFinance:=oPFPremiumFinance)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetSingleFinancePlan", "v_lFinanceCount:=" & m_lPremFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                End If
            End If

            'Get all data we need to work out
            ' Gaurav

            m_lReturn = GetMissingQuoteData(v_vPFTransArray:=v_vPFTransArray, r_vPFPremiumFinance:=oPFPremiumFinance, bDayOfMonthIsValid:=bDayOfMonthIsValid)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetMissingQuoteData", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If
            If Informations.IsArray(oPFPremiumFinance) Then
                r_sSchemeName = ToSafeString(oPFPremiumFinance(5, 0))
                r_sTransType = ToSafeString(oPFPremiumFinance(10, 0))
                m_sRenewalFrequencyInterval = ToSafeString(oPFPremiumFinance(107, 0))
                m_lFrequencyAmount = ToSafeInteger(oPFPremiumFinance(108, 0))
                nMediaTypeID = ToSafeInteger(oPFPremiumFinance(87, 0))
            End If

            If m_iDayInMonth = 0 Then
                m_iDayInMonth = 1
            End If

            m_vTransArray = v_vPFTransArray
            '
            'Dates need to be included to calculate the quote
            If (m_dtStartDate = CDate("00:00:00") OrElse m_dtEndDate = CDate("00:00:00")) AndAlso m_lInsuranceFileCnt > 0 Then
                gPMFunctions.RaiseError("m_dtStartDate = 00:00:00 Or m_dtEndDate = 00:00:00", "No dates", gPMConstants.PMELogLevel.PMLogError)
            End If

            If m_sProductCode <> "REN" Then
                If IsSinglePlanParty(v_lPartyCnt:=m_lInsuranceFileCnt, r_vSinglePlanParty:=oSinglePlanParty) <> gPMConstants.PMEReturnCode.PMTrue Then
                End If

                If Informations.IsArray(oSinglePlanParty) Then
                    If gPMFunctions.ToSafeBoolean(oSinglePlanParty(0, 0)) Then
                        m_bIsSinglePlanParty = True
                    End If
                    If gPMFunctions.ToSafeInteger(oSinglePlanParty(0, 1)) Then
                        m_lOriginalInsuranceFileCnt = oSinglePlanParty(0, 1)
                    End If
                End If
                If m_bIsSinglePlanParty Then
                    m_sProductCode = "MTA"
                    m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread
                    '        If m_lPremFinanceCnt > 0 Then
                    '            vPFPremiumFinance(k_PFPlanEndDate, 0) = m_dtEndDate
                    '        End If
                End If
            End If
            If m_sProductCode.ToUpper() = "MTR" Then
                m_sProductCode = "NB"
                m_bCallFromCM = False
            End If
            Select Case m_sProductCode.ToUpper()
                Case "NB", "SR", "TPR"

                    'Get all the PFRFs valid for this Quote date and Product Type
                    m_lReturn = GetAllPFRFs(oArrayOfPFRFs)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("GetAllPFRFs", "Failed", gPMConstants.PMELogLevel.PMLogError)
                    End If

                    If Informations.IsArray(oArrayOfPFRFs) Then

                        'Get the Quotes for all these PFRFs
                        m_lReturn = CalculateEachQuote(v_vPFPremiumFinance:=oPFPremiumFinance, v_vArrayOfValidPFRFs:=oArrayOfPFRFs,
                                                       r_vQuoteArray:=r_vQuoteArray, v_vUseExistingPaymentDetails:=v_vUseExistingPaymentDetails,
                                                       v_bInHouse:=v_bInHouse)
                        If m_lReturn = gPMConstants.PMEReturnCode.PMError AndAlso m_sErrorText <> "" Then
                            m_lReturn = gPMConstants.PMEReturnCode.PMTrue
                        End If
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                            gPMFunctions.RaiseError("CalculateEachQuote", "v_vPFPremiumFinance:=" & gPMFunctions.ToSafeString(oPFPremiumFinance), gPMConstants.PMELogLevel.PMLogError)
                        End If
                        'Start Girija --- PN 55032
                    End If
                    'End Girija --- PN 55032
                    'If this has worked, re-order the array so that the items are in frequency Order
                    If m_lReturn = gPMConstants.PMEReturnCode.PMTrue AndAlso Informations.IsArray(r_vQuoteArray) Then
                        m_lReturn = gPMFunctions.ShellSort2DArray(r_vQuoteArray, k_PFQuoteProductClass, "DESCENDING")
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            gPMFunctions.RaiseError("ShellSort2DArray", "Failed", gPMConstants.PMELogLevel.PMLogError)
                        End If
                    End If

                Case "MTA"

                    Select Case m_iMTAType
                        Case bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread, bSIRPremFinConst.m_klInstalmentMTAType_AddToNext
                            'Make sure there is a Plan loaded
                            If Not Informations.IsArray(oPFPremiumFinance) Then
                                'Get the Premium Finance Plan for the Original Policy to determine the user's preferred mediatype, frequency etc.

                                m_lReturn = GetLatestValidFinancePlan2(v_lInsuranceFileCnt:=m_lOriginalInsuranceFileCnt, r_vPFPremiumFinance:=oPFPremiumFinance, v_sBusinessType:="MTA")
                                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue And m_lReturn <> gPMConstants.PMEReturnCode.PMNotFound Then
                                    gPMFunctions.RaiseError("GetLatestValidFinancePlan2", "v_lInsuranceFileCnt:=" & m_lOriginalInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                                End If
                                m_lReturn = GetLatestValidFinancePlan(nInsuranceFileCnt:=m_lOriginalInsuranceFileCnt,
                                                                      r_oPFPremiumFinance:=oPFPremiumFinance,
                                                                      sBusinessType:="MTA")
                                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue AndAlso
                                    m_lReturn <> gPMConstants.PMEReturnCode.PMNotFound Then
                                    gPMFunctions.RaiseError("GetSingleFinancePlanFromInsFileCnt", "v_lInsuranceFileCnt:=" & m_lOriginalInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                                End If

                                'Store Premium Finance cnt and ver
                                If Informations.IsArray(oPFPremiumFinance) Then
                                    m_lPremFinanceCnt = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0))
                                    m_lPremFinanceVer = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))
                                End If

                            End If

                            If Informations.IsArray(oPFPremiumFinance) Then

                                nOriginalSchemeId = gPMFunctions.ToSafeInteger(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeNo, 0))

                                nFrequencyID = gPMFunctions.ToSafeInteger(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanPfFrequency_ID, 0))

                                nMediaTypeID = gPMFunctions.ToSafeInteger(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanMediaType_ID, 0))
                            End If

                            m_lReturn = GetSinglePFRFForMTA(v_lOriginalSchemeId:=nOriginalSchemeId, v_lFrequencyID:=nFrequencyID, v_lMediaTypeId:=nMediaTypeID, r_vPFRFArray:=oArrayOfPFRFs)

                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue And m_lReturn <> gPMConstants.PMEReturnCode.PMNotFound Then
                                Return m_lReturn
                            End If

                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                gPMFunctions.RaiseError("GetSinglePFRFForMTA", "v_lOriginalSchemeId:=" & nOriginalSchemeId, gPMConstants.PMELogLevel.PMLogError)
                            End If

                            'We need to get the remaining number of instalments on the original plan
                            If Informations.IsArray(oPFPremiumFinance) Then
                                m_lReturn = GetInstalmentsRemaining(v_lpfprem_finance_cnt:=gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), v_lpfprem_finance_version:=gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)), r_lNoInstalments:=nOriginalNumberOfInstalmentsRemaining)
                                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                    gPMFunctions.RaiseError("GetInstalmentsRemaining", "v_lpfprem_finance_cnt:=" & gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), gPMConstants.PMELogLevel.PMLogError)
                                End If

                                If nOriginalNumberOfInstalmentsRemaining = 0 Then
                                    r_vQuoteArray = Nothing
                                    'GoTo Finally_Renamed
                                    'gPMFunctions.RaiseError("lOriginalNumberOfInstalmentsRemaining = 0", "No instalments remaining", gPMConstants.PMELogLevel.PMLogError)
                                End If

                                'Get some info from previous Plan
                                m_sRenewalFrequencyInterval = gPMFunctions.NullToString(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0)).ToLower()
                                nMediaTypeID = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanMediaType_ID, 0))
                                m_lFrequencyAmount = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyAmount, 0))
                                m_sSchemeName = gPMFunctions.NullToString(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeName, 0))

                                'Perform the calcs on the array

                                m_lReturn = CalculateMTAExtraQuote(v_vExistingPlan:=oPFPremiumFinance,
                                                                   v_vSinglePFRF:=oArrayOfPFRFs,
                                                                   r_vQuoteArray:=r_vQuoteArray,
                                                                   v_lMediaTypeId:=nMediaTypeID,
                                                                       v_bInHouse:=v_bInHouse,
                                                                   bIsCallingFromSAM:=bIsCallingFromSAM)

                                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                    gPMFunctions.RaiseError("CalculateMTAExtraQuote", "Failed", gPMConstants.PMELogLevel.PMLogError)
                                End If
                            End If
                        Case bSIRPremFinConst.m_klInstalmentMTAType_AddToNewPlan, bSIRPremFinConst.m_klInstalmentMTAType_NoAmountChange
                            'Get all the PFRFs valid for this Quote date and Product Type

                            m_lReturn = GetAllPFRFs(oArrayOfPFRFs)
                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                gPMFunctions.RaiseError("GetAllPFRFs", "Failed", gPMConstants.PMELogLevel.PMLogError)
                            End If

                            'Get some info from previous Plan
                            If Informations.IsArray(oPFPremiumFinance) Then
                                m_sRenewalFrequencyInterval = gPMFunctions.NullToString(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0)).ToLower()
                                nMediaTypeID = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanMediaType_ID, 0))
                                m_lFrequencyAmount = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyAmount, 0))
                                m_sSchemeName = gPMFunctions.NullToString(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeName, 0))
                            End If

                            'Perform the calcs on the array

                            m_lReturn = CalculateEachQuote(v_vPFPremiumFinance:=oPFPremiumFinance, v_vArrayOfValidPFRFs:=oArrayOfPFRFs, r_vQuoteArray:=r_vQuoteArray, v_bEnforcePreferredDate:=Informations.IsDate(gPMFunctions.ToSafeDate(v_dtPreferredDate)), v_bFindHighlightedCell:=True, v_lMediaTypeId:=nMediaTypeID, v_bInHouse:=v_bInHouse, bIsCallingFromSAM:=bIsCallingFromSAM)
                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                                gPMFunctions.RaiseError("CalculateEachQuote", "v_vPFPremiumFinance:=" & gPMFunctions.ToSafeString(oPFPremiumFinance), gPMConstants.PMELogLevel.PMLogError)
                            End If

                            'If this has worked, re-order the array so that the items are in frequency Order
                            If Informations.IsArray(r_vQuoteArray) Then
                                m_lReturn = gPMFunctions.ShellSort2DArray(r_vQuoteArray, k_PFQuoteFrequencyPerYear, "DESCENDING")
                                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                    gPMFunctions.RaiseError("ShellSort2DArray", "Failed", gPMConstants.PMELogLevel.PMLogError)
                                End If
                            End If

                    End Select

                Case "REN"

                    If m_lOriginalInsuranceFileCnt <> m_lInsuranceFileCnt Then
                        'Get the Premium Finance Plan for the Original Policy to determine the user's preferred mediatype, frequency etc.
                        If m_bUsePriorTermSchemeAtRenewal Then
                            m_lReturn = GetSingleFinancePlanFromInsFileCnt(m_lOriginalInsuranceFileCnt, oPFPremiumFinance)
                        Else
                            If m_lOriginalInsuranceFileCnt = 0 Then
                                If m_lPremFinanceCnt = 0 Then
                                    m_lReturn = GetSingleFinancePlanFromInsFileCnt(m_lInsuranceFileCnt, oPFPremiumFinance)
                                End If
                            Else
                                m_lReturn = GetLatestValidFinancePlan(v_lInsuranceFileCnt:=m_lOriginalInsuranceFileCnt, r_vPFPremiumFinance:=oPFPremiumFinance, sBusinessType:="REN")
                                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue And m_lReturn <> gPMConstants.PMEReturnCode.PMNotFound Then
                                    gPMFunctions.RaiseError("GetLatestValidFinancePlan", "v_lInsuranceFileCnt:=" & m_lOriginalInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                                End If
                            End If
                        End If

                        'Store Premium Finance cnt and ver
                        If Informations.IsArray(oPFPremiumFinance) Then
                            m_lPremFinanceCnt = gPMFunctions.NullToLong(oPFPremiumFinance.GetValue(bSIRPremFinConst.k_PFPlanPFCnt, 0))
                            m_lPremFinanceVer = gPMFunctions.NullToLong(oPFPremiumFinance.GetValue(bSIRPremFinConst.k_PFPlanPFVersion, 0))
                        End If

                        'If no Plan exists then just quote. The Renewal may be the first Policy in the system for this client
                        If m_lReturn = gPMConstants.PMEReturnCode.PMTrue And m_lOriginalInsuranceFileCnt > 0 Then
                            'Get some info from previous Plan
                            'Start Renuka PN 61715
                            m_lCompanyNo = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanCompanyNo, 0))
                            m_lSchemeNo = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeNo, 0))
                            m_lSchemeVer = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeVersion, 0))
                            'End Renuka PN 61715
                            m_sSchemeName = (oPFPremiumFinance(bSIRPremFinConst.k_PFPlanSchemeName, 0))
                            m_iDayOfWeekOrMonth = gPMFunctions.NullToInteger(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0))
                            m_bPaymentProtection = gPMFunctions.NullToDecimal(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanCostOfProtection, 0)) > 0
                            m_lFrequencyAmount = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyAmount, 0))
                            dtRenewalLastInstalmentDate = gPMFunctions.NullToDate(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanLastInstalmentdate, 0))
                            nMediaTypeID = gPMFunctions.NullToLong(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanMediaType_ID, 0))
                            m_sRenewalFrequencyInterval = gPMFunctions.NullToString(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0)).ToLower()
                            nFrequencyAmount = gPMFunctions.NullToInteger(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanFrequencyAmount, 0))

                            nFrequencyID = gPMFunctions.ToSafeInteger(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanPfFrequency_ID, 0))

                            If m_sRenewalFrequencyInterval = "m" Then
                                m_sVBFrequencyInterval = "m"
                            ElseIf m_sRenewalFrequencyInterval = "w" Then
                                m_sVBFrequencyInterval = "ww"
                            Else
                                gPMFunctions.RaiseError("m_sRenewalFrequencyInterval", "Renewal Frequency Is Invalid", gPMConstants.PMELogLevel.PMLogError)
                            End If

                            'Only if not previously set
                            If gPMFunctions.NullToInteger(m_iDayOfWeekOrMonth) < 1 Then
                                If m_sRenewalFrequencyInterval = "m" Then
                                    'Find out what day of the month the EndDate falls on
                                    m_iDayOfWeekOrMonth = Informations.DatePart("d", dtRenewalLastInstalmentDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1)
                                ElseIf m_sRenewalFrequencyInterval = "w" Then
                                    'Find out what day of the week the EndDate falls on
                                    m_iDayOfWeekOrMonth = Informations.Weekday(dtRenewalLastInstalmentDate, DayOfWeek.Monday)
                                End If
                            End If

                            Dim nLastDayOfMonth As Integer = 31
                            ' Need to pull 1 day back. If Preferred day is last day of Month and r_dtOutputDate.day <> Preferred day 
                            If m_iDayOfWeekOrMonth = nLastDayOfMonth AndAlso
                                        dtRenewalLastInstalmentDate.Day <> m_iDayOfWeekOrMonth AndAlso
                                        Business.AlignPremiumToOptions.AlignWithClientPreference Then

                                dtRenewalLastInstalmentDate = dtRenewalLastInstalmentDate.AddDays(-1)
                            End If

                            'Get the First Instalment date for this plan
                            m_lReturn = CalculateNextOrPrevInstalment(v_dtInputDate:=dtRenewalLastInstalmentDate, v_iFrequencyAmount:=nFrequencyAmount, v_enWhichDirection:=WhichDirection.MovingForwards, r_dtOutputDate:=m_dtPreferredDate)
                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                                gPMFunctions.RaiseError("CalculateNextOrPrevInstalment", "v_dtInputDate:=" & dtRenewalLastInstalmentDate, gPMConstants.PMELogLevel.PMLogError)
                            End If

                            m_dtLastInstalmentDate = dtRenewalLastInstalmentDate
                        End If
                    Else
                        If Informations.IsArray(oPFPremiumFinance) AndAlso CDate(m_dtPreferredDate) = Date.MinValue Then
                            m_dtPreferredDate = gPMFunctions.NullToDate(oPFPremiumFinance(bSIRPremFinConst.k_PFPlanFirstInstalmentdate, 0))
                        End If
                    End If

                    '1.12 Wr25 (Get valid PFRFS based on mediatype and frequency)
                    If v_bIsProductChangedAtREN Then

                        m_lReturn = GetAllPFRFs(oArrayOfPFRFs, nFrequencyID, nMediaTypeID, v_bIsProductChangedAtREN)
                    Else
                        'Get all the PFRFs valid for this Quote date and Product Type

                        m_lReturn = GetAllPFRFs(oArrayOfPFRFs)
                    End If

                    'Start - Sankar - PN 56780

                    If Informations.IsArray(oArrayOfPFRFs) Then

                        m_lReturn = CalculateEachQuote(v_vPFPremiumFinance:=oPFPremiumFinance, v_vArrayOfValidPFRFs:=oArrayOfPFRFs, r_vQuoteArray:=r_vQuoteArray, v_bEnforcePreferredDate:=True, v_bFindHighlightedCell:=True, v_lMediaTypeId:=nMediaTypeID, v_bInHouse:=v_bInHouse, bIsCallingFromSAM:=bIsCallingFromSAM)
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                            gPMFunctions.RaiseError("CalculateEachQuote", "v_vPFPremiumFinance:=" & gPMFunctions.ToSafeString(oPFPremiumFinance), gPMConstants.PMELogLevel.PMLogError)
                        End If
                    End If
                    'End - Sankar - PN 56780

                    'If this has worked, re-order the array so that the items are in frequency Order
                    If Informations.IsArray(r_vQuoteArray) Then
                        m_lReturn = gPMFunctions.ShellSort2DArray(r_vQuoteArray, k_PFQuoteFrequencyPerYear, "DESCENDING")
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            gPMFunctions.RaiseError("ShellSort2DArray", "Failed", gPMConstants.PMELogLevel.PMLogError)
                        End If
                    End If

            End Select

            'Set return values
            r_lPremFinanceCnt = m_lPremFinanceCnt
            r_lPremFinanceVer = m_lPremFinanceVer

            'Make sure Premium Finance record points to latest Insurance File
            If m_sProductCode = "MTA" Then
                'Only do This if it is Roadmap MTA
                If v_lRenewalInsFileCnt <> 0 Then
                    m_lInsuranceFileCnt = v_lRenewalInsFileCnt
                End If
            End If


        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=nResult, excep:=ex)

        Finally

        End Try
        Return nResult
    End Function

    ''' <summary>
    ''' GetOriginalInsuranceFileCnt - Get Original Insurance File Count
    ''' </summary>
    ''' <param name="r_nRenewalInsFileCnt"></param>
    ''' <param name="r_nOriginalInsFileCnt"></param>
    ''' <returns>Integer</returns>
    ''' <remarks></remarks>

    Public Function GetOriginalInsuranceFileCnt(ByVal nRenewalInsFileCnt As Integer,
                                                ByRef o_nOriginalInsFileCnt As Integer) As Integer

        Const kMethodName As String = "GetOriginalInsuranceFileCnt"
        Dim oRenewalDetails As Object = Nothing
        Dim nResult As Integer = gPMConstants.PMEReturnCode.PMTrue


        Try
            AddParameterLite(m_oDatabase, "ren_ins_file_cnt", nRenewalInsFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
            nResult = m_oDatabase.SQLSelect(sSQL:=kGetRenewalStatusFromRenInsFileCntSQL,
                                                sSQLName:=kGetRenewalStatusFromRenInsFileCntName,
                                                bStoredProcedure:=kGetRenewalStatusFromRenInsFileCntStored,
                                                vResultArray:=oRenewalDetails)
            If nResult <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError(kMethodName, kGetRenewalStatusFromRenInsFileCntSQL + " failed", gPMConstants.PMELogLevel.PMLogError)
            End If
            If Informations.IsArray(oRenewalDetails) Then
                o_nOriginalInsFileCnt = ToSafeLong(oRenewalDetails(0, 0))
            End If

        Catch excep As System.Exception
            ' DO Not Call any functions before here or the error will be lost
            nResult = gPMConstants.PMEReturnCode.PMError
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:=kMethodName & " Failed", vApp:=ACApp, vClass:=ACClass, vMethod:=kMethodName, vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)
            ' If you want to rollback a transaction or something, do it here
            Return nResult
        End Try
        Return nResult
    End Function

    '===============
    'PRIVATE METHODS
    '===============
    '*************************************************************************
    'Name:          GetMissingQuoteData
    'Description:   Gets all the data that hasn't been passed in by the client
    '*************************************************************************
    Private Function GetMissingQuoteData(ByVal v_vPFTransArray(,) As Object,
                                         ByRef r_vPFPremiumFinance(,) As Object,
                                         Optional ByVal bDayOfMonthIsValid As Boolean = False) As Integer

        Dim result As Integer = 0

        Dim lLboundArray, lUboundArray, lTransactionID As Integer
        Dim vArrayOfInsuranceFile As Object = Nothing
        Dim crRefundAmount As Decimal
        Dim dtNextInstalmentDate, dtNextInstalmentDatePlus1, dtLastInstalmentDate, dtLastPaidInstalmentDate As Date
        Dim vInsurerName As Object = Nothing
        Dim vBrokerName As Object = Nothing
        Dim vRiskGroupId As Object = Nothing
        Dim vHandlerName As Object = Nothing
        Dim vRelatedPolicyCnt As Object = Nothing
        Dim vRelatedPolicyCode As Object = Nothing
        Dim vRelationshipType As Object = Nothing
        Dim vRiskDesc As Object = Nothing
        Dim vAnalysisDesc As Object = Nothing
        Dim vAgentName As Object = Nothing

        Dim vPolicyTypeDesc As Object = Nothing
        Dim vSchemeId As Object = Nothing
        Dim vSchemeDesc As Object = Nothing
        Dim crTaxNotIncludedInInstalment As Decimal
        'PN 50319
        Dim lAgentPartyCnt As Integer
        Dim vResultArray(,) As Object = Nothing
        Dim dCurrencyToBaseXRate As Double
        Dim crIncludeTaxInPF As Decimal
        Dim lInsuranceFileCntForTax As Integer = 0
        Dim nInsuranceFileTypeID As Integer = 0

        result = gPMConstants.PMEReturnCode.PMTrue

        'There are various types of input data for this
        '1)InsuranceCnt provided.
        '2)Transaction Array provided. Use this to get TransactionID which can then be used to get the InsuranceFileCnt.
        '3)Premium Finance Cnt & Ver provided. Get Finance (This MUST be the scenario for MTA type 3's)

        If m_lInsuranceFileCnt = 0 Then

            'Get the existing PremiumFinance record
            If m_lPremFinanceCnt > 0 And m_lPremFinanceVer > 0 Then
                'No insuranceFileCnt, and no TransArray, we must have an existing PFPremiumFinance ID
                m_lReturn = GetSingleFinancePlan(v_lFinanceCount:=m_lPremFinanceCnt, v_lFinanceVersion:=m_lPremFinanceVer, r_vPFPremiumFinance:=r_vPFPremiumFinance)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetSingleFinancePlan", "v_lFinanceCount:=" & m_lPremFinanceCnt, gPMConstants.PMELogLevel.PMLogError)
                End If
                If Informations.IsArray(r_vPFPremiumFinance) Then
                    m_lInsuranceFileCnt = gPMFunctions.ToSafeLong(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0), 0)
                End If
            End If
        End If

        If Not Informations.IsArray(r_vPFPremiumFinance) And m_lInsuranceFileCnt = 0 Then
            'If no InsuranceFileCnt passed in, and no existing policy to get the details from, then get it from the transactions selected.
            If Informations.IsArray(v_vPFTransArray) Then

                '31203
                m_lReturn = gPMFunctions.ShellSort2DArray(v_vPFTransArray, 3)

                For iRow As Integer = v_vPFTransArray.GetLowerBound(1) To v_vPFTransArray.GetUpperBound(1)

                    lTransactionID = gPMFunctions.ToSafeInteger(v_vPFTransArray(0, iRow))

                    m_lReturn = GetInsuranceFileCnt(v_lTransdetailID:=lTransactionID, r_lInsuranceFileCnt:=m_lInsuranceFileCnt)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("GetInsuranceFileCnt", "v_lTransdetailID:=" & lTransactionID, gPMConstants.PMELogLevel.PMLogError)
                    End If

                    If m_lInsuranceFileCnt > 0 Then
                        Exit For
                    Else
                        m_bHasClientFees = True
                    End If

                Next iRow

            End If
        End If

        'At this point we should definitely know the insuranceFilecnt from the TransArray, PremiumFinance or it passed in directly
        If m_lInsuranceFileCnt > 0 Then

            m_lReturn = m_oInsuranceFile.GetDetails(vInsuranceFileCnt:=m_lInsuranceFileCnt)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oInsuranceFile.GetDetails", "vInsuranceFileCnt:=" & m_lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            m_lReturn = m_oInsuranceFile.GetNext(vArrayOfInsuranceFile)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oInsuranceFile.GetNext", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            m_dCurrencyXRate = gPMFunctions.ToSafeDouble(vArrayOfInsuranceFile(InsuranceFileConst.ACCurrencyToBaseXRate), 1)

            m_lReturn = m_oInsuranceFile.GetOtherDetails(DBNull.Value, vInsurerName, DBNull.Value, vBrokerName, DBNull.Value, vRiskDesc, vRiskGroupId, DBNull.Value, vAnalysisDesc, DBNull.Value, vHandlerName, DBNull.Value, vAgentName, vArrayOfInsuranceFile(1), vRelatedPolicyCnt, vRelatedPolicyCode, vRelationshipType, vArrayOfInsuranceFile(InsuranceFileConst.ACPolicyTypeId), vPolicyTypeDesc, vSchemeId, vSchemeDesc)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oInsuranceFile.GetOtherDetails", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If

            m_sPolicyTypeDesc = vPolicyTypeDesc

            ' RDT - Start - Just use the date part of the datetime field
            'PN44667
            m_dtCoverStartDate = DateTime.FromOADate(Math.Floor(gPMFunctions.NullToDate(vArrayOfInsuranceFile(InsuranceFileConst.ACInceptionTPI)).ToOADate))

            'Now store these details locally, but do not overwrite ones that have been passed in populated
            If m_dtStartDate = CDate("00:00:00") Then
                m_dtStartDate = DateTime.FromOADate(Math.Floor(gPMFunctions.NullToDate(vArrayOfInsuranceFile(InsuranceFileConst.ACCoverStartDate)).ToOADate))
            End If
            If m_dtEndDate = CDate("00:00:00") Then
                m_dtEndDate = DateTime.FromOADate(Math.Floor(gPMFunctions.NullToDate(vArrayOfInsuranceFile(InsuranceFileConst.ACExpiryDate)).ToOADate))
            End If
            If m_dtQuoteDate = CDate("00:00:00") Then
                m_dtQuoteDate = CDate(DateTime.Now.ToString("yyyy/MM/dd"))
            End If
            ' RDT - End
            If m_sProductCode = "" Then
                m_lReturn = GetInsuranceFileDetails(v_lInsuranceFileCnt:=m_lInsuranceFileCnt, r_sLastTransType:=m_sProductCode)
                'PN5232
                m_bCallFromCM = True
            End If
            If m_lProductID = 0 Then
                m_lProductID = gPMFunctions.NullToLong(vArrayOfInsuranceFile(InsuranceFileConst.ACProductID))
            End If
            If gPMFunctions.ToSafeLong(vArrayOfInsuranceFile(InsuranceFileConst.ACSourceID)) >= 0 Then
                m_lSourceID = gPMFunctions.ToSafeLong(vArrayOfInsuranceFile(InsuranceFileConst.ACSourceID))
            End If
            'PN 52183
            If m_lPartyCnt = 0 Then
                m_lPartyCnt = gPMFunctions.NullToLong(vArrayOfInsuranceFile(InsuranceFileConst.ACInsuredCnt))
            End If
            'PN 50319
            If gPMFunctions.ToSafeLong(vArrayOfInsuranceFile(InsuranceFileConst.ACLeadAgentCnt)) > 0 Then
                lAgentPartyCnt = gPMFunctions.ToSafeLong(vArrayOfInsuranceFile(InsuranceFileConst.ACLeadAgentCnt))
                With m_oDatabase
                    .Parameters.Clear()
                    m_lReturn = .Parameters.Add(sName:="party_cnt", vValue:=gPMFunctions.ToSafeString(lAgentPartyCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("Add Parameter party_cnt", "Failed", gPMConstants.PMELogLevel.PMLogError)
                    End If

                    m_lReturn = .SQLSelect(sSQL:=kGetAgentPartyBrokerSQL, sSQLName:=kGetAgentPartyBrokerName, bStoredProcedure:=True, vResultArray:=vResultArray)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("GetMissingQuoteData Failed to process Stored Proc", "kGetAgentPartyBrokerName", gPMConstants.PMELogLevel.PMLogError)
                    End If
                End With

                If Informations.IsArray(vResultArray) And gPMFunctions.ToSafeLong(vArrayOfInsuranceFile(InsuranceFileConst.ACLeadAgentCnt)) > 0 Then

                    m_vAgentCnt = gPMFunctions.NullToLong(vArrayOfInsuranceFile(InsuranceFileConst.ACLeadAgentCnt)) 'Broker Agent
                Else

                    m_vAgentCnt = DBNull.Value
                End If

            End If

            nInsuranceFileTypeID = gPMFunctions.ToSafeLong(vArrayOfInsuranceFile.GetValue(InsuranceFileConst.ACInsuranceFileTypeID))

            'See if the PRemiumFinance Array if populated
            If Not Informations.IsArray(r_vPFPremiumFinance) Then
                'Try and get a Previously created Plan for this Insurance File
                m_lReturn = GetSingleFinancePlanFromInsFileCnt(v_lInsuranceFileCnt:=m_lInsuranceFileCnt, r_vPFPremiumFinance:=r_vPFPremiumFinance)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue And m_lReturn <> gPMConstants.PMEReturnCode.PMNotFound Then
                    gPMFunctions.RaiseError("GetSingleFinancePlanFromInsFileCnt", "v_lInsuranceFileCnt:=" & m_lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                End If

                If m_lOriginalInsuranceFileCnt <> m_lInsuranceFileCnt And m_lOriginalInsuranceFileCnt <> 0 Then
                    'MTA or renewal so try OriginalInsuranceFileCnt
                    m_lReturn = GetSingleFinancePlanFromInsFileCnt(v_lInsuranceFileCnt:=m_lOriginalInsuranceFileCnt, r_vPFPremiumFinance:=r_vPFPremiumFinance)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue And m_lReturn <> gPMConstants.PMEReturnCode.PMNotFound Then
                        gPMFunctions.RaiseError("GetSingleFinancePlanFromInsFileCnt", "v_lInsuranceFileCnt:=" & m_lOriginalInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
                    End If
                End If
            End If
            vResultArray = Nothing
            ' Get InsuranceFileCnt from transaction array and then get tax and fee according to this InsuranceFileCnt 
            'and then re-assign origional InsuranceFileCnt in m_lInsuranceFileCnt variable.
            Dim nOrigionalInsuranceFileCnt As Integer = 0
            If Informations.IsArray(v_vPFTransArray) Then

                nOrigionalInsuranceFileCnt = m_lInsuranceFileCnt

                m_lReturn = gPMFunctions.ShellSort2DArray(v_vPFTransArray, 3)

                For iRow As Integer = v_vPFTransArray.GetLowerBound(1) To v_vPFTransArray.GetUpperBound(1)

                    lTransactionID = gPMFunctions.ToSafeInteger(v_vPFTransArray(0, iRow))

                    m_lReturn = GetInsuranceFileCnt(v_lTransdetailID:=lTransactionID, r_lInsuranceFileCnt:=m_lInsuranceFileCnt)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("GetInsuranceFileCnt", "v_lTransdetailID:=" & lTransactionID, gPMConstants.PMELogLevel.PMLogError)
                    End If
                    If m_lInsuranceFileCnt > 0 Then
                        Exit For
                    End If
                Next iRow
            End If
            With m_oDatabase
                .Parameters.Clear()
                m_lReturn = .Parameters.Add(sName:="insurance_file_cnt", vValue:=m_lInsuranceFileCnt, iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMInteger)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New ApplicationException("Failed to add Parameter insurance_file_cnt")
                End If
                m_lReturn = .SQLSelect(sSQL:=ACGetFeesNotIncludedInInstalmentsSQL, sSQLName:=ACGetFeesNotIncludedInInstalmentsName, bStoredProcedure:=True, vResultArray:=vResultArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New ApplicationException("Failed to execute ACGetFeesNotIncludedInInstalmentsSQL")
                End If
            End With
            If Informations.IsArray(vResultArray) Then
                m_crPolicyRiskFeeAmount = ToSafeCurrency(vResultArray(2, 0)) + ToSafeCurrency(vResultArray(3, 0))
            End If
            vResultArray = Nothing
            With m_oDatabase
                .Parameters.Clear()
                m_lReturn = .Parameters.Add(sName:="insurance_file_cnt",
                                            vValue:=m_lInsuranceFileCnt,
                                            iDirection:=gPMConstants.PMEParameterDirection.PMParamInput,
                                            iDataType:=gPMConstants.PMEDataType.PMInteger)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New ApplicationException("Failed to add Parameter insurance_file_cnt")
                End If

                m_lReturn = .SQLSelect(sSQL:=ACGetTaxesNotIncludedInInstalmentSQL,
                                        sSQLName:=ACGetTaxesNotIncludedInInstalmentName,
                                        bStoredProcedure:=True,
                                        vResultArray:=vResultArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New ApplicationException("Failed to execute ACGetTaxesNotIncludedInInstalmentSQL")
                End If
            End With
            If Informations.IsArray(vResultArray) Then
                m_crPolicyRiskTaxAmount = ToSafeCurrency(vResultArray(2, 0)) + ToSafeCurrency(vResultArray(3, 0))
            End If
            If nOrigionalInsuranceFileCnt <> 0 Then
                lInsuranceFileCntForTax = nOrigionalInsuranceFileCnt
            End If
        End If
        If Informations.IsArray(r_vPFPremiumFinance) Then

            'TR - If there is an existing plan, populate some of the missing data
            If m_lPremFinanceCnt = 0 Then
                m_lPremFinanceCnt = gPMFunctions.NullToLong(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0))
            End If
            If m_lPremFinanceVer = 0 Then
                m_lPremFinanceVer = gPMFunctions.NullToLong(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            End If

            If Not bDayOfMonthIsValid AndAlso m_iDayOfWeekOrMonth = 0 Then
                'no need to pick the Day of Month which is in Cancelled Status.
                If r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanStatusInd, 0) <> "999" Then
                    m_iDayInMonth = gPMFunctions.NullToLong(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0))
                    'm_iDayOfWeek = gPMFunctions.NullToLong(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0))
                End If

            End If

            If m_dtStartDate = CDate("00:00:00") Then
                m_dtStartDate = gPMFunctions.NullToDate(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanStartDate, 0))
            End If
            'In case of Temp MTA and MTA type is Spread over or Put amount in next installment, End Date is taken as Plan End Date instead of Version End Date
            If (nInsuranceFileTypeID = 7 OrElse nInsuranceFileTypeID = 6) AndAlso (m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddToNext OrElse m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread) Then
                m_dtEndDate = gPMFunctions.NullToDate(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanEndDate, 0))
            Else
                If m_dtEndDate = CDate("00:00:00") Then
                    m_dtEndDate = gPMFunctions.NullToDate(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanEndDate, 0))
                End If
            End If
            If m_dtQuoteDate = CDate("00:00:00") Then
                m_dtQuoteDate = CDate(DateTime.Now.ToString("yyyy/MM/dd"))
            End If

            m_lPFFrequencyId = gPMFunctions.ToSafeInteger(r_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanPfFrequency_ID, 0))

            If m_sProductCode = "MTA" Then

                'Get details about existing instalments
                m_lReturn = SettlePlanCalculate(v_vPremiumFinance:=r_vPFPremiumFinance, r_crSettlement:=m_crCurrentOSFinanceAmount, r_crRefund:=crRefundAmount, r_dtNextInstalmentDate:=dtNextInstalmentDate, r_dtNextInstalmentDatePlus1:=dtNextInstalmentDatePlus1, r_dtLastInstalmentDate:=dtLastInstalmentDate, r_dtLastPaidInstalmentDate:=dtLastPaidInstalmentDate)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("SettlePlanCalculate", "Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                m_dtNextDueInstalmentDate = dtNextInstalmentDate
                m_dtNextDueInstalmentDatePlus1 = dtNextInstalmentDatePlus1
                m_dtLastInstalmentDate = dtLastInstalmentDate
                m_dtLastPaidInstalmentDate = dtLastPaidInstalmentDate

            End If

        End If

        Dim iCurrencyID As Integer

        'Sankar - PN 54570 - Added a if condition to the array vArrayOfInsuranceFile
        If Informations.IsArray(vArrayOfInsuranceFile) Then
            'If gPMFunctions.ToSafeDouble(vArrayOfInsuranceFile(InsuranceFileConst.ACCurrencyToBaseXRate), 1) <= 0 Or ((m_sProductCode = "NB" Or m_sProductCode = "MTA") And m_sTransType = "G_NB") Then
            '    dCurrencyToBaseXRate = 1
            'Else
            dCurrencyToBaseXRate = gPMFunctions.ToSafeDouble(vArrayOfInsuranceFile(InsuranceFileConst.ACCurrencyToBaseXRate), 1)
            iCurrencyID = ToSafeInteger(vArrayOfInsuranceFile(InsuranceFileConst.ACCurrencyID), 1)

            If dCurrencyToBaseXRate = 0 Then
                dCurrencyToBaseXRate = 1
            End If
            'End If
        End If

        If m_iDayInMonth <= 0 Then
            m_iDayInMonth = 1
        End If
        If m_iDayOfWeek <= 0 Then
            m_iDayOfWeek = 1
        End If

        'Get the Amount if it hasn't already been supplied
        If m_crChangeToFinanceAmount = 0 Then
            'Do we need to get this info from the Trans Array or from the Insurance cnt?
            If Informations.IsArray(v_vPFTransArray) Then

                lLboundArray = v_vPFTransArray.GetLowerBound(1)

                lUboundArray = v_vPFTransArray.GetUpperBound(1)

                'Loop through the transactions and calculate the total amount to be financed
                For lRowIndex As Integer = lLboundArray To lUboundArray

                    If v_vPFTransArray.GetUpperBound(0) = 5 Then ' PN 66474
                        If gPMFunctions.ToSafeString(v_vPFTransArray(5, lRowIndex)).ToUpper() <> "COMM" Then

                            m_crChangeToFinanceAmount += CDec(v_vPFTransArray(2, lRowIndex))
                        End If
                    Else

                        m_crChangeToFinanceAmount += CDec(v_vPFTransArray(2, lRowIndex))
                    End If
                Next
            End If

            'convert amount to trans currency
            Dim lCompanyNo As Integer = 1

            m_lReturn = m_oCurrencyConvert.ConvertBaseToCurrency(lCurrencyID:=iCurrencyID, lCompanyID:=lCompanyNo,
                        cBaseAmount:=m_crChangeToFinanceAmount, cCurrencyAmount:=m_crChangeToFinanceAmount, vConversionDate:=Nothing, vConversionRate:=dCurrencyToBaseXRate)
        End If

        ' Get the amount of Tax which is not the part of Finanace amount and reduce
        ' the same from the Total Amount to get the Total Finance Amount

        ' Gaurav
        Dim crFeeNotIncludedInInstalment As Double
        'm_lReturn = TotalTaxNotIncludedInInstalment(m_lInsuranceFileCnt, crTaxNotIncludedInInstalment, crTaxIncludedAndNotSpreadAcrossInInstalment)
        GetPolicyFeeAndTaxes(lInsuranceFileCntForTax, crFeeNotIncludedInInstalment, crTaxNotIncludedInInstalment, crIncludeTaxInPF)

        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            gPMFunctions.RaiseError("GetMissingQuoteData", "m_lInsuranceFileCnt:=" & lInsuranceFileCntForTax, gPMConstants.PMELogLevel.PMLogError)
        End If

        Dim dGrossAmt As Double = m_crChangeToFinanceAmount
        '+ crFeeNotIncludedInInstalment
        If m_sProductCode = "NB" Then
            If m_sTransType = "G_NB" Then
                m_crChangeToFinanceAmount = m_crChangeToFinanceAmount + crIncludeTaxInPF
                m_crChangeToFinanceAmount = m_crChangeToFinanceAmount - crTaxNotIncludedInInstalment
            End If
        End If

        If m_sProductCode = "NB" And m_sTransType = "G_NB" Then
            m_crChangeToFinanceAmount -= crFeeNotIncludedInInstalment
        End If

        If Informations.IsArray(r_vPFPremiumFinance) Then
            If Informations.IsArray(r_vPFPremiumFinance) Then
                If m_iUseTransCurrency = -1 Then
                    m_iUseTransCurrency = ToSafeInteger(r_vPFPremiumFinance(186, 0))
                End If
            End If
        End If

        If m_iUseTransCurrency = 0 Then
            m_crChangeToFinanceAmount *= dCurrencyToBaseXRate
        End If

        m_dCurrencyXRate = dCurrencyToBaseXRate

        If m_sProductCode = "MTA" Then

            If m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_NoAmountChange Then
                'Amount is not being changed so use the amount that is still outstanding
                m_crNewTotalFinanceAmount = m_crCurrentOSFinanceAmount

            ElseIf m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddToNewPlan Then
                'Use the new amount
                m_crNewTotalFinanceAmount = m_crChangeToFinanceAmount
            Else
                'Calculate the new amount
                m_crNewTotalFinanceAmount = m_crCurrentOSFinanceAmount + m_crChangeToFinanceAmount
            End If
        Else
            'Use the new amount
            m_crNewTotalFinanceAmount = m_crChangeToFinanceAmount
        End If

        Return result
    End Function

    ''' <summary>
    ''' Loops through the given Array and performs the Instalment
    ''' Quote calculations for valid PF Rate Files
    ''' </summary>
    ''' <param name="v_vPFPremiumFinance"></param>
    ''' <param name="v_vArrayOfValidPFRFs"></param>
    ''' <param name="r_vQuoteArray"></param>
    ''' <param name="v_bEnforcePreferredDate"></param>
    ''' <param name="v_bFindHighlightedCell"></param>
    ''' <param name="v_lMediaTypeId"></param>
    ''' <param name="v_vUseExistingPaymentDetails"></param>
    ''' <param name="v_bInHouse"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function CalculateEachQuote(ByVal v_vPFPremiumFinance(,) As Object,
                                        ByVal v_vArrayOfValidPFRFs(,) As Object,
                                        ByRef r_vQuoteArray(,) As Object,
                                        Optional ByVal v_bEnforcePreferredDate As Boolean = False,
                                        Optional ByVal v_bFindHighlightedCell As Boolean = False,
                                        Optional ByVal v_lMediaTypeId As Integer = 0,
                                        Optional ByVal v_vUseExistingPaymentDetails As Object = Nothing,
                                        Optional ByVal v_bInHouse As Boolean = False,
                                        Optional ByVal bIsCallingFromSAM As Boolean = False) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "CalculateEachQuote"
        Dim iCalculateInstalmentsNetCommission As Integer
        Dim lLowerRateCount, lUpperRateCount, lCountOfValidPFRFs, lLastCompanyNo, lLastSchemeNo, lLastSchemeVersion As Integer
        Dim vArrayOfSources As Object = Nothing
        Dim vArrayOfProducts(,) As Object = Nothing
        Dim bSameScheme As Boolean
        Dim lCompanyNo, lSchemeNo, lSchemeVersion, lDaysDelay, lStartLimit As Integer
        Dim enAlignPremiumTo As AlignPremiumToOptions
        Dim enDepositType As CalculationType
        Dim dDepositAmountOrPecentage As Double
        Dim iDepositChargedTo As Integer
        Dim lPFRF_ID As Integer
        'Dim dMinimumInterest As Double
        'Dim crRangeMinimum, crRangeMaximum As Decimal
        Dim dInterestRate As Double
        Dim enProtectionType As CalculationType
        Dim dProtectionAmountOrPercentage As Double
        Dim enFeesType As CalculationType
        Dim dFeesAmountOrPercentage As Double
        Dim iChargeTaxToFirstInstalment, iChargeFeeToFirstInstalment, iChargeProtectionToFirstInstalment, iChargeBackdatedToFirstInstalment As Integer
        Dim sFrequencyPeriod As String = ""
        Dim lFrequencyAmount, lMediaTypeID As Integer
        'Dim iRangeCount As Integer
        Dim lExistingDaysDelay, lActualDaysDelay As Integer
        Dim crFinanceAmount, cMinimumInterestAmount As Decimal
        Dim iBaseCurrencyID As Integer
        Dim sProductFamily As String = ""
        Dim oPFSubmit As New bSIRPFSubmit.Application
        Dim sProviderCode As String = ""
        'Dim iLpRates As Integer
        Dim bFinished As Boolean
        Dim vTmpArray(,) As Object = Nothing
        Dim lSGCount As Integer
        Dim bCalcAPR As Boolean
        Dim dAPR As Double
        Dim lInstalments, lTerms, lDayOfMonth As Integer
        Dim crDeposit, cMinMTA As Decimal
        Dim lTaxGroupID As Integer
        Dim bInQuoteLoop, bContinueQuote As Boolean
        Dim lTmpVal As Double

        Dim dTmpStartDate As Date
        Dim sTmp As String = ""
        Dim bIsRenewal, bBrokerRenewal, bValidInstalments As Boolean
        Dim bDepositOverrideAllowed As Boolean
        Dim dDepositOverrideAmount As Double
        Dim nOriginalNumberOfInstalmentsRemaining As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Clear the error variables
            m_sErrorText = ""
            m_sErrorCode = ""

            'Initialise variables
            lLastCompanyNo = 0
            lLastSchemeNo = 0
            lLastSchemeVersion = 0
            lCountOfValidPFRFs = -1
            bSameScheme = False
            ReDim r_vQuoteArray(k_PFQuoteUBound, 0)

            'Find out the size of the array
            lLowerRateCount = v_vArrayOfValidPFRFs.GetLowerBound(1)
            lUpperRateCount = v_vArrayOfValidPFRFs.GetUpperBound(1)

            If m_sProductCode = "MTA" AndAlso m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_NoAmountChange Then
                crFinanceAmount = m_crCurrentOSFinanceAmount
            Else
                crFinanceAmount = m_crChangeToFinanceAmount
            End If

            'Get the Batch Currency for the Branch

            m_lReturn = m_oCurrencyConvert.GetBaseCurrency(v_lCompanyId:=m_lSourceID, r_iBaseCurrencyID:=iBaseCurrencyID)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oCurrencyConvert.GetBaseCurrency", "v_lCompanyID:=" & m_lSourceID, gPMConstants.PMELogLevel.PMLogError)
            End If

            bInQuoteLoop = True

            'ACR 20/07/07 Added the following as SG plans can only transact from present day onwards
            dTmpStartDate = m_dtStartDate
            'End ACR 20/07/07

            'Now loop through the PFRF records
            For lCountOfPFRFs As Integer = lLowerRateCount To lUpperRateCount
                dDepositOverrideAmount = m_dOverrideDeposit
                bContinueQuote = True

                'ACR 27-11-07 First of all check whether this particular scheme limits the amount of transactions
                'that can be financed
                If m_sProductCode <> "MTA" Then
                    If gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(77, lCountOfPFRFs)) = 1 Then
                        'then check whether the current amount of transactions is above the specified limit

                        If (m_vTransArray.GetUpperBound(1) + 1) > gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(78, lCountOfPFRFs)) Then
                            bContinueQuote = False
                        End If
                    End If
                End If

                'Get the data to validate this PFRF for this Quote
                lCompanyNo = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(1, lCountOfPFRFs))
                lSchemeNo = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(2, lCountOfPFRFs))
                lSchemeVersion = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(3, lCountOfPFRFs))
                lPFRF_ID = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(11, lCountOfPFRFs))
                sProductFamily = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(50, lCountOfPFRFs)).Trim()
                sProviderCode = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(65, lCountOfPFRFs)).Trim()
                bDepositOverrideAllowed = ToSafeBoolean(v_vArrayOfValidPFRFs(87, lCountOfPFRFs))


                If bDepositOverrideAllowed = False AndAlso dDepositOverrideAmount > -1 Then
                    dDepositOverrideAmount = -1
                End If
                'This code is not required because the branch validation is already being done below. 
                'It may be that scheme is made in one branch but is accessible to all branches.
                'Check For MTA plans For current branch
                'If m_lSourceID > 0 AndAlso m_sProductCode = "MTA" AndAlso m_lSourceID <> lCompanyNo Then
                '    Continue For
                'End If

                'ACR 20/07/07 Added the following as SG plans can only transact from present day onwards
                If sProductFamily = "SG" Then
                    If dTmpStartDate < DateTime.Today Then
                        m_dtStartDate = DateTime.Today
                    End If
                Else
                    m_dtStartDate = dTmpStartDate
                End If
                'End ACR 20/07/07

                'See if The scheme that this PFRF belongs to is the same as the previous
                bSameScheme = lCompanyNo = lLastCompanyNo And lSchemeNo = lLastSchemeNo And lSchemeVersion = lLastSchemeVersion

                ' Get the Valid Products and Sources for this Scheme (if not already loaded)
                If Not bSameScheme Then
                    m_lReturn = GetValidProductsAndSources(v_lCompanyNo:=lCompanyNo, v_lSchemeNo:=lSchemeNo, v_lSchemeVersion:=lSchemeVersion, r_vArrayOfSources:=vArrayOfSources, r_vArrayOfProducts:=vArrayOfProducts)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("GetValidProductsAndSources", "v_lSchemeNo:=" & lSchemeNo, gPMConstants.PMELogLevel.PMLogError)
                    End If
                End If

                'Ensure that this PFRF is valid for this Source & Product
                If Informations.IsArray(vArrayOfSources) Then

                    ' Bypass check for 3rd Party MTAs as it would fail anyway on sources
                    If Not (m_sProductCode = "MTA" And Not v_bInHouse) Then

                        m_lReturn = ValidatePFRFForThisSourceAndProduct(vArrayOfSources, vArrayOfProducts)
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            bContinueQuote = False
                        End If
                    End If
                Else
                    bContinueQuote = False
                End If

                If bContinueQuote AndAlso m_sProductCode = "MTA" AndAlso m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddToNewPlan Then ' So as to get those shemes which is having selected Product
                    If Informations.IsArray(vArrayOfProducts) Then
                        bValidInstalments = False

                        For lCountValidInstalments As Integer = vArrayOfProducts.GetLowerBound(1) To vArrayOfProducts.GetUpperBound(1)

                            If gPMFunctions.ToSafeDouble(vArrayOfProducts(0, lCountValidInstalments)) = m_lProductID Then
                                bValidInstalments = True
                            End If
                        Next
                        If Not bValidInstalments Then
                            bContinueQuote = False
                        End If
                    Else
                        bContinueQuote = False
                    End If
                End If

                'if this is a connectivity quote we need the component to submit with..
                If sProductFamily = "SG" Then
                    'check we haven't already got one somehow
                    If oPFSubmit Is Nothing Then
                        'get an instance of our submit component
                        ' Replace use of ObjectManager when creating objects. PN23065.

                        oPFSubmit = New bSIRPFSubmit.Application
                        m_lReturn = oPFSubmit.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bSIRPFSubmit.Application", gPMConstants.PMELogLevel.PMLogError)
                        End If
                    End If

                    If bContinueQuote Then
                        If m_sProductCode = "MTA" Then
                            If crFinanceAmount <= 0 Then
                                If m_crChangeToFinanceAmount <= 0 Then

                                    crFinanceAmount = CDec(v_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0))
                                Else
                                    crFinanceAmount = m_crChangeToFinanceAmount
                                End If
                            End If
                        End If

                        'Fetch our quotes; first off we need to fill in all the data so that submit knows what it's doing

                        oPFSubmit.URL = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(64, lCountOfPFRFs))

                        oPFSubmit.PartyCnt = m_lPartyCnt

                        oPFSubmit.ProviderCode = sProviderCode.Trim()

                        If gPMFunctions.ToSafeString(v_vArrayOfValidPFRFs(70, lCountOfPFRFs)).Trim() <> "" Then

                            If m_sProductCode = "MTA" Then

                                lTmpVal = gPMFunctions.ToSafeDouble(v_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanAmountToFinance, 0))
                            Else
                                lTmpVal = crFinanceAmount
                            End If

                            sTmp = GetSGBrokerID(v_vArrayOfValidPFRFs, lCountOfPFRFs, crFinanceAmount)

                            If sTmp <> "-" Then

                                oPFSubmit.BrokerID = sTmp
                            End If
                        Else

                            oPFSubmit.BrokerID = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(68, lCountOfPFRFs))
                        End If

                        oPFSubmit.Username = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(66, lCountOfPFRFs))

                        oPFSubmit.Password = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(67, lCountOfPFRFs))

                        oPFSubmit.Timeout = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(69, lCountOfPFRFs))

                        oPFSubmit.Premium = crFinanceAmount

                        oPFSubmit.TransactionArray = m_vTransArray

                        oPFSubmit.OverrideRate = m_dInterestOverrideRate

                        If gPMFunctions.ToSafeString(v_vArrayOfValidPFRFs(75, lCountOfPFRFs)) = "PCLPSG" Then

                            oPFSubmit.Deposit = dDepositOverrideAmount
                        End If

                        If m_sProductCode = "MTA" Then

                            oPFSubmit.MessageType = 2

                            oPFSubmit.Reference = gPMFunctions.NullToString(v_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanReference, 0))

                            oPFSubmit.StartDate = DateTime.Today

                            oPFSubmit.SchemeCode = v_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanSGSchemeCode, 0)
                        Else

                            m_lReturn = CheckSGRenewalType(gPMFunctions.ToSafeString(v_vArrayOfValidPFRFs(75, lCountOfPFRFs)), m_lPartyCnt, bIsRenewal, bBrokerRenewal)

                            If bIsRenewal Then

                                oPFSubmit.Renewal = True
                            End If
                            If bBrokerRenewal Then

                                oPFSubmit.BrokerRenewal = True
                            End If

                            oPFSubmit.MessageType = 0 'GetRates
                        End If

                        oPFSubmit.PaymentDay = m_dtPreferredDate.ToString("dd")

                        oPFSubmit.InsuranceFileCnt = m_lInsuranceFileCnt

                        'and submit the quotes!

                        m_lReturn = oPFSubmit.Submit()
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            'PN32840 If there is error in quote then process next quote
                            Continue For
                        End If
                    End If

                    If bContinueQuote Then
                        'now fetch the result array from the component and add it to
                        'the quote array

                        vTmpArray = oPFSubmit.RateArray

                        'check if we have any results
                        If Not (Informations.IsArray(vTmpArray)) Then
                            gPMFunctions.RaiseError("Not (Informations.IsArray(vTmpArray))", "No Results", gPMConstants.PMELogLevel.PMLogError)
                        End If
                    End If
                End If

                'reset our flag and counter
                bFinished = False
                lSGCount = 0

                'added this as one stargate scheme will bring back more than one rate
                Do While Not bFinished

                    'set our flag
                    If Informations.IsArray(vTmpArray) Then

                        If lSGCount = vTmpArray.GetUpperBound(1) Then
                            bFinished = True
                        End If
                    Else
                        bFinished = True
                    End If

                    'Check if we are a stargate quote as we have the interest rate already
                    If sProductFamily <> "SG" Then
                        'Only Continue for Valid PFRFs
                        If bContinueQuote Then
                            'Only get the interest rate if this is NOT a Backdated MTA
                            If m_lBackDatedMTAType <> bSIRPremFinConst.PFIntermediateBDMTA Then

                                m_lReturn = CalculateInterestRate(v_crFinanceAmount:=crFinanceAmount, v_vArrayOfPFRFs:=v_vArrayOfValidPFRFs,
                                                                  v_lPFRFIndex:=lCountOfPFRFs, r_dInterestRate:=dInterestRate)
                                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                    gPMFunctions.RaiseError("CalculateInterestRate", "crFinanceAmount:=" & crFinanceAmount, gPMConstants.PMELogLevel.PMLogError)
                                End If
                            Else
                                dInterestRate = 0
                            End If
                        End If
                    Else
                        'Get the rate from the connectvity array
                        If Informations.IsArray(vTmpArray) Then

                            dInterestRate = gPMFunctions.ToSafeDouble(vTmpArray(3, lSGCount))
                        Else
                            dInterestRate = 0
                        End If
                    End If

                    If bContinueQuote Then
                        'Get the rest of the required data from the Array
                        'Use numerics rather than constants to get to the required
                        'columns in the array, as this array is never passed externally
                        lDaysDelay = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(4, lCountOfPFRFs))
                        lStartLimit = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(5, lCountOfPFRFs))
                        enAlignPremiumTo = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(6, lCountOfPFRFs))

                        sFrequencyPeriod = gPMFunctions.NullToString(gPMFunctions.ToSafeString(v_vArrayOfValidPFRFs(7, lCountOfPFRFs)).ToLower())
                        enDepositType = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(8, lCountOfPFRFs))

                        If sProductFamily = "SG" Then

                            dDepositAmountOrPecentage = gPMFunctions.ToSafeDouble(vTmpArray(5, lSGCount))

                            'ACR 16-12-2005 check if a deposit has been added but not returned..

                            If (dDepositOverrideAmount > 0) AndAlso (gPMFunctions.ToSafeDouble(vTmpArray(5, lSGCount)) = 0) Then
                                dDepositAmountOrPecentage = dDepositOverrideAmount
                            End If
                        Else
                            dDepositAmountOrPecentage = gPMFunctions.NullToDouble(v_vArrayOfValidPFRFs(9, lCountOfPFRFs))
                        End If

                        If bDepositOverrideAllowed AndAlso dDepositOverrideAmount > -1 And Not (sProductFamily = "SG") Then
                            If m_iUseTransCurrency = 1 Then
                                dDepositAmountOrPecentage = dDepositOverrideAmount * m_dCurrencyXRate
                            Else
                                dDepositAmountOrPecentage = dDepositOverrideAmount
                            End If
                            enDepositType = CalculationType.CalculationTypeAmount
                        End If

                        iDepositChargedTo = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(10, lCountOfPFRFs))
                        enProtectionType = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(13, lCountOfPFRFs))
                        dProtectionAmountOrPercentage = gPMFunctions.NullToDouble(v_vArrayOfValidPFRFs(14, lCountOfPFRFs))
                        enFeesType = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(40, lCountOfPFRFs))
                        dFeesAmountOrPercentage = gPMFunctions.NullToDouble(v_vArrayOfValidPFRFs(41, lCountOfPFRFs))
                        iChargeTaxToFirstInstalment = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(42, lCountOfPFRFs))
                        iChargeFeeToFirstInstalment = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(43, lCountOfPFRFs))
                        iChargeProtectionToFirstInstalment = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(44, lCountOfPFRFs))
                        iChargeBackdatedToFirstInstalment = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(63, lCountOfPFRFs))
                        'Start (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
                        iCalculateInstalmentsNetCommission = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(79, lCountOfPFRFs))
                        'End (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
                        lMediaTypeID = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(48, lCountOfPFRFs))
                        lFrequencyAmount = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(54, lCountOfPFRFs))
                        cMinMTA = gPMFunctions.NullToCurrency(v_vArrayOfValidPFRFs(73, lCountOfPFRFs))
                        lExistingDaysDelay = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(55, lCountOfPFRFs))

                        'Convert Day of Month and Day of Week to single variable and FrequencyPeriod to valid VB Frequency Interval
                        If sFrequencyPeriod.Trim().ToUpper() = "M" Then
                            m_sVBFrequencyInterval = "m"
                            m_iDayOfWeekOrMonth = m_iDayInMonth
                        ElseIf sFrequencyPeriod.Trim().ToUpper() = "W" Then
                            m_sVBFrequencyInterval = "ww"
                            m_iDayOfWeekOrMonth = m_iDayOfWeek
                        Else
                            bContinueQuote = False
                        End If

                        'check the trasaction limit against the limit

                        If (gPMFunctions.ToSafeDouble(v_vArrayOfValidPFRFs(73, lCountOfPFRFs)) = 1) And Informations.IsArray(m_vTransArray) Then

                            If m_vTransArray.GetUpperBound(1) >= gPMFunctions.ToSafeDouble(v_vArrayOfValidPFRFs(74, lCountOfPFRFs)) Then
                                m_lReturn = gPMConstants.PMEReturnCode.PMFail
                            End If
                        End If

                        If bContinueQuote Then
                            lCountOfValidPFRFs += 1
                            ReDim Preserve r_vQuoteArray(k_PFQuoteUBound, lCountOfValidPFRFs)
                            'TR - Populate the result array with all the info gathered so
                            'far. Use Constants to populate the coumns as this array will
                            'be passed externally

                            If sProductFamily = "SG" Then
                                If m_sProductCode = "MTA" Then
                                    'copy over the existing rate details - some of these values will
                                    'be overwritten when the new rate comes back

                                    r_vQuoteArray(k_PFQuoteAprRate, lCountOfValidPFRFs) = v_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanAPR, 0)

                                    r_vQuoteArray(k_PFQuoteInterestRate, lCountOfValidPFRFs) = v_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanInterestRate, 0)
                                End If
                            End If

                            ' Gaurav

                            r_vQuoteArray(k_PFQuoteFrequencyPeriod, lCountOfValidPFRFs) = sFrequencyPeriod

                            r_vQuoteArray(k_PFQuoteFrequencyAmount, lCountOfValidPFRFs) = lFrequencyAmount

                            r_vQuoteArray(k_PFQuotePFRF_ID, lCountOfValidPFRFs) = lPFRF_ID

                            r_vQuoteArray(k_PFQuoteFrequencyPerYear, lCountOfValidPFRFs) = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(0, lCountOfPFRFs))

                            r_vQuoteArray(k_PFQuoteCompanyNo, lCountOfValidPFRFs) = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(1, lCountOfPFRFs))

                            r_vQuoteArray(k_PFQuoteCompanyName, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(53, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFQuoteSchemeNo, lCountOfValidPFRFs) = lSchemeNo

                            r_vQuoteArray(k_PFQuoteSchemeVersion, lCountOfValidPFRFs) = lSchemeVersion

                            r_vQuoteArray(k_PFQuoteSchemeName, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(45, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFQuoteFrequencyID, lCountOfValidPFRFs) = gPMFunctions.NullToInteger(v_vArrayOfValidPFRFs(46, lCountOfPFRFs))

                            r_vQuoteArray(k_PFQuoteFrequencyDescription, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(47, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFQuoteMediaTypeID, lCountOfValidPFRFs) = lMediaTypeID

                            r_vQuoteArray(k_PFQuoteMediaTypeDescription, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(49, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFQuoteProductClass, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(50, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFQuoteProductCode, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(50, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFQuoteTotalAmountInput, lCountOfValidPFRFs) = crFinanceAmount

                            r_vQuoteArray(k_PFQuoteSchemeTypeCode, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(51, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFQuoteMediaTypeValidation, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(52, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFSGBrokerURL, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(64, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFSGUsername, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(66, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFSGPassword, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(67, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFSGBrokerID, lCountOfValidPFRFs) = gPMFunctions.NullToString(v_vArrayOfValidPFRFs(68, lCountOfPFRFs)).Trim()

                            r_vQuoteArray(k_PFSGProviderCode, lCountOfValidPFRFs) = sProviderCode

                            r_vQuoteArray(k_PFQuoteMinMTA, lCountOfValidPFRFs) = cMinMTA

                            r_vQuoteArray(k_PFQuoteTaxGroupID, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(74, lCountOfPFRFs) 'lTaxGroupID

                            r_vQuoteArray(k_PFQuoteXSLCode, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(76, lCountOfPFRFs)

                            r_vQuoteArray(k_PFDepositAsInstalment, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(80, lCountOfPFRFs)

                            r_vQuoteArray(k_PFAlignTo, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(6, lCountOfPFRFs)

                            r_vQuoteArray(k_PFBranchCodeMandatory, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(81, lCountOfPFRFs)

                            r_vQuoteArray(k_PFBranchNameMandatory, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(82, lCountOfPFRFs)

                            r_vQuoteArray(k_PFBankNameMandatory, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(83, lCountOfPFRFs)

                            r_vQuoteArray(k_PFBankAddressMandatory, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(84, lCountOfPFRFs)

                            r_vQuoteArray(k_PFStartLimit, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(5, lCountOfPFRFs)

                            lTaxGroupID = gPMFunctions.ToSafeLong(r_vQuoteArray(k_PFQuoteTaxGroupID, lCountOfValidPFRFs))

                            r_vQuoteArray(k_PFSingleInstalmentPerMonth, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(85, lCountOfPFRFs)

                            r_vQuoteArray(k_PFFirstInstalmentAlignWithMonthInDay, lCountOfValidPFRFs) = v_vArrayOfValidPFRFs(86, lCountOfPFRFs)

                            If Informations.IsArray(v_vPFPremiumFinance) AndAlso m_sProductCode <> "REN" Then

                                r_vQuoteArray(k_PFUseTransCurrncy, lCountOfValidPFRFs) = v_vPFPremiumFinance(186, 0)

                            End If

                            If ToSafeInteger(v_vArrayOfValidPFRFs(86, lCountOfPFRFs)) = 1 Then
                                'Dim dtPreferredDate As Date
                                Dim dtTempStartDate As Date

                                dtTempStartDate = m_dtStartDate

                                If m_sProductCode = "MTA" Then
                                    dtTempStartDate = m_dtEffectiveDate
                                End If

                            End If
                            r_vQuoteArray(k_PFFinanceToNet, lCountOfValidPFRFs) = ToSafeInteger(iCalculateInstalmentsNetCommission)

                            If Object.Equals(r_vQuoteArray(k_PFQuoteInterestRate, lCountOfValidPFRFs), Nothing) Then

                                r_vQuoteArray(k_PFQuoteInterestRate, lCountOfValidPFRFs) = dInterestRate

                                r_vQuoteArray(k_PFOriginalRate, lCountOfValidPFRFs) = dInterestRate
                            End If

                            If sProductFamily = "SG" Then

                                lTerms = gPMFunctions.ToSafeInteger(vTmpArray(7, lSGCount))

                                r_vQuoteArray(k_PFSGTerms, lCountOfValidPFRFs) = lTerms

                                r_vQuoteArray(k_PFSGRef, lCountOfValidPFRFs) = vTmpArray(0, lSGCount)

                                Select Case vTmpArray(8, lSGCount)
                                    Case "NetScheme"

                                        r_vQuoteArray(k_PFSGSchemeType, lCountOfValidPFRFs) = "Net"
                                    Case "MarkupScheme"

                                        r_vQuoteArray(k_PFSGSchemeType, lCountOfValidPFRFs) = "Markup"
                                    Case "GrossScheme"

                                        r_vQuoteArray(k_PFSGSchemeType, lCountOfValidPFRFs) = "Gross"
                                End Select
                            End If

                            If v_bFindHighlightedCell Then

                                If lMediaTypeID = v_lMediaTypeId AndAlso sFrequencyPeriod = m_sRenewalFrequencyInterval AndAlso
                                    lFrequencyAmount = m_lFrequencyAmount AndAlso
                                    gPMFunctions.ToSafeDouble(r_vQuoteArray(k_PFQuoteCompanyNo, lCountOfValidPFRFs)) = m_lCompanyNo AndAlso
                                    lSchemeNo = m_lSchemeNo AndAlso lSchemeVersion = m_lSchemeVer AndAlso
                                    gPMFunctions.ToSafeString(r_vQuoteArray(k_PFQuoteProductCode, lCountOfValidPFRFs)) = m_sProductCode Then

                                    r_vQuoteArray(k_PFQuoteHighlightCell, lCountOfValidPFRFs) = True
                                    'Store the Orignal Amount in the Quote Array
                                    If v_vPFPremiumFinance IsNot Nothing Then
                                        r_vQuoteArray(k_PFQuoteOriginalOtherInstalmentAmount, lCountOfValidPFRFs) = v_vPFPremiumFinance(bSIRPremFinConst.k_PFPlanOtherInstalments, 0)
                                    End If
                                Else

                                    r_vQuoteArray(k_PFQuoteHighlightCell, lCountOfValidPFRFs) = False
                                End If
                            Else

                                r_vQuoteArray(k_PFQuoteHighlightCell, lCountOfValidPFRFs) = False
                            End If

                            If m_sProductCode = "MTA" Then

                                If m_iMTAType <> bSIRPremFinConst.m_klInstalmentMTAType_AddToNewPlan Then

                                    If gPMFunctions.ToSafeDouble(r_vQuoteArray(k_PFQuoteFrequencyID, lCountOfValidPFRFs)) = m_lPFFrequencyId Then

                                        ' this quote is using the same frequency as the plan that is currently in use
                                        ' use the existing instalment dates if we have them
                                        If m_dtNextDueInstalmentDate <> CDate("00:00:00") Then

                                            r_vQuoteArray(k_PFQuoteFirstInstalmentDate, lCountOfValidPFRFs) = m_dtNextDueInstalmentDate
                                        End If
                                        If m_dtNextDueInstalmentDatePlus1 <> CDate("00:00:00") Then

                                            r_vQuoteArray(k_PFQuoteNextInstalmentDate, lCountOfValidPFRFs) = m_dtNextDueInstalmentDatePlus1
                                        End If
                                        If m_dtLastInstalmentDate <> CDate("00:00:00") Then

                                            r_vQuoteArray(k_PFQuoteLastInstalmentDate, lCountOfValidPFRFs) = m_dtLastInstalmentDate
                                        End If
                                    End If
                                End If
                            End If

                            lActualDaysDelay = lDaysDelay

                            If Not Informations.IsNothing(v_vUseExistingPaymentDetails) And Informations.IsArray(v_vUseExistingPaymentDetails) Then
                                lActualDaysDelay = lExistingDaysDelay
                            End If

                            Dim dtAnnualDate As Date = m_dtCoverStartDate.AddYears(1)
                            Dim nHalfYearDays As Long = Informations.DateDiff(DateInterval.Day, m_dtCoverStartDate, dtAnnualDate)
                            Dim nTotalDays As Integer = Informations.DateDiff(DateInterval.Day, m_dtCoverStartDate, m_dtEndDate)
                            'Get the max number of instalments
                            If ((ToSafeString(v_vArrayOfValidPFRFs(47, lCountOfPFRFs))).TrimEnd().ToUpper() = "ANNUALLY" AndAlso
                                    ToSafeString(v_vArrayOfValidPFRFs(7, lCountOfPFRFs)) = "m" AndAlso
                                    NullToLong(v_vArrayOfValidPFRFs(ACMaxNoOfInstalmentsInArray, lCountOfPFRFs)) = 0) OrElse
                                   ((ToSafeString(v_vArrayOfValidPFRFs(47, lCountOfPFRFs))).TrimEnd().ToUpper() = "HALF YEARLY" AndAlso (nTotalDays < nHalfYearDays / 2)) OrElse
                                   ((ToSafeString(v_vArrayOfValidPFRFs(47, lCountOfPFRFs))).TrimEnd().ToUpper() = "QUARTERLY" AndAlso (nTotalDays < nHalfYearDays / 4)) Then
                                m_lMaXNoOfInstalments = 1
                            Else
                                If m_sProductCode = "MTA" AndAlso m_iMTAType = m_klInstalmentMTAType_NoAmountChange Then
                                    If _
                                        (lSchemeNo = ToSafeLong(v_vPFPremiumFinance(k_PFPlanSchemeNo, 0)) AndAlso
                                        lSchemeVersion = ToSafeLong(v_vPFPremiumFinance(k_PFPlanSchemeVersion, 0))) OrElse
                                        (ToSafeString(v_vArrayOfValidPFRFs(47, lCountOfPFRFs))).TrimEnd().ToUpper() = (ToSafeString(v_vPFPremiumFinance(k_PFPlanFrequency, 0))).TrimEnd().ToUpper() Then
                                        m_lReturn = GetInstalmentsRemaining(
                                            v_lpfprem_finance_cnt:=NullToLong(v_vPFPremiumFinance(k_PFPlanPFCnt, 0)),
                                            v_lpfprem_finance_version:=
                                                                               NullToLong(
                                                                                   v_vPFPremiumFinance(k_PFPlanPFVersion, 0)),
                                            r_lNoInstalments:=nOriginalNumberOfInstalmentsRemaining)
                                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                            RaiseError("GetInstalmentsRemaining",
                                                       "v_lpfprem_finance_cnt:=" &
                                                       NullToLong(v_vPFPremiumFinance(k_PFPlanPFCnt, 0)),
                                                       gPMConstants.PMELogLevel.PMLogError)
                                        End If
                                        m_lMaXNoOfInstalments =
                                            gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(ACMaxNoOfInstalmentsInArray,
                                                                                         lCountOfPFRFs))

                                        If (ToSafeString(v_vArrayOfValidPFRFs(47, lCountOfPFRFs))).TrimEnd().ToUpper() = "ANNUALLY" AndAlso ToSafeString(v_vArrayOfValidPFRFs(7, lCountOfPFRFs)) = "m" AndAlso nOriginalNumberOfInstalmentsRemaining = 0 Then
                                            m_lMaXNoOfInstalments = gPMFunctions.NullToLong(v_vArrayOfValidPFRFs(ACMaxNoOfInstalmentsInArray, lCountOfPFRFs))
                                        ElseIf m_lMaXNoOfInstalments > nOriginalNumberOfInstalmentsRemaining Then
                                            m_lMaXNoOfInstalments = nOriginalNumberOfInstalmentsRemaining
                                        End If
                                    Else
                                        m_lMaXNoOfInstalments = NullToLong(v_vArrayOfValidPFRFs(ACMaxNoOfInstalmentsInArray,
                                                                                                lCountOfPFRFs))
                                    End If
                                Else
                                    m_lMaXNoOfInstalments = NullToLong(v_vArrayOfValidPFRFs(ACMaxNoOfInstalmentsInArray,
                                                                                            lCountOfPFRFs))
                                End If
                                'ACR 13-02-06 Added for PCLPSG quotes
                            End If
                            If sProductFamily = "SG" Then

                                cMinimumInterestAmount = CDec(vTmpArray(9, lSGCount))
                            Else
                                'mkw090604 PN12381
                                cMinimumInterestAmount = gPMFunctions.NullToCurrency(v_vArrayOfValidPFRFs(12, lCountOfPFRFs))
                            End If

                            'ACR 01-02-05 Added calc apr flag for connectivity quotes
                            ' as we already have the apr from the webservice
                            If sProductFamily = "SG" Then
                                bCalcAPR = False
                                dAPR = Math.Round(gPMFunctions.NullToDouble(vTmpArray(6, lSGCount)), 2)
                                lInstalments = gPMFunctions.NullToLong(vTmpArray(2, lSGCount))
                                lDayOfMonth = (m_dtStartDate).Day
                            Else
                                bCalcAPR = True
                                dAPR = 0
                                lInstalments = -1
                                lDayOfMonth = -1
                            End If

                            If sProductFamily = "SG" Then

                                crDeposit = CDec(vTmpArray(5, lSGCount))
                            End If

                            ' SET 16/07/2004 ISS12274 - set the enforce preferred date to FALSE
                            'if doing a renewal/MTA and the number of instalments is 1
                            'and scheme uses AlignWithPolicyRenewalDate
                            '           if doing a renewal/MTA and the number of instalments is 1
                            '           and scheme uses AlignWithPolicyRenewalDate
                            ' removed as this code breaks normal instalment calculation for renewals
                            '                If Informations.IsArray(v_vPFPremiumFinance) Then
                            '                    GetInstalmentsRemaining ToSafeLong(v_vPFPremiumFinance(k_PFPlanPFCnt, 0)), ToSafeLong(v_vPFPremiumFinance(k_PFPlanPFVersion, 0)), lInstalments
                            '                End If

                            If (m_sProductCode.ToUpper() = "REN" Or m_sProductCode.ToUpper() = "MTA" Or m_sProductCode.ToUpper() = "SR" Or m_sProductCode.ToUpper() = "TPR") And (m_lMaXNoOfInstalments = 1) And (enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithPolicyRenewalDate) Then
                                'PN32706 : Pass the number of required instalments as 1
                                lInstalments = 1
                                m_lReturn = DoCalculation(v_lArrayCount:=lCountOfValidPFRFs, v_dInterestRate:=dInterestRate, v_lDaysDelay:=lActualDaysDelay, v_lStartLimit:=lStartLimit, v_enAlignPremiumTo:=enAlignPremiumTo, v_iFrequencyAmount:=lFrequencyAmount,
                                                          v_enDepositType:=enDepositType, v_dDepositAmountOrPecentage:=dDepositAmountOrPecentage, v_iDepositChargedTo:=iDepositChargedTo,
                                                          v_enProtectionType:=enProtectionType, v_dProtectionAmountOrPercentage:=dProtectionAmountOrPercentage, v_enFeesType:=enFeesType,
                                                          v_dFeesAmountOrPercentage:=dFeesAmountOrPercentage, v_iChargeTaxToFirstInstalment:=iChargeTaxToFirstInstalment,
                                                          v_iChargeFeeToFirstInstalment:=iChargeFeeToFirstInstalment,
                                                          v_iChargeProtectionToFirstInstalment:=iChargeProtectionToFirstInstalment,
                                                          v_iChargeBackdatedToFirstInstalment:=iChargeBackdatedToFirstInstalment,
                                                          r_vQuoteArray:=r_vQuoteArray, v_bEnforcePreferredDate:=False, v_cMinimumInterestAmount:=cMinimumInterestAmount,
                                                          v_bCalcAPR:=bCalcAPR, v_dAPR:=dAPR, v_lInstalments:=lInstalments, v_lDayOfMonth:=-1, v_cDepositAmount:=crDeposit,
                                                          v_cMinMTA:=cMinMTA, v_lTaxGroupID:=lTaxGroupID, v_iCurrencyID:=iBaseCurrencyID,
                                                          v_iCalculateInstalmentsNetCommission:=iCalculateInstalmentsNetCommission, v_oFinanceArray:=v_vPFPremiumFinance,
                                                          bApplyFeePercentagesToFees:=v_vArrayOfValidPFRFs(88, lCountOfPFRFs), bApplyFeePercentagesToTaxes:=v_vArrayOfValidPFRFs(89, lCountOfPFRFs))
                            Else
                                m_lReturn = DoCalculation(v_lArrayCount:=lCountOfValidPFRFs, v_dInterestRate:=dInterestRate, v_lDaysDelay:=lActualDaysDelay, v_lStartLimit:=lStartLimit, v_enAlignPremiumTo:=enAlignPremiumTo,
                                                          v_iFrequencyAmount:=lFrequencyAmount, v_enDepositType:=enDepositType, v_dDepositAmountOrPecentage:=dDepositAmountOrPecentage, v_iDepositChargedTo:=iDepositChargedTo,
                                                          v_enProtectionType:=enProtectionType, v_dProtectionAmountOrPercentage:=dProtectionAmountOrPercentage, v_enFeesType:=enFeesType,
                                                          v_dFeesAmountOrPercentage:=dFeesAmountOrPercentage, v_iChargeTaxToFirstInstalment:=iChargeTaxToFirstInstalment,
                                                          v_iChargeFeeToFirstInstalment:=iChargeFeeToFirstInstalment, v_iChargeProtectionToFirstInstalment:=iChargeProtectionToFirstInstalment,
                                                          v_iChargeBackdatedToFirstInstalment:=iChargeBackdatedToFirstInstalment,
                                                          r_vQuoteArray:=r_vQuoteArray, v_bEnforcePreferredDate:=v_bEnforcePreferredDate, v_cMinimumInterestAmount:=cMinimumInterestAmount,
                                                          v_bCalcAPR:=bCalcAPR, v_dAPR:=dAPR, v_lInstalments:=lInstalments, v_lDayOfMonth:=lDayOfMonth, v_cDepositAmount:=crDeposit, v_cMinMTA:=cMinMTA,
                                                          v_lTaxGroupID:=lTaxGroupID, v_iCurrencyID:=iBaseCurrencyID, v_bIsSG:=sProductFamily.ToUpper() = "SG",
                                                          v_iCalculateInstalmentsNetCommission:=iCalculateInstalmentsNetCommission,
                                                          bApplyFeePercentagesToFees:=v_vArrayOfValidPFRFs(88, lCountOfPFRFs), bApplyFeePercentagesToTaxes:=v_vArrayOfValidPFRFs(89, lCountOfPFRFs), v_oFinanceArray:=v_vPFPremiumFinance)
                            End If

                            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                                gPMFunctions.RaiseError("DoCalculation", "v_dInterestRate:=dInterestRate", gPMConstants.PMELogLevel.PMLogError)

                                If Informations.IsArray(r_vQuoteArray) Then

                                    If gPMFunctions.ToSafeDouble(r_vQuoteArray(k_PFQuotePFRF_ID, lCountOfValidPFRFs)) = lPFRF_ID Then
                                        lCountOfValidPFRFs -= 1
                                        If lCountOfValidPFRFs > -1 Then
                                            ReDim Preserve r_vQuoteArray(k_PFQuoteUBound, lCountOfValidPFRFs)
                                        Else
                                            ReDim r_vQuoteArray(k_PFQuoteUBound, 0)
                                        End If
                                    End If
                                End If

                                lLastCompanyNo = 0
                                lLastSchemeNo = 0
                                lLastSchemeVersion = 0

                                lCompanyNo = 0
                                lSchemeNo = 0
                                lSchemeVersion = 0
                            End If
                        End If

                        'Update last IDs
                        lLastCompanyNo = lCompanyNo
                        lLastSchemeNo = lSchemeNo
                        lLastSchemeVersion = lSchemeVersion

                        If m_iTask = gPMConstants.PMEComponentAction.PMView AndAlso Informations.IsArray(v_vPFPremiumFinance) AndAlso m_sProductCode.ToUpper() <> "REN" Then

                            r_vQuoteArray(k_PFPlanFirstInstalment, lCountOfValidPFRFs) = v_vPFPremiumFinance(16, 0)
                            r_vQuoteArray(k_PFPlanOtherInstalments, lCountOfValidPFRFs) = v_vPFPremiumFinance(17, 0)

                        End If
                    End If

                    lSGCount += 1
                Loop
            Next

            bInQuoteLoop = False

            If lCountOfValidPFRFs = -1 Then
                r_vQuoteArray = Nothing
            End If

        Catch excep As Exception
            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError,
                               sMsg:=kMethodName & " Failed", vApp:=ACApp, vClass:=ACClass,
                               vMethod:=kMethodName, vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message,
                               excep:=excep)
            ' If you want to rollback a transaction or something, do it here

            'If we are in the quote loop then resume, as we don't won't to stop quoting if a single one errors.
            If bInQuoteLoop AndAlso result = gPMConstants.PMEReturnCode.PMFalse Then
                bContinueQuote = False
                result = gPMConstants.PMEReturnCode.PMTrue
            End If
        End Try

        Return result
    End Function

    ''' <summary>
    '''  Calculates the new Instalments for an existing plan, to
    ''' include payments for an MTA. This can either be spread
    ''' over the remaining payments or added to the Next.
    ''' </summary>
    ''' <param name="v_vExistingPlan"></param>
    ''' <param name="v_vSinglePFRF"></param>
    ''' <param name="r_vQuoteArray"></param>
    ''' <param name="v_lMediaTypeId"></param>
    ''' <param name="v_bInHouse"></param>
    ''' <param name="v_bEnforcePreferredDate"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Private Function CalculateMTAExtraQuote(ByVal v_vExistingPlan(,) As Object,
                                            ByVal v_vSinglePFRF As Object,
                                            ByRef r_vQuoteArray(,) As Object,
                                            Optional ByVal v_lMediaTypeId As Integer = 0,
                                            Optional ByVal v_bInHouse As Boolean = False,
                                            Optional ByVal v_bEnforcePreferredDate As Boolean = False,
                                            Optional ByVal bIsCallingFromSAM As Boolean = False) As Integer

        Dim nResult As Integer = 0
        Dim nExistNoOfInstalments As Integer
        Dim dExistFirstInstalmentAmount, dExistOtherInstalmentAmount, dExistTotalRemainingAmount As Double
        Dim nMTANoOfInstalments As Integer
        Dim dMTAFirstInstalmentAmount, dMTAOtherInstalmentAmount, dMTATotalInstalmentsAmount, dMTATotalInputAmount As Double
        Dim nRemainingInstalments As Integer
        Dim oExistingInstalments(,) As Object = Nothing
        Dim oMTAQuotes(,) As Object = Nothing
        Dim dExistFinancedAmount, dExistInterestAmount, dExistTaxesAmount, dExistTotalAmount As Double 'MKW120903 PF 3rd Party MTA
        Dim dExistFinanceAmount, dExistFinanceCharge, dExistDeposit, dExistFee As Double

        Const k_sFunctionName As String = "CalculateMTAExtraQuote"



        nResult = gPMConstants.PMEReturnCode.PMTrue

        'TR - First work out the Instalments for the MTA in the usual way
        ' RAW 05/11/2003 : CQ1824 : added v_vPFPremiumFinance param

        m_lReturn = CalculateEachQuote(v_vPFPremiumFinance:=v_vExistingPlan, v_vArrayOfValidPFRFs:=v_vSinglePFRF, r_vQuoteArray:=oMTAQuotes, v_bFindHighlightedCell:=True, v_bEnforcePreferredDate:=v_bEnforcePreferredDate, v_lMediaTypeId:=v_lMediaTypeId, v_bInHouse:=v_bInHouse, bIsCallingFromSAM:=bIsCallingFromSAM)

        If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then

            'TR - Get the Instalments for the existing plan
            With m_oDatabase
                .Parameters.Clear()
                .Parameters.Add("pfprem_finance_cnt", gPMFunctions.ToSafeString(m_lPremFinanceCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                .Parameters.Add("pfprem_finance_version", gPMFunctions.ToSafeString(m_lPremFinanceVer), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                'TR - Get outstanding instalments
                .Parameters.Add("filter", gPMFunctions.ToSafeString(2), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                'TR - Get all the result set
                m_lReturn = .SQLSelect(sSQL:=ACGetPFInstalmentsSQL, sSQLName:=ACGetPFInstalmentsName, bStoredProcedure:=ACGetPFInstalmentsStored, vResultArray:=oExistingInstalments, bKeepNulls:=True)

                'TR - Check that this worked OK
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="spu_PFInstalments_saa Failed", vApp:=ACApp, vClass:=ACClass, vMethod:=k_sFunctionName)
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
            End With
        End If

        'TR - Do we continue?
        If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then

            'TR - Get all the data required for the calcs
            nExistNoOfInstalments = gPMFunctions.NullToInteger(v_vExistingPlan(bSIRPremFinConst.k_PFPlanNoOfInstalments, 0))
            dExistOtherInstalmentAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanOtherInstalments, 0))
            'BE 4/9/2003 CQ345 - Save the existing amounts
            dExistFinancedAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)) 'BE
            dExistInterestAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanInterestCost, 0)) 'BE
            dExistTaxesAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanTaxCost, 0)) 'BE
            If Informations.IsArray(oExistingInstalments) Then
                dExistFee = gPMFunctions.NullToDouble(oExistingInstalments(4, 0))
            End If
            'MKW120903 PF 3rd Party MTA
            dExistTotalAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanTotalCost, 0))

            'TR - Get Info from the Instalments for the Existing plan (only if it exists)
            If Informations.IsArray(oExistingInstalments) Then

                nRemainingInstalments = oExistingInstalments.GetUpperBound(1) + 1
                'BE CQ345 - Reduce the existing Financed Amount by the amount paid

                dExistFinancedAmount -= GetPaidFinanceAmount(oExistingInstalments)
            Else
                nRemainingInstalments = 0
            End If

            'MKW120903 PF 3rd Party MTA START

            If gPMFunctions.ToSafeDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) = bSIRPremFinConst.PFThirdParty Or gPMFunctions.ToSafeDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) = bSIRPremFinConst.PFThirdPartyViaStargate Then
                dExistFirstInstalmentAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanFirstInstalment, 0))
                dExistTotalRemainingAmount = dExistFirstInstalmentAmount + ((nExistNoOfInstalments - 1) * dExistOtherInstalmentAmount)
                dExistFinanceAmount = 0
                'PN11684
                If v_bInHouse Then
                    dExistFinanceAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanAmountToFinance, 0))
                End If
                dExistFinanceCharge = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanFinanceCharge, 0))
                dExistDeposit = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanDeposit, 0))
            Else
                'MKW120903 PF 3rd Party MTA END
                'TR - See if the Existing Plan has had any instalments paid yet
                If nRemainingInstalments < nExistNoOfInstalments Then
                    'TR - The Existing First payment has already been paid, so
                    'use Existing Other instead
                    dExistFirstInstalmentAmount = dExistOtherInstalmentAmount
                    'TR - Tricky one - need to calculate what's left using Instalments
                    dExistTotalRemainingAmount = (nRemainingInstalments * dExistOtherInstalmentAmount) - (nRemainingInstalments * dExistFee)
                    'TR - Otherwise check that there aren't more instalments
                    'remaining than intialilly calculated for the plan

                ElseIf nRemainingInstalments = nExistNoOfInstalments Then
                    'TR - The Existing First payment has not already been paid, so
                    'use Existing First instead
                    ' RAW 13/11/2003 : CQ1765 : use first instead of other
                    dExistFirstInstalmentAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanFirstInstalment, 0))
                    'TR - Tricky one - need to calculate what's left using Instalments
                    dExistTotalRemainingAmount = dExistFirstInstalmentAmount + ((nRemainingInstalments - 1) * dExistOtherInstalmentAmount)

                ElseIf (nRemainingInstalments = nExistNoOfInstalments + 1) Then
                    'If transacting deposit as Installment
                    dExistFirstInstalmentAmount = gPMFunctions.NullToDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanFirstInstalment, 0))
                    dExistTotalRemainingAmount = dExistFirstInstalmentAmount + ((nRemainingInstalments - 2) * dExistOtherInstalmentAmount)
                Else
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If
            End If 'MKW120903 PF 3rd Party MTA

            ' CJB 090904 PN14774 Cater for no quotes gracefully!
            If Not Informations.IsArray(oMTAQuotes) Then
                nResult = gPMConstants.PMEReturnCode.PMNotFound

                r_vQuoteArray = Nothing
                Return nResult
            End If

            ReDim r_vQuoteArray(k_PFQuoteUBound, oMTAQuotes.GetUpperBound(1))

            For lCount As Integer = 0 To oMTAQuotes.GetUpperBound(1)
                nMTANoOfInstalments = gPMFunctions.NullToInteger(oMTAQuotes(k_PFQuoteInstalmentsToPay, lCount))
                dMTAFirstInstalmentAmount = gPMFunctions.NullToDouble(oMTAQuotes(k_PFQuoteFirstInstalmentAmount, lCount))
                dMTAOtherInstalmentAmount = gPMFunctions.NullToDouble(oMTAQuotes(k_PFQuoteOtherInstalmentAmount, lCount))
                dMTATotalInstalmentsAmount = gPMFunctions.NullToDouble(oMTAQuotes(k_PFQuoteTotalInstalmentsAmount, lCount))
                dMTATotalInputAmount = gPMFunctions.NullToDouble(oMTAQuotes(k_PFQuoteTotalAmountInput, lCount))

                'TR - Fill in the info that comes only from the New MTA quote

                r_vQuoteArray(k_PFQuoteCompanyNo, lCount) = oMTAQuotes(k_PFQuoteCompanyNo, lCount)

                r_vQuoteArray(k_PFQuoteCompanyName, lCount) = oMTAQuotes(k_PFQuoteCompanyName, lCount)

                r_vQuoteArray(k_PFQuoteSchemeNo, lCount) = oMTAQuotes(k_PFQuoteSchemeNo, lCount)

                r_vQuoteArray(k_PFQuoteSchemeVersion, lCount) = oMTAQuotes(k_PFQuoteSchemeVersion, lCount)

                r_vQuoteArray(k_PFQuoteSchemeName, lCount) = oMTAQuotes(k_PFQuoteSchemeName, lCount)

                r_vQuoteArray(k_PFQuoteFrequencyID, lCount) = oMTAQuotes(k_PFQuoteFrequencyID, lCount)

                r_vQuoteArray(k_PFQuoteFrequencyDescription, lCount) = oMTAQuotes(k_PFQuoteFrequencyDescription, lCount)

                r_vQuoteArray(k_PFQuoteMediaTypeID, lCount) = oMTAQuotes(k_PFQuoteMediaTypeID, lCount)

                r_vQuoteArray(k_PFQuoteMediaTypeDescription, lCount) = oMTAQuotes(k_PFQuoteMediaTypeDescription, lCount)

                r_vQuoteArray(k_PFQuoteProductClass, lCount) = oMTAQuotes(k_PFQuoteProductClass, lCount)

                r_vQuoteArray(k_PFQuoteProductCode, lCount) = oMTAQuotes(k_PFQuoteProductCode, lCount)

                r_vQuoteArray(k_PFQuoteInstalmentsToPay, lCount) = oMTAQuotes(k_PFQuoteInstalmentsToPay, lCount)

                r_vQuoteArray(k_PFQuoteFirstInstalmentDate, lCount) = oMTAQuotes(k_PFQuoteFirstInstalmentDate, lCount)

                r_vQuoteArray(k_PFQuoteLastInstalmentDate, lCount) = oMTAQuotes(k_PFQuoteLastInstalmentDate, lCount)

                r_vQuoteArray(k_PFQuoteNextInstalmentDate, lCount) = oMTAQuotes(k_PFQuoteNextInstalmentDate, lCount)

                r_vQuoteArray(k_PFQuoteAprRate, lCount) = oMTAQuotes(k_PFQuoteAprRate, lCount)

                r_vQuoteArray(k_PFQuoteInterestRate, lCount) = oMTAQuotes(k_PFQuoteInterestRate, lCount)

                r_vQuoteArray(k_PFQuoteDaysDelay, lCount) = oMTAQuotes(k_PFQuoteDaysDelay, lCount)
                'AAB-22-Oct-2003 15:47 - Added the existing deposit amount

                r_vQuoteArray(k_PFQuoteDepositAmount, lCount) = oMTAQuotes(k_PFQuoteDepositAmount, lCount)

                r_vQuoteArray(k_PFQuoteInterestAmount, lCount) = oMTAQuotes(k_PFQuoteInterestAmount, lCount)

                r_vQuoteArray(k_PFQuoteTaxAmount, lCount) = oMTAQuotes(k_PFQuoteTaxAmount, lCount)

                r_vQuoteArray(k_PFQuoteFinanceCharge, lCount) = oMTAQuotes(k_PFQuoteFinanceCharge, lCount)

                r_vQuoteArray(k_PFQuoteProtectionAmount, lCount) = oMTAQuotes(k_PFQuoteProtectionAmount, lCount)

                r_vQuoteArray(k_PFQuoteHighlightCell, lCount) = oMTAQuotes(k_PFQuoteHighlightCell, lCount)

                r_vQuoteArray(k_PFQuoteSchemeTypeCode, lCount) = oMTAQuotes(k_PFQuoteSchemeTypeCode, lCount)

                r_vQuoteArray(k_PFQuoteMediaTypeValidation, lCount) = oMTAQuotes(k_PFQuoteMediaTypeValidation, lCount)

                r_vQuoteArray(k_PFQuotePFRF_ID, lCount) = oMTAQuotes(k_PFQuotePFRF_ID, lCount)

                r_vQuoteArray(k_PFQuoteFrequencyPeriod, lCount) = oMTAQuotes(k_PFQuoteFrequencyPeriod, lCount)

                r_vQuoteArray(k_PFQuoteFrequencyAmount, lCount) = oMTAQuotes(k_PFQuoteFrequencyAmount, lCount)

                r_vQuoteArray(k_PFQuoteMinMTA, lCount) = oMTAQuotes(k_PFQuoteMinMTA, lCount)
                r_vQuoteArray(k_PFStartLimit, lCount) = oMTAQuotes(k_PFStartLimit, lCount)

                r_vQuoteArray(k_PFUseTransCurrncy, lCount) = oMTAQuotes(k_PFUseTransCurrncy, lCount)

                r_vQuoteArray(k_PFQuoteTaxGroupID, lCount) = oMTAQuotes(k_PFQuoteTaxGroupID, lCount)

                r_vQuoteArray(k_PFAlignTo, lCount) = oMTAQuotes.GetValue(k_PFAlignTo, lCount)

                'TR - Total finance amount = Total of MTA quote plus
                'total of existing plan

                'ACR PN22922
                'r_vQuoteArray(k_PFQuoteTotalAmountInput, lCount) = _
                'dExistTotalRemainingAmount + dMTATotalInputAmount

                r_vQuoteArray(k_PFQuoteTotalAmountInput, lCount) = dMTATotalInputAmount

                'PN11684
                If v_bInHouse Then

                    r_vQuoteArray(k_PFQuoteTotalAmountInput, lCount) = dExistFinanceAmount + dMTATotalInputAmount
                End If

                '       BE CQ345 - previous statement incorrect because dExistTotalRemainingAmount
                '                  contains Fees and Tax, dExistFinancedAmount contains correct
                '                  figure.
                'r_vQuoteArray(k_PFQuoteTotalAmountInput, lCount) = dExistTotalRemainingAmount
                'dExistFinancedAmount dMTATotalInputAmount

                'TR - First Instalment Amount = Other Amount from Original plan
                'Plus First Instalment of MTA

                r_vQuoteArray(k_PFQuoteFirstInstalmentAmount, lCount) = dMTAFirstInstalmentAmount
                'dExistFirstInstalmentAmount + dMTAFirstInstalmentAmount

                'TR - Other Instalment Amount = Other Amount from Original plan
                'Plus Other Instalment of MTA

                r_vQuoteArray(k_PFQuoteOtherInstalmentAmount, lCount) = dMTAOtherInstalmentAmount
                'dExistOtherInstalmentAmount + dMTAOtherInstalmentAmount

                'TR - Total Instalment Amount = Total of this quote plus all
                'outstanding on existing plan

                r_vQuoteArray(k_PFQuoteTotalInstalmentsAmount, lCount) = dMTATotalInstalmentsAmount
                'dExistTotalRemainingAmount + dMTATotalInstalmentsAmount

                'TR - Add the Orignal Amount to the Quote Array

                r_vQuoteArray(k_PFQuoteOriginalOtherInstalmentAmount, lCount) = dExistOtherInstalmentAmount

                'BE 4/9/2003 CQ345 - adjust the Interest and Tax

                r_vQuoteArray(k_PFQuoteInterestAmount, lCount) = dExistInterestAmount + gPMFunctions.ToSafeDouble(oMTAQuotes(k_PFQuoteInterestAmount, lCount))

                r_vQuoteArray(k_PFQuoteTaxAmount, lCount) = gPMFunctions.ToSafeDouble(oMTAQuotes(k_PFQuoteTaxAmount, lCount))

                If gPMFunctions.ToSafeDouble(v_vExistingPlan(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) = bSIRPremFinConst.PFThirdParty Then

                    r_vQuoteArray(k_PFQuoteDepositAmount, lCount) = dExistDeposit + gPMFunctions.ToSafeDouble(oMTAQuotes(k_PFQuoteDepositAmount, lCount))

                    r_vQuoteArray(k_PFQuoteFinanceCharge, lCount) = dExistFinanceCharge + gPMFunctions.ToSafeDouble(oMTAQuotes(k_PFQuoteFinanceCharge, lCount))

                End If
                r_vQuoteArray(k_PFDepositAsInstalment, lCount) = oMTAQuotes(k_PFDepositAsInstalment, lCount)
                r_vQuoteArray(k_PFStartDate, lCount) = oMTAQuotes(k_PFStartDate, lCount)
            Next
        End If

        'TR - Set return value
        Return m_lReturn

    End Function

    '*************************************************************************
    'Name:          GetValidProductsAndSources
    'Description:   Gets all the valid Products and Sources for a given
    '               Company/Scheme/Version combination. Uses Stored Procedures
    '               spu_PFSchemeProducts_Sel and spu_PFSchemeSource_Sel
    'History:       TR071102 - Created as per TS23 Section 4.2.1.1
    '*************************************************************************
    Private Function GetValidProductsAndSources(ByVal v_lCompanyNo As Integer, ByVal v_lSchemeNo As Integer, ByVal v_lSchemeVersion As Integer, ByRef r_vArrayOfSources(,) As Object, ByRef r_vArrayOfProducts(,) As Object) As Integer

        Dim result As Integer = 0
        Const k_sFunctionName As String = "GetValidProductsAndSources"



        'TR - Assume success
        result = gPMConstants.PMEReturnCode.PMTrue

        'TR - Use the database Object
