    '*************************************************************************
    'Name:          ValidatePFRFForThisSourceAndProduct
    'Description:   Checks that this PFRF is valid for this Product
    '               Checks at Scheme level
    'History:       TR071102 - Created as per TS23 Section 4.2.1.1
    '*************************************************************************
    Private Function ValidatePFRFForThisSourceAndProduct(
       ByVal v_vArrayOfSources As Object,
       ByVal v_vArrayOfProducts As Object) As Long

        Dim result As Integer = 0
        Dim bValidSource As Boolean
        Dim bValidProduct As Boolean

        result = gPMConstants.PMEReturnCode.PMTrue

        bValidSource = False
        bValidProduct = False

        'TR - See if Array is empty
        If Informations.IsArray(v_vArrayOfSources) = True Then
            m_lReturn = PFFindValueInArray(v_vArrayOfSources, m_lSourceID)
            If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                bValidSource = True
            End If
        Else
            'No records in array means no restrictions immediate, so Scheme is valid for all Sources
            bValidSource = True
        End If

        'TR - Do we continue? (If failed for Source, no need to continue)
        If bValidSource Then
            ' Claim Recovery (SR/TPR): skip product validation — schemes are not linked to a specific product
            If m_sProductCode.ToUpper() = "SR" OrElse m_sProductCode.ToUpper() = "TPR" Then
                bValidProduct = True
            ElseIf m_lProductID > 0 Then
                'TR - Make sure a Product ID has been passed. If not, do not
                'bother to validate
                'TR - See if Array is empty
                If Informations.IsArray(v_vArrayOfProducts) = True Then
                    m_lReturn = PFFindValueInArray(v_vArrayOfProducts, m_lProductID)
                    If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                        bValidProduct = True
                    End If
                Else
                    bValidProduct = False
                End If
            End If
        End If

        If Not bValidSource Or Not bValidProduct Then
            result = gPMConstants.PMEReturnCode.PMFalse
        End If

        Return result

    End Function

    '*************************************************************************
    'Name:          PFFindValueInArray
    'Description:   Looks for a given number in an Array. Does not return
    '               position of number if found.
    '               Will search all columns and rows unless a particular column
    '               is specified
    'Returns:       PMTrue for successful completion when a value is found
    '               PMOk for successful completion when a value is NOT found
    '               PMError  when errors occur
    'History:       TR071102 - Created as per TS23 Section 4.2.1.1
    '*************************************************************************
    Private Function PFFindValueInArray(ByVal v_vArrayToSearch(,) As Object, ByVal v_lNumberToFind As Integer, Optional ByVal v_lColumnNumber As Integer = -1) As Integer

        'TR - Declare local variables
        Dim result As Integer = 0
        Dim lLowerColumnCount, lUpperColumnCount, lLowerRowCount, lUpperRowCount As Integer



        'TR - Assume that the value is not found, but no errors occur
        result = gPMConstants.PMEReturnCode.PMOK

        'TR - Search all columns or only a specified one?
        If v_lColumnNumber = -1 Then
            lLowerColumnCount = v_vArrayToSearch.GetLowerBound(1)
            lUpperColumnCount = v_vArrayToSearch.GetUpperBound(1)
        Else
            lLowerColumnCount = v_lColumnNumber
            lUpperColumnCount = v_lColumnNumber
        End If

        lLowerRowCount = v_vArrayToSearch.GetLowerBound(0)
        lUpperRowCount = v_vArrayToSearch.GetUpperBound(0)

        'TR - Now do the search
        For lRowCount As Integer = lLowerRowCount To lUpperRowCount
            For lColumnCount As Integer = lLowerColumnCount To lUpperColumnCount

                If gPMFunctions.ToSafeDouble(v_vArrayToSearch(lRowCount, lColumnCount)) = v_lNumberToFind Then
                    Return gPMConstants.PMEReturnCode.PMTrue
                End If
            Next lColumnCount
        Next lRowCount

        Return result

    End Function

    '*************************************************************************
    'Name:          DoCalculation
    'Description:   Performs a calculation on a single PFRF
    'History:       TR071102 - Created as per TS23  Section 4.2.1.1.1
    '               TR310103 - Excluded Backdated MTA's from Tax/Interest/Fees
    '                          calculations
    '               mkw090604 - PN12381
    '               ACR 030205 - Added v_lInstalments for connectivity
    '                           quotes but also for future instalment plans
    '                           which are less than 12 months long..
    'Start (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
    'Added the v_iCalculateInstalmentsNetCommission optional parameter
    'End (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
    '*************************************************************************
    Private Function DoCalculation(ByVal v_lArrayCount As Integer, ByVal v_dInterestRate As Double, ByVal v_lDaysDelay As Integer,
                                   ByVal v_lStartLimit As Integer, ByVal v_enAlignPremiumTo As AlignPremiumToOptions, ByVal v_iFrequencyAmount As Integer,
                                   ByVal v_enDepositType As CalculationType, ByVal v_dDepositAmountOrPecentage As Double, ByVal v_iDepositChargedTo As Integer,
                                   ByVal v_enProtectionType As CalculationType, ByVal v_dProtectionAmountOrPercentage As Double, ByVal v_enFeesType As CalculationType,
                                   ByVal v_dFeesAmountOrPercentage As Double, ByVal v_iChargeTaxToFirstInstalment As Integer, ByVal v_iChargeFeeToFirstInstalment As Integer,
                                   ByVal v_iChargeProtectionToFirstInstalment As Integer, ByVal v_iChargeBackdatedToFirstInstalment As Integer, ByRef r_vQuoteArray(,) As Object,
                                   Optional ByVal v_bEnforcePreferredDate As Boolean = False, Optional ByVal v_cMinimumInterestAmount As Decimal = 0,
                                   Optional ByRef v_bCalcAPR As Boolean = True, Optional ByRef v_dAPR As Double = 0, Optional ByRef v_lInstalments As Integer = -1,
                                   Optional ByRef v_lDayOfMonth As Integer = -1, Optional ByRef v_cDepositAmount As Decimal = 0, Optional ByVal v_cMinMTA As Decimal = 0,
                                   Optional ByVal v_lTaxGroupID As Integer = 0, Optional ByVal v_iCurrencyID As Integer = 0, Optional ByVal v_bIsSG As Boolean = False,
                                   Optional ByVal v_iCalculateInstalmentsNetCommission As Integer = 0, Optional ByVal v_oFinanceArray(,) As Object = Nothing,
                                   Optional ByVal bApplyFeePercentagesToFees As Boolean = True, Optional ByVal bApplyFeePercentagesToTaxes As Boolean = True,
                                   Optional ByVal bIsCallingFromSAM As Boolean = False) As Integer

        Dim result As Integer = 0

        Dim iNoOfInstalmentsToPay, iNoOfMissedInstalments As Integer
        Dim crDepositAmount, crInterestAmount, crTaxOnInterest, crProtectionAmount, crFeesAmount, crFinanceAmount, crFirstInstalmentAmount, crOtherInstalmentAmount, crTotalInstalmentAmount As Decimal
        Dim dtFirstInstalmentDate, dtNextInstalmentDate, dtLastInstalmentDate As Date
        Dim dAprRate As Double
        Dim dtStartDate As Date
        'Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
        Dim bCalculateInstalmentsNetCommission As Boolean
        Dim crCommissionAmount As Decimal
        Dim crTaxOnCommissionAmount As Decimal
        'Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
        Dim iNoOfPreviousInstalments As Integer
        Dim crPreviousInstalmentsAmount As Decimal
        Dim v_vPremiumFinance(1, 0) As Object
        Dim crSettlementAmount As Decimal
        Dim crRefundAmount As Decimal
        Dim crFeeFinanceAmount As Decimal
        Dim dOldPlanInterestRate As Double
        Dim crTotalInterestAmount As Decimal
        Dim crPlanOs As Decimal
        Dim crRefundInterestAmount As Decimal

        result = gPMConstants.PMEReturnCode.PMTrue

        If Not Object.Equals(r_vQuoteArray(k_PFQuoteTotalAmountInput, v_lArrayCount), Nothing) Then

            crFinanceAmount = CDec(r_vQuoteArray(k_PFQuoteTotalAmountInput, v_lArrayCount))
        End If

        Dim iMTADayDiff As Integer = 0

        If m_sProductCode = "MTA" Then
            'We are to use the existing instalment dates

            If Not Object.Equals(r_vQuoteArray(k_PFQuoteFirstInstalmentDate, v_lArrayCount), Nothing) Then

                dtFirstInstalmentDate = CDate(r_vQuoteArray(k_PFQuoteFirstInstalmentDate, v_lArrayCount))
                If crFinanceAmount <> 0 AndAlso dtFirstInstalmentDate < m_dtStartDate Then
                    dtFirstInstalmentDate = m_dtStartDate
                    Dim dtOriginalFirstInstalmentDate As Date = CDate(r_vQuoteArray(k_PFQuoteFirstInstalmentDate, v_lArrayCount))

                End If
            End If

            If Not Object.Equals(r_vQuoteArray(k_PFQuoteNextInstalmentDate, v_lArrayCount), Nothing) Then

                dtNextInstalmentDate = CDate(r_vQuoteArray(k_PFQuoteNextInstalmentDate, v_lArrayCount))
            End If

            If Not Object.Equals(r_vQuoteArray(k_PFQuoteLastInstalmentDate, v_lArrayCount), Nothing) Then

                dtLastInstalmentDate = CDate(r_vQuoteArray(k_PFQuoteLastInstalmentDate, v_lArrayCount))
            End If

            If Informations.DateAdd(DateInterval.Day, v_lDaysDelay, m_dtStartDate) < dtFirstInstalmentDate Then
                dtStartDate = dtFirstInstalmentDate
            ElseIf Informations.DateAdd(DateInterval.Day, v_lDaysDelay, m_dtStartDate) > dtFirstInstalmentDate Then
                'dtFirstInstalmentDate = m_dtStartDate
                dtStartDate = m_dtStartDate
            ElseIf Informations.DateAdd(DateInterval.Day, v_lDaysDelay, m_dtStartDate) = dtFirstInstalmentDate Then
                dtStartDate = dtFirstInstalmentDate
            Else
                dtStartDate = m_dtStartDate
            End If
        Else
            dtStartDate = m_dtStartDate
        End If

        'dtStartDate = m_dtStartDate

        If m_sProductCode = "MTA" Then
            If m_iMTAType <> bSIRPremFinConst.m_klInstalmentMTAType_AddToNewPlan Then
                'Changing existing plan

                If gPMFunctions.ToSafeDouble(r_vQuoteArray(k_PFQuoteFrequencyID, v_lArrayCount)) <> m_lPFFrequencyId Then
                    If m_dtLastPaidInstalmentDate <> CDate("00:00:00") Then
                        'Some instalments have already been paid so start any adjustments from today
                        If CDate(m_dtStartDate.ToString("d")) < CDate(DateTime.Now.ToString("d")) Then
                            ' start date is in the past so start date calculations from today
                            dtStartDate = CDate(DateTime.Now.ToString("d"))
                        Else
                            dtStartDate = CDate(m_dtStartDate.ToString("d"))
                        End If

                    End If
                End If
            End If
        End If

        'GetTrue Monthly policy option from product risk maintenance.
        m_lReturn = gPMConstants.PMEReturnCode.PMTrue
        Dim bIsTrueMonthlyPolicy As String = String.Empty

        m_lReturn = GetProductRiskOption(m_lProductID, "is_true_monthly_policy", bIsTrueMonthlyPolicy)
        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            gPMFunctions.RaiseError("GetProductRiskOption", "is_true_monthly_policy:=" & bIsTrueMonthlyPolicy, gPMConstants.PMELogLevel.PMLogError)
        End If

        'system should considerthe monthly policy only if the flag is 1
        If Informations.DateDiff("m", m_dtStartDate, m_dtEndDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1) = 1 AndAlso v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference _
        AndAlso (m_sProductCode.ToUpper() = "REN" Or m_sProductCode.ToUpper() = "MTA") Then

            'Monthly policy aligned to customer preference
            m_lReturn = CalculateInstalmentDate4MonthlyPolicy(v_dtLastInstalmentDate:=m_dtLastInstalmentDate, v_iCustomerPreferredDay:=m_iDayOfWeekOrMonth, v_DaysDelay:=v_lDaysDelay, v_lStartLimit:=v_lStartLimit, r_dtOutputDate:=dtFirstInstalmentDate)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                gPMFunctions.RaiseError("CalculateInstalmentDate4MonthlyPolicy", "v_dtLastInstalmentDate:=" & m_dtLastInstalmentDate, gPMConstants.PMELogLevel.PMLogError)
            End If

            'Set the other dates
            dtNextInstalmentDate = dtFirstInstalmentDate
            dtLastInstalmentDate = dtFirstInstalmentDate

            iNoOfInstalmentsToPay = 1
        Else
            If v_lDayOfMonth = -1 Then
                'Do all the Date calculations

                m_lReturn = CalculateDates(v_dtStartDate:=dtStartDate, v_lDaysDelay:=v_lDaysDelay, v_lStartLimit:=v_lStartLimit,
                                           v_enAlignPremiumTo:=v_enAlignPremiumTo, v_iFrequencyAmount:=v_iFrequencyAmount, r_iNoOfInstalmentsToPay:=iNoOfInstalmentsToPay,
                                           r_iNoOfMissedInstalments:=iNoOfMissedInstalments, r_dtFirstInstalmentDate:=dtFirstInstalmentDate, r_dtNextInstalmentDate:=dtNextInstalmentDate,
                                           r_dtLastInstalmentDate:=dtLastInstalmentDate, v_bEnforcePreferredDate:=v_bEnforcePreferredDate, v_bPremiumFinance:=(gPMFunctions.ToSafeString(r_vQuoteArray(29, v_lArrayCount)) = "TP"),
                                           v_lInstalments:=v_lInstalments, v_crFinanceAmount:=crFinanceAmount, iChargeBackdatedToFirstInstalment:=v_iChargeBackdatedToFirstInstalment,
                                           v_iSingleInstalmentPerMonth:=gPMFunctions.ToSafeInteger(r_vQuoteArray(k_PFSingleInstalmentPerMonth, v_lArrayCount)),
                                           v_iFirstInstalmentAlignWithDayInMonth:=gPMFunctions.ToSafeInteger(r_vQuoteArray(k_PFFirstInstalmentAlignWithMonthInDay, v_lArrayCount)))

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                    gPMFunctions.RaiseError("CalculateDates", "v_dtStartDate:=" & dtStartDate, gPMConstants.PMELogLevel.PMLogError)
                End If
            Else


                iNoOfInstalmentsToPay = v_lInstalments
                dtFirstInstalmentDate = m_dtStartDate
                dtNextInstalmentDate = m_dtStartDate.AddMonths(1)
                'ACR 08-02-06 If the payment day is earlier than the first one
                '(ie payment day is 31st, next instalment is 28 for instance)
                'then default the next payment to the first of the month after
                If (dtNextInstalmentDate).Day <> (dtFirstInstalmentDate).Day Then
                    dtNextInstalmentDate = dtNextInstalmentDate.AddDays(1)
                End If

                If v_lInstalments > -1 Then
                    dtLastInstalmentDate = m_dtStartDate.AddMonths(v_lInstalments)
                Else
                    dtLastInstalmentDate = m_dtStartDate.AddMonths(12)
                End If

                'ACR 08-02-06 as above
                If (dtLastInstalmentDate).Day <> (dtFirstInstalmentDate).Day Then
                    dtLastInstalmentDate = dtLastInstalmentDate.AddDays(1)
                End If
            End If
        End If

        ' If we are not rolling up backdated instalments reset missed count
        If v_iChargeBackdatedToFirstInstalment = 0 Then
            iNoOfMissedInstalments = 0
        End If

        'Start (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
        bCalculateInstalmentsNetCommission = (v_iCalculateInstalmentsNetCommission = 1)

        'Now do the Deposit Calculations
        If bCalculateInstalmentsNetCommission Then
            m_lReturn = GetAgentCommission(v_lInsuranceFileCnt:=m_lInsuranceFileCnt, r_crCommissionAmount:=crCommissionAmount, r_crTaxOnCommissionAmont:=crTaxOnCommissionAmount)
            'PN61609
            If Not FinananceAmountNetPremium AndAlso Not bIsCallingFromSAM Then
                crFinanceAmount -= (crCommissionAmount + crTaxOnCommissionAmount)
                ' crFinanceAmount -= crCommissionAmount
            End If
            'Start - Sankar - PN 54268

            r_vQuoteArray(k_PFQuoteTotalAmountInput, v_lArrayCount) = crFinanceAmount
            'End - Sankar - PN 54268
        End If

        'End (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)

        If v_cDepositAmount > 0 Then
            crDepositAmount = v_cDepositAmount
        Else
            'Start PN: 56850-Prakash Varghese
            'If MTA and crFinanceAmount<0 then its a refund MTA. No need to calculate Deposit
            If m_sProductCode = "MTA" And crFinanceAmount < 0 Then
                'If v_oFinanceArray IsNot Nothing Then
                '    Dim crExistingDeposit As Decimal
                '    Dim bDepositAsInstalment As Boolean
                '    m_lReturn = CheckDeposit(v_lPremiumFinanceCnt:=v_oFinanceArray(0, 0), v_lPremiumFinancePlanVer:=v_oFinanceArray(1, 0), r_cDepositAmount:=crExistingDeposit, r_bDepositAsInstalment:=bDepositAsInstalment)
                '    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                '        gPMFunctions.RaiseError("CheckDeposit", "r_cDepositAmount:=" & crExistingDeposit, gPMConstants.PMELogLevel.PMLogError)
                '    End If

                '    If crExistingDeposit = 0 Then
                '        crDepositAmount = 0
                '    Else
                '        m_lReturn = CalculateDeposit(v_crAmount:=crFinanceAmount, v_enDepositType:=v_enDepositType, v_dDepositAmountOrPecentage:=v_dDepositAmountOrPecentage, r_crDepositAmount:=crDepositAmount)
                '        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                '            gPMFunctions.RaiseError("CalculateDeposit", "v_dDepositAmountOrPecentage:=" & v_dDepositAmountOrPecentage, gPMConstants.PMELogLevel.PMLogError)
                '        End If
                '    End If
                'End If
                crDepositAmount = 0
            Else
                If crTaxIncludedAndNotSpreadAcrossInInstalment > 0 And v_dDepositAmountOrPecentage > 0 Then

                    m_lReturn = CalculateDeposit(
                          v_crAmount:=crFinanceAmount - crTaxIncludedAndNotSpreadAcrossInInstalment,
                          v_enDepositType:=v_enDepositType,
                          v_dDepositAmountOrPecentage:=v_dDepositAmountOrPecentage,
                          r_crDepositAmount:=crDepositAmount)

                    crDepositAmount = crDepositAmount + crTaxIncludedAndNotSpreadAcrossInInstalment

                Else
                    m_lReturn = CalculateDeposit(v_crAmount:=crFinanceAmount, v_enDepositType:=v_enDepositType, v_dDepositAmountOrPecentage:=v_dDepositAmountOrPecentage, r_crDepositAmount:=crDepositAmount)
                End If
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("CalculateDeposit", "v_dDepositAmountOrPecentage:=" & v_dDepositAmountOrPecentage, gPMConstants.PMELogLevel.PMLogError)
                End If

                'End PN: 56850-Prakash Varghese
            End If
        End If
        crFeeFinanceAmount = crFinanceAmount

        If Not bApplyFeePercentagesToFees Then
            crFeeFinanceAmount = crFeeFinanceAmount - m_crPolicyRiskFeeAmount
        End If
        If Not bApplyFeePercentagesToTaxes Then
            crFeeFinanceAmount = crFeeFinanceAmount - m_crPolicyRiskTaxAmount
        End If

        If Informations.IsArray(v_oFinanceArray) AndAlso v_oFinanceArray IsNot Nothing Then
            dOldPlanInterestRate = v_oFinanceArray(bSIRPremFinConst.k_PFPlanInterestRate, 0)
        End If
        'Only get the interest if this is NOT a Backdated MTA
        If m_lBackDatedMTAType <> bSIRPremFinConst.PFIntermediateBDMTA Then
            If crFinanceAmount > 0 Then
                m_lReturn = CalculateInterest(v_crFinanceAmount:=crFeeFinanceAmount, v_dInterestRate:=v_dInterestRate, v_iDepositChargedTo:=v_iDepositChargedTo, v_crDepositAmount:=crDepositAmount, r_crInterestAmount:=crInterestAmount, v_bIsSG:=v_bIsSG, v_sQuoteSchemeName:=r_vQuoteArray(k_PFQuoteSchemeName, v_lArrayCount))
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("CalculateInterest", "v_dInterestRate:=" & v_dInterestRate, gPMConstants.PMELogLevel.PMLogError)
                End If
            ElseIf dOldPlanInterestRate > 0 Then ' Calculate refund interest amount on return MTA

                crTotalInterestAmount = v_oFinanceArray(bSIRPremFinConst.k_PFPlanInterestCost, 0)
                ' to get plan outstanding amount
                Dim oACTInstalments As New bACTInstalments.Business
                m_lReturn = oACTInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bACTInstalments.Business", gPMConstants.PMELogLevel.PMLogError)
                End If
                m_lReturn = oACTInstalments.GetPlanOS(v_lPlanTransDetailID:=v_oFinanceArray(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0), r_cOS:=crPlanOs)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("oACTInstalments.GetPlanOS", "v_lPlanTransDetailID:=" & gPMFunctions.ToSafeInteger(v_oFinanceArray(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)), gPMConstants.PMELogLevel.PMLogError)
                End If
                If crPlanOs > 0 Then
                    crRefundInterestAmount = crFinanceAmount * dOldPlanInterestRate / 100
                    If crTotalInterestAmount > crRefundInterestAmount AndAlso crPlanOs > crRefundInterestAmount Then
                        crInterestAmount = crRefundInterestAmount
                    End If
                End If
            End If

        Else
            crInterestAmount = 0
        End If

        'Check the interest against minimum interest amount
        If Not (False) AndAlso crFinanceAmount > 0 Then

            If crInterestAmount < v_cMinimumInterestAmount And crInterestAmount > 0 Then

                crInterestAmount = v_cMinimumInterestAmount

                'Calculate interest rate
                If v_iDepositChargedTo = 1 Then
                    ' To Avoid Division by Zero error
                    If (crFinanceAmount - crDepositAmount) = 0 Then
                        v_dInterestRate = 0
                    Else
                        v_dInterestRate = (v_cMinimumInterestAmount / (crFinanceAmount - crDepositAmount)) * 100
                    End If

                Else
                    ' To Avoid Division by Zero error
                    If crFinanceAmount = 0 Then
                        v_dInterestRate = 0
                    Else
                        v_dInterestRate = (v_cMinimumInterestAmount / crFinanceAmount) * 100
                    End If

                End If
                v_dInterestRate = gPMFunctions.ToSafeDouble(StringsHelper.Format(v_dInterestRate, "0.00"))

            End If

        End If

        'Work out the amount of Payment Protection Due
        ' No need to calculate protection amount on returm MTA
        If crFinanceAmount > 0 Then
            m_lReturn = CalculatePaymentProtection(v_crAmountForProtection:=(crFeeFinanceAmount - crDepositAmount + crInterestAmount + crTaxOnInterest), v_enProtectionType:=v_enProtectionType, v_dProtectionAmountOrPercentage:=v_dProtectionAmountOrPercentage, r_crProtectionAmount:=crProtectionAmount)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("CalculatePaymentProtection", "v_crAmountForProtection:=" & (gPMFunctions.ToSafeString(crFinanceAmount + crInterestAmount + crTaxOnInterest)), gPMConstants.PMELogLevel.PMLogError)
            End If
        End If
        'Work out the amount of the Fees
        'Fees are calculated on crFinanceAmount ONLY, and no interest, Tax or
        'Payment Protection is added onto them. Also Deposit does not take into account the Fees
        'Only get the fees if this is NOT a Backdated MTA
        If m_lBackDatedMTAType <> bSIRPremFinConst.PFIntermediateBDMTA Then
            ' No need to calculate fee amount on returm MTA
            If crFinanceAmount > 0 Then
                m_lReturn = CalculateFees(v_crFinanceAmount:=crFeeFinanceAmount, v_enFeeType:=v_enFeesType, v_dFeeAmountOrPercentage:=v_dFeesAmountOrPercentage, r_crFeesAmount:=crFeesAmount)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("CalculateFees", "v_crFinanceAmount:=" & crFinanceAmount, gPMConstants.PMELogLevel.PMLogError)
                End If
            End If
        Else
            crFeesAmount = 0
        End If

        'Tax is calulated on all additional charges (don't store the result now as nothing has been
        'saved in PFPremiumFinance yet)
        m_lReturn = CalculateTax(v_lTaxGroupID, v_iCurrencyID, crInterestAmount + crFeesAmount + crProtectionAmount, crTaxOnInterest, True)
        If crTaxIncludedAndNotSpreadAcrossInInstalment > 0 And crDepositAmount = 0 Then
            crFinanceAmount = crFinanceAmount - crTaxIncludedAndNotSpreadAcrossInInstalment
        End If

       ' If bCalculateInstalmentsNetCommission Then
       '     crFinanceAmount -= (crCommissionAmount + crTaxOnCommissionAmount)
     '   End If

        'Work out the amount of the first and subsequant instalments
        m_lReturn = CalculateInstalmentAmounts(v_crFinanceAmount:=crFinanceAmount, v_iNoOfInstalmentsToPay:=iNoOfInstalmentsToPay, v_iNoOfMissedInstalments:=iNoOfMissedInstalments, v_crDepositAmount:=crDepositAmount, v_crInterestAmount:=crInterestAmount, v_crTaxAmount:=crTaxOnInterest, v_crFeesAmount:=crFeesAmount, v_crProtectionAmount:=crProtectionAmount, v_iChargeTaxToFirstInstalment:=v_iChargeTaxToFirstInstalment, v_iChargeFeeToFirstInstalment:=v_iChargeFeeToFirstInstalment, v_iChargeProtectionToFirstInstalment:=v_iChargeProtectionToFirstInstalment, r_crFirstInstalmentAmount:=crFirstInstalmentAmount, r_crOtherInstalmentsAmount:=crOtherInstalmentAmount, v_bIsSG:=v_bIsSG, v_iCalculateInstalmentsNetCommission:=v_iCalculateInstalmentsNetCommission)
        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            gPMFunctions.RaiseError("CalculateInstalmentAmounts", "v_crFinanceAmount:=" & crFinanceAmount, gPMConstants.PMELogLevel.PMLogError)
        End If

        'Validate the minimum MTA per instalment amount
        If Math.Abs(crOtherInstalmentAmount) < v_cMinMTA And m_sProductCode = "MTA" Then
            gPMFunctions.RaiseError("crOtherInstalmentAmount < v_cMinMTA", "m_sProductCode = MTA", gPMConstants.PMELogLevel.PMLogError)
        End If
        If crTaxIncludedAndNotSpreadAcrossInInstalment > 0 And crDepositAmount = 0 Then
            crFirstInstalmentAmount = crFirstInstalmentAmount + crTaxIncludedAndNotSpreadAcrossInInstalment
        End If
        'Calculate Amount of All instalments
        If m_bIsSinglePlanParty Then


            m_lReturn = GetPreviousInstalments(v_lpfprem_finance_cnt:=m_lPremFinanceCnt,
                                                v_lpfprem_finance_version:=m_lPremFinanceVer,
                                                v_dDueDate:=m_dtStartDate,
                                                r_iNoPreviousInstalments:=iNoOfPreviousInstalments)

            m_lReturn = GetPreviousInstalmentsAmount(v_lpfprem_finance_cnt:=m_lPremFinanceCnt,
                                               v_lpfprem_finance_version:=m_lPremFinanceVer,
                                               v_dDueDate:=m_dtStartDate,
                                               r_crPreviousInstalmentsAmount:=crPreviousInstalmentsAmount)
            If iNoOfPreviousInstalments >= iNoOfInstalmentsToPay Then
                iNoOfPreviousInstalments = 0
                crPreviousInstalmentsAmount = 0
            End If

            crTotalInstalmentAmount = crFirstInstalmentAmount + (((iNoOfInstalmentsToPay - iNoOfPreviousInstalments) - 1) * crOtherInstalmentAmount) + crPreviousInstalmentsAmount
        Else
            crTotalInstalmentAmount = crFirstInstalmentAmount + ((iNoOfInstalmentsToPay - 1) * crOtherInstalmentAmount)
        End If
        If m_bIsSinglePlanParty And m_bMakeLiveSingleInstalmentPlan Then
            v_vPremiumFinance(k_PFPlanPFCnt, 0) = m_lPremFinanceCnt
            v_vPremiumFinance(k_PFPlanPFVersion, 0) = m_lPremFinanceVer
            m_lReturn = SettlePlanCalculate(v_vPremiumFinance:=v_vPremiumFinance,
                                                        r_crSettlement:=crSettlementAmount,
                                                        r_crRefund:=crRefundAmount)

            m_lReturn = GetPreviousInstalments(v_lpfprem_finance_cnt:=m_lPremFinanceCnt,
                                               v_lpfprem_finance_version:=m_lPremFinanceVer,
                                               v_dDueDate:=m_dtStartDate,
                                               r_iNoPreviousInstalments:=iNoOfPreviousInstalments)
            If iNoOfPreviousInstalments >= iNoOfInstalmentsToPay Then
                iNoOfPreviousInstalments = 0
            End If

            crTotalInstalmentAmount = crFirstInstalmentAmount + (((iNoOfInstalmentsToPay - iNoOfPreviousInstalments) - 1) * crOtherInstalmentAmount) + crSettlementAmount + crRefundAmount
        End If

        If v_bCalcAPR Then
            m_lReturn = CalculateAPR(cTotalIncludingInterest:=crTotalInstalmentAmount, dRate:=v_dInterestRate, iInstalments:=iNoOfInstalmentsToPay, r_dAprRate:=dAprRate)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("CalculateInstalmentAmounts", "v_crFinanceAmount:=" & crFinanceAmount, gPMConstants.PMELogLevel.PMLogError)
            End If
        Else
            dAprRate = v_dAPR
        End If

        'Populate the rest of the array

        r_vQuoteArray(k_PFQuoteInstalmentsToPay, v_lArrayCount) = iNoOfInstalmentsToPay

        r_vQuoteArray(k_PFQuoteFirstInstalmentDate, v_lArrayCount) = dtFirstInstalmentDate

        r_vQuoteArray(k_PFQuoteLastInstalmentDate, v_lArrayCount) = dtLastInstalmentDate

        r_vQuoteArray(k_PFQuoteNextInstalmentDate, v_lArrayCount) = dtNextInstalmentDate

        r_vQuoteArray(k_PFQuoteFirstInstalmentAmount, v_lArrayCount) = crFirstInstalmentAmount

        r_vQuoteArray(k_PFQuoteOtherInstalmentAmount, v_lArrayCount) = crOtherInstalmentAmount

        r_vQuoteArray(k_PFQuoteTotalInstalmentsAmount, v_lArrayCount) = crTotalInstalmentAmount
        If dAprRate > 0 Then

            r_vQuoteArray(k_PFQuoteAprRate, v_lArrayCount) = dAprRate
        End If
        If v_dInterestRate > 0 Then

            r_vQuoteArray(k_PFQuoteInterestRate, v_lArrayCount) = v_dInterestRate
        End If

        r_vQuoteArray(k_PFQuoteDaysDelay, v_lArrayCount) = v_lDaysDelay
        r_vQuoteArray(k_PFStartLimit, v_lArrayCount) = v_lStartLimit

        r_vQuoteArray(k_PFQuoteDepositAmount, v_lArrayCount) = crDepositAmount

        r_vQuoteArray(k_PFQuoteInterestAmount, v_lArrayCount) = crInterestAmount

        r_vQuoteArray(k_PFQuoteTaxAmount, v_lArrayCount) = crTaxOnInterest

        r_vQuoteArray(k_PFQuoteFinanceCharge, v_lArrayCount) = crFeesAmount

        r_vQuoteArray(k_PFQuoteProtectionAmount, v_lArrayCount) = crProtectionAmount

        r_vQuoteArray(k_PFStartDate, v_lArrayCount) = dtStartDate

        r_vQuoteArray(k_PFDelayULimit, v_lArrayCount) = v_lStartLimit

        Return result
    End Function

    ''' <summary>
    ''' To Get the Product risk value for true Monthly policy
    ''' </summary>
    ''' <param name="nProduct_id"></param>
    ''' <param name="sColumnName"></param>
    ''' <param name="sValue"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function GetProductRiskOption(ByVal nProduct_id As Integer, ByVal sColumnName As String, ByRef sValue As String) As Integer

        Const kMethodName As String = "GetTrueMonthlyOption"
        Dim aoResultArray As Object = Nothing
        Try

            m_oDatabase.Parameters.Clear()
            m_lReturn = AddInputParameter(v_sName:="product_id", v_vValue:=nProduct_id, v_iType:=gPMConstants.PMEDataType.PMInteger)
            m_lReturn = AddInputParameter(v_sName:="column_name", v_vValue:=sColumnName, v_iType:=gPMConstants.PMEDataType.PMString)

            m_lReturn = m_oDatabase.SQLSelect(
                                    sSQL:=kProductRiskOptionSQL,
                                    sSQLName:=kProductRiskOptionSQLName,
                                    bStoredProcedure:=True,
                                    vResultArray:=aoResultArray)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                m_lReturn = gPMConstants.PMEReturnCode.PMFalse
            Else
                If Informations.IsArray(aoResultArray) Then
                    sValue = ToSafeString(aoResultArray(0, 0))
                End If
            End If

            Return m_lReturn


        Catch excep As System.Exception
            m_lReturn = gPMConstants.PMEReturnCode.PMFalse
            bPMFunc.LogError(
                 v_sUsername:=m_sUsername,
                 v_sClass:=ACClass,
                 v_sMethod:=kMethodName,
                 r_lFunctionReturn:=GetProductRiskOption)

            Return m_lReturn

        End Try
    End Function

    '*************************************************************************
    'Name:          CalculateSecondInstalmentDate
    'Description:   Works out the date of 2d instalments, depending on if
    '               we want to align it on the anniversary of the policy or
    '               of the first instalments.
    'History:       Alix Bergeret - 25/03/2003
    '*************************************************************************
    Private Function CalculateSecondInstalmentDate(ByVal v_dtInputDate As Date, ByVal v_iFrequencyAmount As Integer,
                                                   ByVal v_enWhichDirection As WhichDirection, ByRef r_dtOutputDate As Date,
                                                   ByVal v_enAlignPremiumTo As AlignPremiumToOptions,
                                                   ByVal v_iSingleInstalmentPerMonth As Integer) As Integer

        Dim result As Integer = 0
        Dim dtDate As Date
        Dim iCount As Integer



        ' Alix - Work out which date we start from
        If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
            ' Alix - Start on first instalment's date
            dtDate = v_dtInputDate
            ' Alix - If prefered day is greater than 1st instalment day
            If m_sVBFrequencyInterval = "m" And v_iFrequencyAmount = 1 Then
                If m_iDayOfWeekOrMonth > (v_dtInputDate).Day Then
                    If v_iSingleInstalmentPerMonth = 0 And m_iDayOfWeekOrMonth > System.DateTime.DaysInMonth((dtDate.Year), (dtDate.AddMonths(-1).Month)) Then
                        dtDate = dtDate.AddMonths(-1)
                    End If
                End If
            End If
        ElseIf (m_dtStartDate).Day = 31 Then
            dtDate = m_dtStartDate
        Else
            ' Alix - Start on policy start's date
            dtDate = m_dtCoverStartDate
        End If

        iCount = 0
        r_dtOutputDate = dtDate
        Do While r_dtOutputDate <= v_dtInputDate And iCount < 1000 ' to avoid blockage

            ' Alix - Match date on policy renewal date
            m_lReturn = CalculateNextOrPrevInstalment(dtDate, v_iFrequencyAmount * (iCount + 1), WhichDirection.MovingForwards, r_dtOutputDate, v_enAlignPremiumTo, False, v_iSingleInstalmentPerMonth)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If
            iCount += 1
        Loop

        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    '*************************************************************************
    'Name:          CalculateDates
    'Description:   Works out the various dates required
    'History:       TR071102 - Created as per TS23  Section 4.2.1.1.1
    '
    'DD 24/06/2003: Added Premium Finance parameter to overide last date logic
    ' RAW 13/11/2003 : CQ1765 : added ByVal v_dtStartDate param
    '*************************************************************************
    Private Function CalculateDates(ByVal v_dtStartDate As Date,
                                    ByVal v_lDaysDelay As Integer,
                                       ByVal v_lStartLimit As Integer,
                                       ByVal v_enAlignPremiumTo As AlignPremiumToOptions,
                                       ByVal v_iFrequencyAmount As Integer,
                                       ByRef r_iNoOfInstalmentsToPay As Integer,
                                       ByRef r_iNoOfMissedInstalments As Integer,
                                       ByRef r_dtFirstInstalmentDate As Date,
                                       ByRef r_dtNextInstalmentDate As Date,
                                       ByRef r_dtLastInstalmentDate As Date,
                                       Optional ByVal v_bEnforcePreferredDate As Boolean = False,
                                       Optional ByVal v_bPremiumFinance As Boolean = False,
                                       Optional ByVal v_lInstalments As Integer = -1,
                                       Optional ByVal v_crFinanceAmount As Decimal = 0,
                                       Optional ByVal iChargeBackdatedToFirstInstalment As Integer = 0,
                                       Optional ByVal v_iSingleInstalmentPerMonth As Integer = 0,
                                       Optional ByVal v_iFirstInstalmentAlignWithDayInMonth As Integer = 0) As Integer

        Dim result As Integer = 0
        Dim dtFirstPossibleDateFromToday, dtLastPossibleDateFromToday, dtFirstPossibleDateFromStartDate, dtStartDate As Date

        'TR - The Number of Instalments due between the Next and the last (inclusive)
        Dim iNoOfOtherInstalments As Integer
        'TR - The Number of Instalments missed, between Policy StartDate
        '(plus setup delay) and the FirstInstalmentDate, and the Date of
        'the first, guaranteed to match m_iDayOfWeek or m_iDayInMonth.
        Dim dtOverdueFirstInstalmentDate As Date
        Dim lOriginalInstalmentsRemaining As Integer
        Dim v_enWhichDirection As WhichDirection
        Dim bIsAllInstalmentsMissed As Boolean

        If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
            v_enWhichDirection = WhichDirection.MovingForwards
        ElseIf v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithPolicyRenewalDate Then
            v_enWhichDirection = WhichDirection.MovingBackwards
        End If



        m_lReturn = gPMConstants.PMEReturnCode.PMTrue

        ' RAW 13/11/2003 : CQ1765 : added
        If CDate(v_dtStartDate.ToString("d")) < CDate(DateTime.Now.ToString("d")) Then
            ' start date is in the past so start date calculations from today
            dtStartDate = CDate(DateTime.Now.ToString("d"))
        Else
            dtStartDate = CDate(v_dtStartDate.ToString("d"))
        End If
        ' RAW 13/11/2003 : CQ1765 : end

        '===============================
        'CALCULATE FIRST INSTALMENT DATE
        '===============================
        'TR - First see if the Preferred Date MUST be the First Instalment
        'Date (relevant for Renewals ONLY)
        ' RAW 05/11/2003 : CQ2912, 2976 : do not overwrite date if a value has been passed in
        If r_dtFirstInstalmentDate = CDate("00:00:00") Or (v_bEnforcePreferredDate And Informations.IsDate(gPMFunctions.ToSafeDate(m_dtPreferredDate)) And m_dtPreferredDate <> r_dtFirstInstalmentDate) Then

            '        If v_bEnforcePreferredDate = True And m_dtPreferredDate > v_dtStartDate Then
            '                r_dtFirstInstalmentDate = m_dtPreferredDate
            '        Else
            'TR - Calculate the first and last possible days for the First Instalment...
            'IR - 10 Jul 2003 (ClearQuest ref ENDVR00000372)
            '   -       ...using the cover start date as base, not today's date!

            ' RAW 13/11/2003 : CQ1765 : replaced  m_dtStartDate with dtStartDate
            'Start - Sankar - PN 54991
            If m_sProductCode = "MTA" And v_bEnforcePreferredDate And r_dtFirstInstalmentDate <> CDate("00:00:00") And r_dtFirstInstalmentDate >= CDate(DateTime.Now.ToString("d")) Then

                dtFirstPossibleDateFromToday = Informations.DateAdd("w", v_lDaysDelay, CDate(r_dtFirstInstalmentDate.ToString("d"))) ' Now, vbShortDate))
                dtLastPossibleDateFromToday = Informations.DateAdd("w", v_lStartLimit, CDate(r_dtFirstInstalmentDate.ToString("d"))) ' Now, vbShortDate))

            Else
                dtFirstPossibleDateFromToday = Informations.DateAdd("w", v_lDaysDelay, CDate(dtStartDate.ToString("d"))) ' Now, vbShortDate))
                dtLastPossibleDateFromToday = Informations.DateAdd("w", v_lStartLimit, CDate(dtStartDate.ToString("d"))) ' Now, vbShortDate))
            End If
            'End - Sankar - PN 54991
            ' RAW 13/11/2003 : CQ1765 : end

            'TR - See if Customer's Preferred First Instalment Date falls within these 2
            If v_iFirstInstalmentAlignWithDayInMonth = 1 Then

                r_dtFirstInstalmentDate = dtFirstPossibleDateFromToday
                Do Until (r_dtFirstInstalmentDate).Day = m_iDayInMonth OrElse r_dtFirstInstalmentDate >= dtLastPossibleDateFromToday _
                    OrElse (m_iDayInMonth > System.DateTime.DaysInMonth((dtFirstPossibleDateFromToday.Year), (dtFirstPossibleDateFromToday.Month)) AndAlso (r_dtFirstInstalmentDate).Day = 1 AndAlso r_dtFirstInstalmentDate <> dtFirstPossibleDateFromToday)
                    r_dtFirstInstalmentDate = Informations.DateAdd("d", 1, r_dtFirstInstalmentDate)
                Loop
            ElseIf dtFirstPossibleDateFromToday <= m_dtPreferredDate AndAlso
                 dtLastPossibleDateFromToday >= m_dtPreferredDate AndAlso
                 v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
                'TR - Ok, let the Preferred date stand
                r_dtFirstInstalmentDate = m_dtPreferredDate

            Else
                'TR - Otherwise, use the first possible date
                r_dtFirstInstalmentDate = dtFirstPossibleDateFromToday
            End If
            '        End If

            If m_dtStartDate <= m_dtPreferredDate And v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithPolicyRenewalDate Then
                'r_dtFirstInstalmentDate = m_dtPreferredDate
                r_dtFirstInstalmentDate = r_dtFirstInstalmentDate
            ElseIf m_dtStartDate <= m_dtPreferredDate And v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
                r_dtFirstInstalmentDate = m_dtPreferredDate

            End If
        End If
        Dim bIsTrueMonthlyPolicy, bIsAnniversaryCopy As Boolean
        m_oDatabase.Parameters.Clear()

        If gPMFunctions.NullToLong(m_lInsuranceFileCnt) <> 0 Then
            m_oDatabase.Parameters.Add("insurance_file_cnt", gPMFunctions.ToSafeInteger(m_lInsuranceFileCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            m_oDatabase.Parameters.Add("is_true_monthly_policy", 0, gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMLong)
            m_oDatabase.Parameters.Add("anniversary_copy", 0, gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMLong)

            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACCheckIsTrueMonthlyPolicySQL, sSQLName:=ACCheckIsTrueMonthlyPolicyName, bStoredProcedure:=ACCheckIsTrueMonthlyPolicyStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            bIsTrueMonthlyPolicy = Not (m_oDatabase.Parameters.Item("is_true_monthly_policy").Value = 0)
            bIsAnniversaryCopy = Not (m_oDatabase.Parameters.Item("anniversary_copy").Value = 0)

        End If

        m_oDatabase.Parameters.Clear()

        If r_dtFirstInstalmentDate > m_dtEndDate AndAlso bIsTrueMonthlyPolicy = False Then
            r_dtFirstInstalmentDate = CDate(DateTime.Now.ToString("d"))
        End If
        '============================================
        'CALCULATE NO OF INSTALMENTS DUE BEFORE FIRST
        '============================================
        If ((m_lReturn = gPMConstants.PMEReturnCode.PMTrue AndAlso m_sProductCode <> "MTA") AndAlso CDate(v_dtStartDate.ToString("d")) < CDate(DateTime.Now.ToString("d")) AndAlso Informations.DateDiff("m", m_dtStartDate, m_dtEndDate, DayOfWeek.Sunday, FirstWeekOfYear.FirstJan1) > 1) AndAlso iChargeBackdatedToFirstInstalment = 1 Then
            'TR - Work out the Day before the First Possible instalment date
            'from the Policy Start date + Delay Days
            ' RAW 13/11/2003 : CQ1765 : replaced m_dtStartDate with dtStartDate
            If v_lDaysDelay > 0 Then
                dtFirstPossibleDateFromStartDate = Informations.DateAdd("w", v_lDaysDelay - 1, v_dtStartDate)
            Else
                dtFirstPossibleDateFromStartDate = v_dtStartDate
            End If
            'TR - Get the first Instalment Date if this Quote had been asked
            'for on the policy start date, and the number of missed
            'instalments between this date and the actual first date
            m_lReturn = CalculateNoOfInstalments(dtFirstPossibleDateFromStartDate, r_dtFirstInstalmentDate, v_iFrequencyAmount, v_enWhichDirection, r_iNoOfMissedInstalments, v_enAlignPremiumTo, dtOverdueFirstInstalmentDate)
        End If

        'Start - Sankar - PN 54991
        'Added this code as the No. of Installments Paid should also be considered
        'in calculating max no. of installments during MTA
        If m_sProductCode = "MTA" AndAlso (m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread OrElse m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_NoAmountChange) Then

            m_lReturn = GetInstalmentsRemaining(v_lpfprem_finance_cnt:=m_lPremFinanceCnt, v_lpfprem_finance_version:=m_lPremFinanceVer, r_lNoInstalments:=lOriginalInstalmentsRemaining)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("GetInstalmentsRemaining Failed", gPMFunctions.ToSafeString(gPMConstants.PMELogLevel.PMLogError))
            End If
            'This should never cross max no. of instalments set against MTA rate even with Add and spread setting
            'The onus is onto client to configure rates with proportionate setting
            If m_lMaXNoOfInstalments > lOriginalInstalmentsRemaining AndAlso lOriginalInstalmentsRemaining <> 0 Then
                m_lMaXNoOfInstalments = lOriginalInstalmentsRemaining
            End If
            'm_lMaXNoOfInstalments = m_lMaXNoOfInstalments = lPaidInstallments
        End If
        'End - Sankar - PN 54991

        'Update the MaxNoOfInstalments
        If m_lMaXNoOfInstalments > 0 Then
            If m_lMaXNoOfInstalments = 1 And r_iNoOfMissedInstalments = 1 Then
                'Do Nothing(This is the Scenario for Annual Plan (backdated)
            ElseIf m_lMaXNoOfInstalments = r_iNoOfMissedInstalments Then
                m_lMaXNoOfInstalments -= r_iNoOfMissedInstalments
                bIsAllInstalmentsMissed = True
            Else
                m_lMaXNoOfInstalments -= r_iNoOfMissedInstalments
            End If
        End If

        '==============================
        'CALCULATE NEXT INSTALMENT DATE
        '==============================
        ' Alix Bergeret - 25/03/2003 - Issue 2914
        ' If we have more than 2 installments then we calculate....
        ' RAW 05/11/2003 : CQ2912, 2976 : do not overwrite date if a value has been passed in
        Dim dtTempSatrtDate As Date = m_dtStartDate
        If m_sProductCode = "MTA" AndAlso m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread Then
            If r_dtNextInstalmentDate <= m_dtStartDate And v_crFinanceAmount <> 0 And r_dtFirstInstalmentDate <> r_dtLastInstalmentDate Then
                 m_lReturn = CalculateSecondInstalmentDate(r_dtFirstInstalmentDate, v_iFrequencyAmount, v_enWhichDirection, r_dtNextInstalmentDate, v_enAlignPremiumTo, v_iSingleInstalmentPerMonth)
             End If

        Else
          If r_dtNextInstalmentDate = CDate("00:00:00") Or (v_bEnforcePreferredDate And Informations.IsDate(gPMFunctions.ToSafeDate(m_dtPreferredDate)) Or r_dtNextInstalmentDate < m_dtStartDate And m_sProductCode = "MTA") Then 'm_dtPreferredDate <> r_dtFirstInstalmentDate

            If m_lMaXNoOfInstalments >= ACNextDateForceCalculate Or (m_lMaXNoOfInstalments = ACNoMaxNoOfInstalmentsSet AndAlso Not bIsAllInstalmentsMissed) Then
                m_lReturn = CalculateSecondInstalmentDate(r_dtFirstInstalmentDate, v_iFrequencyAmount, v_enWhichDirection, r_dtNextInstalmentDate, v_enAlignPremiumTo, v_iSingleInstalmentPerMonth)
            Else
                ' DD 12/11/2003 : CQ3182 : added
                ' There are no more instalments.
                r_dtNextInstalmentDate = r_dtFirstInstalmentDate 'PN44356--SS
            End If
          ElseIf r_dtNextInstalmentDate <> CDate("00:00:00") AndAlso dtTempSatrtDate.AddDays(v_lDaysDelay) <= r_dtNextInstalmentDate Then
            If m_lMaXNoOfInstalments >= ACNextDateForceCalculate Or (m_lMaXNoOfInstalments = ACNoMaxNoOfInstalmentsSet AndAlso Not bIsAllInstalmentsMissed) Then
                m_lReturn = CalculateSecondInstalmentDate(r_dtFirstInstalmentDate, v_iFrequencyAmount, v_enWhichDirection, r_dtNextInstalmentDate, v_enAlignPremiumTo, v_iSingleInstalmentPerMonth)
            End If
          End If
        End If 
        ' /Alix       

        If r_dtNextInstalmentDate = m_dtStartDate Or r_dtNextInstalmentDate < r_dtFirstInstalmentDate Or r_dtNextInstalmentDate = m_dtEndDate Then
            ' There are no more instalments.
            r_dtNextInstalmentDate = r_dtFirstInstalmentDate
            r_dtLastInstalmentDate = r_dtFirstInstalmentDate
        End If

        If r_dtNextInstalmentDate <= m_dtStartDate And v_crFinanceAmount > 0 And r_dtNextInstalmentDate <> r_dtFirstInstalmentDate Then
            m_lReturn = CalculateSecondInstalmentDate(r_dtFirstInstalmentDate, v_iFrequencyAmount, v_enWhichDirection, r_dtNextInstalmentDate, v_enAlignPremiumTo, v_iSingleInstalmentPerMonth)
        End If
        '==============================
        'CALCULATE LAST INSTALMENT DATE
        '==============================
        If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
            ' RAW 05/11/2003 : CQ2912, 2976 : do not overwrite date if a value has been passed in
            If r_dtLastInstalmentDate = CDate("00:00:00") Or (v_bEnforcePreferredDate And Informations.IsDate(gPMFunctions.ToSafeDate(m_dtPreferredDate)) Or r_dtLastInstalmentDate < m_dtStartDate And m_sProductCode = "MTA") Then

                If m_lMaXNoOfInstalments >= ACLastDateForceCalculate Or (m_lMaXNoOfInstalments = ACNoMaxNoOfInstalmentsSet AndAlso Not bIsAllInstalmentsMissed) Then
                    m_lReturn = CalculateLastInstalmentDate(v_enAlignPremiumTo, r_dtNextInstalmentDate, v_iFrequencyAmount, r_dtLastInstalmentDate, v_bPremiumFinance, v_lInstalments, v_iSingleInstalmentPerMonth)
                    'TR - Check that the last instalment date is after the "next"
                    If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                        If r_dtLastInstalmentDate < r_dtNextInstalmentDate Then
                            r_dtLastInstalmentDate = r_dtNextInstalmentDate
                        End If
                    End If
                Else
                    ' We set the lastinstalmentdate to the nextinstalment date if the Maximum # of instalments =2
                    If r_dtLastInstalmentDate < r_dtNextInstalmentDate Then
                        r_dtLastInstalmentDate = r_dtNextInstalmentDate
                    End If
                End If
                If r_dtLastInstalmentDate > m_dtEndDate Then
                    r_dtLastInstalmentDate = r_dtNextInstalmentDate
                End If
            End If
            If v_enAlignPremiumTo = Business.AlignPremiumToOptions.AlignWithClientPreference Then
                If m_sVBFrequencyInterval = "m" AndAlso r_dtNextInstalmentDate.Month = r_dtLastInstalmentDate.Month AndAlso r_dtNextInstalmentDate > r_dtLastInstalmentDate Then
                    If m_iDayOfWeekOrMonth = r_dtNextInstalmentDate.Month AndAlso (v_iSingleInstalmentPerMonth <> 1 OrElse m_iDayOfWeekOrMonth > System.DateTime.DaysInMonth((r_dtNextInstalmentDate.Year), (r_dtNextInstalmentDate.AddMonths(-1).Month))) Then
                        r_dtNextInstalmentDate = r_dtLastInstalmentDate
                    End If
                End If
            End If
        End If

        '===================================================================
        'CALCULATE NO OF INSTALMENTS BETWEEN NEXTINSTALMENT & LASTINSTALMENT
        '===================================================================
        If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then

            'TR - Is the date of the "Next" instalment after the policy end date?
            If r_dtNextInstalmentDate > m_dtEndDate Then
                'TR - The next instalment date calculated is invalid, so do not include
                'TR - The Last instalment is also invalid, so do not include this either
                If r_dtLastInstalmentDate > m_dtEndDate Then
                    iNoOfOtherInstalments = 0
                    ' There are no more instalments.
                    r_dtNextInstalmentDate = r_dtFirstInstalmentDate
                    r_dtLastInstalmentDate = r_dtFirstInstalmentDate
                Else
                    'TR - The next instalment date calculated is invalid, so do not include
                    iNoOfOtherInstalments = 1
                End If
                ' DD 12/11/2003 : CQ3182 : added
            ElseIf r_dtFirstInstalmentDate = r_dtNextInstalmentDate And r_dtNextInstalmentDate = r_dtLastInstalmentDate Then
                'DD There is only one instalment so set no further instalments to create
                iNoOfOtherInstalments = 0
            ElseIf r_dtNextInstalmentDate = r_dtLastInstalmentDate Then
                'TR - Next and last instalment on the same date - so only count once
                iNoOfOtherInstalments = 1
                'Is the date of the first instalment after the policy end date?
            ElseIf r_dtNextInstalmentDate > r_dtLastInstalmentDate Then
                iNoOfOtherInstalments = 0

            ElseIf r_dtFirstInstalmentDate > m_dtEndDate Then
                iNoOfOtherInstalments = 0
            Else
                m_lReturn = CalculateNoOfInstalments(r_dtFirstInstalmentDate, r_dtLastInstalmentDate, v_iFrequencyAmount, v_enWhichDirection, iNoOfOtherInstalments, v_enAlignPremiumTo, v_iSingleInstalmentPerMonth:=v_iSingleInstalmentPerMonth)
                'TR - If this worked, add on the Next and Last instalments
                If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                    iNoOfOtherInstalments += 1
                End If
            End If
        End If

        '=================================
        'CALCULATE TOTAL NO OF INSTALMENTS
        '=================================
        If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
            r_iNoOfInstalmentsToPay = iNoOfOtherInstalments + 1
        End If

        If m_lMaXNoOfInstalments > 0 AndAlso r_iNoOfInstalmentsToPay > m_lMaXNoOfInstalments Then
            r_iNoOfInstalmentsToPay = m_lMaXNoOfInstalments
        End If
        'TR - Set return value
        Return m_lReturn

    End Function

    '*************************************************************************
    'Name:          CalculateDeposit
    'Description:   Works out the various the Deposit payable on the amount
    'History:       TR071102 - Created as per TS23  Section 4.2.1.1.2
    '*************************************************************************
    Private Function CalculateDeposit(ByVal v_crAmount As Decimal, ByVal v_enDepositType As CalculationType, ByVal v_dDepositAmountOrPecentage As Double, ByRef r_crDepositAmount As Decimal) As Integer

        Dim result As Integer = 0


        'TR - Assume failure
        result = gPMConstants.PMEReturnCode.PMFail

        '=====================
        'CALCULATE THE DEPOSIT
        '=====================
        'TR - What type of deposit does this PFRF have?
        If v_enDepositType = Business.CalculationType.CalculationTypeAmount Then
            r_crDepositAmount = v_dDepositAmountOrPecentage
            If m_iUseTransCurrency = 1 Then
                r_crDepositAmount = gPMFunctions.ToSafeRound(r_crDepositAmount / m_dCurrencyXRate, k_RoundingFormatUpTo, IsSuppressDecimalValues)
            End If
        ElseIf v_enDepositType = Business.CalculationType.CalculationTypePercentage Then
            If v_dDepositAmountOrPecentage > 0 Then
                r_crDepositAmount = gPMFunctions.ToSafeRound((v_crAmount * v_dDepositAmountOrPecentage / 100), k_RoundingFormatUpTo, IsSuppressDecimalValues)
            Else
                r_crDepositAmount = 0
            End If
        End If

        'TR - Set return value
        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    '*************************************************************************
    'Name:          CalculateInterestRate
    'Description:   Works out the Interest Rate Payable
    'History:       TR271102 - Created as per TS23  Section 4.2.1.1.3
    ' RAW 13/11/2003 : CQ1765 : add v_crFinanceAmount param
    '*************************************************************************
    Private Function CalculateInterestRate(ByVal v_crFinanceAmount As Decimal, ByVal v_vArrayOfPFRFs(,) As Object, ByVal v_lPFRFIndex As Integer, ByRef r_dInterestRate As Double) As Integer

        'TR - Declare local variables
        Dim result As Integer = 0
        Dim dMinimumInterest As Double
        Dim iRangeStart, iRangeCount As Integer
        Dim bRateFound As Boolean
        Dim crRangeMinimum, crRangeMaximum As Decimal



        'TR - Assume Success
        result = gPMConstants.PMEReturnCode.PMTrue

        'TR - Get the correct Interest Rate Range for this Total Amount
        'TR - First Check if the User has entered a Manual Interest Rate
        If m_dInterestOverrideRate > -1 Then
            r_dInterestRate = m_dInterestOverrideRate
        Else
            'TR - Using either the Default OR Alternative Interest
            'Rates from the PFRF table
            iRangeStart = 15
            iRangeCount = 1
            bRateFound = False
            'TR - Go through the ranges one at a time until a valid one is found
            Do Until bRateFound Or iRangeCount > 5
                crRangeMinimum = gPMFunctions.NullToDouble(v_vArrayOfPFRFs(iRangeStart, v_lPFRFIndex))
                crRangeMaximum = gPMFunctions.NullToDouble(v_vArrayOfPFRFs(iRangeStart + 1, v_lPFRFIndex))

                If v_crFinanceAmount >= crRangeMinimum And v_crFinanceAmount <= crRangeMaximum Then
                    'TR - Using the Default Rates
                    If Not m_bOverrideCommission Then
                        'TR - Apply minimum to Default Rates Only
                        dMinimumInterest = gPMFunctions.NullToDouble(v_vArrayOfPFRFs(12, v_lPFRFIndex))
                        r_dInterestRate = gPMFunctions.NullToDouble(v_vArrayOfPFRFs(iRangeStart + 2, v_lPFRFIndex))
                        'MKW 090604 PN12381 Minimum Interest is amount not percentage.
                        'If r_dInterestRate < dMinimumInterest Then
                        '    r_dInterestRate = dMinimumInterest
                        'End If
                    Else
                        r_dInterestRate = gPMFunctions.NullToDouble(v_vArrayOfPFRFs(iRangeStart + 3, v_lPFRFIndex))
                    End If
                    bRateFound = True
                End If
                iRangeStart += 5
                iRangeCount += 1
            Loop
            'TR - Return PMTrue if no rate is found for thuis amount, as this
            'is not an error, but we do not want to conitnue processing this PFRF
            If Not bRateFound Then
                'if rate not found set default rate to 0.
                r_dInterestRate = 0
                result = gPMConstants.PMEReturnCode.PMTrue
            End If
        End If

        Return result

    End Function

    '*************************************************************************
    'Name:          CalculateInterest
    'Description:   Works out the Interest Payable on the amount that has
    '               interest charged on it.
    'History:       TR071102 - Created as per TS23  Section 4.2.1.1.3
    '*************************************************************************
    Private Function CalculateInterest(ByVal v_crFinanceAmount As Decimal, ByVal v_dInterestRate As Double, ByVal v_iDepositChargedTo As Integer, ByVal v_crDepositAmount As Decimal, ByRef r_crInterestAmount As Decimal, Optional ByVal v_bIsSG As Boolean = False, Optional ByVal v_sQuoteSchemeName As String = "") As Integer

        'TR - Declare local variables
        Dim result As Integer = 0
        Dim crAmountToChargeInterestOn As Decimal



        'TR - Assume failure
        result = gPMConstants.PMEReturnCode.PMFail

        '===================================================
        'DETERMINE THE AMOUNT TO HAVE INTEREST CHARGED ON IT
        '===================================================
        'TR - Check if the Deposit has interest charged on it or not
        'PN13972
        '    If v_iDepositChargedTo = 1 Then
        '        crAmountToChargeInterestOn = v_crFinanceAmount - v_crDepositAmount
        '    Else
        '        crAmountToChargeInterestOn = v_crFinanceAmount
        '    End If
        If v_iDepositChargedTo = 1 Then
            crAmountToChargeInterestOn = v_crFinanceAmount
        Else
            If v_sQuoteSchemeName.ToUpper() = "CLOSEIP" And v_bIsSG Then
                crAmountToChargeInterestOn = v_crFinanceAmount
            Else
                crAmountToChargeInterestOn = v_crFinanceAmount - v_crDepositAmount
            End If

        End If
        'PN13972End
        '======================
        'CALCULATE THE INTEREST
        '======================
        r_crInterestAmount = crAmountToChargeInterestOn * (v_dInterestRate / 100)

        ' RAW 05/11/2003 : CQ2912, 2976 : added
        r_crInterestAmount = gPMFunctions.ToSafeRound(r_crInterestAmount, k_RoundingFormatUpTo, IsSuppressDecimalValues)


        'TR - Set return value
        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    '*************************************************************************
    'Name:          CalculateTax
    'Description:   Works out the Instalment Tax Payable on an amount
    'Author:        Danny Davis
    'Date:          06-03-2006
    '*************************************************************************
    Private Function CalculateTax(ByVal lTaxGroupID As Integer, ByVal iCurrencyID As Integer, ByVal crTaxableAmount As Decimal, ByRef r_crTaxAmount As Decimal, ByVal bCalculateOnly As Boolean, Optional ByVal lInsuranceFileCnt As Integer = 0, Optional ByVal lPFPremFinanceCnt As Integer = 0, Optional ByVal lPFPremFinanceVersion As Integer = 0) As Integer

        Dim result As Integer = 0

        result = gPMConstants.PMEReturnCode.PMTrue

        If crTaxableAmount <> 0 Then
            bPMAddParameter.AddParameterLite(m_oDatabase, "company_id", m_lSourceID, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger, True)
            bPMAddParameter.AddParameterLite(m_oDatabase, "tax_group_id", lTaxGroupID, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            bPMAddParameter.AddParameterLite(m_oDatabase, "transtype", "TTI", gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMString)
            bPMAddParameter.AddParameterLite(m_oDatabase, "currency_id", iCurrencyID, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            bPMAddParameter.AddParameterLite(m_oDatabase, "amount", crTaxableAmount, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMCurrency)

            bPMAddParameter.AddParameterLite(m_oDatabase, "tax_currency_amount", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMCurrency)

            bPMAddParameter.AddParameterLite(m_oDatabase, "tax_base_amount", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMCurrency)

            bPMAddParameter.AddParameterLite(m_oDatabase, "risk_cnt", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            bPMAddParameter.AddParameterLite(m_oDatabase, "calculate_only", Math.Abs(gPMFunctions.ToSafeInteger(bCalculateOnly)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger)

            If Not bCalculateOnly Then
                bPMAddParameter.AddParameterLite(m_oDatabase, "insurance_file_cnt", lInsuranceFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                bPMAddParameter.AddParameterLite(m_oDatabase, "associated_key_id", lPFPremFinanceCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                bPMAddParameter.AddParameterLite(m_oDatabase, "associated_key_id2", lPFPremFinanceVersion, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            Else

                bPMAddParameter.AddParameterLite(m_oDatabase, "insurance_file_cnt", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            End If

            m_lReturn = m_oDatabase.SQLAction("spu_SIR_Calculate_Tax_Amounts", "Calculate Tax", True)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New System.Exception(m_lReturn.ToString() + ", " + +", spu_SIR_Calculate_Tax_Amounts failed")
            End If
            r_crTaxAmount = gPMFunctions.ToSafeRound(gPMFunctions.ToSafeCurrency(m_oDatabase.Parameters.Item("tax_currency_amount").Value, 0), k_RoundingFormatUpTo, IsSuppressDecimalValues)
        Else
            r_crTaxAmount = 0
        End If

        Return result

    End Function

    '*************************************************************************
    'Name:          CalculatePaymentProtection
    'Description:   Works out the Payment Protection Payable on an Amount
    'History:       TR111102 - Created as per TS23  Section 4.2.1.1.5
    '*************************************************************************
    Private Function CalculatePaymentProtection(ByVal v_crAmountForProtection As Decimal, ByVal v_enProtectionType As CalculationType, ByVal v_dProtectionAmountOrPercentage As Double, ByRef r_crProtectionAmount As Decimal) As Integer

        Dim result As Integer = 0


        'TR - Assume failure
        result = gPMConstants.PMEReturnCode.PMFail
        r_crProtectionAmount = 0

        '==========================================
        'CALCULATE THE AMOUNT OF PROTECTION PAYABLE
        '==========================================
        'TR - Does the Customer even want Payment protection?
        If m_bPaymentProtection Then
            'TR - Is this Protection calculated as a fixed amount or a percentage?
            If v_enProtectionType = Business.CalculationType.CalculationTypeAmount Then
                r_crProtectionAmount = v_dProtectionAmountOrPercentage
                If m_iUseTransCurrency = 1 Then
                    r_crProtectionAmount = r_crProtectionAmount / m_dCurrencyXRate
                End If
                'TR - If the Protection is a Percentage, then it is of the
                'TOTAL of m_crAmountToFinance + Interest + Tax
            ElseIf v_enProtectionType = Business.CalculationType.CalculationTypePercentage Then
                If v_dProtectionAmountOrPercentage > 0 Then
                    r_crProtectionAmount = v_crAmountForProtection * v_dProtectionAmountOrPercentage / 100
                End If
            End If
        End If

        ' RAW 05/11/2003 : CQ2912, 2976 : added
        r_crProtectionAmount = gPMFunctions.ToSafeRound(r_crProtectionAmount, k_RoundingFormatUpTo, IsSuppressDecimalValues)

        'TR - Set return value
        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    '*************************************************************************
    'Name:          CalculateFees
    'Description:   Works out the Fees Payable on an Amount
    'History:       TR111102 - Created as per TS23  Section 4.2.1.1.6
    '*************************************************************************
    Private Function CalculateFees(ByVal v_crFinanceAmount As Decimal, ByVal v_enFeeType As CalculationType, ByVal v_dFeeAmountOrPercentage As Double, ByRef r_crFeesAmount As Decimal) As Integer

        Dim result As Integer = 0


        'TR - Assume failure
        result = gPMConstants.PMEReturnCode.PMFail
        r_crFeesAmount = 0

        If m_dCurrencyXRate = 0 Then
            m_dCurrencyXRate = 1
        End If
        '====================================
        'CALCULATE THE AMOUNT OF FEES PAYABLE
        '====================================
        'TR - Is this Protection calculated as a fixed amount or a percentage?
        If v_enFeeType = Business.CalculationType.CalculationTypeAmount Then
            r_crFeesAmount = v_dFeeAmountOrPercentage
            If m_iUseTransCurrency = 1 Then
                r_crFeesAmount = r_crFeesAmount / m_dCurrencyXRate
            End If
        ElseIf v_enFeeType = Business.CalculationType.CalculationTypePercentage Then
            If v_dFeeAmountOrPercentage > 0 Then
                r_crFeesAmount = v_crFinanceAmount * v_dFeeAmountOrPercentage / 100
            End If
        End If

        ' RAW 05/11/2003 : CQ2912, 2976 : added
        r_crFeesAmount = gPMFunctions.ToSafeRound(r_crFeesAmount, k_RoundingFormatUpTo, IsSuppressDecimalValues)
        'TR - Set return value
        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    '*************************************************************************
    'Name:          CalculateInstalmentAmounts
    'Description:   Works out the Amount of the First Instalment (special) and
    '               all the "other" instalments (same). If m_iMTAType
    '               = 1 then The first Payment is equal to v_crFinanceAmount
    '               (indicates this ia an MTA quote)
    'History:       TR111102 - Created as per TS23  Section 4.2.1.1.8
    'Start (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
    'Added the v_iCalculateInstalmentsNetCommission optional parameter
    'End (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
    '*************************************************************************
    Private Function CalculateInstalmentAmounts(ByVal v_crFinanceAmount As Decimal, ByVal v_iNoOfInstalmentsToPay As Integer, ByVal v_iNoOfMissedInstalments As Integer, ByVal v_crDepositAmount As Decimal, ByVal v_crInterestAmount As Decimal, ByVal v_crTaxAmount As Decimal, ByVal v_crFeesAmount As Decimal, ByVal v_crProtectionAmount As Decimal, ByVal v_iChargeTaxToFirstInstalment As Integer, ByVal v_iChargeFeeToFirstInstalment As Integer, ByVal v_iChargeProtectionToFirstInstalment As Integer, ByRef r_crFirstInstalmentAmount As Decimal, ByRef r_crOtherInstalmentsAmount As Decimal, Optional ByVal v_bIsSG As Boolean = False, Optional ByVal v_iCalculateInstalmentsNetCommission As Integer = 0) As Integer

        Dim result As Integer = 0
        Dim crAmountToBeSpread, crNewInstalmentFinanceAmount, crNewInterestAmount, crNewTaxAmount, crNewFeesAmount, crNewProtectionAmount, crSettlementAmount, crRefundAmount As Decimal
        Dim bChargeFinanceAmountToFirstInstalment, bChargeInterestToFirstInstalment, bChargeTaxToFirstInstalment, bChargeFeeToFirstInstalment, bChargeProtectionToFirstInstalment As Boolean
        Dim v_vPremiumFinance(1, 0) As Object
        Dim iNoOfPreviousInstalments As Integer
        Dim crPreviousInstalmentsAmount As Decimal



        'TR - Assume failure
        result = gPMConstants.PMEReturnCode.PMFail

        ' RAW 05/11/2003 : CQ2912, 2976 : added
        bChargeTaxToFirstInstalment = (v_iChargeTaxToFirstInstalment = 1)
        bChargeFeeToFirstInstalment = (v_iChargeFeeToFirstInstalment = 1)
        bChargeProtectionToFirstInstalment = (v_iChargeProtectionToFirstInstalment = 1)

        If m_sProductCode = "MTA" And m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddToNext Then
            ' All of the new amounts are to be added to the next instalment only
            bChargeFinanceAmountToFirstInstalment = True
            bChargeInterestToFirstInstalment = True
            bChargeTaxToFirstInstalment = True
            bChargeFeeToFirstInstalment = True
            bChargeProtectionToFirstInstalment = True
        End If
        ' RAW 05/11/2003 : CQ2912, 2976 : end

        crNewInstalmentFinanceAmount = v_crFinanceAmount - v_crDepositAmount
        crNewInterestAmount = v_crInterestAmount
        crNewTaxAmount = v_crTaxAmount
        crNewFeesAmount = v_crFeesAmount
        crNewProtectionAmount = v_crProtectionAmount
        ' RAW 05/11/2003 : CQ2912, 2976 : end

        ' RAW 05/11/2003 : CQ2912, 2976 :
        If m_sProductCode = "MTA" And (m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_NoAmountChange Or m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_AddToNewPlan) Then

            'SMJB CQ2912: we already have the total amount to be financed
            If Not bChargeFinanceAmountToFirstInstalment Then
                crAmountToBeSpread = crNewInstalmentFinanceAmount
            End If

        Else
            ' if we are here then the amount may be being changed

            ' The parameter values passed in are additional amounts to be ADDED to the existing outstanding balance

            ' Establish what is still outstanding from the existing plan

            ' crNewInstalmentFinanceAmount is the new additional amount (excl supplements like interest, taxes etc) that is to be added to the existing plan
            ' crSettlementAmount is the amount (excl supplements like interest, taxes etc) still outstanding from the original plan
            ' crRefundAmount is the total amount of supplements still outstanding

            If m_sProductCode <> "REN" Then

                v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0) = m_lPremFinanceCnt

                v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0) = m_lPremFinanceVer

                m_lReturn = SettlePlanCalculate(v_vPremiumFinance:=v_vPremiumFinance, r_crSettlement:=crSettlementAmount, r_crRefund:=crRefundAmount)
                If m_bIsSinglePlanParty Then
                    m_lReturn = GetPreviousInstalmentsAmount(v_lpfprem_finance_cnt:=m_lPremFinanceCnt,
                                            v_lpfprem_finance_version:=m_lPremFinanceVer,
                                            v_dDueDate:=m_dtStartDate,
                                                r_crPreviousInstalmentsAmount:=crPreviousInstalmentsAmount)
                    If (crSettlementAmount - crPreviousInstalmentsAmount) > 0 Then
                        crSettlementAmount = crSettlementAmount - crPreviousInstalmentsAmount
                    End If
                End If

                ' Now add the new amount to the amount outstanding from the existing plan
                ' If existing taxes and fees were originally assigned to the first instalment and that
                ' instalment has not yet been paid then they will be spread across all instalments here regardless
                ' RAW 05/11/2003 : CQ2912, 2976 : added crRefundAmount to total
                ' RAW 05/11/2003 : CQ2912, 2976 : replace m_crAmountToFinance with crFinanceAmount
                If Not bChargeFinanceAmountToFirstInstalment Then
                    crAmountToBeSpread = crNewInstalmentFinanceAmount + crSettlementAmount + crRefundAmount
                Else
                    crAmountToBeSpread = crSettlementAmount + crRefundAmount
                End If
            Else
                crAmountToBeSpread = crNewInstalmentFinanceAmount
            End If
        End If

        If m_iTask = gPMConstants.PMEComponentAction.PMView And m_sProductCode <> "REN" Then ' no need to include refund amt
            crAmountToBeSpread = crSettlementAmount
        End If

        ' RAW 05/11/2003 : CQ2912, 2976 : end

        ' Now add the new supplements to the amount to be spread

        '==========================
        'ADD THE INTEREST IF REQUIRED
        '==========================
        ' RAW 05/11/2003 : CQ2912, 2976 : add test for bChargeInterestToFirstInstalment
        If Not bChargeInterestToFirstInstalment Then
            crAmountToBeSpread += crNewInterestAmount
        End If

        '===================
        'ADD TAX IF REQUIRED
        '===================
        If Not bChargeTaxToFirstInstalment Then
            crAmountToBeSpread += crNewTaxAmount
        End If

        '====================
        'ADD FEES IF REQUIRED
        '====================
        If Not bChargeFeeToFirstInstalment Then
            crAmountToBeSpread += crNewFeesAmount
        End If

        '==========================
        'ADD PROTECTION IF REQUIRED
        '==========================
        If Not bChargeProtectionToFirstInstalment Then
            If Not (m_iTask = gPMConstants.PMEComponentAction.PMView And m_sProductCode <> "REN") Then
                crAmountToBeSpread += crNewProtectionAmount
            End If
        End If

        '=======================================
        'CALCULATE THE AMOUNT OF THE INSTALMENTS
        '=======================================
        If m_bIsSinglePlanParty Then
            m_lReturn = GetPreviousInstalments(v_lpfprem_finance_cnt:=m_lPremFinanceCnt,
                                               v_lpfprem_finance_version:=m_lPremFinanceVer,
                                               v_dDueDate:=m_dtStartDate,
                                                   r_iNoPreviousInstalments:=iNoOfPreviousInstalments)
            If iNoOfPreviousInstalments >= v_iNoOfInstalmentsToPay Then
                iNoOfPreviousInstalments = 0
            End If
            v_iNoOfInstalmentsToPay = v_iNoOfInstalmentsToPay - iNoOfPreviousInstalments
        End If

        If m_bIsSinglePlanParty And m_bMakeLiveSingleInstalmentPlan Then
            'crAmountToBeSpread = crNewInstalmentFinanceAmount
            m_lReturn = CalculateFirstOtherInstalments(crNewInstalmentFinanceAmount,
                v_iNoOfInstalmentsToPay, v_iNoOfMissedInstalments,
                    r_crFirstInstalmentAmount, r_crOtherInstalmentsAmount, v_bIsSG)
        Else

            m_lReturn = CalculateFirstOtherInstalments(crAmountToBeSpread, v_iNoOfInstalmentsToPay, v_iNoOfMissedInstalments, r_crFirstInstalmentAmount, r_crOtherInstalmentsAmount, v_bIsSG)
        End If

        'TR - Make sure that worked OK
        If m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then

            ' Now add in any amounts that are not to be spread but are added to the first/next instalment

            '=======================================
            'ADD NEW FINANCE AMOUNT TO FIRST INSTALMENT IF REQUIRED
            '=======================================
            If bChargeFinanceAmountToFirstInstalment Then
                r_crFirstInstalmentAmount += crNewInstalmentFinanceAmount
            End If

            '=======================================
            'ADD INTEREST TO FIRST INSTALMENT IF REQUIRED
            '=======================================
            If bChargeInterestToFirstInstalment Then
                r_crFirstInstalmentAmount += crNewInterestAmount
            End If

            '=======================================
            'ADD TAX TO FIRST INSTALMENT IF REQUIRED
            '=======================================
            If bChargeTaxToFirstInstalment Then
                r_crFirstInstalmentAmount += crNewTaxAmount
            End If

            '========================================
            'ADD FEES TO FIRST INSTALMENT IF REQUIRED
            '=======================================
            If bChargeFeeToFirstInstalment Then
                r_crFirstInstalmentAmount += crNewFeesAmount
            End If

            '==============================================
            'ADD PROTECTION TO FIRST INSTALMENT IF REQUIRED
            '==============================================
            If bChargeProtectionToFirstInstalment Then
                r_crFirstInstalmentAmount += crNewProtectionAmount
            End If
        End If

        'TR - Set return value
        Return m_lReturn

    End Function
    ' ***************************************************************** '
    ' Name:         GetAgentCommission
    ' Description:  gets the calulated agent commisiion based on insurance file cnt
    ' History:      20-Oct -2008
    'Start (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)
    ' ***************************************************************** '
    Private Function GetAgentCommission(ByVal v_lInsuranceFileCnt As Integer, ByRef r_crCommissionAmount As Decimal, Optional ByRef r_crTaxOnCommissionAmont As Decimal = 0) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "GetAgentCommission"
        Dim vArrayOfInsuranceFile As Object = Nothing
        Dim dCurrencyToBaseXRate As Double


        result = gPMConstants.PMEReturnCode.PMTrue
        Dim vResultArray(,) As Object = Nothing
        m_oDatabase.Parameters.Clear()
        ' Add Required Stored Procedure Parameters
        bPMAddParameter.AddParameterLite(m_oDatabase, "insurance_file_cnt", v_lInsuranceFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, gPMConstants.PMEReturnCode.PMTrue)

        m_lReturn = m_oDatabase.SQLSelect(sSQL:=ACGetAgentCommissionTypeSQL, sSQLName:=ACGetAgentCommissionTypeName, bStoredProcedure:=ACGetAgentCommissionTypeStored, vResultArray:=vResultArray, lNumberRecords:=gPMConstants.PMAllRecords)
        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            gPMFunctions.RaiseError(kMethodName, ACGetAgentCommissionTypeSQL & " Failed", gPMConstants.PMELogLevel.PMLogError)
        End If

        r_crCommissionAmount = 0

        If Informations.IsArray(vResultArray) Then

            For ctr As Integer = 0 To vResultArray.GetUpperBound(1)

                r_crCommissionAmount += gPMFunctions.ToSafeDouble(vResultArray(k_AgentCommission, ctr))
                r_crTaxOnCommissionAmont += Math.Round(gPMFunctions.ToSafeDouble(vResultArray(k_TaxOnCommission, ctr)), 2)
            Next ctr

            result = gPMConstants.PMEReturnCode.PMTrue
        End If

        If m_lInsuranceFileCnt > 0 Then

            m_lReturn = m_oInsuranceFile.GetDetails(vInsuranceFileCnt:=m_lInsuranceFileCnt)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oInsuranceFile.GetDetails", "vInsuranceFileCnt:=" & m_lInsuranceFileCnt, gPMConstants.PMELogLevel.PMLogError)
            End If

            m_lReturn = m_oInsuranceFile.GetNext(vArrayOfInsuranceFile)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("m_oInsuranceFile.GetNext", "Failed", gPMConstants.PMELogLevel.PMLogError)
            End If
        End If

        If Informations.IsArray(vArrayOfInsuranceFile) Then
            'If gPMFunctions.ToSafeDouble(vArrayOfInsuranceFile(InsuranceFileConst.ACCurrencyToBaseXRate), 1) <= 0 Or ((m_sProductCode = "NB" Or m_sProductCode = "MTA") And m_sTransType = "G_NB") Then
            '	dCurrencyToBaseXRate = 1
            'Else
            dCurrencyToBaseXRate = gPMFunctions.ToSafeDouble(vArrayOfInsuranceFile(InsuranceFileConst.ACCurrencyToBaseXRate), 1)
            'End If
        End If

        m_dCurrencyXRate = dCurrencyToBaseXRate

        If r_crCommissionAmount <> 0 Then
            If m_iUseTransCurrency = 0 Then
                r_crCommissionAmount *= dCurrencyToBaseXRate
            End If
        End If

        Return result

    End Function
    'End (Sriram P)Tech Spec - Valiant - P16 - Broker Instalments.doc section(5.3.1)

    '*************************************************************************
    'Name:          CalculateAPR
    'Description:   Works out the APR from an Interest amount
    'History:       Written by Dave Cleaver in 1.8.5 which came from Unix PMB.
    '               DD 04/07/2003: Taken from 1.8.5 Interface into here.
    '*************************************************************************
    Private Function CalculateAPR(ByVal cTotalIncludingInterest As Decimal, ByVal dRate As Double, ByVal iInstalments As Integer, ByRef r_dAprRate As Double) As Integer

        Dim result As Integer = 0


        Dim iInstalmentCount As Integer
        Dim lCounter As Integer

        Dim cRateAdj As Integer
        Dim cRateHi, cRateLo As Decimal
        Dim w_first_payment As Integer

        Dim cRateToCheck, cLoanAmount, Inamt, cTopRate, Cn, cInstalment, cInterest, cRateCheck1, cRateCheck2, cRateCheck3, cOverAmount, cInterestAmount, cAmountPayable, cInstalmentAmount, I1 As Decimal

        Dim cRate, cMonthlyRate As Decimal

        Dim bOverFlow As Boolean

        result = gPMConstants.PMEReturnCode.PMTrue

        w_first_payment = 1

        If (cTotalIncludingInterest = 0 Or dRate = 0) Or iInstalments = 0 Then

            r_dAprRate = 0

        Else

            'DC130605 added check for underwriting to keep as before for them

            'BE 3/9/2003 CQ345 Allow for negative amount (credits) using Abs()
            cInterestAmount = Math.Abs((cTotalIncludingInterest * dRate) / 100)

            cOverAmount = 0 '(premium * over_rate) / 100
            cAmountPayable = Math.Abs(cTotalIncludingInterest + cInterestAmount + cOverAmount)

            cInstalmentAmount = Math.Abs(cAmountPayable / iInstalments)
            cRate = dRate '- over_rate

            'DC130605 readded as mistakenly removed from previous version
            cTopRate = 14
            cRateAdj = 3

            cLoanAmount = Math.Abs(cTotalIncludingInterest)
            iInstalmentCount = iInstalments
            Inamt = cInstalmentAmount
            I1 = cAmountPayable - (cInstalmentAmount * (iInstalmentCount - 1))

            cRateToCheck = cTopRate
            cRateHi = 0
            cRateLo = 99
            cMonthlyRate = 0
            r_dAprRate = 0
            lCounter = 0

            If iInstalmentCount <= 1 Then Return result
            If cLoanAmount <= I1 Then Return result

            bOverFlow = False
            While cMonthlyRate <= 0 And Not bOverFlow
                lCounter += 1
                If lCounter = 100 Then
                    bOverFlow = True
                End If
                Cn = cLoanAmount
                For iCounter2 As Integer = 1 To iInstalmentCount
                    If iCounter2 = w_first_payment Then
                        Cn = cLoanAmount
                        cInterest = 0
                        cInstalment = I1
                    Else
                        cInterest = (Cn * cRateToCheck) / 100
                        cInstalment = Inamt
                    End If
                    Cn = Cn - cInstalment + cInterest
                Next iCounter2

                If Cn >= -0.005 And Cn <= 0.005 Then
                    cMonthlyRate = cRateToCheck
                Else
                    If Cn > 0 Then
                        cRateHi = cRateToCheck
                        If cRateLo = 99 Then
                            cRateToCheck -= cRateAdj
                        Else
                            cRateToCheck = (cRateLo + cRateHi) / 2
                        End If
                    Else
                        If Cn < 0 Then
                            cRateLo = cRateToCheck
                            If cRateHi = 0 Then
                                cRateToCheck += cRateAdj
                            Else
                                cRateToCheck = (cRateLo + cRateHi) / 2
                            End If
                        End If
                    End If
                End If
                cRateCheck1 = cRateHi - cRateLo

                If cRateCheck1 <= 0.0001 And cRateHi > 0 And cRateLo < 99 Then
                    cMonthlyRate = cRateLo
                Else
                    cRateCheck2 = cRateToCheck - cRateLo
                    cRateCheck3 = cRateHi - cRateToCheck

                    If (cRateCheck2 <= 0.00001 And cRateLo < 99) Or (cRateCheck3 <= 0.00001 And cRateHi > 0) Then

                        cMonthlyRate = cRateToCheck

                    End If
                End If

            End While

            If cMonthlyRate > 0 Then
                r_dAprRate = Math.Round(((1 + cMonthlyRate / 100) ^ 12 - 1) * 100, 2)
            End If

        End If

        'TR - Set return value
        Return gPMConstants.PMEReturnCode.PMTrue

    End Function

    Public Function GetPolicyFeeAndTaxes(ByVal v_lInsuranceFileCnt As Long, ByRef r_dFeeExcluded As Double, ByRef r_dTaxExcluded As Double, Optional ByRef r_dIncludeTaxInPF As Double = 0) As Integer
        Dim vResultArray(,) As Object = Nothing
        Dim result As Integer = 0
        Dim iIncludePolicyFee As Integer
        Dim iSpreadFeeAcrossInstalments As Integer
        Dim cPolicyFeeAmount As Decimal
        Dim cTotalPolicyFeeAmount As Decimal
        Dim iIncludePolicyTaxInPF As Integer
        Dim iSpreadTaxAcrossInstalments As Integer
        Dim cPolicyTaxAmount As Decimal
        Dim cTotalPolicyTaxAmount As Decimal
        Dim iIsNotAappliedToClient As Integer
        Dim cIncludeTaxInPF As Decimal

        Try

            m_oDatabase.Parameters.Clear()

            AddParameterLite(m_oDatabase, "Insurance_File_Cnt", v_lInsuranceFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
            m_lReturn = m_oDatabase.SQLSelect(sSQL:=ACSpreadFeesAmongInstalmentsSQL,
                                                    sSQLName:=ACSpreadFeesAmongInstalmentsName,
                                                    bStoredProcedure:=True,
                                                    vResultArray:=vResultArray)

            If Informations.IsArray(vResultArray) And m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                For i As Integer = 0 To vResultArray.GetUpperBound(1)
                    cPolicyFeeAmount = ToSafeCurrency(vResultArray(20, i))
                    iIncludePolicyFee = ToSafeInteger(vResultArray(25, i))
                    iSpreadFeeAcrossInstalments = ToSafeInteger(vResultArray(26, i))

                    If iIncludePolicyFee = 0 And iSpreadFeeAcrossInstalments = 0 Then
                        cTotalPolicyFeeAmount += cPolicyFeeAmount
                    End If
                Next
            End If


            m_oDatabase.Parameters.Clear()
            AddParameterLite(m_oDatabase, "Insurance_File_Cnt", v_lInsuranceFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger, True)
            m_lReturn = m_oDatabase.SQLSelect(sSQL:=ACSpreadTaxAmongInstalmentsSQL,
                                                    sSQLName:=ACSpreadTaxAmongInstalmentsName,
                                                    bStoredProcedure:=False,
                                                    vResultArray:=vResultArray)

            cTotalPolicyTaxAmount = 0
            cIncludeTaxInPF = 0

            If Informations.IsArray(vResultArray) And m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
                For i As Integer = 0 To vResultArray.GetUpperBound(1)
                    cPolicyTaxAmount = ToSafeCurrency(vResultArray(2, i))
                    iIncludePolicyTaxInPF = ToSafeInteger(vResultArray(0, i))
                    iSpreadTaxAcrossInstalments = ToSafeInteger(vResultArray(1, i))
                    iIsNotAappliedToClient = ToSafeInteger(vResultArray(3, i))

                    'If iIsNotAappliedToClient = 0 Then
                    'And iSpreadTaxAcrossInstalments = 0 
                    If iIncludePolicyTaxInPF = 0 Then
                        cTotalPolicyTaxAmount += cPolicyTaxAmount
                    End If
                    'End If
                    If iIsNotAappliedToClient = 1 Then
                        cIncludeTaxInPF += cPolicyTaxAmount
                    End If
                Next
            End If

            r_dFeeExcluded = cTotalPolicyFeeAmount
            r_dTaxExcluded = cTotalPolicyTaxAmount
            r_dIncludeTaxInPF = cIncludeTaxInPF

        Catch ex As Exception
            Return PMConst.PMFalse
        End Try

        Return m_lReturn

    End Function

    ' ***************************************************************** '
    ' Name:         CalculateFirstOtherInstalments
    ' Description:  Determines the first/other instalments where first
    '               one may be different to handle rounding.
    ' History:      02/10/2001 DD - Created.
    ' ***************************************************************** '
    Private Function CalculateFirstOtherInstalments(ByVal v_crAmountToFinance As Decimal, ByVal v_iNoOfInstalmentsToPay As Integer, ByVal v_iNoOfMissedInstalments As Integer, ByRef r_crFirstInstalment As Decimal, ByRef r_crOtherInstalments As Decimal, Optional ByRef v_vIsSG As Boolean = False) As Integer

        Dim result As Integer = 0
        Dim dPaymentCheck As Double
        Dim lPaymentCheck As Integer
        Dim iIncludePolicyFee As Integer
        Dim iSpreadFeeAcrossInstalments As Integer
        Dim cPolicyFeeAmount As Decimal
        Dim cTotalPolicyFeeAmount As Decimal
        Dim vResultArray(,) As Object = Nothing
        Dim iIncludePolicyTax As Integer
        Dim iSpreadTaxAcrossInstalments As Integer
        Dim cPolicyTaxAmount As Decimal
        Dim cTotalPolicyTaxAmount As Decimal
        Dim nRoundWholeNumber As Integer = 0

        Dim crTempFirstInstalment As Decimal = 0.0



        'TR - Make sure parameters are OK
        If (v_iNoOfInstalmentsToPay + v_iNoOfMissedInstalments) = 0 Then
            Return gPMConstants.PMEReturnCode.PMFail
        Else
            'TR - Assume success
            result = gPMConstants.PMEReturnCode.PMTrue
        End If

        'Spread Fee Across Instalments
        m_oDatabase.Parameters.Clear()
        AddParameterLite(m_oDatabase, "Insurance_File_Cnt", m_lInsuranceFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
        m_lReturn = m_oDatabase.SQLSelect(sSQL:=ACSpreadFeesAmongInstalmentsSQL,
                                                sSQLName:=ACSpreadFeesAmongInstalmentsName,
                                                bStoredProcedure:=True,
                                                    vResultArray:=vResultArray)

        If Informations.IsArray(vResultArray) And m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
            For i As Integer = 0 To vResultArray.GetUpperBound(1)
                cPolicyFeeAmount = ToSafeCurrency(vResultArray(20, i))
                iIncludePolicyFee = ToSafeInteger(vResultArray(25, i))
                iSpreadFeeAcrossInstalments = ToSafeInteger(vResultArray(26, i))

                If iIncludePolicyFee = 1 And iSpreadFeeAcrossInstalments = 0 Then
                    v_crAmountToFinance = v_crAmountToFinance - cPolicyFeeAmount
                    cTotalPolicyFeeAmount += cPolicyFeeAmount
                End If

            Next
        End If

        m_oDatabase.Parameters.Clear()
        AddParameterLite(m_oDatabase, "Insurance_File_Cnt", m_lInsuranceFileCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
        m_lReturn = m_oDatabase.SQLSelect(sSQL:=ACSpreadTaxAmongInstalmentsSQL,
                                                sSQLName:=ACSpreadTaxAmongInstalmentsName,
                                                bStoredProcedure:=False,
                                                    vResultArray:=vResultArray)

        If Informations.IsArray(vResultArray) And m_lReturn = gPMConstants.PMEReturnCode.PMTrue Then
            For i As Integer = 0 To vResultArray.GetUpperBound(1)
                cPolicyTaxAmount = ToSafeCurrency(vResultArray(2, i))
                iIncludePolicyTax = ToSafeInteger(vResultArray(0, i))
                iSpreadTaxAcrossInstalments = ToSafeInteger(vResultArray(1, i))


                If iIncludePolicyTax = 1 And iSpreadTaxAcrossInstalments = 0 Then
                    v_crAmountToFinance = v_crAmountToFinance - cPolicyTaxAmount
                    cTotalPolicyTaxAmount += cPolicyTaxAmount
                End If

            Next
        End If

        ' RAW 05/11/2003 : CQ2912, 2976 : removed code thatset First instalment to the full amount
        'TR - See if the Amount is Equally divisible by the no of instalments
        dPaymentCheck = v_crAmountToFinance / (v_iNoOfInstalmentsToPay + v_iNoOfMissedInstalments)
        dPaymentCheck *= 100
        lPaymentCheck = gPMFunctions.ToSafeInteger(Math.Floor(dPaymentCheck))
        dPaymentCheck = (lPaymentCheck / 100) * (v_iNoOfInstalmentsToPay + v_iNoOfMissedInstalments)

        ' SET 12/05/2004 ISS11906 - if amounts are equal or there is only one instalment
        If (dPaymentCheck = v_crAmountToFinance) Or (v_iNoOfInstalmentsToPay + v_iNoOfMissedInstalments) = 1 Or v_vIsSG Or v_iNoOfInstalmentsToPay = 1 Then

            'If IsSuppressDecimalValues Then

            ' All payments will be equal
            If (v_iNoOfInstalmentsToPay + v_iNoOfMissedInstalments = 1) Or v_iNoOfInstalmentsToPay = 1 Or v_crAmountToFinance <= 1 Then
                r_crOtherInstalments = 0
                r_crFirstInstalment = v_crAmountToFinance
            Else
                r_crOtherInstalments = v_crAmountToFinance / (v_iNoOfInstalmentsToPay + v_iNoOfMissedInstalments)
                'Perform the rounding on the basis of expression like 0.1 to .49 goes down side and 0.5 t0 .99 goes to 1
                r_crOtherInstalments = gPMFunctions.ToSafeRound(r_crOtherInstalments, k_RoundingFormatUpTo, IsSuppressDecimalValues)
                ' Corrected incorrectly corrected maths: The first instalment is ALWAYS:
                '   The total amount minus the sum of the other instalments
                ' This allows for rounding and rollup of backdated amounts!!
                r_crFirstInstalment = v_crAmountToFinance - (r_crOtherInstalments * (v_iNoOfInstalmentsToPay - 1))
            End If

            r_crFirstInstalment = r_crFirstInstalment + cTotalPolicyFeeAmount

            r_crFirstInstalment = r_crFirstInstalment + cTotalPolicyTaxAmount

        Else
            ' Calculate for higher first instalment
            r_crOtherInstalments = v_crAmountToFinance / (v_iNoOfInstalmentsToPay + v_iNoOfMissedInstalments)

            ' Adjust OthInstalments for rounding
            r_crOtherInstalments = (Math.Floor(r_crOtherInstalments * 100)) / 100

            'Round the otherinstalment in whole numbers and add the sum of decimal part of all instalments in first instalment.
            'Hence the first instalment also should be in whole number because Suppress decimal flag is ON
            r_crOtherInstalments = gPMFunctions.ToSafeRound(r_crOtherInstalments, k_RoundingFormatUpTo, IsSuppressDecimalValues)

            ' Corrected incorrectly corrected maths: The first instalment is ALWAYS:
            '   The total amount minus the sum of the other instalments
            ' This allows for rounding and rollup of backdated amounts!!
            r_crFirstInstalment = v_crAmountToFinance - (r_crOtherInstalments * (v_iNoOfInstalmentsToPay - 1))

            '==============================================
            'Do Not Spread Fee Across Instalments
            '==============================================
            'If iIncludePolicyFee = 1 And iSpreadFeeAcrossInstalments = 0 Then
            r_crFirstInstalment = r_crFirstInstalment + cTotalPolicyFeeAmount
            'End If

            'If iIncludePolicyTax = 1 And iSpreadTaxAcrossInstalments = 0 Then
            r_crFirstInstalment = r_crFirstInstalment + cTotalPolicyTaxAmount
            'End If
        End If

        Return result

    End Function
