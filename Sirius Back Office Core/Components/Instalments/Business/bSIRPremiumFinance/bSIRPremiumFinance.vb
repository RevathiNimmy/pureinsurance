            lReturn = .Parameters.Add(sName:="insurance_file_cnt", vValue:=gPMFunctions.ToSafeString(m_lInsuranceFileCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
