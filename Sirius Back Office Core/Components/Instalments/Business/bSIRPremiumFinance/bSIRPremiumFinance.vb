    Public Function GetSGXMLList(ByVal v_sProviderName As String, ByVal v_lListType As Integer, ByRef r_vArray(,) As Object) As Integer

        Dim result As Integer = 0
        Dim oDoc As XmlDocument
        Dim oNodeList As XmlNodeList
        Dim vArray(,) As Object = Nothing
        Dim sTmp As String = ""
        Dim lCount As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'get reg setting for xsl path's
            m_lReturn = gPMFunctions.GetPMRegSetting(gPMConstants.HKEY_LOCAL_MACHINE, gPMConstants.PMEProductFamily.pmePFSiriusSolutions, gPMConstants.PMERegSettingLevel.pmeRSLServer, "XSLPath", sTmp)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception()
            End If

            'check if we have a path
            If sTmp <> "" Then
                'add the xsl path, provider and list type to the path
                sTmp = sTmp & ACXSLPath & "\" & v_sProviderName.Trim() & "\"

                'check what list we need
                Select Case v_lListType
                    Case bSIRPremFinConst.ACSGListBusiness
                        sTmp = sTmp & bSIRPremFinConst.ACSGListBusinessText
                    Case bSIRPremFinConst.ACSGListInsurers
                        sTmp = sTmp & bSIRPremFinConst.ACSGListInsurersText
                End Select

                'get a new dom document
                oDoc = New XmlDocument()
                Dim temp_xml_result As Boolean
                Try
                    oDoc.Load(sTmp)
                    temp_xml_result = True

                Catch parseError As System.Exception
                    temp_xml_result = False
                End Try
                If temp_xml_result Then
                    'now parse each item from the document
                    oNodeList = oDoc.SelectNodes("//item")
                    'check that we have some
                    If oNodeList.Count > 0 Then
                        'loop thru the items and add them to the array
                        For Each oNode As XmlNode In oNodeList
                            'redimension the array

                            ReDim Preserve vArray(1, lCount)

                            'get the attributes for each node
                            For Each oAtt As XmlAttribute In oNode.Attributes
                                Select Case oAtt.Name
                                    Case "code"

                                        vArray(0, lCount) = oAtt.InnerText
                                    Case "desc"

                                        vArray(1, lCount) = oAtt.InnerText
                                End Select
                            Next oAtt

                            'increment the counter
                            lCount += 1
                        Next oNode

                        'return our result array
                        r_vArray = vArray
                    Else
                        Throw New Exception()
                    End If
                Else
                    Throw New Exception()
                End If
            Else
                Throw New Exception()
            End If

            Return result

        Catch

            'dont log an error! if the list fails to load this is not too much of an issue
            'as it will be picked up by the providers web service and reported back

            Return gPMConstants.PMEReturnCode.PMError
        End Try

    End Function

