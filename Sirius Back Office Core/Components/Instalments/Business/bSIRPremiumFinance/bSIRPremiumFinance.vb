    Public Function AutoAllocate(ByVal v_lPFPremiumFinanceCnt As Integer,
                                 ByRef r_lAccountID As Integer,
                                 ByRef r_cWriteoffAmount As Decimal,
                                 ByRef r_lDoumentId As Integer,
                                 ByRef r_lTransDetailId As Integer,
                                 ByRef r_lInsuranceFileCnt As Integer,
                                 Optional ByVal v_bViaSettlePlan As Boolean = False,
                                 Optional ByVal v_lSRPTransDetailId As Integer = 0,
                                 Optional ByVal v_lDebitTransdetail As Integer = 0) As Integer

        Dim result As Integer = 0
        Dim vKeys As Object
        Dim vAllocationArray(,) As Object = Nothing
        Dim vMatchTrans As Object = Nothing
        Dim lMatchRow As Integer
        Dim oAllocationManual As bACTAllocationManual.Business
        Dim lSEDDocumentTypeId As Integer
        Dim dWriteOffAmount As Double
        'Dim oTransdetail As Object
        Dim cOutstandingAmount As Decimal
        Dim cSettleSEDAmount As Decimal

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Clear Down Database Parameters
            m_oDatabase.Parameters.Clear()

            m_lReturn = AddInputParameter(v_sName:="pfprem_finance_cnt", v_vValue:=v_lPFPremiumFinanceCnt, v_iType:=gPMConstants.PMEDataType.PMLong)

            ' Execute selection Query

            m_lReturn = m_oDatabase.SQLSelect(sSQL:=kGetTransDetailsForPlanSQL, sSQLName:=kGetTransDetailsForPlanName, bStoredProcedure:=True, vResultArray:=vAllocationArray, lNumberRecords:=gPMConstants.PMAllRecords)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception
            End If

            If Not Informations.IsArray(vAllocationArray) Then
                Return result
            End If
            If r_cWriteoffAmount <> 0 AndAlso v_bViaSettlePlan = False Then
                'First check if all incomming transactions have correct setoff amount or there is any write off difference
                r_cWriteoffAmount = 0
                For lRow As Integer = 0 To vAllocationArray.GetUpperBound(1)
                    r_cWriteoffAmount += gPMFunctions.ToSafeDouble(vAllocationArray(1, lRow))
                Next
            End If

            If vAllocationArray.GetUpperBound(0) = 0 Then
                Return result
            End If

            m_lReturn = GetOutstandingAmountFromTransDetailId(v_lTransDetail_id:=v_lSRPTransDetailId,
                                              r_cOutstandingAmount:=cOutstandingAmount)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception
            End If

            ' SED Settlement transaction amount
            m_lReturn = GetOutstandingAmountFromTransDetailId(v_lTransDetail_id:=ToSafeLong(v_lDebitTransdetail, 0),
                                                  r_cOutstandingAmount:=cSettleSEDAmount)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception
            End If

            ' Partial payment allocation
            If (cSettleSEDAmount + cOutstandingAmount) <> 0 And cOutstandingAmount <> 0 Then
                cSettleSEDAmount = cOutstandingAmount * -1
            End If

            ' Outstanding amount should not be zero

            ReDim vKeys(1, 2)

            m_lReturn = GetDocumentType("SED", lSEDDocumentTypeId)

            lMatchRow = 0

            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 0) = ACTKeyNameAccountID
            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 1) = ACTKeyNameTransDetailID
            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyName, 2) = ACTKeyNameTransDetailIDs

            r_lAccountID = 0
            r_lDoumentId = 0
            r_lTransDetailId = 0

            For lRow As Integer = 0 To vAllocationArray.GetUpperBound(1)
                If gPMFunctions.ToSafeLong(vAllocationArray(4, lRow)) = lSEDDocumentTypeId Then

                    dWriteOffAmount = 0
                    If r_cWriteoffAmount > 0 Then
                        dWriteOffAmount = r_cWriteoffAmount * -1
                        r_lTransDetailId = gPMFunctions.ToSafeLong(vAllocationArray(0, lRow))
                        r_lDoumentId = gPMFunctions.ToSafeLong(vAllocationArray(2, lRow))
                    End If

                    r_lAccountID = gPMFunctions.ToSafeLong(vAllocationArray(6, lRow))
                    r_lInsuranceFileCnt = gPMFunctions.ToSafeLong(vAllocationArray(5, lRow))
                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 0) = gPMFunctions.ToSafeLong(vAllocationArray(6, lRow))
                    vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 1) = CStr(gPMFunctions.ToSafeLong(vAllocationArray(0, lRow))) & "|" & CStr(gPMFunctions.ToSafeDouble(vAllocationArray(1, lRow)) + dWriteOffAmount)

                End If
            Next

            For lRow As Integer = 0 To vAllocationArray.GetUpperBound(1)
                If gPMFunctions.ToSafeLong(vAllocationArray(4, lRow)) <> lSEDDocumentTypeId Then

                    dWriteOffAmount = 0

                    If lMatchRow = 0 Then
                        If r_cWriteoffAmount < 0 Then
                            dWriteOffAmount = r_cWriteoffAmount * -1
                            r_lTransDetailId = gPMFunctions.ToSafeLong(vAllocationArray(0, lRow))
                            r_lDoumentId = gPMFunctions.ToSafeLong(vAllocationArray(2, lRow))
                        End If
                    End If

                    '5436
                    If Not Informations.IsArray(vMatchTrans) Then
                        ReDim vMatchTrans(0)
                    Else
                        ReDim Preserve vMatchTrans(UBound(vMatchTrans) + 1)
                    End If
                    '5436

                    vMatchTrans(lMatchRow) = CStr(gPMFunctions.ToSafeLong(vAllocationArray(0, lRow))) & "|" & CStr(gPMFunctions.ToSafeDouble(vAllocationArray(1, lRow)) + dWriteOffAmount)
                    lMatchRow += 1
                End If
            Next lRow

            If v_bViaSettlePlan = True Then
                If cOutstandingAmount <> 0 Then
                    ReDim vMatchTrans(lMatchRow)
                    vMatchTrans(lMatchRow) = CStr(v_lSRPTransDetailId) & "|" & CStr(cOutstandingAmount)
                Else
                    ' Simply come out of the function - without any error..
                    Exit Function
                End If
            End If

            vKeys(gPMConstants.PMENavLetGetKeyColPosition.PMKeyValue, 2) = vMatchTrans

            ' Create a new instance of the Insurer Payment Allocation
            oAllocationManual = New bACTAllocationManual.Business()

            ' Initialise Product Options object
            m_lReturn = (oAllocationManual).Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=m_sCallingAppName)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                oAllocationManual = Nothing
                Throw New Exception

            End If

            m_lReturn = oAllocationManual.SetProcessModes(vTask:=gPMConstants.PMEComponentAction.PMEdit)

            ' Set the keys
            m_lReturn = oAllocationManual.SetKeys(vKeyArray:=vKeys)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception
            End If

            m_lReturn = oAllocationManual.Start()

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Throw New Exception
            End If

            oAllocationManual.Dispose()
            oAllocationManual = Nothing

            Return result
        Catch ex As Exception

            ' DO Not Call any functions before here or the error will be lost
            bPMFunc.LogMessage(m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to set navigator keys.", vApp:=ACApp, vClass:=ACClass, vMethod:="AutoAllocate", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description, excep:=ex)
            result = gPMConstants.PMEReturnCode.PMFalse
            Return result
            ' If you want to rollback a transaction or something, do it here

        Finally

            '       Return result

            '        Resume
            'Return result
        End Try
        Return result
    End Function

