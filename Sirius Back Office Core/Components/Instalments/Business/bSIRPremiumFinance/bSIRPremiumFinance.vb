            m_lReturn = m_oDatabase.SQLAction(sSQL:=ACUpdatePFPremiumFinanceSQL, sSQLName:=ACUpdatePFPremiumFinanceName, bStoredProcedure:=ACUpdatePFPremiumFinanceStored)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = m_lReturn
                m_lReturn = m_oDatabase.SQLRollbackTrans()
                Return result
            End If

            m_lReturn = m_oDatabase.SQLCommitTrans()

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="UpdateExistingRecord Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="UpdateExistingRecord", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            m_lReturn = m_oDatabase.SQLRollbackTrans()

            Return result
        End Try
    End Function
    ' ***************************************************************** '
    '
    ' Name: InsertPolicy Record
    '
    ' Description:
    '
    ' ***************************************************************** '
    Public Function InsertPfPolicy(ByRef vPfPrem_finance_cnt As Object, ByRef vPfPrem_policy_id As Object) As Integer
        Dim result As Integer = 0
        Dim sSqlString, sSqlName As String
        Dim bStoredProc As Boolean

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'NowUpdate Child Table PFPolicy_Code
            sSqlString = "INSERT INTO PFPolicy_Code "

            sSqlString = sSqlString &
                         "(pfprem_finance_cnt, pfprem_finance_version,pfpolicy_id) " &
                         "VALUES ( " &
                         "{PremFinance_Cnt}" & "," & " {PremFinance_Version} " & "," & "{Policy_Id} " &
                         ")"

            With m_oDatabase.Parameters
                .Clear()

                .Add("PremFinance_Cnt", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(vPfPrem_finance_cnt)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                .Add("PremFinance_Version", gPMFunctions.ToSafeString(1), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger)

                .Add("Policy_Id", gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(vPfPrem_policy_id)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
            End With

            sSqlName = "InsertNew PF Policy Code Record"

            'Call SQL.Action from within PMDAO
            m_lReturn = m_oDatabase.SQLAction(sSqlString, sSqlName, bStoredProc)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="InsertPfPolicy Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="InsertPfPolicy", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    '*************************************************************************
    ' Name:         InsertPFTransID
    ' Description:  Loops through all the Transactions in the array and
    '               associates them all with this Premium Finance record by
    '               inserting a record into PFTransactionID
    ' History:      Changed parameters from passed in byref to byval
    '               TR13122002 - TS23 - renamed
    '*************************************************************************
    Public Overloads Function InsertPFTransID(ByVal v_lPremFinanceCnt As Integer, ByVal v_lPremFinanceVersion As Integer, ByVal v_vPFTransArray(,) As Object) As Integer

        Dim result As Integer = 0
        Dim sSqlString As String = ""
        Dim InsuranceFileCntIndexinArray As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'TR - Only attempt this if the TransArray is populated
            If Informations.IsArray(v_vPFTransArray) Then
                InsuranceFileCntIndexinArray = v_vPFTransArray.GetUpperBound(0)
                'InsuranceFileCntIndexinArray = 3 Roll back PN 5299
                For lRowIndex As Integer = v_vPFTransArray.GetLowerBound(1) To v_vPFTransArray.GetUpperBound(1)
                    'TR - Add a record into the Transaction_ID table, linking the
                    'Transaction to the PremiumFinance

                    bPMAddParameter.AddParameterLite(m_oDatabase, "pfprem_finance_cnt", v_lPremFinanceCnt, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong, True)
                    bPMAddParameter.AddParameterLite(m_oDatabase, "pfprem_finance_version", v_lPremFinanceVersion, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                    bPMAddParameter.AddParameterLite(m_oDatabase, "pftransaction_id", gPMFunctions.ToSafeInteger(v_vPFTransArray(0, lRowIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    If gPMFunctions.ToSafeLong(v_vPFTransArray(InsuranceFileCntIndexinArray, lRowIndex)) = 0 Then

                        bPMAddParameter.AddParameterLite(m_oDatabase, "insurance_file_cnt", DBNull.Value, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    Else
                        bPMAddParameter.AddParameterLite(m_oDatabase, "insurance_file_cnt", gPMFunctions.ToSafeLong(v_vPFTransArray(InsuranceFileCntIndexinArray, lRowIndex)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    End If

