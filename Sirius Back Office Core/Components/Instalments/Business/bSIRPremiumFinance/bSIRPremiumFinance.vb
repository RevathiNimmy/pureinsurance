    Public Function GetPreferredDates(ByVal v_lPremFinanceVersion As Integer, ByVal v_lPremFinanceCnt As Integer, ByRef r_sFrequency As String, ByRef r_lDayOfWeekOrMonth As Integer, ByVal v_sProductCode As String) As Integer
        Return GetPreferredDates(v_lPremFinanceVersion:=v_lPremFinanceVersion, v_lPremFinanceCnt:=v_lPremFinanceCnt, r_sFrequency:=r_sFrequency, r_lDayOfWeekOrMonth:=r_lDayOfWeekOrMonth, r_dtFirstInstalmentDate:=#12/30/1899#, v_sProductCode:=v_sProductCode)
    End Function

    Public Function GetPreferredDates(ByVal v_lPremFinanceVersion As Integer, ByVal v_lPremFinanceCnt As Integer, ByRef r_sFrequency As String, ByRef r_lDayOfWeekOrMonth As Integer, ByRef r_dtFirstInstalmentDate As Date, ByVal v_sProductCode As String) As Integer

        Dim result As Integer = 0
        Dim vPremiumFinancePlan As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_lReturn = GetSingleFinancePlan(v_lFinanceCount:=v_lPremFinanceCnt, v_lFinanceVersion:=v_lPremFinanceVersion, r_vPFPremiumFinance:=vPremiumFinancePlan)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Or Not Informations.IsArray(vPremiumFinancePlan) Then
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogError, sMsg:="Unable to load previous plan", vApp:=ACApp, vClass:=ACClass, vMethod:=gPMFunctions.ToSafeString(result))
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            If r_lDayOfWeekOrMonth = 0 Then
                r_lDayOfWeekOrMonth = gPMFunctions.ToSafeInteger(vPremiumFinancePlan(bSIRPremFinConst.k_PFPlanDayOfWeekOrMonth, 0))
            End If

            r_sFrequency = gPMFunctions.ToSafeString(vPremiumFinancePlan(bSIRPremFinConst.k_PFPlanFrequencyPeriod, 0))

            r_dtFirstInstalmentDate = CDate(vPremiumFinancePlan(bSIRPremFinConst.k_PFPlanFirstInstalmentdate, 0)) ' RAW 05/11/2003 : CQ2912, 2976 : added

            If v_sProductCode = "MTA" Then
                'Get details about existing instalments
                m_lReturn = SettlePlanCalculate(v_vPremiumFinance:=vPremiumFinancePlan, r_crSettlement:=m_crCurrentOSFinanceAmount, r_crRefund:=0, r_dtNextInstalmentDate:=r_dtFirstInstalmentDate)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("SettlePlanCalculate", "Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                Return result

            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMFalse

            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetPreferredDates Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetPreferredDates", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result
        End Try
    End Function


