    Public Function SettlePlanCalculate(ByVal v_vPremiumFinance As Object, ByRef r_crSettlement As Decimal, ByRef r_crRefund As Decimal, ByRef r_dtNextInstalmentDate As Date, ByRef r_dtNextInstalmentDatePlus1 As Date, ByRef r_dtLastInstalmentDate As Date, ByRef r_dtLastPaidInstalmentDate As Date) As Integer
        Return SettlePlanCalculate(v_vPremiumFinance:=v_vPremiumFinance, r_crSettlement:=r_crSettlement, r_crRefund:=r_crRefund, r_dtNextInstalmentDate:=r_dtNextInstalmentDate, r_dtNextInstalmentDatePlus1:=r_dtNextInstalmentDatePlus1, r_dtLastInstalmentDate:=r_dtLastInstalmentDate, r_dtLastPaidInstalmentDate:=r_dtLastPaidInstalmentDate, r_vSettlementFormatted:=Nothing)
    End Function

    Public Function SettlePlanCalculate(ByVal v_vPremiumFinance As Object, ByRef r_crSettlement As Decimal, ByRef r_crRefund As Decimal, ByRef r_dtNextInstalmentDate As Date, ByRef r_dtNextInstalmentDatePlus1 As Date, ByRef r_dtLastInstalmentDate As Date, ByRef r_dtLastPaidInstalmentDate As Date, ByRef r_vSettlementFormatted As Object) As Integer

        Dim result As Integer = 0
        Dim vResultArray(,) As Object = Nothing
        Dim iCurrencyID As Integer
        Dim dXRate As Double
        Dim oACTInstalments As New bACTInstalments.Business
        Dim crRefundTax As Decimal
        Dim crRefundFee As Decimal
        Dim crCostOfProtection As Decimal
        Try

            'TR - Use SP spu_PFPremiumFinance_settlement to calculate the Amount
            With m_oDatabase
                .Parameters.Clear()

                .Parameters.Add("pfprem_finance_cnt", gPMFunctions.ToSafeString(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                .Parameters.Add("pfprem_finance_version", gPMFunctions.ToSafeString(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                .Parameters.Add("SettleAmount", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMDouble)
                .Parameters.Add("RefundFee", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMDouble)
                .Parameters.Add("RefundTax", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMDouble)
                .Parameters.Add("NextInstalmentDate", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMDate)
                .Parameters.Add("NextInstalmentDatePlus1", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMDate)
                .Parameters.Add("LastInstalmentDate", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMDate)
                .Parameters.Add("LastPaidInstalmentDate", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMDate)
                .Parameters.Add("CostOfProtection", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamOutput, gPMConstants.PMEDataType.PMDouble)
                m_lReturn = .SQLSelect(ACGetPFPremiumFinanceSettleSQL, ACGetPFPremiumFinanceSettleName, ACGetPFPremiumFinanceSettleStored, , vResultArray)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = m_lReturn
                    bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogError, "SQL statement failed", ACApp, ACClass, "SettlePlanCalculate")
                    Return result
                End If

                'TR - Now save the amounts locally
                r_crSettlement = gPMFunctions.NullToDecimal(.Parameters.Item("SettleAmount").Value)
                crRefundTax = gPMFunctions.NullToDecimal(.Parameters.Item("RefundTax").Value)
                crRefundFee = gPMFunctions.NullToDecimal(.Parameters.Item("RefundFee").Value)

                If Not (Convert.IsDBNull(.Parameters.Item("NextInstalmentDate").Value) Or Informations.IsNothing(.Parameters.Item("NextInstalmentDate").Value)) Then
                    r_dtNextInstalmentDate = .Parameters.Item("NextInstalmentDate").Value
                End If

                If Not (Convert.IsDBNull(.Parameters.Item("NextInstalmentDatePlus1").Value) Or Informations.IsNothing(.Parameters.Item("NextInstalmentDatePlus1").Value)) Then
                    r_dtNextInstalmentDatePlus1 = .Parameters.Item("NextInstalmentDatePlus1").Value
                End If

                If Not (Convert.IsDBNull(.Parameters.Item("LastInstalmentDate").Value) Or Informations.IsNothing(.Parameters.Item("LastInstalmentDate").Value)) Then
                    r_dtLastInstalmentDate = .Parameters.Item("LastInstalmentDate").Value
                End If

                If Not (Convert.IsDBNull(.Parameters.Item("LastPaidInstalmentDate").Value) Or Informations.IsNothing(.Parameters.Item("LastPaidInstalmentDate").Value)) Then
                    r_dtLastPaidInstalmentDate = .Parameters.Item("LastPaidInstalmentDate").Value
                Else
                    r_dtLastPaidInstalmentDate = #12/30/1899#
                End If
                If Not (Convert.IsDBNull(.Parameters.Item("CostOfProtection").Value) Or Informations.IsNothing(.Parameters.Item("CostOfProtection").Value)) Then
                    crCostOfProtection = .Parameters.Item("CostOfProtection").Value
                End If

                oACTInstalments = New bACTInstalments.Business
                m_lReturn = oACTInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    m_lReturn = gPMConstants.PMEReturnCode.PMFalse
                    Throw New ApplicationException("Failed to create object of bACTInstalments.Business")
                End If
                If Not v_vPremiumFinance Is Nothing AndAlso gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)) <> 0 AndAlso gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)) <> 0 Then
                    m_lReturn = oACTInstalments.SettlePlanCalculateRefund(nPremiumFinanceCnt:=gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), nPremiumFinanceVersion:=gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)),
                                          r_crSettlement:=r_crSettlement, r_crInterestRefund:=r_crRefund)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        m_lReturn = gPMConstants.PMEReturnCode.PMFalse
                        Throw New ApplicationException("Method SettlePlanCalculateRefund() failed")
                    End If
                End If
                r_crRefund = r_crRefund + crRefundTax

                'If the formatted parameter is passed then format the settlement in
                'the currency format of the plan

                Dim dOutStandingDeposit As Decimal = 0


                If m_iMTAType = bSIRPremFinConst.m_klInstalmentMTAType_NoAmountChange Then
                    m_lReturn = GetOutStandingDeposit(v_lPremiumFinanceCnt:=gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)),
                                                                     v_lPremiumFinancePlanVer:=gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)),
                                                                     r_cDepositAmount:=dOutStandingDeposit)

                    r_crSettlement = r_crSettlement + dOutStandingDeposit
                ElseIf Not Informations.IsNothing(r_vSettlementFormatted) Then

                    m_lReturn = GetOutStandingDeposit(v_lPremiumFinanceCnt:=gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)),
                                                                    v_lPremiumFinancePlanVer:=gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)),
                                                                    r_cDepositAmount:=dOutStandingDeposit)

                    r_crSettlement = r_crSettlement + dOutStandingDeposit

                    m_lReturn = GetSchemeCurrency(lPremiumFinanceCnt:=gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), lPremiumFinanceVersion:=gPMFunctions.ToSafeInteger(v_vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)), r_iCurrencyID:=iCurrencyID, r_XRate:=dXRate)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Throw New System.Exception(m_lReturn.ToString() + ", " + +", Failed to get Scheme Currency")
                    End If

                    m_lReturn = m_oCurrencyConvert.FormatCurrency(vCurrencyID:=iCurrencyID, vCurrencyAmount:=r_crSettlement, vFormattedCurrency:=r_vSettlementFormatted)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Throw New System.Exception(m_lReturn.ToString() + ", " + +", Failed to get Format Currency")
                    End If
                End If

            End With

            'Calculate the amount of Interest

            Return gPMConstants.PMEReturnCode.PMTrue

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError
            bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "SettlePlanCalculate Failed", ACApp, ACClass, "SettlePlanCalculate", Informations.Err().Number, excep.Message, excep:=excep)
            Return result
        Finally
            If Not oACTInstalments Is Nothing Then
                oACTInstalments.Dispose()
                oACTInstalments = Nothing
            End If
        End Try
    End Function

    ' ***************************************************************** '
    ' Name:         SettlePlanInHouse
    ' Description:  Cancels an In-House plan returning any overpayment
    ' History:      28/09/2001 DD - Created.
    ' ***************************************************************** '
    Public Function SettlePlanInHouse(ByRef vPremiumFinance(,) As Object, ByRef vPremiumFinanceTransactions(,) As Object, ByRef dtSettleDate As Date, ByRef cAmount As Decimal, ByRef cRefund As Decimal) As Integer

        Dim result As Integer = 0
        Dim oACTInstalments As bACTInstalments.Business
        Dim vPFTrans As Object = Nothing
        Dim oPM As Object = Nothing
        Dim oPFInstalments As New bSIRPFInstalments.Business
        Dim lPFPaymentMethod_cnt As Integer

        Try

            'Hook up to Orion
            'SD 31/07/2002 Scalability changes

            oACTInstalments = New bACTInstalments.Business
            m_lReturn = oACTInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            'Hook up Instalments
            'SD 31/07/2002 Scalability changes

            oPFInstalments = New bSIRPFInstalments.Business
            m_lReturn = oPFInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Prepare the Payment Method object
            'SD 31/07/2002 Scalability changes
            m_lReturn = gPMComponentServices.CreateBusinessObject(r_oObject:=oPM, v_sClassName:="bSIRPFExport.Business", v_sCallingAppName:=ACApp, v_sUsername:=m_sUsername, v_sPassword:=m_sPassword, v_iUserID:=m_iUserID, v_iSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_iCurrencyID:=m_iCurrencyID, v_iLogLevel:=m_iLogLevel, v_oDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If
            'Adjust the array for Orion
            'PSL 17/03/2003 Iss 2993
            If Informations.IsArray(vPremiumFinanceTransactions) Then
                ReDim vPFTrans(vPremiumFinanceTransactions.GetUpperBound(1))
                For lCount As Integer = vPremiumFinanceTransactions.GetLowerBound(1) To vPremiumFinanceTransactions.GetUpperBound(1)

                    vPFTrans(lCount) = vPremiumFinanceTransactions(0, lCount)
                Next lCount
            Else
                ReDim vPFTrans(0)

                vPFTrans(0) = vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)
            End If
            m_oDatabase.SQLBeginTrans()

            'Get the Payment Method for this Plan

            CheckSchemeType(gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)), "", lPFPaymentMethod_cnt)

            'Initialise Orion object

            oPM.PFPaymentMethod_cnt = lPFPaymentMethod_cnt

            oACTInstalments.BankCode = oPM.BankShortCode

            oACTInstalments.FeeCode = "FEESI"

            'Refund the interest to Orion
            'PSL 17/03/2003 Iss 2993

            m_lReturn = oACTInstalments.PostAdjustment(gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)), vPFTrans, -cRefund, vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0), vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            'Pay off the plan in Orion

            m_lReturn = oACTInstalments.PostAdjustment(gPMFunctions.ToSafeInteger(vPremiumFinance(bSIRPremFinConst.k_PFPlanPlanTransactionID, 0)), vPFTrans, -cAmount, vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0), vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0))
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                m_oDatabase.SQLRollbackTrans()
                Return m_lReturn
            End If

            'Update the Instalments as Complete
            With m_oDatabase
                .Parameters.Clear()

                m_lReturn = m_oDatabase.Parameters.Add(sName:="FinanceCount", vValue:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0)), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                m_lReturn = m_oDatabase.Parameters.Add(sName:="FinanceVersion", vValue:=gPMFunctions.ToSafeString(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0)), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
                m_lReturn = m_oDatabase.Parameters.Add(sName:="CollectedStatus", vValue:=gPMFunctions.ToSafeString(bSIRPremFinConst.PFStatusCollected), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
                m_lReturn = m_oDatabase.Parameters.Add(sName:="ManualStatus", vValue:=gPMFunctions.ToSafeString(bSIRPremFinConst.PFStatusManual), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                m_lReturn = m_oDatabase.Parameters.Add(sName:="DueDate", vValue:=dtSettleDate, iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMDate)

                m_lReturn = m_oDatabase.SQLAction(ACInstalmentsSettleSQL, ACInstalmentsSettleName, ACInstalmentsSettleStored)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    m_oDatabase.SQLRollbackTrans()
                    Return m_lReturn
                End If
            End With

            'Change the plan status
            m_lReturn = StatusUpdate(vPremiumFinance(bSIRPremFinConst.k_PFPlanPFCnt, 0), vPremiumFinance(bSIRPremFinConst.k_PFPlanPFVersion, 0), bSIRPremFinConst.PFStatusIndCompleted)

            'Save
            m_oDatabase.SQLCommitTrans()

            'DD 02/09/2003: No longer used
            'Relcalculate any parent plan
            'm_lReturn = oPFInstalments.MergeInstalments(vPremiumFinance(k_PFPlanPFCnt, 0), _
            ''        vPremiumFinance(k_PFPlanPFVersion, 0))

            'Clean up

            oACTInstalments.Dispose()
            oACTInstalments = Nothing

            oPFInstalments.Dispose()
            oPFInstalments = Nothing

            Return gPMConstants.PMEReturnCode.PMTrue

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="SettlePlanInHouse Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="SettlePlanInHouse", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            m_oDatabase.SQLRollbackTrans()

            Return result

        End Try
    End Function

