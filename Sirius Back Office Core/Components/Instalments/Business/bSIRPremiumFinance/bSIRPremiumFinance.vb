    ' ***************************************************************** '
    '
    ' Name: ProduceEDIMessage
    '
    ' Description:
    '
    'Steve Watton 08/06/2004 Added optional bIsCancellation parameter PN 12141
    'Steve Watton 09/06/2004 Added optional bNonTransactionalMTA parameter PN 12140
    '
    ' ***************************************************************** '
    Public Function ProduceEDIMessage(ByVal vPremFinanceArray As Array, ByVal vReTransmit As String) As Integer
        Return ProduceEDIMessage(vPremFinanceArray:=vPremFinanceArray, vReTransmit:=vReTransmit, bIsCancellation:=False, bIsNonTransactionalMTA:=False)
    End Function

    Public Function ProduceEDIMessage(ByVal vPremFinanceArray As Array, ByVal vReTransmit As String, ByVal bIsCancellation As Boolean, ByVal bIsNonTransactionalMTA As Boolean) As Integer

        Dim result As Integer = 0
        Dim vPolicies As Object = Nothing

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            Dim vPFEdiArray As Array
            Dim vOldPFPlan As Object = Nothing

            'Create object for EDIMessage


            m_oEDIMessage = New bSIRPFEDIMessage.Business
            m_lReturn = m_oEDIMessage.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                ' Log Error Message
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="ProduceEDIMessage Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="ProduceEDIMessage", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                m_oEDIMessage = Nothing
                Return m_lReturn
            End If

            'Get a list of policies for this plan
            With m_oDatabase
                .Parameters.Clear()

                .Parameters.Add("pfprem_finance_cnt", gPMFunctions.ToSafeString(vPremFinanceArray(bSIRPremFinConst.k_PFPlanPFCnt, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                .Parameters.Add("pfprem_finance_version", gPMFunctions.ToSafeString(vPremFinanceArray(bSIRPremFinConst.k_PFPlanPFVersion, 0)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                m_lReturn = .SQLSelect("spu_PFTransaction_id_getpolicies", "Get Policies for Plan", True, , vPolicies)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Or Not Informations.IsArray(vPolicies) Then
                    ' Log Error Message
                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="spu_PFTransaction_id_getpolicies returned no Policies", vApp:=ACApp, vClass:=ACClass, vMethod:="ProduceEDIMessage", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    result = m_lReturn

                    m_oEDIMessage.Dispose()
                    m_oEDIMessage = Nothing
                    Return result
                End If
            End With

            If (gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanSchemeType_ID, 0)) = bSIRPremFinConst.PFThirdParty) And (gPMFunctions.ToSafeString(vPremFinanceArray(bSIRPremFinConst.k_PFPlanTransactionType, 0)) = "M") Then

                vPFEdiArray = vPremFinanceArray

                If gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanPFVersion, 0)) >= 2 Then

                    m_lReturn = GetSingleFinancePlan(v_lFinanceCount:=gPMFunctions.ToSafeInteger(vPremFinanceArray(bSIRPremFinConst.k_PFPlanPFCnt, 0)), v_lFinanceVersion:=gPMFunctions.ToSafeInteger(gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanPFVersion, 0)) - 1), r_vPFPremiumFinance:=vOldPFPlan)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        Return gPMConstants.PMEReturnCode.PMFalse
                    End If

                    'Update Values with MTA Transaction Values

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanAmountToFinance, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanFirstInstalment, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanFirstInstalment, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanFirstInstalment, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanOtherInstalments, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanOtherInstalments, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanOtherInstalments, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanCostOfProtection, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanCostOfProtection, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanCostOfProtection, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanNetAmount, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanNetAmount, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanNetAmount, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanTotalCost, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanTotalCost, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanTotalCost, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanInterestCost, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanInterestCost, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanInterestCost, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanTaxCost, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanTaxCost, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanTaxCost, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanFinanceCharge, 0) = gPMFunctions.ToSafeDouble(vPremFinanceArray(bSIRPremFinConst.k_PFPlanFinanceCharge, 0)) - gPMFunctions.ToSafeDouble(vOldPFPlan(bSIRPremFinConst.k_PFPlanFinanceCharge, 0))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanOriginalAmount, 0) = Val(gPMFunctions.ToSafeString(vPremFinanceArray(bSIRPremFinConst.k_PFPlanOriginalAmount, 0))) - Val(gPMFunctions.ToSafeString(vOldPFPlan(bSIRPremFinConst.k_PFPlanOriginalAmount, 0)))

                    vPFEdiArray(bSIRPremFinConst.k_PFPlanDeposit, 0) = Val(gPMFunctions.ToSafeString(vPremFinanceArray(bSIRPremFinConst.k_PFPlanDeposit, 0))) - Val(gPMFunctions.ToSafeString(vOldPFPlan(bSIRPremFinConst.k_PFPlanDeposit, 0)))

                End If

                'Produce the EDI Message
                'Steve Watton 08/06/2004 Added optional bIsCancellation parameter PN 12141

                m_lReturn = m_oEDIMessage.ProcessEDIMessage(vPremFinanceArray:=vPFEdiArray, vPolicies:=vPolicies, sReTransmit:=vReTransmit, bIsCancellation:=bIsCancellation, bIsNonTransactionalMTA:=bIsNonTransactionalMTA)
            Else
                'Produce the EDI Message
                'Steve Watton 08/06/2004 Added optional bIsCancellation parameter PN 12141

                m_lReturn = m_oEDIMessage.ProcessEDIMessage(vPremFinanceArray:=vPremFinanceArray, vPolicies:=vPolicies, sReTransmit:=vReTransmit, bIsCancellation:=bIsCancellation, bIsNonTransactionalMTA:=bIsNonTransactionalMTA)
            End If

            '    'Produce the EDI Message
            '    m_lReturn = m_oEDIMessage.ProcessEDIMessage( _
            ''        vPremFinanceArray:=vPremFinanceArray, _
            ''        vPolicies:=vPolicies, sReTransmit:=vReTransmit)

            result = m_lReturn

            'Close down object

            m_oEDIMessage.Dispose()
            m_oEDIMessage = Nothing

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="ProduceEDIMessage Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="ProduceEDIMessage", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function


