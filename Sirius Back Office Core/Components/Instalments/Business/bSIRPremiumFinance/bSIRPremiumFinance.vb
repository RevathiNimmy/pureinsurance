        Return InsertNewVersion(v_vExistingPF:=v_vExistingPF, v_lPremiumFinanceCnt:=v_lPremiumFinanceCnt, v_lPremiumFinanceVersion:=v_lPremiumFinanceVersion, v_vPremiumFinanceMTA:=v_vPremiumFinanceMTA, v_dtNextPaymentDate:=v_dtNextPaymentDate, v_lInsuranceFileCnt:=v_lInsuranceFileCnt, v_lPlanTransID:=0)
