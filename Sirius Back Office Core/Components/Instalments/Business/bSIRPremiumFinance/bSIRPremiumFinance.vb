    ' ***************************************************************** '
    ' Name: GetFinancePlanInstalments
    '
    ' Description: This function returns instalments for the given plan
    '
    ' History:
    '   PF060901 - Created
    ' ***************************************************************** '
    Public Function GetFinancePlanInstalments(ByRef v_lFinancePlanCnt As Integer, ByRef v_lFinancePlanVersion As Integer, ByRef r_vFinancePlanArray(,) As Object) As Integer

        Dim result As Integer = 0
        Dim oPFInstalments As bSIRPFInstalments.Business

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            ' Get link to instalments
            'SD 31/07/2002 Scalability changes
            oPFInstalments = New bSIRPFInstalments.Business
            m_lReturn = oPFInstalments.Initialise(sUserName:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            ' Get the instalment array

            m_lReturn = oPFInstalments.GetInstalments(v_lFinancePlanCnt:=v_lFinancePlanCnt, v_lFinancePlanVersion:=v_lFinancePlanVersion, r_vFinancePlanArray:=r_vFinancePlanArray, v_lFilter:=1)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetFinancePlanInstalments Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetFinancePlanInstalments", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

