    Public Function RetrieveScheme(ByRef v_StartDate As Object, ByRef v_ClientID As Object, ByRef v_BusinessType As Object, ByRef v_AmountToFinance As Object, ByRef v_NoOfInstalments As Object, ByRef v_TransType As Object, ByRef v_SystemTag As Object, ByRef v_UseFlipArray As Object, ByRef v_EndDate As Object, ByRef v_PolicyId As Object, ByRef r_vResultString As Object) As Integer

        Dim result As Integer = 0
        Dim vRequestArray(,) As Object
        Dim vSchemeArray(,) As Object
        Dim vProdClass As Object = Nothing
        Dim lPFCount As Integer
        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Simulate access via com
            m_lReturn = Initialise()

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                r_vResultString = "Error - Failed to Initialise Object bPMPremFinance"
                Return result
            End If

            'Perform basic validation on parameters, ensuring datatype is correct
            If Not Informations.IsDate(v_StartDate) Then
                result = gPMConstants.PMEReturnCode.PMFalse
                r_vResultString = "Error - Invalid Start Date"
                Return result
            End If

            If v_EndDate <> "" And Not Informations.IsNothing(v_EndDate) Then
                If Not Informations.IsDate(v_EndDate) Then
                    result = gPMConstants.PMEReturnCode.PMFalse
                    r_vResultString = "Error - Invalid End Date"
                    Return result
                End If
            Else

                v_EndDate = Nothing
            End If

            If gPMFunctions.ToSafeDouble(v_AmountToFinance) < 1 Then
                result = gPMConstants.PMEReturnCode.PMFalse
                r_vResultString = "Error - Finance Amount Must Be More Than ?1"
                Return result
            End If

            If v_NoOfInstalments <> 10 And v_NoOfInstalments <> 1 Then
                result = gPMConstants.PMEReturnCode.PMFalse
                r_vResultString = "Error - Invalid Number of Instalments"
                Return result
            End If

            v_SystemTag = v_SystemTag.ToUpper()
            If v_SystemTag <> "E" And v_SystemTag <> "S" Then
                result = gPMConstants.PMEReturnCode.PMFalse
                r_vResultString = "Error - SystemTag Must Be E or S"
                Return result
            End If

            'Test the flip array value for 1 or 9 as it will be auto used when
            'needed, on entry into the business object via this function
            If v_UseFlipArray <> 1 And v_UseFlipArray <> 9 Then
                result = gPMConstants.PMEReturnCode.PMFalse
                r_vResultString = "Error - Use FlipArray Value Must be 1 or 9. " & Strings.ChrW(13) & Strings.ChrW(10) &
                                  Strings.ChrW(13) & Strings.ChrW(10) &
                                  "CAUTION the Value of 9 Should Only be Used for ACCEPTING" & Strings.ChrW(13) & Strings.ChrW(10) &
                                  "the Results of the Premium Finance Quote"
                Return result
            End If

            'Apply any formating to the parameters prior to retrieving scheme

            m_lReturn = FormatParameters(vStartDate:=v_StartDate, vEndDate:=v_EndDate, vBusinessType:=v_BusinessType, vTransType:=v_TransType, vProductClassCodes:=vProdClass)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                r_vResultString = "Error - Formatting Input Parameters"
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'Initialiase return array

            vRequestArray = Nothing

            'If reached this point then start to process request

            m_lReturn = GetAvailableSchemes(vStartDate:=v_StartDate, vEndDate:=v_EndDate, vProductFamily:=vProdClass, vSystemTag:=v_SystemTag, vNoOfInstall:=v_NoOfInstalments, vResultArray:=vRequestArray, vUseFlipArray:="1")

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'Test to see if only one scheme has been returned.  If so automatically
            'build the selection array and perform calculations before displaying the results.
            If Not Informations.IsArray(vRequestArray) Then
                result = gPMConstants.PMEReturnCode.PMFalse
                r_vResultString = "No Schemes Available"
                Return result
            End If

            'BuildQuote Array ready to send for calculation

            vSchemeArray = Nothing

            m_lReturn = BuildQuoteArray(v_AmountToFinance, v_ClientID, v_TransType, v_PolicyId, vRequestArray, vSchemeArray)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                r_vResultString = "Error - Building of Quote Failed"
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            'Call to calculate premium finance

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                r_vResultString = "Error - Calcuation Process Failed"
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            If v_UseFlipArray = 1 Then

                r_vResultString = gPMFunctions.ToSafeString(vSchemeArray(0, bSIRPremFinConst.k_PFPlanAmountToFinance)) & "^" &
                                  gPMFunctions.ToSafeString(vSchemeArray(0, bSIRPremFinConst.k_PFPlanInterestRate)) & "^" &
                                  gPMFunctions.ToSafeString(vSchemeArray(0, bSIRPremFinConst.k_PFPlanAPR)) & "^" &
                                  gPMFunctions.ToSafeString(vSchemeArray(0, bSIRPremFinConst.k_PFPlanInterestCost)) & "^" &
                                  gPMFunctions.ToSafeString(vSchemeArray(0, bSIRPremFinConst.k_PFPlanNoOfInstalments)) & "^" &
                                  gPMFunctions.ToSafeString(vSchemeArray(0, bSIRPremFinConst.k_PFPlanFirstInstalment)) & "^" &
                                  gPMFunctions.ToSafeString(vSchemeArray(0, bSIRPremFinConst.k_PFPlanOtherInstalments))

                'Test Return Message
            Else
                'PFPremiumFinance table

                m_lReturn = InsertNewPFPlan(vSchemeArray, lPFCount)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    r_vResultString = "Error - Could Not Create Premium Finance Record"
                    Return gPMConstants.PMEReturnCode.PMFalse
                End If

            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="RetrieveScheme Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="RetrieveScheme", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function
    ' ***************************************************************** '
    '
    ' Name: FormatParameters
    '
    ' Description:
    ' ***************************************************************** '
    Public Function FormatParameters(ByRef vStartDate As String, ByRef vEndDate As Object, ByRef vBusinessType As String, ByRef vTransType As String) As Integer
        Return FormatParameters(vStartDate:=vStartDate, vEndDate:=vEndDate, vBusinessType:=vBusinessType, vTransType:=vTransType, vProductClassCodes:=Nothing)
    End Function

    Public Function FormatParameters(ByRef vStartDate As String, ByRef vEndDate As Object, ByRef vBusinessType As String, ByRef vTransType As String, ByRef vProductClassCodes() As Object) As Integer
        Dim result As Integer = 0
        Dim sFirstElement As String = String.Empty
        Dim sSecondElement As String = String.Empty
        Dim sThirdElement As String = String.Empty
        Dim sFourthElement As String = String.Empty
        Dim sSixthElement As String = String.Empty
        Dim sFifthElement As String = String.Empty
        Dim iNumberOfElements As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'if it is commercial and new business
            If (vBusinessType = "Commercial Lines Business Only") And (vTransType = "New Business") Then
                iNumberOfElements = 3
                sFirstElement = "C"
                sSecondElement = "I"
                sThirdElement = "N"
                sFourthElement = "A"

                'if it is personal and new business
            ElseIf (vBusinessType = "Personal Lines Business Only") And (vTransType = "New Business") Then
                iNumberOfElements = 3
                sFirstElement = "P"
                sSecondElement = "W"
                sThirdElement = "N"
                sFourthElement = "A"

                'if it is commercial and renewal
            ElseIf (vBusinessType = "Commercial Lines Business Only") And (vTransType = "Renewal") Then
                iNumberOfElements = 3
                sFirstElement = "M"
                sSecondElement = "I"
                sThirdElement = "R"
                sFourthElement = "A"

                'if it is personal and renewal
            ElseIf (vBusinessType = "Personal Lines Business Only") And (vTransType = "Renewal") Then
                iNumberOfElements = 3
                sFirstElement = "L"
                sSecondElement = "W"
                sThirdElement = "R"
                sFourthElement = "A"

                'if it is any business and new business
            ElseIf (vBusinessType = "Any Business Type") And (vTransType = "New Business") Then
                iNumberOfElements = 5
                sFirstElement = "N"
                sSecondElement = "C"
                sThirdElement = "P"
                sFourthElement = "A"
                sFifthElement = "I"
                sSixthElement = "W"

                'if it is any business and renewal
            ElseIf (vBusinessType = "Any Business Type") And (vTransType = "Renewal") Then

                iNumberOfElements = 5
                sFirstElement = "R"
                sSecondElement = "M"
                sThirdElement = "L"
                sFourthElement = "A"
                sFifthElement = "I"
                sSixthElement = "W"

            End If

            'redimension the array to be the number of elements equal to the number of codes
            ReDim vProductClassCodes(iNumberOfElements)

            If iNumberOfElements = 3 Then

                vProductClassCodes(0) = sFirstElement

                vProductClassCodes(1) = sSecondElement

                vProductClassCodes(2) = sThirdElement

                vProductClassCodes(3) = sFourthElement
            Else

                vProductClassCodes(0) = sFirstElement

                vProductClassCodes(1) = sSecondElement

                vProductClassCodes(2) = sThirdElement

                vProductClassCodes(3) = sFourthElement

                vProductClassCodes(4) = sFifthElement

                vProductClassCodes(5) = sSixthElement
            End If

            Dim TempDate As Date
            vStartDate = If(DateTime.TryParse(vStartDate, TempDate), TempDate.ToString("yyyy/MM/dd"), vStartDate)
            If Informations.IsDate(vEndDate) Then

                vEndDate = CDate(vEndDate).ToString("yyyy/MM/dd")
            Else

                vEndDate = CDate("31/12/2199")

                vEndDate = CDate(vEndDate).ToString("yyyy/MM/dd")
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="FormatParameters Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="FormatParameters", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function
    ' ***************************************************************** '
    '
    ' Name: BuildQuoteArray
    '
    ' Description:
    '
    ' ***************************************************************** '
    Public Function BuildQuoteArray(ByRef vAmountToFinance As Object, ByRef vClientID As Object, ByRef vTransType As String, ByRef vPolicyID As Object, ByRef vRequestArray(,) As Object) As Integer
        Return BuildQuoteArray(vAmountToFinance:=vAmountToFinance, vClientID:=vClientID, vTransType:=vTransType, vPolicyID:=vPolicyID, vRequestArray:=vRequestArray, vSchemeArray:=Nothing)
    End Function

    Public Function BuildQuoteArray(ByRef vAmountToFinance As Object, ByRef vClientID As Object, ByRef vTransType As String, ByRef vPolicyID As Object, ByRef vRequestArray(,) As Object, ByRef vSchemeArray(,) As Object) As Integer
        Dim result As Integer = 0
        Dim iNoOfSchemes As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'For the present set iNoOfSchemes to 0.  This indicates that only the
            'first scheme has been selected from the returned array
            iNoOfSchemes = 0

            vSchemeArray = Nothing

            ReDim vSchemeArray(iNoOfSchemes, bSIRPremFinConst.k_PFPlanCountOfFields)

            For iSelScheme As Integer = 0 To iNoOfSchemes

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanCompanyNo) = vRequestArray(4, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanSchemeNo) = vRequestArray(5, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanSchemeVersion) = vRequestArray(2, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanStartDate) = vRequestArray(3, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanAmountToFinance) = vAmountToFinance

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanProductClass) = vRequestArray(6, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanNBInd) = vRequestArray(7, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanMTAInd) = vRequestArray(8, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanRNWLInd) = vRequestArray(9, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanCNCLInd) = vRequestArray(10, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanPPInd) = vRequestArray(11, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanCompanyName) = vRequestArray(0, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanSchemeName) = vRequestArray(1, iNoOfSchemes)
                If vTransType = "New Business" Then

                    vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanTransactionType) = "NB"
                Else

                    vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanTransactionType) = "REN"
                End If

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanQuoteDocID) = vRequestArray(12, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanBankDocID) = vRequestArray(13, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanCreditDocID) = vRequestArray(14, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanEndDate) = vRequestArray(15, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanClientId) = vClientID

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanClientCode) = ""

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanSystemTag) = vRequestArray(16, iNoOfSchemes)

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanFinCollPlanRef) = vPolicyID

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanAutoGenPlanRef) = ""

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanFinCollPlanRef) = "" 'MKW190903

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanPFCnt) = "0"

                vSchemeArray(iSelScheme, bSIRPremFinConst.k_PFPlanInterestFree) = "N"
            Next iSelScheme

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(m_sUsername, gPMConstants.PMELogLevel.PMLogOnError, "BuildQuoteArray Failed", MainModule.ACApp, ACClass, "BuildQuoteArray", Informations.Err().Number, excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ***************************************************************** '
    '
    ' Name: GetNextPFCount
    '
    ' Description: To allocate next sequential count on the premium finance
    '              table
    '
    ' ***************************************************************** '
    Public Function GetNextPFCount(ByRef lPFCount As Integer) As Integer
        Dim result As Integer = 0
        Dim vResultArray(,) As Object = Nothing
        Dim sSqlString, sSqlName As String
        Dim bStoredProc, bKeepNull As Boolean

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            sSqlString = "SELECT MAX (pfprem_finance_cnt) from pfpremiumfinance "

            sSqlName = "Alloc Next Count On PFPremiumFinance"
            bStoredProc = False
            bKeepNull = True

            m_lReturn = m_oDatabase.SQLSelect(sSqlString, sSqlName, bStoredProc,  , vResultArray)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            If Not Informations.IsArray(vResultArray) Or gPMFunctions.ToSafeString(vResultArray(0, 0)) = "" Then
                lPFCount = 1
            Else
                'Increment the count

                lPFCount = gPMFunctions.ToSafeInteger(gPMFunctions.ToSafeDouble(vResultArray(0, 0)) + 1)
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetNextPFCount Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetNextPFCount", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ***************************************************************** '
    '
    ' Name: GetPolicy Cnt from Transactions
    '
    ' Description:
    '
    '
    ' ***************************************************************** '
    Public Function GetPolicyfromTransactions(ByRef lPremFinCnt As Integer, ByRef lPremFinVersion As Integer, ByRef vPolicyCnt As Array) As Integer
        Dim result As Integer = 0
        Dim vPolicyRef As Object = Nothing
        Dim sSqlString, sSqlName As String
        Dim bStoredProc, bKeepNull As Boolean
        Dim vDatabase As Object = Nothing
        Dim bDuplicate As Boolean
        Dim vResultArray(,) As Object = Nothing
        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            sSqlString = "SELECT  PfTransaction_id " &
                         "FROM  PFTransaction_Id " &
                         "WHERE pfprem_finance_cnt = '" & gPMFunctions.ToSafeString(lPremFinCnt) & "'" &
                         " AND pfprem_finance_version= '" & gPMFunctions.ToSafeString(lPremFinVersion) & "'"

            sSqlName = "Get Policies From PFPremiumFinance Transactions"
            bStoredProc = False
            bKeepNull = True

            m_lReturn = m_oDatabase.SQLSelect(sSqlString, sSqlName, bStoredProc,  , vResultArray,  ,  ,  , bKeepNull)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            If Not Informations.IsArray(vResultArray) Then
                Return m_lReturn
            End If

            m_oDataBaseOrion = New dPMDAO.Database()

            m_lReturn = gPMComponentServices.CheckDatabase(v_sUsername:=m_sUsername, v_iSourceID:=m_iSourceID, v_iLanguageID:=m_iLanguageID, v_lPMProductFamily:=gPMConstants.PMEProductFamily.pmePFOrion, r_bNewInstanceCreated:=m_bCloseDatabase, r_oCheckedDatabase:=m_oDataBaseOrion, v_vDatabase:=vDatabase)

            For lRow As Integer = vResultArray.GetLowerBound(1) To vResultArray.GetUpperBound(1)

                sSqlString = "SELECT  insurance_ref " &
                             "FROM  transdetail" &
                             " WHERE transdetail_id =  " & gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(vResultArray(0, lRow)))
                sSqlName = "Get Policies Ref for Transactions"
                bStoredProc = False
                bKeepNull = True

                m_lReturn = m_oDataBaseOrion.SQLSelect(sSqlString, sSqlName, bStoredProc,  , vPolicyRef,  ,  ,  , bKeepNull)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = m_lReturn
                    m_lReturn = m_oDataBaseOrion.CloseDatabase()
                    Return result
                End If

                If Not Informations.IsArray(vPolicyRef) Then
                    result = m_lReturn
                    m_lReturn = m_oDataBaseOrion.CloseDatabase()
                    Return result
                End If
                Dim auxVar As Object = vPolicyRef(0, 0)

                If Not (Convert.IsDBNull(auxVar) Or Informations.IsNothing(auxVar)) Then

                    sSqlString = "SELECT  insurance_file_cnt " &
                                 "FROM  insurance_file" &
                                 " WHERE insurance_ref =  '" & gPMFunctions.ToSafeString(vPolicyRef(0, 0)) & "'"
                    sSqlName = "Get Policy Cnt for Transactions"
                    bStoredProc = False
                    bKeepNull = True
                    m_lReturn = m_oDatabase.SQLSelect(sSqlString, sSqlName, bStoredProc,  , vPolicyRef,  ,  ,  , bKeepNull)

                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        result = m_lReturn
                        m_lReturn = m_oDataBaseOrion.CloseDatabase()
                        Return result
                    End If

                    If Not Informations.IsArray(vPolicyRef) Then
                        result = m_lReturn
                        m_lReturn = m_oDataBaseOrion.CloseDatabase()
                        Return result
                    End If
                    If Not Informations.IsArray(vPolicyCnt) Then
                        vPolicyCnt = Array.CreateInstance(GetType(Object), New Integer() {1, 1}, New Integer() {0, 0})

                        vPolicyCnt(0, 0) = gPMFunctions.ToSafeInteger(vPolicyRef(0, 0))
                    Else
                        bDuplicate = False
                        For lCount As Integer = vPolicyCnt.GetLowerBound(1) To vPolicyCnt.GetUpperBound(1)

                            vPolicyCnt(0, lCount) = gPMFunctions.ToSafeInteger(vPolicyRef(0, 0))
                            bDuplicate = True
                        Next lCount
                        If Not bDuplicate Then
                            vPolicyCnt = ArraysHelper.RedimPreserve(Of Object(,))(vPolicyCnt, New Integer() {1, vPolicyCnt.GetUpperBound(1) + 2}, New Integer() {0, 0})

                            vPolicyCnt(0, vPolicyCnt.GetUpperBound(1)) = gPMFunctions.ToSafeInteger(vPolicyRef(0, 0))
                        End If
                    End If
                End If

            Next lRow
            m_lReturn = m_oDataBaseOrion.CloseDatabase()
            If Informations.IsArray(vPolicyCnt) Then
                m_lReturn = gPMFunctions.FlipArray(vPolicyCnt)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Return m_lReturn
                End If
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetPolicyFromTransactions Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetPolicyFromTransactions", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

