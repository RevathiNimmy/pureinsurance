            Return nResult
        End Try
    End Function

    '*************************************************************************
    ' Name:         InsertSupercedingPlan
    ' Description:  Inserts a new version of the current record. Unpaid
    '               instalments are NOT transferred. Unpaid Instalments from
    '               old Plan are deleted
    ' TR120303   -  Copied from InsertNewVersion but removed the call to copy
    '               instalments over as this will be used for MTA's, and
    '               Instalments will always be created independently from here
    '*************************************************************************
    'PSL 21/03/2003 Issue 2992
    'Pass the Premium finance version back as byref so that the corrct record is reference to, from now on
    Public Function InsertSupercedingPlan(ByRef r_vNewPFPlan As Array, ByVal v_lPremiumFinanceCnt As Integer, ByRef r_lPremiumFinanceVersion As Integer, ByVal v_vTransDetailArray(,) As Object, Optional ByVal nMTAType As Integer = bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread) As Integer
        Return InsertSupercedingPlan(r_vNewPFPlan:=r_vNewPFPlan, v_lPremiumFinanceCnt:=v_lPremiumFinanceCnt, r_lPremiumFinanceVersion:=r_lPremiumFinanceVersion, v_vTransDetailArray:=v_vTransDetailArray, v_dtNextPaymentDate:=Nothing, v_lInsuranceFileCnt:=0, v_lPlanTransID:=0, nMTAType:=nMTAType)
    End Function

    ''' <summary>
    ''' InsertSupercedingPlan
    ''' </summary>
    ''' <param name="r_vNewPFPlan"></param>
    ''' <param name="v_lPremiumFinanceCnt"></param>
    ''' <param name="r_lPremiumFinanceVersion"></param>
    ''' <param name="v_vTransDetailArray"></param>
    ''' <param name="v_dtNextPaymentDate"></param>
    ''' <param name="v_lInsuranceFileCnt"></param>
    ''' <param name="v_lPlanTransID"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function InsertSupercedingPlan(ByRef r_vNewPFPlan As Array,
                                          ByVal v_lPremiumFinanceCnt As Integer,
                                          ByRef r_lPremiumFinanceVersion As Integer,
                                          ByVal v_vTransDetailArray(,) As Object,
                                          ByRef v_dtNextPaymentDate As Object,
                                          ByVal v_lInsuranceFileCnt As Integer,
                                          ByVal v_lPlanTransID As Integer,
                                          Optional ByVal nMTAType As Integer = bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread) As Integer

        Dim nResult As Integer = 0
        Dim sSqlString As String = ""
        Dim oTransArray(,) As Object = Nothing
        Dim nLBound, nUBound, nOldPlanVerNo, nNewPlanVerNo As Integer
        Dim bDepositAsInstalment As Boolean
        Dim crExistDeposit As Decimal
        Dim oLeadAgent(,) As Object = Nothing
        Dim bNewlyTranArryaddedYN As Boolean = False
        Dim oSinglePlanParty(,) As Object = Nothing
        Dim sICCS As String = ""

        'MKW190903 START Get Iccs Number
        m_lReturn = GETICCS(sICCS)
        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
            sICCS = ""
        End If

        Try
            'TR - Make sure that the array is populated
            If Not Informations.IsArray(r_vNewPFPlan) Then
                Return gPMConstants.PMEReturnCode.PMFail
            Else
                'TR - Assume success
                nResult = gPMConstants.PMEReturnCode.PMTrue
            End If
            nOldPlanVerNo = r_lPremiumFinanceVersion
            nNewPlanVerNo = r_lPremiumFinanceVersion + 1
            'PSL 21/03/2003 Issue 2992
            r_lPremiumFinanceVersion = nNewPlanVerNo

            'TR - Start transaction
            m_lReturn = m_oDatabase.SQLBeginTrans()
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            'TR - Make sure that there are Transactions before processing them
            If Informations.IsArray(v_vTransDetailArray) Then
                'TR - Loop through the Array of Transactions if there are any
                nLBound = v_vTransDetailArray.GetLowerBound(1)
                nUBound = v_vTransDetailArray.GetUpperBound(1)
                For lRowIndex As Integer = nLBound To nUBound
                    'TR - First time in the loop, create our local array
                    If Not Informations.IsArray(oTransArray) Then
                        ReDim oTransArray(0, 0)
                    Else
                        'TR - Successive time in loop, just increase size of array

                        ReDim Preserve oTransArray(0, oTransArray.GetUpperBound(1) + 1)
                    End If
                    'TR - Add a new column to the array and populate it with
                    'corresponding column from passed in array

                    oTransArray(0, oTransArray.GetUpperBound(1)) = v_vTransDetailArray(0, lRowIndex)
                Next lRowIndex

                'MKW120903 PF 3rd Party MTA START
                'MKW13129
