    ' ***************************************************************** '
    '
    ' Name: GetBranchAndProducts
    '
    ' Description:  Returns the Branches and Products for the array of
    '               Insurance files.
    '
    ' History: 27/09/2001 DD - Created.
    '
    ' ***************************************************************** '
    Public Function GetBranchesAndProducts(ByRef vInsuranceFiles(,) As Object, ByRef vBranches(,) As Object, ByRef vProducts(,) As Object) As Integer
        Dim result As Integer = 0
        Dim sOrBit As String = ""
        Dim sWhere As New StringBuilder

        Try

            'Build the SQL
            sWhere = New StringBuilder("WHERE ")
            sOrBit = ""
            For iRow As Integer = vInsuranceFiles.GetLowerBound(1) To vInsuranceFiles.GetUpperBound(1)

                sWhere.Append(sOrBit & "insurance_ref='" & gPMFunctions.ToSafeString(vInsuranceFiles(1, iRow)) & "'")
                sOrBit = " OR "
            Next iRow

            'Get each array
            m_lReturn = m_oDatabase.SQLSelect(sSQL:="SELECT source_id FROM Insurance_File " & sWhere.ToString() & " GROUP BY source_id", sSQLName:="Select Source from Insurance File", bStoredProcedure:=False, vResultArray:=vBranches)

            m_lReturn = m_oDatabase.SQLSelect(sSQL:="SELECT product_id FROM Insurance_File " & sWhere.ToString() & " GROUP BY " &
                        "product_id", sSQLName:="Select Product from Insurance File", bStoredProcedure:=False, vResultArray:=vProducts)

            'that's it

            Return gPMConstants.PMEReturnCode.PMTrue

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetBranchesAndProducts Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetBranchesAndProducts", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

