    ''' <param name="nFinanceVersion"></param>
    ''' <param name="r_oNextInstalmentDate"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Function GetSingleFinancePlanNextInstDate(
                        ByVal nFinanceCount As Integer,
                        ByVal nFinanceVersion As Integer,
                        ByRef r_oNextInstalmentDate As Object) As Integer

        Const sMethodName As String = "GetSingleFinancePlanNextInstDate"
        Dim oPFPremiumFinance As Object = Nothing

        Try
            GetSingleFinancePlanNextInstDate = gPMConstants.PMEReturnCode.PMTrue

            AddParameterLite(m_oDatabase, "npfprem_finance_cnt", nFinanceCount, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger, True)
            AddParameterLite(m_oDatabase, "npfprem_finance_version", nFinanceVersion, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMInteger)


            m_lReturn = m_oDatabase.SQLSelect(
                sSQL:=ksACGetPFPremiumFinanceSingleNextDateSQL,
                sSQLName:=ksACGetPFPremiumFinanceSingleNextDateName,
                bStoredProcedure:=kbACGetPFPremiumFinanceSingleNextDateStored,
                vResultArray:=oPFPremiumFinance)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                RaiseError("m_oDatabase.SQLSelect", "sSQL:=ACGetPFPremiumFinanceSingleNextDateSQL", gPMConstants.PMELogLevel.PMLogError)
