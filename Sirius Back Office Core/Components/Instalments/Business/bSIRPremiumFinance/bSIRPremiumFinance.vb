                result = gPMConstants.PMEReturnCode.PMFalse
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to add parameter InsuranceFileCnt", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessPF")
                Return result
            End If
            m_lReturn = m_oDatabase.SQLSelect(sSQL:="spu_PFGetTransactionsFromInsuranceFile", sSQLName:="PFGetTransactionsFromInsuranceFile", bStoredProcedure:=True, vResultArray:=vTransArray)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed on SQLAction", vApp:=ACApp, vClass:=ACClass, vMethod:="ProcessPF")
                Return result
            End If
            If Not Informations.IsArray(vTransArray) Then
                'No Transactions
                Return result
            Else

                ReDim vPfTransArray(3, vTransArray.GetUpperBound(1))

                For lCount As Integer = 0 To vTransArray.GetUpperBound(1)

                    vPfTransArray(0, lCount) = vTransArray(0, lCount)

                    vPfTransArray(1, lCount) = vTransArray(1, lCount)

                    vPfTransArray(2, lCount) = vTransArray(2, lCount)

                    vPfTransArray(3, lCount) = vTransArray(4, lCount)
                Next lCount
            End If

            crAmountToFinance = 0

            For lCount As Integer = vTransArray.GetLowerBound(1) To vTransArray.GetUpperBound(1)

                crAmountToFinance += gPMFunctions.ToSafeDouble(vTransArray(2, lCount))
            Next lCount
            m_crChangeToFinanceAmount = crAmountToFinance

            'Get Company Number from Insurance File

            m_lReturn = GetSourceIDFromTransdetailID(v_lTransdetailID:=gPMFunctions.ToSafeInteger(vTransArray(0, 0)), r_lSourceID:=lCompanyNo, r_lSubBranchId:=lSubBranchID)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                gPMFunctions.RaiseError("GetSourceIDFromTransdetailID", "v_lTransdetailID:=" & gPMFunctions.ToSafeString(vTransArray(0, 0)), gPMConstants.PMELogLevel.PMLogError)
            End If

            'Get Current Scheme Version
            Dim vSchemeArray(,) As Object = Nothing
            lSchemeVersion = 0
            m_oDatabase.Parameters.Clear()
            m_lReturn = m_oDatabase.Parameters.Add(sName:="SchemeNo", vValue:=gPMFunctions.ToSafeString(v_lFinancePlanSchemeNo), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)
