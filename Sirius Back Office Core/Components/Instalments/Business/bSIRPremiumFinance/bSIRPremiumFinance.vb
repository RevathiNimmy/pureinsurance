    Private Function CheckSGRenewalType(ByVal v_sProviderCode As String, ByVal v_lPartyCnt As Integer, ByRef r_bIsRenewal As Boolean, ByRef r_bIsBrokerRenewal As Boolean) As Integer

        Dim result As Integer = 0

        Const ACGetSGRenewalsSQL As String = "spu_PF_GetSGRenewals"
        Const ACGetSGRenewals As String = "GetSGRenewals"

        Dim sSQL As String = ""

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            With m_oDatabase

                .Parameters.Clear()

                m_lReturn = .Parameters.Add("workdate", DateTime.Today, gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMDate)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception()
                End If

                m_lReturn = .Parameters.Add("dayallowance", gPMFunctions.ToSafeString(30), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception()
                End If

                m_lReturn = .Parameters.Add("clientid", gPMFunctions.ToSafeString(v_lPartyCnt), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception()
                End If

                m_lReturn = .SQLSelect(ACGetSGRenewalsSQL, ACGetSGRenewals, True)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception()
                End If

                If .Records.Count() > 0 Then
                    'ok we have renewal records so set the flag!
                    r_bIsRenewal = True
                    r_bIsBrokerRenewal = True

                    'now loop through each of the returned records
                    For lpRenewals As Integer = 1 To .Records.Count()
                        'check if the scheme code is the same as the one passed in

                        If .Records.Item(lpRenewals - 1).Fields("schemename") = v_sProviderCode Then
                            r_bIsBrokerRenewal = False
                        End If
                    Next lpRenewals
                Else
                    r_bIsRenewal = False
                    r_bIsBrokerRenewal = False
                End If

            End With

            Return result

        Catch

            Return gPMConstants.PMEReturnCode.PMError
        End Try

    End Function

