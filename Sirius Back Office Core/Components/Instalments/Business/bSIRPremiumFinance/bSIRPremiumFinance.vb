    '*************************************************************************
    'Name:          Terminate
    'Description:   Checks for the existance of modular objects, calls their
    '               terminate function and destroys them.
    'History:
    '*************************************************************************
    Private disposedValue As Boolean
    Public Sub Dispose() Implements IDisposable.Dispose
        Dispose(True)
        GC.SuppressFinalize(Me)
    End Sub


    Protected Sub Dispose(disposing As Boolean)
        If Not Me.disposedValue Then
            Me.disposedValue = True
            If disposing Then
                If m_oOrionLink IsNot Nothing Then
                    m_oOrionLink.Dispose()
                    m_oOrionLink = Nothing
                End If
                If m_oPremiumFinance IsNot Nothing Then
                    m_oPremiumFinance.Dispose()
                    m_oPremiumFinance = Nothing
                End If
                If m_oInsuranceFile IsNot Nothing Then
                    m_oInsuranceFile.Dispose()
                    m_oInsuranceFile = Nothing
                End If
                If m_oPFInstalments IsNot Nothing Then
                    m_oPFInstalments.Dispose()
                    m_oPFInstalments = Nothing
                End If
                If m_oLookup IsNot Nothing Then
                    m_oLookup.Dispose()
                    m_oLookup = Nothing
                End If
                If m_oCurrencyConvert IsNot Nothing Then
                    m_oCurrencyConvert.Dispose()
                    m_oCurrencyConvert = Nothing
                End If
                If m_bCloseDatabase Then
                    m_oDatabase.CloseDatabase()
                End If
                m_oDatabase = Nothing
            End If
        End If
        Me.disposedValue = True
    End Sub


