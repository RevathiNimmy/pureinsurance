    ' ***************************************************************** '
    ' Name: CheckAllocationAgainstPolicy
    '
    ' Description: Checks Payment against this policy has been posted or not
    '
    ' History: 27/07/2006 Rahul Jaiswal - Created
    ' ***************************************************************** '

    Public Function CheckAllocationAgainstPolicy(ByVal v_lInsuranceFileCnt As Integer, ByRef r_bAllocationExist As Boolean) As Integer

        Dim result As Integer = 0
        Try

            Dim vResultArray(,) As Object = Nothing

            result = gPMConstants.PMEReturnCode.PMTrue

            With m_oDatabase

                .Parameters.Clear()

                m_lReturn = .Parameters.Add(sName:="insurance_file_cnt", vValue:=gPMFunctions.ToSafeString(v_lInsuranceFileCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                    result = m_lReturn

                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CheckAllocationAgainstPolicy  Failed to add Parameter to Stored Proc", vApp:=ACApp, vClass:=ACClass, vMethod:="CheckAllocationAgainstPolicy", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    Return result

                End If

                m_lReturn = .SQLSelect(sSQL:=ACCheckAllocationAgainstPolicySQL, sSQLName:=ACCheckAllocationAgainstPolicyName, bStoredProcedure:=ACCheckAllocationAgainstPolicyStored, vResultArray:=vResultArray)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                    result = m_lReturn

                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CheckAllocationAgainstPolicy Failed to process the Stored Proc", vApp:=ACApp, vClass:=ACClass, vMethod:="CheckAllocationAgainstPolicy", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    Return result

                End If

            End With
            If Informations.IsArray(vResultArray) Then

                r_bAllocationExist = gPMFunctions.ToSafeCurrency(gPMFunctions.ToSafeInteger(vResultArray(1, 0))) <> 0 Or gPMFunctions.ToSafeInteger(gPMFunctions.ToSafeInteger(vResultArray(2, 0))) = 1

            Else
                r_bAllocationExist = False
            End If

            Return result

        Catch

            Return gPMConstants.PMEReturnCode.PMError
        End Try

    End Function

    Public Function GetOutStandingDeposit(ByVal v_lPremiumFinanceCnt As Integer, ByVal v_lPremiumFinancePlanVer As Integer, ByRef r_cDepositAmount As Decimal) As Integer

        Dim result As Integer = 0
        Dim vResultArray As Object = Nothing


        Try
            r_cDepositAmount = 0

            result = gPMConstants.PMEReturnCode.PMTrue

            Dim sSQL As String = "select PFInstalments.Amount from PFInstalments where pfprem_finance_cnt = " & v_lPremiumFinanceCnt

            sSQL = sSQL & " AND InstalmentNumber = 0 "
            sSQL = sSQL & " AND (PFInstalments.Status <> 3) "
            sSQL = sSQL & " and PFInstalments.TransactionCode IN (5,7) "
            sSQL = sSQL & " and PFInstalments.pfprem_finance_version =  " & v_lPremiumFinancePlanVer

            With m_oDatabase

                .Parameters.Clear()

                result = .SQLSelect(sSQL:=sSQL, sSQLName:="GetOutStandingDeposit", bStoredProcedure:=False, vResultArray:=vResultArray)

                If result <> gPMConstants.PMEReturnCode.PMTrue Then

                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CheckDeposit Failed to process the Stored Proc", vApp:=ACApp, vClass:=ACClass, vMethod:="CheckDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    Return result

                End If

                If Informations.IsArray(vResultArray) Then
                    r_cDepositAmount = ToSafeDecimal(vResultArray(0, 0))
                End If

            End With

        Catch ex As Exception

            Return PMConst.PMFail
        End Try

        Return result
    End Function

    Public Function CheckDeposit(ByVal v_lPremiumFinanceCnt As Integer, ByVal v_lPremiumFinancePlanVer As Integer, ByRef r_cDepositAmount As Decimal, ByRef r_bDepositAsInstalment As Boolean) As Integer

        Dim result As Integer = 0
        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            With m_oDatabase

                .Parameters.Clear()

                m_lReturn = .Parameters.Add(sName:="PremiumFinanceCnt", vValue:=gPMFunctions.ToSafeString(v_lPremiumFinanceCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                    result = m_lReturn

                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CheckDeposit Failed to add Parameter to Stored Proc", vApp:=ACApp, vClass:=ACClass, vMethod:="CheckDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    Return result

                End If

                m_lReturn = .Parameters.Add(sName:="PremiumFinanceVersion", vValue:=gPMFunctions.ToSafeString(v_lPremiumFinancePlanVer), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                    result = m_lReturn

                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CheckDeposit Failed to add Parameter to Stored Proc", vApp:=ACApp, vClass:=ACClass, vMethod:="CheckDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    Return result

                End If

                m_lReturn = .SQLSelect(sSQL:=ACCheckDepositSQL, sSQLName:=ACCheckDepositName, bStoredProcedure:=ACCheckDepositStored)

                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                    result = m_lReturn

                    bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="CheckDeposit Failed to process the Stored Proc", vApp:=ACApp, vClass:=ACClass, vMethod:="CheckDeposit", vErrNo:=Informations.Err().Number, vErrDesc:=Informations.Err().Description)

                    Return result

                End If

                If .Records.Count() >= 1 Then

                    r_bDepositAsInstalment = gPMFunctions.NullToBoolean(.Records.Item(0).Fields("deposit_as_instalment"))
                    If gPMFunctions.NullToBoolean(.Records.Item(0).Fields("deposit_as_instalment")) Then
                        If gPMFunctions.NullToLong(.Records.Item(0).Fields("status")) <> 3 Then
                            r_cDepositAmount = gPMFunctions.NullToCurrency(.Records.Item(0).Fields("amount"))
                        Else
                            r_cDepositAmount = 0
                        End If
                    Else
                        r_cDepositAmount = 0
                    End If
                Else
                    r_bDepositAsInstalment = False
                    r_cDepositAmount = 0
                End If

            End With

            Return result

        Catch

            Return gPMConstants.PMEReturnCode.PMError
        End Try

    End Function

    ' *****************************************************************
    ' PN 71095
    ' Update Payment_Method
    ' *****************************************************************
    Public Function UpdatePaymentMethod(ByVal v_lInsuranceFileCnt As Integer) As Integer

        Dim result As Integer = 0
        Try
            result = gPMConstants.PMEReturnCode.PMTrue

            m_oDatabase.Parameters.Clear()

            If m_oDatabase.Parameters.Add(sName:="InsuranceFileCnt", vValue:=gPMFunctions.ToSafeString(v_lInsuranceFileCnt), iDirection:=gPMConstants.PMEParameterDirection.PMParamInput, iDataType:=gPMConstants.PMEDataType.PMLong) <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                Throw New Exception
            End If

            If m_oDatabase.SQLSelect(sSQL:=ACUpdatePaymentMethodSQL, sSQLName:=ACUpdatePaymentMethodName, bStoredProcedure:=ACUpdatePaymentMethodStored) <> gPMConstants.PMEReturnCode.PMTrue Then
                result = gPMConstants.PMEReturnCode.PMFalse
                Throw New Exception
            End If

            Return result
        Catch ex As Exception

            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:="UpdatePaymentMethod", r_lFunctionReturn:=result, excep:=ex)

        Finally


        End Try
        Return result
    End Function

