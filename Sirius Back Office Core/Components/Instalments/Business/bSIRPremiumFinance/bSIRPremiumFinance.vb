    ' ***************************************************************** '
    ' Name: ProcessCreditControl
    '
    ' Description: Generates Credit Control Items for each Instalment
    '              This is used to invoice for Instalments in advance.
    '
    ' History:
    ' AAB 25/03/2003 : Created
    ' ***************************************************************** '
    Private Function ProcessCreditControl(ByVal sTransactionType As String, ByVal lPremiumFinanceCnt As Integer, ByVal lPRemiumFinanceVer As Integer) As Integer

        Dim result As Integer = 0
        Dim sErrorMessage As String = ""
        Dim lReturn As Integer


        Dim oACTInstalments As bACTInstalments.Business
        Dim lOldPlanVerNo As Integer

        result = gPMConstants.PMEReturnCode.PMTrue

        Select Case sTransactionType
            Case "NB", "EDIT", "REN", "MTR"
                ' New Business, Mid Term Adjustment, Edit Policy,  Renewals, Reinstate Policy / Risk
                lReturn = AddCreditControlItem(sTransactionType)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = lReturn
                    sErrorMessage = "ProcessCreditControl failed to add Credit Control Item"
                    Throw New Exception()
                End If

            Case "MTA", "M"
                lReturn = AddCreditControlItem(sTransactionType)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = lReturn
                    sErrorMessage = "ProcessCreditControl failed to add Credit Control Item"
                    Throw New Exception()
                End If

                'After we add it we check to see if we need to remove the old transactions

                Select Case m_iInstalmentsMTAType
                    Case bSIRPremFinConst.m_klInstalmentMTAType_AddAndSpread, bSIRPremFinConst.m_klInstalmentMTAType_AddToNext

                        'Delete OLD ITems.
                        'Create an object for Orion

                        oACTInstalments = New bACTInstalments.Business
                        m_lReturn = oACTInstalments.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                            m_lReturn = m_oDatabase.SQLRollbackTrans()

                            oACTInstalments.Dispose()
                            oACTInstalments = Nothing
                            Return result
                        End If
                        lOldPlanVerNo = lPRemiumFinanceVer - 1
                        'TR - Delete the instalments for the previous plan (unpaid instalments only)

                        m_lReturn = oACTInstalments.DeleteCancelledInstalments(lPremiumFinanceCnt, lOldPlanVerNo)

                        If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                            oACTInstalments.Dispose()
                            oACTInstalments = Nothing
                            Return result
                        End If
                    Case 2

                End Select

            Case "MTC"
                ' Cancellation of Policy

                ' New Business, Mid Term Adjustment, Renewals
                lReturn = DeleteCreditControlItem(m_lInsuranceFileCnt)

                If lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    result = lReturn
                    sErrorMessage = "ProcessCreditControl failed to delete Credit Control Item"
                    Throw New Exception()
                End If

            Case Else
                ' Do Error trapping here if needed

        End Select

        Return result

    End Function

    '****************************************************************************
    ' Procedure:    TransactXML
    ' Date:         16-03-05
    ' Author:       Aaron Rhodes
    ' Usage:        Transacts an MTA via the PF connectivity DLL. Currently unused
    '               until providers support MTA's however this code MUST NOT BE REMOVED
    '               as it WILL be used soon!
    '****************************************************************************
    Private Function TransactXML(ByRef r_vPremiumFinanceArray As Array, ByVal v_vTransArray(,) As Object, ByVal v_lMTAType As Integer) As Integer

        Dim result As Integer = 0
        Const kMethodName As String = "TransactXML"

        Dim oPFSubmit As New bSIRPFSubmit.Application
        Dim lSchemeID As Integer
        Dim vArray(,) As Object = Nothing
        Dim sTmp As String = ""
        Dim bIsRenewl, bBrokerRenewal As Boolean
        Dim sCode As String = ""

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'get an instance of our submit component
            ' Replace use of ObjectManager when creating objects. PN23065.

            oPFSubmit = New bSIRPFSubmit.Application
            m_lReturn = oPFSubmit.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                gPMFunctions.RaiseError("gPMComponentServices.CreateBusinessObject", "v_sClassName:=bSIRPFSubmit.Application", gPMConstants.PMELogLevel.PMLogError)
            End If

            'now we need to try and send the accept message - we need to bomb out if
            'this doesn't work as sbo will be out of sync..
            If Not (oPFSubmit Is Nothing) Then

                m_dtQuoteDate = DateTime.Now

                m_lReturn = GetAllPFRFs(vArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    gPMFunctions.RaiseError("GetAllPFRFs", "Failed", gPMConstants.PMELogLevel.PMLogError)
                End If

                If Not (Informations.IsArray(vArray)) Then
                    gPMFunctions.RaiseError("GetAllPFRFs", "vArray is not an array", gPMConstants.PMELogLevel.PMLogError)
                End If

                lSchemeID = -1

                For x As Integer = vArray.GetLowerBound(1) To vArray.GetUpperBound(1)

                    If gPMFunctions.ToSafeDouble(vArray(2, x)) = gPMFunctions.ToSafeInteger(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanSchemeNo, 0)) Then
                        lSchemeID = x
                        Exit For
                    End If
                Next x

                If lSchemeID = -1 Then
                    gPMFunctions.RaiseError("GetAllPFRFs", "Scheme ID not found", gPMConstants.PMELogLevel.PMLogError)
                End If

                With oPFSubmit

                    .BrokerID = GetSGBrokerID(vArray, lSchemeID, CDec(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)))

                    .url = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanURL, 0))

                    .PartyCnt = gPMFunctions.NullToLong(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientId, 0))

                    .ProviderCode = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanXSLCode, 0)).Trim()

                    .UserName = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanUsername, 0))

                    .Password = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanPassword, 0))

                    .AccountNo = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanBankAccountNo, 0)).Trim()

                    .SortCode = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanBankSortCode, 0)).Trim()

                    .ClientName = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientName, 0)).Trim()

                    .AccountName = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanBankAccountName, 0)).Trim()

                    .Premium = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanAmountToFinance, 0)).Trim()

                    .Instalments = gPMFunctions.NullToLong(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanNoOfInstalments, 0))

                    If gPMFunctions.ToSafeString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanTerms, 0)) <> "" Then

                        .Terms = gPMFunctions.NullToLong(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanTerms, 0))
                    End If

                    .Percentage = gPMFunctions.NullToDouble(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanOriginalRate, 0))

                    .StartDate = gPMFunctions.NullToDate(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanStartDate, 0))

                    .EndDate = gPMFunctions.NullToDate(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanEndDate, 0))

                    .InsuranceFileCnt = gPMFunctions.ToSafeLong(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanInsuranceFileCnt, 0))

                    .OverrideRate = gPMFunctions.NullToDouble(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanInterestRate, 0))

                    .RefundType = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanRefundType, 0))

                    .BusinessCode = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanBusinessCode, 0))

                    .Reference = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanReference, 0))

                    .Address1 = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientAddress1, 0))

                    .Address2 = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientAddress2, 0))

                    .Address3 = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientAddress3, 0))

                    .Address4 = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientAddress4, 0))

                    .PostCode = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientPostcode, 0))

                    .Deposit = gPMFunctions.NullToCurrency(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanDeposit, 0))

                    .ExistingReference = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanAgentRef, 0))

                    .TransactionArray = v_vTransArray

                    .InstalmentAmount = gPMFunctions.NullToCurrency(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanOtherInstalments, 0))

                    .FirstInstalmentDate = gPMFunctions.NullToDate(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanFirstInstalmentdate, 0))

                    .SchemeType = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanSGSchemeType, 0))

                    .SchemeCode = gPMFunctions.NullToString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanSGSchemeCode, 0))

                    'client type code
                    GetPartyType(gPMFunctions.NullToLong(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientId, 0)), sCode)

                    .ClientType = sCode

                    .Timeout = gPMFunctions.NullToLong(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanTimeout, 0))
                    If v_lMTAType = 1 Then

                        .MessageType = 3
                    Else

                        .MessageType = 1
                    End If

                    .LoadPartners(m_vPartnerArray)

                    'check if we need to add the credit card details

                    If gPMFunctions.ToSafeString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanCCNumber, 0)).Trim() <> "" Then

                        .CardNumber = r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanCCNumber, 0)

                        .CardExpiryDate = r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanCCExpiryDate, 0)

                        .CardStartDate = r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanCCStartDate, 0)

                        .CardIssueNo = r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanCCIssue, 0)

                        .CardHolder = gPMFunctions.ToSafeBoolean(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanIsCardholder, 0))

                        .CardType = r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanCardType, 0)
                        If gPMFunctions.ToSafeBoolean(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanIsCardholder, 0)) Then

                            .CardName = r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanBankAccountName, 0)
                        Else

                            .CardTPName = r_vPremiumFinanceArray(bSIRPremFinConst.k_PfPlanCardholderName, 0)

                            .CardTPAddress1 = r_vPremiumFinanceArray(bSIRPremFinConst.k_PfPlanCardholderAddress1, 0)

                            .CardTPAddress2 = r_vPremiumFinanceArray(bSIRPremFinConst.k_PfPlanCardholderAddress2, 0)

                            .CardTPAddress3 = r_vPremiumFinanceArray(bSIRPremFinConst.k_PfPlanCardholderAddress3, 0)

                            .CardTPAddress4 = r_vPremiumFinanceArray(bSIRPremFinConst.k_PfPlanCardholderAddress4, 0)

                            .CardTPPostCode = r_vPremiumFinanceArray(bSIRPremFinConst.k_PfPlanCardholderPostcode, 0)
                        End If
                    End If

                    'check the renewal type for pclpsg schemes

                    m_lReturn = CheckSGRenewalType(gPMFunctions.ToSafeString(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanXSLCode, 0)), gPMFunctions.ToSafeInteger(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanClientId, 0)), bIsRenewl, bBrokerRenewal)
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                        gPMFunctions.RaiseError("CheckSGRenewalType", "Failed", gPMConstants.PMELogLevel.PMLogError)
                    End If

                    If bIsRenewl Then

                        .Renewal = True
                    End If
                    If bBrokerRenewal Then

                        .BrokerRenewal = True
                    End If

                    'and submit the quotes!

                    m_lReturn = .Submit()
                    If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then

                        m_sErrorText = .ErrorText

                        m_sErrorCode = .ErrorCode
                        gPMFunctions.RaiseError("oPFSubmit.Submit", m_sErrorCode & " - " & m_sErrorText, gPMConstants.PMELogLevel.PMLogError)
                    End If

                    If .StatusCode <> 1 Then
                        gPMFunctions.RaiseError("oPFSubmit.StatusCode", "Status code is not one", gPMConstants.PMELogLevel.PMLogError)
                    End If

                    If .TotalPayable <> 0 Then

                        r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanTotalCost, 0) = .TotalPayable
                    End If

                    r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanReference, 0) = .Reference

                    r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanAutoGenPlanRef, 0) = .Reference

                    r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanDocURL, 0) = .DocURL

                    Dim dbNumericTemp As Double
                    If Double.TryParse(.FirstInstalment, NumberStyles.Number, CultureInfo.CurrentCulture.NumberFormat, dbNumericTemp) Then

                        If .FirstInstalment > 0 Then

                            r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanFirstInstalment, 0) = .FirstInstalment
                        End If
                    End If

                    Dim dbNumericTemp2 As Double
                    If Double.TryParse(.OtherInstalment, NumberStyles.Number, CultureInfo.CurrentCulture.NumberFormat, dbNumericTemp2) Then

                        If .OtherInstalment > 0 Then

                            r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanOtherInstalments, 0) = .OtherInstalment
                        End If
                    End If
                    If v_lMTAType = 1 Then

                        r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanInterestCost, 0) = .CreditCharge

                        r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanNoOfInstalments, 0) = .Instalments
                    End If
                End With
            End If
            Return result

        Catch ex As Exception
            bPMFunc.LogError(v_sUsername:=m_sUsername, v_sClass:=ACClass, v_sMethod:=kMethodName, r_lFunctionReturn:=result, excep:=ex)
        Finally





            ' Do any tidy up, e.g. Set x = Nothing here

            If Not (oPFSubmit Is Nothing) Then
                'm_lReturn = oPFSubmit.Terminate
                oPFSubmit = Nothing
            End If


            ' This is for debugging only

        End Try
        Return result
    End Function

    Public Function NotifyConnectivityMTA(ByRef r_vPremiumFinanceArray(,) As Object) As Integer

        Dim result As Integer = 0
        Try

            Dim oPFSubmit As bSIRPFSubmit.Application
            Dim lSchemeID As Integer
            Dim vArray(,) As Object = Nothing
            Dim sTmp As String = ""

            result = gPMConstants.PMEReturnCode.PMTrue

            'get an instance of our submit component
            ' Replace use of ObjectManager when creating objects. PN23065.

            oPFSubmit = New bSIRPFSubmit.Application
            m_lReturn = oPFSubmit.Initialise(sUsername:=m_sUsername, sPassword:=m_sPassword, iUserID:=m_iUserID, iSourceID:=m_iSourceID, iLanguageID:=m_iLanguageID, iCurrencyID:=m_iCurrencyID, iLogLevel:=m_iLogLevel, sCallingAppName:=ACApp, vDatabase:=m_oDatabase)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to get an " & "instance of bSIRPFSubmit for connectivity quotes", vApp:=ACApp, vClass:=ACClass, vMethod:="InsertOrUpdatePremiumFinance")
            End If

            'now we need to try and send the accept message - we need to bomb out if
            'this doesn't work as sbo will be out of sync..
            If oPFSubmit Is Nothing Then
                Throw New Exception()
            Else
                If m_dtQuoteDate = #12/30/1899# Then
                    m_dtQuoteDate = DateTime.Today
                End If

                m_lReturn = GetAllPFRFs(vArray)
                If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                    Throw New Exception()
                End If

                If Not (Informations.IsArray(vArray)) Then
                    Throw New Exception()
                End If

                lSchemeID = -1

                For x As Integer = vArray.GetLowerBound(1) To vArray.GetUpperBound(1)

                    If gPMFunctions.ToSafeDouble(vArray(2, x)) = gPMFunctions.ToSafeInteger(r_vPremiumFinanceArray(bSIRPremFinConst.k_PFPlanSchemeNo, 0)) Then
                        lSchemeID = x
                    End If
