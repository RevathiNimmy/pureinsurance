    End Function

    Public Function GetAvailableSchemes(ByRef vStartDate As String, ByRef vEndDate As String, ByRef vProductFamily() As String) As Integer
        Return GetAvailableSchemes(vStartDate:=vStartDate, vEndDate:=vEndDate, vProductFamily:=vProductFamily, vTransactions:=Nothing, vSystemTag:="", vNoOfInstall:="", vResultArray:=Nothing, vUseFlipArray:=Nothing, vDaysDelay:="", vCompanyNo:="")
    End Function

    Public Function GetAvailableSchemes(ByRef vStartDate As String, ByRef vEndDate As String, ByRef vProductFamily() As String, ByRef vTransactions As Object, ByRef vSystemTag As String, ByRef vNoOfInstall As String, ByRef vResultArray(,) As Object, ByRef vUseFlipArray As Object, ByRef vDaysDelay As String, ByRef vCompanyNo As String) As Integer

        Dim result As Integer = 0
        Dim sSqlString, sSqlName As String
        Dim sProdClassString As New StringBuilder
        Dim bStoredProc, bKeepNulls As Boolean
        Dim vSources(,) As Object = Nothing
        Dim vProducts(,) As Object = Nothing
        Dim vCheck(,) As Object = Nothing
        Dim bDeleteRow As Boolean
        Dim lCount, lLower, lUpper As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            m_bUseFlipArray = Informations.IsNothing(vUseFlipArray)

            'Get the Branches and Products involved

            GetBranchesAndProducts(vTransactions, vSources, vProducts)

            'Format dates to correct format
            Dim TempDate As Date
            vStartDate = If(DateTime.TryParse(vStartDate, TempDate), TempDate.ToString("yyyy/MM/dd"), vStartDate)
            Dim TempDate2 As Date
            vEndDate = If(DateTime.TryParse(vEndDate, TempDate2), TempDate2.ToString("yyyy/MM/dd"), vEndDate)

            'Build product class search string
            'eck310102 reinstated multiple product families
            '    sProdClassString = "AND (R.productfamily LIKE '" & vProductFamily & "')"
            ' PWF 03/09/2002 - Check special 'all product' case
            lLower = vProductFamily.GetLowerBound(0)
            lUpper = vProductFamily.GetUpperBound(0)
            For lCount = lLower To lUpper

                If gPMFunctions.ToSafeString(vProductFamily(lCount)) = "%" Then
                    sProdClassString = New StringBuilder("AND R.productfamily Like '%' ")
                    Exit For
                Else
                    Select Case lCount
                        Case lLower

                            sProdClassString = New StringBuilder("AND R.productfamily In ('" & gPMFunctions.ToSafeString(vProductFamily(lCount)) & "'")
                        Case lUpper

                            sProdClassString.Append(", '" & gPMFunctions.ToSafeString(vProductFamily(lCount)) & "') ")
                        Case Else

                            sProdClassString.Append(", '" & gPMFunctions.ToSafeString(vProductFamily(lCount)) & "'")
                    End Select
                End If
            Next

            sSqlString = ""
            Dim TempDate3 As Date
            sSqlString = "SELECT S.companyno, S.schemeno, S.schemeversion, " &
                         "S.party_cnt, S.datamodelcode, '" & (If(DateTime.TryParse(vStartDate, TempDate3), TempDate3.ToString("dd-MMM-yyyy"), vStartDate)) & "' AS " &
                         "startdate, " &
                         "S.enddate, S.paymentmethod_cnt, " &
                         "S.systemtag, S.schemename, S.schemedescription, S.quoteableind, " &
                         "R.productfamily, S.basisofcalcnew, S.basisofcalcmta, " &
                         "S.basisofcalcrenewal, S.basisofcalccancel, S.basisofpp, " &
                         "S.quotedocid, S.bankdocid, S.creditdocid, " &
                         "S.InsrMailBoxNo, S.EdiMessageCount, S.NoOfInstallments, P.Shortname, " &
                         "S.IsInHouse " &
                         "FROM pfscheme S, PFRF R, Party_finance_provider PF, Party P " &
                         "WHERE quoteableind = 'Y' " &
                         "AND S.party_cnt = PF.party_cnt " &
                         "AND PF.party_cnt = P.Party_cnt " &
                         "AND S.CompanyNo = R.CompanyNo " &
                         "AND S.SchemeNo = R.SchemeNo " &
                         "AND S.SchemeVersion = R.SchemeVersion " &
                         "AND R.startdate <= '" & vStartDate & "' " &
                         "AND R.enddate >= '" & vStartDate & "' " &
                         "AND S.startdate <= '" & vStartDate & "' "

            sSqlString = sSqlString & "AND S.enddate >= '" & vStartDate & "' " &
                         sProdClassString.ToString()
            'Thinh Nguyen 01/03/2002 (start)

            If Not Informations.IsNothing(vSystemTag) Then
                If vSystemTag <> "" Then
                    sSqlString = sSqlString & " AND S.systemTag = '" & vSystemTag & "'"
                End If
            End If

            If Not Informations.IsNothing(vNoOfInstall) Then
                If vNoOfInstall <> "" Then
                    sSqlString = sSqlString & " AND S.NoOfInstallments =  " & vNoOfInstall
                End If
            End If

            If Not Informations.IsNothing(vCompanyNo) Then
                If vCompanyNo <> "" Then
                    sSqlString = sSqlString & " AND S.companyno = " & vCompanyNo
                End If
            End If

            If Not Informations.IsNothing(vDaysDelay) Then
                If vDaysDelay <> "" Then
                    sSqlString = sSqlString & " AND R.daysdelay = " & vDaysDelay
                End If
            End If
            sSqlName = "Retrieve Schemes"
            bStoredProc = False
            bKeepNulls = True

            m_lReturn = m_oDatabase.SQLSelect(sSqlString, sSqlName, bStoredProc, , vResultArray, , , , bKeepNulls)

            'now filter out the Schemes which do not apply for the Sources and Products
            If Informations.IsArray(vResultArray) Then
                lCount = 0

                Do While lCount <= vResultArray.GetUpperBound(1)
                    With m_oDatabase
                        .Parameters.Clear()

                        .Parameters.Add("CompanyNo", gPMFunctions.ToSafeString(vResultArray(0, lCount)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                        .Parameters.Add("SchemeNo", gPMFunctions.ToSafeString(vResultArray(1, lCount)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)

                        .Parameters.Add("SchemeVersion", gPMFunctions.ToSafeString(vResultArray(2, lCount)), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                        .Parameters.Add("id", gPMFunctions.ToSafeString(0), gPMConstants.PMEParameterDirection.PMParamInput, gPMConstants.PMEDataType.PMLong)
                    End With

                    bDeleteRow = False

                    'Check the sources
                    'eck310102 Check if we have any sources
                    If Informations.IsArray(vSources) Then

                        For iFilter As Integer = vSources.GetLowerBound(1) To vSources.GetUpperBound(1)

                            m_oDatabase.Parameters.Item("id").Value = vSources(0, iFilter)
                            m_oDatabase.SQLSelect(sSQL:=ACCheckPFSchemeSourceSQL, sSQLName:=ACCheckPFSchemeSourceName, bStoredProcedure:=ACCheckPFSchemeSourceStored, vResultArray:=vCheck)

                            If gPMFunctions.ToSafeString(vCheck(0, 0)) = "0" Then
                                'delete this row
                                bDeleteRow = True
                                Exit For
                            End If
                        Next iFilter
                    End If

                    'Check the Products
                    If Not bDeleteRow Then
                        'Check the products
                        'eck310102 Check if we have any products
                        If Informations.IsArray(vProducts) Then

                            For iFilter As Integer = vProducts.GetLowerBound(1) To vProducts.GetUpperBound(1)

                                m_oDatabase.Parameters.Item("id").Value = vProducts(0, iFilter)
                                m_oDatabase.SQLSelect(sSQL:=ACCheckPFSchemeProductSQL, sSQLName:=ACCheckPFSchemeProductName, bStoredProcedure:=ACCheckPFSchemeProductStored, vResultArray:=vCheck)

                                If gPMFunctions.ToSafeString(vCheck(0, 0)) = "0" Then
                                    'delete this row
                                    bDeleteRow = True
                                    Exit For
                                End If
                            Next iFilter
                        End If
                    End If

                    'Delete or move on
                    If bDeleteRow Then
                        'Once we have deleted then the current row is replaced with the
                        'next, hence we don't increment on this loop

                        vResultArray = RemoveArrayRow(vResultArray, lCount)

                        ' PWF - Check for removal of last scheme
                        If Not Informations.IsArray(vResultArray) Then
                            Exit Do
                        End If
                    Else
                        lCount += 1
                    End If
                Loop
            End If

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'Return error to calling object/module
                Return m_lReturn
            End If

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError
            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetAvailableSchemes Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetAvailableSchemes", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

    ' ***************************************************************** '
    ' ********************** THIS IS A MARSH METHOD ******************* '
    ' Name: GetQuoteDetails
    '
    ' Description: This function returns 1 row of data for the client
    '               to enable the re-printing of premium finance
    '               documents
    '
    'DD210801 - Removed the DOC Paths from the Select SQL because fields
    '           were removed fromt the database for performance.
    '
    ' ***************************************************************** '
    Public Function GetQuoteDetails(ByRef vClientKey(,) As Object) As Integer
        Dim result As Integer = 0
        Dim sSqlString, sSqlName As String
        Dim bStoredProc As Boolean
        Dim vResultArray(,) As Object = Nothing
        Dim lPremFinCnt, lPremFinVersion As Integer

        Try

            result = gPMConstants.PMEReturnCode.PMTrue

            'Build SQL String to get all of the fields from PFPremiumFinance

            sSqlString = "SELECT clientid, companyno, schemeno, schemeversion, startdate, " &
                         "clientname, clientaddr1, clientaddr2, clientaddr3, clientaddr4, clientpcode, " &
                         "transtype, totalcost, apr, noofInstalments, othInstalments, interestcost, " &
                         "costofprotection, amounttofinance, bankname, bankbranch, bankpcode, " &
                         "bankaccountname, bankaccountno, banksortcode, " &
                         "autogeneratedplanref,interestrate,daysdelay " &
                         "FROM PFPremiumFinance " &
                         "WHERE pfprem_finance_cnt =  " & gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(vClientKey(0, 0))) &
                         "AND pfprem_finance_version = " & gPMFunctions.ToSafeString(gPMFunctions.ToSafeInteger(vClientKey(0, 1)))

            'removed from above
            '"quotedocpath, quotedocname, bankdocpath, bankdocname, " & _
            ''"cdtagreedocpath, cdtagreedocname, autogeneratedplanref,interestrate,daysdelay " & _
            '

            sSqlName = "Retrieve Quote From PFPremiumFinance"
            bStoredProc = False

            m_lReturn = m_oDatabase.SQLSelect(sSqlString, sSqlName, bStoredProc,  , vResultArray)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                'Return error to calling object/module
                Return m_lReturn
            End If

            'Prepare vClientKey to return an array sized to m_cMainArray, which allows for future
            'enhancements and compatability with the other functions.

            lPremFinCnt = gPMFunctions.ToSafeInteger(vClientKey(0, 0))

            lPremFinVersion = gPMFunctions.ToSafeInteger(vClientKey(0, 1))
            vClientKey = Nothing
            ReDim vClientKey(0, bSIRPremFinConst.k_PFPlanCountOfFields)

            'Flip the array into row/column format
            m_lReturn = gPMFunctions.FlipArray(vResultArray)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            'Build vClientKey from vResultArray

            vClientKey(0, bSIRPremFinConst.k_PFPlanClientId) = vResultArray(0, 0)

            vClientKey(0, bSIRPremFinConst.k_PFPlanCompanyNo) = vResultArray(0, 1)

            vClientKey(0, bSIRPremFinConst.k_PFPlanSchemeNo) = vResultArray(0, 2)

            vClientKey(0, bSIRPremFinConst.k_PFPlanSchemeVersion) = vResultArray(0, 3)

            vClientKey(0, bSIRPremFinConst.k_PFPlanStartDate) = vResultArray(0, 4)

            vClientKey(0, bSIRPremFinConst.k_PFPlanClientName) = vResultArray(0, 5)

            vClientKey(0, bSIRPremFinConst.k_PFPlanClientAddress1) = vResultArray(0, 6)

            vClientKey(0, bSIRPremFinConst.k_PFPlanClientAddress2) = vResultArray(0, 7)

            vClientKey(0, bSIRPremFinConst.k_PFPlanClientAddress3) = vResultArray(0, 8)

            vClientKey(0, bSIRPremFinConst.k_PFPlanClientAddress4) = vResultArray(0, 9)

            vClientKey(0, bSIRPremFinConst.k_PFPlanClientPostcode) = vResultArray(0, 10)

            vClientKey(0, bSIRPremFinConst.k_PFPlanTransactionType) = vResultArray(0, 11)

            vClientKey(0, bSIRPremFinConst.k_PFPlanTotalCost) = vResultArray(0, 12)

            vClientKey(0, bSIRPremFinConst.k_PFPlanAPR) = vResultArray(0, 13)

            vClientKey(0, bSIRPremFinConst.k_PFPlanNoOfInstalments) = vResultArray(0, 14)

            vClientKey(0, bSIRPremFinConst.k_PFPlanOtherInstalments) = vResultArray(0, 15)

            vClientKey(0, bSIRPremFinConst.k_PFPlanInterestCost) = vResultArray(0, 16)

            vClientKey(0, bSIRPremFinConst.k_PFPlanCostOfProtection) = vResultArray(0, 17)

            vClientKey(0, bSIRPremFinConst.k_PFPlanAmountToFinance) = vResultArray(0, 18)

            vClientKey(0, bSIRPremFinConst.k_PFPlanBankName) = vResultArray(0, 19)

            vClientKey(0, bSIRPremFinConst.k_PFPlanBankBranch) = vResultArray(0, 20)

            vClientKey(0, bSIRPremFinConst.k_PFPlanBankPostcode) = vResultArray(0, 21)

            vClientKey(0, bSIRPremFinConst.k_PFPlanBankAccountName) = vResultArray(0, 22)

            vClientKey(0, bSIRPremFinConst.k_PFPlanBankAccountNo) = vResultArray(0, 23)

            vClientKey(0, bSIRPremFinConst.k_PFPlanBankSortCode) = vResultArray(0, 24)

            vClientKey(0, bSIRPremFinConst.k_PFPlanPFCnt) = lPremFinCnt

            vClientKey(0, bSIRPremFinConst.k_PFPlanPFVersion) = lPremFinVersion

            vClientKey(0, bSIRPremFinConst.k_PFPlanAutoGenPlanRef) = vResultArray(0, 25)

            vClientKey(0, bSIRPremFinConst.k_PFPlanInterestRate) = vResultArray(0, 26)

            vClientKey(0, bSIRPremFinConst.k_PFPlanDaysDelay) = vResultArray(0, 27)

            'Retrieve Broker details and append onto the vClientArray
            'This bit of code will need ajustments made to the field names when
            'the next version of the sbo database is installed.
            m_lReturn = RetrieveBroker(vResultArray:=vResultArray)

            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return m_lReturn
            End If

            If Informations.IsArray(vResultArray) Then

                'Setup Broker details

                vClientKey(0, bSIRPremFinConst.k_PFPlanBrokerName) = vResultArray(0, 0)

                vClientKey(0, bSIRPremFinConst.k_PFPlanBrokerAddress1) = vResultArray(0, 1)

                vClientKey(0, bSIRPremFinConst.k_PFPlanBrokerAddress2) = vResultArray(0, 2)

                vClientKey(0, bSIRPremFinConst.k_PFPlanBrokerAddress3) = vResultArray(0, 3)

                vClientKey(0, bSIRPremFinConst.k_PFPlanBrokerPostcode) = vResultArray(0, 4)

                vClientKey(0, bSIRPremFinConst.k_PFPlanBrokerAddress4) = vResultArray(0, 5)

            End If

            vResultArray = Nothing

            Return result

        Catch excep As System.Exception

            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            bPMFunc.LogMessage(sUsername:=m_sUsername, iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="GetQuoteDetails Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="GetQuoteDetails", vErrNo:=Informations.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function

