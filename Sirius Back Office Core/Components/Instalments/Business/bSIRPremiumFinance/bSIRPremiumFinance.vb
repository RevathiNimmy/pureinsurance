                Return result
            End If
            If Informations.IsArray(vSchemeArray) Then
                lSchemeVersion = gPMFunctions.ToSafeLong(vSchemeArray(0, 0), 0)
            End If

            m_lReturn = GetSingleScheme(v_lCompanyNo:=lCompanyNo, v_lSchemeNo:=v_lFinancePlanSchemeNo, v_lSchemeVersion:=lSchemeVersion, r_vArrayOfScheme:=vArrayOfScheme)
            If m_lReturn <> gPMConstants.PMEReturnCode.PMTrue Then
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            m_lReturn = GetMissingQuoteData(vPfTransArray, vArrayOfScheme)

            Dim vPfrfArray(,) As Object = Nothing

            m_lReturn = GetAllPFRFs(vPfrfArray)

            Dim vQuoteArray(,) As Object = Nothing

            m_lReturn = CalculateEachQuote(vArrayOfScheme, vPfrfArray, vQuoteArray)

            'Find PF Scheme
            Dim lQuoteIndex As Integer

            For lCount As Integer = vQuoteArray.GetLowerBound(1) To vQuoteArray.GetUpperBound(1)

                If gPMFunctions.ToSafeDouble(vQuoteArray(k_PFQuoteSchemeNo, lCount)) = v_lFinancePlanSchemeNo Then
