            VB6.SetDefault(cmdOK, False)
        End If

    End Sub

    Private Sub lvwProductTypes_ColumnClick(ByVal eventSender As Object, ByVal eventArgs As ColumnClickEventArgs) Handles lvwProductTypes.ColumnClick
        Dim ColumnHeader As ColumnHeader = lvwProductTypes.Columns(eventArgs.Column)

        ' Column click event for the search details

        Try

            With lvwProductTypes
                ' If current sort column header is
                ' pressed.
                If ColumnHeader.Index + 1 - 1 = ListViewHelper.GetSortKeyProperty(lvwProductTypes) Then
                    ' Set sort order opposite of
                    ' current direction.
                    ListViewHelper.SetSortOrderProperty(lvwProductTypes, (ListViewHelper.GetSortOrderProperty(lvwProductTypes) + 1) Mod 2)
                Else
                    ' Sort by this column (ascending).
                    ListViewHelper.SetSortedProperty(lvwProductTypes, False)

                    ' Turn off sorting so that the list
                    ' is not sorted twice
                    ListViewHelper.SetSortOrderProperty(lvwProductTypes, SortOrder.Ascending)
                    ListViewHelper.SetSortKeyProperty(lvwProductTypes, ColumnHeader.Index + 1 - 1)
                    ListViewHelper.SetSortedProperty(lvwProductTypes, True)
                End If
            End With

        Catch excep As System.Exception




            ' Log Error.
            iPMFunc.LogMessage(iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="Failed to sort the column", vApp:=ACApp, vClass:=ACClass, vMethod:="lvwProductTypes_ColumnClick", vErrNo:=Information.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Exit Sub

        End Try

    End Sub

