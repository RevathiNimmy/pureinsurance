            ' {* USER DEFINED CODE (Begin) *}

            m_lReturn = CType(SetExtraListViewProperties(v_hWndList:=lvwProductTypes.Handle.ToInt32(), v_vShowRowSelect:=True), gPMConstants.PMEReturnCode)

