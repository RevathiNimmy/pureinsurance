    Private Sub cmdMaintain_Click(ByVal eventSender As Object, ByVal eventArgs As EventArgs) Handles cmdMaintain.Click

        If cboUser.SelectedIndex = -1 Then
            MessageBox.Show("Please select a User", "Maintain User Authority", MessageBoxButtons.OK, MessageBoxIcon.Exclamation)
            Exit Sub
        End If
        'Developer Guide No. 69
        frmDetail = New frmDetail
        frmDetail.UserId = VB6.GetItemData(cboUser, cboUser.SelectedIndex)
        frmDetail.UserDesc = cboUser.Text.Trim()
        frmDetail.ShowDialog()
        frmDetail.Close()
        frmDetail = Nothing
    End Sub

