    ' ***************************************************************** '
    ' Name: ProcessInterface (Standard Method)
    '
    ' Description: Calls the appropriate methods to process the
    '              interface.
    '
    ' ***************************************************************** '
    Private Function ProcessInterface() As Integer

        Dim result As Integer = 0



        result = gPMConstants.PMEReturnCode.PMTrue
        m_ofrmRenewalProcess = New frmRenewalProcess
        'assign renewal mode and filters values to form
        m_ofrmRenewalProcess.RenewalMode = m_lRenewalMode

        'load renewal main form

        If m_ofrmRenewalProcess.Status = gPMConstants.PMEReturnCode.PMTrue Then
            m_ofrmRenewalProcess.ShowDialog()
        Else
            result = gPMConstants.PMEReturnCode.PMFalse
        End If
        'Developer Guide No. 69
        m_ofrmRenewalProcess = Nothing

        Return result

    End Function

