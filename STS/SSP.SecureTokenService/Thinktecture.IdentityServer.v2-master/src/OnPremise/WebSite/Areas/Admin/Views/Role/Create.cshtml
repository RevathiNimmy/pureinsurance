@using Thinktecture.IdentityServer.Web.Areas.Admin.App_LocalResources.Role
@model RoleInputModel
@using (Html.BeginForm("Create", "Role"))
{
    @Html.AntiForgeryToken()
    <div class="card">
        <div class="card-heading">
             <h1>@Create_cshtml.CreateRole</h1>
        </div>
           <div class="card-body clearfix">
               <div class="form-horizontal">
                    @Html.EditorForModel()
               </div>
           </div>
        <div class="card-footer">
            <button type="reset" class="btn btn-sm btn-dark">@Create_cshtml.Cancel</button>
            <button type="submit" class="btn btn-sm btn-primary">@Create_cshtml.Create</button>
        </div>
   </div>
    @Html.ValidationSummary(Create_cshtml.ErrorCreatingRole)
}