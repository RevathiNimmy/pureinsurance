@using Thinktecture.IdentityServer.Web.Areas.Admin.App_LocalResources.IP
@model IdentityProvidersViewModel

@{
    ViewBag.Title = Index_cshtml.IdentityProviders;
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="card">
        <div class="card-heading">
             <h1>@ViewBag.Title</h1>
        </div>
           <div class="card-body clearfix">
               <div class="form-horizontal">
                  
                    @{
                        var list = Model.IdentityProviders;
                    }
                    @for (int i = 0; i < list.Length; i++)
                    {
                        <div class="form-group form-group-sm">
                            @Html.HiddenFor(x=>list[i].ID)
                            @Html.LabelFor(x => list[i].Delete, list[i].Name, new { @class = "Col-lg-2 col-md-3 control-label"})
                            <div class="Col-lg-8 col-md-8">
                            @Html.CheckBoxFor(x => list[i].Delete)
                            </div>
                        </div>
                    }
               </div>
           </div>
        <div class="card-footer">
            <button type="reset" class="btn btn-sm btn-dark">@Index_cshtml.Cancel</button>
            <button type="submit" name="action" value="delete" class="btn btn-sm btn-dark">@Index_cshtml.DeleteSelected</button>
            <button type="submit" name="action" value="new" class="btn btn-sm btn-primary">@Index_cshtml.New</button>
        </div>
    </div>
    @Html.ValidationSummary(Index_cshtml.ErrorDeletingIdentityProviders)
}

