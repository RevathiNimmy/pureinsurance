@using Thinktecture.IdentityServer.Web.Areas.Admin.App_LocalResources.Shared.EditorTemplates
@{
    var id = ViewData.ModelMetadata.PropertyName+"file";
    var name = id;
}

    @Html.TextBox("", Model as string, new { @class = "form-control" })
    <div class="m-v-sm">
        <label for="@id">@Thumbprint_cshtml.Upload</label>
        <input class="md-btn md-raised m-b bg-white" type="file" id="@id" name="@name" />
    </div>

