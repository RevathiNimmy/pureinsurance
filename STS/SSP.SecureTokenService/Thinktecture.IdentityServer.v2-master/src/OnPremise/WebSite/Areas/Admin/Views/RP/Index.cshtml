@using Thinktecture.IdentityServer.Web.Areas.Admin.App_LocalResources.RP
@model RelyingPartiesViewModel

@{
    ViewBag.Title = Index_cshtml.EnabledRelyingParties;
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
   
    <div class="card">
        <div class="card-heading">
             <h1>@ViewBag.Title</h1>
        </div>
           <div class="card-body clearfix">
               <div class="form-horizontal">
                    @{
                    var list = Model.RPs.ToArray();
                        }
                        @for (int i = 0; i < list.Length; i++)
                        {
                            <div class="form-group form-group-sm">
                                @Html.HiddenFor(x => list[i].ID)
                                @Html.LabelFor(x => list[i].Enabled, list[i].DisplayName, new { @class = "Col-lg-2 col-md-3 control-label" })
                                <div class="Col-lg-8 col-md-8">
                                @Html.CheckBoxFor(x => list[i].Enabled)
                                </div>
                            </div>
                        }
               </div>
           </div>
        <div class="card-footer">
           <button type="reset" class="btn btn-sm btn-dark">@Index_cshtml.Cancel</button>
           <button type="submit" name="action" class="btn btn-sm btn-primary" value="new">@Index_cshtml.New</button>
           <button type="submit" name="action" class="btn btn-sm btn-primary" value="save">@Index_cshtml.SaveChanges</button>
        </div>
 </div>
     @Html.ValidationSummary(Index_cshtml.ErrorUpdatingRelyingParties)
}