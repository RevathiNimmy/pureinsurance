@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
        <aside id="aside" class="app-aside modal show" role="menu">
            <div class="left">
                <div class="box bg-white">
                    <div id="headerbar" class="navbar no-radius grey-300">
                        <!-- logo -->
                      @*  <a id="brand-logo" class="navbar-brand navbar-item pull-left">
                        </a>*@
                         <!-- Page title - Bind to $state's title -->
                        <div class="navbar-item pull-left text-dark dk font-bold text-md">Configuration Menu</div>
                        <!-- / -->
                    </div>
                    <div class="box-row">
                        <div class="box-cell scrollable hover">
                            <div class="box-inner">
                                <div id="nav">
                                    <nav ui-nav>
                                        <ul class="nav nav-override">
                                             @Html.Action("Index", "Menu")
                                        </ul>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
        <div id="content" class="app-content" role="main">
            <div class="box">
                <div class="box-row">
                    <div class="box-cell">
                        <div class="box-inner p">
                             @if (TempData["Message"] != null)
                             {
                              <div class="message">@TempData["Message"]</div>
                             }
                              @RenderBody()
                        </div>
                    </div>
                </div>
            </div>
        </div>
@section scripts
{
    <script>
        var cryptoRandomUrl = '@Url.Action("Random", "Home")';
    </script>
    <script src="~/Areas/Admin/Scripts/Admin.js"></script>
    @RenderSection("scripts", false)
}