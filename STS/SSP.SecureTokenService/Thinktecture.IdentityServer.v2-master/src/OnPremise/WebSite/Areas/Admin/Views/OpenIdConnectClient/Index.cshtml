@model OpenIdConnectClientIndexViewModel

@{
    ViewBag.Title = "OpenID Connect Clients";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="card">
        <div class="card-heading">
            <h1>@ViewBag.Title</h1>
        </div>
           <div class="card-body clearfix">
               <div class="form-horizontal">
                    @{
                       var list = Model.Clients;
                        }
                        @for (int i = 0; i < list.Length; i++)
                        {
                            <div class="form-group form-group-sm">
                                @Html.HiddenFor(x=>list[i].ClientId)
                                @Html.LabelFor(x => list[i].Delete, list[i].Name, new { @class = "Col-lg-2 col-md-3 control-label"})
                                <div class="Col-lg-8 col-md-8">
                                @Html.CheckBoxFor(x => list[i].Delete)
                                </div>
                            </div>
                        }
               </div>
           </div>
        <div class="card-footer">
            <button type="reset" class="btn btn-sm btn-dark">Cancel</button>
            <button type="submit" name="action" value="delete" class="btn btn-sm btn-dark">Delete Selected</button>
            <button type="submit" name="action" value="new" class="btn btn-sm btn-primary">New</button>
        </div>
    </div>
    @Html.ValidationSummary("Error deleting clients")
   
}

