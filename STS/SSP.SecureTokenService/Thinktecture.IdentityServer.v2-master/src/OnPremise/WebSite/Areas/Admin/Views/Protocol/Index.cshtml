@using Thinktecture.IdentityServer.Web.Areas.Admin.App_LocalResources.Protocol
@model ProtocolsViewModel

@{
    ViewBag.Title = Index_cshtml.Protocols;
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="card">
        <div class="card-heading">
             <h1>@ViewBag.Title</h1>
        </div>
           <div class="card-body clearfix">
               <div class="form-horizontal">
                    @foreach (var protocol in Model.Protocols)
                        {
                           <div class="form-group form-group-sm">
                                @{
                                    var name = "protocols[" + protocol.ID + "]";
                                    var id = name.Replace("[", "_").Replace("]", "_");
                                }
                                <label class="Col-lg-2 col-md-3 control-label" for="@id">@protocol.Name</label>
                                <div class="Col-lg-8 col-md-8">
                                        @Html.CheckBox(name, protocol.Enabled)
                                </div>
                            </div>
                        }
               </div>
           </div>
        <div class="card-footer">
            <button type="reset" class="btn btn-sm btn-dark">@Index_cshtml.Cancel</button>
            <button type="submit" class="btn btn-sm btn-primary">@Index_cshtml.SaveChanges</button>
        </div>
   </div>
    @Html.ValidationSummary(Index_cshtml.ErrorUpdatingProtocols)
}