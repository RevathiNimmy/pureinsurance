<?xml version="1.0"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003" DefaultTargets="DesktopBuild" ToolsVersion="4.0">
  <!--<Import Project="$(MSBuildExtensionsPath)\Microsoft\VisualStudio\TeamBuild\Microsoft.TeamFoundation.Build.targets"/>-->
  <ProjectExtensions>
    <ProjectFileVersion>2</ProjectFileVersion>
    <Description/>
    <BuildMachine>VMB-TFS-AGENT1</BuildMachine>
  </ProjectExtensions>
  <PropertyGroup>
    <BuildDirectoryPath>$(BuildProjectFolderPath)\Binaries</BuildDirectoryPath>
<DropLocation>C:\PureBuild\Releases</DropLocation>
    <RunTest>false</RunTest>
    <RunCodeAnalysis>Never</RunCodeAnalysis>
    <WorkItemType>Bug</WorkItemType>
    <WorkItemFieldValues>System.Reason=Build Failure;System.Description=Start the build using Team Build</WorkItemFieldValues>
    <WorkItemTitle>Build failure in build:</WorkItemTitle>
    <DescriptionText>This work item was created by Team Build on a build failure.</DescriptionText>
    <BuildlogText>The build log file is at:</BuildlogText>
    <ErrorWarningLogText>The errors/warnings log file is at:</ErrorWarningLogText>
    <UpdateAssociatedWorkItems>true</UpdateAssociatedWorkItems>
    <AdditionalVCOverrides/>
    <CustomPropertiesForClean/>
    <CustomPropertiesForBuild/>
    <CustomizableOutDir>True</CustomizableOutDir>
    <StopOnFirstFailure>false</StopOnFirstFailure>
	<BuildProjectFolderPath>C:\PureInsurance\PureInsurance</BuildProjectFolderPath>
  </PropertyGroup>
  <!--<PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x64' ">
    <OutputPath>$(BuildProjectFolderPath)\..\Binaries</OutputPath>
    <OutDir>$(BuildProjectFolderPath)\..\Binaries</OutDir>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>-->
  
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|x64' ">
    <OutputPath>$(BuildProjectFolderPath)\..\Binaries</OutputPath>
    <OutDir>$(BuildProjectFolderPath)\..\Binaries</OutDir>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup>
    <BuildAllDependsOn>CoreBuild</BuildAllDependsOn>
  </PropertyGroup>

  <Target Name="BuildPortal" DependsOnTargets="$(BuildAllDependsOn)"/>
  
  <ItemGroup>
    <AdditionalReferencePath Include="$(BuildProjectFolderPath)\..\Binaries"/>
    <AdditionalReferencePath Include="$(BuildProjectFolderPath)\..\Pure Build Process\Core DLLs"/>
  </ItemGroup>
  
    <ItemGroup>
    <SourceExes Include="$(BuildProjectFolderPath)\..\Pure Build Process\Core DLLs\**\*.exe" />
    <DescExesFolder Include="$(BuildProjectFolderPath)\..\Binaries" />
  </ItemGroup>
  
  <ItemGroup>
    <SourceExes Include="$(BuildProjectFolderPath)\..\Pure Build Process\Core DLLs\**\*.exe" />
    <DescExesFolder Include="$(BuildProjectFolderPath)\..\Binaries" />
  </ItemGroup>
  
  <ItemGroup>
    <MySourceFiles Include="$(BuildProjectFolderPath)\..\Web Portal\**\*.*" />
    <MyDestinationFiles Include="$(BuildProjectFolderPath)\..\Pure Build Process\PortalBuildScripts\BuildSource" />
	
  </ItemGroup>
  <Target Name="CopyPortalFiles">
    <MakeDir Directories="$(BuildProjectFolderPath)\..\Pure Build Process\PortalBuildScripts\BuildSource" />
    <Copy SourceFiles="@(MySourceFiles)" DestinationFiles="@(MySourceFiles->'$(BuildProjectFolderPath)\..\Pure Build Process\PortalBuildScripts\BuildSource\%(RecursiveDir)%(FileName)%(Extension)')" />
	<Copy SourceFiles="@(SourceExes)" DestinationFolder="%(DescExesFolder.Fullpath)" />
  </Target>
  <Target Name="DesktopBuild">
    <!-- <CallTarget Targets="CopyPortalFiles"/> -->
    <!-- <Copy SourceFiles="$(BuildProjectFolderPath)\Pure Build Process\Core DLLs\" DestinationFolder="$(BuildProjectFolderPath)\Binaries\" /> -->
    <MSBuild Projects="@(SolutionToBuild)" BuildInParallel="false" />
  </Target>
  <Target Name="CoreBuild">
    <CallTarget Targets="CopyPortalFiles"/>
    <Exec Command="&quot;$(BuildProjectFolderPath)\..\Pure Build Process\PortalBuildScripts\BuildPurePortals.cmd&quot; $(BuildNumber)" WorkingDirectory="$(BuildProjectFolderPath)\..\Pure Build Process\PortalBuildScripts" />
  </Target>

  <ItemGroup>
    <!-- <ConfigurationToBuild Include="Debug|x64">
      <FlavorToBuild>Debug</FlavorToBuild>
      <PlatformToBuild>x64</PlatformToBuild>
    </ConfigurationToBuild>-->
    <ConfigurationToBuild Include="Release|x64">
      <FlavorToBuild>Release</FlavorToBuild>
      <PlatformToBuild>x64</PlatformToBuild>
    </ConfigurationToBuild>
 
     <SolutionToBuild Include="$(BuildProjectFolderPath)\shared files\sharedfiles.vbproj">
      <Targets/>
      <Properties>OutputPath=$(BuildProjectFolderPath)\Binaries\</Properties>
    </SolutionToBuild>
 
  <SolutionToBuild Include="$(BuildProjectFolderPath)\SharedQuoteEngine\SharedQuoteEngine.vbproj">
   <Targets/>
   <Properties>OutputPath=$(BuildProjectFolderPath)\Binaries\</Properties>
  </SolutionToBuild>
 
	
