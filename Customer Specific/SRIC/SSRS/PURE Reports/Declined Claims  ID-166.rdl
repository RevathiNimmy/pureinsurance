<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="BIExtended">
      <DataSourceReference>/UAT/Data Sources/BIExtended</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>e7fd22c8-1c21-4f3b-8b13-1adb237a2a83</rd:DataSourceID>
    </DataSource>
    <DataSource Name="ETAPRDDB_SIRIUS">
      <DataSourceReference>/UAT/Data Sources/ETAPRDDB_Sirius</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>24bdd28e-f725-4ecb-9275-bb375da11caf</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Declined">
      <Query>
        <DataSourceName>ETAPRDDB_SIRIUS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DF">
            <Value>=Parameters!DF.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DT">
            <Value>=Parameters!DT.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Subbranch">
            <Value>=Parameters!Subbranch.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select  distinct
b.code AS Branch,
c.claim_number,
Replace(Replace(Replace(Replace(Replace(Replace(Replace(C.Client_name,Char(13), ''), Char(10), ''), Char(9), ''),'.',''), '''',''),'?',''), ',','') AS Client_name,
Agt.resolved_name AS Broker,
rsk.description AS Product_Type,
C.Loss_from_date AS Loss_Date,
MAx(Replace(Replace(Replace(Replace(Replace(Replace(Replace(C.Description,Char(13), ''), Char(10), ''), Char(9), ''),'.',''), '''',''),'?',''), ',','')) AS Claims_Description,
ISNULL(mc.REJECTED_DATE,'') AS Date_Declined,
Isnull(mc.PRESCRIPTION_DATE,'') AS PRESCRIPTION_DATE,
Ombudsman_approached = Case When ISnull(mc.Ombudsman_approached,0) = 1 Then 'Yes' ELSE 'NO' END,
Rejection_Overturned = Case When ISnull(mc.Rejection_Overturned,0) = 1 Then 'Yes' ELSE 'NO' END,
MAX(Replace(Replace(Replace(Replace(Replace(Replace(Replace(Isnull(REJECTED_REASON_LETTER,''),Char(13), ''), Char(10), ''), Char(9), ''),'.',''), '''',''),'?',''), ',','')) AS Rejected_Reason,
Max(ISNULL(MST.description,'')) AS Decline_approved_By,
MAx(u.description) AS Claims_Handler,
SUM(GCT.Gross_SI)/count(cp.claim_id)				as Gross_SI,
sum(rig.Gross_Reserve)/count(Distinct cp.claim_peril_id) as Gross_Incurred


INTO #Temp1
From  dbo.claim c 
INNER JOIN (Select Max(claim_id) as claim_id ,base_claim_id from ETAPRDDB_Sirius.dbo.claim where is_dirty = 0 group by base_claim_id) f ON c.base_claim_id = f.base_claim_id
INNER JOIN ETAPRDDB_Sirius.dbo.claim clm on f.claim_id = clm.claim_id
INNER JOIN ETAPRDDB_Sirius.[dbo].[Claim_Status] cs on clm.Claim_Status_id = cs.claim_status_id
INNER JOIN ETAPRDDB_Sirius.dbo.claim_peril cp on f.claim_id = cp.Claim_id
INNER JOIN [dbo].[claim_folder] clf ON clf.claim_folder_id = clm.claim_folder_id  
Left JOIN dbo.handler u on c.Handler_id = u.handler_id
Left JOIN dbo.GIS_Policy_Link gpl    ON f.Claim_id = gpl.claim_id
 Inner JOIN dbo.CLMMOTOR_Policy_Binder cpb    ON gpl.gis_policy_link_id = cpb.gis_policy_link_id
Inner JOIN 
(Select Distinct *
From  dbo.CLMMOTOR_MOTORCLAIM mc 
Where mc.CLM_REJECTED = 1) mc on cpb.[CLMMOTOR_Policy_binder_id] = mc.[CLMMOTOR_Policy_binder_id]
Left Join [dbo].[UDL_MOTORSALVTENDER] MST on mc.REJECTED_APPR_BY = MST.UDL_MOTORSALVTENDER_id
LEFT OUTER JOIN dbo.insurance_file insf		ON c.policy_id = insf.insurance_file_cnt 
LEFT OUTER JOIN dbo.Party Agt			on insf.lead_agent_cnt = Agt.party_cnt
LEFT OUTER JOIN dbo.Source b				ON insf.source_id = b.source_id  
Left OUTER JOIN [dbo].[Risk] rsk ON rsk.risk_cnt = clf.risk_cnt 
LEFT JOIN ( SELECT Sral.claim_id, Sum(isnull(this_reserve,0)) as Gross_Reserve, SUM(isnull(Sum_Insured,0)) as Gross_SI, SUM(payment - this_recovery) as Paid
								FROM dbo.Claim_RI_Arrangement_Line SRAL
								 INNER JOIN dbo.Claim cc ON cc.claim_id = SRAL.claim_id  and is_dirty=0
								 and  cc.claim_version_description not like 'Portfolio Claim Adjustment'
								GROUP BY Sral.claim_id
							) GCT ON c.claim_id = GCT.claim_id 
LEFT OUTER JOIN ( SELECT cc.claim_id, Sum(isnull(this_reserve,0)) as Gross_Reserve, SUM(isnull(Sum_Insured,0)) as Gross_SI
										  FROM dbo.Claim_RI_Arrangement_Line SRAL
										  INNER JOIN dbo.Claim cc ON cc.claim_id = SRAL.claim_id  and is_dirty=0
										 Where cc.Loss_from_date between @DF and @DT
												and  cc.claim_version_description not like 'Portfolio Claim Adjustment'
										  GROUP BY cc.claim_id
							) rig ON c.claim_id = rig.claim_id   

where c.is_dirty = 0 and c.Loss_from_date between @DF and @DT
 and  c.claim_version_description not like 'Portfolio Claim Adjustment' 
 AND insf.branch_id in (@Subbranch)
 Group by b.code,
c.claim_number,
C.Client_name,
C.Insurer_short_name,
rsk.description,
C.Loss_from_date,
mc.REJECTED_DATE,
mc.PRESCRIPTION_DATE,
mc.Ombudsman_approached,
mc.Rejection_Overturned,



--u.description,
Agt.resolved_name

Select Distinct Branch,
claim_number,
Client_name,
Broker,
Ombudsman_approached,
Rejection_Overturned,
Product_Type,
MAX(Loss_Date) AS Loss_Date,
Claims_Description,
sts.Claim_Status,
MAX(Date_Declined) AS Date_Declined,
MAx(PRESCRIPTION_DATE) AS PRESCRIPTION_DATE,
MAX(Rejected_Reason) AS Rejected_Reason,
MAX(Decline_approved_By) AS Decline_approved_By,
Claims_Handler,
Sum(Isnull(Gross_Incurred,0)) AS Gross_Incurred

From #Temp1 f

OUTER APPLY (
		Select Claim_Status  = Replace(Replace(Replace(Replace(Replace(Replace(Replace(CS.DESCRIPTION, CHAR(13), ''), CHAR(10), ''), CHAR(9), ''), '.', ''), '''', ''), '?', ''), ',', '')
				FROM [ETAPRDDB_Sirius].dbo.Claim c WITH (NOLOCK)
				inner join [ETAPRDDB_Sirius].dbo.[case] ca									ON c.base_case_id = ca.case_id
				INNER JOIN [ETAPRDDB_Sirius].dbo.GIS_Policy_Link gpl						ON gpl.claim_id = c.Claim_id
				LEFT JOIN [ETAPRDDB_Sirius].dbo.[CLMMOTOR_MOTORCLAIM] CLM					ON CLM.CLMMOTOR_Policy_binder_id = gpl.gis_policy_link_id
				INNER JOIN [ETAPRDDB_Sirius].dbo.Claim_Status cs							ON c.Claim_Status_id = cs.claim_status_id
				where  exists (Select f.claim_id from (select Max(Claim_id) claim_id from [ETAPRDDB_Sirius].dbo.claim cl  WITH (NOLOCK) where cl.base_claim_id = c.base_claim_id and is_dirty = 0) f where c.claim_id = f.claim_id)
				AND  c.claim_number  = f.claim_number

)sts

Group by  Branch,
claim_number,
Client_name,
Broker,
Product_Type,
Claims_Handler,
Claims_Description,
Ombudsman_approached,
Rejection_Overturned
,sts.Claim_Status

Drop table #Temp1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
