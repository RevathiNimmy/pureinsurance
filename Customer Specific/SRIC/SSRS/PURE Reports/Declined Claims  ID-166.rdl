  <Code>Function GetFinancialYearStart(dt As Date) As Date
  	IF dt = Date.MinValue Then
		dt = Now
 	End If

	Return New Date((GetFinancialYear(dt)- 1),7,1)
	
End Function

Function GetFinancialYear(dt as Date) As Integer
	IF dt = Date.MinValue Then
		dt = Now
 	End If

	If dt.Month &gt; 6 Then
		Return dt.Year + 1
	Else
		Return dt.Year
	End If
End Function

Function GetFinancialMonth(dt as Date) As Integer
	IF dt = Date.MinValue Then
		dt = Now
 	End If

	If dt.Month &gt; 6
		Return dt.Month - 6
	Else
		Return dt.Month + 6
	End If
End Function

Function CalculateRatio(ByVal numerator As Decimal, ByVal denominator As Decimal) As String
	Dim val as decimal

	If denominator = 0 Then
		Return Nothing
	Else 
		val = Math.Round((numerator / denominator) * 100,2)
		Return val.ToString("0.00")+"%"
	End If
End Function

Function GetMonthPremium(ByVal Premium As Decimal, ByVal FinMonth As String, ColumnMonth As String) As Decimal
	If ColumnMonth Like "Jul" AND FinMonth  Like "Jul" 
		Return Premium 
	End If
End Function
</Code>
