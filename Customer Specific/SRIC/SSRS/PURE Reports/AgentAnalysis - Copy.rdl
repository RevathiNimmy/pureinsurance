  <ReportParameters>
    <ReportParameter Name="ShortName">
      <DataType>String</DataType>
      <Prompt>Agent Search</Prompt>
    </ReportParameter>
    <ReportParameter Name="branch_id">
      <DataType>String</DataType>
      <Prompt>branch id</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>AllBranches</DataSetName>
          <ValueField>Sub_branch_id</ValueField>
          <LabelField>Branch</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="PeriodDate">
      <DataType>DateTime</DataType>
      <Prompt>Period Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="Agent">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <Prompt>Agent</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>FindAgent</DataSetName>
          <ValueField>Shortname</ValueField>
          <LabelField>Shortname</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="sBasis">
      <DataType>String</DataType>
      <Prompt>Report Basis</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>Transaction Period</Value>
            <Label>Transaction Period</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>Transaction Date</Value>
            <Label>Transaction Date</Label>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="AgentGroupCode">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value>All</Value>
        </Values>
      </DefaultValue>
      <Prompt>Agent Group</Prompt>
    </ReportParameter>
  </ReportParameters>
