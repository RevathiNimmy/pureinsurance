    ' ***************************************************************** '
    Private Function ValidateForm() As Integer

        Dim result As Integer = 0
       

        Try

            result = gPMConstants.PMEReturnCode.PMTrue
            If cboCompany.SelectedIndex < 0 Then
                MessageBox.Show("Please Enter a Valid Company", Application.ProductName)
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            If cboPaymentGroup.SelectedIndex < 0 Then
                MessageBox.Show("Please Enter a Valid Payment Company", Application.ProductName)
                Return gPMConstants.PMEReturnCode.PMFalse
            End If

            Return result

        Catch excep As System.Exception



            result = gPMConstants.PMEReturnCode.PMError

            ' Log Error Message
            iPMFunc.LogMessage(iType:=gPMConstants.PMELogLevel.PMLogOnError, sMsg:="ValidateForm Failed", vApp:=ACApp, vClass:=ACClass, vMethod:="ValidateForm", vErrNo:=Information.Err().Number, vErrDesc:=excep.Message, excep:=excep)

            Return result

        End Try
    End Function


