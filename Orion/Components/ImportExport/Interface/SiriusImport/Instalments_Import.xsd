      <xs:attribute name="sepa_plan_bic" type="xs:string"/>
      <xs:attribute name="sepa_plan_iban" type="xs:string"/>
      <xs:attribute name="new_sepa_plan_bic" type="xs:string"/>
      <xs:attribute name="new_sepa_plan_iban" type="xs:string"/>
    </xs:complexType>
	</xs:element>
</xs:schema>