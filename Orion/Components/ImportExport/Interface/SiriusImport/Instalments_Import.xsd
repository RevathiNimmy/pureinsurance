			<xs:attribute name="new_plan_bank_account_name" type="xs:string" />
			<xs:attribute name="new_plan_bank_name" type="xs:string" />
			<xs:attribute name="new_plan_bank_address1" type="xs:string" />
			<xs:attribute name="new_plan_bank_address2" type="xs:string" />
			<xs:attribute name="new_plan_bank_address3" type="xs:string" />
			<xs:attribute name="new_plan_bank_address4" type="xs:string" />
			<xs:attribute name="new_plan_bank_postal_code" type="xs:string" />
			<xs:attribute name="new_plan_bank_country_code" type="xs:string" />
			<xs:attribute name="new_plan_cc_number" type="xs:string" />
			<xs:attribute name="new_plan_cc_expiry_date" type="xs:string" />
			<xs:attribute name="new_plan_cc_start_date" type="xs:string" />
			<xs:attribute name="new_plan_cc_issue" type="xs:string" />
			<xs:attribute name="new_plan_cc_pin" type="xs:string" />
