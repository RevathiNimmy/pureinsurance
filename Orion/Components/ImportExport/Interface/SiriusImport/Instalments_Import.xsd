			<xs:attribute name="generated_task_description_prefix" type="xs:string" />
			<xs:attribute name="generated_task_customer" type="xs:string" />
			<xs:attribute name="generate_instalment_notification" type="xs:string" />
			<xs:attribute name="set_next_instalment_transaction_code" type="xs:string" />
