			<xs:attribute name="alternate_reference" type="xs:string"/>
			<xs:attribute name="is_client_invoiced" type="xs:string"/>
			<xs:attribute name="quote_expiry_date" type="xs:dateTime"/>
			<xs:attribute name="policy_status_code" type="xs:string"/>
			<xs:attribute name="inception_date_tpi" type="xs:dateTime"/>
			<xs:attribute name="discount_reason_code" type="xs:string"/>
			<xs:attribute name="discounted_premium" type="xs:double"/>
			<xs:attribute name="discount_percentage" type="xs:double"/>
			<xs:attribute name="match_discounted_premium_flag" type="xs:string"/>
			<xs:attribute name="Country_code" type="xs:string"/>
			<xs:attribute name="inception_Date" type="xs:dateTime"/>
			<xs:attribute name="policy_documents_issued_date" type="xs:dateTime"/>
			<xs:attribute name="policy_documents_correct" type="xs:long"/>
			<xs:attribute name="agent_name" type="xs:string"/>
			<xs:attribute name="agent_address1" type="xs:string"/>
			<xs:attribute name="agent_address2" type="xs:string"/>
			<xs:attribute name="agent_address3" type="xs:string"/>
			<xs:attribute name="agent_address4" type="xs:string"/>
			<xs:attribute name="agent_postal_code" type="xs:string"/>
			<xs:attribute name="agent_country_code" type="xs:string"/>
			<xs:attribute name="agent_main_contact" type="xs:string"/>
			<xs:attribute name="agent_telephone_number" type="xs:string"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="RISK">
		<xs:annotation>
			<xs:documentation>Risk Record</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="RISKDATA" type="xs:string" minOccurs="0"/>
				<xs:element ref="RATING_SECTION" minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attribute name="risk_cnt" type="xs:long"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="RATING_SECTION">
		<xs:annotation>
			<xs:documentation>Rating Section</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:attribute name="rating_section_id" type="xs:long"/>
			<xs:attribute name="sequence" type="xs:long"/>
			<xs:attribute name="rating_section_type_code" type="xs:string"/>
			<xs:attribute name="sum_insured" type="xs:double"/>
			<xs:attribute name="annual_premium" type="xs:double"/>
			<xs:attribute name="this_premium" type="xs:double"/>
			<xs:attribute name="original_flag" type="xs:long"/>
			<xs:attribute name="calculated_premium" type="xs:double"/>
			<xs:attribute name="earning_pattern_code" type="xs:string"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="STANDARD_WORDINGS">
		<xs:annotation>
			<xs:documentation>Standard Wordings</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:attribute name="code" type="xs:string"/>
		</xs:complexType>
	</xs:element>
</xs:schema>
