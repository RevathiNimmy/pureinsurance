			<xs:attribute name="trading_since_date" type="xs:string"/>
			<xs:attribute name="party_business_code" type="xs:string"/>
			<xs:attribute name="location" type="xs:string"/>
			<xs:attribute name="no_of_offices" type="xs:long"/>
			<xs:attribute name="no_of_employees" type="xs:long"/>
			<xs:attribute name="financial_year" type="xs:string"/>
			<xs:attribute name="trade_code" type="xs:string"/>
			<xs:attribute name="wage_roll" type="xs:string"/>
			<xs:attribute name="trade_id" type="xs:string"/>
			<xs:attribute name="party_group_type_code" type="xs:string"/>
			<xs:attribute name="is_registered_charity" type="xs:string"/>
			<xs:attribute name="charity_number" type="xs:string"/>
			<xs:attribute name="number_of_members" type="xs:string"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="PARTYADDRESS">
		<xs:annotation>
			<xs:documentation>Party Address Record</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute name="party_address_cnt" type="xs:long"/>
					<xs:attribute name="party_address_type" type="xs:string"/>
					<xs:attribute name="party_address1" type="xs:string"/>
					<xs:attribute name="party_address2" type="xs:string"/>
					<xs:attribute name="party_address3" type="xs:string"/>
					<xs:attribute name="party_address4" type="xs:string"/>
					<xs:attribute name="party_postal_code" type="xs:string"/>
					<xs:attribute name="party_country_code" type="xs:string"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="PARTYCONTACT">
		<xs:annotation>
			<xs:documentation>Party Contact Record</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute name="contact_cnt" type="xs:long"/>
					<xs:attribute name="contact_type_code" type="xs:string"/>
					<xs:attribute name="description" type="xs:string"/>
					<xs:attribute name="detail" type="xs:string"/>
					<xs:attribute name="extension" type="xs:string"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="POLICY">
		<xs:annotation>
			<xs:documentation>Policy Record</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="STANDARD_WORDINGS" minOccurs="0" maxOccurs="unbounded"/>
				<xs:element ref="RISK" minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attribute name="insurance_file_cnt" type="xs:long"/>
			<xs:attribute name="insurance_file_status_code" type="xs:string"/>
			<xs:attribute name="insurance_file_type_code" type="xs:string"/>
			<xs:attribute name="insurance_ref" type="xs:string"/>
			<xs:attribute name="insurance_folder_cnt" type="xs:long"/>
