			<xs:attribute name="language_code" type="xs:string"/>
			<xs:attribute name="date_issued" type="xs:dateTime"/>
			<xs:attribute name="cover_start_date" type="xs:dateTime"/>
			<xs:attribute name="expiry_date" type="xs:dateTime"/>
			<xs:attribute name="renewal_date" type="xs:dateTime"/>
			<xs:attribute name="renewal_frequency_code" type="xs:string"/>
			<xs:attribute name="is_referred_at_renewal" type="xs:string"/>
			<xs:attribute name="policy_version" type="xs:long"/>
			<xs:attribute name="Analysis_code" type="xs:string"/>
			<xs:attribute name="proposal_date" type="xs:dateTime"/>
			<xs:attribute name="Policy_type_code" type="xs:string"/>
			<xs:attribute name="annual_premium" type="xs:double"/>
			<xs:attribute name="this_premium" type="xs:double"/>
			<xs:attribute name="net_premium" type="xs:double"/>
			<xs:attribute name="commission_amount" type="xs:double"/>
			<xs:attribute name="iptable_amount" type="xs:double"/>
			<xs:attribute name="ipt_percentage" type="xs:double"/>
			<xs:attribute name="is_ipt_overridden" type="xs:string"/>
			<xs:attribute name="tax_amount" type="xs:double"/>
			<xs:attribute name="vatable_amount" type="xs:double"/>
			<xs:attribute name="vat_percentage" type="xs:double"/>
