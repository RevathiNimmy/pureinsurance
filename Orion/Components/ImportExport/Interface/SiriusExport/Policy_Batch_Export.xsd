<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns="http://www.siriusfs.com/SFI/Export/Policy_Batch_Export/20060419" xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.siriusfs.com/SFI/Export/Policy_Batch_Export/20060419" elementFormDefault="qualified">
	<xs:element name="EXPORT_HEADER">
		<xs:annotation>
			<xs:documentation>Sirius Export Header</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence minOccurs="0" maxOccurs="unbounded">
				<xs:element ref="PARTY"/>
			</xs:sequence>
			<xs:attribute name="parameters_used" type="xs:string"/>
			<xs:attribute name="interface_name" type="xs:string" use="required" fixed="POLICY_BATCH_EXPORT"/>
			<xs:attribute name="date_exported" type="xs:dateTime" use="required"/>
			<xs:attribute name="total_transactions" type="xs:long"/>
			<xs:attribute name="total_amount" type="xs:double"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="PARTY">
		<xs:annotation>
			<xs:documentation>Individual Party Record</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="POLICY" minOccurs="0" maxOccurs="unbounded"/>
				<xs:element ref="PARTYCONTACT" minOccurs="0" maxOccurs="unbounded"/>
				<xs:element ref="PARTYADDRESS" minOccurs="0" maxOccurs="unbounded"/>
				<xs:element name="PARTYBUILDER" type="xs:string" minOccurs="0"/>
			</xs:sequence>
			<xs:attribute name="party_cnt" type="xs:long"/>
			<xs:attribute name="party_type_code" type="xs:string"/>
			<xs:attribute name="source_code" type="xs:string"/>
			<xs:attribute name="shortname" type="xs:string"/>
			<xs:attribute name="name" type="xs:string"/>
			<xs:attribute name="resolved_name" type="xs:string"/>
			<xs:attribute name="currency_code" type="xs:string"/>
			<xs:attribute name="language_code" type="xs:string"/>
			<xs:attribute name="agent_code" type="xs:string"/>
			<xs:attribute name="created_by_username" type="xs:string"/>
			<xs:attribute name="date_created" type="xs:dateTime"/>
			<xs:attribute name="last_modified" type="xs:dateTime"/>
			<xs:attribute name="modified_by_username" type="xs:string"/>
			<xs:attribute name="payment_method_code" type="xs:string"/>
			<xs:attribute name="file_code" type="xs:string"/>
			<xs:attribute name="is_prospect" type="xs:long"/>
			<xs:attribute name="loyalty_number" type="xs:string"/>
			<xs:attribute name="alternative_identifier" type="xs:string"/>
			<xs:attribute name="trading_name" type="xs:string"/>
			<xs:attribute name="sub_branch_code" type="xs:string"/>
			<xs:attribute name="tax_number" type="xs:string"/>
			<xs:attribute name="domiciled_for_tax" type="xs:string"/>
			<xs:attribute name="tax_exempt" type="xs:string"/>
			<xs:attribute name="tax_percentage" type="xs:double"/>
			<xs:attribute name="blacklist_reason_code" type="xs:string"/>
			<xs:attribute name="party_title_code" type="xs:string"/>
			<xs:attribute name="forename" type="xs:string"/>
			<xs:attribute name="initials" type="xs:string"/>
			<xs:attribute name="employment_status_code" type="xs:string"/>
			<xs:attribute name="employer_business" type="xs:string"/>
			<xs:attribute name="secondary_employer_business" type="xs:string"/>
			<xs:attribute name="secondary_employment_status_code" type="xs:string"/>
			<xs:attribute name="marital_status_code" type="xs:string"/>
			<xs:attribute name="number_of_children" type="xs:string"/>
			<xs:attribute name="Nationality_id" type="xs:long"/>
			<xs:attribute name="country_of_origin_code" type="xs:string"/>
			<xs:attribute name="mailshot" type="xs:string"/>
			<xs:attribute name="is_pet_owner" type="xs:long"/>
			<xs:attribute name="accommodation_type_code" type="xs:string"/>
			<xs:attribute name="date_of_birth" type="xs:dateTime"/>
			<xs:attribute name="gender_code" type="xs:string"/>
			<xs:attribute name="occupation_code" type="xs:string"/>
			<xs:attribute name="secondary_occupation_code" type="xs:string"/>
