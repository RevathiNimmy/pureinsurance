#include "ifx.h"

STRING g_ProcutVersion, g_InstalledVersion;
STRING gInstallMode;

STRING gSTSFileName,g_STSFolderName;

string g_szHostName,g_szUserName; 

BOOL g_bFreshInstaller;	//Flag Variable to identify Fresh Installation
BOOL g_bUpgradeInstaller; // Flag Variable to identify Upgrade Installation of this new installer

STRING g_szAppPoolSTS,g_szApplicationSTS,g_szPhysicalPathSTS;

STRING g_PureSTSFolderName,gPureSTSFileName;
STRING g_STSInstallPath;
STRING g_szWCFServiceUrl;
STRING g_PureAppServer,g_PureWCFServicesUser,g_UserPrincipalName;

STRING g_szPureSTSAppPoolUser, g_szPureSTSAppPoolPassword;

STRING g_STSDefaultInstallPath;

STRING g_OLDSTSConfigPath;


// web services XML
#define ERROR_SUCCESS 0
#define ERROR_XML_FILE_CREATION "Setup could not find the web.config file."
//#define ERROR "Error"
#define ERROR_XML_FILE_STRUCTURE "The web.config file structure is corrupted."
#define ERROR_XML_FILE_LOAD "The web.config file was not loaded."

