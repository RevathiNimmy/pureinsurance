function GetPureSTSFileName()
NUMBER nvResult;  
STRING szPureSTSFileName,svPath;
number nvPureSTSFileExtnLocation;
begin
	svPath= SRCDIR ^ "PureSTS";
    nvResult = FindFile(svPath,"*.zip",szPureSTSFileName);
	if(nvResult <0)then
		//MessageBox("There is no portal available in the Installer",INFORMATION);
	else
	
		gPureSTSFileName=szPureSTSFileName;
		ParsePath (g_PureSTSFolderName, szPureSTSFileName, FILENAME_ONLY ); 
		
		WriteToLogFile(INSTALL_LOG,"Pure STS folder name =" + g_PureSTSFolderName);
	endif;
end;


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  UpdateSTSWebConfig  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for PureSTS                  //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function UpdatePureSTSWebConfig()
STRING  szSrcPath, szFileName,szTargetFile, szTargetPath, szAddKey,szPath;
NUMBER	nResult,i,nvResult;  
OBJECT  oDoc, oNodeList,oNode;
STRING	szProgram,szCommand,szCommand1,szPermission;
STRING  szWebServiceUrl,strNodeName;
begin

    SdShowMsg ( "Updating Pure STS web.config . . . please wait." , TRUE );
    szPath = WINDISK + "\\";
	
	szSrcPath= g_szPhysicalPathSTS;
    LongPathToQuote(szSrcPath, TRUE); 
    
    g_szWCFServiceUrl= "http://" + g_PureAppServer + "/PureWCFServices/PureSecurityService.svc";
    //g_UserPrincipalName= "." + "\\" + g_PureWCFServicesUser ;
    
    // icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
   	szCommand=	szSrcPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
   	
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	
	Disable (LOGGING);
	nResult = XCopyFile (g_szPhysicalPathSTS ^ "web.config", szPath,COMP_NORMAL);
	Enable(LOGGING);
	
    szFileName = szPath ^ "web.config";
    LongPathToQuote(szFileName, TRUE); 
    
	WriteToLogFile(INSTALL_LOG,"web.config path=" + szFileName); 
	if Is(FILE_EXISTS, szFileName) = TRUE then
    else
        MessageBox ( "Can't find web.config", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	// Set the read-only flag OFF
	
	SetFileInfo ( g_szPhysicalPathSTS ^ "web.config", FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("*");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                                
				try
					//<endpoint address="http://localhost/PureWCFServices/PureSecurityService.svc"
					strNodeName= oNode.nodeName;
					if(strNodeName= "endpoint")then
						oNode.attributes.getNamedItem("address").value = g_szWCFServiceUrl;
						WriteToLogFile(INSTALL_LOG,"Updating web.config, endpoint address=" + g_szWCFServiceUrl);
					endif;
                catch
				endcatch;
				
				/*
				try
					//<endpoint address="http://localhost/PureWCFServices/PureSecurityService.svc"
					strNodeName= oNode.nodeName;
					if(strNodeName= "userPrincipalName")then
						oNode.attributes.getNamedItem("value").value = g_UserPrincipalName;
						WriteToLogFile(INSTALL_LOG,"Updating web.config, userPrincipalName=" + g_UserPrincipalName);
					endif;
                catch
				endcatch;
			    */
             endfor; 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   
    else
        MessageBox(ERROR_XML_FILE_LOAD,WARNING);                         
        return -1;
    endif;
    oDoc.save(szFileName);
    set oDoc = NOTHING;
    //Delay(60);
	Disable (LOGGING);
	nResult = XCopyFile (szPath ^ "web.config", g_szPhysicalPathSTS  ,COMP_NORMAL);
	Enable(LOGGING);
	SdShowMsg ( "Updating Pure STS web.config . . . please wait." , FALSE );	
    //DeleteFile(szFileName); 
    return 0;
end; 

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CreatePureSTSRegistry 	                                                 //
//				                                                                     //
// Purpose:   This function create Pure STS Regsitry                                    //
///////////////////////////////////////////////////////////////////////////////////////
function CreatePureSTSRegistry()
STRING szKey,szPureAppServer,szPhysicalPathSTS,szPureWCFServicesUser,szSTSDefaultInstallPath;
NUMBER nSize,nType;

begin 
    nSize= -1;
    nType= REGDB_STRING;
	szKey="SOFTWARE\\PureSTS";
	
	
	szPureAppServer="PureAppServerName";
	szPhysicalPathSTS="PureSTSPhysicalPath";
	szPureWCFServicesUser="PureWCFAppPoolUser";
	szSTSDefaultInstallPath="PureSTSInstallPath";
	
		
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    RegDBCreateKeyEx(szKey, "");
    
    RegDBSetKeyValueEx (szKey, szPureAppServer, nType, g_PureAppServer, nSize);
	RegDBSetKeyValueEx (szKey, szPhysicalPathSTS, nType, g_szPhysicalPathSTS, nSize); 
	//RegDBSetKeyValueEx (szKey, szPureWCFServicesUser, nType, g_PureWCFServicesUser, nSize);
	RegDBSetKeyValueEx (szKey, szSTSDefaultInstallPath, nType, g_STSDefaultInstallPath, nSize);


	return 0;
end;


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  GetPureSTSRegistry 	                                                 //
//				                                                                     //
// Purpose:   This function create Pure STS Regsitry                                    //
///////////////////////////////////////////////////////////////////////////////////////
function GetPureSTSRegistry()
STRING szKey,szPureAppServer,szPhysicalPathSTS,szPureWCFServicesUser,szSTSDefaultInstallPath;
NUMBER nSize,nType;
STRING svPureAppServer,svPhysicalPathSTS,svPureWCFServicesUser,svSTSDefaultInstallPath;

begin 
    nSize= -1;
    nType= REGDB_STRING;
	szKey="SOFTWARE\\PureSTS";
	
	
	szPureAppServer="PureAppServerName";
	szPhysicalPathSTS="PureSTSPhysicalPath";
	//szPureWCFServicesUser="PureWCFAppPoolUser";
	szSTSDefaultInstallPath="PureSTSInstallPath";
	
	
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    if(RegDBKeyExist(szKey)=1) then
		
		if(RegDBGetKeyValueEx (szKey, szPureAppServer, nType, svPureAppServer, nSize) <0 ) then
			
		else
			g_PureAppServer=svPureAppServer;
			WriteToLogFile(INSTALL_LOG,"Pure Insurance Application Server Name=" + g_PureAppServer);
		endif;
		
		if(RegDBGetKeyValueEx (szKey, szPhysicalPathSTS, nType, svPhysicalPathSTS, nSize) <0 ) then
			
		else
			g_szPhysicalPathSTS=svPhysicalPathSTS;
			g_OLDSTSConfigPath=svPhysicalPathSTS;
			//WriteToLogFile(INSTALL_LOG,"Pure Portal Physical Path=" + g_szPhysicalPathPortal);
			WriteToLogFile(INSTALL_LOG,"Pure STS Physical Path=" + g_szPhysicalPathSTS);
		endif;
		/*
		if(RegDBGetKeyValueEx (szKey, szPureWCFServicesUser, nType, svPureWCFServicesUser, nSize) <0 ) then
			
		else
			g_PureWCFServicesUser=svPureWCFServicesUser;
			WriteToLogFile(INSTALL_LOG,"Pure WCF Service User Name=" + g_PureWCFServicesUser);
		endif;
		*/
		if(RegDBGetKeyValueEx (szKey, szSTSDefaultInstallPath, nType, svSTSDefaultInstallPath, nSize) <0 ) then
			
		else
			g_STSDefaultInstallPath=svSTSDefaultInstallPath;
			WriteToLogFile(INSTALL_LOG,"Pure STS default Install Path=" + g_STSDefaultInstallPath);
		endif;
		
	endif;

	return 0;
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  Load User Profile 								             //
//                                                                           //
// Purpose:   This function sets the load user profile = True                        //
//
///////////////////////////////////////////////////////////////////////////////
function LoadAppPoolUserProfile()
STRING szProgram,szSTSAppPoolCommand;
NUMBER nvResult;
begin
	
	
	//%windir%\system32\inetsrv\appcmd set config -section:applicationPools /[name='DefaultAppPool'].processModel.loadUserProfile:true
	//Update Pure Portal App Pool load user profile
	
	SdShowMsg ( "Updating PureSTS App Pool settings . . . please wait." , TRUE );
	szProgram = WINSYSDIR ^ "inetsrv\\appcmd.exe"; 
    LongPathToQuote(szProgram, TRUE); 
    
    szSTSAppPoolCommand = "set config -section:applicationPools /[name=" + "'" + "PureSTSAppPool" + "'].processModel.loadUserProfile:true";
    LongPathToQuote(szSTSAppPoolCommand, FALSE); 
    
    	
	WriteToLogFile(INSTALL_LOG,szSTSAppPoolCommand);
	
	LaunchAppAndWait(szProgram,szSTSAppPoolCommand,WAIT);
	SdShowMsg ( "Updating Portal application settings . . . please wait." , FALSE );
	
	
	
	return 0;

end; 

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CopySTSConfigFile  	                                                 //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for Portal                  //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function CopySTSConfigFile()
STRING  szSrcPath,szTargetPath;
NUMBER	nResult,nvResult;  
STRING  szPermission,szCommand;
begin
	
	//If same build then don't copy
	//IdentityServerConfiguration.sdf
    SdShowMsg ( "Copying existing PureSTS configuration file . . . please wait." , TRUE );
    
	//szSrcPath= g_OLDSTSConfigPath ^ "App_Data" ^ "IdentityServerConfiguration.sdf";
	szSrcPath= g_OLDSTSConfigPath ^ "App_Data";
	szTargetPath=g_szPhysicalPathSTS ^ "App_Data";
	
    // icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
   	szCommand=	szTargetPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	
    
    nResult = CopyFile(szSrcPath ^ "*.*", szTargetPath ^ "*.*");
	
	WriteToLogFile(INSTALL_LOG,"source path= "+ szSrcPath + " TargetPath=" + szTargetPath);
	
	SdShowMsg ( "Copying existing PureSTS configuration file . . . please wait." , FALSE );    
	
    return 0;
    
end; 


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  SSPValidateUserCredentials  	                                             //
//				                                                                     //
// Purpose:   This function varifies the username/password entered on account        //
//            information dialog                                                     //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////

function BOOL SSPValidateUserCredentials()
STRING szCommand,szProgram,szDomain;
STRING szSspValidateLog,szPath;
STRING svReturnLine,svTemp;
NUMBER nvLineNumber,nvResult;


begin
	
	szPath = WINDISK + "\\";
	szDomain = g_szHostName;
	
	szProgram = SUPPORTDIR ^ "SSPValidateUser.exe";
	szSspValidateLog = szPath ^ "SSPValidateUser.log";

	
	
	//Zain Cassimjee Code fixed to allow for the usage of special Characters
	szCommand = "/C " + szProgram + " " + g_szPureSTSAppPoolUser + " \"" + g_szPureSTSAppPoolPassword + "\" " + szSspValidateLog;
	nvResult = LaunchAppAndWait("CMD.EXE",szCommand, WAIT);
	Delay(1);
	
	SetFileInfo(szSspValidateLog, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
	Delay(1);
	
	// Find the search string in the log file.
	nvResult = FileGrep( szSspValidateLog, "LogOnSuccessfull", svReturnLine, nvLineNumber, RESTART);
	
	/*while (nvResult != END_OF_FILE) 
		nvResult = FileGrep (szSspLogonLog, "Succeeded", svReturnLine, nvLineNumber, CONTINUE);
	endwhile; 
	*/	
	
		if (nvResult < 0) then
      
      DeleteFile(szSspValidateLog);
      return FALSE;
    else                                                                                     
   	  
   	  DeleteFile(szSspValidateLog);
   	  return TRUE;
	endif;	
		
	
end;
