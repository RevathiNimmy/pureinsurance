//---------------------------------------------------------------------------
// OnSetUpdateMode
//
// OnSetUpdateMode is called directly by the framework to set the UPDATEMODE
// InstallShield system variable appropriately to control which UI events
// are called by OnShowUI.
//
// Note: This event is called for all setups.
//---------------------------------------------------------------------------
function OnSetUpdateMode()
	number	nIgnore, nMediaFlags, nInstalledVersion, nUpdateVersion, nResult;
	string	szVersion, szIgnore, szMsg;
begin
	
	UPDATEMODE = FALSE; // Non-update mode by default.

	// Added 11.5 - Don't set UPDATEMODE when running from Add/Remove
	if( ADDREMOVE ) then
		return ISERR_SUCCESS;
	endif;

	// Added 11.5 - Don't set UPDATEMODE when REMOVEONLY is specified
	if( REMOVEONLY ) then
		return ISERR_SUCCESS;
	endif;

	// Get the media flags.
	MediaGetData( MEDIA, MEDIA_FIELD_MEDIA_FLAGS, nMediaFlags, szIgnore );

	// TODO: If you are updating an application that was installed by a previous
	// version of InstallShield, IFX_INSTALLED_VERSION will be empty, and
	// VERSION_COMPARE_RESULT_NOT_INSTALLED will be returned by
	// VerProductCompareVersions. Change the value of IFX_INSTALLED_VERSION (and
	// IFX_INSTALLED_DISPLAY_VERSION) here based on application specific version
	// information determined by the setup. Only do this if IFX_INSTALLED_VERSION
	// is empty.
	//if ( !StrLengthChars( IFX_INSTALLED_VERSION ) && MAINTENANCE ) then
	//	IFX_INSTALLED_VERSION = "X.XX.XXX";
	//	IFX_INSTALLED_DISPLAY_VERSION = IFX_INSTALLED_VERSION;
	//endif;

	// Verify that the installed version is valid.
	if( !StrLengthChars( IFX_INSTALLED_VERSION ) && MAINTENANCE ) then
		// If this error occurs, IFX_INSTALLED_VERSION needs to be set manually.
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_NO_INSTALLED_VERSION );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Verify that the product version is valid.
	if( !StrLengthChars( IFX_PRODUCT_VERSION ) ) then
		// If this error occures, IFX_PRODUCT_VERSION was not initialized correctly.
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_NO_PRODUCT_VERSION );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Do the version comparison.
	nResult = VerProductCompareVersions();

	// Make sure that valid data was returned by VerProductCompareVersions
	if( nResult < ISERR_SUCCESS ) then
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_VERSION_COMPARE_FAILURE );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Set update mode if this is a differential media or the product is already installed and the versions do not match.
	UPDATEMODE = ( nMediaFlags & MEDIA_FLAG_FORMAT_DIFFERENTIAL || ( MAINTENANCE && ( nResult != VERSION_COMPARE_RESULT_SAME ) ) );

end;

//////////////////////////////////////////////////////////////////////////////////
// Function:  CopyStagingDatabasebackupToRemoteServer                                  //
// Purpose:   This function copy the database backup file from local server to  //
//            Remote server shared location provided by the user                //  
//                                                                              //
//////////////////////////////////////////////////////////////////////////////////
function CopyStagingDatabasebackupToRemoteServer()
STRING szProgram,szCommand;
STRING szStagingDBBackUpFilePath;
begin
			szStagingDBBackUpFilePath = SRCDIR ^ "Scripts\\PureStaging.bak";
			szProgram=WINSYSDIR ^ "Robocopy.exe";
			szCommand= SRCDIR ^ "Scripts";
			WriteToLogFile(INSTALL_LOG,"Command=" + szCommand);
			LongPathToQuote(szCommand,TRUE);
			LongPathToQuote(gStagingSharedPath,TRUE);
			szCommand= szCommand + " " + gStagingSharedPath + " " + "PureStaging.bak";
			WriteToLogFile(INSTALL_LOG,"Robobopy Command=" + szCommand);
			LaunchAppAndWait(szProgram,szCommand,WAIT);
			LongPathToQuote(gStagingSharedPath,FALSE);
	return 0;
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  CreateStagingDatabaseFromBackup                                 //
//                                                                           //
// Purpose:   This function is used to create or restore the Staging Database //
//            from the backup for the suitable product version for           //
//			  fresh installation                                             //
///////////////////////////////////////////////////////////////////////////////           
function number CreateStagingDatabaseFromBackup()
number nvResult;
string szRestoreDBScript;    
string szStagingDBBackUpFilePath;    
string szStagingDBFileName;
string szStagingLogFileName;
STRING szRestoreDBFileName,szBackupPath;
STRING szProgram,szCommand;
begin        
try     
	szStagingDBFileName = gStagingDB + "_Data.mdf" ;
	szStagingLogFileName = gStagingDB + "_Log.ldf" ;
	if(g_bStagingRemoteDBServer = FALSE) then
				szStagingDBBackUpFilePath = SRCDIR ^ "Scripts\\PureStaging.bak";
				szRestoreDBScript = "restore database "+ gStagingDB +" from disk = '"+ szStagingDBBackUpFilePath +"' with ";
				szRestoreDBScript =  szRestoreDBScript + "move 'SAMStaging_Data' to '"+g_StagingMDFDirPath+"\\"+szStagingDBFileName+"',";
				szRestoreDBScript =  szRestoreDBScript + "move 'SAMStaging_Log' to '"+g_StagingDFDirPath+"\\"+szStagingLogFileName+"'";
				WriteToLogFile(INSTALL_LOG,"Pure Staging database restore=" + szRestoreDBScript);
	else
				szStagingDBBackUpFilePath = gStagingSharedPath ^ "PureStaging.bak";
				WriteToLogFile(INSTALL_LOG,"Shared Path=" + gStagingSharedPath);
				WriteToLogFile(INSTALL_LOG,"Backup Path=" + szStagingDBBackUpFilePath);
				szRestoreDBScript = "restore database "+ gStagingDB +" from disk = '"+ szStagingDBBackUpFilePath +"' with ";
				szRestoreDBScript =  szRestoreDBScript + "move 'SAMStaging_Data' to '"+g_StagingMDFDirPath+"\\"+szStagingDBFileName+"',";
				szRestoreDBScript =  szRestoreDBScript + "move 'SAMStaging_Log' to '"+g_StagingDFDirPath+"\\"+szStagingLogFileName+"'";
				WriteToLogFile(INSTALL_LOG,"Pure Staging database restore=" + szRestoreDBScript);
	endif;
catch
	MessageBox("There was a problem with the Pure Staging Database Creation from the Pure Staging DBBackup. Please investigate.",WARNING);        
 	abort;       
endcatch;
	
	SdShowMsg(gStagingDB + " Database Creation is in progress",TRUE);
	nvResult = ADODBConnectAndExecuteStaging(gStagingDBServer,"master",gStagingDBUser,gStagingDBPassword,szRestoreDBScript);
	if(nvResult = 1) then
		SdShowMsg(gStagingDB + " Database Creation done",FALSE);
		WriteToLogFile(INSTALL_LOG,"Database " + gStagingDB + " Creation Completed");
	else  
		SdShowMsg("Problem with "+ gStagingDB + " Database Creation",FALSE);
		MessageBox("Database Creation operation Failed. Check for any Issues in the Database Error Log.",SEVERE);
		abort;
	endif;
return 1;
end;  

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ADODBConnectAndExecuteStaging                                         //
//                                                                           //
// Purpose:  This function connects to the DB Server and executes            //
//			 a SQL Script on the database specified in the                   //
//			 function parameters                                             //
///////////////////////////////////////////////////////////////////////////////
function number ADODBConnectAndExecuteStaging(gStagingDBServer,gStagingDB,gStagingDBUser,gStagingDBPassword,szSQLScript)
 string szADOObjID,szDriver,szConnString,szADOCommObjID,szErrorLog;
 object objADO,objADOComm;  
 number nvRecords;
 begin 
	
	//MessageBox(gStagingDBServer + gStagingDB + gStagingDBUser + gStagingDBPassword + szSQLScript,INFORMATION);
   	
   	szADOObjID = "ADODB.Connection";
	set objADO = CreateObject(szADOObjID);	
	szConnString = GetConnectionStringStaging(gStagingDB);
	
	//MessageBox("Connection String=" + szConnString,INFORMATION);
   	
	// Open the ADO Connection 
	objADO.Open(szConnString);
	//MessageBox("After Open=" ,INFORMATION);
   
   // Create the ADO Command object to execute the script                           	
	szADOCommObjID = "ADODB.Command";
	set objADOComm = CreateObject(szADOCommObjID); 
	objADOComm.CommandTimeout = 600;   
	objADOComm.ActiveConnection = objADO;
	try    
	 	 	// Execute the call to run the script
			objADOComm.CommandText = szSQLScript;
			objADOComm.Execute(nvRecords ,0x81);
	catch
			szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n"; 
			//WritetoDatabaseLog(szErrorLog,TRUE);	
			WriteToLogFile(INSTALL_ERROR_LOG,szErrorLog);
			objADO.Close(); 
			set objADO = NOTHING; 
			return -1;
	endcatch;     
	//Close the Connections after executing SQL Scripts
	objADO.Close(); 
	set objADO = NOTHING;
   return 1;
end;
///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ADODBConnectExecuteAndReturnStaging                                   //
//                                                                           //
//  Purpose:  This function connects to the DB Server and executes a 		 //
//			  SQL Script on the database specified in the function 			 //
//			  parameters  and returns a value as a String Result        	 //
///////////////////////////////////////////////////////////////////////////////
function string ADODBConnectExecuteAndReturnStaging(gStagingDBServer,gStagingDB,gStagingDBUser,gStagingDBPassword,szSQLScript,szReturnParameter)  
 string szADOObjID,szDriver,szConnString,szReturnValue,szErrorLog;
 object objConnection,objRecordSet;  
 begin 
   	try
   			szReturnValue = "";
			szADOObjID = "ADODB.Connection";
			set objConnection = CreateObject(szADOObjID);	
		    szConnString = GetConnectionStringStaging(gStagingDB);
			objConnection.ConnectionString = szConnString;
			// Open the ADO Connection 
			objConnection.Open;
	catch
	         szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n";
	         return szReturnValue;  
	endcatch;
    try    
	 	 	set objRecordSet = objConnection.Execute(szSQLScript);
	        szReturnValue = objRecordSet(szReturnParameter);     
	        return szReturnValue;    
	         //sRetValue
	catch
	     	szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n";
			//WritetoDatabaseLog(szErrorLog,TRUE);	
			WriteToLogFile(INSTALL_ERROR_LOG,szErrorLog);
			objConnection.Close();
			set objConnection = NOTHING;
			return szReturnValue;   
	endcatch;  
	//Close the Connections after executing SQL Scripts
	objConnection.Close();
	set objConnection = NOTHING;
  return szReturnValue;
end;   


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  GetPureDBDetailFromRegistry 	                                                 //
//				                                                                     //
// Purpose:   This function gets PortalRegsitry                                    //
///////////////////////////////////////////////////////////////////////////////////////

function GetPureDBDetailFromRegistry()

begin

gPureDB = GetFromRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Database");
gPureDBServer =GetFromRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Server");
             

end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function: GetFromRegistry                                                 //
//                                                                           //
// Purpose:  This function gets  a particular value for the registry key     //
//			 under the foldername as specified in the function parameters    //
//                                                                      	 //
///////////////////////////////////////////////////////////////////////////////

function string GetFromRegistry(szFolderName,szKey)
number nvResult,nvType,nvSize;
string szValue;
begin                         
nvSize = -1; 
try 
	if(RegDBKeyExist(szFolderName) = 1) then
		if(RegDBGetKeyValueEx(szFolderName,szKey,nvType,szValue,nvSize) < 0) then 
			WriteToLogFile(INSTALL_ERROR_LOG,"Not able to fetch the value "+szKey+ " from the folder "+szFolderName+ " registry");
		else
			WriteToLogFile(INSTALL_LOG,"Value fetched for "+ szKey + " from the folder "+szFolderName+ " registry");
		endif;  
	else
		WriteToLogFile(INSTALL_ERROR_LOG,"The Specified Folder/Key "+szFolderName+ "//" + szKey + " does not exist");
	endif;
catch 
         WriteToLogFile(INSTALL_ERROR_LOG,"Error Encountered fetching key value "+szKey+" from folder "+szFolderName);
         return "";
endcatch;

return szValue;
end;  


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CreateDTURegistry 	                                                 //
//				                                                                     //
// Purpose:   This function create DRERegsitry                                       //
///////////////////////////////////////////////////////////////////////////////////////
function CreateDTURegistry()
STRING szKey;
NUMBER nSize,nType;
STRING szDTUDBServer,szDTUDB;
begin 
    
    nSize= -1;
    
    nType= REGDB_STRING;
	szKey="SOFTWARE\\DTU";
	
	szDTUDBServer="StagingDBServer";
	szDTUDB="StagingDBName";
	
    
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    RegDBCreateKeyEx(szKey, "");
    
	//DTU database registry
	RegDBSetKeyValueEx (szKey, szDTUDBServer, nType, gStagingDBServer, nSize);
	RegDBSetKeyValueEx (szKey, szDTUDB, nType, gStagingDB, nSize);
	
	return 0;
end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  GetDTURegistry 	                                                 //
//				                                                                     //
// Purpose:   This function gets PortalRegsitry                                    //
///////////////////////////////////////////////////////////////////////////////////////
function GetDTURegistry()
NUMBER nSize,nType;
STRING svDTUDBServer,svDTUDB;
STRING szKey;
STRING szDTUDBServer,szDTUDB;

begin 
    nSize= -1;
    nType= REGDB_STRING;
	szKey="SOFTWARE\\DTU";
	
	
	szDTUDBServer="StagingDBServer";
	szDTUDB="StagingDBName";
	
	
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
	
    if(RegDBKeyExist(szKey)=1) then
		
		//DTU Staging DB Server
		if(RegDBGetKeyValueEx (szKey, szDTUDBServer, nType, svDTUDBServer, nSize) <0 ) then
			//
		else
			gStagingDBServer=svDTUDBServer;
			WriteToLogFile(INSTALL_LOG,"DTU Staging DB Server=" + gStagingDBServer);
		endif;
		
		//DTU Staging DB NAME
		if(RegDBGetKeyValueEx (szKey, szDTUDB, nType, svDTUDB, nSize) <0 ) then
			//
		else
			gStagingDB=svDTUDB;
			WriteToLogFile(INSTALL_LOG,"DTU DB=" + gStagingDB);
		endif;
		
	else
		//
	endif;
	
	return 0;
end;
///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  GetPureInstallPath 	                                                 //
//				                                                                     //
// Purpose:   This function gets Pure Install path                                    //
///////////////////////////////////////////////////////////////////////////////////////

function GetPureInstallPath()
STRING szUninstallKey,szInstallLocation;
NUMBER nSize,nType;
begin

	 // Read Pure InstallLocation from regsitry
	szUninstallKey="SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{A5D571AB-3D05-4530-A631-74E8D1CADCA6}";
    szInstallLocation= "InstallLocation"; 
    
    nSize= -1;
    nType= REGDB_STRING;   
    
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if((RegDBKeyExist(szUninstallKey)=1)) then
		RegDBGetKeyValueEx (szUninstallKey, szInstallLocation, nType, gPureInstallLocation, nSize); 
	else
		// Not Installed, so it is Fresh Install
		//gInstallMode="Fresh";
	endif;

end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ReadWCFSecurityTokenFile  								             //
//                                                                           //
// Purpose:   This function read WCFSecurityTokenFile.txt                        //
//
///////////////////////////////////////////////////////////////////////////////

function ReadWCFSecurityTokenFile()
STRING szDir,szFile;
number  nvFileHandle,nvResult; 
begin   
	
	szDir = gPureInstallLocation ^ "Application";
	
	szFile = "WCFSecurityTokenFile.txt";
	
	// Set the file mode to normal. 
    OpenFileMode (FILE_MODE_NORMAL); 
    
    // Open the text file. 
    if (OpenFile (nvFileHandle, szDir, szFile) < 0) then 
        MessageBox ("OpenFile failed.", SEVERE); 
    else
    	nvResult = GetLine(nvFileHandle,g_szWCFSecuirtyToken);
      
    endif; 
    
    CloseFile(nvFileHandle);
	
return 0;

end; 


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  UpdateDTUWebConfig  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for DTU         //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function UpdateDTUWebConfig()
STRING  szFileName,szTargetFile, szTargetPath, szAddKey,szPath;
NUMBER	nResult,i,nvResult;  
OBJECT  oDoc, oNodeList,oNode;
STRING	szProgram,szCommand,szCommand1,szPermission;
begin
	
	SdShowMsg ( "Updating SiriusFS.S4I.DataImport3.exe.config . . . please wait." , TRUE );
	
    szTargetPath = TARGETDIR;
    
    szFileName = szTargetPath ^ "SiriusFS.S4I.DataImport3.exe.config";
    
    LongPathToQuote(szTargetPath, TRUE); 
	//LongPathToQuote ( szFileName, TRUE );
	// icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
   	szCommand=	szTargetPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
   	
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	//LongPathToQuote ( szFileName, TRUE );
	WriteToLogFile(INSTALL_LOG,"web.config path=" + szFileName); 
	if Is(FILE_EXISTS, szFileName) = TRUE then
       //
    else
        MessageBox ( "Can't find web.config", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	 // Set the read-only flag OFF
	SetFileInfo ( szTargetFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("*");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                try
                    szAddKey = oNode.attributes.getNamedItem("key").value;
                catch
                    szAddKey = "";
                endcatch;
                
                try
                    if szAddKey = "WCFSecurityToken" then
                        oNode.attributes.getNamedItem("value").value = g_szWCFSecuirtyToken;
                        WriteToLogFile(INSTALL_LOG,"Updating web.config, WCFSecurityToken=" + g_szWCFSecuirtyToken); 
                    endif;
                    
                catch
                endcatch;
             endfor; 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   
    else
        MessageBox(ERROR_XML_FILE_LOAD,SEVERE);                         
        return -1;
    endif;
    oDoc.save(szFileName);
    set oDoc = NOTHING;
    
	SdShowMsg ( "Updating SiriusFS.S4I.DataImport2.exe.config . . . please wait." , FALSE );
    return 0;
end; 

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  DeleteDTU2Files  	                                                         //
//				                                                                     //
// Purpose:   This function 
//                                                                                   //
///////////////////////////////////////////////////////////////////////////////////////
function DeleteDTU2Files()
STRING szTargetPath,szFileName;

begin
	
	Disable (LOGGING);
	
	szTargetPath = TARGETDIR;
	
	szFileName = szTargetPath ^ "SiriusFS.S4I.DataImport2.application";
	if Is(FILE_EXISTS, szFileName) = TRUE then
			DeleteFile ( szFileName );
	endif;
	
	szFileName = szTargetPath ^ "SiriusFS.S4I.DataImport2.exe";
	if Is(FILE_EXISTS, szFileName) = TRUE then
			DeleteFile ( szFileName );
	endif;
	
	szFileName = szTargetPath ^ "SiriusFS.S4I.DataImport2.exe.config";
	if Is(FILE_EXISTS, szFileName) = TRUE then
			DeleteFile ( szFileName );
	endif;
	
	szFileName = szTargetPath ^ "SiriusFS.S4I.DataImport2.exe.manifest";
	if Is(FILE_EXISTS, szFileName) = TRUE then
			DeleteFile ( szFileName );
	endif;
	
	szFileName = szTargetPath ^ "SiriusFS.S4I.DataImport2.pdb";
	if Is(FILE_EXISTS, szFileName) = TRUE then
			DeleteFile ( szFileName );
	endif;
	
	szFileName = szTargetPath ^ "SiriusFS.S4I.DataImport2.vshost.exe";
	if Is(FILE_EXISTS, szFileName) = TRUE then
			DeleteFile ( szFileName );
	endif;
	
	szFileName = szTargetPath ^ "SiriusFS.S4I.DataImport2.xml";
	if Is(FILE_EXISTS, szFileName) = TRUE then
			DeleteFile ( szFileName );
	endif;
	
	Enable (LOGGING);
	 
	return 0;

end;

