		if( nResult = NEXT ) then
			 //store data in case we need it again
            SQLRTPutConnectionInfo2( szConnection, szServer, szDB, szUser, szPassword );

	        SQLRTPutConnectionAuthentication( szConnection, bStagingDBWinLogin );

            //try connection
