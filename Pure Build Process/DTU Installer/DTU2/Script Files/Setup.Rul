//---------------------------------------------------------------------------
// OnBegin
//
// The OnBegin event is called directly by the framework after the setup
// initializes. Note that this event will be called AFTER "Initialization"
// events (i.e.) OnSetTARGETDIR, OnCheckMediaPassword.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnBegin()
begin
    
     if( REMOVEONLY = 0) then
		
		// Get the hostname of the machine.
 		GetEnvVar("COMPUTERNAME",g_szHostName); 
 		GetEnvVar("USERNAME",g_szUserName); 
 		
		CheckTypeofInstallation();
		
		GetPureInstallPath();
		
		
     endif;
    
end;

//---------------------------------------------------------------------------                                                                        
// OnFirstUIBefore
//
// First Install UI Sequence - Before Move Data
//
// The OnFirstUIBefore event is called by OnShowUI when the setup is
// running in first install mode. By default this event displays UI allowing
// the end user to specify installation parameters.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnFirstUIBefore()
    number  nResult, nLevel, nSize, nSetupType,nvResult;
    string  szTitle, szMsg, szOpt1, szOpt2, szLicenseFile;
    string  szName, szCompany, szTargetPath, szDir, szFeatures;
    BOOL    bLicenseAccepted;
    NUMBER nvStringLocation,nvStringLength;
    STRING szDTUfolder;
    HWND hMSI;
    
begin	

    // Added in InstallShield 15 - Show an appropriate error message if
    // -removeonly is specified and the product is not installed.
    if( REMOVEONLY ) then
        Disable( DIALOGCACHE );
		szMsg = SdLoadString( IDS_IFX_ERROR_PRODUCT_NOT_INSTALLED_UNINST );
   		SdSubstituteProductInfo( szMsg );
		MessageBox( szMsg, SEVERE );
		abort;
    endif;
   
    nSetupType = COMPLETE;	
    szDir = TARGETDIR;
    szName = "";
    szCompany = "";
    //bLicenseAccepted = FALSE;
    
	g_bDTU=TRUE;
	//g_bPureDatabase=TRUE;
    //g_bStagingDatabase=FALSE;
    g_bCreateStagingDatabase=TRUE;
    
    gPureDBServer="";
    gPureDB="";
    gPureDBUser="";
    gPureDBPassword="";
    
    gStagingDBServer="";
    gStagingDB="";
    gStagingDBUser="";
    gStagingDBPassword="";

// Beginning of UI Sequence
Dlg_Start:
    //nResult = 0;
    
    //WriteToLogFile(INSTALL_LOG,"Installation started =" + g_InstallPath);

Dlg_SdWelcome:
    szTitle = "";
    szMsg = "";
    
    nResult = SdWelcome( szTitle, szMsg );
    
    if (nResult = BACK) goto Dlg_Start;

Dlg_InstallationType:

		//nResult    = AskOptions(NONEXCLUSIVE,'Select the type of Installation Required.',"Install DTU Files",g_bDTU,"Run Pure DTU database Scripts",g_bPureDatabase, "Run Staging Scripts", g_bStagingDatabase); 
		nResult    = AskOptions(NONEXCLUSIVE,'Select the type of Installation Required.',"Install DTU application",g_bDTU,"Create Staging database",g_bCreateStagingDatabase);
		
		if (nResult = BACK) goto Dlg_SdWelcome;

Dlg_SdAskDestPath2:
   
		TARGETDIR="C:\\DTU";
		g_InstallPath = TARGETDIR;
		nResult = SdAskDestPath(szTitle, szMsg, g_InstallPath, 0);
	
	
	    //Check to Add Pure Folder to the Destination Path if one is not present
	    
	    StrRemoveLastSlash(g_InstallPath);
	    
	    nvStringLength = StrLengthChars(g_InstallPath);
	    nvStringLocation = StrFind(g_InstallPath,"\DTU");
			
		if(nvStringLocation < 0) then 
				// if pure is not present, then add
				StrRemoveLastSlash(g_InstallPath);
				g_InstallPath= g_InstallPath ^ "DTU";
				WriteToLogFile(INSTALL_LOG,"No DTU present,DTU added in the  path" + g_InstallPath);
	    	
		elseif(nvStringLocation > 0)  then   
	    	StrSub(szDTUfolder, g_InstallPath, nvStringLength - 3, nvStringLength);
	    	
	    	if (szDTUfolder="DTU")then
				WriteToLogFile(INSTALL_LOG,"DTU present in the path" + g_InstallPath);
	    	
	    	else
				//if pure is not the last in the path e.g C:\Pure\test\Pure, then add pure
				g_InstallPath= g_InstallPath ^ "DTU";
				WriteToLogFile(INSTALL_LOG,"DTU present, but not at the end, DTU added in the  path" + g_InstallPath);
	    	
	    	endif;
	    endif;
	    
	       
		StrRemoveLastSlash(g_InstallPath);
	    
	   	   
	    TARGETDIR = g_InstallPath;
	    WriteToLogFile(INSTALL_LOG,"Final TARGETDIR=" + g_InstallPath);
	    
	
		if (nResult = BACK) goto Dlg_InstallationType;


Dlg_PureDatabaseDetails:

		if(g_bDTU=TRUE) then
			GetPureDBDetailFromRegistry();
			nResult= PureDatabaseDetails();
		endif;
		
		if (nResult = BACK) goto Dlg_SdAskDestPath2;

Dlg_StagingDatabaseDetails:
			 /*if (gInstallMode="Fresh") then			 
				CreateDTURegistry();
			 else
				GetDTURegistry();
			 endif;	*/ 
			 
			 
			nResult= StagingDatabaseDetails();
			
				
			//Set Compatibility Level
			//SetStagingCompatibilityLevel();
			
			if (nResult = BACK) goto Dlg_PureDatabaseDetails;	
					
		
			if (g_bCreateStagingDatabase=TRUE) then
					
					if(StrCompare(gStagingDBServer,g_szHostName)=0)  then
						g_bStagingRemoteDBServer = FALSE;
					elseif(StrFind(gStagingDBServer,"(local)") >= 0) then
						g_bStagingRemoteDBServer = FALSE;
					elseif(StrFind(gStagingDBServer,g_szHostName) >= 0) then
						g_bStagingRemoteDBServer = FALSE;
					else 
						g_bStagingRemoteDBServer = TRUE;
					endif;   
				
					if(g_bStagingRemoteDBServer = TRUE) then
						// Pass default backup DB name 
						//Don't do anything, currently hardcoded backup file name is provided already 
						//SelectDir ( "", "Select the Shared location:", gSharedPath, FALSE );
						SetDialogTitle ( DLG_ASK_PATH, "Select the Share location" );
						nResult= AskPath ( "Select the Shared folder location(UNC Path) on the database server", "", gStagingSharedPath ); 
						StrRemoveLastSlash ( gStagingSharedPath ); 
						
						if (nResult = BACK) goto Dlg_StagingDatabaseDetails;
					endif;
			endif;
				
	
// Ask new DB details
Dlg_SdStagingnewdbdetails:
			 if (g_bCreateStagingDatabase=TRUE) then

					nvResult = SdStagingnewdbdetails(hMSI,gStagingDBServer,gStagingDBUser,gStagingDBPassword,gStagingDB,g_StagingMDFDirPath,g_StagingDFDirPath);
						//create registry for later use
					CreateDTURegistry();	
					if(nvResult = BACK) then
						goto Dlg_StagingDatabaseDetails;
					endif;
					
					
					//Create Stagingf database
					/*Disable( DIALOGCACHE );
					CreateStagingDatabaseFromBackup();
					Enable( DIALOGCACHE );
				*/
					//Set Compatibility Level
					//SetStagingCompatibilityLevel();
					
			 endif;
			
 
Dlg_SdStartCopy2:
		szTitle = "";
		szMsg = "";
		
		nResult = SdStartCopy2( szTitle, szMsg );	
		
   
		if (nResult = BACK) then
		  if (g_bCreateStagingDatabase=TRUE) then
				goto Dlg_SdStagingnewdbdetails;
		  else
				goto Dlg_StagingDatabaseDetails;
		  endif;
		endif;
		
		
		if (g_bCreateStagingDatabase=TRUE) then
			
			if(g_bStagingRemoteDBServer = TRUE) then
				SdShowMsg ( "Copying database backup file to database server . . . please wait." , TRUE );
				CopyStagingDatabasebackupToRemoteServer();
				SdShowMsg ( "Copying database backup file to database server . . . please wait." , FALSE );
			
			endif;
			
			//Create Stagingf database
			Disable( DIALOGCACHE );
			CreateStagingDatabaseFromBackup();
			Enable( DIALOGCACHE );
				
		endif;  
  
		// Added in 11.0 - Set appropriate StatusEx static text.
		SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_FIRSTUI ) );
 
    return 0;
end;

//---------------------------------------------------------------------------
// OnMaintUIBefore
//
// Maintenance UI Sequence - Before Move Data
//
// The OnMaintUIBefore event is called by OnShowUI when the setup is
// running in maintenance mode. By default this event displays UI that
// allows the end user to add or remove features, repair currently
// installed features or uninstall the application.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnMaintUIBefore()
    number	nResult, nType;
    string	szTitle, szMsg;
begin
	
	// nType defaults to MODIFY.
	nType = MODIFY;

    //Initialize SQL
    //OnSQLServerInitializeMaint();

// Beginning of UI Sequence
Dlg_Start:

    // Added in Version 9.5 - Support for REMOVEONLY option.
    if( !REMOVEONLY ) then
    	// In standard mode show maintenance dialog
	    Disable( BACKBUTTON );
	    //nType = SdWelcomeMaint( szTitle, szMsg, nType );
	    
	    if(gInstallMode="Same")then
			//MessageBox("Same",INFORMATION);
			nType=MODIFY;
	    endif;
	    
	    Enable( BACKBUTTON );
        nResult = NEXT;
    else
        // Hide the initial progress dialog as otherwise the user can
        // click on it, and hide the MessageBox.
        Disable( DIALOGCACHE );

        // In RemoveOnly mode, set to remove.
        nType = REMOVEALL;
    endif;

	// Show Uninstall Confirmation Dialog
    if ( nType = REMOVEALL ) then
		nResult = MessageBox( SdLoadString( IFX_MAINTUI_MSG ), MB_YESNO );
		if (nResult != IDYES ) then
            
            if( REMOVEONLY ) then
                // In REMOVEONLY mode, abort the setup.
                abort;
            else
                // In non-REMOVEONLY mode, redisplay the previous dialog.
			    goto Dlg_Start;
            endif;

		endif;
	endif;



Dlg_ObjDialogs:
    nResult = ShowObjWizardPages( nResult );
    if ( ( nResult = BACK ) && ( nType != MODIFY ) ) goto Dlg_Start;
 
	switch(nType)

        case REMOVEALL:
						
			// Ensure that all previously installed features are removed.
			FeatureRemoveAllInMediaAndLog();

            // Added in 11.0 - Set appropriate StatusEx static text.
            SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_REMOVEALL ) );

       case REPAIR:
				
			FeatureReinstall();
           
            // Added in 11.0 - Set appropriate StatusEx static text.
            szMsg="The InstallShield Wizard is repairing Pure Insurance DTU.";
            SetStatusExStaticText(szMsg);
            //SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_REPAIR ) );

        case MODIFY:
            
            FeatureReinstall();
            // Added in 11.0 - Set appropriate StatusEx static text.
            szMsg="The InstallShield Wizard is modifying Pure Insurance DTU.";
            SetStatusExStaticText(szMsg);
            //SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_MODIFY ) );

    endswitch;
 
end;

//---------------------------------------------------------------------------
// OnUpdateUIBefore
//
// Update UI Sequence - Before Move Data
//
// The OnUpdateUIBefore event is called when the setup is running in update
// mode. By default this event displays UI that allows the end user to
// update the application to the current version.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnUpdateUIBefore()
	string szTitle, szMsg, szIgnore, szVersionInstalled, szVersionSupported, szVersionUpdate;
	number nVersionInstalled;
	number nIgnore, nId, nMediaFlags;
	number nResult;
	
begin

	Disable (DIALOGCACHE);
	
	Enable(STATUSEX);
    SetStatusWindow (0, ""); 
    StatusUpdate (ON, 99); 
    
	  //Call FeatureReinstall to reinstall all the files
    FeatureReinstall();
    FeatureTransferData(MEDIA);

end;


//---------------------------------------------------------------------------
// OnFirstUIAfter
//
// First Install UI Sequence - After Move Data
//
// The OnFirstUIAfter event called by OnShowUI after the file transfer
// of the setup when the setup is running in first install mode. By default
// this event displays UI that informs the end user that the setup has been
// completed successfully.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnFirstUIAfter()
    STRING szTitle, szMsg1, szMsg2, szOpt1, szOpt2;
    NUMBER bvOpt1, bvOpt2;
begin

    ShowObjWizardPages(NEXT);
    
    szTitle = "";
    szMsg1 = ""; 
    szMsg2 = "";
    szOpt1 = "";
    szOpt2 = "";
	bvOpt1   = FALSE;
    bvOpt2   = FALSE;    
    
   
    if ( BATCH_INSTALL ) then
    	SdFinishReboot ( szTitle , szMsg1 , SYS_BOOTMACHINE , szMsg2 , 0 );
    else
	    SdFinish ( szTitle , szMsg1 , szMsg2 , szOpt1 , szOpt2 , bvOpt1 , bvOpt2 );
	endif;
    
end;

//---------------------------------------------------------------------------
// OnMaintUIAfter
//
// The OnMaintUIAfter event called by OnShowUI after the file transfer
// of the setup when the setup is running in maintenance mode. By default
// this event displays UI that informs the end user that the maintenance setup
// has been completed successfully.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnMaintUIAfter()
    STRING szTitle, szMsg1, szMsg2, szOpt1, szOpt2;
    NUMBER bvOpt1, bvOpt2;
begin

    ShowObjWizardPages(NEXT);
    
    if( REMOVEALLMODE ) then
        szTitle = SdLoadString(IFX_SDFINISH_REMOVE_TITLE);
        szMsg1 = SdLoadString(IFX_SDFINISH_REMOVE_MSG1);
    else
        szTitle = SdLoadString(IFX_SDFINISH_MAINT_TITLE);    
        szMsg1  = SdLoadString(IFX_SDFINISH_MAINT_MSG1);
    endif;

	szMsg2 = "";    
    szOpt1 = "";
    szOpt2 = "";
	bvOpt1   = FALSE;
    bvOpt2   = FALSE;    

    if ( BATCH_INSTALL ) then
    	SdFinishReboot ( szTitle , szMsg1 , SYS_BOOTMACHINE , szMsg2 , 0 );
    else    
       	SdFinish ( szTitle , szMsg1 , szMsg2 , szOpt1 , szOpt2 , bvOpt1 , bvOpt2 );
    endif;
end;

//---------------------------------------------------------------------------
// OnUpdateUIAfter
//
// Update Mode UI Sequence - After Move Data
//
// The OnUpdateUIAfter event called by OnShowUI after the file transfer
// of the setup when the setup is running in update mode. By default
// this event displays UI that informs the end user that the maintenance setup
// has been completed successfully.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnUpdateUIAfter()
    string	szTitle, szMsg1, szMsg2, szOpt1, szOpt2;
    BOOL	bOpt1, bOpt2;
begin

    ShowObjWizardPages(NEXT);
    
	szTitle = SdLoadString(IDS_IFX_SDFINISH_UPDATE_TITLE);    
    szMsg1  = "The InstallShield Wizard has successfully upgraded Pure Insurance DTU. Click Finish to exit the wizard.";
	szMsg2 = "";    
    szOpt1 = "";
    szOpt2 = "";
	bOpt1   = FALSE;
    bOpt2   = FALSE;    
    
    if ( BATCH_INSTALL ) then
    	SdFinishReboot ( szTitle , szMsg1 , SYS_BOOTMACHINE , szMsg2 , 0 );
    else    
       	SdFinish ( szTitle , szMsg1 , szMsg2 , szOpt1 , szOpt2 , bOpt1 , bOpt2 );
    endif;
end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CopyDTUFiles  	                                                         //
//				                                                                     //
// Purpose:   This function 
//                                                                                   //
///////////////////////////////////////////////////////////////////////////////////////
function CopyDTUFiles()
STRING szSource,sztarget,szPath;

begin
	
	Disable (LOGGING);
	
	SdShowMsg ( "Copying files. . . please wait." , TRUE );
	
	szSource= SRCDIR ^ "DTU";
	sztarget= TARGETDIR;
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR); 
	
	SdShowMsg ( "Copying files . . . please wait. . . please wait." , FALSE );	
	
	Enable (LOGGING);
	 
	return 0;

end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  RunPureScripts  	                                                         //
//				                                                                     //
// Purpose:   This function 
//                                                                                   //
///////////////////////////////////////////////////////////////////////////////////////
function RunPureScripts()
LIST lstFiles;
NUMBER nRes,nBuffer;
STRING sFileName, szExecutionError;
BOOL bSuccess;
STRING svFileName,svFileNameForList,svDir;
NUMBER  nFlag, nFileHandle; 
STRING svLine;


begin
	
	SdShowMsg ( "Executing Pure DTU scripts . . . please wait." , TRUE );
	WriteToLogFile(INSTALL_LOG, "Runing Pure scripts...");
	
	svDir= SRCDIR ^ "Scripts\\Pure";
	
	lstFiles = ListCreate (STRINGLIST);

    OpenFileMode (FILE_MODE_NORMAL); 
    
    OpenFile (nFileHandle, SRCDIR, "PureScripts.txt"); 
	
	while (GetLine (nFileHandle, svLine) = 0) 
        ListAddString (lstFiles, svLine, AFTER); 
    endwhile; 
    
    CloseFile (nFileHandle); 

    nRes = ListGetFirstString(lstFiles, sFileName);
	while (nRes != END_OF_LIST)
		//Add Path To File Name
		sFileName = svDir ^ sFileName;
		//MessageBox(sFileName,INFORMATION);
		
		if( !REMOVEONLY ) then
			bSuccess = ExecuteSQLScriptPure(sFileName);
		endif;
		
		if (bSuccess = FALSE) then
			
		endif;
		
		//Next entry
		nRes = ListGetNextString(lstFiles, sFileName);
	endwhile;
	
	SdShowMsg ( "Executing Pure DTU scripts . . . please wait." , FALSE );
	
	ListDestroy (lstFiles); 
	
	return 0;

	

end;


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  RunStagingScript  	                                                         //
//				                                                                     //
// Purpose:   This function 
//                                                                                   //
///////////////////////////////////////////////////////////////////////////////////////
function RunStagingScript()
LIST lstFiles;
	NUMBER nRes,nBuffer;
	STRING sFileName, szExecutionError;
	BOOL bSuccess;
	STRING svFileName,svFileNameForList,svDir;

begin
	
	SdShowMsg ( "Executing Staging scripts . . . please wait." , TRUE );
	WriteToLogFile(INSTALL_LOG, "Runing Staging scripts...");
	lstFiles = ListCreate (STRINGLIST);
	svDir= SRCDIR ^ "Scripts\\Staging";
	
	if (StrLengthChars(svDir) > 0) then
		if (FindAllFiles(svDir, "*.sql", svFileName, RESET) = 0) then
			ParsePath(svFileNameForList, svFileName,FILENAME); 
			if (ListFindString(lstFiles, svFileNameForList) > 0) then
					ListAddString(lstFiles, svFileNameForList, AFTER);
			endif;
			
			while (FindAllFiles(svDir, "*.sql", svFileName, CONTINUE) = 0)
				ParsePath(svFileNameForList, svFileName,FILENAME); 
				if (ListFindString(lstFiles, svFileNameForList) > 0) then
					ListAddString(lstFiles, svFileNameForList, AFTER);
				endif;
			endwhile;
		endif;
	endif;
	
	FindAllFiles(svDir, "*.sql", svFileName, CANCEL);
	
	nRes = ListGetFirstString(lstFiles, sFileName);
	while (nRes != END_OF_LIST)
		//Add Path To File Name
		sFileName = svDir ^ sFileName;
		
		if( !REMOVEONLY ) then
			bSuccess = ExecuteSQLScriptStaging(sFileName);
		endif;
		
		if (bSuccess = FALSE) then
			
		endif;
		
		//Next entry
		nRes = ListGetNextString(lstFiles, sFileName);
	endwhile;
	
	SdShowMsg ( "Executing Staging scripts . . . please wait." , FALSE );
	
	return 0;

		
	
end;


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  RunStagingStructureScript  	                                                         //
//				                                                                     //
// Purpose:   This function 
//                                                                                   //
///////////////////////////////////////////////////////////////////////////////////////
function RunStagingStructureScript()
LIST lstFiles;
	NUMBER nRes,nBuffer;
	STRING sFileName, szExecutionError;
	BOOL bSuccess;
	STRING svFileName,svFileNameForList,svDir;

begin
	
	SdShowMsg ( "Executing Staging structure scripts . . . please wait." , TRUE );
	WriteToLogFile(INSTALL_LOG, "Runing Staging scripts...");
	svDir= SRCDIR ^ "Scripts\\Structure";
	
	sFileName = svDir ^ "Structure.sql";
		
	if( !REMOVEONLY ) then
			bSuccess = ExecuteSQLScriptStaging(sFileName);
	endif;
	
	SdShowMsg ( "Executing Staging structure scripts . . . please wait." , FALSE );
	
	return 0;

		
	
end;


///////////////////////////////////////////////////////////////////////////////
//
//	Function: ExecuteSQLScript
//
//	Purpose: This function will execute a SQL script.
//
// 	Arguments: 	svScriptFile - A fully qualified path to a SQL script file
//			svErrLog - Reference to a string which will contain teh log of errors occured during the execution of SQL script file
//
//	Usage: 
//	ExecuteSQLScript("C:\Scripts\tables.sql", svLog)
//
//	Notes:		You could change this function to accept the script as a string
//			instead of the file.  With a file, you can add the scripts
//			as files in the installation, putting them in a directory.
//			This would allow them to be reused later, or they can just be
//			deleted after each script is run.
//
///////////////////////////////////////////////////////////////////////////////     
function BOOL ExecuteSQLScriptPure(svScriptFile)
	OBJECT pADOObj, pADOCommObj;
	STRING szADOObjID, szADOCommObjID;
	STRING svLine, szConnString, szSQL, svString;
	STRING szHead, szTail;
	NUMBER nResult, nRecords, nBegin, nEnd;
	BOOL   bExitLoop;
	LIST   listID;
	LIST   listCmd;
	number nRet;
	string szErrorLog;
begin
	//LogErrorMessage("Entering to execute file " + svScriptFile, "ExecuteSQLScript", FALSE);
	szErrorLog = "";
	nRet = 0;
	 // Create an empty string list.
	listID = ListCreate(STRINGLIST);
	listCmd = ListCreate(STRINGLIST);
	
	// Read the SQL script file into the list
	if (ListReadFromFile(listID, svScriptFile) < 0) then // read list from file
		//svErrLog = "Unable to open SQL script: " + svScriptFile + ".";
		return FALSE;
	endif;
	
	// Go through each list item and add it to a string (which will then hold the script)
	szSQL = "";
	nResult = ListGetFirstString(listID, svString);
	while (nResult = 0)
		if (StrFind(svString, "GO") = 0) then
			// Remove comments
			bExitLoop = FALSE;
			repeat
				nBegin = StrFind(szSQL, "/*");
				nEnd = StrFind(szSQL, "*/");
				if ((nBegin >= 0) && (nBegin < nEnd)) then
					StrSub(szHead, szSQL, 0, nBegin);
					StrSub(szTail, szSQL, nEnd+2, 65535);
					szSQL = szHead + szTail;
				else
					bExitLoop = TRUE;
				endif;
			until (bExitLoop);
			// Add it to commands
			if (StrLengthChars(szSQL) > 0) then
				ListAddString(listCmd, szSQL, AFTER);
			endif;
			szSQL = "";
		elseif (StrFind(svString, "--") = 0) then
			// It is a comment, so do nothing
		else
			szSQL = szSQL + "\r\n" + svString; 
		endif;
		nResult = ListGetNextString(listID, svString);		
	endwhile;
	
	// Add it to commands
	if (StrLengthChars(szSQL) > 0) then
		ListAddString(listCmd, szSQL, AFTER);
	endif;
	
	//szSQL = "";
	
	DatabaseExecutePure(listCmd,svScriptFile);
	
	// Be good and clean up your trash
	ListDestroy(listID);
	
	// Be good and clean up your trash
	ListDestroy(listCmd);
	
	
end;

///////////////////////////////////////////////////////////////////////////////
//
//	Function: ExecuteSQLScript
//
//	Purpose: This function will execute a SQL script.
//
// 	Arguments: 	svScriptFile - A fully qualified path to a SQL script file
//			svErrLog - Reference to a string which will contain teh log of errors occured during the execution of SQL script file
//
//	Usage: 
//	ExecuteSQLScript("C:\Scripts\tables.sql", svLog)
//
//	Notes:		You could change this function to accept the script as a string
//			instead of the file.  With a file, you can add the scripts
//			as files in the installation, putting them in a directory.
//			This would allow them to be reused later, or they can just be
//			deleted after each script is run.
//
///////////////////////////////////////////////////////////////////////////////     
function BOOL ExecuteSQLScriptStaging(svScriptFile)
	OBJECT pADOObj, pADOCommObj;
	STRING szADOObjID, szADOCommObjID;
	STRING svLine, szConnString, szSQL, svString;
	STRING szHead, szTail;
	NUMBER nResult, nRecords, nBegin, nEnd;
	BOOL   bExitLoop;
	LIST   listID;
	LIST   listCmd;
	number nRet;
	string szErrorLog;
begin
	//LogErrorMessage("Entering to execute file " + svScriptFile, "ExecuteSQLScript", FALSE);
	szErrorLog = "";
	nRet = 0;
	 // Create an empty string list.
	listID = ListCreate(STRINGLIST);
	listCmd = ListCreate(STRINGLIST);
	
	// Read the SQL script file into the list
	if (ListReadFromFile(listID, svScriptFile) < 0) then // read list from file
		//svErrLog = "Unable to open SQL script: " + svScriptFile + ".";
		return FALSE;
	endif;
	
	// Go through each list item and add it to a string (which will then hold the script)
	szSQL = "";
	nResult = ListGetFirstString(listID, svString);
	while (nResult = 0)
		if (StrFind(svString, "GO") = 0) then
			// Remove comments
			bExitLoop = FALSE;
			repeat
				nBegin = StrFind(szSQL, "/*");
				nEnd = StrFind(szSQL, "*/");
				if ((nBegin >= 0) && (nBegin < nEnd)) then
					StrSub(szHead, szSQL, 0, nBegin);
					StrSub(szTail, szSQL, nEnd+2, 65535);
					szSQL = szHead + szTail;
				else
					bExitLoop = TRUE;
				endif;
			until (bExitLoop);
			// Add it to commands
			if (StrLengthChars(szSQL) > 0) then
				ListAddString(listCmd, szSQL, AFTER);
			endif;
			szSQL = "";
		elseif (StrFind(svString, "--") = 0) then
			// It is a comment, so do nothing
		else
			szSQL = szSQL + "\r\n" + svString; 
		endif;
		nResult = ListGetNextString(listID, svString);		
	endwhile;
	
	// Add it to commands
	if (StrLengthChars(szSQL) > 0) then
		ListAddString(listCmd, szSQL, AFTER);
	endif;
	
	//szSQL = "";
	
	DatabaseExecuteStaging(listCmd,svScriptFile);
	
	// Be good and clean up your trash
	ListDestroy(listID);
	
	// Be good and clean up your trash
	ListDestroy(listCmd);
	
	
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  DatabaseExecute                                        		 //
//                                                                           //
// Purpose:   This function takes as input the SQL file or Script for        //
//			  Execution along with the executable statements of the file     //
//			  in a list object and executes it on Sirius DB                  //
///////////////////////////////////////////////////////////////////////////////            
            
function number DatabaseExecutePure(listCmdText,szSQLFile)
string szConnString,szADOObjID,szString,szADOCommObjID; 
object objADO,objADOComm;  
number nvRet,nvResult,nvRecords,nvErrorHandlerValue;
string szErrorLog,szInfoLog,szTitle; 
BOOL bCatchFlag;
BOOL bErrorCondition;
HWND hMSI; 
NUMBER nLocation;

begin
  
    bCatchFlag = FALSE;
    //To Check if any error condition happened in the SQL file
    bErrorCondition = FALSE;
    // Create ADO Connection Object to connect to the SQL server	               
	szADOObjID = "ADODB.Connection";
	try
		set objADO = CreateObject(szADOObjID);	
		objADO.ConnectionTimeout = 0;
		
		//MessageBox(szSQLFile,INFORMATION);
		
		//nLocation = StrFind (szSQLFile, "Pure"); 
		
		//if(nLocation < 0) then
			//szConnString = GetConnectionString(gPureDB);
			//szConnString = GetConnectionStringStaging(gStagingDB);
		//else
		szConnString = GetConnectionString(gPureDB);
		
		//endif;
		
		//MessageBox(szConnString,INFORMATION);
		
		// Open the ADO Connection 
		objADO.Open(szConnString);
	catch      
		SdShowMsg("SQL File Connection Object Error",FALSE);
		WriteToLogFile(INSTALL_ERROR_LOG,"Connection Object Error While Executing "+szSQLFile+".Continuing with next script");  
        objADO.Close();              
		set objADO = NOTHING;                 
		return 1;
	endcatch;                         
		  
	// Execute each command
	nvResult = ListGetFirstString(listCmdText, szString);
	while (nvResult = 0)
		
		// Create the ADO Command object to execute the script                           	
		try		
			szADOCommObjID = "ADODB.Command";
			set objADOComm = CreateObject(szADOCommObjID);  
			objADOComm.CommandTimeout = 600;
			objADOComm.ActiveConnection = objADO;  
		catch    
			SdShowMsg("SQL File Command Object Error",FALSE);
			WriteToLogFile(INSTALL_ERROR_LOG,"Command Object Error While Executing "+szSQLFile+".Continuing with next script");  	      
		    objADO.Close();              
			set objADO = NOTHING;                 
			return 1;  
		endcatch;
	 
		try    
		 	 	// Execute the call to run the script
		 	   	objADOComm.CommandText = szString;
				objADOComm.Execute();
		catch
				nvRet = Err.Number;
				szErrorLog = "Error:  " + Err.Description + "\n"
					+ "Source: " + Err.Source + "\n\n";
					
			szErrorLog = "Error Occured in the File "+szSQLFile+" in Database Execute Method "+szErrorLog;		
			bCatchFlag = TRUE;
		endcatch;
		
		if(bCatchFlag = TRUE) then 
			SdShowMsg("SQL File Error",FALSE);
		    szTitle = "Database Execution Error Handler"; 
			nvErrorHandlerValue = SprintfBox (MB_ABORTRETRYIGNORE,szTitle,szErrorLog); 
		    if(nvErrorHandlerValue = IDRETRY) then
		    	  ParseSQLFilePure(szSQLFile);
		    elseif(nvErrorHandlerValue = IDABORT) then
		    	  objADO.Close();              
		    	  set objADO = NOTHING;
		    	  WriteToLogFile(INSTALL_ERROR_LOG,szErrorLog);
		    	  bErrorCondition = TRUE;
		    	  szErrorLog = "";
		      	  abort;
		    else// IGNORE condition Execution
		      	  WriteToLogFile(INSTALL_ERROR_LOG,szErrorLog);
		      	  bErrorCondition = TRUE;
		      	  szErrorLog = "";
		    endif;    
		    bCatchFlag = FALSE;
		endif;                   
	
		set objADOComm = NOTHING;	
		nvResult = ListGetNextString(listCmdText,szString);		
	endwhile; 
 
	objADO.Close();              
	set objADO = NOTHING; 
	
	if(bErrorCondition = FALSE) then                   
		szInfoLog = szSQLFile + " SQL File Executed Successfully";
		WriteToLogFile(INSTALL_LOG,szInfoLog);
		g_nvSQLFileSuccessCount =  g_nvSQLFileSuccessCount + 1;
	else
		bErrorCondition = FALSE;	
		g_nvSQLFileErrorCount = g_nvSQLFileErrorCount + 1;
	endif;
 	// Be good and clean up your trash
	ListDestroy(listCmdText);     
	SdShowMsg("SQL File Executed",FALSE);
	
    return 1;
 end;           
 
 
 ///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  DatabaseExecute                                        		 //
//                                                                           //
// Purpose:   This function takes as input the SQL file or Script for        //
//			  Execution along with the executable statements of the file     //
//			  in a list object and executes it on Sirius DB                  //
///////////////////////////////////////////////////////////////////////////////            
            
function number DatabaseExecuteStaging(listCmdText,szSQLFile)
string szConnString,szADOObjID,szString,szADOCommObjID; 
object objADO,objADOComm;  
number nvRet,nvResult,nvRecords,nvErrorHandlerValue;
string szErrorLog,szInfoLog,szTitle; 
BOOL bCatchFlag;
BOOL bErrorCondition;
HWND hMSI; 
NUMBER nLocation;

begin
  
    bCatchFlag = FALSE;
    //To Check if any error condition happened in the SQL file
    bErrorCondition = FALSE;
    // Create ADO Connection Object to connect to the SQL server	               
	szADOObjID = "ADODB.Connection";
	try
		set objADO = CreateObject(szADOObjID);	
		objADO.ConnectionTimeout = 0;
		
		//MessageBox(szSQLFile,INFORMATION);
		
		//nLocation = StrFind (szSQLFile, "Pure"); 
		
		//if(nLocation < 0) then
			//szConnString = GetConnectionString(gPureDB);
		szConnString = GetConnectionStringStaging(gStagingDB);
		//else
		//	szConnString = GetConnectionString(gPureDB);
		//endif;
		
		//MessageBox(szConnString,INFORMATION);
		
		// Open the ADO Connection 
		objADO.Open(szConnString);
	catch      
		SdShowMsg("SQL File Connection Object Error",FALSE);
		WriteToLogFile(INSTALL_ERROR_LOG,"Connection Object Error While Executing "+szSQLFile+".Continuing with next script");  
        objADO.Close();              
		set objADO = NOTHING;                 
		return 1;
	endcatch;                         
		  
	// Execute each command
	nvResult = ListGetFirstString(listCmdText, szString);
	while (nvResult = 0)
		
		// Create the ADO Command object to execute the script                           	
		try		
			szADOCommObjID = "ADODB.Command";
			set objADOComm = CreateObject(szADOCommObjID);  
			objADOComm.CommandTimeout = 600;
			objADOComm.ActiveConnection = objADO;  
		catch    
			SdShowMsg("SQL File Command Object Error",FALSE);
			WriteToLogFile(INSTALL_ERROR_LOG,"Command Object Error While Executing "+szSQLFile+".Continuing with next script");  	      
		    objADO.Close();              
			set objADO = NOTHING;                 
			return 1;  
		endcatch;
	 
		try    
		 	 	// Execute the call to run the script
		 	   	objADOComm.CommandText = szString;
				objADOComm.Execute();
		catch
				nvRet = Err.Number;
				szErrorLog = "Error:  " + Err.Description + "\n"
					+ "Source: " + Err.Source + "\n\n";
					
			szErrorLog = "Error Occured in the File "+szSQLFile+" in Database Execute Method "+szErrorLog;		
			bCatchFlag = TRUE;
		endcatch;
		
		if(bCatchFlag = TRUE) then 
			SdShowMsg("SQL File Error",FALSE);
		    szTitle = "Database Execution Error Handler"; 
			nvErrorHandlerValue = SprintfBox (MB_ABORTRETRYIGNORE,szTitle,szErrorLog); 
		    if(nvErrorHandlerValue = IDRETRY) then
		    	  ParseSQLFileStaging(szSQLFile);
		    elseif(nvErrorHandlerValue = IDABORT) then
		    	  objADO.Close();              
		    	  set objADO = NOTHING;
		    	  WriteToLogFile(INSTALL_ERROR_LOG,szErrorLog);
		    	  bErrorCondition = TRUE;
		    	  szErrorLog = "";
		      	  abort;
		    else// IGNORE condition Execution
		      	  WriteToLogFile(INSTALL_ERROR_LOG,szErrorLog);
		      	  bErrorCondition = TRUE;
		      	  szErrorLog = "";
		    endif;    
		    bCatchFlag = FALSE;
		endif;                   
	
		set objADOComm = NOTHING;	
		nvResult = ListGetNextString(listCmdText,szString);		
	endwhile; 
 
	objADO.Close();              
	set objADO = NOTHING; 
	
	if(bErrorCondition = FALSE) then                   
		szInfoLog = szSQLFile + " SQL File Executed Successfully";
		WriteToLogFile(INSTALL_LOG,szInfoLog);
		g_nvSQLFileSuccessCount =  g_nvSQLFileSuccessCount + 1;
	else
		bErrorCondition = FALSE;	
		g_nvSQLFileErrorCount = g_nvSQLFileErrorCount + 1;
	endif;
 	// Be good and clean up your trash
	ListDestroy(listCmdText);     
	SdShowMsg("SQL File Executed",FALSE);
	
    return 1;
 end;           
            
///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function: GetConnectionString                                         	 //
//                                                                           //
// Purpose:  This function gets the Connection string for the 				 //
//			 Sirius Database for execution of Sirius DB SQL Scripts          //
///////////////////////////////////////////////////////////////////////////////

function string GetConnectionString(szDatabaseName)
string szConnString,szDriver;

begin 
	szDriver = "SQL Server";

	if(bPureDBWinLogin = FALSE) then
		// Create the connection string for SQL Server Authentication
		szConnString = "driver={" + szDriver + "};";
		szConnString = szConnString + "server=" + gPureDBServer + ";";	
		szConnString = szConnString + "uid=" + gPureDBUser + ";";    	
		szConnString = szConnString + "pwd=" + gPureDBPassword + ";";  
		szConnString = szConnString + "database=" + szDatabaseName;
	else
		// Create the connection string for Windows Authentication
		szConnString = "driver={" + szDriver + "};";
		szConnString = szConnString + "server=" + gPureDBServer + ";";	
		szConnString = szConnString + "database=" + szDatabaseName + ";";
		szConnString = szConnString + "Trusted_Connection=Yes";
	endif;


return szConnString;
end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function: GetConnectionString                                         	 //
//                                                                           //
// Purpose:  This function gets the Connection string for the 				 //
//			 Sirius Database for execution of Sirius DB SQL Scripts          //
///////////////////////////////////////////////////////////////////////////////

function string GetConnectionStringStaging(szDatabaseName)
string szConnString,szDriver;

begin 
	
	szDriver = "SQL Server";

	if(bStagingDBWinLogin = FALSE) then
		// Create the connection string for SQL Server Authentication
		szConnString = "driver={" + szDriver + "};";
		szConnString = szConnString + "server=" + gStagingDBServer + ";";	
		szConnString = szConnString + "uid=" + gStagingDBUser + ";";    	
		szConnString = szConnString + "pwd=" + gStagingDBPassword + ";";  
		szConnString = szConnString + "database=" + szDatabaseName;
	else
		// Create the connection string for Windows Authentication
		szConnString = "driver={" + szDriver + "};";
		szConnString = szConnString + "server=" + gStagingDBServer + ";";	
		szConnString = szConnString + "database=" + szDatabaseName + ";";
		szConnString = szConnString + "Trusted_Connection=Yes";
	endif;


return szConnString;
end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ParseSQLFile                                        		     //
//                                                                           //
// Purpose:   This function takes as input the SQL File for Script execution //
//			  and parses out the executable statements into a list object    //
//			  and removes out comments                                       //
///////////////////////////////////////////////////////////////////////////////
function number ParseSQLFilePure(szSQLFile)
	string  szSQL,szString;
	number nvResult,nvRet;
	LIST   listID;
	string szErrorLog,szSQLFilePath;
	int nvSrcDirLength,nvFullPathLength; 
	HWND hMSI;    
	number nvCommentStart;
	number nvGoStartPosition;
	string szTrimmedString; 
	number nvBegin,nvEnd;  
	
begin     
	szErrorLog = "";
	nvRet = 0;
	 // Create an empty string list.
	listID = ListCreate(STRINGLIST);
	g_listCmdText = ListCreate(STRINGLIST);
	if(g_bPatchInstallation = FALSE) then
		//Truncating the Full Disk Path to Specify the Exact Script Folder Path
		nvSrcDirLength = StrLengthChars(SUPPORTDIR); 
		nvFullPathLength = StrLengthChars(szSQLFile); 
    	StrSub(szSQLFilePath,szSQLFile,nvSrcDirLength,nvFullPathLength -nvSrcDirLength);
    	SdShowMsg("Executing SQL File: " + szSQLFilePath,TRUE);
    else
    	//Truncation not required in case of Patch Installation
    	SdShowMsg("Executing SQL File: " + szSQLFile,TRUE); 
    endif;
	// Read the SQL script file into the list
	if (ListReadFromFile(listID, szSQLFile) < 0) then // read list from file
		//WriteToLogFile(DATABASE_ERRORLOG,"Unable to open SQL script: " + szSQLFile);
		return -1;
	endif;
	// Go through each list item and add it to a string (which will then hold the script)
	szSQL = ""; 
	try
		nvResult = ListGetFirstString(listID, szString);
	while (nvResult = 0)
	//If Comment Tag("--") Comes at the start of the line ignore to proceed to the next line
		if(StrFind(szString,"--")=0) then
		     	// It is a comment, so do nothing and proceed to the next line
		else    
				//If Comment Tag("--") Comes after some Text extract the text before the comments tag("--")                                    
		    	if(StrFind(szString,"--")>0) then
			    	nvCommentStart = StrFind(szString,"--");
			    	nvBegin = StrFind(szString,"/*"); 
					nvEnd = StrFind(szString,"*/");
					if(nvBegin >= 0 && nvBegin < nvCommentStart) then
					   //Add to the SQL Statement String till a "GO" Delimiter Statement is found
					   //It is done at the End of Else Part of IF Statement
			    	elseif(nvEnd >= 0 && nvCommentStart < nvEnd) then
			    		//Add to the SQL Statement String till a "GO" Delimiter Statement is found
			    		//It is done at the End of Else Part of IF Statement
			    	else
			    		//Else remove the Text after the Comments Tags("--") and proceed forward
			    	   	StrSub(szString,szString,0,nvCommentStart);
			    	endif;
			    endif;
			    nvGoStartPosition = StrFind(szString,"GO");  
			    if(nvGoStartPosition = 0) then 
			    	szTrimmedString = TrimEnd(szString," ");
			     	szTrimmedString = TrimEnd(szTrimmedString,"\t");
			     	szTrimmedString = TrimEnd(szTrimmedString," "); 
			     	szTrimmedString = TrimEnd(szTrimmedString,"\t");
			     	if(StrLengthChars(szTrimmedString)=2) then
			     		AddCommandTextToList(szSQL);  
			     		szSQL = "";
			     	endif;
			    elseif(nvGoStartPosition > 0) then
			        szTrimmedString = TrimStart(szString," ");
			        szTrimmedString = TrimStart(szTrimmedString,"\t");
			        szTrimmedString = TrimStart(szTrimmedString," ");
			        szTrimmedString = TrimStart(szTrimmedString,"\t");
			        if(StrFind(szTrimmedString,"GO")=0) then
				        szTrimmedString = TrimEnd(szTrimmedString," ");
				        szTrimmedString = TrimEnd(szTrimmedString,"\t");
				        szTrimmedString = TrimEnd(szTrimmedString," ");
				        szTrimmedString = TrimEnd(szTrimmedString,"\t");
			            if(StrLengthChars(szTrimmedString)=2) then
			            	AddCommandTextToList(szSQL);
			            	szSQL = "";
			       	    else
			        		//Add to the SQL Statement String till a "GO" Delimiter Statement is found
			    			szSQL = szSQL + "\r\n" + szString;    	    	
			            endif;
			        else
			     		//Add to the SQL Statement String till a "GO" Delimiter Statement is found
			    		szSQL = szSQL + "\r\n" + szString;    	
			        endif;
			    else 	
			    	//Add to the SQL Statement String till a "GO" Delimiter Statement is found
			    	szSQL = szSQL + "\r\n" + szString; 
			    endif;  
		 endif;
		 //Read the Next line of the SQL file from the List into the String
		 nvResult = ListGetNextString(listID, szString);		
		 	//End of While Statement as all the content of the SQL file is read into the List
	endwhile;    
    catch
    		 MessageBox("Error Occured in the Script File"+szSQLFile,WARNING);
	endcatch;
	// Be good and clean up your trash
	ListDestroy(listID); 
	DatabaseExecutePure(g_listCmdText,szSQLFile);
	return 1;
end; 

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ParseSQLFile                                        		     //
//                                                                           //
// Purpose:   This function takes as input the SQL File for Script execution //
//			  and parses out the executable statements into a list object    //
//			  and removes out comments                                       //
///////////////////////////////////////////////////////////////////////////////
function number ParseSQLFileStaging(szSQLFile)
	string  szSQL,szString;
	number nvResult,nvRet;
	LIST   listID;
	string szErrorLog,szSQLFilePath;
	int nvSrcDirLength,nvFullPathLength; 
	HWND hMSI;    
	number nvCommentStart;
	number nvGoStartPosition;
	string szTrimmedString; 
	number nvBegin,nvEnd;  
	
begin     
	szErrorLog = "";
	nvRet = 0;
	 // Create an empty string list.
	listID = ListCreate(STRINGLIST);
	g_listCmdText = ListCreate(STRINGLIST);
	if(g_bPatchInstallation = FALSE) then
		//Truncating the Full Disk Path to Specify the Exact Script Folder Path
		nvSrcDirLength = StrLengthChars(SUPPORTDIR); 
		nvFullPathLength = StrLengthChars(szSQLFile); 
    	StrSub(szSQLFilePath,szSQLFile,nvSrcDirLength,nvFullPathLength -nvSrcDirLength);
    	SdShowMsg("Executing SQL File: " + szSQLFilePath,TRUE);
    else
    	//Truncation not required in case of Patch Installation
    	SdShowMsg("Executing SQL File: " + szSQLFile,TRUE); 
    endif;
	// Read the SQL script file into the list
	if (ListReadFromFile(listID, szSQLFile) < 0) then // read list from file
		//WriteToLogFile(DATABASE_ERRORLOG,"Unable to open SQL script: " + szSQLFile);
		return -1;
	endif;
	// Go through each list item and add it to a string (which will then hold the script)
	szSQL = ""; 
	try
		nvResult = ListGetFirstString(listID, szString);
	while (nvResult = 0)
	//If Comment Tag("--") Comes at the start of the line ignore to proceed to the next line
		if(StrFind(szString,"--")=0) then
		     	// It is a comment, so do nothing and proceed to the next line
		else    
				//If Comment Tag("--") Comes after some Text extract the text before the comments tag("--")                                    
		    	if(StrFind(szString,"--")>0) then
			    	nvCommentStart = StrFind(szString,"--");
			    	nvBegin = StrFind(szString,"/*"); 
					nvEnd = StrFind(szString,"*/");
					if(nvBegin >= 0 && nvBegin < nvCommentStart) then
					   //Add to the SQL Statement String till a "GO" Delimiter Statement is found
					   //It is done at the End of Else Part of IF Statement
			    	elseif(nvEnd >= 0 && nvCommentStart < nvEnd) then
			    		//Add to the SQL Statement String till a "GO" Delimiter Statement is found
			    		//It is done at the End of Else Part of IF Statement
			    	else
			    		//Else remove the Text after the Comments Tags("--") and proceed forward
			    	   	StrSub(szString,szString,0,nvCommentStart);
			    	endif;
			    endif;
			    nvGoStartPosition = StrFind(szString,"GO");  
			    if(nvGoStartPosition = 0) then 
			    	szTrimmedString = TrimEnd(szString," ");
			     	szTrimmedString = TrimEnd(szTrimmedString,"\t");
			     	szTrimmedString = TrimEnd(szTrimmedString," "); 
			     	szTrimmedString = TrimEnd(szTrimmedString,"\t");
			     	if(StrLengthChars(szTrimmedString)=2) then
			     		AddCommandTextToList(szSQL);  
			     		szSQL = "";
			     	endif;
			    elseif(nvGoStartPosition > 0) then
			        szTrimmedString = TrimStart(szString," ");
			        szTrimmedString = TrimStart(szTrimmedString,"\t");
			        szTrimmedString = TrimStart(szTrimmedString," ");
			        szTrimmedString = TrimStart(szTrimmedString,"\t");
			        if(StrFind(szTrimmedString,"GO")=0) then
				        szTrimmedString = TrimEnd(szTrimmedString," ");
				        szTrimmedString = TrimEnd(szTrimmedString,"\t");
				        szTrimmedString = TrimEnd(szTrimmedString," ");
				        szTrimmedString = TrimEnd(szTrimmedString,"\t");
			            if(StrLengthChars(szTrimmedString)=2) then
			            	AddCommandTextToList(szSQL);
			            	szSQL = "";
			       	    else
			        		//Add to the SQL Statement String till a "GO" Delimiter Statement is found
			    			szSQL = szSQL + "\r\n" + szString;    	    	
			            endif;
			        else
			     		//Add to the SQL Statement String till a "GO" Delimiter Statement is found
			    		szSQL = szSQL + "\r\n" + szString;    	
			        endif;
			    else 	
			    	//Add to the SQL Statement String till a "GO" Delimiter Statement is found
			    	szSQL = szSQL + "\r\n" + szString; 
			    endif;  
		 endif;
		 //Read the Next line of the SQL file from the List into the String
		 nvResult = ListGetNextString(listID, szString);		
		 	//End of While Statement as all the content of the SQL file is read into the List
	endwhile;    
    catch
    		 MessageBox("Error Occured in the Script File"+szSQLFile,WARNING);
	endcatch;
	// Be good and clean up your trash
	ListDestroy(listID); 
	DatabaseExecuteStaging(g_listCmdText,szSQLFile);
	return 1;
end; 


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  AddCommandTextToList                                           //
//                                                                           //
// Purpose:  This function would take the executable SQL text as its input   //
//			 and parses the script to remove the multi line comments         //
//			 existing in the script	                                         //
///////////////////////////////////////////////////////////////////////////////

function number AddCommandTextToList(szSQLText)
BOOL bExitLoop,bBeginCommentFlag,bEndCommentFlag; 
number nvBegin,nvEnd; 
number nvTextLength;
string szHead,szTail;
begin     

bExitLoop = FALSE;              
bBeginCommentFlag = FALSE;  
bEndCommentFlag = FALSE;
//Looping through the SQLText for any multiline comments(/* & */)
repeat  
	//Get the Total length of the String
	nvTextLength = StrLengthChars(szSQLText);
	nvBegin = StrFind(szSQLText, "/*"); 
	if(nvBegin >= 0) then
	  bBeginCommentFlag = TRUE;
	endif;          
	
	nvEnd = StrFind(szSQLText, "*/");
	if(nvEnd > nvBegin) then
	  bEndCommentFlag = TRUE;
	endif;  
	
	if(bBeginCommentFlag = TRUE &&  bEndCommentFlag =TRUE) then
		if ((nvBegin >= 0) && (nvBegin < nvEnd)) then
			StrSub(szHead, szSQLText, 0, nvBegin);
			StrSub(szTail, szSQLText,nvEnd+2,nvTextLength);
			szSQLText = szHead + szTail;
		else
			bExitLoop = TRUE;
		endif;
	else				
	      bExitLoop = TRUE; 
	endif;
			
until (bExitLoop);
// Add the commandtext to the List Variable 
if((bBeginCommentFlag = TRUE &&  bEndCommentFlag =TRUE) ||(bBeginCommentFlag = FALSE &&  bEndCommentFlag =FALSE)) then
	if (StrLengthChars(szSQLText) > 0) then
		ListAddString(g_listCmdText, szSQLText, AFTER);
	endif;
		szSQLText = "";
endif;  

return 1;
end;


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  TrimEnd                                         				 //
//                                                                           //
// Purpose:   This function is used to trim the end of any string text for   //
//			  blank spaces(white spaces) and tab spaces and returns the      //
//			  trimmed string                                                 //
///////////////////////////////////////////////////////////////////////////////  

function string TrimEnd(szString,szTrim)
string szReturn;
number ivStartIndex; 
number ivTrimLength; 
number ivStringLength;
begin 
szReturn = szString; 
ivTrimLength = StrLength(szTrim);
ivStringLength = StrLength(szReturn);
ivStartIndex = ivStringLength - ivTrimLength; 

while(StrFindEx(szReturn,szTrim, ivStartIndex) > 0)
StrReplace(szReturn, szTrim,"",ivStartIndex);
ivStartIndex = StrLength(szReturn) - ivTrimLength;
endwhile;  

return szReturn;
end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  TrimStart                                        				 //
//                                                                           //
// Purpose:   This function is used to trim the start of any string text for //
//			  blank spaces(white spaces) and tab spaces and returns the      //
//			  trimmed string                                                 //
///////////////////////////////////////////////////////////////////////////////  

function string TrimStart(szString,szTrim)
string szReturn;
begin   
szReturn = szString; 
while(StrFind(szReturn,szTrim) = 0)
StrSub(szReturn, szReturn, StrLength(szTrim), StrLength(szReturn));
endwhile;  

return szReturn;
end;   


////////////////////////////////////////////////////////////////////////
//                                                                    //
// Function:  WriteToLogFile                                          //
//                                                                    //
// Purpose:   This function takes as input the Text File name         //
//			  and the  Log Message and writes that message to         //
//			  the Text File                                           //
////////////////////////////////////////////////////////////////////////

function number WriteToLogFile(szFileName,szLogString)
string  szSeperator,szLogFilePath, svResult; 
number  nvFileHandle; 
begin   
szLogFilePath = WINDISK + "\\";  

if (FindFile(szLogFilePath, szFileName, svResult ) < 0) then
     CreateLogFile(szFileName);
endif;    

OpenFileMode (FILE_MODE_APPEND); 
szSeperator = "************************************************************************************************************";
// Create a new file and leave it open. 
if (OpenFile(nvFileHandle,szLogFilePath,szFileName) < 0) then 
     // Report the error. 
       MessageBox (szFileName+ " file cannot be opened",SEVERE); 
       abort; 
else    
     // Append the message to the file. 
     if (WriteLine(nvFileHandle,szLogString) < 0) then 
    	// Report the error. 
	   	MessageBox ("WriteLine failed for "+szFileName,SEVERE); 
	  endif;
	  if(WriteLine(nvFileHandle,szSeperator) < 0) then 
	     // Report the error. 
	  	 MessageBox ("WriteLine failed for "+szFileName,SEVERE); 
	  endif;  
endif;
// Close the file. 
CloseFile (nvFileHandle); 
	
return 1;
end;  

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  CreateLogFile                                                  //
//                                                                           //
// Purpose:   This function takes a text filename as an input parameter      //
//			  and it creates a Installation Normal/Error Logs Uninstallation //
//			  Normal/Error Logs Database Normal/Error Logs                   //
///////////////////////////////////////////////////////////////////////////////

function number CreateLogFile(szFileName)
number nvResult,nvFileHandle; 
string szPath;
begin         
szPath = WINDISK + "\\";
OpenFileMode(FILE_MODE_APPEND); 


nvResult = CreateFile(nvFileHandle,szPath,szFileName); 
if(nvResult < 0) then
	MessageBox("Log File "+szFileName +" Cannot be Created",INFORMATION);
endif;

return 1;
end;        


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  PureDatabaseDetails                                                  //
//                                                                           //
// Purpose:   This function takes a text filename as an input parameter      //
//			  and it creates a Installation Normal/Error Logs Uninstallation //
//			  Normal/Error Logs Database Normal/Error Logs                   //
///////////////////////////////////////////////////////////////////////////////

function number PureDatabaseDetails()
number nResult, nErrorCode, nErrorLine;
number nCount;
string szConnection;
string szServer, szDB, szUser, szPassword;
string szMessage;
string szKey;
LIST   listConnections;
BOOL   bWinLogin;
BOOL   bNext;
NUMBER nvErrorCode;
STRING svTechnology;
NUMBER nBtn;
begin

    //First initialize SQL Server runtime
    SQLRTInitialize2( );

    //Get the names of all the necessary connections
    listConnections = SQLRTGetConnections();
    ListGetFirstString (listConnections, szConnection);

    nCount = 0;

    //determine if NEXT or BACK will be returned 
    //if there are no connections to make
    if( nBtn != BACK ) then
        bNext = TRUE;
    else
        bNext = FALSE;
		//start at end if going BACK
		while (ISERR_SUCCESS = ListGetNextString( listConnections, szConnection ) );
			nCount++;
		endwhile;
    endif;

    // Login for each connection
    while (nResult = ISERR_SUCCESS)

        //Get Default values for connection
        SQLRTGetConnectionInfo( szConnection, szServer, szDB, szUser, szPassword );
        bPureDBWinLogin = SQLRTGetConnectionAuthentication( szConnection );
        bPureDBWinLogin = FALSE;
        
        szServer= gPureDBServer; 
        szDB=gPureDB;
        
         
		Dlg_SQLConnection1:
	    
				nResult= SQLServerSelectLogin2( szConnection, szServer,szUser,szPassword, bPureDBWinLogin, szDB, FALSE, TRUE );
				//g_bWinLoginAuthenticate = bWinLogin;
	       
				if(szDB="")then
						MessageBox("Database catalog name is empty, Please specify which database catalog should be used for connection.\n\n" +
								   "Click the Browse button to select database catalog or database name available on the database server.",WARNING);
						goto  Dlg_SQLConnection1;
						
				endif;
				
		if( nResult = NEXT ) then
			 //store data in case we need it again
            SQLRTPutConnectionInfo2( szConnection, szServer, szDB, szUser, szPassword );

	        SQLRTPutConnectionAuthentication( szConnection, bPureDBWinLogin );

            //try connection
            nResult = SQLRTConnect( szConnection, szServer, bPureDBWinLogin, szUser, szPassword );
            	
			if( nResult < ISERR_SUCCESS && MODE != SILENTMODE ) then

                SQLRTGetLastError2( nvErrorCode, szMessage, svTechnology, szConnection, szServer, szDB ); 
			    MessageBox( szMessage, MB_OK );

                //Show same login dialog again
                nResult = ListCurrentString(listConnections, szConnection);
			
            else //SUCCESS
                   //Move on to next connection
	                nCount++;
	                bNext = TRUE;
	                nResult = ListGetNextString(listConnections, szConnection);
	                gPureDBServer =  szServer;
	                gPureDB = szDB;
	                
	                if(bPureDBWinLogin = FALSE) then
	                		gPureDBUser =  szUser;
							gPureDBPassword =  szPassword;
					endif;
	                
			 endif;			
            
         else
            //BACK
            nCount--;
            bNext = FALSE;
            nResult = ListSetIndex( listConnections, nCount );
            ListCurrentString( listConnections, szConnection );

        endif;

    endwhile;

    if( bNext ) then
        return NEXT;
    else
        return BACK;
    endif;

end;

