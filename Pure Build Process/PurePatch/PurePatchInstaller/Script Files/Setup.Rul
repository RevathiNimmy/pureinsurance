///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  GetPatchVersionFromTextFile                                    //
//                                                                           //
// Purpose:   This function is used to get the Patch Version from the        //
//			  name of the text file available along with the Patch Package   //
//			  delivered											             //
///////////////////////////////////////////////////////////////////////////////

function number GetPatchVersionFromTextFile()
number nvResult;  
string szPatchFileName;
number nvPatchFileExtnLocation;
STRING szInstallerTitle1;
begin

	WriteToLogFile(INSTALL_LOG,"Reading Installer.ini");
	szPatchFileName= SRCDIR ^ "Installer.ini";

	GetProfString (szPatchFileName, "General", "InstallerTitle1", gszInstallerTitle1); 
	GetProfString (szPatchFileName, "General", "PatchVersion", g_szPatchVersion);
	GetProfString (szPatchFileName, "General", "PureCompatibleVersion", g_PureCompatibleVersion); 
	
	return 0;
  
end;

////////////////////////////////////////////////////////////////////////
//                                                                    //
// Function:  CheckPrerequisites                                            //
//                                                                    //
// Purpose:                                                           //
////////////////////////////////////////////////////////////////////////
function CheckPrerequisites()
begin
	
	//Check Pure build version
	//[HKEY_LOCAL_MACHINE\SOFTWARE\Wow6432Node\Pure\PureInstallation\Setup]
	//"New Version"="300.000.0015"
		
	//Compare PureCompatibleVersion in Installer.ini with the New version in the registry
	
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
	g_PureInstalledVersion = GetFromRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","New Version");
	
	if(g_PureInstalledVersion=g_PureCompatibleVersion)then
		 WriteToLogFile(INSTALL_LOG,"Pure version " + g_PureCompatibleVersion + " is  installed in the system");
	else
		 MessageBox("Pure Insurance version " + g_PureCompatibleVersion + " is not installed in the system, Pure Insurance patch cannot be Installed.", SEVERE);
		 abort;
	endif;
	
	//g_PureCompatibleVersion 
	return 0;
end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  ValidateUserCredentials  	                                             //
//				                                                                     //
// Purpose:   This function varifies the username/password entered on account        //
//            information dialog                                                     //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////

function BOOL ValidateUserCredentials()
STRING szCommand,szProgram,szDomain;
STRING szSspLogonLog,szPath;
STRING svReturnLine,svTemp;
NUMBER nvLineNumber,nvResult;

begin
	
	szPath = WINDISK + "\\";
	szDomain = g_szHostName;
	
	szProgram = SUPPORTDIR ^ "ssplogon.exe";
	szSspLogonLog = szPath ^ "ssplogon.log";
	
	szCommand = "/C " + szProgram + " " + szDomain + " " + g_szWebservicesUser + " " + g_szWebservicesPassword + " > " + szSspLogonLog;
	
	nvResult = LaunchAppAndWait("CMD.EXE",szCommand, WAIT);
	Delay(1);
	
	SetFileInfo(szSspLogonLog, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
	Delay(1);
	
	// Find the search string in the log file.
	nvResult = FileGrep( szSspLogonLog, "Succeeded", svReturnLine, nvLineNumber, RESTART);
	
	/*while (nvResult != END_OF_FILE) 
		nvResult = FileGrep (szSspLogonLog, "Succeeded", svReturnLine, nvLineNumber, CONTINUE);
	endwhile; 
	*/	
	
		
	if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Logon failed for user=" + g_szWebservicesUser);
      DeleteFile(szSspLogonLog);
      return FALSE;
    else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"Logon Succeeded for user=" + g_szWebservicesUser);
   	  DeleteFile(szSspLogonLog);
   	  return TRUE;
	endif;
		
	
end;

