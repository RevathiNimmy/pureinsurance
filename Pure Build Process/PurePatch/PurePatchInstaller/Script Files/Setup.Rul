////////////////////////////////////////////////////////////////////////
//                                                                    //
// Function:  CopyApplication                                            //
//                                                                    //
// Purpose:                                                           //
////////////////////////////////////////////////////////////////////////
function CopyApplication()
STRING szSource,szTarget;

begin
	
	szSource=SRCDIR ^ "Application" ^ "*.*";
	szTarget=TARGETDIR ^ "Application";
	
	if (XCopyFile (szSource, szTarget,INCLUDE_SUBDIR | COMP_NORMAL) < 0) then 
        MessageBox ("Application: XCopyFile failed", SEVERE); 
    else 
        WriteToLogFile(INSTALL_LOG,"Application files copied successfully."); 
    endif; 


	
	return 0;
end;

