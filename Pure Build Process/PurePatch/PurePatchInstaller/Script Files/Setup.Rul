// Purpose:   This function read WCFSecurityTokenFile.txt                        //
//
///////////////////////////////////////////////////////////////////////////////

function ReadWCFSecurityTokenFile()
STRING szDir,szFile;
number  nvFileHandle,nvResult; 
begin   
	
	szDir = TARGETDIR ^ PURE_APPLICATION_FOLDER;
	
	szFile = "WCFSecurityTokenFile.txt";
	
	// Set the file mode to normal. 
    OpenFileMode (FILE_MODE_NORMAL); 
    
    // Open the text file. 
    if (OpenFile (nvFileHandle, szDir, szFile) < 0) then 
        MessageBox ("OpenFile failed.", SEVERE); 
    else
    	nvResult = GetLine(nvFileHandle,g_szWCFSecuirtyToken);
      
    endif; 
    
    CloseFile(nvFileHandle);
	
return 0;

end; 

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  ReadPureConfigFiles  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for PureWCFservices         //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function ReadPureConfigFiles()
STRING  szFileName,szTargetFile, szTargetPath, szAddKey,szPath;
NUMBER	nResult,i,nvResult;  
OBJECT  oDoc, oNodeList,oNode;
STRING	szProgram,szCommand,szCommand1,szPermission;
begin
	
	SdShowMsg ( "Updating config files . . . please wait." , TRUE );
	szFileName = SRCDIR ^ "PureConfigFiles.xml";
    
    WriteToLogFile(INSTALL_LOG,"PureConfigFiles path=" + szFileName); 
    
	if Is(FILE_EXISTS, szFileName) = TRUE then
       //
    else
        MessageBox ( "Can't find PureConfigFiles.xml", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("ConfigFile");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                try
                    g_PureConfigFileName = oNode.attributes.getNamedItem("FileName").value;
                    g_PureConfigFolderName = oNode.attributes.getNamedItem("FolderName").value;
                    
                    if(g_WCFServices=TRUE) then
						if(g_PureConfigFolderName="SiriusFS.SAM.WCFService")then
								UpdatePureConfigFiles(g_PureConfigFileName,g_PureConfigFolderName);
						endif;
					endif;
					
					if(g_bAppServerOnly=TRUE) then
						if(g_PureConfigFileName="iPMUserMaintenance.exe.config")then
								if(g_PureConfigFolderName="Application")then
									UpdatePMUserMaintenanceConfigFile(g_PureConfigFileName,g_PureConfigFolderName);
								endif;
						else
								if(g_PureConfigFolderName="Application")then
									UpdatePureConfigFiles(g_PureConfigFileName,g_PureConfigFolderName);
								endif;
    					endif;
					endif;
                catch
                    //szAddKey = "";
                endcatch;
              endfor; 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   
    else
        MessageBox(ERROR_XML_FILE_LOAD,SEVERE);                         
        return -1;
    endif;
   
    set oDoc = NOTHING;
    
	SdShowMsg ( "Updating config files . . . please wait." , FALSE );
    return 0;
end; 


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  UpdatePureConfigFiles  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for PureWCFservices         //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function UpdatePureConfigFiles(g_PureConfigFileName,g_PureConfigFolderName)
STRING  szFileName,szTargetFile, szTargetPath, szAddKey,szPath;
NUMBER	nResult,i,nvResult;  
OBJECT  oDoc, oNodeList,oNode;
STRING	szProgram,szCommand,szCommand1,szPermission;
begin
	
	
	SdShowMsg ( "Updating config files . . . please wait." , TRUE );
	
	if(g_WCFServices=TRUE) then
		if(g_PureConfigFolderName="SiriusFS.SAM.WCFService")then
	
			szTargetPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "_PublishedWebsites" ^ g_PureConfigFolderName;
    
		endif;
	endif;
	
    if(g_bAppServerOnly=TRUE) then
		if(g_PureConfigFolderName="Application")then
	
			szTargetPath = TARGETDIR ^ PURE_APPLICATION_FOLDER;
    
		endif;
	endif;
    
    szFileName = szTargetPath ^ g_PureConfigFileName;
    
    LongPathToQuote ( szTargetPath, TRUE );
	//LongPathToQuote ( szFileName, TRUE );
	// icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
   	szCommand=	szTargetPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
   	
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	//LongPathToQuote ( szFileName, TRUE );
	WriteToLogFile(INSTALL_LOG,"web.config path=" + szFileName); 
	if Is(FILE_EXISTS, szFileName) = TRUE then
       //
    else
        MessageBox ( "Can't find web.config", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	 // Set the read-only flag OFF
	SetFileInfo ( szTargetFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("*");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                try
                    szAddKey = oNode.attributes.getNamedItem("key").value;
                catch
                    szAddKey = "";
                endcatch;
                
                try
                    if szAddKey = "WCFSecuirtyToken" then
                        oNode.attributes.getNamedItem("value").value = g_szWCFSecuirtyToken;
                        WriteToLogFile(INSTALL_LOG,"Updating web.config, WCFSecuirtyToken=" + g_szWCFSecuirtyToken); 
                    endif;
                    
                catch
                endcatch;
             endfor; 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   
    else
        MessageBox(ERROR_XML_FILE_LOAD,SEVERE);                         
        return -1;
    endif;
    oDoc.save(szFileName);
    set oDoc = NOTHING;
    
	SdShowMsg ( "Updating config files . . . please wait." , FALSE );
    return 0;
end; 


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  UpdatePMUserMaintenanceConfigFile  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for PureWCFservices         //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function UpdatePMUserMaintenanceConfigFile(g_PureConfigFileName,g_PureConfigFolderName)
STRING  szFileName,szTargetFile, szTargetPath, szAddKey,szPath;
NUMBER	nResult,i,nvResult;  
OBJECT  oDoc, oNodeList,oNode,oWCFSecuirtyTokenValueNode;
STRING	szProgram,szCommand,szCommand1,szPermission;
STRING strNodeName;
STRING WCFSecuirtyTokenValueNode;
begin
	
	
	SdShowMsg ( "Updating config files . . . please wait." , TRUE );
	
	if(g_WCFServices=TRUE) then
		if(g_PureConfigFolderName="SiriusFS.SAM.WCFService")then
	
			szTargetPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "_PublishedWebsites" ^ g_PureConfigFolderName;
    
		endif;
	endif;
	
    if(g_bAppServerOnly=TRUE) then
		if(g_PureConfigFolderName="Application")then
	
			szTargetPath = TARGETDIR ^ PURE_APPLICATION_FOLDER;
    
		endif;
	endif;
    
    szFileName = szTargetPath ^ g_PureConfigFileName;
    
    LongPathToQuote ( szTargetPath, TRUE );
	//LongPathToQuote ( szFileName, TRUE );
	// icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
   	szCommand=	szTargetPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
   	
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	//LongPathToQuote ( szFileName, TRUE );
	WriteToLogFile(INSTALL_LOG,"web.config path=" + szFileName); 
	if Is(FILE_EXISTS, szFileName) = TRUE then
       //
    else
        MessageBox ( "Can't find web.config", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	 // Set the read-only flag OFF
	SetFileInfo ( szTargetFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("*");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                try
					strNodeName= oNode.nodeName;
					if(strNodeName= "setting")then
							szAddKey = oNode.attributes.getNamedItem("name").value;
							if szAddKey = "WCFSecuirtyToken" then
								oNode.firstChild.text=g_szWCFSecuirtyToken;
								WriteToLogFile(INSTALL_LOG,"Updating web.config, WCFSecuirtyToken=" + g_szWCFSecuirtyToken); 
							endif;
					endif;
                catch
                    szAddKey = "";
                endcatch;
                
             endfor; 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   
    else
        MessageBox(ERROR_XML_FILE_LOAD,SEVERE);                         
        return -1;
    endif;
    oDoc.save(szFileName);
    set oDoc = NOTHING;
    
	SdShowMsg ( "Updating config files . . . please wait." , FALSE );
    return 0;
end; 


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  PurePortalDatabaseDetails                                                  //
//                                                                           //
// Purpose:   This function takes a text filename as an input parameter      //
//			  and it creates a Installation Normal/Error Logs Uninstallation //
//			  Normal/Error Logs Database Normal/Error Logs                   //
///////////////////////////////////////////////////////////////////////////////

function number PurePortalDatabaseDetails()
number nResult, nErrorCode, nErrorLine;
number nCount;
string szConnection;
string szServer, szDB, szUser, szPassword;
string szMessage;
string szKey;
LIST   listConnections;
BOOL   bWinLogin;
BOOL   bNext;
NUMBER nvErrorCode;
STRING svTechnology;
NUMBER nBtn;
begin

    //First initialize SQL Server runtime
    SQLRTInitialize2( );

    //Get the names of all the necessary connections
    listConnections = SQLRTGetConnections();
    ListGetFirstString (listConnections, szConnection);

    nCount = 0;

    //determine if NEXT or BACK will be returned 
    //if there are no connections to make
    if( nBtn != BACK ) then
        bNext = TRUE;
    else
        bNext = FALSE;
		//start at end if going BACK
		while (ISERR_SUCCESS = ListGetNextString( listConnections, szConnection ) );
			nCount++;
		endwhile;
    endif;

    // Login for each connection
    while (nResult = ISERR_SUCCESS)

        //Get Default values for connection
        SQLRTGetConnectionInfo( szConnection, szServer, szDB, szUser, szPassword );
        bPurePortalDBWinLogin = SQLRTGetConnectionAuthentication( szConnection );
        bPurePortalDBWinLogin = FALSE;
       
       /* 
        if(g_bCreatePurePortalDatabase = TRUE) then
	    	szDB = "master";
	    endif;  
	   */ 
	    
	   //During Upgrade assign Portal server
	   //if (g_PortalExists=TRUE ) then
		szServer   = g_PortalDBServer; 
		szDB = g_PortaDB;
	   //endif;
	    
        Dlg_SQLConnection1:
	    
				nResult= SdSQLServerSelectLogin3( szConnection, szServer,szUser,szPassword, bPurePortalDBWinLogin, szDB, FALSE, FALSE );
				
				/*
				if(szDB="")then
						MessageBox("Database catalog name is empty, Please specify which database catalog should be used for connection.\n\n" +
								   "Click the Browse button to select database catalog or database name available on the database server.",WARNING);
						goto  Dlg_SQLConnection1;
						
				endif;
				*/
				
		if( nResult = NEXT ) then
			 //store data in case we need it again
            SQLRTPutConnectionInfo2( szConnection, szServer, szDB, szUser, szPassword );

	        SQLRTPutConnectionAuthentication( szConnection, bPurePortalDBWinLogin );

            //try connection
            nResult = SQLRTConnect( szConnection, szServer, bPurePortalDBWinLogin, szUser, szPassword );
            	
			if( nResult < ISERR_SUCCESS && MODE != SILENTMODE ) then

                SQLRTGetLastError2( nvErrorCode, szMessage, svTechnology, szConnection, szServer, szDB ); 
			    MessageBox( szMessage, MB_OK );

                //Show same login dialog again
                nResult = ListCurrentString(listConnections, szConnection);
			
            else //SUCCESS
                   //Move on to next connection
	                nCount++;
	                bNext = TRUE;
	                nResult = ListGetNextString(listConnections, szConnection);
	                g_PortalDBServer =  szServer;
	                g_PortaDB = szDB;
	                
	                if(bPurePortalDBWinLogin = FALSE) then
	                		g_PortalUser =  szUser;
							g_PortalPwd =  szPassword;
					endif;
	                
			 endif;			
            
         else
            //BACK
            nCount--;
            bNext = FALSE;
            nResult = ListSetIndex( listConnections, nCount );
            ListCurrentString( listConnections, szConnection );

        endif;

    endwhile;

    if( bNext ) then
        return NEXT;
    else
        return BACK;
    endif;

end;


