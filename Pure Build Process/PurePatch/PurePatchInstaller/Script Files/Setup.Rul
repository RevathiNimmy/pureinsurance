///////////////////////////////////////////////////////////////////////////////////////                                                                                   //
// Function:  StopPureService  	                                                     //
//				                                                                     //
// Purpose:   This function checks the status of Pure windows service                //
//            Pure windows service and stop it if it is running                      //
///////////////////////////////////////////////////////////////////////////////////////
function StopPureService()
number nvServiceState;
begin
		
	ServiceGetServiceState('PureWindowsService', nvServiceState);
    //check the state of the NT service
    if ( nvServiceState != SERVICE_STOPPED ) then
			SdShowMsg ( "Stopping SSP Pure Windows Service . . . please wait." , TRUE );
       	    ServiceStopService ( 'PureWindowsService' ); 
       	    Delay(15);
       	    SdShowMsg ( "Stopping SSP Pure Windows Service . . . please wait." , FALSE );
	endif;
       
end;

