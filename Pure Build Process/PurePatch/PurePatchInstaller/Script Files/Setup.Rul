//---------------------------------------------------------------------------
// OnBegin
//
// The OnBegin event is called directly by the framework after the setup
// initializes. Note that this event will be called AFTER "Initialization"
// events (i.e.) OnSetTARGETDIR, OnCheckMediaPassword.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnBegin()
begin
     
     if( REMOVEONLY = 0) then
		
		CreateLogFile(INSTALL_LOG);       
	 	CreateLogFile(INSTALL_ERRORLOG); 
	 	CreateLogFile(DATABASE_LOG);       
	 	CreateLogFile(DATABASE_ERRORLOG); 
     
		//Setting the type of Installation as Patch Installation to FALSE
		g_bPatchInstallation = FALSE;
	
		
		// Get the hostname of the machine.
 		GetEnvVar("COMPUTERNAME",g_szHostName); 
 		GetEnvVar("USERNAME",g_szUserName); 
 		//MessageBox(g_szUserName,INFORMATION);
 		
 		GetEnvVar ("TEMP", gTemp); 
      
 	
 		//Initializing the Count Variable 
 		g_nvSQLFileSuccessTotalCount = 0;
 		g_nvSQLFileErrorTotalCount  = 0;
  	
	
 		//Initializing the Sirius Database Name and MDF/LDF Path
 		g_szSiriusDBName = "";                                  
 
 		//Initializing the Windows Authentication Mechanism Flag to False for SQL Server Authentication
 		g_szWindowsAuthenticate = "";                                                                  
 		
 		//Validate whether the logged in user of the system is an administrator user
		//Installation prerequisite
		ValidateLoggedinUser();
		
		GetPMRegistryInstalledValuesforUpgradeInstall();
		
	              
	endif;
	
end;

//---------------------------------------------------------------------------                                                                        
// OnFirstUIBefore
//
// First Install UI Sequence - Before Move Data
//
// The OnFirstUIBefore event is called by OnShowUI when the setup is
// running in first install mode. By default this event displays UI allowing
// the end user to specify installation parameters.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnFirstUIBefore()
    number  nResult, nLevel, nSize, nSetupType;
    string  szTitle, szMsg, szOpt1, szOpt2, szLicenseFile;
    string  szName, szCompany, szTargetPath, szDir, szFeatures;
    NUMBER nvResult;
    STRING szUser,szPassword;
    STRING szQuestion;
    number nvDefault,nvAskButtonRetValue;  
begin	

    // Added in InstallShield 15 - Show an appropriate error message if
    // -removeonly is specified and the product is not installed.
    if( REMOVEONLY ) then
        Disable( DIALOGCACHE );
		szMsg = SdLoadString( IDS_IFX_ERROR_PRODUCT_NOT_INSTALLED_UNINST );
   		SdSubstituteProductInfo( szMsg );
		MessageBox( szMsg, SEVERE );
		abort;
    endif;
   
    nSetupType = COMPLETE;	
    szDir = TARGETDIR;
    szName = "";
    szCompany = "";
    
    //Get the Patch Name or Patch Version from the Text File available in the folder along with Update.exe
	GetPatchVersionFromTextFile();
	
	CheckPrerequisites();
	
	IsPurePortalInstalled();

// Beginning of UI Sequence
Dlg_Start:
    nResult = 0;
    
  

Dlg_SdWelcome:
		g_bAppServerOnly = TRUE;
		//g_bAppServerWithDB = TRUE;
		g_bWebServices = FALSE;
		g_bPortal = FALSE;
		g_WCFServices=TRUE;
		//This Dialog is used to show the Welcome Screen indicating the Start of Upgrade Installation
	    szTitle = "SSP Pure Insurance Patch Installation";  
	    szMsg   = "Welcome to the Installation of Pure Insurance version " + gszInstallerTitle1 + "" ;
		Disable(BACKBUTTON);    
	    nvResult = SdWelcome(szTitle,szMsg);  
	    
	    if ((ExistsDir (SRCDIR ^ "Portal") != EXISTS) || IsPortalInstalled=FALSE) then
				g_bPortal = FALSE;
		else
				g_bPortal = TRUE;
				GetPortalFileName();
				if(gPortalFileName="")then
					g_bPortal = FALSE;
				else
					g_bPortal = TRUE;
				endif;
		endif;
	    
Dlg_AskInstallationType:

	szTitle    = "SSP Pure Insurance Patch Installation Type";
    szMsg      = "This specifies the type of patch you require";   
    
        
	if(g_bPortal=FALSE) then
	        nvResult    = AskOptions(NONEXCLUSIVE,'Select the required Pure Patch Installation Type .',"Back Office",g_bAppServerOnly,"Pure WCF Services",g_WCFServices); 
	    
	endif;
	    
	if(g_bPortal=TRUE) then
			nvResult    = AskOptions(NONEXCLUSIVE,'Select the required Pure Patch Installation Type.',"Back Office",g_bAppServerOnly,"Pure WCF Services",g_WCFServices,"Pure Portal", g_bPortal); 
				
	endif;
		
	
	if(nvResult = BACK) then 
		goto Dlg_SdWelcome; 
	endif;
	
	FeatureSelectItem (MEDIA, "BackOffice", TRUE);


Dlg_UserInformation:

if(g_bWebServices=TRUE || g_WCFServices=TRUE || g_bPortal=TRUE) then
	  
	  g_szAppPoolPortal="PurePortalAppPool";
	  g_szApplicationPortal="Pure.Portal";
	  g_szPhysicalPathPortal=IISROOTFOLDER ^ g_PortalFolderName;
	  g_szWebServiceUrl="http://" + g_szHostName + "/PureWebServices/SAMForInsuranceV2.asmx";
	  g_szDocumentsLocation=TARGETDIR ^ "DocZipTemp";
	  g_szReportsLocation=TARGETDIR ^ "Reports";
	  g_szTempFileLocation=TARGETDIR ^ "DocZipTemp";
	
	 szTitle = "";
	 szMsg   = "Specify the User and Password for configuring Web Services and setting permissions on Pure Application folders. Make sure user is a member of the IIS_IUSRS group on the Web server so that the account can access the appropriate resources.";  
	 szUser="User:";
	 szPassword="Password:";
		 
	 nvResult=SdShowDlgEdit2 ( szTitle, szMsg, szUser, szPassword, g_szWebservicesUser,g_szWebservicesPassword); 
	 
	 if(nvResult = BACK) then 
		goto Dlg_AskInstallationType; 
	 endif;    
	 
	 if(g_szWebservicesUser="")then
		       MessageBox("Username cannot be empty, Please specify a valid user.",INFORMATION);
		       goto Dlg_UserInformation;
	 endif;
		 
	 if(g_szWebservicesPassword="")then
	    	  MessageBox("Password cannot be empty, Please specify a valid password.",INFORMATION);
		      goto Dlg_UserInformation;
	 endif;	 
	 
	 /*
	 if (ValidateUserCredentials() = FALSE) then
				MessageBox("Login failed, please provide the Username and Password correctly.\n\n",INFORMATION);
				goto Dlg_UserInformation;
	 endif;
	 */
	 
	 //TextSubSetValue("<APPPOOLUSERID>", g_szWebservicesUser, TRUE);
	 //TextSubSetValue("<APPPOOLPASSWORD>", g_szWebservicesPassword, TRUE);
	 
	 //MsiSetProperty( ISMSI_HANDLE, "APPPOOLUSERID", g_szWebservicesUser );
	 //MsiSetProperty( ISMSI_HANDLE, "APPPOOLPASSWORD", g_szWebservicesPassword ); 
endif;
	 	
Dlg_PortalDetails:
	if(g_bPortal=TRUE) then
		GetPortalFileName();
		GetPortalRegistry();
			
		g_szPhysicalPathPortal=IISROOTFOLDER ^ g_PortalFolderName;
		//MessageBox(g_szPhysicalPathPortal,INFORMATION);
		LongPathToQuote(g_szPhysicalPathPortal,FALSE);
		
		if(nvResult = BACK) then
					goto Dlg_UserInformation;
		endif; 
	endif;
	
Dlg_PortalConfigPath:
	if(g_bPortal=TRUE) then
		/*if(g_PortalExists=FALSE)then
				nvResult = SdPortalConfigPath();
		endif;
		*/
		if(nvResult = BACK) then
					goto Dlg_PortalDetails;
		endif; 
		
		CopyPortalFiles();
	endif;
	
	
	
Dlg_TestConnectDBforUpgradeInstall:	
	  
	  if(g_bAppServerOnly=TRUE ) then
	  
		nvResult=OnSQLServerInitialize(NEXT);
	  
	  endif;
	  
	  if(nvResult = BACK) then
					goto Dlg_UserInformation;
	  endif;
	  
	  if(g_bAppServerOnly=TRUE ) then 
		Disable( DIALOGCACHE );
		StartUpgradeDBScriptsExecution(SRCDIR ^ "Scripts");
		Enable( DIALOGCACHE );
	  endif;
	  
	  //Update Portal database
	 if(g_bPortal=TRUE) then
			// Ask SQL Server Connection details
			//nvResult = SdSQLConnectionPortal();	
			nvResult = PurePortalDatabaseDetails();	
			
			//Update Tbl_Portal table
			//AddEditTbl_Portal();
			
			
		    // Create Portal registry
		    Disable( DIALOGCACHE );
			CreatePortalRegistry();
			Enable( DIALOGCACHE );
			
			szQuestion= "Do you want to copy existing web.config file to new Pure Portal location?\n\n" +
						"Click YES to 'copy existing web.config file' or Click NO to 'copy new web.config file'.";
			nvDefault = YES;
			
			nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
			if(nvAskButtonRetValue = YES) then
					g_szWebFileName=g_OLDWebConfigPath ^ "web.config";
					CopyOLDWebConfig();
					MessageBox("Please update the portal web.config file manually after Installation, please refer to release notes for the details.",INFORMATION);
			else
				   
				   //Update Portal web config
					UpdatePortalWebConfig();
			endif;
	 endif;
	 

Dlg_SdStartCopy2:
    
    szTitle = "";
    szMsg = "";
    
    
    nResult = SdStartCopy2( szTitle, szMsg );	
    
   
    if (nResult = BACK) goto Dlg_TestConnectDBforUpgradeInstall;
    
    szMsg = "Installing Pure Insurance Version "+gszInstallerTitle1+""; 
    SetStatusExStaticText(szMsg);
    
    // setup default status
    Enable(STATUSEX);
    
    //Main function to run all the steps for Patch Installation
    InstallPatch();
    
    return 0;
end;

