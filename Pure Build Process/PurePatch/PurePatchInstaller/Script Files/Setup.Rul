// Purpose:   This function                                                  //
///////////////////////////////////////////////////////////////////////////////
function IsPurePortalInstalled()
STRING szKey;
NUMBER nSize,nType;
begin

	nSize= -1;
    nType= REGDB_STRING;
	szKey="SOFTWARE\\Pure\\PureInstallation\\Portal";
	
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    if(RegDBKeyExist(szKey)=1) then
		IsPortalInstalled=TRUE;
    else
		IsPortalInstalled=FALSE;
    endif;
	

end;


///////////////////////////////////////////////////////////////////////////
//                                                                       //
// Function:  RegisterbPMPAFWrapper                                     //
//                                                                       //
//  Purpose:  This function regsiters the .Net assembly bPMPAFWrapper   //
//            for COM interoperability.                                  //
//                                                                       //
///////////////////////////////////////////////////////////////////////////
function number RegisterbPMPAFWrapper()   
string svResult, svPath, szOfficeDir, szWordTARGETDIR, szDocTemplateDll, svMessage, szDocTemplateDllPath;	
LIST listDocTemplateDlls;
number nvResult, nvCopyResult;
STRING svcmd1,svcmd2;
begin
   if ( FindAllFiles ( WINDIR ^ "Microsoft.NET" ^ "Framework", "regasm.exe", svResult, RESET ) == 0 ) then
		svPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "bPMPAFWrapper.dll";
		
		// Stick some quotes around the path
		if (LongPathToQuote(svPath,TRUE) != 0) then
			MessageBox ("Unable to convert path to quoted path.\n" + svPath, SEVERE );		
			WriteToLogFile(INSTALL_ERRORLOG,"Unable to convert path to quoted path.\n" + svPath + ".");
			return -1;
		else   
			svcmd1 = svPath + " /codebase /tlb";
			nvResult = LaunchAppAndWait ( svResult, svcmd1, LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
			if ( nvResult < 0) then
				WriteToLogFile(INSTALL_ERRORLOG, "Unable to launch " + svcmd1 + ".");
				return -1; 
			else
				WriteToLogFile(INSTALL_LOG, "Successfully executed the command " + svcmd1 + " to register bPMPAFWrapper.dll.");
			endif;
			
			svcmd2 = svPath + " /codebase /regfile";
			nvResult = LaunchAppAndWait ( svResult, svcmd2, LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
			if ( nvResult < 0) then
				WriteToLogFile(INSTALL_ERRORLOG, "Unable to launch " + svcmd2 + ".");
				return -1; 
			else
				WriteToLogFile(INSTALL_LOG, "Successfully executed the command " + svcmd2 + " to register bPMPAFWrapper.dll.");
			endif;
			
		endif;    
	endif;
	
	return 0;
end;   


