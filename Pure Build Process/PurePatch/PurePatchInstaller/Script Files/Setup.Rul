//                                                                           //
// Function:  CreateLogFile                                                  //
//                                                                           //
// Purpose:   This function takes a text filename as an input parameter      //
//			  and it creates a Installation Normal/Error Logs Uninstallation //
//			  Normal/Error Logs Database Normal/Error Logs                   //
///////////////////////////////////////////////////////////////////////////////

function number CreateLogFile(szFileName)
number nvResult,nvFileHandle; 
string szPath;
begin         
szPath = WINDISK + "\\";
OpenFileMode(FILE_MODE_APPEND); 


nvResult = CreateFile(nvFileHandle,szPath,szFileName); 
if(nvResult < 0) then
	MessageBox("Log File "+szFileName +" Cannot be Created",INFORMATION);
endif;

return 1;
end;          

////////////////////////////////////////////////////////////////////////
//                                                                    //
// Function:  WriteToLogFile                                          //
//                                                                    //
// Purpose:   This function takes as input the Text File name         //
//			  and the  Log Message and writes that message to         //
//			  the Text File                                           //
////////////////////////////////////////////////////////////////////////

function number WriteToLogFile(szFileName,szLogString)
string  szSeperator,szLogFilePath, svResult; 
number  nvFileHandle; 
begin   
szLogFilePath = WINDISK + "\\";  

if (FindFile(szLogFilePath, szFileName, svResult ) < 0) then
     CreateLogFile(szFileName);
endif;    

OpenFileMode (FILE_MODE_APPEND); 
szSeperator = "************************************************************************************************************";
// Create a new file and leave it open. 
if (OpenFile(nvFileHandle,szLogFilePath,szFileName) < 0) then 
     // Report the error. 
       MessageBox (szFileName+ " file cannot be opened",SEVERE); 
       abort; 
else    
     // Append the message to the file. 
     if (WriteLine(nvFileHandle,szLogString) < 0) then 
    	// Report the error. 
	   	MessageBox ("WriteLine failed for "+szFileName,SEVERE); 
	  endif;
	  if(WriteLine(nvFileHandle,szSeperator) < 0) then 
	     // Report the error. 
	  	 MessageBox ("WriteLine failed for "+szFileName,SEVERE); 
	  endif;  
endif;
// Close the file. 
CloseFile (nvFileHandle); 
	
return 1;
end;  

////////////////////////////////////////////////////////////////////////
//                                                                    //
// Function:  InstallPatch                                            //
//                                                                    //
// Purpose:                                                           //
////////////////////////////////////////////////////////////////////////
function InstallPatch()
STRING szFileName;
begin

	
	// Install Back Office
	if(g_bAppServerOnly=TRUE || g_bWebServices=TRUE || g_WCFServices=TRUE) then
		InstallBackOffice();
		
	endif;
		
	// Install PureWebservices
	if(g_bWebServices=TRUE) then
		InstallPureWebservices();
	endif;
	
	// Install PureWebservices
	if(g_WCFServices=TRUE) then
		InstallPureWCFservices();
	endif;
		
	// Install Pure database
	//InstallDatabase();
	if(g_bPortal=TRUE) then
		InstallPortal();
	endif;
	
	RegisterbPMPAFWrapper();
	
	if(g_bAppServerOnly=TRUE || g_WCFServices=TRUE) then
		
		szFileName = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "WCFSecurityTokenFile.txt";
	
		if Is(FILE_EXISTS, szFileName) = TRUE then
			ReadWCFSecurityTokenFile();
		else
			RunGenerateWCFTokenID();
		
			ReadWCFSecurityTokenFile();
		endif;
	
		ReadPureConfigFiles();
		
	endif;
		
	// Update Patch Installation registry
	UpdatePatchInstallationHistory();
	
end;

////////////////////////////////////////////////////////////////////////
//                                                                    //
// Function:  InstallBackOffice                                            //
//                                                                    //
// Purpose:                                                           //
////////////////////////////////////////////////////////////////////////
function InstallBackOffice()
STRING szCommand,szProgram;
NUMBER nvResult;
LIST lAppInUse;
NUMBER nResult;
begin
	
	// STop Pure windows service
	StopPureService();
	
	Disable(STATUSEX);
    // Check for file in use during uninstall
	while(CheckApplicationInUse(lAppInUse) == TRUE)
				//nResult = SdRMFilesInUse( "", "", "", lAppInUse,FALSE);
				nResult = SdFilesInUse("", "", "", lAppInUse);
				if (nResult == IDCANCEL) then
					if (IDYES = SprintfBox(MB_YESNO|MB_ICONEXCLAMATION|MB_DEFBUTTON2, 
											SdLoadString(SD_STR_ONCANCELING_TITLE), 
											SdLoadString(SD_STR_ONCANCELING_MSG))) then
                       
						EndCurrentDialog();
						Enable(USE_LOADED_SKIN);
						abort;
					endif;	
				
				endif;
	endwhile;
    
    Enable(STATUSEX);
    SetStatusWindow (0, ""); 
    StatusUpdate (ON, 99); 
	
	
	CopyApplication();
	
	if (ExistsDir (SRCDIR ^ "Lists") = EXISTS) then 
			CopyLists();
	endif;
	
	if (ExistsDir (SRCDIR ^ "Lookups") = EXISTS) then 
		CopyLookups();
	endif;
	
	if (ExistsDir (SRCDIR ^ "NavigatorXM") = EXISTS) then 	
		CopyNavigatorXM();
	endif;
	
	if (ExistsDir (SRCDIR ^ "Reports") = EXISTS) then 
		CopyReports();
	endif;
	
	if (ExistsDir (SRCDIR ^ "Rules") = EXISTS) then 
		CopyRules();
	endif;
	
	if (ExistsDir (SRCDIR ^ "PMDocs") = EXISTS) then 
		CopyPMDocs();
	endif;
		
	// Run GISListCreator.exe
	//RunGISListCreator();
	
	DataModelRebuild();
	
	//Start the service 
	szProgram= WINSYSDIR ^ "sc.exe";
	szCommand="start PureWindowsService";
	
	nvResult = LaunchAppAndWait(szProgram,szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	Delay(15);
	
	
	return 0;
	
end;


