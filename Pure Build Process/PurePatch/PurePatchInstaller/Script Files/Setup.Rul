	LongPathToQuote ( szTargetFile, TRUE ); 
	WriteToLogFile(INSTALL_LOG,"Sourec file=" + szSourceFile + "Destination file=" +  szTargetFile);  
	Disable(LOGGING);	   
    nResult= CopyFile ( szSourceFile, szTargetFile);
    if(nResult <0)then
		WriteToLogFile(INSTALL_LOG,"Couldn't copy file " + szSourceFile);
	endif;
	Enable(LOGGING);
	*/    
    //pkzip25 -extr -dir=relative -over=all "Pure.Portals 2.03.12100.1.zip" "C:\inetpub\wwwroot"
	szAppParms = "-extr" + " -dir=relative -over=all " +
				 szPortalFile + " " + 
				 IISROOTFOLDER;
	ChangeDirectory(szPath);
	LaunchAppAndWait (szAppPath, szAppParms, WAIT);
	WriteToLogFile(INSTALL_LOG,"Copying and extracting Portal files" + szAppParms);
	return 0;
end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  GetPortalRegistry 	                                                 //
//				                                                                     //
// Purpose:   This function gets PortalRegsitry                                    //
///////////////////////////////////////////////////////////////////////////////////////
function GetPortalRegistry()
STRING szKey,szApplication,szPath,szAppPool,szWebServiceUrl,szDocumentsLocation,szReportsLocation,szTempFileLocation;
NUMBER nSize,nType;
STRING svApplicationPortal,svPhysicalPathPortal,svAppPoolPortal,svWebServiceUrl,svDocumentsLocation,svReportsLocation,svTempFileLocation;
STRING szAppLicationPortalKey;
STRING szPortalDBServer,szPortaDB,svPortalDBServer,svPortaDB;
STRING szPureAppServerName,svPureAppServerName;
STRING szPureSTSServerName,szThumbprint,szCertificateName,svPureSTSServerName,svThumbprint,svCertificateName;
begin 
    
    nSize= -1;
    nType= REGDB_STRING;
	szKey="SOFTWARE\\Pure\\PureInstallation\\Portal";
	//szAppLicationPortalKey = szKey ^ g_szApplicationPortal;
	szApplication="Application";
	szPath="Path";
	szAppPool="AppPool";
	//szWebServiceUrl="WebServiceUrl";
	szPureAppServerName="PureAppServerName";
	szDocumentsLocation="DocumentsLocation";
	szReportsLocation="ReportsLocation";
	szTempFileLocation="TempFileLocation";
	szPortalDBServer="DBServer";
	szPortaDB="DBName";
	
	
	szPureSTSServerName="PureSTSServerName";
	szThumbprint="thumbprint";
	szCertificateName="CertificateName";
	
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    if(RegDBKeyExist(szKey)=1) then
		g_PortalExists=TRUE;
		if(RegDBGetKeyValueEx (szKey, szApplication, nType, svApplicationPortal, nSize) <0 ) then
			g_PortalExists=FALSE;
		else
			g_szApplicationPortal=svApplicationPortal;
			WriteToLogFile(INSTALL_LOG,"Pure Portal Application=" + g_szApplicationPortal);
		endif;
		if(RegDBGetKeyValueEx (szKey, szPath, nType, svPhysicalPathPortal, nSize) <0 ) then
			g_PortalExists=FALSE;
		else
			g_szPhysicalPathPortal=svPhysicalPathPortal;
			g_OLDWebConfigPath=svPhysicalPathPortal;
			//WriteToLogFile(INSTALL_LOG,"Pure Portal Physical Path=" + g_szPhysicalPathPortal);
			WriteToLogFile(INSTALL_LOG,"Pure Portal existing Physical Path=" + g_OLDWebConfigPath);
		endif;
		if(RegDBGetKeyValueEx (szKey, szAppPool, nType, svAppPoolPortal, nSize) <0 ) then
			g_PortalExists=FALSE;
		else
			g_szAppPoolPortal=svAppPoolPortal;
			WriteToLogFile(INSTALL_LOG,"Pure Portal ApplicationPool=" + g_szAppPoolPortal);
		endif;
		
		/*
		if(RegDBGetKeyValueEx (szKey, szWebServiceUrl, nType, svWebServiceUrl, nSize)<0) then
			g_PortalExists=FALSE;
		else
			g_szWebServiceUrl=svWebServiceUrl;
			WriteToLogFile(INSTALL_LOG,"PureWebServices URL=" + g_szWebServiceUrl);
		endif;
		
		*/
		
				
		if(RegDBGetKeyValueEx (szKey, szPureAppServerName, nType, svPureAppServerName, nSize)<0) then
			g_PortalExists=FALSE;
		else
			g_szPureAppServerName=svPureAppServerName;
			WriteToLogFile(INSTALL_LOG,"Pure Application Server Name=" + g_szPureAppServerName);
		endif;
		
		
		if(RegDBGetKeyValueEx (szKey, szDocumentsLocation, nType, svDocumentsLocation, nSize) <0 ) then
			g_PortalExists=FALSE;
		else
			g_szDocumentsLocation=svDocumentsLocation;
			WriteToLogFile(INSTALL_LOG,"Documents Location=" + g_szDocumentsLocation);
		endif;
		
		if(RegDBGetKeyValueEx (szKey, szReportsLocation, nType, svReportsLocation, nSize) <0 )then
			g_PortalExists=FALSE;
		else
			g_szReportsLocation=svReportsLocation;
			WriteToLogFile(INSTALL_LOG,"Reports Location=" + g_szReportsLocation);
		endif;
		
		if(RegDBGetKeyValueEx (szKey, szTempFileLocation, nType, svTempFileLocation, nSize) <0) then
			g_PortalExists=FALSE;
		else
			g_szTempFileLocation=svTempFileLocation;
			WriteToLogFile(INSTALL_LOG,"Temp Location=" + g_szTempFileLocation);
		endif;
		
		if(RegDBGetKeyValueEx (szKey, szPortalDBServer, nType, svPortalDBServer, nSize) <0) then
			g_PortalExists=FALSE;
		else
			g_PortalDBServer=svPortalDBServer;
			WriteToLogFile(INSTALL_LOG,"DB Server=" + g_PortalDBServer);
		endif;
		
		if(RegDBGetKeyValueEx (szKey, szPortaDB, nType, svPortaDB, nSize) <0) then
			g_PortalExists=FALSE;
		else
			g_PortaDB=svPortaDB;
			WriteToLogFile(INSTALL_LOG,"DB Name=" + g_PortaDB);
		endif;
		
		if(RegDBGetKeyValueEx (szKey, szPureSTSServerName, nType, svPureSTSServerName, nSize) <0) then
			g_PortalExists=FALSE;
		else
			g_szSTSServer=svPureSTSServerName;
			WriteToLogFile(INSTALL_LOG,"STS Server name=" + g_szSTSServer);
		endif;
		
		if(RegDBGetKeyValueEx (szKey, szThumbprint, nType, svThumbprint, nSize) <0) then
			g_PortalExists=FALSE;
		else
			g_szThumbprint=svThumbprint;
			WriteToLogFile(INSTALL_LOG,"thumbprint=" + g_szThumbprint);
		endif;
		
		if(RegDBGetKeyValueEx (szKey, szCertificateName, nType, svCertificateName, nSize) <0) then
			g_PortalExists=FALSE;
		else
			g_szCertificateName=svCertificateName;
			WriteToLogFile(INSTALL_LOG,"CertificateName=" + g_szCertificateName);
		endif;
		
	else
		g_PortalExists=FALSE;
	endif;
	return 0;
end;
///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  AddEditTbl_Portal                                              //
//                                                                           //
// Purpose:   This function                                                  //
///////////////////////////////////////////////////////////////////////////////
function number AddEditTbl_Portal()
number nvResult;
string szReturnValue;   
number nvSystemIDValue; 
STRING szPortalIdCheckSQLScript,szPortalIdUpdateScript;
begin     
//UPDATE tbl_portal SET url = 'http://localhost/Pure.Portal',culture_code = 'EN-GB',master_page = 'masterpages/internal',theme = 'internal' WHERE portal_id = 1
//UPDATE tbl_portal SET url = 'http://localhost/Pure.Portal',culture_code = 'EN-GB',master_page = 'masterpages/external',theme = 'external' WHERE portal_id = 2
szPortalIdCheckSQLScript ="if exists(select * from tbl_portal where portal_id=1) select sRetValue='YES' else select sRetValue='NO'";
szReturnValue = ADODBConnectExecuteAndReturnPortal(g_PortalDBServer,g_PortaDB,g_PortalUser,g_PortalPwd,szPortalIdCheckSQLScript,"sRetValue");
if(szReturnValue = "YES") then
	szPortalIdUpdateScript="UPDATE tbl_portal SET url = 'http://localhost/" + g_szApplicationPortal + "'" + ",culture_code = 'EN-GB',master_page = 'masterpages/internal',theme = 'internal' WHERE portal_id = 1";
	WriteToLogFile(INSTALL_LOG,szPortalIdUpdateScript);
	nvResult = ADODBConnectAndExecutePortal(g_PortalDBServer,g_PortaDB,g_PortalUser,g_PortalPwd,szPortalIdUpdateScript);
else
	// Insert Portal_ID=1 
	WriteToLogFile(INSTALL_LOG,"Upgrading of Portal database failed since there is no Portal available with portal_id=1, please configure the Portal database manually after Installation."+ szPortalIdUpdateScript);
	//MessageBox("Upgrading of Portal database failed since there is no Portal available with portal_id=1, please configure the Portal database manually after Installation.", INFORMATION);
endif;
szPortalIdCheckSQLScript ="if exists(select * from tbl_portal where portal_id=2) select sRetValue='YES' else select sRetValue='NO'";
szReturnValue = ADODBConnectExecuteAndReturnPortal(g_PortalDBServer,g_PortaDB,g_PortalUser,g_PortalPwd,szPortalIdCheckSQLScript,"sRetValue");
if(szReturnValue = "YES") then
	szPortalIdUpdateScript="UPDATE tbl_portal SET url = 'http://" + g_szHostName + "/" + g_szApplicationPortal + "'" + ",culture_code = 'EN-GB',master_page = 'masterpages/external',theme = 'external' WHERE portal_id = 2";
	WriteToLogFile(INSTALL_LOG,szPortalIdUpdateScript);
	nvResult = ADODBConnectAndExecutePortal(g_PortalDBServer,g_PortaDB,g_PortalUser,g_PortalPwd,szPortalIdUpdateScript);
else
	// Insert Portal_ID=2
	WriteToLogFile(INSTALL_LOG,"Upgrading of Portal database failed since there is no Portal available with portal_id=2, please configure the Portal database manually after Installation."+ szPortalIdUpdateScript);
	//MessageBox("Upgrading of Portal database failed since there is no Portal available with portal_id=2, please configure the Portal database manually after Installation..", INFORMATION);
endif;
return 1;            
end;   

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CreatePortalRegistry 	                                                 //
//				                                                                     //
// Purpose:   This function create PortalRegsitry                                    //
///////////////////////////////////////////////////////////////////////////////////////
function CreatePortalRegistry()
STRING szKey,szApplication,szPath,szAppPool,szWebServiceUrl,szDocumentsLocation,szReportsLocation,szTempFileLocation;
NUMBER nSize,nType;
STRING szAppLicationPortalKey;
STRING szPortalDBServer,szPortaDB;
begin 
    nSize= -1;
    nType= REGDB_STRING;
	szKey="SOFTWARE\\Pure\\PureInstallation\\Portal";
	//szAppLicationPortalKey = szKey ^ g_szApplicationPortal;
	szApplication="Application";
	szPath="Path";
	szAppPool="AppPool";
	szWebServiceUrl="WebServiceUrl";
	szDocumentsLocation="DocumentsLocation";
	szReportsLocation="ReportsLocation";
	szTempFileLocation="TempFileLocation";
	szPortalDBServer="DBServer";
	szPortaDB="DBName";
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    RegDBCreateKeyEx(szKey, "");
    //RegDBCreateKeyEx(szKey,g_szApplicationPortal); 
    //Portal Application registry 
    RegDBSetKeyValueEx (szKey, szApplication, nType, g_szApplicationPortal, nSize);
	RegDBSetKeyValueEx (szKey, szPath, nType, g_szPhysicalPathPortal, nSize); 
	RegDBSetKeyValueEx (szKey, szAppPool, nType, g_szAppPoolPortal, nSize);
	RegDBSetKeyValueEx (szKey, szWebServiceUrl, nType, g_szWebServiceUrl, nSize);
	RegDBSetKeyValueEx (szKey, szDocumentsLocation, nType, g_szDocumentsLocation, nSize);
	RegDBSetKeyValueEx (szKey, szReportsLocation, nType, g_szReportsLocation, nSize);
	RegDBSetKeyValueEx (szKey, szTempFileLocation, nType, g_szTempFileLocation, nSize);
	//Portal database registry
	RegDBSetKeyValueEx (szKey, szPortalDBServer, nType, g_PortalDBServer, nSize);
	RegDBSetKeyValueEx (szKey, szPortaDB, nType, g_PortaDB, nSize);
	return 0;
end;



///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CopyOLDWebConfig  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for Portal                  //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function CopyOLDWebConfig()
STRING  szSrcPath;
NUMBER	nResult,nvResult;  
STRING	szProgram,szCommand,szPermission;
begin
    SdShowMsg ( "Copying existing Pure Portal web.config . . . please wait." , TRUE );
	szSrcPath= g_szPhysicalPathPortal;
    LongPathToQuote(szSrcPath, TRUE); 
    // icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
   	szCommand=	szSrcPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	Disable (LOGGING);
	nResult = XCopyFile (g_szWebFileName, g_szPhysicalPathPortal,COMP_NORMAL);
	Enable(LOGGING);
	SdShowMsg ( "Copying existing Pure Portal web.config . . . please wait." , FALSE );    
    return 0;
end; 

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  UpdatePortalWebConfig  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for Portal                  //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function UpdatePortalWebConfig()
STRING  szSrcPath, szFileName,szTargetFile, szTargetPath, szAddKey,szPath;
NUMBER	nResult,i,j,nvResult;  
OBJECT  oDoc, oNodeList,oNode;
STRING	szProgram,szCommand,szCommand1,szPermission;
STRING szWebRootKey, szconnectionString,szWebServiceUrl,strNodeName;
OBJECT  xEndPointNodeList,xEndPointNode;
STRING strPureWCFSeriveName;
STRING szPureAccountServiceUrl,szPureSecurityServiceUrl,szPureCoreServiceUrl,szPurePolicyServiceUrl,szPurePartyServiceUrl,szPureClaimServiceUrl;
STRING szPureSTSFederationMetadataUrl,szPureSTSissuerUrl;
STRING strIssuerKey,strFederationMetadataLocationKey,szCertificateName;
begin
    SdShowMsg ( "Updating Pure Portal web.config . . . please wait." , TRUE );
    szPath = WINDISK + "\\";
    
    if(bPurePortalDBWinLogin = FALSE) then
    
		szconnectionString= "SERVER=" + g_PortalDBServer + ";" + 
						"Initial Catalog=" + g_PortaDB + ";" + 
						"UID=" + g_PortalUser + ";" +
						"PWD=" + g_PortalPwd + ";";
						
	else
		szconnectionString= "SERVER=" + g_PortalDBServer + ";" + 
						"Initial Catalog=" + g_PortaDB + ";" + 
						"Integrated Security=SSPI" + ";";
	endif;
	
	//WCF Services URLS
	szPureAccountServiceUrl= "http://" + g_szPureAppServerName + "/PureWCFServices/PureAccountService.svc";
	szPureSecurityServiceUrl = "http://" + g_szPureAppServerName + "/PureWCFServices/PureSecurityService.svc";
	szPureCoreServiceUrl = "http://" + g_szPureAppServerName + "/PureWCFServices/PureCoreService.svc";
	szPurePolicyServiceUrl = "http://" + g_szPureAppServerName + "/PureWCFServices/PurePolicyService.svc";
	szPurePartyServiceUrl = "http://" + g_szPureAppServerName + "/PureWCFServices/PurePartyService.svc";
	szPureClaimServiceUrl = "http://" + g_szPureAppServerName + "/PureWCFServices/PureClaimService.svc";
	
	//PureSTS URLS
				
	szPureSTSFederationMetadataUrl="https://" + g_szSTSServer + "/PureSTS/FederationMetadata/2007-06/FederationMetadata.xml";
	szPureSTSissuerUrl="https://" + g_szSTSServer + "/PureSTS/issue/wsfed";
	
	szCertificateName="CN=" + g_szCertificateName;
	
	
	szSrcPath= g_szPhysicalPathPortal;
    LongPathToQuote(szSrcPath, TRUE); 
    // icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
	
   	szCommand=	szSrcPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	
	Disable (LOGGING);
	nResult = XCopyFile (g_szPhysicalPathPortal ^ "web.config", szPath,COMP_NORMAL);
	Enable(LOGGING);
	
    szFileName = szPath ^ "web.config";
    LongPathToQuote(szFileName, TRUE); 
	WriteToLogFile(INSTALL_LOG,"web.config path=" + szFileName); 
	
	if Is(FILE_EXISTS, szFileName) = TRUE then
    else
        MessageBox ( "Can't find web.config", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	// Set the read-only flag OFF
	SetFileInfo ( g_szPhysicalPathPortal ^ "web.config", FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("*");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                
                try
                     szWebRootKey = oNode.attributes.getNamedItem("key").value;
                     if szWebRootKey = "WebRoot" then
                        oNode.attributes.getNamedItem("value").value = "/" + g_szApplicationPortal + "/";
                        WriteToLogFile(INSTALL_LOG,"Updating web.config, WebRoot=" + "/" + g_szApplicationPortal + "/"); 
                     endif;
                catch
				endcatch;    
				
				
				try
				     //<add key="ida:FederationMetadataLocation" value="https://localhost/PureSTS/FederationMetadata/2007-06/FederationMetadata.xml" />
                     strNodeName= oNode.nodeName;
					 if(strNodeName= "add")then
								strFederationMetadataLocationKey=oNode.attributes.getNamedItem("key").value;
								if(strFederationMetadataLocationKey="ida:FederationMetadataLocation")then
											oNode.attributes.getNamedItem("value").value = szPureSTSFederationMetadataUrl;
											WriteToLogFile(INSTALL_LOG,"Updating web.config, FederationMetadataLocation value=" + szPureSTSFederationMetadataUrl);
								endif;
					 endif;
                     
                     //<add key="ida:Issuer" value="https://localhost/PureSTS/issue/wsfed" />
                     strNodeName= oNode.nodeName;
					 if(strNodeName= "add")then
								strIssuerKey=oNode.attributes.getNamedItem("key").value;
								if(strIssuerKey="ida:Issuer")then
											oNode.attributes.getNamedItem("value").value = szPureSTSissuerUrl;
											WriteToLogFile(INSTALL_LOG,"Updating web.config, Issuer value=" + szPureSTSissuerUrl);
								endif;
							
                     endif;
                catch
				endcatch;
				
				/*
				try
					//WebServiceUrl
					oNode.attributes.getNamedItem("WebServiceUrl").value = g_szWebServiceUrl;
                    WriteToLogFile(INSTALL_LOG,"Updating web.config, WebServiceUrl=" + g_szWebServiceUrl);
                    
                catch
				endcatch;
				*/
				
				try
                    //TempFileLocation
                     oNode.attributes.getNamedItem("TempFileLocation").value = g_szTempFileLocation;
                     WriteToLogFile(INSTALL_LOG,"Updating web.config, TempFileLocation=" + g_szTempFileLocation);
                catch
				endcatch;
				
                try
                    //connectionString
                     oNode.attributes.getNamedItem("connectionString").value = szconnectionString;
                     WriteToLogFile(INSTALL_LOG,"Updating web.config, connectionString=" + szconnectionString);
				catch
				endcatch;
				
                try     
                     strNodeName= oNode.nodeName;
					 if(strNodeName= "Reports")then
							oNode.attributes.getNamedItem("Location").value = g_szReportsLocation;
							WriteToLogFile(INSTALL_LOG,"Updating web.config, Reports Location=" + g_szReportsLocation);
                     endif;
					 if(strNodeName= "Documents")then
							oNode.attributes.getNamedItem("Location").value = g_szDocumentsLocation;
							WriteToLogFile(INSTALL_LOG,"Updating web.config, Documents Location=" + g_szDocumentsLocation);
                     endif;
				 catch
				 endcatch;
									 
				try     
                     
					//<add thumbprint="BB42A447B3327D8B64D91E97AA27CAEB895B2E31" />
                     strNodeName= oNode.nodeName;
					 if(strNodeName= "add")then
							oNode.attributes.getNamedItem("thumbprint").value = g_szThumbprint;
							WriteToLogFile(INSTALL_LOG,"Updating web.config, thumbprint=" + g_szThumbprint);
                     endif;
                     
                     //<serviceCertificate findValue="CN=localhost" storeLocation="LocalMachine" storeName="My" x509FindType="FindBySubjectDistinguishedName" />
                     strNodeName= oNode.nodeName;
					 if(strNodeName= "serviceCertificate")then
							oNode.attributes.getNamedItem("findValue").value = szCertificateName;
							WriteToLogFile(INSTALL_LOG,"Updating web.config, certificate=" + szCertificateName);
                     endif;
                     
                                       
                     //<wsFederation passiveRedirectEnabled="true" issuer="https://localhost/PureSTS/issue/wsfed" realm="http://localhost/Pure.Portal/Login.aspx" requireHttps="false" />
					 strNodeName= oNode.nodeName;
					 if(strNodeName= "wsFederation")then
								oNode.attributes.getNamedItem("issuer").value = szPureSTSissuerUrl;
							    WriteToLogFile(INSTALL_LOG,"Updating web.config, issuer=" + szPureSTSissuerUrl);
							
                     endif;
                     
                 catch
				 endcatch;
				 
				 try     
                     strNodeName= oNode.nodeName;
                     if(strNodeName= "client")then
							set xEndPointNodeList = oNode.childNodes;  
             	
							for j = 0 to (xEndPointNodeList.length - 1) 
								
								set xEndPointNode = xEndPointNodeList.nextNode;
                   		
								if(xEndPointNode.nodeType==8) then
										
								else    					
									
									strPureWCFSeriveName=xEndPointNode.attributes.getNamedItem("name").value;
									
									if(strPureWCFSeriveName="CustomBinding_IPureAccountService")then
											xEndPointNode.attributes.getNamedItem("address").value = szPureAccountServiceUrl;
									endif;
									
									if(strPureWCFSeriveName="CustomBinding_IPureSecurityService")then
											xEndPointNode.attributes.getNamedItem("address").value = szPureSecurityServiceUrl;
									endif;
									
									if(strPureWCFSeriveName="CustomBinding_IPureCoreService")then
											xEndPointNode.attributes.getNamedItem("address").value = szPureCoreServiceUrl;
									endif;
									
									if(strPureWCFSeriveName="CustomBinding_IPurePolicyService")then
											xEndPointNode.attributes.getNamedItem("address").value = szPurePolicyServiceUrl;
									endif;
									
									if(strPureWCFSeriveName="CustomBinding_IPurePartyService")then
											xEndPointNode.attributes.getNamedItem("address").value = szPurePartyServiceUrl;
									endif;
									
									if(strPureWCFSeriveName="CustomBinding_IPureClaimService")then
											xEndPointNode.attributes.getNamedItem("address").value = szPureClaimServiceUrl;
									endif;

								endif;//if(xEndPointNode.nodeType==8)
                    		endfor;//for j
                    endif;//if(strNodeName= "client")then
				 catch
				 endcatch;
			 endfor; //for i = 0 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   // if (oNodeList.length > 0) then   
    else
        MessageBox(ERROR_XML_FILE_LOAD,WARNING);                         
        return -1;
    endif;//if oDoc.load(szFileName) then
    
    oDoc.save(szFileName);
    set oDoc = NOTHING;
    //Delay(60);
    
	Disable (LOGGING);
	nResult = XCopyFile (szPath ^ "web.config", g_szPhysicalPathPortal  ,COMP_NORMAL);
	Enable(LOGGING);
	SdShowMsg ( "Updating Pure Portal web.config . . . please wait." , FALSE );	
    //DeleteFile(szFileName); 
    return 0;
end; 

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ModifyPortalApplicationSetting                                 //
//                                                                           //
// Purpose:   This function                                                  //
///////////////////////////////////////////////////////////////////////////////
function ModifyPortalApplicationSetting()
STRING szProgram,szCommand,szCommand1,szAppPoolCommand,szAppPathCommand;
NUMBER nvResult;
begin
	//Modify Application Physical Path
	//%systemroot%\system32\inetsrv\APPCMD set app "Default Web Site/Pure.Portal1" /[path='/'].physicalPath:c:\application
	szProgram = WINSYSDIR ^ "inetsrv\\appcmd.exe"; 
    LongPathToQuote(szProgram, TRUE); 
    szCommand = "set app ";
    szCommand1 = "Default Web Site/" + g_szApplicationPortal;
    LongPathToQuote(szCommand1, TRUE); 
    LongPathToQuote(g_szPhysicalPathPortal, TRUE); 
    szAppPathCommand = szCommand + szCommand1 + " /[path='/'].physicalPath:" + g_szPhysicalPathPortal;
	WriteToLogFile(INSTALL_LOG,szAppPathCommand);
	LaunchAppAndWait(szProgram,szAppPathCommand,WAIT);
	//Modify Application Pool
	//%systemroot%\system32\inetsrv\APPCMD set app "Default Web Site/Pure.Portal1" /applicationPool:PurePortalAppPool
	szAppPoolCommand = szCommand + szCommand1 + " /applicationPool:" + g_szAppPoolPortal;
	WriteToLogFile(INSTALL_LOG,szAppPoolCommand);
	LaunchAppAndWait(szProgram,szAppPoolCommand,WAIT);
	return 0;
end;
  
