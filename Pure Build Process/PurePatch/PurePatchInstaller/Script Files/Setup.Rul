begin
	Disable(STATUSEX);

	bOpt1   = FALSE;
    bOpt2   = FALSE;    

    szTitle = "SSP Pure Patch Installation Complete";    
	szMsg1 = "SSP Pure Insurance " + gszInstallerTitle1  + " Installation has successfully installed. Click Finish to exit the Wizard";     
    
    szMsg2 = "Click Finish to exit %P setup."; 
	
  	SdFinish(szTitle,szMsg1,szMsg2,"","", bOpt1, bOpt2);
end;

