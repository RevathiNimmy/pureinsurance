<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <!--<UsingTask TaskName="MyTasks.IncrementBuildNumber" AssemblyFile="../../IncrementBuildNumber.dll" />
  <UsingTask TaskName="MyTasks.ReadBuildNumber" AssemblyFile="../../IncrementBuildNumber.dll" />
  -->
  
  <PropertyGroup>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProductVersion>8.0.60403</ProductVersion>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{3FC86F32-E8F3-49D3-A84B-6C1EEF59C98E}</ProjectGuid>
    <SourceWebPhysicalPath>BuildSource\Nexus\Pure.Portals</SourceWebPhysicalPath>
    <SourceWebProject>{B1CFBAE7-0FD4-4D26-B13E-65A9AE0BD17E}|http://localhost/Pure.Portals</SourceWebProject>
    <SourceWebVirtualPath>BuildSource\Nexus\Pure.Portals</SourceWebVirtualPath>
    <SourceWebMetabasePath>/LM/W3SVC/1/ROOT/Pure.Portals/</SourceWebMetabasePath>
    <DebugSymbols>false</DebugSymbols>
    <OutputPath>.\Temp</OutputPath>
    <UseFixedNames>true</UseFixedNames>
    <EnableUpdateable>true</EnableUpdateable>
    <UseMerge>false</UseMerge>
    <SingleAssemblyName>Pure.Portals</SingleAssemblyName>
    <StopOnFirstFailure>true</StopOnFirstFailure>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="BuildSource\CSSFriendly\CSSFriendly\CSSFriendly.csproj">
