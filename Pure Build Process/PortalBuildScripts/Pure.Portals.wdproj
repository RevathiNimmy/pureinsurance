  <ItemGroup>
    <ExcludeFromBuild Include="$(SourceWebPhysicalPath)\Products\**\*.*" />
    <ExcludeFromBuild Include="$(SourceWebPhysicalPath)\App_Themes\**\*.*" />
    <ExcludeFromBuild Include="$(SourceWebPhysicalPath)\EmailTemplates\**\*.*" />
    <ExcludeFromBuild Include="$(SourceWebPhysicalPath)\Masterpages\**\*.*" />
    <ExcludeFromBuild Include="$(SourceWebPhysicalPath)\TempFiles\**\*.*" />
    <ExcludeFromBuild Include="$(SourceWebPhysicalPath)\**\*.scc" />
    <ExcludeFromBuild Include="$(SourceWebPhysicalPath)\bin\*.xml" />
    <ExcludeFromBuild Include="$(SourceWebPhysicalPath)\bin\*.pdb" />
  </ItemGroup>

  <Import Project="$(MSBuildExtensionsPath)\Microsoft\WebDeployment\v8.0\Microsoft.WebDeployment.targets" />
  <ItemGroup>
    <MySourceFiles Include="$(MSBuildProjectDirectory)\Temp\**\*.*" />
  </ItemGroup>
  <Target Name="BeforeBuild">
   <!--<IncrementBuildNumber File="$(MSBuildProjectDirectory)\BuildNumbers.txt" XMLFile="$(MSBuildProjectDirectory)\BuildSource\Nexus\Pure.Portals\web.config">
      <Output TaskParameter="BuildNumber" PropertyName="BuildNumber" />
      <Output TaskParameter="RevisionNumber" PropertyName="RevisionNumber" />
    </IncrementBuildNumber>
    -->
    <CreateItem Include="AssemblyFileVersion" AdditionalMetadata="Value=$(MajorVersion).$(BuildNumber).$(RevisionNumber)">
      <Output ItemName="AssemblyAttributes" TaskParameter="Include" />
    </CreateItem>
    <CreateItem Include="AssemblyVersion" AdditionalMetadata="Value=$(MajorVersion).$(BuildNumber).$(RevisionNumber)">
      <Output ItemName="AssemblyAttributes" TaskParameter="Include" />
    </CreateItem>
    <GenerateAssemblyInfo OutputDir="$(MSBuildProjectDirectory)\AssemblyInfo" AssemblyAttributes="@(AssemblyAttributes)"/>
  </Target>


  <Target Name="FinalCopy">
   <!-- <ReadBuildNumber File="$(MSBuildProjectDirectory)\BuildNumbers.txt">
      <Output TaskParameter="BuildNumber" PropertyName="BuildNumber" />
      <Output TaskParameter="RevisionNumber" PropertyName="RevisionNumber" />
    </ReadBuildNumber>
    -->
 
<!--create output directory -->
    <MakeDir Directories="$(OutputDirectory)\$(ApplicationName)\$(ApplicationName) $(MajorVersion).$(BuildNumber).$(RevisionNumber)" />



    <Copy SourceFiles="@(MySourceFiles)" DestinationFiles="@(MySourceFiles->'$(OutputDirectory)\$(ApplicationName)\$(ApplicationName) $(MajorVersion).$(BuildNumber).$(RevisionNumber)\%(RecursiveDir)%(FileName)%(Extension)')" />
    <MakeDir Directories="$(OutputDirectory)\$(ApplicationName)\$(ApplicationName) $(MajorVersion).$(BuildNumber).$(RevisionNumber)\Products" />

    <MakeDir Directories="$(OutputDirectory)\$(ApplicationName)\$(ApplicationName) $(MajorVersion).$(BuildNumber).$(RevisionNumber)\App_Themes" />

<MakeDir Directories="$(OutputDirectory)\$(ApplicationName)\$(ApplicationName) $(MajorVersion).$(BuildNumber).$(RevisionNumber)\EmailTemplates" />


    <!-- rename and move the build log file 
   
<Exec Command="copy Build.log &quot;$(MSBuildProjectDirectory)\Logs\Pure.Portals.$(MajorVersion).$(BuildNumber).$(RevisionNumber).log&quot;" WorkingDirectory="$(MSBuildProjectDirectory)\Scripts"/>
    -->

  </Target>
</Project>