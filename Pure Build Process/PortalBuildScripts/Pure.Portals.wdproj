    </ProjectReference>
    <ProjectReference Include="BuildSource\Nexus\Nexus.Library\Nexus.Library.vbproj">
      <Project>{DBE041F0-949E-4A3A-8604-A59F81FAF758}</Project>
      <Name>Nexus.Library</Name>
    </ProjectReference>
    <ProjectReference Include="BuildSource\Nexus\Nexus.Utils\Nexus.Utils.vbproj">
      <Project>{42857D04-0B2A-48A8-9B82-B272F20F81C6}</Project>
      <Name>Nexus.Library</Name>
