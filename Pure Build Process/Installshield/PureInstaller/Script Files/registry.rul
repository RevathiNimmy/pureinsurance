///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ImportFreshInstallRegistryFile                                 //
//                                                                           //
// Purpose:   This function import the PM Registry files with default values //
//            to the Installed Machine in case of Fresh Installations        //
//                                                                           //
///////////////////////////////////////////////////////////////////////////////
 
function number ImportFreshInstallRegistryFile()
string szProgram,szCMDline,szRegFileName,szPath;   
number nvExitCode;   
number nvLaunchApplicationvResult;
begin       

szPath = WINDISK + "\\";
szRegFileName = szPath ^ FRESHREGFILEPATH;
szProgram = "regedit";
szCMDline = " /s " + szRegFileName;
nvLaunchApplicationvResult = LaunchApplication(szProgram,szCMDline,"",SW_HIDE,120,LAAW_OPTION_USE_SHELLEXECUTE|LAAW_OPTION_WAIT);

if(nvLaunchApplicationvResult = ISERR_SUCCESS) then
    WriteToLogFile(INSTALL_LOG,"Fresh Registry file Import Successful");
else
    MessageBox("Fresh Registry File Cannot be Imported.Check out Aborting the Installation..",SEVERE);	
    abort;
endif;
return 1;
end;    

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  PlacePMInstallPathforFreshRegistry                             //
//                                                                           //
// Purpose:   This function replaces the PM destination path of the default  //
//			  values in the templated Fresh Registry file before it          //
//			  is imported to the target machine during fresh installation    //
//                                                                           //
///////////////////////////////////////////////////////////////////////////////

function number PlacePMInstallPathforFreshRegistry()
number nvResult;
string szReplaceString;
begin    
try 
	szReplaceString = ParsePathString(g_szPMInstallPath);
	nvResult = ReplaceMatchPatterninFile(SUPPORTDIR ^ FRESHREGFILEPATH,"[DESTPATH]",szReplaceString);
	if(nvResult = 1) then
		WriteToLogFile(INSTALL_LOG,"PM Installable Path Set Successfully in the Freshly Imported Registry File");
	endif;
catch    
		MessageBox("Registry Updating error-Incorrect operation in fresh installation",WARNING);
		abort;
endcatch;
	//Set PMDIR Name for 32 bit setupdb
	WriteToRegistry("SOFTWARE\\WOW6432Node\\Pure","PMDIR",REGDB_STRING,g_szPMPath);
	
return 1;
end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ReplaceMatchPatterninFile                                      //
//                                                                           //
// Purpose:   This function replaces a matched pattern with the replaceable  //
//			  pattern in any Text formatted file specified by the filename   //
//            parameter                                                	     //
///////////////////////////////////////////////////////////////////////////////
function number ReplaceMatchPatterninFile(szFilename,szMatchPattern,szReplacePattern)
number nvResult,nvLineNumber,nvPatternStartLocation,nvReturnLineLength,nvPatternLength;
string szReturnLine,szBeforePattern,szAfterPattern,szModifiedLine;
STRING szPath;
begin   

szPath = WINDISK + "\\";

 //XCopyFile ( szFilename, gTemp, COMP_NORMAL ); 
 XCopyFile ( szFilename, szPath, COMP_NORMAL );    
 szFilename = szPath ^ FRESHREGFILEPATH;
 
 SetFileInfo(szFilename, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
 
nvPatternLength =  StrLengthChars(szMatchPattern);
nvResult = FileGrep (szFilename,szMatchPattern,szReturnLine,nvLineNumber,RESTART);
while (nvResult = 0) 
		nvPatternStartLocation = StrFind(szReturnLine,szMatchPattern);
		nvReturnLineLength = StrLengthChars(szReturnLine);
		if (nvPatternStartLocation >= 0) then    
	     	StrSub(szBeforePattern,szReturnLine,0,nvPatternStartLocation);
	    	StrSub(szAfterPattern,szReturnLine,nvPatternStartLocation+nvPatternLength,nvReturnLineLength-(nvPatternStartLocation+nvPatternLength));
	   		szModifiedLine = szBeforePattern + szReplacePattern + szAfterPattern;
			//WriteToLogFile(INSTALL_LOG,szFilename);
	   		//WriteToLogFile(INSTALL_LOG,szModifiedLine);
	   	 	nvResult= FileInsertLine(szFilename,szModifiedLine,nvLineNumber,REPLACE);
	     	if(nvResult < 0) then
		  	  WriteToLogFile(INSTALL_ERRORLOG,"Replacing Pattern of "+szMatchPattern+ " with this "+szReplacePattern+" Failed in File "+szFilename);
		  	  return -1;
			endif;
	 	endif;
		nvResult = FileGrep(szFilename,szMatchPattern, szReturnLine, nvLineNumber,CONTINUE);
endwhile;    
return 1;
end;      

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ParsePathString                                                //
//                                                                           //
// Purpose:   This function formats the Dir Path pattern of the PM folder    //
//			  by placing "\\\\" instead of "\\" in the Fresh Registry file   //
//                                                                           //
///////////////////////////////////////////////////////////////////////////////
       
function string ParsePathString(szStringName)
number nvResult,nvStringLength;
string szConcatenatedString,szIntermediateString;
begin  
nvStringLength =  StrLengthChars(szStringName);    
szConcatenatedString = "";
Recurse:
nvStringLength =  StrLengthChars(szStringName);    
nvResult = StrFind(szStringName,"\\");             
if(nvResult >= 0) then
	StrSub(szIntermediateString,szStringName,0,nvResult);
	if(szConcatenatedString = "") then
  	 	szConcatenatedString =  szIntermediateString;
	else
		szConcatenatedString = szConcatenatedString + "\\\\" +szIntermediateString;
	endif;
StrSub(szStringName,szStringName,nvResult + 1,nvStringLength);
goto  Recurse;
else
szConcatenatedString = szConcatenatedString + "\\\\" + szStringName;
endif;

return szConcatenatedString;
end; 

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetPMRegistryInstalledValues                                   //
//                                                                           //
// Purpose:   This function writes the installed values and parameters       //
//			  to the registry under "HKEY_LOCAL_MACHINE\SOFTWARE\PM" folder  //
//            after every installation                                       //                       
///////////////////////////////////////////////////////////////////////////////

function number SetPMRegistryInstalledValues()
number nvTARGETDIRLength,nvResult; 
string szMajorVersion1,szMajorVersion2,szCacheLocation,szBriefCaseDir,szCommonCacheLocation,szSiriusEventLog,szMinorVersion;
STRING szEDIPathName;
begin     

RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);

//Set the Conventional Product Version after installation
StrSub(szMajorVersion1,g_szTobeInstalledMajorVersion,0,1);
StrSub(szMajorVersion2,g_szTobeInstalledMajorVersion,1,2);
StrSub(szMinorVersion,g_szTobeInstalledMajorVersion,2,1);

WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Version",REGDB_STRING,szMajorVersion1 + "."+ szMajorVersion2 + "." + g_szTobeInstalledSubVersion);	
//InsertRegistrySetting(KeyPath, KeyName, KeyType, keydata, system_id)
						
WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","PureReleaseVersion",REGDB_STRING,szMajorVersion1 + "."+ szMinorVersion);

//Get the Full Service Release Version Number and Split it up for any product SubVersion Availability
StrSub(g_szTobeInstalledServiceRelease,g_szTobeInstalledMinorVersion,1,2); 

if(StrFind(g_szTobeInstalledServiceRelease,"0") = 0) then
	StrSub(g_szTobeInstalledServiceRelease,g_szTobeInstalledServiceRelease,1,1); 	
endif;

//Set the Build number of the installed product
WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Build",REGDB_STRING,g_szTobeInstalledBuildNumber);

//Set the Service Release Version and Sirius Release Version of the product currently installed              
WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Service Release",REGDB_STRING,g_szTobeInstalledServiceRelease + "." + g_szTobeInstalledBuildNumber);
WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Sirius Release",REGDB_STRING,g_szTobeInstalledServiceRelease + "." + g_szTobeInstalledBuildNumber);		


//Set the Full Version of the Product
WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Full Version",REGDB_STRING,g_szTobeInstalledFullVersion);

//Set the New Product Version after installation
WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","New Version",REGDB_STRING,IFX_PRODUCT_VERSION);

//Set the New Product Version after installation
WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Server","Version",REGDB_STRING,IFX_PRODUCT_VERSION);
WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Client","Version",REGDB_STRING,IFX_PRODUCT_VERSION);
  
//Set the New DME Version after installation
WriteToRegistry("SOFTWARE\\Pure\\DocuMaster\\Server","Version",REGDB_STRING,IFX_PRODUCT_VERSION);
WriteToRegistry("SOFTWARE\\Pure\\DocuMaster\\Client","Version",REGDB_STRING,IFX_PRODUCT_VERSION);  

//Set the DME Cache location
szCacheLocation = GetFromRegistry("SOFTWARE\\Pure\\DocuMaster\\Client\\Cache","Cache Location");
if (szCacheLocation = "") then
	nvResult = RegDBCreateKeyEx("SOFTWARE\\Pure\\DocuMaster\\Client","Cache");   
	WriteToRegistry("SOFTWARE\\Pure\\DocuMaster\\Client\\Cache","Cache Location",REGDB_STRING,TARGETDIR ^ "DocuMaster Enterprise\\DME\\Data");  
endif;

// Set BriefcaseDir
szBriefCaseDir=GetFromRegistry("SOFTWARE\\Pure\\DocuMaster\\Common","BriefcaseDir");
if (szBriefCaseDir = "") then
	nvResult = RegDBCreateKeyEx("SOFTWARE\\Pure\\DocuMaster","Common");   
	WriteToRegistry("SOFTWARE\\Pure\\DocuMaster\\Common","BriefcaseDir",REGDB_STRING,TARGETDIR ^ "DocuMaster Enterprise\\DME\\Data");  
endif;

// Set Common Cache Location
szCommonCacheLocation = GetFromRegistry("SOFTWARE\\Pure\\DocuMaster\\Common\\Cache","Cache Location");
if (szCommonCacheLocation = "") then
	nvResult = RegDBCreateKeyEx("SOFTWARE\\Pure\\DocuMaster\\Common","Cache");   
	WriteToRegistry("SOFTWARE\\Pure\\DocuMaster\\Common\\Cache","Cache Location",REGDB_STRING,g_szPMPath ^ "\\DocuMaster Cache");  
endif;

//Set for Event Logging
szSiriusEventLog=GetFromRegistry("SOFTWARE\\Pure\\Architecture\\Common","EventLogMessaging");
if (szSiriusEventLog = "") then
		WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Common","EventLogMessaging",REGDB_STRING,"1"); 
endif; 

//Create EventLog for Sirius Application
if(RegDBKeyExist("SYSTEM\\CurrentControlSet\\services\\eventlog\\Application\\Sirius") < 0) then
	nvResult = RegDBCreateKeyEx("SYSTEM\\CurrentControlSet\\services\\eventlog\\Application","Sirius");   
	WriteToRegistry("SYSTEM\\CurrentControlSet\\services\\eventlog\\Application\\Sirius","CategoryCount",REGDB_NUMBER,"4"); 
	WriteToRegistry("SYSTEM\\CurrentControlSet\\services\\eventlog\\Application\\Sirius","TypesSupported",REGDB_NUMBER,"7");   
else
	WriteToRegistry("SYSTEM\\CurrentControlSet\\services\\eventlog\\Application\\Sirius","CategoryCount",REGDB_NUMBER,"4"); 
	WriteToRegistry("SYSTEM\\CurrentControlSet\\services\\eventlog\\Application\\Sirius","TypesSupported",REGDB_NUMBER,"7");   
endif;

if(g_bFreshInstaller = TRUE) then           
	//Set PMDIR Name
	WriteToRegistry("SOFTWARE\\Pure","PMDIR",REGDB_STRING,g_szPMPath);
	//Set PMDIR Name for 32 bit setupdb
	WriteToRegistry("SOFTWARE\\WOW6432Node\\Pure","PMDIR",REGDB_STRING,g_szPMPath);
	//Set DBServerName  
	WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Server",REGDB_STRING,g_szDBServer);
	//Set Sirius DBName
	WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Database",REGDB_STRING,g_szSiriusDBName);
	//Set Sirius Installation Folder Name
	WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Setup","Installation folder",REGDB_STRING,g_szPMPath);
	//Set Sirius DB MDF Filename 
	WriteToRegistry("SOFTWARE\\Pure\\DatabaseInstaller\\Server","DataFilesFolder",REGDB_STRING,g_szMDFFileName);
	//Set Sirius DB LDF Filename
	WriteToRegistry("SOFTWARE\\Pure\\DatabaseInstaller\\Server","LogFilesFolder",REGDB_STRING,g_szLDFFileName);
	//Set Sirius DB Backup Filename
	//WriteToRegistry("SOFTWARE\\Pure\\DatabaseInstaller\\Server","BackupFileName",REGDB_STRING,g_szDBBackupFileName);
	//Set Sirius DB Backup Foldername
	//WriteToRegistry("SOFTWARE\\Pure\\DatabaseInstaller\\Server","BackupFilesFolder",REGDB_STRING,g_szDBBackupPath);
	//Set S4B path in PureInstallation Folder Name
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","S4B Path",REGDB_STRING,g_szPMPath);
endif;	

//Update the Product Installation History after installation
UpdateUpgradeInstallationHistory();

//Set the SQL Server Authentication Mode for Windows or SQL Server Authentication
if(g_bWinLoginAuthenticate = TRUE) then   
	//Set the Trusted Connection entry to 1(true).
   	WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Trusted",REGDB_STRING,"1");
else
    //Remove the Trusted Connection entry if present
    //nvResult = RegDBDeleteValue("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Trusted"); 
    WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Trusted",REGDB_STRING,"0");
endif;

//Set the SQL Server Authentication Mode for Windows or SQL Server Authentication
if(g_bWinLoginAuthenticate = TRUE) then   
	WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\SiriusSolutions","Trusted",REGDB_STRING,"1");
else
    WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\SiriusSolutions","Trusted",REGDB_STRING,"0");
endif;

WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server","UserIncorrectAttemptsAllowed",REGDB_STRING,"3");
WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server","CachePath",REGDB_STRING,TARGETDIR ^ "Cache");
WriteToRegistry("SOFTWARE\\Pure\\Architecture\\Server","SysOptionsCacheFile",REGDB_STRING,"PureCache");


//Set the EDIPathName
szEDIPathName = GetFromRegistry("SOFTWARE\\Pure\\PureInstallation\\Server","EDIPathName");
if (szEDIPathName = "") then
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Server","EDIPathName",REGDB_STRING,TARGETDIR ^ "EDI");  
endif;

WriteToLogFile(INSTALL_LOG,"Setting Pure Registry Completed after installation");
return 1;
end;
    
///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  UpdateUpgradeInstallationHistory                               //
//                                                                           //
// Purpose:   This function writes the installed values and parameters       //
//			  to the registry under "HKEY_LOCAL_MACHINE\SOFTWARE\Pure" folder  //
//            after every upgrade/Productupgrade but Fresh Installation      //                                                        //
///////////////////////////////////////////////////////////////////////////////
function number UpdateUpgradeInstallationHistory()
number nvResult;
string szFoldername,szCurrentDate,szCurrentTime,szRegValue; 
string szProductVersionFolder;  
string szTempVersion;

begin 

szFoldername = GetCurrentDateTime("DATETIME");
szRegValue = "1";
szProductVersionFolder = IFX_PRODUCT_VERSION;
//nvResult = RegDBCreateKeyEx("SOFTWARE\\Pure\\PureInstallation\\Installation History",szProductVersionFolder);

if(nvResult =0) then  
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Product Version",REGDB_STRING,IFX_PRODUCT_VERSION);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Full Version",REGDB_STRING,g_szTobeInstalledFullVersion);
	if(g_bFreshInstaller = TRUE) then
		WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Type",REGDB_STRING,"Fresh");
	else
		WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Type",REGDB_STRING,"Upgrade");
	endif;
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Setup",REGDB_STRING,"SERVER");
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Product Name",REGDB_STRING,"PureInstallation");
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Component Client",REGDB_STRING,szRegValue);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Component Server",REGDB_STRING,szRegValue);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Component Update Databases",REGDB_STRING,szRegValue);
	//Set the Date and Time for the Product Installation
	GetSystemInfo(TIME,nvResult,szCurrentTime);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Time",REGDB_STRING,szCurrentTime);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Time Installed",REGDB_STRING,szCurrentTime);
	FormatDate("UK",4,"/",g_szFDate);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Date",REGDB_STRING,g_szFDate);    
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Date Installed",REGDB_STRING,g_szFDate);    
	
	WriteToLogFile(INSTALL_LOG,"Upgrade Installation History updated in the registry");
 endif;     
 
return 1;
end;    

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  UpdatePatchInstallationHistory                                 //
//                                                                           //
// Purpose:   This function writes the installed values and parameters       //
//			  to the registry under "HKEY_LOCAL_MACHINE\SOFTWARE\Pure" folder  //
//            after every Patch Installation                                 //                            
///////////////////////////////////////////////////////////////////////////////

function number UpdatePatchInstallationHistory()
number nvResult;
string szFoldername,szCurrentDate,szCurrentTime;
string szDBBackupFlag;

begin 
RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);

nvResult = RegDBCreateKeyEx("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller",g_szPatchVersion);
if(nvResult =0) then  
    WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller\\"+g_szPatchVersion,"Product Version",REGDB_STRING,IFX_PRODUCT_VERSION);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller\\"+g_szPatchVersion,"Product Type",REGDB_STRING,"Insurance");
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller\\"+g_szPatchVersion,"Product Name",REGDB_STRING,"PureInstallation");
	GetSystemInfo(TIME,nvResult,szCurrentTime);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller\\"+g_szPatchVersion,"Install Time",REGDB_STRING,szCurrentTime);
	FormatDate("UK",4,"/",g_szFDate);
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller\\"+g_szPatchVersion,"Install Date",REGDB_STRING,g_szFDate);
	//Registry entry to show whether the current patch in installed or uninstalled
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller\\"+g_szPatchVersion,"Installation Status",REGDB_STRING,"Installed");
	//Uninstallation  date and time log addition to the patch installation
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller\\"+g_szPatchVersion,"UnInstall Date",REGDB_STRING,"");
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\PatchInstaller\\"+g_szPatchVersion,"UnInstall Time",REGDB_STRING,"");
	//Writing to the log file that patch history is updated in the registry
	WriteToLogFile(INSTALL_LOG,"Patch Installation History updated in the registry");
else   
	//MessageBox(" Registry Key not Created "+g_szPatchVersion,INFORMATION);  
	WriteToLogFile(INSTALL_ERRORLOG,"Patch Installation History root cannot be updated");
endif;

return 1;
end;
	

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  GetPMRegistryInstalledValuesforUpgradeInstall                  //
//                                                                           //
// Purpose:   This function get the installed values and parameters          //
//			  from the registry under "HKEY_LOCAL_MACHINE\SOFTWARE\Pure" 	     // 
//            folder for every upgrade/product upgrade installation          //
///////////////////////////////////////////////////////////////////////////////

function number GetPMRegistryInstalledValuesforUpgradeInstall()
string szRegFolder; 
number nvType,nvSize;
number nvValidateInstallPrerequisite;
string szMajorVersion1,szMajorVersion2;
 
begin  
RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
  
g_szInstalledProductVersion = GetFromRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Version");
    
//Checking for 1.12 Product Version Prerequisite in case of Product Upgrade but Fresh Installation    
if(g_bProductUpgradeNewInstaller = TRUE ) then
	if(g_szInstalledProductVersion = "") then
	    MessageBox("Registry Corrupted.Current Product Version cannot be fetched.",INFORMATION);
	    abort;
	else
		nvValidateInstallPrerequisite = ValidateOldProductInstalledVersion();
		if(nvValidateInstallPrerequisite = -1) then
			g_bPreRequisiteFailure = TRUE;
			abort;
		endif;
	endif;   
endif;    

nvSize = -1;          
szRegFolder ="SOFTWARE\\Pure";  

//This key  will fetch the  Sirius Product Installed Path
g_szPMPath = GetFromRegistry("SOFTWARE\\Pure","PMDIR");
StrRemoveLastSlash(g_szPMPath); 
WriteToLogFile(INSTALL_LOG, "PMDIR:" + g_szPMPath);
//g_szPMInstallPath = g_szPMPath + "\\Pure"; 
g_szPMInstallPath = g_szPMPath ^ "Pure"; 
WriteToLogFile(INSTALL_LOG, "Pure Install Path:" + g_szPMInstallPath);
TARGETDIR = g_szPMInstallPath;
WriteToLogFile(INSTALL_LOG, "TARGETDIR:" + TARGETDIR);
//This code will fetch MDF file name
g_szMDFFileName = GetFromRegistry("SOFTWARE\\Pure\\DatabaseInstaller\\Server","DataFilesFolder");
//This code will fetch LDF file name
g_szLDFFileName = GetFromRegistry("SOFTWARE\\Pure\\DatabaseInstaller\\Server","LogFilesFolder");
//This code will fetch DB Backup File Name
g_szDBBackupFileName = GetFromRegistry("SOFTWARE\\Pure\\DatabaseInstaller\\Server","BackupFileName");
//This code will fetch DB Backup  Folder Name
g_szDBBackupPath = GetFromRegistry("SOFTWARE\\Pure\\DatabaseInstaller\\Server","BackupFilesFolder");
//This code will fetch the Sirius Product database name
g_szSiriusDBName = GetFromRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Database");
//This code will fetch DB server name
g_szDBServer =GetFromRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Server");		
//This code will fetch whether windows authentication is set or not
g_szWindowsAuthenticate = GetFromRegistry("SOFTWARE\\Pure\\Architecture\\Server\\Databases\\Pure","Trusted");		
//Set the Windows Authentication flag based on the setting above
if(g_szWindowsAuthenticate = "1") then
   g_bWinLoginAuthenticate = TRUE;
else
   g_bWinLoginAuthenticate = FALSE;
endif;

//Get the Product Major Version,Service Release Version and Build Numbers 
g_szInstalledBuildNumber = GetFromRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Build");
g_szInstalledServiceReleaseAndBuildNumber = GetFromRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Service Release"); 
GetMajorandServiceReleaseVersionandBuildNumberforInstalledProduct(); 

StrSub(szMajorVersion1,g_szInstalledMajorVersion,0,1);
StrSub(szMajorVersion2,g_szInstalledMajorVersion,1,2);


if(g_bUpgradeInstaller = TRUE) then
	g_szInstalledFullVersion = GetFromRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Full Version");
else
    if(g_szInstalledSubVersion != "" && g_szInstalledSubVersion != "0") then
		g_szInstalledFullVersion =  szMajorVersion1 + "." + szMajorVersion2 + "." + g_szInstalledSubVersion + " Service Release " + g_szInstalledServiceRelease + " BuildNumber:"+ g_szInstalledBuildNumber;
	else
 	   g_szInstalledFullVersion =  szMajorVersion1 + "." + szMajorVersion2 + " Service Release " + g_szInstalledServiceRelease + " Build "+ g_szInstalledBuildNumber;
	endif;
endif;
	  
		                                                             
return 1;
end;
	

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function: WriteToRegistry                                                 //
//                                                                           //
// Purpose:  This function writes the a registry key with a particular value //
//			 under the foldername as specified in the function parameters    //
//                                                                     		 //
///////////////////////////////////////////////////////////////////////////////
	
function number WriteToRegistry(szFolderName,szKey,nvType,szValue)
number nvResult,nvSize;
begin   
try
	nvResult = RegDBSetKeyValueEx(szFolderName,szKey,nvType,szValue,nvSize);
	if(nvResult < 0) then
		WriteToLogFile(INSTALL_ERRORLOG,"Not able to set the Registry Value in "+szFolderName+" for "+szKey);
	else
		WriteToLogFile(INSTALL_LOG,"The Registry Value in "+szFolderName+" for "+szKey+" has been set successfully");	
	endif;  
catch 
    WriteToLogFile(INSTALL_ERRORLOG,"Error Encountered writing value "+szValue+" to the key"+szKey+" in folder "+szFolderName);
    return -1;
endcatch;
	
return 1;
end; 

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function: GetFromRegistry                                                 //
//                                                                           //
// Purpose:  This function gets  a particular value for the registry key     //
//			 under the foldername as specified in the function parameters    //
//                                                                      	 //
///////////////////////////////////////////////////////////////////////////////

function string GetFromRegistry(szFolderName,szKey)
number nvResult,nvType,nvSize;
string szValue;
begin                         
nvSize = -1; 
try 
	if(RegDBKeyExist(szFolderName) = 1) then
		if(RegDBGetKeyValueEx(szFolderName,szKey,nvType,szValue,nvSize) < 0) then 
			WriteToLogFile(INSTALL_ERRORLOG,"Not able to fetch the value "+szKey+ " from the folder "+szFolderName+ " registry");
		else
			WriteToLogFile(INSTALL_LOG,"Value fetched for "+ szKey + " from the folder "+szFolderName+ " registry");
		endif;  
	else
		WriteToLogFile(INSTALL_ERRORLOG,"The Specified Folder/Key "+szFolderName+ "//" + szKey + " does not exist");
	endif;
catch 
         WriteToLogFile(INSTALL_ERRORLOG,"Error Encountered fetching key value "+szKey+" from folder "+szFolderName);
         return "";
endcatch;

return szValue;
end;  


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function: DeleteRegFile                                                   //
//                                                                           //
// Purpose:  This function deletes the PM folder key and its associated      //
//			 child from the registry                                         //
///////////////////////////////////////////////////////////////////////////////

function number  DeleteRegFile()
number nvResult;
begin 

//Delete the Local Machine Software entry for the PM folder 
RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
if(RegDBKeyExist ("SOFTWARE\\Pure")) then
   nvResult = RegDBDeleteKey("SOFTWARE\\Pure");
   if(nvResult < 0) then
     WriteToLogFile(UNINSTALL_ERRORLOG,"Pure folder under Local Machine Registry cannot be deleted during Uninstallation");
   else
   	 WriteToLogFile(UNINSTALL_LOG,"Pure folder under Local Machine Registry deleted successfully  during Uninstallation");
   endif;
else
	WriteToLogFile(UNINSTALL_ERRORLOG,"Pure folder Information under Local Machine Registry  not available for Deletion");
endif; 

if(RegDBKeyExist ("SOFTWARE\\WOW6432Node\\Pure")) then
   nvResult = RegDBDeleteKey("SOFTWARE\\WOW6432Node\\Pure");
   if(nvResult < 0) then
     WriteToLogFile(UNINSTALL_ERRORLOG,"Pure folder under 32 bit Local Machine Registry cannot be deleted during Uninstallation");
   else
   	 WriteToLogFile(UNINSTALL_LOG,"Pure folder under 32 bit Local Machine Registry deleted successfully  during Uninstallation");
   endif;
else
	WriteToLogFile(UNINSTALL_ERRORLOG,"Pure folder Information under 32 bit Local Machine Registry  not available for Deletion");
endif; 

//Delete the Current User Software entry for the PM folder 
RegDBSetDefaultRoot(HKEY_CURRENT_USER);
if(RegDBKeyExist ("SOFTWARE\\Pure")) then
   nvResult = RegDBDeleteKey("SOFTWARE\\Pure");
   if(nvResult < 0) then
     WriteToLogFile(UNINSTALL_ERRORLOG,"Pure folder under Current User Registry cannot be deleted during Uninstallation");
   else
   	 WriteToLogFile(UNINSTALL_LOG,"Pure folder under Current User Registry deleted successfully  during Uninstallation");
   endif;
else
	WriteToLogFile(UNINSTALL_ERRORLOG,"Pure folder under Current User Registry Information not available for Deletion");
endif; 

  
return 1;
end; 

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function: DeleteUninstallReg                                              //
//                                                                           //
// Purpose:  This function deletes the Pure Uninstall key and its associated //
//			 child from the registry                                         //
///////////////////////////////////////////////////////////////////////////////

function number  DeleteUninstallReg()
number nvResult;
begin 

RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
if(RegDBKeyExist ("SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{A5D571AB-3D05-4530-A631-74E8D1CADCA6}")) then
   nvResult = RegDBDeleteKey("SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{A5D571AB-3D05-4530-A631-74E8D1CADCA6}");
   if(nvResult < 0) then
     WriteToLogFile(UNINSTALL_ERRORLOG,"Pure Uninstall registry cannot be deleted during Uninstallation");
   else
   	 WriteToLogFile(UNINSTALL_LOG,"Pure Uninstall registry deleted successfully during Uninstallation");
   endif;
else
	WriteToLogFile(UNINSTALL_ERRORLOG,"Pure Uninstall registry not available for Deletion");
endif; 
  
return 1;
end; 


