	WriteToLogFile(INSTALL_LOG,"Setting up File Shares Completed");
 	
return 1;
end;
 
////////////////////////////////////////////////////////////////////////
// Function: ClearReadOnly
// Purpose: Clear the Read Only attribute on all files in or below the 
//          directory passed in
////////////////////////////////////////////////////////////////////////
function NUMBER ClearReadOnly(svDirectory)
 NUMBER nFilesResult;
 STRING svMatchingFileName;
 
 begin
  nFilesResult = FindAllFiles(svDirectory, "*.*", svMatchingFileName, RESET);
  while(nFilesResult = 0)
   SetFileInfo(svMatchingFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
   nFilesResult = FindAllFiles(svDirectory,"*.*", svMatchingFileName, CONTINUE);
  endwhile;
  
  return nFilesResult;
 end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  AddShare                                                    	 //
//                                                                           //
// Purpose:   This function creates a share for the folder as mentioned      //
//			  in the function parameter with the sharename as given in       //
//			  the same function parameter                                    //
///////////////////////////////////////////////////////////////////////////////     

function number AddShare(szShareName,szPath,szComment)
	number	nvResult;
	string	szProgram,szCommand,szMsg;
	long lvValue;    
	BOOL bRetValue;
begin
	
try
	// Make sure it's quoted
	//LongPathToQuote(szPath, TRUE);
	//Remove the Last Slash in the Path Name
	StrRemoveLastSlash(szPath); 
	
	if(IsShareNameExists(szShareName) = TRUE) then
 		DelNetShare(g_szHostName,szShareName,lvValue);
 		bRetValue = AddNetShare(g_szHostName,szShareName,szPath,szComment,"","",lvValue,lvValue,100,lvValue);  
 		if(bRetValue = TRUE) then
 			szMsg = szPath+ " path has been shared";
			WriteToLogFile(INSTALL_LOG,szMsg);
		else
			szMsg = "Unable to share path : " + szPath;
			WriteToLogFile(INSTALL_ERRORLOG,szMsg);
		endif;
	else
 		bRetValue = AddNetShare(g_szHostName,szShareName,szPath,szComment,"","",lvValue,lvValue,100,lvValue);  
 		if(bRetValue = TRUE) then
 			szMsg = szPath+ " path has been shared";
			WriteToLogFile(INSTALL_LOG,szMsg);
		else
			szMsg = "Unable to share path : " + szPath;
			WriteToLogFile(INSTALL_ERRORLOG,szMsg);
		endif;
 	endif;
	
	//commented as it is not reliable method for Sharing Folders in a Network
	
	/*
	// Remove the old share
	szCommand = "SHARE " + szShareName + " /DELETE";
		
	nvResult = LaunchAppAndWait("NET ",szCommand,WAIT);
	
	
	if(SYSINFO.WINNT.bWinServer2003 = TRUE) then
		// Add new share for server2003 machines
		szCommand = "SHARE " + szShareName + "=\"" + szPath + "\" /GRANT:\\Everyone,FULL /UNLIMITED";
	else
		// Add new share for other machines	
		szCommand = "SHARE " + szShareName + "=" + szPath + " /UNLIMITED";
	endif;     
	
	 nvResult = LaunchAppAndWait("NET ",szCommand,WAIT);
	 //nvResult = LaunchApplication("NET ",szCommand,"",SW_HIDE,180,LAAW_OPTION_WAIT);
	
	*/ 

	if (nvResult = ISERR_SUCCESS) then
		szMsg = szPath+ " path has been shared";
		WriteToLogFile(INSTALL_LOG,szMsg);
	else                                        
		szMsg = "Unable to share path : " + szPath;
		WriteToLogFile(INSTALL_ERRORLOG,szMsg);
	endif;   
catch
	  WriteToLogFile(INSTALL_ERRORLOG,"Error during Creation of Shares inside the PM folder");
endcatch;
  
return 1;
end;


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  InstallRatingEngine                                            //
//                                                                           //
// Purpose:   This function is used to install the rating engine in          //
//			  case of Fresh Installation for use of VB script components     //
///////////////////////////////////////////////////////////////////////////////

function number InstallRatingEngine()
number nvResult,nvType,nvSize;    
string szCmdLine,szProgram,szValue,szMsg;
begin
//Install VB script components
//nvSize = -1;
//nvResult = RegDBGetKeyValueEx ( "SOFTWARE\\Pure\\PureInstallation\\Server","RatingEngine",nvType,szValue,nvSize);
nvResult = 1;
if (nvResult < 0) then
	SdShowMsg("Installing Ratings Engine . . . please wait.",TRUE);
	
	szCmdLine = "";
	szProgram = TARGETDIR ^ "Application\\scd10en.exe";	
	nvResult = LaunchAppAndWait(szProgram,szCmdLine,WAIT);
	if (nvResult != 1) then
		SdShowMsg("Installing Ratings Engine . . . please wait.",FALSE);
		szMsg = "Unable to launch : " + szProgram + " it will need to be run manually.";
		MessageBox(szMsg,SEVERE);
		return 0;
	endif;
	
	szProgram = TARGETDIR ^ "Application\\sct10en.exe";	
	nvResult = LaunchAppAndWait(szProgram,szCmdLine,WAIT);
	if (nvResult != 1) then
		SdShowMsg("Installing Ratings Engine . . . please wait.",FALSE);
		szMsg = "Unable to launch : " + szProgram + " it will need to be run manually.";
		MessageBox(szMsg,SEVERE);
		return 0;
	endif;
	
	szProgram = TARGETDIR ^ "Application\\ste51en.exe";	
	nvResult = LaunchAppAndWait(szProgram,szCmdLine,WAIT);
	if (nvResult != 1) then
		SdShowMsg("Installing Ratings Engine . . . please wait.",FALSE);
		szMsg = "Unable to launch : " + szProgram + " it will need to be run manually.";
		MessageBox(szMsg,SEVERE);
		return 0;
	endif;
	SdShowMsg("Installing Ratings Engine . . . please wait.",FALSE);
	//Write to the Registry that VB Script Components has been installed
	WriteToRegistry("SOFTWARE\\Pure\\PureInstallation\\Server","RatingEngine",REGDB_STRING,"INSTALLED");
	
else
	 return 0;
endif;	

return 1;
end;  

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  IsShareNameExists                                              //
//                                                                           //
// Purpose:   This function is used to check for the existence of a share    //
//			  with the  name as given in its parameters                  	 //
///////////////////////////////////////////////////////////////////////////////

function BOOL IsShareNameExists(szShareName)
LIST  listMachineShares;
BOOL bRetValue; 
long lvValue;  
number nvVal; 
BOOL bFuncRetValue;
string szError,szFolderName;
begin  
       
lvValue = 0;
listMachineShares = ListCreate(STRINGLIST);
szShareName = "\\\\" + g_szHostName + "\\" + szShareName;
bRetValue = GetServerDiskShares(g_szHostName,listMachineShares,lvValue,szError);
if(bRetValue = TRUE) then
	 nvVal = ListGetFirstString(listMachineShares,szFolderName);
	 while(nvVal = 0)
	 if(StrCompare(szShareName,szFolderName)= 0) then
	 	bFuncRetValue = TRUE;
	 	goto EndLabel;
	 endif;
	 nvVal = ListGetNextString(listMachineShares,szFolderName);
	 endwhile; 
endif;

EndLabel:
return bFuncRetValue; 
end;    


