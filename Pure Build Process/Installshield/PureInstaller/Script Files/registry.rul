///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  RemoveShare                                                   //
//                                                                           //
// Purpose:   This function removes the share of various folders inside PM   //
//			  folder after unInstallation is done                            //
///////////////////////////////////////////////////////////////////////////////
function number RemoveFolderShare(szShareName)
BOOL bRetValue; 
long lvValue;  
string szMsg;
begin       
if(IsShareNameExists(szShareName) = TRUE) then
	bRetValue = DelNetShare(g_szHostName,szShareName,lvValue);
	if(bRetValue = TRUE) then
    	szMsg = "Share Name "+szShareName+ " has been removed";
		WriteToLogFile(UNINSTALL_LOG,szMsg);
	else                               
		szMsg = "Share Name "+szShareName+ " has not been removed.Do Manually.";
		WriteToLogFile(UNINSTALL_ERRORLOG,szMsg);
	endif;  
endif;

return 1;
end;


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetUpPermissions                                               //
//                                                                           //
// Purpose:   This function sets up permissions for various folders inside PM//
//			  folder after an Installation is done                           //
///////////////////////////////////////////////////////////////////////////////

function number SetUpPermissions()        
number	nvResult;
string	szFolder,szPermission,szGroup,szUsersGroup,szUsersGroupPermission;
begin  



    SdShowMsg("Setting user Permissions . . . please wait.",TRUE);	
    
	
    // Set permission for "Users" and "Pure Users" group
    szGroup="Pure Users";
    LongPathToQuote(szGroup, TRUE); 
    
    szUsersGroup="Users";
    
    StrRemoveLastSlash(g_szPMInstallPath);
	szFolder = g_szPMInstallPath;
	
	//Clear read only from "Pure"
	nvResult = ClearReadOnly(szFolder);
	nvResult = RemoveReadOnly(szFolder);
		
    szUsersGroupPermission="(OI)(CI)F";
    
	
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);

        
    szFolder = WINDIR ^ "TEMP";
	szPermission="(OI)(CI)WR";
	
	if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
	
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	szFolder = TARGETDIR ^ "Application";
	szPermission="(OI)(CI)R";
	
	if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
	
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	szFolder = TARGETDIR ^ "Datasets";
	szPermission="(OI)(CI)WR";
	
	if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
	
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	nvResult = RemoveReadOnly(szFolder);
		 
	szFolder = TARGETDIR ^ "Documaster";
	szPermission="(OI)(CI)WR";	
    
    if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
    
    nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	szFolder = TARGETDIR ^ "DocZipTemp";
	szPermission="(OI)(CI)WR";	
    
    if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
    
    nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
    
    szFolder = TARGETDIR ^ "Export";	
    szPermission="(OI)(CI)WR";
    
    if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
    
    nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	nvResult = RemoveReadOnly(szFolder);
	
    szFolder = TARGETDIR ^ "Lists";
    szPermission="(OI)(CI)WR";	
    
    if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;

    nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	nvResult = RemoveReadOnly(szFolder);
	
    
    szFolder = TARGETDIR ^ "Lookups";
    szPermission="(OI)(CI)WR";	
    
    if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
    
    nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	nvResult = RemoveReadOnly(szFolder);
	
    szFolder = TARGETDIR ^ "Reports";
    szPermission="(OI)(CI)WR";
	
	if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
	
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	nvResult = RemoveReadOnly(szFolder);
		
	szFolder = TARGETDIR ^ "Rules";
	szPermission="(OI)(CI)WR";
	
	if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
	
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	nvResult = RemoveReadOnly(szFolder);
	
	szFolder = TARGETDIR ^ "Cache";
	szPermission="(OI)(CI)WR";
	
	if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
	
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	nvResult = RemoveReadOnly(szFolder);
	
	
	szFolder = TARGETDIR ^ "Temp";
	if ExistsDir ( szFolder ) < 0 then 
		CreateDir ( szFolder ); 
	endif;
	szPermission="(OI)(CI)WR";
	
	if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		nvResult = SetPermission(szFolder, szPermission, g_szWebservicesUser);
	endif;
	
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFolder, szUsersGroupPermission, szUsersGroup);
	
	nvResult = RemoveReadOnly(szFolder);	
	
	
    SdShowMsg("Setting user Permissions . . . please wait.",FALSE);	
	WriteToLogFile(INSTALL_LOG,"Setting up permissions Completed");
 	
return 1;
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetUpPermissions                                               //
//                                                                           //
// Purpose:   This function sets up permissions for various folders inside PM     //
//			  folder after an Installation is done                           //
///////////////////////////////////////////////////////////////////////////////

function SetPermission(szFolder, szPermission, g_szWebservicesUser)      
STRING szCommand;
NUMBER nvResult;
begin  
     
    // icacls C:\pure\rules /grant test:(OI)(CI)WR
    LongPathToQuote(szFolder,TRUE);
   	szCommand=	szFolder + " /grant " + g_szWebservicesUser + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	 
return 1;
end;
///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetupRegistryPermissions                                       //
//                                                                           //
// Purpose:   This function sets up registry permission                      //
//			  after an Installation is done                                  //
///////////////////////////////////////////////////////////////////////////////

function SetupRegistryPermissions()
begin
     
     SetObjectPermissions("MACHINE\\SOFTWARE\\Pure", IS_PERMISSIONS_TYPE_REGISTRY, "", g_szWebservicesUser, KEY_QUERY_VALUE|KEY_ENUMERATE_SUB_KEYS|KEY_NOTIFY, IS_PERMISSIONS_OPTION_ALLOW_ACCESS); 
     
     return 0;

end;
///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetupRegistryPermissionsBackoffice                             //
//                                                                           //
// Purpose:   This function sets up registry permission                      //
//			 after an Installation is done for user everyone                 //
///////////////////////////////////////////////////////////////////////////////

function SetupRegistryPermissionsBackoffice()

begin

     SetObjectPermissions("MACHINE\\SOFTWARE\\Pure", IS_PERMISSIONS_TYPE_REGISTRY, "","Everyone",STANDARD_RIGHTS_ALL|KEY_QUERY_VALUE|KEY_CREATE_LINK|KEY_SET_VALUE|KEY_CREATE_SUB_KEY|KEY_ENUMERATE_SUB_KEYS|KEY_NOTIFY,IS_PERMISSIONS_OPTION_ALLOW_ACCESS); 
     //SetObjectPermissions("MACHINE\\SOFTWARE\\Pure", IS_PERMISSIONS_TYPE_REGISTRY, "","Everyone",STANDARD_RIGHTS_ALL|KEY_SET_VALUE|KEY_CREATE_SUB_KEY,IS_PERMISSIONS_OPTION_ALLOW_ACCESS); 
		
		if (ISERR_SUCCESS) then 
		WriteToLogFile(INSTALL_LOG,"Access to Pure Registry Folder Failed");
		
		else 
		WriteToLogFile(INSTALL_LOG,"Access to Pure Registry Folder Granted");
	 endif;
	 
     return 0;

end;


////////////////////////////////////////////////////////////////////////
// Function: RemoveReadOnly
// Purpose: Removes the Read Only attribute on all files in or below the 
//          directory passed in
////////////////////////////////////////////////////////////////////////
function NUMBER RemoveReadOnly(svDirectory)
STRING szCommand;
NUMBER nvResult;
 
begin
	//attrib -r C:\Pure\*.* /s
	LongPathToQuote(svDirectory,TRUE);
   	szCommand=	"-r -s /S /D " +  svDirectory ^ "*.*";
   	WriteToLogFile(INSTALL_LOG,"Remove Read only with command=" + szCommand );
	nvResult = LaunchAppAndWait("attrib",szCommand,WAIT);

  
  return nvResult;
 end;
/***********************Registry.rul File Coding Ends*********************************************/
