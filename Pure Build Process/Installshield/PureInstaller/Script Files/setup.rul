function ReadRegistryFile()
    STRING szFilePath, szLine, szKeyPath, szValueName, szValueData, szTemp;
    NUMBER hFile, nResult, nLength, nPos, SystemID ;
    LIST listFileContents;
begin

SystemID = CurrentSystemID();


    // --- 1. Define file path ---
    szFilePath = "C:\\FreshInstallationRegistry.reg";
    
    // --- 2. Create list to hold file contents ---
    listFileContents = ListCreate(STRINGLIST);
    
    // --- 3. Load entire file into list ---
    if (ListReadFromFile(listFileContents, szFilePath) < 0) then
        MessageBox("Failed to read registry file.", SEVERE);
        ListDestroy(listFileContents);
        return 0;
    endif;
    
    // --- 4. Initialize key path ---
    szKeyPath = "";
    
    // --- 5. Process each line from the list ---
    nResult = ListGetFirstString(listFileContents, szLine);
    while (nResult != END_OF_LIST)
        
        // Skip empty lines
        if (szLine == "") then
            goto next_line;
        endif;
        
        // Skip comments (lines starting with ;)
        if (szLine[0] == ';') then
            goto next_line;
        endif;
        
        // --- Case 1: Registry Key [HKEY...] ---
        if (szLine[0] == '[') then
            // Remove [ and ] brackets
            nLength = StrLength(szLine);
            if (nLength > 2 && szLine[nLength-1] == ']') then
                szKeyPath = "";
                StrSub(szKeyPath, szLine, 1, nLength - 2);
            endif;
            
        // --- Case 2: Value Line: "Name"="Value" or @="Value" ---
        else
            // Find '=' position
            nPos = StrFind(szLine, "=");
            if (nPos > 0) then
                
                // Extract Value Name
                if (szLine[0] == '@') then
                    szValueName = "(Default)";
                else
                    // Simple extraction - assume quoted name
                    szValueName = "";
                    if (szLine[0] == '"' && nPos > 2) then
                        StrSub(szValueName, szLine, 1, nPos - 2);
                    endif;
                endif;
                
                // Extract Value Data (after '=')
                szValueData = "";
                nLength = StrLength(szLine);
                if (nPos < nLength) then
                    StrSub(szValueData, szLine, nPos + 1, nLength - nPos);
                    
                    // Remove quotes from value data
                    nLength = StrLength(szValueData);
                    if (nLength >= 2 && szValueData[0] == '"' && szValueData[nLength-1] == '"') then
                        szTemp = "";
                        StrSub(szTemp, szValueData, 1, nLength - 2);
                        szValueData = szTemp;
                    endif;
                endif;
                
                // --- Display the parsed data ---
                if (szKeyPath != "" && szValueName != "") then
                    Sprintf(szTemp, "Key: %s\nName: %s\nData: %s", szKeyPath, szValueData, szValueName );
                   // MessageBox(szTemp, INFORMATION);
                    
                    InsertRegistrySetting(szKeyPath, szValueName, "String", szValueData, SystemID);
                
                endif;
            endif;
        endif;
        
next_line:
        // Get next line
        nResult = ListGetNextString(listFileContents, szLine);
    endwhile;
    
    // --- 6. Clean up ---
    ListDestroy(listFileContents);
   
    return 0;
end;




function number BackupConfigFiles()
    STRING svConfigDir, svBackupDir;
begin
    svConfigDir = g_InstallLocation ^ "APPLICATION";
    svBackupDir = SUPPORTDIR ^ "_config_backup";
    
    if (ExistsDir(svConfigDir) != EXISTS) then
        return 0;
    endif;
    
    CreateDir(svBackupDir);
    XCopyFile(svConfigDir ^ "*.config", svBackupDir, COMP_NORMAL);
    
    return 0;
end;