//---------------------------------------------------------------------------
// OnBegin
//
// The OnBegin event is called directly by the framework after the setup
// initializes and this event is called first during the installation process
//---------------------------------------------------------------------------
function OnBegin()  
string szResult;
number nvResult;  
number nBuffer;

begin
	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
    if( REMOVEONLY = 0) then     
		//Setting the Prerequisite flag to false initially
		g_bPreRequisiteFailure = FALSE;                                  
	
		//Setting the type of Installation as Patch Installation to FALSE
		g_bPatchInstallation = FALSE;
	
		//Setting False to All Scenarios of Installation
	 	g_bFreshInstaller = FALSE;
	 	g_bUpgradeInstaller = FALSE;	
	 	g_bProductUpgradeNewInstaller = FALSE;   
	 	
	 	nBuffer = 261; // initialize size buffer before calling MsiGetProperty
		//MsiGetProperty(ISMSI_HANDLE, "SETUPEXEDIR", SETUPEXEDIR, nBuffer);
	 
		// Get the hostname of the machine.
 		GetEnvVar("COMPUTERNAME",g_szHostName); 
 		GetEnvVar("USERNAME",g_szUserName); 
 		//MessageBox(g_szUserName,INFORMATION);
 		
 		GetEnvVar ("TEMP", gTemp); 
      

 	
 		//Initializing the Count Variable 
 		g_nvSQLFileSuccessTotalCount = 0;
 		g_nvSQLFileErrorTotalCount  = 0;
  	
	
		// Test Code to Get the Path of the File
	
		nvResult = FindAllFiles("","*.txt",szResult,CONTINUE); 

		// Test Code to Get the Path of the File
 		//Get the Product Version Details like Major Version,BuildNumber 
 		//and ServiceRelease Version of the Product that needs to be installed
 		GetMajorandServiceReleaseVersionandBuildNumberforTobeInstalledProduct();
 	
 	 	
 		//Initializing the Sirius Database Name and MDF/LDF Path
 		g_szSiriusDBName = "";                                  
 		g_szMDFDirPath   = "";
 		g_szLDFDirPath   = "";
 		//Initializing the Windows Authentication Mechanism Flag to False for SQL Server Authentication
 		g_szWindowsAuthenticate = "";                                                                  
 	
 		//Initializing the SubVersion Flag (Sub Version implies "3" of 1.11.3 or 1.14.3)
 		g_szInstalledSubVersion = "0";
 	
		////Initializing Portal database name
		g_PortaDB="";
		//Validate whether the logged in user of the system is an administrator user
		//Installation prerequisite
		
		ValidateLoggedinUser();
		
		//Check for OS
		//IsOSSupported();
		
		CheckPureInstallscriptMSIInstallerExists();
		
		//RunMSXMLInstaller();
		RunCrystalReportInstaller();
		
		//Check the type of Installation for Fresh or Pure Upgrade or Product Upgrade but Fresh Installation
		//Fresh  Installation implies First Time Installation using this installer
		//Pure Upgrade Installation implies Fresh Installation followed by upgrade installation both by this installer
		//Product Upgrade but Fresh Installation implies Upgrade installation of Existing product installed by OLD installer using this new installer
		CheckTypeofInstallation();
	
	
		//This logic copies the custom controls/dlls used by the Sirius Components
		//This Includes Sherdian Controls and Other Third Party Controls
		//This is done during Fresh Installation only
		if(g_bFreshInstaller = TRUE) then
	 		GetAllTobeCopiedSupportDllNames();
	 		//CopySupportDlls();     
		endif;	              
	endif;
end;  

//---------------------------------------------------------------------------
// OnFirstUIBefore
//
// The OnFirstUIBefore event is called by the framework when the setup is
// running in first install mode. By default this event displays UI allowing
// the end user to specify installation parameters.
//---------------------------------------------------------------------------
function OnFirstUIBefore()
    number nvResult,nvStringLocation,nvStringLength,nvPMStartLocation;
    string szTitle,szMsg,szQuestion;
    string szLicenseFile;
    HWND hMSI;
    string szExistsSiriusLoginScript;
    BOOL bDBChkState;   
    string szReturnValue;    
    number nvDefault,nvAskButtonRetValue;
    string szUser,szPassword;
    STRING szICCSPath;
    STRING svBackupLocation,svTargetLocation;
    STRING szPurefolder;
    
	
begin	
    // TO DO: if you want to enable background, window title, and caption bar title                                                                   
      // SetTitle( @PRODUCT_NAME, 24, WHITE );                                        
      // SetTitle( @PRODUCT_NAME, 0, BACKGROUNDCAPTION ); 	                  
      // Enable( FULLWINDOWMODE );						   
      // Enable( BACKGROUND );							  
      // SetColor(BACKGROUND,RGB (0, 128, 128));					   

    // Added in InstallShield 15 - Show an appropriate error message if
    // -uninst is specified and the product is not installed.
    REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
    if( REMOVEONLY ) then
        Disable( DIALOGCACHE );
		szMsg = SdLoadString(IDS_IFX_ERROR_PRODUCT_NOT_INSTALLED_UNINST);
   		SdSubstituteProductInfo(szMsg);
		MessageBox(szMsg,SEVERE);
		abort;
    endif;
    
//Setting Default value for Installation type of Sirius Product
g_bAppServerOnly = TRUE;
g_bAppServerWithDB = TRUE;
g_bWebServices = FALSE;
g_bPortal = FALSE;
g_bDashBoard=FALSE;
g_WCFServices=TRUE;
g_SkipDb= FALSE;

//Flag to indicate that Database  has been created 
//in case of fresh installations  and used during abort scenarios
g_bSiriusDBCreatedFlag = FALSE;
g_bSiriusDBUpgradedFlag = FALSE;

//Setting defaults for database type
g_blankDB = FALSE;
g_brestoreDB = TRUE;

//default backup file name
g_szRestoreDBFileName="";

//Default user and password
g_szWebservicesUser="";
g_szWebservicesPassword="";
g_bPortal=FALSE;

	
Dlg_Start:
	    // beginning of dialogs label  
	    //This Label indicates the Start of Dialog Sequences in case of Fresh Installation
	    // as well as product upgrade but fresh installation
	
Dlg_SdWelcome:
		//This Dialog is used to show the Welcome Screen indicating the Start of Fresh Installation
	    szTitle = "SSP Pure Insurance Installation";  // @ID_STRING4 from Summary Information Stream 'Title'
	               	    
		#define BITMAP_ID_1 12 
		
		// Include Ifx.h for built-in InstallScript function prototypes. 
		#include "Ifx.h" 
			
	    //Enable ( BACKGROUND ); 
	    
	    //Enable ( BACKGROUND ); 
	
	    // Display the bitmap in the upper left corner. 
	    //PlaceBitmap (SSPLOGO, BITMAP_ID_1, CENTERED, CENTERED, 0); 
	    
	    // Set bitmap reveal effect. 
	    //SetDisplayEffect (EFF_REVEAL); 
	
	    if(g_bFreshInstaller = TRUE) then
	    	szMsg   = "Welcome to the Installation of Pure Insurance version "+ g_szTobeInstalledFullVersion;
	    elseif(g_bProductUpgradeNewInstaller = TRUE) then
	    	szMsg   = "Welcome to the Upgrade Installation of Pure Insurance version "+ g_szTobeInstalledFullVersion +" from Current Version "+ g_szInstalledFullVersion;
	    endif;
	    




	    nvResult = SdWelcome(szTitle,szMsg);
	    
	    if (nvResult = BACK) goto Dlg_Start;
	    
	    if(g_bProductUpgradeNewInstaller =TRUE) then
			goto  Dlg_AskInstallationType;
		endif;
 	
//Dlg_SdLicense:
		//This Dialog takes as input the License Agreement Text File
	//    szLicenseFile = SETUPEXEDIR ^ "license.txt";
	//    szTitle    = "";
	//    szMsg      = "";
	//    szQuestion = "";
	//    nvResult    = SdLicense( szTitle, szMsg, szQuestion, szLicenseFile);
	//    if (nvResult = BACK) goto Dlg_SdWelcome;
	     
Dlg_SdAskDestPath: 
	    //This Dialog gets the destination path in case of fresh installation
	 	szTitle = "";
	 	szMsg   = "Specify the Destination folder for your installation components";      	
		TARGETDIR="C:\\Pure";
	 	g_szPMInstallPath = TARGETDIR;
	    nvResult = SdAskDestPath(szTitle, szMsg, g_szPMInstallPath, 0);
	    //Check to Add Pure Folder to the Destination Path if one is not present
	    StrRemoveLastSlash(g_szPMInstallPath);
	    nvStringLength = StrLengthChars(g_szPMInstallPath);
	    nvStringLocation = StrFind(g_szPMInstallPath,"\Pure");
			
		if(nvStringLocation < 0) then 
				// if pure is not present, then add
				StrRemoveLastSlash(g_szPMInstallPath);
				g_szPMInstallPath= g_szPMInstallPath ^ "Pure";
				WriteToLogFile(INSTALL_LOG,"No pure present,Pure added in the  path" + g_szPMInstallPath);
	    	
		elseif(nvStringLocation > 0)  then   
	    	StrSub(szPurefolder, g_szPMInstallPath, nvStringLength - 4, nvStringLength);
	    	
	    	if (szPurefolder="Pure")then
				WriteToLogFile(INSTALL_LOG,"Pure present in the path" + g_szPMInstallPath);
	    	
	    	else
				//if pure is not the last in the path e.g C:\Pure\test\Pure, then add pure
				g_szPMInstallPath= g_szPMInstallPath ^ "Pure";
				WriteToLogFile(INSTALL_LOG,"Pure present, but not at the end, Pure added in the  path" + g_szPMInstallPath);
	    	
	    	endif;
	    endif;
	    
	       
		StrRemoveLastSlash(g_szPMInstallPath);
	    
	    nvStringLength = StrLengthChars(g_szPMInstallPath);
	    nvStringLocation = StrFind(g_szPMInstallPath,"\Pure");
	    //Standard PM Location
	    //nvPMStartLocation =  nvStringLength - 4;
	    
	    if(nvStringLocation < 0) then 
	    	StrRemoveLastSlash(g_szPMInstallPath);
	    //elseif((nvStringLocation > 0) && (nvStringLocation = nvPMStartLocation)) then   
	    elseif(nvStringLocation > 0)  then   
	    	g_szPMPath = g_szPMInstallPath;
	    	StrSub(g_szPMPath, g_szPMPath, 0, nvStringLength - 4);
	    	StrRemoveLastSlash(g_szPMPath);
	    endif;
	    
	    TARGETDIR = g_szPMInstallPath;
	    WriteToLogFile(INSTALL_LOG,"Final TARGETDIR=" + g_szPMInstallPath);
	    
	    
		if(g_bFreshInstaller = TRUE) then 
		
			// BSJ Registry is required early for SetupDB to work..
			
			//write the Code for handling a Fresh New Installer in Target machine
			PlacePMInstallPathforFreshRegistry(); 
	
			//Import the Registry file for the New Structure and update the Database entries in the respective keys as this 
			//ImportFreshInstallRegistryFile();
			//	ZC - 28-08 - The line below was to create the Pure Registry, this is now moved to DB.
			//UpdateRegistryEntriesAfterInstallation();
			
			
			// Check to see if that directory already exists. 
		    if (ExistsDir (g_szPMInstallPath ) != EXISTS) then 
		        // The directory does not exist; create it. 
		        if (CreateDir (g_szPMInstallPath ) < 0) then 
		            // Report the error; then abort. 
		            MessageBox ("Unable to create directory" + g_szPMInstallPath , SEVERE); 
		            abort; 
		        endif; 
			
		    endif; 	
			
	 	    // Check to see if that directory already exists. 
		    if (ExistsDir (g_szPMInstallPath ^ PURE_APPLICATION_FOLDER) != EXISTS) then 
		        // The directory does not exist; create it. 
		        if (CreateDir (g_szPMInstallPath ^ PURE_APPLICATION_FOLDER) < 0) then 
		            // Report the error; then abort. 
		            MessageBox ("Unable to create directory" + g_szPMInstallPath ^ PURE_APPLICATION_FOLDER, SEVERE); 
		            abort; 
		        endif; 
			
	    endif; 	
		endif;
	    
	    if (nvResult = BACK) goto Dlg_SdWelcome;         
        
        
        //Restore files backup during uninstallation of previous install during Fresh Install.
        if(gRestoreBackupFile=TRUE) then
                SdShowMsg ( "Restoring custom configuraion files . . . please wait." , TRUE );
				svBackupLocation=WINDISK + "\\";
				svTargetLocation=TARGETDIR;
				RestoreFiles(svBackupLocation,svTargetLocation);
				SdShowMsg ( "Restoring custom configuraion files . . . please wait." , FALSE );
        endif;
			
		
		
Dlg_AskInstallationType:
		//This Dialog is used to take 2 inputs of type
		//Appserver only which does a AppServer only Installation
		//Appserver with DB only which does a Appserver as well as Database Installation
     	szTitle    = "Pure Insurance Installation Type";
	    szMsg      = "This specifies the type of installation as Application only or Application with Database";   
	   
	   
	    if (ExistsDir (SRCDIR ^ "Portal") != EXISTS) then
				g_bPortal = FALSE;
		else
				g_bPortal = TRUE;
				GetPortalFileName();
				if(gPortalFileName="")then
					g_bPortal = FALSE;
				else
					g_bPortal = TRUE;
				endif;
		endif;
				
	    if(g_bPortal=FALSE) then
	            nvResult    = AskOptions(NONEXCLUSIVE,'Select "Create new Pure Database" if you want to create a new pure database. Uncheck "Create new Pure Database" if you want to connect to an existing Pure Database.',"Back Office",g_bAppServerOnly,"Create new Pure Database",g_bAppServerWithDB, "Dashboard",g_bDashBoard,"Pure WCF Services",g_WCFServices,"Bypass Database Installer" ,g_SkipDb); 
	    endif;
	    
	    if(g_bPortal=TRUE) then
				nvResult    = AskOptions(NONEXCLUSIVE,'Select "Create new Pure Database" if you want to create a new pure database. Uncheck "Create new Pure Database" if you want to connect to an existing Pure Database.',"Back Office",g_bAppServerOnly,"Create new Pure Database",g_bAppServerWithDB, "Pure Portal", g_bPortal,"Dashboard",g_bDashBoard,"Pure WCF Services",g_WCFServices,"Bypass Database Installer" ,g_SkipDb); 
	    endif;
	    
	    if(g_bDashBoard=TRUE && g_bAppServerOnly=FALSE) then
			MessageBox("You cannot install Dashboard unless Back Office is also installed.",INFORMATION);
			g_bAppServerOnly = TRUE;
			g_bDashBoard=TRUE;
			goto Dlg_AskInstallationType;
	    endif;
	    
	    if(g_bWebServices=TRUE && g_bAppServerOnly=FALSE) then
			MessageBox("You cannot install Web Services unless Back Office is also installed.",INFORMATION);
			g_bAppServerOnly = TRUE;
			g_bWebServices=TRUE;
			goto Dlg_AskInstallationType;
	    endif;
	    
	    if(g_WCFServices=TRUE && g_bAppServerOnly=FALSE) then
			MessageBox("You cannot install Pure WCF Services unless Back Office is also installed.",INFORMATION);
			g_bAppServerOnly = TRUE;
			g_WCFServices=TRUE;
			goto Dlg_AskInstallationType;
	    endif;
	    
	    
	    
	    //select features based on selection
	    if(g_bAppServerOnly=TRUE) then
			//FeatureSelectItem (MEDIA, "SiriusBackOffice\\AppServer", TRUE);
			FeatureSelectItem (MEDIA, "SiriusBackOffice", TRUE);
		else
			FeatureSelectItem (MEDIA, "SiriusBackOffice", FALSE);
		endif;
		if(g_bWebServices=TRUE) then
			FeatureSelectItem (MEDIA, "WebServices", TRUE);
		else
			FeatureSelectItem (MEDIA, "WebServices", FALSE);
		endif;
		if(g_bPortal=TRUE) then
			FeatureSelectItem (MEDIA, "WebPortal", TRUE);
		else
			FeatureSelectItem (MEDIA, "WebPortal", FALSE);
		endif;
		
		if(g_WCFServices=TRUE) then
			FeatureSelectItem (MEDIA, "WCFServices", TRUE);
		else
			FeatureSelectItem (MEDIA, "WCFServices", FALSE);
		endif;
	    
	    //Pre-requisiste Checks based on Installation option
	    
	    if(g_bAppServerOnly=TRUE) then
			
			CheckNET4version();
			//if(g_SkipDb=FALSE) then	
				//IsMSXML4Installed();
			//endif;
			//CheckMSOfficeversion();
	    endif;
	    
	    if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
			//if(g_SkipDb=FALSE) then	
				//IsMSXML4Installed();
			//endif;
			//IsWSE3Installed();
			CheckIISversion();
			CheckNET4version();
			IsASPNETRoleInstalled();
		endif;
		
		if(g_bPortal=TRUE) then
			//if(g_SkipDb=FALSE) then	
				//IsMSXML4Installed();
			//endif;
			//IsWSE3Installed();
			CheckIISversion();
			CheckNET4version();
			IsASPNETRoleInstalled();
			//CheckSilverLightversion();
		endif;
	    
	    
	    if (nvResult = BACK) then
	    	   if(g_bProductUpgradeNewInstaller = TRUE) then
	    	   	   goto Dlg_SdWelcome;
	    	   else//Fresh Installation
	    	       goto Dlg_SdAskDestPath;
	    	   endif;
        else //at the Click of Next Button  
	           goto Dlg_UserInformation; 	
	    endif; 
 
Dlg_UserInformation:
	if(g_bWebServices=TRUE || g_bPortal=TRUE || g_WCFServices=TRUE) then
		 g_szAppPoolPortal="PurePortalAppPool";
		 g_szApplicationPortal="Pure.Portal";
		 g_szPhysicalPathPortal=IISROOTFOLDER ; //^ g_PortalFolderName;
		 //g_szWebServiceUrl="http://" + g_szHostName + "/PureWebServices/SAMForInsuranceV2.asmx";
		 g_szDocumentsLocation=TARGETDIR ^ "DocZipTemp";
		 g_szReportsLocation=TARGETDIR ^ "Reports";
		 g_szTempFileLocation=TARGETDIR ^ "DocZipTemp";
         szTitle = "";
	 	 //szMsg   = "Specify the User and Password for configuring Web Services and setting permissions on Pure Application folders. Make sure user is a member of the IIS_IUSRS group on the Web server so that the account can access the appropriate resources.";  
		 szMsg = "Specify the User and Password for configuring Web Services and setting permissions on Pure Application folders. Make sure user is a member of the IIS_IUSRS group on the Web server. User accounts must be in the format DOMAIN\\Username";  
		 szUser="User:";
		 szPassword="Password:";

		  //log Mode 
		if (MODE=SILENTMODE) then 
	   	  WriteToLogFile(INSTALL_LOG,"SilentMode" );
		Delay(40);
		else
		  WriteToLogFile(INSTALL_LOG,"MSI Mode" );
        endif;
	
		 
		 //if (MODE = SILENTMODE) then
		 	nvResult= SdShowDlgEdit2 ( szTitle, szMsg, szUser, szPassword, g_szWebservicesUser,g_szWebservicesPassword);
		//else
			//nvResult= SdLogonUserInformation ("", szMsg,  g_szWebservicesUser, g_szWebservicesPassword);
		//endif;

		 if(nvResult = BACK) then
				goto Dlg_AskInstallationType;
		 endif; 
		 if(g_szWebservicesUser="")then
		       MessageBox("Username cannot be empty, Please specify a valid user.",INFORMATION);
		       goto Dlg_UserInformation;
		 endif;
		 
		 if(g_szWebservicesPassword="")then
				MessageBox("Password cannot be empty, Please specify a valid password.",INFORMATION);
		       goto Dlg_UserInformation;
		 endif;

	 
		 if (ValidateUserCredentials() = FALSE) then
				MessageBox("Login failed, please provide the Username and Password correctly.\n\n",INFORMATION);
				goto Dlg_UserInformation;
	     endif;

	     
		 TextSubSetValue("<APPPOOLUSERID>", g_szWebservicesUser, TRUE);
		 TextSubSetValue("<APPPOOLPASSWORD>", g_szWebservicesPassword, TRUE);
	endif;
		  
		 //MsiSetProperty( ISMSI_HANDLE, "APPPOOLUSERID", g_szWebservicesUser );
		 //MsiSetProperty( ISMSI_HANDLE, "APPPOOLPASSWORD", g_szWebservicesPassword );
		 
		
Dlg_EmailConfiguration:
		 if(g_bWebServices=TRUE) then
			nvResult = EmailConfiguration();
			if(nvResult = BACK) then
				goto Dlg_UserInformation;
			endif; 
		 endif; 
		  
Dlg_PortalDetails:
		 if(g_bPortal=TRUE) then
				GetPortalFileName();
				nvResult = SdPurePortal();
				WriteToLogFile(INSTALL_LOG,"Pure Portal Application=" + g_szApplicationPortal);
				WriteToLogFile(INSTALL_LOG,"Pure Portal Physical Path=" + g_szPhysicalPathPortal ^ g_PortalFolderName);
				WriteToLogFile(INSTALL_LOG,"Pure Portal ApplicationPool=" + g_szAppPoolPortal);
				TextSubSetValue("<PUREPORTALAPP>", g_szApplicationPortal, TRUE);
				TextSubSetValue("<PUREPORTALAPPPOOL>", g_szAppPoolPortal, TRUE);
				TextSubSetValue("<PUREPORTALPATH>", g_szPhysicalPathPortal ^ g_PortalFolderName, TRUE);
				if(nvResult = BACK) then
						goto Dlg_UserInformation;
				endif; 
		 endif;
		 
Dlg_PureSTSDetails:
		 if(g_bPortal=TRUE) then
				nvResult = PureSTSConfiguration();
				
				if(nvResult = BACK) then
					goto Dlg_PortalDetails;
				endif; 
		 endif;			 
		 
Dlg_PortalConfigPath:
		 if(g_bPortal=TRUE) then
				nvResult = SdPortalConfigPath();
				//WriteToLogFile(INSTALL_LOG,"PureWebServices URL=" + g_szWebServiceUrl);
				WriteToLogFile(INSTALL_LOG,"Pure Application Server Name=" + g_szPureAppServerName);
				WriteToLogFile(INSTALL_LOG,"Documents Location=" + g_szDocumentsLocation);
				WriteToLogFile(INSTALL_LOG,"Reports Location=" + g_szReportsLocation);
				WriteToLogFile(INSTALL_LOG,"Temp Location=" + g_szTempFileLocation);
				
				if(nvResult = BACK) then
						goto Dlg_PureSTSDetails;
				endif; 
				CopyPortalFiles();
		 endif;

	 
		 
		 if(g_bAppServerOnly && g_bAppServerWithDB=FALSE) then
	        		 if(g_bProductUpgradeNewInstaller = TRUE) then
	        	 	 	//goto Dlg_SQLTestConnectDBforProductUpgradeFreshInstallation;        
	        	 	 	  goto Dlg_DialogEnd;
	        	 	 else
	        	 	 	goto Dlg_SQLTestConnectDBforAppServerOnlyFreshInstallation; 
	        	 	 endif;
	     elseif (g_bAppServerWithDB=TRUE) then //AppServer with DB Installation
	   				 if(g_bProductUpgradeNewInstaller = TRUE) then 
	   				 	szQuestion = "Please take a backup of the database \""+g_szSiriusDBName+"\"  Version \""+g_szInstalledProductVersion+"\" from the DBServer \""+g_szDBServer+"\". Click YES to proceed, if backup is taken already or Click NO to abort the installation";
	 	   	   			nvDefault = NO;
						nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
						if(nvAskButtonRetValue = YES) then
	     		   	 	 	goto Dlg_SQLTestConnectDBforProductUpgradeFreshInstallation;
	     		   	 	else
	     		   	 		abort;
	     		   	 	endif;
	        	 	 else
	        	 	 	goto Dlg_SQLConnectToDBforAppWithDBFreshInstallation; 
	        	 	 endif;
	     endif;
		  

//DB Server Connection Details for AppServer only type Fresh Installation
 Dlg_SQLTestConnectDBforAppServerOnlyFreshInstallation:
      //This Dialog is used to take DBServer/Sirius Database name as input for appserver only type of installations
	  //Used for filling up the registry to connect to the required DB server
	  //nvResult = OnSQLLogin(NEXT); 
	  if(g_bAppServerOnly && g_bAppServerWithDB=FALSE ) then
			nvResult=OnSQLServerInitialize(NEXT);
	  endif;
	  
	  if(nvResult = BACK) then
			if(g_bPortal=TRUE) then
				  	goto Dlg_PortalConfigPath;
		    else
				if(g_bWebServices=TRUE) then
					goto Dlg_EmailConfiguration;
				else
					goto Dlg_AskInstallationType;
				endif;
		    endif;
	  else   
	  	//Used for Testing Purpose 
	  //SetPMLogicalDatabaseFolderVersionsToInstallerVariables(); 
	  //StartUpgradeDBScriptsExecution("");
	  //Used for Testing Purpose
		if(g_bAppServerOnly && g_bAppServerWithDB=FALSE && g_SkipDb = FALSE) then
			CompareDatabaseServerDateTime();
			CompareDatabaseCollation();
	  	
			//Set the Compatibility level of the newly created DB to SQLSERVER 2000 format
			SetFreshDBCompatibilityLevel();
	  	
			//Get the Scripts Folder Version for the Freshly installed Sirius Backup
			SetPMLogicalDatabaseFolderVersionsToInstallerVariables(); 
			
			//setup the ODBC
			InstallODBCDSNs();
			//Method Call to Run Upgrade DBScripts for Product Upgrade but Fresh Installation
			Disable( DIALOGCACHE );
			StartUpgradeDBScriptsExecution(SRCDIR ^ "Scripts");
			Enable( DIALOGCACHE );
			//Update the PMLogicalDatabase with the Current Version of the Installation
			SetUpgradedFolderVersionsToPMLogicalDatabase();

			goto Dlg_SdStartCopy;
	  	endif;
	  endif;  
		   
//DB Server Connection Details for AppServer with DB type Fresh Installation		   
 Dlg_SQLConnectToDBforAppWithDBFreshInstallation:
	  //This Dialog is used in case of Appserver with DB only type of Fresh Installation
	  //used to take DBServer/Login Credentials to connect to the DB Server
	  //nvResult =OnSQLLogin(NEXT);
	if (g_bAppServerWithDB=TRUE) then
	  nvResult=OnSQLServerInitialize(NEXT);
	endif;
	
	 if(nvResult = BACK) then
			if(g_bPortal=TRUE) then
				  	goto Dlg_PortalConfigPath;
		    else
					if(g_bWebServices=TRUE) then
					goto Dlg_EmailConfiguration;
					else
						goto Dlg_AskInstallationType;
					endif;
		    endif;
	  endif;	
	  //Get the Default Path for MDF and LDF files depending on the HostMachine
	  //if Local Machine set the default installation path
	  //Setting the MDF Path
	if (g_bAppServerWithDB=TRUE) then
	  CompareDatabaseServerDateTime();
	  CompareDatabaseCollation(); 
	  
	  //Set the Compatibility level of the newly created DB to SQLSERVER 2000 format
	  //SetFreshDBCompatibilityLevel();
	
	  if(StrLengthChars(g_szMDFDirPath) = 0) then
	  	if(StrCompare(g_szDBServer,g_szHostName)=0)  then
	 	 	//g_szMDFDirPath = PROGRAMFILES ^ DEFAULTMDFPATH;
		  	g_bRemoteDBServer = FALSE;
	  	elseif(StrFind(g_szDBServer,"(local)") >= 0) then
	  		//g_szMDFDirPath = PROGRAMFILES ^ DEFAULTMDFPATH;
		  	g_bRemoteDBServer = FALSE;
		elseif(StrFind(g_szDBServer,g_szHostName) >= 0) then
	  		//g_szMDFDirPath = PROGRAMFILES ^ DEFAULTMDFPATH;
		  	g_bRemoteDBServer = FALSE;
	  	else 
	  	    g_bRemoteDBServer = TRUE;
	  	endif;    
	  endif;
	  //Setting the LDF Path
	  if(StrLengthChars(g_szLDFDirPath) = 0) then
	  	if(StrCompare(g_szDBServer,g_szHostName)=0)  then
	 	 	//g_szLDFDirPath = PROGRAMFILES ^ DEFAULTLDFPATH;
		  	g_bRemoteDBServer = FALSE;
	  	elseif(StrFind(g_szDBServer,"(local)") >= 0) then
	  		//g_szLDFDirPath = PROGRAMFILES ^ DEFAULTLDFPATH;
		  	g_bRemoteDBServer = FALSE;
		elseif(StrFind(g_szDBServer,g_szHostName) >= 0) then
	  		//g_szMDFDirPath = PROGRAMFILES ^ DEFAULTMDFPATH;
		  	g_bRemoteDBServer = FALSE;
	  	else 
	  	    g_bRemoteDBServer = TRUE;
	  	endif;        
	 endif;
	  
	  if(nvResult = NEXT) goto Dlg_SQLCreateNewDB;
	  endif;

 // DB Server Connection Details for both AppServer only and AppServer with DB type ProductUpgrade but Fresh Installation
 Dlg_SQLTestConnectDBforProductUpgradeFreshInstallation:
 	  //This Dialog is used in case of Appserver with DB only type of Product Upgrade But Fresh Installation
	  //used to take DBServer/Login Credentials to connect to the DB Server
	  //BSJ Ignore Dialogue
	  //nvResult =OnSQLLogin(NEXT);  
	if (g_bAppServerWithDB=TRUE) then
	  nvResult=OnSQLServerInitialize(NEXT);
	endif;

	  if(nvResult = BACK) then
			if(g_bPortal=TRUE) then
				  	goto Dlg_PortalConfigPath;
		    else
					if(g_bWebServices=TRUE) then
					goto Dlg_EmailConfiguration;
					else
						goto Dlg_AskInstallationType;
					endif;
		    endif;
	  endif;

	if (g_bAppServerWithDB=TRUE) then 

  	  CompareDatabaseServerDateTime();
	  CompareDatabaseCollation();
	  
	  //Set the Compatibility level of the newly created DB to SQLSERVER 2000 format
		SetFreshDBCompatibilityLevel();

	  if(g_bAppServerWithDB = TRUE) then
	  	//Create database normal/error log files 
	 	CreateLogFile(DATABASE_LOG);       
	 	CreateLogFile(DATABASE_ERRORLOG);  
	 	
	 	CheckPMUsersLoggedOn();
	  
	  	//Get the Scripts Folder Version for the Freshly installed Sirius Backup
		SetPMLogicalDatabaseFolderVersionsToInstallerVariables(); 
		//Method Call to Run Upgrade DBScripts for Product Upgrade but Fresh Installation
		//setup ODBC
		InstallODBCDSNs();
		
		Disable( DIALOGCACHE );
	  	StartUpgradeDBScriptsExecution(SRCDIR ^ "Scripts");
	  	Enable( DIALOGCACHE );
	  	//Update the PMLogicalDatabase with the Current Version of the Installation
		SetUpgradedFolderVersionsToPMLogicalDatabase();
	  endif;
	  if(nvResult = NEXT) goto Dlg_ProductUpgradeButFreshInstallResume;
	  
	  endif;
	  
 Dlg_SQLCreateNewDB:  
		
	if (g_bAppServerWithDB=TRUE) then
	    szTitle    = "Pure Insurance database creation Type";
	    
	    SetDialogTitle ( DLG_ASK_OPTIONS, szTitle ); 
        nvResult    = AskOptions(EXCLUSIVE,"Select the type of Database Required","Create a blank database",g_blankDB,"Restore existing database",g_brestoreDB); 
	    
	    if (nvResult = BACK) then
	    	  goto Dlg_SQLConnectToDBforAppWithDBFreshInstallation;
	    endif;
	    
		if(g_bRemoteDBServer = FALSE) then
			if(g_blankDB=TRUE) then
				// Pass default backup DB name 
				//Don't do anything, currently hardcoded backup file name is provided already 
				goto Dlg_DBDetails;
			endif;
	    
			if(g_brestoreDB=TRUE) then
				goto Dlg_SelectBackupFile;  
			endif;
		endif;
		
		//for remote db ask for UNC path of shared location with Full permission on remote server such that 
		if(g_bRemoteDBServer = TRUE) then
			if(g_blankDB=TRUE) then
				// Pass default backup DB name 
				//Don't do anything, currently hardcoded backup file name is provided already 
				//SelectDir ( "", "Select the Shared location:", gSharedPath, FALSE );
				SetDialogTitle ( DLG_ASK_PATH, "Select the Share location" );
				AskPath ( "Select the Shared folder location(UNC Path) on the database server", "", gSharedPath ); 
				StrRemoveLastSlash ( gSharedPath ); 
				goto Dlg_DBDetails;
			endif;
	    
			if(g_brestoreDB=TRUE) then
				SetDialogTitle ( DLG_ASK_PATH, "Select the Share location" );
				AskPath ( "Select the Shared folder location(UNC Path) on the database server", "", gSharedPath ); 
				StrRemoveLastSlash ( gSharedPath );  
				goto Dlg_SelectBackupFile;  
			endif;
		endif;
    else
		goto Dlg_SdStartCopy;
		
	endif;
		
		
		
Dlg_SelectBackupFile:
         
		 nvResult=SdBrowseFile(hMSI,g_szRestoreDBFileName);
		 
		 if(nvResult = -1) goto Dlg_SQLCreateNewDB;
		
Dlg_DBDetails:
		
		if(g_bRemoteDBServer = TRUE) then
				SdShowMsg ( "Copying database backup file to database server . . . please wait." , TRUE );
				CopyDatabasebackupToRemoteServer();
				SdShowMsg ( "Copying database backup file to database server . . . please wait." , FALSE );
		endif;
		
		//This Dialog is used in case of AppServer with DB only type of Fresh Installation
	    //for getting New Sirius DB name and MDF/LDF path  
	    nvResult = ExFn_NewDBDetailsDefineDialog(hMSI,g_szDBServer,g_szMasterUser,g_szMasterPassword,g_szSiriusDBName,g_szMDFDirPath,g_szLDFDirPath);
	    if(nvResult = -1) then
	       if(g_brestoreDB=TRUE) then
	            goto Dlg_SelectBackupFile;
	       endif;
	       
	        if(g_blankDB=TRUE) then
				goto Dlg_SQLCreateNewDB;
	        endif;
	        
	    endif;
	    
  
 Dlg_ICCSNumber: 
 		//This Dialog takes as input a 4 digit ICCS number as input 
  		nvResult = ExFn_ICCSNumberDialog(hMSI,g_szICCSNumber);
		if(nvResult = -1) goto Dlg_DBDetails;   
		
		nvResult = ReplaceICCSNumber(SUPPORTDIR ^ ICCSFILENAME);
		if(nvResult=-1) then
				MessageBox("ICCS Number Entry failed.Check for Issues",SEVERE);
		endif;  

		//StrToNum(n_szICCSNumber, g_szICCSNumber);
		
				
 Dlg_SelectLicenseFile:
         
         //if(g_szICCSNumber="4033")then
			// Do not ask for License File
		 //	gPMLicenceFile= SRCDIR ^ "PMLicence.ini";
			
         //else
         
		//	nvResult=SdPMLicenseFileFile(hMSI,gPMLicenceFile);
		 
		//	if(nvResult = -1) goto Dlg_ICCSNumber;
			
		 // endif;
		
		
		 //nvResult=SelectPMLicenseFile (gPMLicenceFile);
			
		//Create database normal/error log files 
	 	CreateLogFile(DATABASE_LOG);       
	 	CreateLogFile(DATABASE_ERRORLOG);			
		
		//Create the New Sirius Database from the backup file
		Disable( DIALOGCACHE );
		CreateSiriusDatabaseFromBackup();     
		Enable( DIALOGCACHE );      
		         
		//Flag to indicate new Sirius DB is created.
		g_bSiriusDBCreatedFlag = TRUE;
		
		//Set the Compatibility level of the newly created DB to SQLSERVER 2000 format
		SetFreshDBCompatibilityLevel();
		
		//Execute the ICCS number Script in the newly created database
		szICCSPath = WINDISK + "\\";
		ParseSQLFile(szICCSPath ^ ICCSFILENAME);                   
		
		if(g_bWinLoginAuthenticate =FALSE) then
			//Create the Inbuilt Sirius Username/Password for use by Sirius Back Office Application
        	//CreateSiriusLogin();
        else
        	//Leave as such without creating the Sirius Username/Password 
        	//as Windows Authentication is used by Sirius BackOffice Application
		endif;			            
		
		
		//Install the ODBC DSN's for Sirius Back Office Application		 
		InstallODBCDSNs();
		
		//Get the Scripts Folder Version for the Freshly installed Sirius Backup
		SetPMLogicalDatabaseFolderVersionsToInstallerVariables(); 
		
		//Method Call to Run Upgrade DBScripts for higher version on top of the Sirius DB
		Disable( DIALOGCACHE );
		StartUpgradeDBScriptsExecution(SRCDIR ^ "Scripts");                                                
		Enable( DIALOGCACHE );
		//Update the PMLogicalDatabase with the Current Version of the Installation
		SetUpgradedFolderVersionsToPMLogicalDatabase();



Dlg_SdStartCopy:
		if(g_bWebServices=TRUE) then
			CreatePureWebServicesRegistry();
			if(g_SkipDb=FALSE) then
				UpdatePureWebServicesWebConfig();
			endif; 						  
		endif;
		if(g_bPortal=TRUE && g_SkipDb =FALSE) then
			szQuestion= "Do you want to create a new Pure Portal database?\n\n" +
						"Click YES to 'create a new Pure Portal database' or Click NO to 'update the existing Pure Portal database'.";
			nvDefault = NO;
			nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
			if(nvAskButtonRetValue = YES) then
				g_bCreatePurePortalDatabase=TRUE;
				// Ask SQL Server Connection details
			Dlg_SdSQLConnectionPortal:
				//nvResult = SdSQLConnectionPortal();	
				nvResult = PurePortalDatabaseDetails();	
				WriteToLogFile(INSTALL_LOG,"Portal DB Server=" + g_PortalDBServer);
				WriteToLogFile(INSTALL_LOG,"Pure Portal Login ID=" + g_PortalUser);
				WriteToLogFile(INSTALL_LOG,"Pure Portal Password=" + g_PortalPwd);
				WriteToLogFile(INSTALL_LOG,"Pure Portal DB Name=" + g_PortaDB);
				if(StrCompare(g_PortalDBServer,g_szHostName)=0)  then
					g_bPortalRemoteDBServer = FALSE;
				elseif(StrFind(g_PortalDBServer,"(local)") >= 0) then
					g_bPortalRemoteDBServer = FALSE;
				elseif(StrFind(g_PortalDBServer,g_szHostName) >= 0) then
					g_bPortalRemoteDBServer = FALSE;
				else 
					g_bPortalRemoteDBServer = TRUE;
				endif;   
				if(g_bPortalRemoteDBServer = TRUE) then
					// Pass default backup DB name 
					//Don't do anything, currently hardcoded backup file name is provided already 
					//SelectDir ( "", "Select the Shared location:", gSharedPath, FALSE );
					SetDialogTitle ( DLG_ASK_PATH, "Select the Share location" );
					AskPath ( "Select the Shared folder location(UNC Path) on the database server", "", gPortalSharedPath ); 
					StrRemoveLastSlash ( gPortalSharedPath ); 
				endif;
				if(g_bPortalRemoteDBServer = TRUE) then
					SdShowMsg ( "Copying database backup file to database server . . . please wait." , TRUE );
					CopyPortalDatabasebackupToRemoteServer();
					SdShowMsg ( "Copying database backup file to database server . . . please wait." , FALSE );
				endif;
				// Ask new DB details
			Dlg_SdPortalnewdbdetails:
				nvResult = SdPortalnewdbdetails(hMSI,g_PortalDBServer,g_PortalUser,g_PortalPwd,g_PortaDB,g_PortalMDFDirPath,g_PortalDFDirPath);
				if(nvResult = BACK) then
					goto Dlg_SdSQLConnectionPortal;
				endif;
				//Create Portal database
				Disable( DIALOGCACHE );
				CreatePortalDatabaseFromBackup();
				Enable( DIALOGCACHE );
				
				//Set Compatibility Level
				SetPortalCompatibilityLevel();
				
				//Update Tbl_Portal table
				AddEditTbl_Portal();
				WriteToLogFile(INSTALL_LOG,"New Portal database created");
			else
				// Ask SQL Server Connection details
				WriteToLogFile(INSTALL_LOG,"Update existing portal database");
				Disable(BACKBUTTON);
				//nvResult = SdSQLConnectionPortal();	
				nvResult=PurePortalDatabaseDetails();
				//Set Compatibility Level
				SetPortalCompatibilityLevel();
				//Update Tbl_Portal table
				//AddEditTbl_Portal();
			endif;
			// create portal registry
			Disable( DIALOGCACHE );
			CreatePortalRegistry();
			Enable( DIALOGCACHE );
			
			szQuestion= "Do you want to copy existing web.config file to new Pure Portal location?\n\n" +
						"Click YES to 'copy existing web.config file' or Click NO to 'copy new web.config file'.";
			nvDefault = NO;
			nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
			if(nvAskButtonRetValue = YES) then
					//Browse for path of OLD web.config
					//Copy web.config
					//nvResult=SdBrowseFile(hMSI,g_szWebFileName);
					//nvResult = SelectFile ( g_szWebFileName); 
					WriteToLogFile(INSTALL_LOG,"copy existing web.config file");
					nvResult=SelectWebConfigFile(g_szWebFileName);
					CopyOLDWebConfig();
					MessageBox("Please update the portal web.config file manually after Installation, please refer to release notes for the details.",INFORMATION);
			else
				   //
			//Update Portal web config
			WriteToLogFile(INSTALL_LOG,"copy new web.config file");
			UpdatePortalWebConfig();
			endif;
		endif;
		
		
		//DashBoard database creation
		//g_DashBoardDB="SiriusMonitorDB";
	if(g_bDashBoard=TRUE)then
		    szQuestion= "Do you want to create a new Pure Dashboard database?\n\n" +
						"Click YES to 'create a new Pure Dashboard database' or Click NO to 'update the existing Pure Dashboard database'.";
			
			nvDefault = NO;
			nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
			
			if(nvAskButtonRetValue = YES) then
				//GetDashBoardRegistry();
				//if(g_DashBoardExists=FALSE) then
			
				Dlg_SdSQLConnectionDashBoard:
				
					if(StrCompare(g_szDBServer,g_szHostName)=0)  then
						g_bRemoteDBServer = FALSE;
					elseif(StrFind(g_szDBServer,"(local)") >= 0) then
						g_bRemoteDBServer = FALSE;
					elseif(StrFind(g_szDBServer,g_szHostName) >= 0) then
						g_bRemoteDBServer = FALSE;
					else 
						g_bRemoteDBServer = TRUE;
					endif;   
				
					if(g_bRemoteDBServer = TRUE) then
						// Pass default backup DB name 
						//Don't do anything, currently hardcoded backup file name is provided already 
						//SelectDir ( "", "Select the Shared location:", gSharedPath, FALSE );
						SetDialogTitle ( DLG_ASK_PATH, "Select the Share location" );
						AskPath ( "Select the Shared folder location(UNC Path) on the database server", "", gDashBoardSharedPath ); 
						StrRemoveLastSlash ( gDashBoardSharedPath ); 
					endif;
				
					if(g_bRemoteDBServer = TRUE) then
						SdShowMsg ( "Copying database backup file to database server . . . please wait." , TRUE );
						CopyDashBoardDatabasebackupToRemoteServer();
						SdShowMsg ( "Copying database backup file to database server . . . please wait." , FALSE );
					endif;
					// Ask new DB details
				Dlg_SdDashBoardnewdbdetails:
					nvResult = SdDashBoardnewdbdetails(hMSI,g_szDBServer,g_szMasterUser,g_szMasterPassword,g_DashBoardDB,g_DashBoardMDFDirPath,g_DashBoardLDFDirPath);
					if(nvResult = BACK) then
						goto Dlg_SdSQLConnectionDashBoard;
					endif;
					//Create DashBoard database
					Disable( DIALOGCACHE );
					CreateDashBoardDatabaseFromBackup();
					Enable( DIALOGCACHE );
				
			else
				// DO not create DashBoard database
				SdSQLConnectionDashBoard();
				
			endif;
	endif;
        
        

//08-08-2025
//This is the change to accommodate the usage of the Pure DB instead of the Registry.

		if(g_bFreshInstaller = TRUE) then 
		
			
				CreateRegistrySettingTable();  
				ReadRegistryFile();
				UpdateDBRegistryEntriesAfterInstallation();
				CheckOrCreatePureConfig();
			endif;		





        //This Dialog initiates the start copy of the Appserver components
		if(g_bFreshInstaller = TRUE) then
			//Allow the Default Title and Message to be displayed for Fresh Installation
			szTitle = "";
			szMsg   = "Click Install to begin the Installation of SSP Pure Insurance Product Version "+g_szTobeInstalledFullVersion+".";
		else 
			//Customise the Title and Message to be displayed for Product Upgrade but Fresh Installation
			szTitle = "Upgrade Installation";
			szMsg   = "Click Install to begin the Upgrade Installation of SSP Pure Insurance Product to Version "+g_szTobeInstalledFullVersion+" from Current Version "+g_szInstalledFullVersion;  
		endif;
		
		//Back Button enabled AppServer Only Installation and Disabled for AppServer with DB Installation
		if(g_bAppServerOnly = TRUE && g_bAppServerWithDB = FALSE) then 
			Enable(BACKBUTTON);             
		elseif(g_bAppServerWithDB = TRUE) then
			Disable(BACKBUTTON);
		endif;   
		
		nvResult = SdStartCopy2(szTitle,szMsg);			
		//for Back Button Click
		if (nvResult = BACK) then       
			if(g_bFreshInstaller = TRUE) then
					goto Dlg_SQLTestConnectDBforAppServerOnlyFreshInstallation;
			elseif( g_bProductUpgradeNewInstaller = TRUE) then
				goto Dlg_SQLTestConnectDBforProductUpgradeFreshInstallation;
			endif;
		endif;                 
		//for Next Button Click
		if(g_bFreshInstaller = TRUE) then
			goto Dlg_DialogEnd;
		endif;
		
		
		
Dlg_ProductUpgradeButFreshInstallResume:
    //szTitle = "Resume Upgrading Component Installation";
	//szMsg   ="Databases are Installed. Click Next to Continue upgrading the Application Components to "+g_szTobeInstalledFullVersion+" from current version "+g_szInstalledFullVersion;
	//Disable(BACKBUTTON);
    //nvResult = SdWelcome(szTitle,szMsg);
    
Dlg_DialogEnd:
    if(g_bFreshInstaller = TRUE) then
		//Status Message for Fresh Installation of Sirius Back Office 
    	// Added in IS 2009 - Set appropriate StatusEx static text.
    	szMsg = "Installer is Installing the SSP Pure Insurance Version "+g_szTobeInstalledFullVersion+" in your system."; 
    	SetStatusExStaticText(szMsg);
    	//SetStatusExStaticText(SdLoadString(IDS_IFX_STATUSEX_STATICTEXT_FIRSTUI));
    else
     	//Status Message for Product Upgrade but Fresh Installation of Sirius Back Office.
    	// Added in IS 2009 - Set appropriate StatusEx static text.
    	 szMsg = "Installer is Upgrading the SSP Pure Insurance to Version "+g_szTobeInstalledFullVersion+" from Current Version "+g_szInstalledFullVersion;
    	SetStatusExStaticText(szMsg);
    endif;
    

    // setup default status
    Enable(STATUSEX);
 
    return 0;
end;                      

//---------------------------------------------------------------------------
// OnFirstUIAfter
//
// The OnFirstUIAfter event called by the framework after the file transfer
// of the setup when the setup is running in first install mode. By default
// this event displays UI that informs the end user that the setup has been
// completed successfully.
//---------------------------------------------------------------------------
function OnFirstUIAfter()
    STRING szTitle, szMsg1, szMsg2, szOpt1, szOpt2,szFileName;
    NUMBER bOpt1, bOpt2;
begin
	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
	Disable(STATUSEX);
	
	szFileName = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "WCFSecurityTokenFile.txt";
	if(g_WCFServices=TRUE) then
		if Is(FILE_EXISTS, szFileName) = TRUE then
			ReadWCFSecurityTokenFile();
		else
			RunGenerateWCFTokenID();
		
			ReadWCFSecurityTokenFile();
		endif;
	endif;

	if(g_bAppServerOnly=TRUE || g_WCFServices=TRUE) then
		
		if(g_SkipDb=FALSE) then
			ReadPureConfigFiles();
		endif; 	
		
	endif;
	
	if(g_bAppServerOnly=TRUE || g_bWebServices=TRUE || g_WCFServices=TRUE) then
		
		RemoveFilesDuringInstall();
	
	endif;
	
	/*
	if(g_bAppServerOnly=TRUE) then
		UpdatePMWorkManagerConfig();
	endif;
	
	if(g_WCFServices=TRUE) then
		UpdateWCFServiceConfig();
	endif;
	*/
	
	if(g_bPortal=TRUE || g_WCFServices=TRUE) then
		LoadAppPoolUserProfile();
	endif;
	
	if(g_bPortal=TRUE) then
		ModifyPortalApplicationSetting();
		
		//BSJ Call the registry functions after upgrade 
		UpdateDBRegistryEntriesAfterInstallation();
		
		
		//Configure ASP .NET state service
		ConfigureAspDotNetSateService();
	
	endif;
	
	/*if(g_bPortal=TRUE) then
		CopyCrystalReportWebFormViewer4Files();
	endif;*/
	
	

	bOpt1   = FALSE;
    bOpt2   = FALSE;    

    if(g_bFreshInstaller = TRUE) then
    //Title and Message Box text for Fresh Installation
	    szTitle = "SSP Pure Installation";
	    szMsg1 = "SSP Pure Insurance Installation has successfully installed the Version "+g_szTobeInstalledFullVersion+" in your System.Click Finish to exit the Wizard"; 
    else
	    //Title and Message Box text for Product Upgrade but Fresh Installation
	    szTitle = "SSP Pure Upgrade Installation Complete";    
	    szMsg1 = "SSP Pure Insurance Installation has successfully upgraded to Version "+g_szTobeInstalledFullVersion+" from Version "+g_szInstalledFullVersion+".Click Finish to exit the Wizard";     
    endif;
    
    szMsg2 = "Click Finish to exit %P setup."; 
	
  	SdFinish(szTitle,szMsg1,szMsg2,"","", bOpt1, bOpt2);

end;

