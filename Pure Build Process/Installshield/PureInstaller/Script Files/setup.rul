///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  CheckNET35version  								                                         //
//                                                                                                       //
// Purpose:   This function check for .NET Framework version 3.5 SP1                                     //
//                                                                                                       //
///////////////////////////////////////////////////////////////////////////////////////////////////////////
/*function CheckNET35version()
STRING szKey,szVersion,szValue,szMsg;
NUMBER nSize,nType;
begin
    
    nSize= -1;
    nType= REGDB_NUMBER;
    
    szKey="SOFTWARE\\Microsoft\\NET Framework Setup\\NDP\\v3.5";
    szVersion="SP";

	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if(RegDBKeyExist(szKey)=1) then
		if (RegDBGetKeyValueEx (szKey, szVersion, nType, szValue, nSize) < 0) then 
			 MessageBox("This computer does not have the correct version of the .NET Framework installed, the minimum supported version is 3.5 SP1. Please install this Framework and re-run the Installer.",SEVERE);
			 abort;
		else
			 if(szValue="1")then
				szMsg = ".NET Framework 3.5 is Installed, SP= " + szValue + ".";
				WriteToLogFile(INSTALL_LOG,szMsg);
			 else
				MessageBox("This computer does not have the correct version of the .NET Framework installed, the minimum supported version is 3.5 SP1. Please install this Framework and re-run the Installer.",SEVERE);
				abort;
			 endif;
		endif;  
	else
		MessageBox("This computer does not have the correct version of the .NET Framework installed, the minimum supported version is 3.5 SP1. Please install this Framework and re-run the Installer.",SEVERE);
		abort;
	endif;

    return 0;
   
end;
*/
///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  CheckNET4version  								                                         //
//                                                                                                       //
// Purpose:   This function check for .NET Framework version 4.5                                         //
//                                                                                                       //
///////////////////////////////////////////////////////////////////////////////////////////////////////////
function CheckNET4version()
STRING szKey,szVersion,szValue,szMsg;
NUMBER nSize,nType,nValue;
STRING szRelease,sVersion;
begin
    
	nSize= -1;
    nType= REGDB_NUMBER;
    
    szKey="SOFTWARE\\Microsoft\\NET Framework Setup\\NDP\\v4\\Full";
    szRelease="Release";
    sVersion= "Version" ;
    
    RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if(RegDBKeyExist(szKey)=1) then
		//szMsg = ".NET Framework 4.0 is Installed.";
		//WriteToLogFile(INSTALL_LOG,szMsg);
		
		if (RegDBGetKeyValueEx (szKey, sVersion, nType, szValue, nSize) < 0) then
			// .Net 4.5 not installed
			MessageBox("This computer does not have the correct version of the .NET Framework installed, the minimum supported version is 4.8. Please install .Net 4.8 Full Framework and re-run the Installer.",SEVERE);
			abort;
		else
		
			if( StrFindEx ( szValue, "4.8",0 ) < 0) then
			MessageBox("This computer does not have the correct version of the .NET Framework installed, the minimum supported version is 4.8. Please install .Net 4.8 Full Framework and re-run the Installer.",SEVERE);
			abort;
			endif;
			
			 // .Net 4.5 Installed
			// StrToNum(nValue,szValue);
			 
			// if(nValue >= 378389)then
				//.Net 4.8 is Installed
			// else
				// .Net 4.8 not installed
			//	MessageBox("This computer does not have the correct version of the .NET Framework installed, the minimum supported version is 4.5. Please install .Net 4.5 Full Framework and re-run the Installer.",SEVERE);
			//	abort;
			// endif;
		endif;
			
	else
		MessageBox("This computer does not have the correct version of the .NET Framework installed, the minimum supported version is 4.8. Please install .Net 4.8 Full Framework and re-run the Installer.",SEVERE);
		abort;
	endif;

    return 0;

end;

///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  CheckSilverLightversion  								                                     //
//                                                                                                       //
// Purpose:   This function check for Silverlight version is 4.0                                         //
//                                                                                                       //
///////////////////////////////////////////////////////////////////////////////////////////////////////////
function CheckSilverLightversion()
STRING szKey,szVersion,szValue,svMajorVersion,szMsg;
NUMBER nSize,nType,nMajorversion;
begin
    
    nSize= -1;
    nType= REGDB_STRING;
    
    szKey="SOFTWARE\\Microsoft\\Silverlight";
    szVersion="Version";

	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if(RegDBKeyExist(szKey)=1) then
		if (RegDBGetKeyValueEx (szKey, szVersion, nType, szValue, nSize) < 0) then 
			 MessageBox("This computer does not have the correct version of Silverlight installed, the minimum supported version is 4.0. Please install Silverlight and re-run the Installer.",SEVERE);
			 abort;
		else
			 StrSub(svMajorVersion,szValue,0,1);
			 StrToNum(nMajorversion,svMajorVersion);
			 
			 if(nMajorversion >= 4)then
				szMsg = "Silverlight is Installed, Version= " + szValue + ".";
				WriteToLogFile(INSTALL_LOG,szMsg);
			 else
				MessageBox("This computer does not have the correct version of Silverlight installed, the minimum supported version is 4.0. Please install Silverlight and re-run the Installer.",SEVERE);
				abort;
			 endif;
		endif;  
	else
		MessageBox("This computer does not have the correct version of Silverlight installed, the minimum supported version is 4.0. Please install Silverlight and re-run the Installer.",SEVERE);
		abort;
	endif;

    return 0;
   
end;

///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  CheckIISversion  								                                             //
//                                                                                                       //
// Purpose:   This function check for IIS Version version  7                                             //
//                                                                                                       //
///////////////////////////////////////////////////////////////////////////////////////////////////////////
function CheckIISversion()
STRING szKey,szVersion,szValue,szMsg;
NUMBER nSize,nType,nMajorversion;
begin
    
    nSize= -1;
    nType= REGDB_NUMBER;
    
    szKey="SOFTWARE\\Microsoft\\InetStp";
    szVersion="MajorVersion";

	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if(RegDBKeyExist(szKey)=1) then
		if (RegDBGetKeyValueEx (szKey, szVersion, nType, szValue, nSize) < 0) then 
			 MessageBox("This computer does not have the correct version of IIS installed, the minimum supported IIS Version is 7.0. Please install this module and re-run the Installer.",SEVERE);
			 abort;
		else
             StrToNum(nMajorversion,szValue);			 
			 if(nMajorversion >= 7)then
				szMsg = "IIS is Installed, MajorVersion= " + szValue + ".";
				WriteToLogFile(INSTALL_LOG,szMsg);
			 else
				MessageBox("This computer does not have the correct version of IIS installed, the minimum supported IIS Version is 7.0. Please install this module and re-run the Installer.",SEVERE);
			    abort;
			 endif;
		endif;  
	else
		MessageBox("This computer does not have the correct version of IIS installed, the minimum supported IIS Version is 7.0. Please install this module and re-run the Installer.",SEVERE);
		abort;
	endif;
	
	return 0;
end;

///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  CheckMSOfficeversion  								                                     //
//                                                                                                       //
// Purpose:   This function checks for MS Word: Supported Office versions are 2007 or 2010               //
//            This function find the path of Winword.exe in the registry then checks the Major version   //
//                                                                                                       //
///////////////////////////////////////////////////////////////////////////////////////////////////////////
function CheckMSOfficeversion()
STRING szKey,szValue,szMsg,svWinwordPath,szPath,szFile,svVersionNumber;
NUMBER nSize,nType,nMajorversion;

begin
    
	// Search for WINWORD.EXE, get the fileversion and compare the major version >=12
    nSize= -1;
    nType= REGDB_STRING;
    
    svWinwordPath="";
        
    szKey= "Software\\Microsoft\\Windows\\CurrentVersion\\App Paths\\Winword.exe";
    szPath="Path";
    
    RegDBSetDefaultRoot(HKEY_CURRENT_USER);
    
    if(RegDBKeyExist(szKey)=1) then
       	if (RegDBGetKeyValueEx (szKey, szPath, nType, szValue, nSize) < 0) then 
		    svWinwordPath="";
		else
            svWinwordPath=szValue;
		endif;  
	else
		svWinwordPath="";
	endif;
    
    if(svWinwordPath="")then
    
		RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
	
		if(RegDBKeyExist(szKey)=1) then
			if (RegDBGetKeyValueEx (szKey, szPath, nType, szValue, nSize) < 0) then 
				svWinwordPath="";
			else
				svWinwordPath=szValue;
			endif;  
		else
			svWinwordPath="";
		endif;
	endif;
	
	if(svWinwordPath="")then
	    MessageBox("This computer does not have the correct version of Microsoft Word installed, the minimum supported version is 2007. Please install Microsoft Word 2007 (or later) and re-run the Installer.",SEVERE);
		abort; 
	else
        StrRemoveLastSlash(svWinwordPath);	 
        szFile=   svWinwordPath ^ "Winword.exe";
	    VerGetFileVersion(szFile, svVersionNumber); 
	    StrSub(svVersionNumber,svVersionNumber,0,2); 
	    
	    StrToNum(nMajorversion,svVersionNumber);			 
		if(nMajorversion >= 12)then
			szMsg = "Microsoft Word is Installed, MajorVersion= " + svVersionNumber + ".";
			WriteToLogFile(INSTALL_LOG,szMsg);
		else
			MessageBox("This computer does not have the correct version of Microsoft Word installed, the minimum supported version is 2007. Please install Microsoft Word 2007 (or later) and re-run the Installer.",SEVERE);
		    abort; 
		endif;

	endif;
	
	return 0;
end;

///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  IsASPNETRoleInstalled  								                                     //
//                                                                                                       //
// Purpose:   This function check for ASP .NET Role for IIS is not Installed                             //
//                                                                                                       //
///////////////////////////////////////////////////////////////////////////////////////////////////////////
function IsASPNETRoleInstalled()
STRING szKey,szVersion,szValue,szMsg;
NUMBER nSize,nType;
begin
    
    nSize= -1;
    nType= REGDB_NUMBER;
    
    szKey="SOFTWARE\\Microsoft\\InetStp\\Components";
    szVersion="ASPNET45";

	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if(RegDBKeyExist(szKey)=1) then
		if (RegDBGetKeyValueEx (szKey, szVersion, nType, szValue, nSize) < 0) then 
			 MessageBox("The ASP.NET Role for IIS is not installed. Please install this role and re-run the Installer.",SEVERE);
			 abort;
		else
			 if(szValue="1")then
				szMsg = "ASP .NET Role for IIS is Installed.";
				WriteToLogFile(INSTALL_LOG,szMsg);
			 else
				MessageBox("The ASP.NET Role for IIS is not installed. Please install this role and re-run the Installer.",SEVERE);
				abort;
			 endif;
		endif;  
	else
		MessageBox("The ASP.NET Role for IIS is not installed. Please install this role and re-run the Installer.",SEVERE);
		abort;
	endif;
	
	return 0;
end;


