begin
	
	
	SdShowMsg ( "Updating config files . . . please wait." , TRUE );
	
	if(g_WCFServices=TRUE) then
		if(g_PureConfigFolderName="SiriusFS.SAM.WCFService")then
	
			szTargetPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "_PublishedWebsites" ^ g_PureConfigFolderName;
    
		endif;
	endif;
	
    if(g_bAppServerOnly=TRUE) then
		if(g_PureConfigFolderName="Application")then
	
			szTargetPath = TARGETDIR ^ PURE_APPLICATION_FOLDER;
    
		endif;
	endif;
    
    szFileName = szTargetPath ^ g_PureConfigFileName;
    
    LongPathToQuote ( szTargetPath, TRUE );
	//LongPathToQuote ( szFileName, TRUE );
	// icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
   	szCommand=	szTargetPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
   	
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	//LongPathToQuote ( szFileName, TRUE );
	WriteToLogFile(INSTALL_LOG,"web.config path=" + szFileName); 
	if Is(FILE_EXISTS, szFileName) = TRUE then
       //
    else
        MessageBox ( "Can't find web.config", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	 // Set the read-only flag OFF
	SetFileInfo ( szTargetFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("*");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                try
					strNodeName= oNode.nodeName;
					if(strNodeName= "setting")then
							szAddKey = oNode.attributes.getNamedItem("name").value;
							if szAddKey = "WCFSecurityToken" then
								oNode.firstChild.text=g_szWCFSecuirtyToken;
								WriteToLogFile(INSTALL_LOG,"Updating web.config, WCFSecurityToken=" + g_szWCFSecuirtyToken); 
							endif;
					endif;
                catch
                    szAddKey = "";
                endcatch;
                
             endfor; 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   
    else
        MessageBox(ERROR_XML_FILE_LOAD,SEVERE);                         
        return -1;
    endif;
    oDoc.save(szFileName);
    set oDoc = NOTHING;
    
	SdShowMsg ( "Updating config files . . . please wait." , FALSE );
    return 0;
end; 


////////////////////////////////////////////////////////////
// Function:  CopyiPMUserMaintenanceExeConfig 	                                                 //
//				                                                                     //
// Purpose:   This function  
//////////////////////////////////////////////////////////////
function CopyiPMUserMaintenanceExeConfig()
STRING szSrcFile, szTargetFile,szTargetPath;
NUMBER  nResult;
begin
	
	szSrcFile= SUPPORTDIR ^ "iPMUserMaintenance.exe.config";
			
	
	szTargetPath=TARGETDIR ^ PURE_APPLICATION_FOLDER;
	szTargetFile= szTargetPath ^ "iPMUserMaintenance.exe.config";
	
	//LongPathToQuote ( szTargetPath, TRUE );
			
	if Is(FILE_EXISTS, szTargetFile) = TRUE then
				WriteToLogFile(INSTALL_LOG, "don't Copy " + szTargetFile);
	else
			
				nResult = XCopyFile (szSrcFile, szTargetPath,COMP_NORMAL);
				WriteToLogFile(INSTALL_LOG, "Copied " + szTargetFile);
	endif;
	
	
	return 0;
end;



///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  RemovePureWebServicesDuringInstall                             //
//                                                                           //
// Purpose:   This function removes the PureWebServices                      //
//			                                                                 //
///////////////////////////////////////////////////////////////////////////////
function RemovePureWebServicesDuringInstall()
STRING szPath,szProgram,szCommand,szCommand1,szAppPoolCommand,szAppCommand;
begin    
		//Delete ASMX Web Applictaion
		//%systemroot%\system32\inetsrv\APPCMD delete app "Default Web Site/PureWebServices"
		
		SdShowMsg ( "Removing PureWebServices . . . please wait." , TRUE );
			
		szProgram = WINSYSDIR64^ "inetsrv\\appcmd.exe"; 
		LongPathToQuote(szProgram, TRUE); 
		
		szCommand = "delete app ";
		szCommand1 = "Default Web Site/PureWebServices";
		LongPathToQuote(szCommand1, TRUE); 
	
		szAppCommand = szCommand + szCommand1;
		WriteToLogFile(INSTALL_LOG,szAppCommand);
		LaunchAppAndWait(szProgram,szAppCommand,WAIT);
		
		//Delete ASMX Application Pool
		//%systemroot%\system32\inetsrv\APPCMD delete apppool /apppool.name:PureInsurance
		
		szCommand = "delete apppool /apppool.name:PureInsurance";
		WriteToLogFile(INSTALL_LOG,szCommand);
		LaunchAppAndWait(szProgram,szCommand,WAIT);
		
		//Delete ASMX files/folders
		
		szPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "_PublishedWebsites\\SAM.SERVICEAGENT";
		
		if(DeleteDir(szPath, ALLCONTENTS) < 0) then
			WriteToLogFile(INSTALL_ERRORLOG, "An error occured while removing SAM.SERVICEAGENT directory:" + szPath + ". Please remove it manually");	
		else
			WriteToLogFile(INSTALL_LOG, "Successfully removed SAM.SERVICEAGENT directory: " + szPath);	
		endif;
		
		SdShowMsg ( "Removing PureWebServices . . . please wait." , FALSE );
		
		
		return 0;
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  RemoveFilesDuringInstall                                       //
//                                                                           //
// Purpose:   This function removes the files when Installation is done      //
//			                                                                 //
///////////////////////////////////////////////////////////////////////////////
function RemoveFilesDuringInstall()
STRING szFileName,szPath;
begin    
		if(g_bAppServerOnly=TRUE ) then
			szPath = TARGETDIR ^ PURE_APPLICATION_FOLDER;
			szFileName= szPath ^ "bSIRRepostTransaction.dll";
			if Is(FILE_EXISTS, szFileName) = TRUE then
				DeleteFile(szFileName);
				WriteToLogFile(INSTALL_LOG, "Deleted file " + szFileName);
			endif;
		
			szPath = TARGETDIR ^ PURE_APPLICATION_FOLDER;
			szFileName= szPath ^ "iPMURepostTransaction.exe";
			if Is(FILE_EXISTS, szFileName) = TRUE then
				DeleteFile(szFileName);
				WriteToLogFile(INSTALL_LOG, "Deleted file " + szFileName);
			endif;
		endif;
		
		if(g_bWebServices=TRUE ) then
			szPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "_PublishedWebsites\\SAM.SERVICEAGENT\\bin";
			szFileName= szPath ^ "bSIRRepostTransaction.dll";
			if Is(FILE_EXISTS, szFileName) = TRUE then
				DeleteFile(szFileName);
				WriteToLogFile(INSTALL_LOG, "Deleted file " + szFileName);
			endif;
		endif;
		
		if(g_WCFServices=TRUE) then
			szPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "_PublishedWebsites\\SiriusFS.SAM.WCFService\\bin";
			szFileName= szPath ^ "bSIRRepostTransaction.dll";
			if Is(FILE_EXISTS, szFileName) = TRUE then
				DeleteFile(szFileName);
				WriteToLogFile(INSTALL_LOG, "Deleted file " + szFileName);
			endif;
		endif;

		return 0;
end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CompareCrystalReportVersion  	                                                     //
//				                                                                     //
// Purpose:   This function                                                                       //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function CompareCrystalReportVersion()
    NUMBER nResult,nPos, nLastPos, nLoop;
	STRING svMajor,svMinor,svBuild,svRegMajor,svRegMinor,svRegBuild; 
    NUMBER nMajor,nMinor,nBuild,nRegMajor,nRegMinor,nRegBuild; 
    STRING sRegProductVersionArray(3), sTemp;
    STRING szCRRuntimeKey, szCRRuntime64Version,svCRRuntime64Version,svMSXMLInstalledVersion;
    NUMBER nSize,nType;
        
begin

    svCRRuntime64Version="13.0.29";
  		
	svMajor ="13";  
	StrToNum(nMajor,svMajor); 
	svMinor ="0";
  	StrToNum(nMinor,svMinor);
  	svBuild ="29"; 
  	StrToNum(nBuild,svBuild);
  
    // Read CRRuntime32Version from regsitry
    //[HKEY_LOCAL_MACHINE\SOFTWARE\Wow6432Node\SAP BusinessObjects\Crystal Reports for .NET Framework 4.0\Crystal Reports]
	//"CRRuntime32Version"="13.0.20"
	szCRRuntimeKey="SOFTWARE\\SAP BusinessObjects\\Crystal Reports for .NET Framework 4.0\\Crystal Reports";
    szCRRuntime64Version= "CRRuntime64Version"; 
    
    nSize= -1;
    nType= REGDB_STRING;   
    
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if((RegDBKeyExist(szCRRuntimeKey)=1)) then
		RegDBGetKeyValueEx (szCRRuntimeKey, szCRRuntime64Version, nType, svMSXMLInstalledVersion, nSize); 
	else
		// Not Installed, so it is Fresh Install
		gCRInstallMode="Fresh";
	endif;
	
	if(gCRInstallMode="Fresh") then
		//
	
	else

		//Look for three values - Major, Minor,Build Number
		nLastPos = 0;
		for nLoop = 0 to 2  
			nPos = StrFind ( svMSXMLInstalledVersion, "." );
			if ( nPos <= 0 ) then 
				nPos = StrLength ( svMSXMLInstalledVersion );
			endif;
			StrSub ( sTemp, svMSXMLInstalledVersion, 0, nPos );
			sRegProductVersionArray ( nLoop ) = sTemp; 
			StrSub ( svMSXMLInstalledVersion, svMSXMLInstalledVersion, nPos + 1, StrLength ( svMSXMLInstalledVersion ) );
		endfor;
	
		svRegMajor =sRegProductVersionArray (0);
		StrToNum(nRegMajor,svRegMajor);
		svRegMinor =sRegProductVersionArray (1);
		StrToNum(nRegMinor,svRegMinor);
		svRegBuild =sRegProductVersionArray (2); 
		StrToNum(nRegBuild,svRegBuild);
  	
		// Compare the Installed Version and New version for each of the three values
  	  	
		if(nMajor < nRegMajor)then
  	     	gCRInstallMode="Older"; 
		else
			if((nMajor = nRegMajor)&&(nMinor < nRegMinor))then 
  			 		gCRInstallMode="Older"; 
			else
				if((nMajor = nRegMajor)&&(nMinor = nRegMinor)&&(nBuild < nRegBuild)) then
  				 		gCRInstallMode="Older"; 
				else
					if((nMajor = nRegMajor)&&(nMinor = nRegMinor)&&(nBuild = nRegBuild)) then 
  					 		gCRInstallMode="Same";
							
					else
						gCRInstallMode="Upgrade";
					endif;
				endif;
			endif;
		endif;
	endif;//if(gCRInstallMode="Fresh") then
		
   return 0; 
    
end;
   
///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CompareMSXLVersion  	                                                     //
//				                                                                     //
// Purpose:   This function                                                                       //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function CompareMSXMLVersion()
    
    STRING szCRRuntimeKey, szMSXML,svMSMXL,svMSXMLInstalledVersion;
    NUMBER nSize,nType;
    NUMBER nCompareFlag;
    STRING szFileName, svPath, svVersionNumber, szExistingVersion, szUpdateVersion; 

    STRING szTitle, szMsg; 
    

    NUMBER nResult; 

        
begin
	
	
    svMSMXL="4.30.2100.0";
  		
	
	szCRRuntimeKey="SOFTWARE\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{196467F1-C11F-4F76-858B-5812ADC83B94}";
    szMSXML= "DisplayVersion"; 
    
    nSize= -1;
    nType= REGDB_STRING;   
    
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if((RegDBKeyExist(szCRRuntimeKey)=1)) then
		RegDBGetKeyValueEx (szCRRuntimeKey, szMSXML, nType, svMSXMLInstalledVersion, nSize); 
		nCompareFlag = VERSION; 
		nResult = VerCompare (svMSMXL, svMSXMLInstalledVersion, nCompareFlag); 
		szMsg=svMSXMLInstalledVersion;
	   //MessageBox (szMsg, INFORMATION); 
	    if (nResult = GREATER_THAN) then 
	    	gCRInstallMode="Upgrade"; 
		// If the target file is a more current version, do not install. 

		elseif (nResult = LESS_THAN) then 
			gCRInstallMode="Older";
		// If both the target and source versions are the same, do not install. 

		elseif (nResult = EQUALS) then
			gCRInstallMode="Same";

		endif; 
	else
		// Not Installed, so it is Fresh Install
		gCRInstallMode="Fresh";
	endif;		


end;


