///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  CreatePureUsersGroup  								         //
//                                                                           //
// Purpose:   This function create a "Pure Users" group and add this group as//
//            a member of "Users" group.
//
//
///////////////////////////////////////////////////////////////////////////////

function CreatePureUsersGroup()
STRING szCommand,szGroup,szGroupComment;
NUMBER nvResult;
begin    
	
	szGroup="Pure Users";
	LongPathToQuote(szGroup, TRUE); 
	
	szGroupComment="Pure Insurance users";
	LongPathToQuote(szGroupComment, TRUE); 
	
	SdShowMsg ( "Creating 'Pure Users' group and setting permissions. . . please wait." , TRUE );
	
	//Create "Pure Users" group
	//net localgroup "Pure Users" /add /comment:"Pure Insurance users"

	szCommand= "localgroup" + " " + szGroup + " /add /comment:" + szGroupComment;

	nvResult = LaunchAppAndWait("net",szCommand, LAAW_OPTION_WAIT);
    if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Unable to create 'Pure Users' group  : \n" +" " + szCommand );
    else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"create 'Pure Users' group Command=" + szCommand);
	endif;
	
	//Add "Pure Users" group as a member of Users group
	//net localgroup Users "Pure Users" /add
	szCommand= "localgroup" + " " + "Users" + " " + szGroup + " /add";

	nvResult = LaunchAppAndWait("net",szCommand, LAAW_OPTION_WAIT);
    if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Unable to Add 'Pure Users' group as a member of Users group  : \n" +" " + szCommand );
    else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"Added 'Pure Users' group as a member of Users group Command=" + szCommand);
	endif;
	
	/*
	//Set Full permission to "Pure Users"
	//icacls C:\pure /grant "Pure Users":(OI)(CI)F
	szCommand=	INSTALLDIR + " /grant " + szGroup + ":(OI)(CI)F";
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
	nvResult = LaunchAppAndWait("icacls ",szCommand,WAIT);
	*/
	
	//Add siriusonline as a member of "Pure Users"
	//net localgroup "Pure Users" siriusonline /add
	if(g_bWebServices=TRUE) then
	szCommand= "localgroup" + " " + szGroup + " " + g_szWebservicesUser + " /add";

	nvResult = LaunchAppAndWait("net",szCommand, LAAW_OPTION_WAIT);
    if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Unable to Add " + g_szWebservicesUser + "as a member of Pure Users group  : \n" +" " + szCommand );
    else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"Added " + g_szWebservicesUser + "as a member of Pure Users group Command=" + szCommand);
		endif;
	endif;
	
	
	SdShowMsg ( "Creating 'Pure Users' group and setting permissions. . . please wait." , FALSE );

return 0;
end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  ValidateUserCredentials  	                                             //
//				                                                                     //
// Purpose:   This function varifies the username/password entered on account        //
//            information dialog                                                     //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////

function BOOL ValidateUserCredentials()
STRING szCommand,szProgram,szDomain;
STRING szSspValidateLog,szPath;
STRING svReturnLine,svTemp;
NUMBER nvLineNumber,nvResult;

begin
	
	szPath = WINDISK + "\\";
	szDomain = g_szHostName;
	
	szProgram = SUPPORTDIR ^ "SSPValidateUser.exe";
	szSspValidateLog = szPath ^ "SSPValidateUser.log";
	
	//corrected function below to correctly process special characters 
	
	szCommand = "/C " + szProgram + " " + g_szWebservicesUser + " \"" + g_szWebservicesPassword + "\" " + szSspValidateLog;

	nvResult = LaunchAppAndWait("CMD.EXE",szCommand, WAIT);
	Delay(1);
	
	SetFileInfo(szSspValidateLog, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
	Delay(1);
	
	// Find the search string in the log file.
	nvResult = FileGrep( szSspValidateLog, "LogOnSuccessfull", svReturnLine, nvLineNumber, RESTART);
	
	/*while (nvResult != END_OF_FILE) 
		nvResult = FileGrep (szSspLogonLog, "Succeeded", svReturnLine, nvLineNumber, CONTINUE);
	endwhile; 
	*/	
	
		
	if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Logon failed for user=" + g_szWebservicesUser);
      DeleteFile(szSspValidateLog);
      return FALSE;
    else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"Logon Succeeded for user=" + g_szWebservicesUser);
   	  DeleteFile(szSspValidateLog);
   	  return TRUE;
	endif;
		
				
	
end;


