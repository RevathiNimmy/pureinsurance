////////////////////////////////////////////////////////////
// Function:  CopyPMDocs 	                                                 //
//				                                                                     //
// Purpose:   This function  
//////////////////////////////////////////////////////////////
function CopyPMDocs()
    STRING	svFileName,svFileNameForList,szSrcFile,szTargetFile;
	STRING szType5Path,szFileName;
	STRING szSource,szTarget;
	STRING szDocuments,szSpooledDocuments,szSignatures;
begin
	
	szSource=SRCDIR ^ "PMDocs" ^ "*.*";
	szTarget=TARGETDIR ^ "PMDocs";
	
	if (XCopyFile (szSource, szTarget,INCLUDE_SUBDIR | COMP_NORMAL) < 0) then 
        MessageBox ("PMDocs: XCopyFile failed", SEVERE); 
    else 
        WriteToLogFile(INSTALL_LOG,"PMDocs files copied successfully.");  
    endif; 
	
	szDocuments=TARGETDIR ^ "PMDocs\\Documents";
	szSpooledDocuments= TARGETDIR ^ "PMDocs\\Documents\\Spooled Documents";
	szSignatures=TARGETDIR ^ "PMDocs\\Signatures";
	
	if (ExistsDir (szDocuments) != EXISTS) then 
		CreateDir (szDocuments);
    endif;
    
    if (ExistsDir (szSpooledDocuments) != EXISTS) then 
		CreateDir (szSpooledDocuments);
    endif;
    
     if (ExistsDir (szSignatures) != EXISTS) then 
		CreateDir (szSignatures);
    endif;
		    
		
	/*
	//PMDocs\Documents\Type 5
	szType5Path= SRCDIR ^ "PMDocs\\Documents\\Type 5";
	//PMDocs\Documents\Spooled Documents
	//PMDocs\Documents
	//PMDocs\Signatures
	
	
	if (StrLengthChars(szType5Path) > 0) then
		if (FindAllFiles(szType5Path, "*.*", svFileName, RESET) = 0) then
			ParsePath(szFileName, svFileName,FILENAME); 
						
			szSrcFile= szType5Path ^ szFileName;
			szTargetFile=TARGETDIR ^ "PMDocs\\Documents\\Type 5" ^ szFileName ;
			
			if Is(FILE_EXISTS, szTargetFile) = TRUE then
				//MessageBox("don't Copy " + szTargetFile,INFORMATION);
			else
				CopyFile (szSrcFile, szTargetFile);
			endif;
			
			while (FindAllFiles(szType5Path, "*.*", svFileName, CONTINUE) = 0)
				ParsePath(szFileName, svFileName,FILENAME); 
						
				szSrcFile= szType5Path ^ szFileName;
				szTargetFile=TARGETDIR ^ "PMDocs\\Documents\\Type 5" ^ szFileName ;
			
				if Is(FILE_EXISTS, szTargetFile) = TRUE then
					//MessageBox("don't Copy " + szTargetFile,INFORMATION);
				else
					CopyFile (szSrcFile, szTargetFile);
				endif;
				
			endwhile;
		endif;
	endif;
	FindAllFiles(TARGETDIR, "*.*", svFileName, CANCEL);
	*/
	
	return 0;
end;


////////////////////////////////////////////////////////////
// Function:  CopyRules 	                                                 //
//				                                                                     //
// Purpose:   This function  
//////////////////////////////////////////////////////////////
function CopyRules()
    STRING	svFileName,szSrcFile,szTargetFile;
	STRING szPath,szFileName;
begin
	
	
	szPath= SRCDIR ^ "Rules";
	
	if (ExistsDir (szPath) = EXISTS) then
	
		if (StrLengthChars(szPath) > 0) then
			if (FindAllFiles(szPath, "*.*", svFileName, RESET) = 0) then
			
				ParsePath(szFileName, svFileName,FILENAME); 
						
				szSrcFile= szPath ^ szFileName;
				szTargetFile=TARGETDIR ^ "Rules" ^ szFileName ;
			
				if Is(FILE_EXISTS, szTargetFile) = TRUE then
				//MessageBox("don't Copy " + szTargetFile,INFORMATION);
				else
					CopyFile (szSrcFile, szTargetFile);
				endif;
			
				while (FindAllFiles(szPath, "*.*", svFileName, CONTINUE) = 0)
					ParsePath(szFileName, svFileName,FILENAME); 
						
					szSrcFile= szPath ^ szFileName;
					szTargetFile=TARGETDIR ^ "Rules" ^ szFileName ;
			
					if Is(FILE_EXISTS, szTargetFile) = TRUE then
					//MessageBox("don't Copy " + szTargetFile,INFORMATION);
					else
						CopyFile (szSrcFile, szTargetFile);
					endif;
				
				endwhile;
			endif;
		endif;
	
	endif;
	
	FindAllFiles(szPath, "*.*", svFileName, CANCEL);
	
	return 0;
end;

////////////////////////////////////////////////////////////
// Function:  CopySiriusImportexeconfig 	                                                 //
//				                                                                     //
// Purpose:   This function  
//////////////////////////////////////////////////////////////
function CopySiriusImportexeconfig()
STRING szSrcFile, szTargetFile,szTargetPath;
NUMBER  nResult;
begin
	
	szSrcFile= SUPPORTDIR ^ "SiriusImport.exe.config";
			
	
	szTargetPath=TARGETDIR ^ PURE_APPLICATION_FOLDER;
	szTargetFile= szTargetPath ^ "SiriusImport.exe.config";
	
	//LongPathToQuote ( szTargetPath, TRUE );
			
	if Is(FILE_EXISTS, szTargetFile) = TRUE then
				WriteToLogFile(INSTALL_LOG, "don't Copy " + szTargetFile);
	else
			
				nResult = XCopyFile (szSrcFile, szTargetPath,COMP_NORMAL);
				WriteToLogFile(INSTALL_LOG, "Copied " + szTargetFile);
	endif;
	
	
	return 0;
end;


////////////////////////////////////////////////////////////
// Function:  CopyLists 	                                                 //
//				                                                                     //
// Purpose:   This function  
//////////////////////////////////////////////////////////////
function CopyLists()
    STRING	svFileName,szSrcFile,szTargetFile;
	STRING szPath,szFileName;
begin
	
	
	szPath= SRCDIR ^ "Lists";
	
	if (ExistsDir (szPath) = EXISTS) then
	
		if (StrLengthChars(szPath) > 0) then
			if (FindAllFiles(szPath, "*.*", svFileName, RESET) = 0) then
			
				ParsePath(szFileName, svFileName,FILENAME); 
						
				szSrcFile= szPath ^ szFileName;
				szTargetFile=TARGETDIR ^ "Lists" ^ szFileName ;
			
				if Is(FILE_EXISTS, szTargetFile) = TRUE then
				//MessageBox("don't Copy " + szTargetFile,INFORMATION);
				else
					CopyFile (szSrcFile, szTargetFile);
				endif;
			
				while (FindAllFiles(szPath, "*.*", svFileName, CONTINUE) = 0)
					ParsePath(szFileName, svFileName,FILENAME); 
						
					szSrcFile= szPath ^ szFileName;
					szTargetFile=TARGETDIR ^ "Lists" ^ szFileName ;
			
					if Is(FILE_EXISTS, szTargetFile) = TRUE then
					//MessageBox("don't Copy " + szTargetFile,INFORMATION);
					else
						CopyFile (szSrcFile, szTargetFile);
					endif;
				
				endwhile;
			endif;
		endif;
	
	endif;
	
	FindAllFiles(szPath, "*.*", svFileName, CANCEL);
	
	return 0;
end;


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetPortalCompatibilityLevel  							     //
//                                                                           //
// Purpose:   This function is used to set the DB compatibility level        //
//			  to SQLSERVER 2000 to newly created Sirius DB in SQLServer 2005 //
///////////////////////////////////////////////////////////////////////////////

function number SetPortalCompatibilityLevel()
number nvResult;
string szDBCompatScript;
STRING szProductVersionSQL,svProductVersion,svMajorProductVersion;
begin   

	szProductVersionSQL="SELECT SERVERPROPERTY('ProductVersion') ProductVersion";
	//svProductVersion = ADODBConnectExecuteAndReturn(g_PortalDBServer,"master",g_PortalUser,g_PortalPwd,szProductVersionSQL,"ProductVersion");  
	svProductVersion = ADODBConnectExecuteAndReturnPortal(g_PortalDBServer,"master",g_PortalUser,g_PortalPwd,szProductVersionSQL,"ProductVersion");  
	
	
	//MessageBox("Product version=" + svProductVersion ,INFORMATION);
	StrSub(svMajorProductVersion,svProductVersion,0,2); 
	//MessageBox("Major version=" + svMajorProductVersion ,INFORMATION);

	if(svMajorProductVersion= "11") then
		szDBCompatScript = "execute sp_dbcmptlevel '"+ g_PortaDB +"',110";
	endif;
	
	if(svMajorProductVersion= "10") then
		szDBCompatScript = "execute sp_dbcmptlevel '"+ g_PortaDB +"',100";
	endif;
	
	//nvResult = ADODBConnectAndExecute(g_PortalDBServer,g_PortaDB,g_PortalUser,g_PortalPwd,szDBCompatScript);
	nvResult = ADODBConnectAndExecutePortal(g_PortalDBServer,g_PortaDB,g_PortalUser,g_PortalPwd,szDBCompatScript);
	if(nvResult = 1) then
		WriteToLogFile(INSTALL_LOG,g_PortaDB +" Database Compatibility set to SQL Server 2008");
	else
		WriteToLogFile(INSTALL_ERRORLOG,g_PortaDB +" Database Compatibility cannot to SQL Server 2008. Please perform this step manually.");
	endif; 

return 1;
end;   

