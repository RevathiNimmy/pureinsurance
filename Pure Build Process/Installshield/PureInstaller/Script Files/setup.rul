///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CopyBackOfficeProduct 	                                             //
//				                                                                     //
// Purpose:   This function extract  BackOfficeProduct\FLEET.zip and copy the PMDocs //
//			  and Rules files//                                                      //
///////////////////////////////////////////////////////////////////////////////////////

function CopyBackOfficeProduct()
STRING szSourceFile,szTargetFile,szAppPath,szAppParms,szPath,szFile;
NUMBER nResult,nvExitCode;
begin 
	
	SdShowMsg ( "Copying BackOffice product . . . please wait." , TRUE );
	//MessageBox("Copied",INFORMATION);
	//szPath = WINDISK + "\\";
    szPath = SRCDIR ^ "BackOfficeProduct";
   	szAppPath =szPath ^ "pkzip25.exe";
	//szTargetFile= gTemp ^ "pkzip25.exe" ;
	/*
	Disable(LOGGING);
	nResult= CopyFile ( szSourceFile, szTargetFile);
	if(nResult <0)then
		WriteToLogFile(INSTALL_LOG,"Couldn't copy file " + szSourceFile);
	endif;
	Enable(LOGGING);
	*/
	szFile = szPath ^ "FLEET.zip";
	LongPathToQuote ( szFile, TRUE );  
	/*szTargetFile= gTemp ^ gPortalFileName ;
	LongPathToQuote ( szTargetFile, TRUE ); 
	WriteToLogFile(INSTALL_LOG,"Sourec file=" + szSourceFile + "Destination file=" +  szTargetFile);  
	Disable(LOGGING);	   
    nResult= CopyFile ( szSourceFile, szTargetFile);
    if(nResult <0)then
		WriteToLogFile(INSTALL_LOG,"Couldn't copy file " + szSourceFile);
	endif;
	Enable(LOGGING);
	*/    
    //pkzip25 -extr -dir=relative -over=all "Pure.Portals 2.03.12100.1.zip" "C:\inetpub\wwwroot"
	szAppParms = "-extr" + " -dir=relative -over=all " +
				 szFile + " " + 
				 TARGETDIR ^ "BackOfficeProduct";
				 
	ChangeDirectory(szPath);
	LaunchAppAndWait (szAppPath, szAppParms, WAIT);
	WriteToLogFile(INSTALL_LOG,"Copying and extracting Portal files" + szAppParms);
	
	//Copy Files
	szSourceFile= TARGETDIR ^ "BackOfficeProduct\\FLEET\\PMDocs";
	szTargetFile= TARGETDIR ^ "PMDocs";
	XCopyFile (szSourceFile ^ "*.*",  szTargetFile ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR); 
	
	//Copy Files
	szSourceFile= TARGETDIR ^ "BackOfficeProduct\\FLEET\\Rules";
	szTargetFile= TARGETDIR ^ "Rules";
	XCopyFile (szSourceFile ^ "*.*",  szTargetFile ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR); 
	
	DeleteDir(TARGETDIR ^ "BackOfficeProduct",ALLCONTENTS);
	
	SdShowMsg ( "Copying BackOffice product . . . please wait." , FALSE );
	
	return 0;
end;

