//---------------------------------------------------------------------------
// OnAbort
//
// The OnAbort is called when a setup is aborted via the abort keyword.
//---------------------------------------------------------------------------
function OnAbort()
begin    

if(g_bPreRequisiteFailure = FALSE) then
	HandleAbortInstallation();
endif;

end;   

//---------------------------------------------------------------------------
// OnUninstall
//
// The OnUninstall event is called when the setup is run with the -uninst
// switch, in this case this is the only event that will be called.
//---------------------------------------------------------------------------
function OnUninstall()
	BOOL   bOpt1, bOpt2;
	int    nReturn;
	string szTitle, szMsg1, szMsg2, szOpt1, szOpt2, svResult, szCaption;
	string szMsg;
	 LIST lAppInUse;
	 NUMBER nvResult,nResult;
	 BOOL bFileInUse;
	 STRING  svBackupLocation,svTargetLocation;
begin
	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
    // Added in InstallShield 15 - Show an appropriate error message if
    // -uninst is specified and the product is not installed.
    //MessageBox("Inside Uninstallation function",INFORMATION);
    if( !MAINTENANCE ) then
		szMsg1 = SdLoadString( IDS_IFX_ERROR_PRODUCT_NOT_INSTALLED_UNINST );
   		SdSubstituteProductInfo(szMsg1);
		MessageBox(szMsg1,SEVERE);
		abort;
    endif;  
    
 

    svResult = SdLoadString(ISWI_IS5_UNINST_MSG);
	szCaption = SdLoadString(IFX_ONMAINTUI_CAPTION);
	Sprintf(svResult,svResult,@PRODUCT_NAME);
	if (IDCANCEL = SprintfBox(MB_OKCANCEL,szCaption,svResult)) then
		abort; 
	endif;

	// Added in IS 2009 - Set appropriate StatusEx static text.
	szMsg= "The InstallShield Wizard is removing Pure Insurance.";
    SetStatusExStaticText(szMsg);
    //SetStatusExStaticText(SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_REMOVEALL));
		
	//Stop the Pure Service
    //LaunchAppAndWait ("net stop PureWindowsService", "", WAIT);
    
    StopPureService();
	
	// Check for file in use during uninstall
	while(CheckApplicationInUse(lAppInUse) == TRUE)
				//nResult = SdRMFilesInUse( "", "", "", lAppInUse,FALSE);
				nResult = SdFilesInUse("", "", "", lAppInUse);
				if (nResult == IDCANCEL) then
					if (IDYES = SprintfBox(MB_YESNO|MB_ICONEXCLAMATION|MB_DEFBUTTON2, 
											SdLoadString(SD_STR_ONCANCELING_TITLE), 
											SdLoadString(SD_STR_ONCANCELING_MSG))) then
                       
						EndCurrentDialog();
						Enable(USE_LOADED_SKIN);
						abort;
					endif;	
				
				endif;
	endwhile;
	
	
	Enable(STATUSEX);

	//////////////////////////////////////
	//DO NOT DELETE.  The below code will
	//initiate the uninstallation process.
	//ComponentRemoveAll();
	FeatureRemoveAllInMediaAndLog ( ); 
	//FeatureTransferData(MEDIA);
	//////////////////////////////////////

	Disable(STATUSEX);

	bOpt1 = FALSE;
	bOpt2 = FALSE;
  
    if(DeleteDir(TARGETDIR, ALLCONTENTS) < 0) then
    	WriteToLogFile(UNINSTALL_ERRORLOG, "An error occured while removing installation directory:" + TARGETDIR + ". Please remove it manually");	
    else
    	WriteToLogFile(UNINSTALL_LOG, "Successfully removed installation directory: " + TARGETDIR);	
    endif;
    
  	szMsg = "SSP Pure Insurance Installation Version "+g_szInstalledFullVersion+" has been Uninstalled.Click Finish to Exit the Wizard";   
    
	 if(gRestoreBackupFile=TRUE)then
		svBackupLocation=gBackupPath;
		svTargetLocation=TARGETDIR;
		RestoreFiles(svBackupLocation,svTargetLocation);
	endif;
	
    // Show final dialog.
    if(BATCH_INSTALL)then
       	SdFinishReboot(SdLoadString(IFX_SDFINISH_REMOVE_TITLE),szMsg,SYS_BOOTMACHINE,"",0);
    else    
    	SdFinish(SdLoadString(IFX_SDFINISH_REMOVE_TITLE),szMsg,"","","",bOpt1,bOpt2);
    endif;

end;     

//---------------------------------------------------------------------------
// OnComponentError
//
// The OnComponentError event is called by the framework when the call
// to FeatureTransferData or FeatureMoveData returns an error.
//---------------------------------------------------------------------------
function void OnComponentError()
	int    nError;
	string szErrFormat, szCaption, szDesc;  
	object ErrorInfo;
begin
	set ErrorInfo = ComponentErrorInfo();

	szCaption = SdLoadString(IFX_ONCOMPONENTERR_CAPTION);

	if(IsObject(ErrorInfo))then
		if(IsObject(ErrorInfo.Feature))then
			
			szDesc = ErrorInfo.FileError.Description;
			if(szDesc = "")then
				szDesc = FormatMessage(ErrorInfo.LastError);
				if(szDesc = "")then
					nError = ErrorInfo.LastError;
					Sprintf(szDesc,"%d",nError);
				endif;
			endif;

			szErrFormat = SdLoadString(STR_STR_DEFERRORTITLE);
			szErrFormat = szErrFormat + ": %s";
    		SprintfBox(MB_OK,szCaption,szErrFormat,szDesc);
		else
			szErrFormat = SdLoadString(IFX_UNKNWN_COMPERROR_MSG);
   			SprintfBox(MB_OK,szCaption,szErrFormat,ErrorInfo.LastError);
		endif;
	else
		szDesc = SdLoadString(IFX_COMPERROR_UNKNOWN);
		SprintfBox(MB_OK,szCaption,szDesc);
	endif;
	WriteToLogFile(INSTALL_ERRORLOG,"Caption:"+szCaption+" Description:"+szDesc);
end;


 
 

