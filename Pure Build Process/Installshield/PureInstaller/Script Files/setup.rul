// Function:  UpdatePMProduct  	                                                     //
//				                                                                     //
// Purpose:   This function updates database name in PMProduct table                                                                       //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function UpdatePMProduct()
    STRING szDBUpdateSQL;
    NUMBER nvResult;
  
begin;
  
   // PMProduct Update
   //update PMProduct set database_name='Pure303'
   szDBUpdateSQL = "update PMProduct SET database_name='" + g_szSiriusDBName + "'"; 
   
   WriteToLogFile(INSTALL_LOG, "Updating PMProduct using SQL: " +  szDBUpdateSQL);
   nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword, szDBUpdateSQL);
   if(nvResult < 0) then
   		WriteToLogFile(INSTALL_ERRORLOG, "Updating Updating PMProduct failed");
   else
    	WriteToLogFile(INSTALL_LOG, "Updating Updating PMProduct success");
   endif;  
end; 


//---------------------------------------------------------------------------
// OnSetUpdateMode
//
// OnSetUpdateMode is called directly by the framework to set the UPDATEMODE
// InstallShield system variable appropriately to control which UI events
// are called by OnShowUI.
//
// Note: This event is called for all setups.
//---------------------------------------------------------------------------
function OnSetUpdateMode()
	number	nIgnore, nMediaFlags, nInstalledVersion, nUpdateVersion, nResult;
	string	szVersion, szIgnore, szMsg, sEncrypted, sPart1, sPart2, sResult, Sqllogin ;
begin




	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
	UPDATEMODE = FALSE; // Non-update mode by default.
	
	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
	
	// Added 11.5 - Don't set UPDATEMODE when running from Add/Remove
	if( ADDREMOVE ) then
		return ISERR_SUCCESS;
	endif;

	// Added 11.5 - Don't set UPDATEMODE when REMOVEONLY is specified
	if( REMOVEONLY ) then
		return ISERR_SUCCESS;
	endif;

	// Get the media flags.
	MediaGetData( MEDIA, MEDIA_FIELD_MEDIA_FLAGS, nMediaFlags, szIgnore );

	// TODO: If you are updating an application that was installed by a previous
	// version of InstallShield, IFX_INSTALLED_VERSION will be empty, and
	// VERSION_COMPARE_RESULT_NOT_INSTALLED will be returned by
	// VerProductCompareVersions. Change the value of IFX_INSTALLED_VERSION (and
	// IFX_INSTALLED_DISPLAY_VERSION) here based on application specific version
	// information determined by the setup. Only do this if IFX_INSTALLED_VERSION
	// is empty.
	//if ( !StrLengthChars( IFX_INSTALLED_VERSION ) && MAINTENANCE ) then
	//	IFX_INSTALLED_VERSION = "X.XX.XXX";
	//	IFX_INSTALLED_DISPLAY_VERSION = IFX_INSTALLED_VERSION;
	//endif;

	// Verify that the installed version is valid.
	if( !StrLengthChars( IFX_INSTALLED_VERSION ) && MAINTENANCE ) then
		// If this error occurs, IFX_INSTALLED_VERSION needs to be set manually.
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_NO_INSTALLED_VERSION );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Verify that the product version is valid.
	if( !StrLengthChars( IFX_PRODUCT_VERSION ) ) then
		// If this error occures, IFX_PRODUCT_VERSION was not initialized correctly.
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_NO_PRODUCT_VERSION );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Do the version comparison.
	nResult = VerProductCompareVersions();

	// Make sure that valid data was returned by VerProductCompareVersions
	if( nResult < ISERR_SUCCESS ) then
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_VERSION_COMPARE_FAILURE );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Set update mode if this is a differential media or the product is already installed and the versions do not match.
	UPDATEMODE = ( nMediaFlags & MEDIA_FLAG_FORMAT_DIFFERENTIAL || ( MAINTENANCE && ( nResult != VERSION_COMPARE_RESULT_SAME ) ) );

end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CompareVersion  	                                                     //
//				                                                                     //
// Purpose:   This function                                                                       //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function CompareVersion()
    NUMBER nResult,nPos, nLastPos, nLoop;
	STRING svMajor,svMinor,svBuild,svRegMajor,svRegMinor,svRegBuild; 
    NUMBER nMajor,nMinor,nBuild,nRegMajor,nRegMinor,nRegBuild; 
    STRING	sProductVersionArray(3),sRegProductVersionArray(3), sTemp;
    
    STRING szUninstallKey, szDisplayVersion;
    NUMBER nSize,nType;
        
begin

    // Read Product Version of Installer from ProductVersion property
    g_ProcutVersion = IFX_PRODUCT_VERSION;
	
  	//Look for three values - Major, Minor,Build Number
	nLastPos = 0;
	for nLoop = 0 to 2  
		nPos = StrFind ( g_ProcutVersion, "." );
		if ( nPos <= 0 ) then 
			nPos = StrLength ( g_ProcutVersion );
		endif;
		StrSub ( sTemp, g_ProcutVersion, 0, nPos );
		sProductVersionArray ( nLoop ) = sTemp; 
		StrSub ( g_ProcutVersion, g_ProcutVersion, nPos + 1, StrLength ( g_ProcutVersion ) );
	endfor;
	
	svMajor =sProductVersionArray (0);  
	StrToNum(nMajor,svMajor); 
	svMinor =sProductVersionArray (1);
  	StrToNum(nMinor,svMinor);
  	svBuild =sProductVersionArray (2); 
  	StrToNum(nBuild,svBuild);
  
    // Read Product Version from regsitry
	szUninstallKey="SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{A5D571AB-3D05-4530-A631-74E8D1CADCA6}";
    szDisplayVersion= "DisplayVersion"; 
    
    nSize= -1;
    nType= REGDB_STRING;   
    
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if((RegDBKeyExist(szUninstallKey)=1)) then
	 WriteToLogFile(INSTALL_LOG,"Uninstall key exists");
		RegDBGetKeyValueEx (szUninstallKey, szDisplayVersion, nType, g_InstalledVersion, nSize); 
	else
		// Not Installed, so it is Fresh Install
		gInstallMode="Fresh";
	endif;
	
	if(gInstallMode="Fresh") then
		//
	
	else

		//Look for three values - Major, Minor,Build Number
		nLastPos = 0;
		for nLoop = 0 to 2  
			nPos = StrFind ( g_InstalledVersion, "." );
			if ( nPos <= 0 ) then 
				nPos = StrLength ( g_InstalledVersion );
			endif;
			StrSub ( sTemp, g_InstalledVersion, 0, nPos );
			sRegProductVersionArray ( nLoop ) = sTemp; 
			StrSub ( g_InstalledVersion, g_InstalledVersion, nPos + 1, StrLength ( g_InstalledVersion ) );
		endfor;
	
		svRegMajor =sRegProductVersionArray (0);
		StrToNum(nRegMajor,svRegMajor);
		svRegMinor =sRegProductVersionArray (1);
		StrToNum(nRegMinor,svRegMinor);
		svRegBuild =sRegProductVersionArray (2); 
		StrToNum(nRegBuild,svRegBuild);
  	
		// Compare the Installed Version and New version for each of the three values
  	  	
		if(nMajor < nRegMajor)then
  	     	gInstallMode="Older"; 
		else
			if((nMajor = nRegMajor)&&(nMinor < nRegMinor))then 
  			 		gInstallMode="Older"; 
			else
				if((nMajor = nRegMajor)&&(nMinor = nRegMinor)&&(nBuild < nRegBuild)) then
  				 		gInstallMode="Older"; 
				else
					if((nMajor = nRegMajor)&&(nMinor = nRegMinor)&&(nBuild = nRegBuild)) then 
  					 		gInstallMode="Same";
							
					else
						gInstallMode="Upgrade";
					endif;
				endif;
			endif;
		endif;
	endif;//if(gInstallMode="Fresh") then
		
   return 0; 
    
end;
   
////////////////////////////////////////////////////////////////////////////////////////
//                                                                                    //
// Function:  RunCrystalReportInstaller  								              //  
//                                                                                    //
// Purpose:   This function uninstall the crystal report 10.5.0.0 and Install 10.5.1.0//
//                                                                                    //                                                                                                       //
//                                                                                    //
////////////////////////////////////////////////////////////////////////////////////////
function RunCrystalReportInstaller()
STRING szProgram,szCommand,szFile;
NUMBER nvResult;
begin
	
	CreateLogFile(INSTALL_LOG);  
	CreateLogFile(INSTALL_ERRORLOG);  
    
    szFile= SRCDIR ^ "SetupPrerequisites" ^ "CRRuntime_64bit_13_0_29.msi";
	LongPathToQuote(szFile,TRUE);
	szProgram=WINSYSDIR64 ^ "msiexec.exe";
				
    CompareCrystalReportVersion();
	
	switch (gCRInstallMode)
		case "Upgrade":
				WriteToLogFile(INSTALL_LOG,"Upgrading Crystal Report runtime on this machine...please wait");  
				szCommand="/i " + szFile +  " /qn /norestart UPGRADE=1";
				nvResult = LaunchAppAndWait(szProgram,szCommand,WAIT);
		case "Same":
		       WriteToLogFile(INSTALL_LOG,"Same version of Crystal Report runtime is already installed on this machine.");          
		case "Fresh":  
				WriteToLogFile(INSTALL_LOG,"Installing Crystal Report runtime on this machine...please wait");  
				szCommand="/i " + szFile +  " /qn /norestart";
				nvResult = LaunchAppAndWait(szProgram,szCommand,WAIT);
		case "Older":
				WriteToLogFile(INSTALL_LOG,"A later version of Crystal Report runtime is already installed on this machine.");
	endswitch; 
	
 return 0;
   
end; 
