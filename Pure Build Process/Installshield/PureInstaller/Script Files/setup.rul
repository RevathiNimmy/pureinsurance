///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ReadWCFSecurityTokenFile  								             //
//                                                                           //
// Purpose:   This function read WCFSecurityTokenFile.txt                        //
//
///////////////////////////////////////////////////////////////////////////////

function ReadWCFSecurityTokenFile()
STRING szDir,szFile,szPermission,szFilePath,szGroup,szUsersGroupPermission,szUsersGroup;
//STRING szCommand,szCommandUsers
number  nvFileHandle,nvResult; 
begin   
	
	szDir = TARGETDIR ^ PURE_APPLICATION_FOLDER;
	
	szFile = "WCFSecurityTokenFile.txt";
	szFilePath = szDir ^ szFile;
	szGroup="Pure Users";
    LongPathToQuote(szGroup, TRUE); 
    
    szUsersGroup="Users";
	szUsersGroupPermission="(OI)(CI)F";
	szPermission="(OI)(CI)R";
	
	nvResult = SetPermission(szFilePath, szPermission, g_szWebservicesUser);
	nvResult = SetPermission(szFilePath, szUsersGroupPermission, szGroup);
	nvResult = SetPermission(szFilePath, szUsersGroupPermission, szUsersGroup);
	
	// Set the file mode to normal. 
    OpenFileMode (FILE_MODE_NORMAL); 
   
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions to WCFSecuirtyToken TextFile for " + szGroup+","+szUsersGroup+","+g_szWebservicesUser);
   	
	// Open the text file. 
   if (OpenFile (nvFileHandle, szDir, szFile) < 0) then 
        MessageBox ("OpenFile failed.", SEVERE); 
    else
    	nvResult = GetLine(nvFileHandle,g_szWCFSecuirtyToken);
      
    endif; 
    
    CloseFile(nvFileHandle);
	
return 0;

end; 

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  ReadPureConfigFiles  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for PureWCFservices         //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function ReadPureConfigFiles()
STRING  szFileName,szTargetFile, szTargetPath, szAddKey,szPath;
NUMBER	nResult,i,nvResult;  
OBJECT  oDoc, oNodeList,oNode;
STRING	szProgram,szCommand,szCommand1,szPermission;
begin
	
	SdShowMsg ( "Updating config files . . . please wait." , TRUE );
	szFileName = SRCDIR ^ "PureConfigFiles.xml";
    
    WriteToLogFile(INSTALL_LOG,"PureConfigFiles path=" + szFileName); 
    
	if Is(FILE_EXISTS, szFileName) = TRUE then
       //
    else
        MessageBox ( "Can't find PureConfigFiles.xml", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("ConfigFile");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                try
                    g_PureConfigFileName = oNode.attributes.getNamedItem("FileName").value;
                    g_PureConfigFolderName = oNode.attributes.getNamedItem("FolderName").value;
                    
                    if(g_WCFServices=TRUE) then
						if(g_PureConfigFolderName="SiriusFS.SAM.WCFService")then
							if(g_SkipDb=FALSE) then   
								UpdatePureConfigFiles(g_PureConfigFileName,g_PureConfigFolderName);
							endif;
						endif;
					endif;
					
					if(g_bAppServerOnly=TRUE) then
						if(g_PureConfigFileName="iPMUserMaintenance.exe.config")then
								if(g_PureConfigFolderName="Application")then
									if(g_SkipDb=FALSE) then						
										UpdatePMUserMaintenanceConfigFile(g_PureConfigFileName,g_PureConfigFolderName);
									endif;
								endif;
						else
								if(g_PureConfigFolderName="Application")then
									UpdatePureConfigFiles(g_PureConfigFileName,g_PureConfigFolderName);
								endif;
    					endif;
					endif;
                catch
                    //szAddKey = "";
                endcatch;
              endfor; 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   
    else
        MessageBox(ERROR_XML_FILE_LOAD,SEVERE);                         
        return -1;
    endif;
   
    set oDoc = NOTHING;
    
	SdShowMsg ( "Updating config files . . . please wait." , FALSE );
    return 0;
end; 


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  UpdatePureConfigFiles  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for PureWCFservices         //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function UpdatePureConfigFiles(g_PureConfigFileName,g_PureConfigFolderName)
STRING  szFileName,szTargetFile, szTargetPath, szAddKey,szPath;
NUMBER	nResult,i,nvResult;  
OBJECT  oDoc, oNodeList,oNode;
STRING	szProgram,szCommand,szCommand1,szPermission;
begin
	
	
	SdShowMsg ( "Updating config files . . . please wait." , TRUE );
	
	if(g_WCFServices=TRUE) then
		if(g_PureConfigFolderName="SiriusFS.SAM.WCFService")then
	
			szTargetPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "_PublishedWebsites" ^ g_PureConfigFolderName;
    
		endif;
	endif;
	
    if(g_bAppServerOnly=TRUE) then
		if(g_PureConfigFolderName="Application")then
	
			szTargetPath = TARGETDIR ^ PURE_APPLICATION_FOLDER;
    
		endif;
	endif;
    
    szFileName = szTargetPath ^ g_PureConfigFileName;
    
    LongPathToQuote ( szTargetPath, TRUE );
	//LongPathToQuote ( szFileName, TRUE );
	// icacls C:\pure\rules /grant test:(OI)(CI)WR
	szPermission="(OI)(CI)MWR";
   	szCommand=	szTargetPath + " /grant " + g_szUserName + ":" + szPermission;
   	WriteToLogFile(INSTALL_LOG,"Setting up permissions with command=" + szCommand );
   	
	nvResult = LaunchAppAndWait("icacls ",szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	//LongPathToQuote ( szFileName, TRUE );
	WriteToLogFile(INSTALL_LOG,"web.config path=" + szFileName); 
	if Is(FILE_EXISTS, szFileName) = TRUE then
       //
    else
        MessageBox ( "Can't find web.config", INFORMATION );
    endif;
    
    // Set the read-only flag OFF
	SetFileInfo ( szFileName, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	 // Set the read-only flag OFF
	SetFileInfo ( szTargetFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
    set oDoc = CreateObject("Msxml2.DOMDocument.6.0"); 
    if (IsObject(oDoc) = FALSE) then
        MessageBox(ERROR_XML_FILE_CREATION, 0);
        return -1;     
    endif;  
    //False means that the download must be completed before the caller gets the control back
    oDoc.async = FALSE;  
    if oDoc.load(szFileName) then
		Delay(15);
		WriteToLogFile(INSTALL_LOG,"web.config file Loaded successfully");
        set oNodeList = oDoc.getElementsByTagName("*");
        if (oNodeList.length > 0) then   
            for i = 0 to (oNodeList.length - 1);            
                set oNode = oNodeList.nextNode;
                try
                    szAddKey = oNode.attributes.getNamedItem("key").value;
                catch
                    szAddKey = "";
                endcatch;
                
                try
                    if szAddKey = "WCFSecurityToken" then
                        oNode.attributes.getNamedItem("value").value = g_szWCFSecuirtyToken;
                        WriteToLogFile(INSTALL_LOG,"Updating web.config, WCFSecurityToken=" + g_szWCFSecuirtyToken); 
                    endif;
                    
                catch
                endcatch;
             endfor; 
        else
            MessageBox(ERROR_XML_FILE_STRUCTURE,SEVERE);
            return -1;
        endif;   
    else
        MessageBox(ERROR_XML_FILE_LOAD,SEVERE);                         
        return -1;
    endif;
    oDoc.save(szFileName);
    set oDoc = NOTHING;
    
	SdShowMsg ( "Updating config files . . . please wait." , FALSE );
    return 0;
end; 


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  UpdatePMUserMaintenanceConfigFile  	                                             //
//				                                                                     //
// Purpose:   This function edit/updates web.config file for PureWCFservices         //
