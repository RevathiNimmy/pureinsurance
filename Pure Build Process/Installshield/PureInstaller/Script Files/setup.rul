///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  Load User Profile 								             //
//                                                                           //
// Purpose:   This function sets the load user profile = True                        //
//
///////////////////////////////////////////////////////////////////////////////
function LoadAppPoolUserProfile()
STRING szProgram,szPortalAppPoolCommand,szWCFAppPoolCommand;
NUMBER nvResult;
begin
	
	
	//%windir%\system32\inetsrv\appcmd set config -section:applicationPools /[name='DefaultAppPool'].processModel.loadUserProfile:true
	//Update Pure Portal App Pool load user profile
	
	szProgram = WINSYSDIR64 ^ "inetsrv\\appcmd.exe"; 
	LongPathToQuote(szProgram, TRUE); 
    
	
	if(g_bPortal=TRUE ) then
		SdShowMsg ( "Updating PurePortal App Pool settings . . . please wait." , TRUE );
		
		szPortalAppPoolCommand = "set config -section:applicationPools /[name=" + "'" + g_szAppPoolPortal + "'].processModel.loadUserProfile:true";
		LongPathToQuote(szPortalAppPoolCommand, FALSE); 
    
    	
		WriteToLogFile(INSTALL_LOG,szPortalAppPoolCommand);
	
		LaunchAppAndWait(szProgram,szPortalAppPoolCommand,WAIT);
		SdShowMsg ( "Updating Portal application settings . . . please wait." , FALSE );
		
	endif;
	
	
	if(g_WCFServices=TRUE) then
		//Update Pure WCF App Pool load user profile
		SdShowMsg ( "Updating PureWCFServices App Pool settings . . . please wait." , TRUE );
    
		szWCFAppPoolCommand = "set config -section:applicationPools /[name=" + "'" + "PureWCFAppPool" + "'].processModel.loadUserProfile:true";
		LongPathToQuote(szWCFAppPoolCommand, FALSE); 
    
    	
		WriteToLogFile(INSTALL_LOG,szWCFAppPoolCommand);
	
		LaunchAppAndWait(szProgram,szWCFAppPoolCommand,WAIT);
		SdShowMsg ( "Updating Portal application settings . . . please wait." , FALSE );
		
	endif;
	
	return 0;

end; 


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  PurePortalDatabaseDetails                                                  //
//                                                                           //
// Purpose:   This function takes a text filename as an input parameter      //
//			  and it creates a Installation Normal/Error Logs Uninstallation //
//			  Normal/Error Logs Database Normal/Error Logs                   //
///////////////////////////////////////////////////////////////////////////////

function number PurePortalDatabaseDetails()
number nResult, nErrorCode, nErrorLine;
number nCount;
string szConnection;
string szServer, szDB, szUser, szPassword;
string szMessage;
string szKey;
LIST   listConnections;
BOOL   bWinLogin;
BOOL   bNext;
NUMBER nvErrorCode;
STRING svTechnology;
NUMBER nBtn;
begin

    //First initialize SQL Server runtime
    SQLRTInitialize2( );

    //Get the names of all the necessary connections
    listConnections = SQLRTGetConnections();
    ListGetFirstString (listConnections, szConnection);

    nCount = 0;

    //determine if NEXT or BACK will be returned 
    //if there are no connections to make
    if( nBtn != BACK ) then
        bNext = TRUE;
    else
        bNext = FALSE;
		//start at end if going BACK
		while (ISERR_SUCCESS = ListGetNextString( listConnections, szConnection ) );
			nCount++;
		endwhile;
    endif;

    // Login for each connection
    while (nResult = ISERR_SUCCESS)

        //Get Default values for connection
        SQLRTGetConnectionInfo( szConnection, szServer, szDB, szUser, szPassword );
        bPurePortalDBWinLogin = SQLRTGetConnectionAuthentication( szConnection );
        bPurePortalDBWinLogin = FALSE;
        
        if(g_bCreatePurePortalDatabase = TRUE) then
	    	szDB = "master";
	    endif;  
	    
	    
	   //During Upgrade assign Portal server
	   if (g_PortalExists=TRUE ) then
			szServer   = g_PortalDBServer; 
			szDB = g_PortaDB;
	   endif;
	    
        Dlg_SQLConnection1:
				
				if(g_bCreatePurePortalDatabase = TRUE) then
					nResult= SdSQLServerSelectLogin3( szConnection, szServer,szUser,szPassword, bPurePortalDBWinLogin, szDB, FALSE, FALSE );
				else
					nResult= SdSQLServerSelectLogin3( szConnection, szServer,szUser,szPassword, bPurePortalDBWinLogin, szDB, FALSE, TRUE );
				endif;
				
				if(g_bCreatePurePortalDatabase = FALSE) then
					if(szDB="")then
						MessageBox("Database name is empty, Please specify which database name should be used for connection.\n\n" +
								   "Click the Browse button to select database name available on the database server.",WARNING);
						goto  Dlg_SQLConnection1;
						
					endif;
				 endif;
				
		if( nResult = NEXT ) then
			 //store data in case we need it again
            SQLRTPutConnectionInfo2( szConnection, szServer, szDB, szUser, szPassword );

	        SQLRTPutConnectionAuthentication( szConnection, bPurePortalDBWinLogin );

            //try connection
            nResult = SQLRTConnect( szConnection, szServer, bPurePortalDBWinLogin, szUser, szPassword );
            	
			if( nResult < ISERR_SUCCESS && MODE != SILENTMODE ) then

                SQLRTGetLastError2( nvErrorCode, szMessage, svTechnology, szConnection, szServer, szDB ); 
			    MessageBox( szMessage, MB_OK );

                //Show same login dialog again
                nResult = ListCurrentString(listConnections, szConnection);
			
            else //SUCCESS
                   //Move on to next connection
	                nCount++;
	                bNext = TRUE;
	                nResult = ListGetNextString(listConnections, szConnection);
	                g_PortalDBServer =  szServer;
	                g_PortaDB = szDB;
	                
	                if(bPurePortalDBWinLogin = FALSE) then
	                		g_PortalUser =  szUser;
							g_PortalPwd =  szPassword;
					endif;
	                
			 endif;			
            
         else
            //BACK
            nCount--;
            bNext = FALSE;
            nResult = ListSetIndex( listConnections, nCount );
            ListCurrentString( listConnections, szConnection );

        endif;

    endwhile;

    if( bNext ) then
        return NEXT;
    else
        return BACK;
    endif;

end;


///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  EmailConfiguration  	                                                 //
//				                                                                     //
// Purpose:   This function ask for to user about Email configuration details        //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function PureSTSConfiguration()
NUMBER	nResult;
STRING	svString, szTitle, szMsg, szField1, szField2, szField3;
begin
	szTitle  = "Pure STS Configuration Details";
	szMsg    = "Enter the SSL Server Certificate Common Name (CN) and thumbprint value which is used for configuration of PureSTS Web application on PureSTS server.";
	
	szField1 = "Pure STS Server Name";
	szField2 = "SSL Server Certificate Common Name (CN):";
	szField3 = "SSL Server Certificate thumbprint:";
	
	nResult  = SdShowDlgEdit3 ( szTitle, szMsg, 
								szField1, szField2, szField3, 
								g_szSTSServer, g_szCertificateName, g_szThumbprint ); 
					
			
	//nResult  = SdShowDlgEdit2 ( szTitle, szMsg, szField1, szField2, g_szCertificateName, g_szThumbprint ); 
	
	
	if(g_szSTSServer="")then
			MessageBox("Pure STS Server Name is empty, please specify a Pure STS Server Name.",INFORMATION);
			PureSTSConfiguration();
	endif;
		
	if(g_szCertificateName="")then
			MessageBox("SSL Server Certificate Common Name (CN) is empty, please specify SSL Server Certificate Common Name (CN).",INFORMATION);
			PureSTSConfiguration();
	endif;
	if(g_szThumbprint="")then
			MessageBox("SSL Server Certificate thumbprint is empty, please specify SSL Server Certificate thumbprint value.",INFORMATION);
			PureSTSConfiguration();
	endif;
	
	return nResult;
end; 


