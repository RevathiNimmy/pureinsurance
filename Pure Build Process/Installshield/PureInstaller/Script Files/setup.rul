#include "featureevents.rul"


/**************************InstallShield Built in Events Functions End *****************************************/


/***********************Setup.rul File Coding End***************************************************************/

//---------------------------------------------------------------------------
// OnMaintUIBefore
//
// Maintenance UI Sequence - Before Move Data
//
// The OnMaintUIBefore event is called by OnShowUI when the setup is
// running in maintenance mode. By default this event displays UI that
// allows the end user to add or remove features, repair currently
// installed features or uninstall the application.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function OnMaintUIBefore()
    number	nResult, nType;
    string	szTitle, szMsg;
    BOOL bFileInUse;
    LIST lAppInUse;
    STRING svInstallLocation,svBackupLocation;
    NUMBER nvDefault,nvAskButtonRetValue;
    STRING szQuestion;
    STRING szProgram, szCommand,szService;
begin
	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
	// nType defaults to MODIFY.
	nType = MODIFY;

    //Initialize SQL
    //OnSQLServerInitializeMaint();

// Beginning of UI Sequence
Dlg_Start:

    // Added in Version 9.5 - Support for REMOVEONLY option.
    if( !REMOVEONLY ) then
    	// In standard mode show maintenance dialog
	    Disable( BACKBUTTON );
	    //nType = SdWelcomeMaint( szTitle, szMsg, nType );
	    
	    if(gInstallMode="Same")then
			//MessageBox("Same",INFORMATION);
			nType=MODIFY;
	    endif;
	    
	    
	    Enable( BACKBUTTON );
        nResult = NEXT;
    else
        // Hide the initial progress dialog as otherwise the user can
        // click on it, and hide the MessageBox.
        Disable( DIALOGCACHE );

        // In RemoveOnly mode, set to remove.
        nType = REMOVEALL;
    endif;

	// Show Uninstall Confirmation Dialog
    if ( nType = REMOVEALL ) then
		nResult = MessageBox( SdLoadString( IFX_MAINTUI_MSG ), MB_YESNO );
		if (nResult != IDYES ) then
            
            if( REMOVEONLY ) then
                // In REMOVEONLY mode, abort the setup.
                abort;
            else
                // In non-REMOVEONLY mode, redisplay the previous dialog.
			    goto Dlg_Start;
            endif;

		endif;
	endif;

/*
Dlg_SdFeatureTree:
	if ( nType = MODIFY ) then
		szTitle = "";
		szMsg = SdLoadString( SD_STR_COMPONENT_MAINT_MSG );
		nResult = SdFeatureTree( szTitle, szMsg, TARGETDIR, "", -1 );
		if ( nResult = BACK ) goto Dlg_Start;
    endif;
*/

Dlg_ObjDialogs:
    nResult = ShowObjWizardPages( nResult );
    if ( ( nResult = BACK ) && ( nType != MODIFY ) ) goto Dlg_Start;
    //if ( ( nResult = BACK ) && ( nType = MODIFY ) ) goto Dlg_SdFeatureTree;

	switch(nType)

        case REMOVEALL:
			
			szQuestion= "Do you want to completely remove the Pure folder or retain the custom configuration files?\n\n" +
		            "Click YES to 'remove the Pure folder' or Click NO to 'retain the custom configuration files'.";
        
			
			nvDefault = NO;
			nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
		
			if(nvAskButtonRetValue = YES) then
				  gRestoreBackupFile=FALSE;
				  
			else
				  gRestoreBackupFile=TRUE;
				  
				  
				  SetDialogTitle ( DLG_ASK_PATH, "Select the Backup location" );
				  AskPath ( "Select the Backup location to copy custom configuration files (Documaster, Lists, PMDocs, Rules and Reports).","", gBackupPath ); 
				  StrRemoveLastSlash ( gBackupPath ); 
				  
				  
				  if (ExistsDir (gBackupPath) != EXISTS) then 
						CreateDir (gBackupPath); 
				  endif; 

				  svInstallLocation=TARGETDIR;
				  svBackupLocation= gBackupPath;
				  BackupFiles(svInstallLocation,svBackupLocation);  
				  
			endif;		 
			
			//Stop the Pure Service
			//LaunchAppAndWait ("net stop PureWindowsService", "", WAIT);
			StopPureService();			
			// Check for file in use during uninstall
			while(CheckApplicationInUse(lAppInUse) == TRUE)
				//nResult = SdRMFilesInUse( "", "", "", lAppInUse,FALSE);
				nResult = SdFilesInUse("", "", "", lAppInUse);
				if (nResult == IDCANCEL) then
					if (IDYES = SprintfBox(MB_YESNO|MB_ICONEXCLAMATION|MB_DEFBUTTON2, 
											SdLoadString(SD_STR_ONCANCELING_TITLE), 
											SdLoadString(SD_STR_ONCANCELING_MSG))) then
                       
						EndCurrentDialog();
						Enable(USE_LOADED_SKIN);
						abort;
					endif;	
				
				endif;
			endwhile;
	
	
			Enable(STATUSEX);
			
			//Uninstall Pure Windows service
			
			SdShowMsg ( "Uninstalling SSP Pure Service . . . please wait." , TRUE );

			szProgram =  WINDIR ^ "Microsoft.NET\\Framework\\v4.0.30319\\InstallUtil.exe";
			szService =  TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "Ssp.Pure.Service.WindowsService.exe";
			LongPathToQuote ( szService, TRUE );
			
			szCommand = "/u " + szService;
			
			LaunchAppAndWait (szProgram, szCommand, LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	
			SdShowMsg ( "Uninstalling SSP Pure Service . . . please wait." , FALSE );
			
			
			// Ensure that all previously installed features are removed.
			FeatureRemoveAllInMediaAndLog ( );

            // Added in 11.0 - Set appropriate StatusEx static text.
            szMsg= "The InstallShield Wizard is removing Pure Insurance.";
            SetStatusExStaticText(szMsg);
            //SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_REMOVEALL ) );

        case REPAIR:
				
			FeatureReinstall();
           
            // Added in 11.0 - Set appropriate StatusEx static text.
            szMsg="The InstallShield Wizard is repairing Pure Insurance.";
            SetStatusExStaticText(szMsg);
            //SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_REPAIR ) );

        case MODIFY:
            
            FeatureReinstall();
            // Added in 11.0 - Set appropriate StatusEx static text.
            szMsg="The InstallShield Wizard is modifying Pure Insurance.";
            SetStatusExStaticText(szMsg);
            //SetStatusExStaticText( SdLoadString( IDS_IFX_STATUSEX_STATICTEXT_MAINTUI_MODIFY ) );

    endswitch;

end;


///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  CheckPureInstallscriptMSIInstallerExists  								                 //  
//                                                                                                       //
// Purpose:   This function check for existtence of Pure Installer  created by InstallscriptMSI project  //
//			  if present then Installer will uninstall it and install the Instalslcript project Installer//
//                                                                                                       //
///////////////////////////////////////////////////////////////////////////////////////////////////////////
function CheckPureInstallscriptMSIInstallerExists()
STRING szUninstallKey,szUninstallString,szQuestion,szInstallPath,svInstallLocation,svBackupLocation;
NUMBER nvDefault,nvAskButtonRetValue;
NUMBER nSize,nType;

begin
    
    szUninstallKey="SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{2FA51B7B-8A63-408A-9673-DCB683150B34}";
    szUninstallString="SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\InstallShield_{2FA51B7B-8A63-408A-9673-DCB683150B34}";
    
    szInstallPath= "InstallLocation"; 
    
    nSize= -1;
    nType= REGDB_STRING;   
    
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if((RegDBKeyExist(szUninstallKey)=1) || (RegDBKeyExist(szUninstallString)=1)) then
		RegDBGetKeyValueEx (szUninstallKey, szInstallPath, nType, svInstallLocation, nSize); 
		
		szQuestion= "Installer has detected a previous version of Pure Insurance and it will be uninstalled.\n\n" +
					"Do you want to completely remove the Pure folder or retain the custom configuration files?\n\n" +
		            "Click YES to 'remove the Pure folder' or Click NO to 'retain the custom configuration files'.";
        
        nvDefault = NO;
		nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
		
		if(nvAskButtonRetValue = YES) then
				  gRestoreBackupFile=FALSE;
				  UninstallInstallscriptMSIInstaller(svInstallLocation);
	    else
				  gRestoreBackupFile=TRUE;
				  
				  SetDialogTitle ( DLG_ASK_PATH, "Select the Backup location" );
				  AskPath ( "Select the Backup location to copy custom configuration files (Documaster, Lists, PMDocs, Rules and Reports).","", gBackupPathUninstall ); 
				  StrRemoveLastSlash ( gBackupPathUninstall ); 
				  
				  
				  if (ExistsDir (gBackupPathUninstall) != EXISTS) then 
						CreateDir (gBackupPathUninstall); 
				  endif; 
				  
				  svBackupLocation=gBackupPathUninstall;
				  Disable( DIALOGCACHE );
				  BackupFiles(svInstallLocation,svBackupLocation); 
				  UninstallInstallscriptMSIInstaller(svInstallLocation);
				  Enable( DIALOGCACHE );
	     		  // Restore just before file install takes place during new Install
	     		  //RestoreFiles(svInstallLocation);
	    endif;		 
	 
	endif;
	
	return 0;
end;


///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  UninstallInstallscriptMSIInstaller  								                         //  
//                                                                                                       //
// Purpose:   This function uninstall the InstallscriptMSIInstaller installed by previous build,         //
//            if present, deletes "Pure" files/folder and "Pure "regsitry enties                         //
//                                                                                                       //
//                                                                                                       //
///////////////////////////////////////////////////////////////////////////////////////////////////////////
function UninstallInstallscriptMSIInstaller(svInstallLocation)
STRING szProgram,szCommand;
NUMBER nvResult;
begin
    
    SdShowMsg ( "Uninstalling previous version of Pure Insurance . . . please wait." , TRUE );
    //Stop Pure windows service
    StopPureService();	
    
    
    szProgram=WINSYSDIR64 ^ "msiexec.exe";
    szCommand="/x {2FA51B7B-8A63-408A-9673-DCB683150B34} /qn REBOOT=ReallySuppress";
   
    nvResult = LaunchAppAndWait(szProgram,szCommand,WAIT);
   
   	//Creates the Uninstallation log/error log file
	CreateLogFile(UNINSTALL_LOG);
	CreateLogFile(UNINSTALL_ERRORLOG);  
	
	//deletes the registry file during uninstallation
	DeleteRegFile();   
	
	ClearReadOnly(svInstallLocation);	

	if(DeleteDir(svInstallLocation, ALLCONTENTS) < 0) then
    	WriteToLogFile(UNINSTALL_ERRORLOG, "An error occured while removing installation directory:" + svInstallLocation );	
    else
    	WriteToLogFile(UNINSTALL_LOG, "Successfully removed installation directory: " + svInstallLocation);	
    endif;
   
    //Delete Uninstall key of InstallScript MSI project
    RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    RegDBDeleteKey("SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{2FA51B7B-8A63-408A-9673-DCB683150B34}");
    RegDBDeleteKey("SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\InstallShield_{2FA51B7B-8A63-408A-9673-DCB683150B34}");
	
	SdShowMsg ( "Uninstalling previous version of Pure Insurance . . . please wait." , FALSE );
  return 0;
   
end;

///////////////////////////////////////////////////////////////////////////////////////                                                                                   //
// Function:  StopPureService  	                                                     //
//				                                                                     //
// Purpose:   This function checks the status of Pure windows service                //
//            Pure windows service and stop it if it is running                      //
///////////////////////////////////////////////////////////////////////////////////////
function StopPureService()
number nvServiceState;
begin
		
	ServiceGetServiceState('PureWindowsService', nvServiceState);
    //check the state of the NT service
    if ( nvServiceState != SERVICE_STOPPED ) then
			SdShowMsg ( "Stopping SSP Pure Windows Service . . . please wait." , TRUE );
       	    ServiceStopService ( 'PureWindowsService' ); 
       	    Delay(15);
       	    SdShowMsg ( "Stopping SSP Pure Windows Service . . . please wait." , FALSE );
	endif;
       
end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  BackupFiles  	                                                         //
//				                                                                     //
// Purpose:   This function takes the Backup of "Documaster","Lists","Rules","PMDocs //
//            and"Reports" folder to Backup location                                 //
//                                                                                   //
///////////////////////////////////////////////////////////////////////////////////////
function BackupFiles(svInstallLocation,svBackupLocation)
STRING szSource,sztarget,szPath;

begin
	
	// Chnage the backup Path
	//szPath = WINDISK + "\\";
	
	Disable (LOGGING);
	
	SdShowMsg ( "Backup custom configuration files . . . please wait." , TRUE );
	
	szSource= svInstallLocation ^ "Documaster";
	sztarget= svBackupLocation ^ "PureApplicationBackup\\Documaster";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR); 
	
	szSource= svInstallLocation ^ "Lists";
	sztarget= svBackupLocation ^ "PureApplicationBackup\\Lists";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR);
	
	szSource= svInstallLocation ^ "PMDocs";
	sztarget= svBackupLocation ^ "PureApplicationBackup\\PMDocs";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR);
	
	szSource= svInstallLocation ^ "Rules";
	sztarget= svBackupLocation ^ "PureApplicationBackup\\Rules";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR);
	
	szSource= svInstallLocation ^ "Reports";
	sztarget= svBackupLocation ^ "PureApplicationBackup\\Reports";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR);
	
	SdShowMsg ( "Backup custom configuration files . . . please wait." , FALSE );	
	
	Enable (LOGGING);
	 
	return 0;

end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  RestoreFiles  	                                                     //
//				                                                                     //
// Purpose:   This function checks the status of Pure windows service                //
//            Pure windows service and stop it if it is running                      //
///////////////////////////////////////////////////////////////////////////////////////
function RestoreFiles(svBackupLocation,svTargetLocation)
STRING szSource,sztarget,szPath;

begin
	
	//szPath = WINDISK + "\\";
	
	SdShowMsg ( "Restore custom configuration files . . . please wait." , TRUE );
	
	szSource= svBackupLocation ^ "PureApplicationBackup\\Documaster";
	sztarget= svTargetLocation ^ "Documaster";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR); 
	
	szSource= svBackupLocation ^ "PureApplicationBackup\\Lists";
	sztarget= svTargetLocation ^ "Lists";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR);
	
	szSource= svBackupLocation ^ "PureApplicationBackup\\PMDocs";
	sztarget= svTargetLocation ^ "PMDocs";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR);
	
	szSource= svBackupLocation ^ "PureApplicationBackup\\Rules";	
	sztarget= svTargetLocation ^ "Rules";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR);
	
	szSource= svBackupLocation ^ "PureApplicationBackup\\Reports";
	sztarget= svTargetLocation ^ "Reports";
	XCopyFile (szSource ^ "*.*",  sztarget ^ "*.*",COMP_NORMAL | INCLUDE_SUBDIR);
	
	SdShowMsg ( "Restore custom configuration files . . . please wait." , TRUE );
	
	return 0;

end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  ConfigurePureservice  	                                             //
//				                                                                     //
// Purpose:   This function Configure SSP Pure Service to login as a suitable user   //
//			  with read/write access to the Pure folder  and set it to automatic     //
///////////////////////////////////////////////////////////////////////////////////////
function ConfigurePureservice()
STRING szProgram,szCommand,szStartServiceArgs;
NUMBER nvResult;
STRING szKey,szName,szValue;

begin
	
	SdShowMsg ( "Configuring SSP Pure Service . . . please wait." , TRUE );
	
	//sc config PureWindowsService obj= .\siriusonline password= Sirius@India
	szProgram= WINSYSDIR64 ^ "sc.exe";
	szCommand="config PureWindowsService obj= " + g_szWebservicesUser + " password= " + g_szWebservicesPassword ;
	
	nvResult = LaunchAppAndWait(szProgram,szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	WriteToLogFile(INSTALL_LOG,"Configuring SSP Pure Service");
	
	//Added by krishna
	//Implementing Logon as a service right
		
	szProgram = SUPPORTDIR ^ "ntrights.exe";
	
	szCommand = szProgram +" "+"-u" + " "+g_szWebservicesUser +" "+"+r"+" "+"SeServiceLogonRight";
	nvResult = LaunchAppAndWait (szProgram, szCommand, LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	WriteToLogFile(INSTALL_LOG,"Log on right granted");
	//end of Implementing Logon as a service right	
	
	//set it to automatic
	RegDBSetDefaultRoot ( HKEY_LOCAL_MACHINE );
	szKey = "SYSTEM\\CurrentControlSet\\services\\PureWindowsService"; 
	szName="Start";
	szValue="2";
	
	RegDBSetKeyValueEx ( szKey, szName, REGDB_NUMBER, szValue, -1 ); 
	
	//Stop the service after configuration
	StopPureService();
	Delay(15);
	
	//Start the service after configuration
	szProgram= WINSYSDIR64 ^ "sc.exe";	
	szCommand="start PureWindowsService";
	
	nvResult = LaunchAppAndWait(szProgram,szCommand,LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
	Delay(15);
    
    //SERVICE_IS_PARAMS.nStartServiceWaitCount=0;
    //ServiceStartService ( 'PureWindowsService', szStartServiceArgs ); 
	
	SdShowMsg ( "Configuring SSP Pure Service . . . please wait." , FALSE );
	
	return 0;

end;

