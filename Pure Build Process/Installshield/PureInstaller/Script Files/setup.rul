				szCommand="/i " + szFile +  " /qn /norestart";
				nvResult = LaunchAppAndWait(szProgram,szCommand,WAIT);
		case "Older":
				WriteToLogFile(INSTALL_LOG,"A later version of MSXML is already installed on this machine.");
	endswitch; 
	
 return 0;
   
end; 
////////////////////////////////////////////////////////////////////////////////////////
//                                                                                    //
// Function:  CopyDashBoardFiles  								              //  
//                                                                                    //
// Purpose:  
//                                                                                    //                                                                                                       //
//                                                                                    //
////////////////////////////////////////////////////////////////////////////////////////

function CopyDashBoardFiles()
STRING szSrcFile,szTargetPath,szTargetFile,szQuestion,gBackupPath,szQuestion1,szQuestion2;
NUMBER nvResult,nvAskButtonRetValue,nvDefault;
begin
	
	SdShowMsg ( "Copying Dashboard files . . . please wait." , TRUE );
	//szSrcFile= SRCDIR ^ "Dashboard\\scripts" ^ "*.*";
	
	//Define backup path
	gBackupPath=TARGETDIR ^ "Dashboard\\DashboardInstallBackup";
	szSrcFile= SRCDIR ^ "Dashboard\\scripts" ^ "*.sql";
	
	szTargetPath=TARGETDIR ^ "Dashboard";
	
	XCopyFile ( szSrcFile, szTargetPath, COMP_NORMAL ); 
	
	//copy qvw files
	szSrcFile= SRCDIR ^ "Dashboard\\scripts" ^ "*.qvw";
	
	szTargetPath=TARGETDIR ^ "Dashboard";
	
	XCopyFile ( szSrcFile, szTargetPath, COMP_NORMAL ); 
	
	//Check if files  Connection_MonitorDB1.txt exists
	szSrcFile=  SRCDIR ^ "Dashboard\\scripts" ^ "Connection_MonitorDB1.txt";		
	
	szTargetPath=TARGETDIR ^ "Dashboard";
	szTargetFile= szTargetPath ^ "Connection_MonitorDB1.txt";	
			
	if Is(FILE_EXISTS, szTargetFile) = TRUE then
				szQuestion1 = "Connection_MonitorDB1.txt file already exists. Do you wish to replace it with the latest version?" +" " ;
				szQuestion2=	"If Yes, a backup of the existing file will be created in" +" "+gBackupPath+".If No, please refer to release documentation for any manual modifications required to the file.";		
				szQuestion=szQuestion1+szQuestion2;
				
	 	   	   			nvDefault = NO;
						nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
						if(nvAskButtonRetValue = YES) then
							
						//Take backup of files.
						if (ExistsDir (gBackupPath) != EXISTS) then 
						CreateDir (gBackupPath); 		
						endif; 	
						//copy files in backup folder			
						XCopyFile (szTargetFile,  gBackupPath ,COMP_NORMAL); 						
						
						//copy new files
						nvResult = XCopyFile (szSrcFile, szTargetPath,COMP_NORMAL);
						WriteToLogFile(INSTALL_LOG, "Copied " + szTargetFile);
						
						else 
						//do nothing
						WriteToLogFile(INSTALL_LOG, "don't Copy " + szTargetFile);
						endif;						
				
	else
			
				nvResult = XCopyFile (szSrcFile, szTargetPath,COMP_NORMAL);
				WriteToLogFile(INSTALL_LOG, "Copied " + szTargetFile);
	endif;
	
			//Check if files  Connection_SiriusDB1.txt exists
			szSrcFile=  SRCDIR ^ "Dashboard\\scripts" ^ "Connection_SiriusDB1.txt";		
		
			szTargetPath=TARGETDIR ^ "Dashboard";
			szTargetFile= szTargetPath ^ "Connection_SiriusDB1.txt";	
					
			if Is(FILE_EXISTS, szTargetFile) = TRUE then
				szQuestion1 = "Connection_SiriusDB1.txt file already exists. Do you wish to replace it with the latest version?" +" ";
				szQuestion2=	"If Yes, a backup of the existing file will be created in" +" "+gBackupPath+".If No, please refer to release documentation for any manual modifications required to the file.";		
				szQuestion=szQuestion1+szQuestion2;
				
	 	   	   			nvDefault = NO;
						nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
						if(nvAskButtonRetValue = YES) then
							
						//Take backup of files.
							if (ExistsDir (gBackupPath) != EXISTS) then 
							CreateDir (gBackupPath); 		
							endif; 	
							//copy files in backup folder			
							XCopyFile (szTargetFile,  gBackupPath ,COMP_NORMAL); 						
							
						//copy new files
						nvResult = XCopyFile (szSrcFile, szTargetPath,COMP_NORMAL);
						WriteToLogFile(INSTALL_LOG, "Copied " + szTargetFile);
						
						else 
						//do nothing
						WriteToLogFile(INSTALL_LOG, "don't Copy " + szTargetFile);
						endif;						
						
			else
					
						nvResult = XCopyFile (szSrcFile, szTargetPath,COMP_NORMAL);
						WriteToLogFile(INSTALL_LOG, "Copied " + szTargetFile);
			endif;
				
		//Check if files  Refresh_Sirius.bat exists
			szSrcFile=  SRCDIR ^ "Dashboard\\scripts" ^ "Refresh_Sirius.bat";		
		
			szTargetPath=TARGETDIR ^ "Dashboard";
			szTargetFile= szTargetPath ^ "Refresh_Sirius.bat";	
					
			if Is(FILE_EXISTS, szTargetFile) = TRUE then
				szQuestion1 = "Refresh_Sirius.bat file already exists. Do you wish to replace it with the latest version?" +" " ;
				szQuestion2=	"If Yes, a backup of the existing file will be created in" +" "+gBackupPath+".If No, please refer to release documentation for any manual modifications required to the file.";		
				szQuestion=szQuestion1+szQuestion2;
				
	 	   	   			nvDefault = NO;
						nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
						if(nvAskButtonRetValue = YES) then
							
						//check backup folder
							if (ExistsDir (gBackupPath) != EXISTS) then 
							CreateDir (gBackupPath);
							endif;  
							//copy files in backup folder
							XCopyFile (szTargetFile,  gBackupPath ,COMP_NORMAL); 						
							
							
						//copy new files
						nvResult = XCopyFile (szSrcFile, szTargetPath,COMP_NORMAL);
						WriteToLogFile(INSTALL_LOG, "Copied " + szTargetFile);
						
						else 
						//do nothing
						WriteToLogFile(INSTALL_LOG, "don't Copy " + szTargetFile);
						endif;
						
			else
					
						nvResult = XCopyFile (szSrcFile, szTargetPath,COMP_NORMAL);
						WriteToLogFile(INSTALL_LOG, "Copied " + szTargetFile);
			endif;
		
	
	WriteToLogFile(INSTALL_LOG, "Copy DashBoard files completed.");
	SdShowMsg ( "Copying Dashboard files . . . please wait." , FALSE );
	
	return 0;


end;

////////////////////////////////////////////////////////////////////////////////////////
//                                                                                    //
// Function:  RunDashBoardScripts  								              //  
//                                                                                    //
// Purpose:  
//                                                                                    //                                                                                                       //
//                                                                                    //
////////////////////////////////////////////////////////////////////////////////////////

function RunDashBoardScripts()
	LIST lstFiles;
	NUMBER nRes,nBuffer;
	STRING sFileName, szExecutionError;
	BOOL bSuccess;
	STRING svFileName,svFileNameForList,svDir;

begin
	//From DashBoard Installer
	
	//InstallComponentSQL();
	//ExecuteSQLScript();--> this can be replace by DatanaseExecute() of Pure
	
	SdShowMsg ( "Executing DashBoard scripts . . . please wait." , TRUE );
	WriteToLogFile(INSTALL_LOG, "Runing DashBoard scripts...");
	lstFiles = ListCreate (STRINGLIST);
	svDir= TARGETDIR ^ "Dashboard";
	
	if (StrLengthChars(svDir) > 0) then
		if (FindAllFiles(svDir, "*.sql", svFileName, RESET) = 0) then
			ParsePath(svFileNameForList, svFileName,FILENAME); 
			if (ListFindString(lstFiles, svFileNameForList) > 0) then
					ListAddString(lstFiles, svFileNameForList, AFTER);
			endif;
			
			while (FindAllFiles(svDir, "*.sql", svFileName, CONTINUE) = 0)
				ParsePath(svFileNameForList, svFileName,FILENAME); 
				if (ListFindString(lstFiles, svFileNameForList) > 0) then
					ListAddString(lstFiles, svFileNameForList, AFTER);
				endif;
			endwhile;
		endif;
	endif;
	
	FindAllFiles(svDir, "*.sql", svFileName, CANCEL);
	
	nRes = ListGetFirstString(lstFiles, sFileName);
	while (nRes != END_OF_LIST)
		//Add Path To File Name
		sFileName = svDir ^ sFileName;
		
		if( !REMOVEONLY ) then
			bSuccess = ExecuteSQLScript(sFileName);
			//ParseSQLFile(sFileName);
		endif;
		
		if (bSuccess = FALSE) then
			
		endif;
		
		//Next entry
		nRes = ListGetNextString(lstFiles, sFileName);
	endwhile;
	
	SdShowMsg ( "Executing DashBoard scripts . . . please wait." , FALSE );
	
	return 0;


end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CreateDashBoardRegistry 	                                                 //
//				                                                                     //
// Purpose:   This function create DashBoardRegsitry                                    //
///////////////////////////////////////////////////////////////////////////////////////
function CreateDashBoardRegistry()
STRING szKey;
NUMBER nSize,nType;
STRING szDashBoardDBServer,szDashBoardDB;
begin 
    nSize= -1;
    nType= REGDB_STRING;
	szKey="SOFTWARE\\Pure\\PureInstallation\\DashBoard";
	szDashBoardDBServer="DBServer";
	szDashBoardDB="DBName";
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    RegDBCreateKeyEx(szKey, "");
   
    //DashBoard database registry
	RegDBSetKeyValueEx (szKey, szDashBoardDBServer, nType, g_szDBServer, nSize);
	RegDBSetKeyValueEx (szKey, szDashBoardDB, nType, g_DashBoardDB, nSize);
	return 0;
end;

///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  GetDashBoardRegistry 	                                                 //
//				                                                                     //
// Purpose:   This function gets DashBoardRegistry                                    //
///////////////////////////////////////////////////////////////////////////////////////
function GetDashBoardRegistry()
STRING szKey;
NUMBER nSize,nType;
STRING szDashBoardDBServer,szDashBoardDB,svDashBoardDBServer,svDashBoardDB;
begin 
    nSize= -1;
    nType= REGDB_STRING;
	szKey="SOFTWARE\\Pure\\PureInstallation\\DashBoard";
	//szAppLicationPortalKey = szKey ^ g_szApplicationPortal;
	
	szDashBoardDBServer="DBServer";
	szDashBoardDB="DBName";
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    if(RegDBKeyExist(szKey)=1) then
		g_DashBoardExists=TRUE;
		
		if(RegDBGetKeyValueEx (szKey, szDashBoardDBServer, nType, svDashBoardDBServer, nSize) <0) then
			g_DashBoardExists=FALSE;
		else
			//g_PortalDBServer=svPortalDBServer;
			//WriteToLogFile(INSTALL_LOG,"DashBoard DB Server=" + g_PortalDBServer);
		endif;
		if(RegDBGetKeyValueEx (szKey, szDashBoardDB, nType, svDashBoardDB, nSize) <0) then
			g_DashBoardExists=FALSE;
		else
			g_DashBoardDB=svDashBoardDB;
			WriteToLogFile(INSTALL_LOG,"DB Name=" + g_DashBoardDB);
		endif;
	else
		g_DashBoardExists=FALSE;
	endif;
	return 0;
end;


///////////////////////////////////////////////////////////////////////////////
//
//	Function: ExecuteSQLScript
//
//	Purpose: This function will execute a SQL script.
//
// 	Arguments: 	svScriptFile - A fully qualified path to a SQL script file
//			svErrLog - Reference to a string which will contain teh log of errors occured during the execution of SQL script file
//
//	Usage: 
//	ExecuteSQLScript("C:\Scripts\tables.sql", svLog)
//
//	Notes:		You could change this function to accept the script as a string
//			instead of the file.  With a file, you can add the scripts
//			as files in the installation, putting them in a directory.
//			This would allow them to be reused later, or they can just be
//			deleted after each script is run.
//
///////////////////////////////////////////////////////////////////////////////     
function BOOL ExecuteSQLScript(svScriptFile)
	OBJECT pADOObj, pADOCommObj;
	STRING szADOObjID, szADOCommObjID;
	STRING svLine, szConnString, szSQL, svString;
	STRING szHead, szTail;
	NUMBER nResult, nRecords, nBegin, nEnd;
	BOOL   bExitLoop;
	LIST   listID;
	LIST   listCmd;
	number nRet;
	string szErrorLog;
begin
	//LogErrorMessage("Entering to execute file " + svScriptFile, "ExecuteSQLScript", FALSE);
	szErrorLog = "";
	nRet = 0;
	 // Create an empty string list.
	listID = ListCreate(STRINGLIST);
	listCmd = ListCreate(STRINGLIST);
	
	// Read the SQL script file into the list
	if (ListReadFromFile(listID, svScriptFile) < 0) then // read list from file
		//svErrLog = "Unable to open SQL script: " + svScriptFile + ".";
		return FALSE;
	endif;
	
	// Go through each list item and add it to a string (which will then hold the script)
	szSQL = "";
	nResult = ListGetFirstString(listID, svString);
	while (nResult = 0)
		if (StrFind(svString, "GO") = 0) then
			// Remove comments
			bExitLoop = FALSE;
			repeat
				nBegin = StrFind(szSQL, "/*");
				nEnd = StrFind(szSQL, "*/");
				if ((nBegin >= 0) && (nBegin < nEnd)) then
					StrSub(szHead, szSQL, 0, nBegin);
					StrSub(szTail, szSQL, nEnd+2, 65535);
					szSQL = szHead + szTail;
				else
					bExitLoop = TRUE;
				endif;
			until (bExitLoop);
			// Add it to commands
			if (StrLengthChars(szSQL) > 0) then
				ListAddString(listCmd, szSQL, AFTER);
			endif;
			szSQL = "";
		elseif (StrFind(svString, "--") = 0) then
			// It is a comment, so do nothing
		else
			szSQL = szSQL + "\r\n" + svString; 
		endif;
		nResult = ListGetNextString(listID, svString);		
	endwhile;
	
	// Add it to commands
	if (StrLengthChars(szSQL) > 0) then
		ListAddString(listCmd, szSQL, AFTER);
	endif;
	
	//szSQL = "";
	
	DatabaseExecute(listCmd,svScriptFile);
	
	// Be good and clean up your trash
	ListDestroy(listID);
	
	// Be good and clean up your trash
	ListDestroy(listCmd);
	
	
end;
///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  Update_Refresh_Sirius_BatFile 	                                                 //
//				                                                                     //
// Purpose:   This function gets DashBoardRegistry                                    //
///////////////////////////////////////////////////////////////////////////////////////

function Update_Refresh_Sirius_BatFile()
number nvResult,nvLineNumber,nvPatternStartLocation,nvReturnLineLength,nvPatternLength;
string szFile,szReturnLine,szBeforePattern,szAfterPattern,szModifiedLine;
STRING szPath,szMatchPattern,szReplacePattern;
begin   

	SdShowMsg ( "Updating  Refresh_Sirius.bat . . . please wait." , TRUE );
	szFile = TARGETDIR ^ "Dashboard" ^ "Refresh_Sirius.bat";
	
	//Setup DBuserName
	
	//g_szMasterUser,g_szMasterPassword
	
		szMatchPattern = "[USERNAME]";
	szReplacePattern = g_szMasterUser;

	SetFileInfo(szFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
 
	nvPatternLength =  StrLengthChars(szMatchPattern);
	nvResult = FileGrep (szFile,szMatchPattern,szReturnLine,nvLineNumber,RESTART);
	while (nvResult = 0) 
		nvPatternStartLocation = StrFind(szReturnLine,szMatchPattern);
		nvReturnLineLength = StrLengthChars(szReturnLine);
		if (nvPatternStartLocation >= 0) then    
	     	StrSub(szBeforePattern,szReturnLine,0,nvPatternStartLocation);
	    	StrSub(szAfterPattern,szReturnLine,nvPatternStartLocation+nvPatternLength,nvReturnLineLength-(nvPatternStartLocation+nvPatternLength));
	   		szModifiedLine = szBeforePattern + szReplacePattern + szAfterPattern;
			
			nvResult= FileInsertLine(szFile,szModifiedLine,nvLineNumber,REPLACE);
	     	if(nvResult < 0) then
		  	  WriteToLogFile(INSTALL_ERRORLOG,"Replacing Pattern of "+szMatchPattern+ " with this "+szReplacePattern+" Failed in File "+szFile);
		  	  return -1;
			endif;
	 	endif;
		nvResult = FileGrep(szFile,szMatchPattern, szReturnLine, nvLineNumber,CONTINUE);
	endwhile;  
	
	//Set db user password
	
		szMatchPattern = "[PASSWORD]";
	szReplacePattern = g_szMasterPassword;

	SetFileInfo(szFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
 
	nvPatternLength =  StrLengthChars(szMatchPattern);
	nvResult = FileGrep (szFile,szMatchPattern,szReturnLine,nvLineNumber,RESTART);
	while (nvResult = 0) 
		nvPatternStartLocation = StrFind(szReturnLine,szMatchPattern);
		nvReturnLineLength = StrLengthChars(szReturnLine);
		if (nvPatternStartLocation >= 0) then    
	     	StrSub(szBeforePattern,szReturnLine,0,nvPatternStartLocation);
	    	StrSub(szAfterPattern,szReturnLine,nvPatternStartLocation+nvPatternLength,nvReturnLineLength-(nvPatternStartLocation+nvPatternLength));
	   		szModifiedLine = szBeforePattern + szReplacePattern + szAfterPattern;
			
			nvResult= FileInsertLine(szFile,szModifiedLine,nvLineNumber,REPLACE);
	     	if(nvResult < 0) then
		  	  WriteToLogFile(INSTALL_ERRORLOG,"Replacing Pattern of "+szMatchPattern+ " with this "+szReplacePattern+" Failed in File "+szFile);
		  	  return -1;
			endif;
	 	endif;
		nvResult = FileGrep(szFile,szMatchPattern, szReturnLine, nvLineNumber,CONTINUE);
	endwhile;  
	
	//-------------------------------------------------------//
	szMatchPattern = "[DBSERVERNAME]";
	szReplacePattern = g_szDBServer;

	SetFileInfo(szFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
 
	nvPatternLength =  StrLengthChars(szMatchPattern);
	nvResult = FileGrep (szFile,szMatchPattern,szReturnLine,nvLineNumber,RESTART);
	while (nvResult = 0) 
		nvPatternStartLocation = StrFind(szReturnLine,szMatchPattern);
		nvReturnLineLength = StrLengthChars(szReturnLine);
		if (nvPatternStartLocation >= 0) then    
	     	StrSub(szBeforePattern,szReturnLine,0,nvPatternStartLocation);
	    	StrSub(szAfterPattern,szReturnLine,nvPatternStartLocation+nvPatternLength,nvReturnLineLength-(nvPatternStartLocation+nvPatternLength));
	   		szModifiedLine = szBeforePattern + szReplacePattern + szAfterPattern;
			
			nvResult= FileInsertLine(szFile,szModifiedLine,nvLineNumber,REPLACE);
	     	if(nvResult < 0) then
		  	  WriteToLogFile(INSTALL_ERRORLOG,"Replacing Pattern of "+szMatchPattern+ " with this "+szReplacePattern+" Failed in File "+szFile);
		  	  return -1;
			endif;
	 	endif;
		nvResult = FileGrep(szFile,szMatchPattern, szReturnLine, nvLineNumber,CONTINUE);
	endwhile;   
	
	szMatchPattern="[DBNAME]";
	szReplacePattern=g_szSiriusDBName;
	
	SetFileInfo(szFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
	
 
	nvPatternLength =  StrLengthChars(szMatchPattern);
	nvResult = FileGrep (szFile,szMatchPattern,szReturnLine,nvLineNumber,RESTART);
	while (nvResult = 0) 
		nvPatternStartLocation = StrFind(szReturnLine,szMatchPattern);
		nvReturnLineLength = StrLengthChars(szReturnLine);
		if (nvPatternStartLocation >= 0) then    
	     	StrSub(szBeforePattern,szReturnLine,0,nvPatternStartLocation);
	    	StrSub(szAfterPattern,szReturnLine,nvPatternStartLocation+nvPatternLength,nvReturnLineLength-(nvPatternStartLocation+nvPatternLength));
	   		szModifiedLine = szBeforePattern + szReplacePattern + szAfterPattern;
			
			nvResult= FileInsertLine(szFile,szModifiedLine,nvLineNumber,REPLACE);
	     	if(nvResult < 0) then
		  	  WriteToLogFile(INSTALL_ERRORLOG,"Replacing Pattern of "+szMatchPattern+ " with this "+szReplacePattern+" Failed in File "+szFile);
		  	  return -1;
			endif;
	 	endif;
		nvResult = FileGrep(szFile,szMatchPattern, szReturnLine, nvLineNumber,CONTINUE);
	endwhile;   
	
	SdShowMsg ( "Updating  Refresh_Sirius.bat . . . please wait." , FALSE );

	return 0;
end;

