///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  RunGISListCreator  								             //
//                                                                           //
// Purpose:   This function runs GISListCreator.exe and updates GIS user def //
//            details values present in Lists\DEFList0101.txt                //
///////////////////////////////////////////////////////////////////////////////

function RunGISListCreator()
string  szFile,szCommand;
number nvResult;
begin    

SdShowMsg ( "Updating GIS user def details . . . please wait." , TRUE );
szFile = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "GISListCreator.exe";
szCommand= TARGETDIR ^ "Lists\\DEFList0101.txt";

// Stick some quotes around the path
if (LongPathToQuote(szFile,TRUE) != 0) then
	MessageBox ("Unable to convert path to quoted path.\n" + szFile, SEVERE );
else
	nvResult = LaunchAppAndWait(szFile,szCommand, LAAW_OPTION_WAIT);
    if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Unable to launch the following file : \n" +" " + szFile + "\nYou need to run this for Updating GIS user def details.");
    else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"Updating GIS user def details with Command=" + szCommand);
   endif;
endif;
   
SdShowMsg ( "Updating GIS user def details . . . please wait." , FALSE );

return 0;
end; 

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  Registerdsoframer  								             //
//                                                                           //
// Purpose:   This function regsiter dsoframer.ocx 							 //
//            													             //
///////////////////////////////////////////////////////////////////////////////

function Registerdsoframer()
	STRING	szProgram,szCommand,szFile;
	NUMBER  nvResult,nvExitCode;
begin
	
	szFile = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "dsoframer.ocx";
	
	if (!Is(FILE_EXISTS, szFile)) then
		MessageBox ("Unable to find" + szFile, SEVERE );
	endif;

	szProgram = WINSYSDIR ^ "regsvr32.exe";
	szCommand = "/s \"" + szFile + "\"";
	
	nvResult = LaunchAppAndWait(szProgram,szCommand, LAAW_OPTION_WAIT);
    
    if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Unable to register the following file : \n" +" " + szFile + "\nPlease register this file manually.");
    else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"Registering the following file Command=" + szCommand);
    endif;

return 0;

end; 

////////////////////////////////////////////////////////////
//
//
//
//////////////////////////////////////////////////////////////
function BOOL CheckApplicationInUse(listInUseApplications)
    NUMBER	nvDataType;
	STRING	szPath;
	NUMBER	nvSize;

	STRING	svFileName,svFileNameForList;
	BOOL	bInUse;
	BOOL	bReturn;
	NUMBER  nvRet;
begin
	
	//WriteToLogFile(UNINSTALL_LOG,"entering CheckApplicationInUse function");
	bReturn = FALSE;
	bInUse = FALSE;
	ListDestroy(listInUseApplications);
	listInUseApplications = ListCreate(STRINGLIST);

	if (StrLengthChars(TARGETDIR) > 0) then
		if (FindAllFiles(TARGETDIR, "*.exe", svFileName, RESET) = 0) then
			ParsePath(svFileNameForList, svFileName,FILENAME); 
			WriteToLogFile(UNINSTALL_LOG,"CheckApplicationInUse:" + svFileName);
			bInUse = Is(FILE_LOCKED, svFileName);
			bReturn = bReturn || bInUse;
			if (bInUse = TRUE) then
				//MessageBox(svFileName,INFORMATION);
				//WriteToLogFile(UNINSTALL_LOG,"Locked File:" + svFileName);
				if (ListFindString(listInUseApplications, svFileNameForList) > 0) then
					ListAddString(listInUseApplications, svFileNameForList, AFTER);
				endif;
			endif;
			while (FindAllFiles(TARGETDIR, "*.exe", svFileName, CONTINUE) = 0)
				ParsePath(svFileNameForList, svFileName,FILENAME); 
				WriteToLogFile(INSTALL_LOG,"CheckApplicationInUse:" + svFileName);
				bInUse = Is(FILE_LOCKED, svFileName);
				bReturn = bReturn || bInUse; 
				if (bInUse = TRUE) then
					//MessageBox(svFileName,INFORMATION);
					//WriteToLogFile(UNINSTALL_LOG,"Locked File:" + svFileName);
					if (ListFindString(listInUseApplications, svFileNameForList) > 0) then
						ListAddString(listInUseApplications, svFileNameForList, AFTER);
					endif;
				endif;
			endwhile;
		endif;
	endif;
	FindAllFiles(TARGETDIR, "*.exe", svFileName, CANCEL);

	
	return bReturn;
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  RegisterMSScriptControlDll  								     //
//                                                                           //
// Purpose:   This function regsiter MSScriptControl dlls in system32 folder //
//            													             //
///////////////////////////////////////////////////////////////////////////////

function RegisterMSScriptControlDll()
	STRING	szProgram,szCommand,szFile,szPureFile;
	NUMBER  nvResult,nvExitCode;
begin	
	szPureFile = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "MSScriptControl64.dll";
	szFile = WINSYSDIR64 ^ "MSScriptControl64.dll";
	if (!Is(FILE_EXISTS, szFile)) then		
		XCopyFile ( szPureFile, WINSYSDIR64, COMP_NORMAL );
		WriteToLogFile(INSTALL_LOG,"Successfully copied the MSScriptControl64.dll");		
		szProgram = WINSYSDIR64 ^ "regsvr32.exe";	
		szCommand = "/s \"" + szFile + "\"";		
		nvResult = LaunchAppAndWait(szProgram,szCommand, LAAW_OPTION_WAIT);		
		if (nvResult < 0) then
		  WriteToLogFile(INSTALL_ERRORLOG,"Unable to register the following file : \n" +" " + szFile + "\nPlease register this file manually.");
		else                                                                                     
		  WriteToLogFile(INSTALL_LOG,"Registering the following file Command=" + szCommand);
		endif;
	endif;
	DeleteFile(szPureFile);
return 0;

end; 


