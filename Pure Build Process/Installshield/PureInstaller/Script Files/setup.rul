//---------------------------------------------------------------------------
// OnSQLServerInitialize
//
// The OnSQLServerInitialize event is called by OnFirstUIBefore to
// establish any connections necessary for SQL Server support.
//
// This function will initialize the SQL Server runtime, and attempt to
// make any necessary SQL Server connections, displaying a login dialog
// for each one.
//
// Parameter nBtn indicates whether NEXT or BACK was the result of the 
// previously displayed dialog.  It is for information purposes only.
//
// Note: This event will not be called automatically in a
// program...endprogram style setup.
//---------------------------------------------------------------------------
function number OnSQLServerInitialize( nBtn )
number nResult, nErrorCode, nErrorLine;
number nCount;
string szConnection;
string szServer, szDB, szUser, szPassword;
string szMessage;
string szKey;
LIST   listConnections;
BOOL   bWinLogin;
BOOL   bNext;
NUMBER nvErrorCode;
STRING svTechnology;
begin
	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
	
	
    //First initialize SQL Server runtime
    SQLRTInitialize2( );

    //Get the names of all the necessary connections
    listConnections = SQLRTGetConnections();
    ListGetFirstString (listConnections, szConnection);

    nCount = 0;

    //determine if NEXT or BACK will be returned 
    //if there are no connections to make
    if( nBtn != BACK ) then
        bNext = TRUE;
    else
        bNext = FALSE;
		//start at end if going BACK
		while (ISERR_SUCCESS = ListGetNextString( listConnections, szConnection ) );
			nCount++;
		endwhile;
    endif;

    // Login for each connection
    while (nResult = ISERR_SUCCESS)

        //Get Default values for connection
        SQLRTGetConnectionInfo( szConnection, szServer, szDB, szUser, szPassword );
        bWinLogin = SQLRTGetConnectionAuthentication( szConnection );
        bWinLogin = FALSE;
        
        //Assign the DB Server Name if one is already available for pure upgrade or product upgrade but fresh installation           
	    szServer   = g_szDBServer; 
	    
	    
	    if(g_bProductUpgradeNewInstaller = TRUE || g_bUpgradeInstaller = TRUE || g_bPatchInstallation = TRUE) then
           szDB = "master";
	       Dlg_SQLConnection: 
        
						// Display login dialog (without connection name)
						// COMMENT OUT TO SWAP DIALOGS
						nResult = SQLServerSelectLogin2( szConnection, szServer, szUser, szPassword, bWinLogin, szDB, FALSE, FALSE );
						g_bWinLoginAuthenticate = bWinLogin;
						if(StrCompare(szServer,g_szDBServer) != 0) then
							MessageBox("The Database Server Name cannot be changed for Upgrades.",WARNING);
							goto  Dlg_SQLConnection;
						endif;	           		
	    endif;
	    
	    if(g_bAppServerWithDB = TRUE) then
	    	szDB = "master";
	    endif;  
	    
	    if(g_bFreshInstaller = TRUE) then
	    
				Dlg_SQLConnection1:
	    
					if(g_bAppServerWithDB = TRUE) then
						nResult = SQLServerSelectLogin2( szConnection,szServer,szUser,szPassword,bWinLogin,szDB,FALSE,FALSE);
					else
						nResult = SQLServerSelectLogin2( szConnection,szServer,szUser,szPassword,bWinLogin,szDB,FALSE,g_bAppServerOnly);
					endif;
					
					g_bWinLoginAuthenticate = bWinLogin;
	       
					if(g_bAppServerOnly = TRUE && g_bAppServerWithDB = FALSE ) then
						if(szDB="")then
							MessageBox("Database name is empty, Please specify which database name should be used for connection.\n\n" +
								   "Click the Browse button to select database name available on the database server.",WARNING);
							goto  Dlg_SQLConnection1;
						
						endif;
					endif;	
		 endif;
		
		if( nResult = NEXT ) then
			
			
            //store data in case we need it again
            SQLRTPutConnectionInfo2( szConnection, szServer, szDB, szUser, szPassword );

	        SQLRTPutConnectionAuthentication( szConnection, bWinLogin );

            //try connection
            nResult = SQLRTConnect( szConnection, szServer, bWinLogin, szUser, szPassword );
            //nResult = SQLRTConnect2( szConnection, szServer, bWinLogin, szUser, szPassword, szDB);
            //nResult = SQLRTConnectDB( szConnection, szDB, szServer, bWinLogin, szUser, szPassword );
            //SQLRTTestConnection2( szConnection, szServer, szDB, szUser, szPassword, bWinLogin );
            //SQLRTConnect2( szConnection, szServer, bWinLogin, szUser, szPassword, szDatabaseServer ); 

            //if( szTemp != "0" && MODE != SILENTMODE) then
			//		nResult = ListCurrentString(listConnections, szConnection);
			
			if( nResult < ISERR_SUCCESS && MODE != SILENTMODE ) then

                // Get error message
				//SQLRTGetErrorMessage( szMessage );
				SQLRTGetLastError2( nvErrorCode, szMessage, svTechnology, szConnection, szServer, szDB ); 
				//Sprintf(szMessage, SdLoadString( IDS_IFX_SQL_ERROR_LOGIN_FAILED ), szConnection, SdLoadString( ISCRIPT_E_UNKNOWN_ERROR_DESC ));
				// Display error
				MessageBox( szMessage, MB_OK );

                //Show same login dialog again
                nResult = ListCurrentString(listConnections, szConnection);
					
			elseif(MODE = SILENTMODE) then //WorkAround to solve the Silent Mode Issue for TestConnection Method
			//Move on to next connection
	                nCount++;
	                bNext = TRUE;
	                nResult = ListGetNextString(listConnections, szConnection);
	                     
	                                
	                if(g_bAppServerOnly = TRUE && g_bAppServerWithDB = FALSE && g_bFreshInstaller = TRUE) then
	                	g_szDBServer =  szServer;
	                	g_szSiriusDBName = szDB;  
	                	
	                	if(g_bWinLoginAuthenticate = FALSE) then
	                		g_szMasterUser    =   szUser;
							g_szMasterPassword =  szPassword;  
							/*Added below 2 lines based on Bal's Remarks on May 22 2009 
						  	No Specific Sirius User Name/Password would be used
			  			 	 Master Login User/Password would be used for Sirius DB Scripts execution */
			       			g_szSiriusUserName =  szUser;
							g_szSiriusPassword =  szPassword;
						endif;
	                else
	                	g_szDBServer      = szServer;
	                	if(g_bWinLoginAuthenticate = FALSE) then
							g_szMasterUser    =   szUser;
							g_szMasterPassword =  szPassword;  
							/*Added below 2 lines based on Bal's Remarks on May 22 2009 
						  	No Specific Sirius User Name/Password would be used
			  			  	Master Login User/Password would be used for Sirius DB Scripts execution */
			       			g_szSiriusUserName =  szUser;
							g_szSiriusPassword =  szPassword;     
						endif;
					endif;
             else //SUCCESS
                   //Move on to next connection
	                nCount++;
	                bNext = TRUE;
	                nResult = ListGetNextString(listConnections, szConnection);
	                if(g_bAppServerOnly = TRUE && g_bAppServerWithDB = FALSE && g_bFreshInstaller = TRUE) then
	                	g_szDBServer =  szServer;
	                	g_szSiriusDBName = szDB;
	                	if(g_bWinLoginAuthenticate = FALSE) then
	                		g_szMasterUser    =   szUser;
							g_szMasterPassword =  szPassword;  
							/*Added below 2 lines based on Bal's Remarks on May 22 2009 
						  	No Specific Sirius User Name/Password would be used
			  			  	Master Login User/Password would be used for Sirius DB Scripts execution */
			       			g_szSiriusUserName =  szUser;
							g_szSiriusPassword =  szPassword;
						endif;
	                else
	                	g_szDBServer      = szServer;
	                	if(g_bWinLoginAuthenticate = FALSE) then
							g_szMasterUser    =   szUser;
							g_szMasterPassword =  szPassword; 
							/*Added below 2 lines based on Bal's Remarks on May 22 2009 
						 	 No Specific Sirius User Name/Password would be used
			  			  	Master Login User/Password would be used for Sirius DB Scripts execution */
				      		g_szSiriusUserName =  szUser;
							g_szSiriusPassword =  szPassword; 
						endif;
					endif; 
			 endif;			
            
         else
            //BACK
            nCount--;
            bNext = FALSE;
            nResult = ListSetIndex( listConnections, nCount );
            ListCurrentString( listConnections, szConnection );

        endif;

    endwhile;

    if( bNext ) then
        return NEXT;
    else
        return BACK;
    endif;

end;


//---------------------------------------------------------------------------
//  OnResumeUIBefore
//
//  The OnResumeUIBefore event is called when end user runs installation that
//  is performing a resumed install. Usually this happens by specifying
//  a property like REINSTALL or ADDLOCAL at the command line when the 
//  product is already installed. After this function returns, 
//  ComponentTransferData is called to perform file transfer.
//---------------------------------------------------------------------------
function OnUpdateUIBefore()
	number    nvResult,nResult;
	string szTitle, szMsg;
	LIST lAppInUse;
	BOOL bFileInUse;
begin   
REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
Disable(WOW64FSREDIRECTION);
//if(g_bAppServerWithDB = TRUE) then
//Upgrade the PMLogicalDatabase after successful upgrade DB Installation
SetUpgradedFolderVersionsToPMLogicalDatabase();

Dlg_SdWelcome:
	szTitle = "Resume Upgrading AppServer Installation";
	szMsg   ="Click Next to Continue upgrading the Application Components to "+g_szTobeInstalledFullVersion+" from current version "+g_szInstalledFullVersion;
	Disable(BACKBUTTON);
    nvResult = SdWelcome(szTitle, szMsg);
//endif;

	
		BackupConfigFiles();	
	
	Disable (DIALOGCACHE);
	
    //Stop the Pure Service
    //LaunchAppAndWait ("net stop PureWindowsService", "", WAIT);
    
    StopPureService();
    
    szMsg = "Installer is Upgrading the SSP Pure Insurance Installation to Version "+g_szTobeInstalledFullVersion+" from Current Version "+g_szInstalledFullVersion;
    
	SdSubstituteProductInfo(szMsg);
    SetStatusExStaticText(szMsg);
    
    
    Enable(STATUSEX);
    SetStatusWindow (0, ""); 
    StatusUpdate (ON, 99); 


    //Call FeatureReinstall to reinstall all the files
    FeatureReinstall();
    FeatureTransferData(MEDIA);

	
end;  

 

//---------------------------------------------------------------------------
// OnResumeUIAfter
//
// The OnResumeUIBefore event is called when end user runs installation that is
// performing a resumed install. Usually this happens by specifying a property
// like REINSTALL or ADDLOCAL at the command line when the  product is already
// installed. In the handler, installation usually displays UI that will
// inform end user that Reinstallation has been completed successfully.
//---------------------------------------------------------------------------
function OnUpdateUIAfter()
    string szTitle, szMsg1, szMsg2, szOption1, szOption2,szFileName;
    number bOpt1, bOpt2, nvResult;
begin
	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
	szFileName = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "WCFSecurityTokenFile.txt";
	
	if(g_WCFServices=TRUE) then
		if Is(FILE_EXISTS, szFileName) = TRUE then
			ReadWCFSecurityTokenFile();
		else
			RunGenerateWCFTokenID();
			ReadWCFSecurityTokenFile();
		endif;
	endif;

	if(g_bAppServerOnly=TRUE || g_WCFServices=TRUE) then
		if(g_SkipDb=FALSE) then	
			ReadPureConfigFiles();
		endif;	
	endif;
	
	if(g_bAppServerOnly=TRUE || g_bWebServices=TRUE || g_WCFServices=TRUE) then
		
		RemoveFilesDuringInstall();
	
	endif;
	
	/*
	if(g_bAppServerOnly=TRUE) then
		UpdatePMWorkManagerConfig();
	endif;
	if(g_WCFServices=TRUE) then
		UpdateWCFServiceConfig();
	endif;
	*/
	
	if(g_bPortal=TRUE || g_WCFServices=TRUE) then
		LoadAppPoolUserProfile();
	endif;
	
	if(g_bPortal=TRUE) then
		ModifyPortalApplicationSetting();
		
		//BSJ Call the registry functions after upgrade 
		UpdateDBRegistryEntriesAfterInstallation();
		
		//Configure ASP .NET state service
		ConfigureAspDotNetSateService();
		
	endif;
	
	
	/*if(g_bPortal=TRUE) then
		CopyCrystalReportWebFormViewer4Files();
	endif;*/
	
	if(g_bAppServerOnly=TRUE || g_WCFServices=TRUE) then
		
		RemovePureWebServicesDuringInstall();
	
	endif;

	Disable(STATUSEX);

	//szTitle = SdLoadString(IDS_IFX_SDFINISH_UPDATE_TITLE);    
   // szMsg1  = SdLoadString(IDS_IFX_SDFINISH_UPDATE_MSG1);
	bOpt1   = FALSE;
    bOpt2   = FALSE; 
    
    /*if (g_bAppServerOnly=TRUE || g_bAppServerWithDB=TRUE) then
		SetupWord();    
	endif;
	*/
	
    //This Method updates the Registry Entries after upgrade installation
	//UpdateRegistryEntriesAfterInstallation();
	
    if (g_bAppServerOnly=TRUE || g_bAppServerWithDB=TRUE) then
		if(g_bWinLoginAuthenticate =FALSE) then
			//Create the Inbuilt Sirius Username/Password for use by Sirius Back Office Application
			//CreateSiriusLogin();
		else
       	//Leave as such without creating the Sirius Username/Password 
       	//as Windows Authentication is used by Sirius BackOffice Application
		endif;	
	endif;		            
    
    //Update all the System DSNs for any changes with DB,DBServer,Authentication Mode
    if (g_bAppServerOnly=TRUE || g_bAppServerWithDB=TRUE) then
    	UpdateODBCDSNs();
    
		//RegisterPMFieldManager();
	
		// Run UpdatePMWrkTasks.sql during upgrade, Also changed SRCDIR to SETUPEXEDIR
       /* if ParseSQLFile(SRCDIR ^ "Scripts" ^ "UpdatePMWrkTasks.sql") < 0  then
			WriteToLogFile(INSTALL_ERRORLOG,"Error occured while updating the table PMWrk_Task"); 
		else
			WriteToLogFile(INSTALL_LOG,"Successfully updated the table PMWrk_Task"); 
		endif;
		*/
	endif;
	
	
	//BSJ Update the pm product client install
	//UpdateProductClientInstall();
    
	//f (g_bAppServerOnly=TRUE) then
	//	//Updated Ssce.ini file
    //	UpdateSsceINIFile();
	//endif;
    
    // Run CompleteWebServicesInstall.cmd during upgrade
    //if(g_bAppServerOnly=TRUE || g_bWebServices=TRUE) then
	//	RunCompleteWebServicesInstallCmdFile();
    //endif;
    
    
    // setup user permission
	//SetUpPermissions();
    
	//SetupRegistryPermissions();
    
	// Run GISListCreator.exe
	//RunGISListCreator();
	
    // Run data Model rebuild
    //DataModelRebuild();
	

    szTitle = "SSP Pure Upgrade Installation Complete";
    szMsg1 = "SSP Pure Insurance Installation has been successfully upgraded to Version "+g_szTobeInstalledFullVersion+" from Version "+g_szInstalledFullVersion+".Click Finish to exit the Wizard"; 
    szMsg2 = "Click Finish to exit %P setup.";
    
  	SdFinishReboot(szTitle,szMsg1,SYS_BOOTMACHINE,szMsg2,0);

end;

