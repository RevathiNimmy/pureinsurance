///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ValidateLoggedinUser                                           //
//                                                                           //
// Purpose:   This function validates whether the 			                 //
//            logged in user of the target machine is an administrative user //
//                                                                           //
///////////////////////////////////////////////////////////////////////////////

function number ValidateLoggedinUser()
string szLogonUser;  
number nvBufferSize;
BOOL bReturnFlag;

begin   
	nvBufferSize = 256;
	//MsiGetProperty(ISMSI_HANDLE,"LogonUser",szLogonUser,nvBufferSize);
	bReturnFlag = IsUserMemberOfGroup(g_szHostName,g_szUserName,"Administrators");
	if(bReturnFlag = FALSE) then
		g_bPreRequisiteFailure = TRUE;
		MessageBox("The Logged in user should be an administrator to carry out installations",SEVERE);
		abort;
	endif;

return 1;		
end;    
  

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  CreateLogFile                                                  //
//                                                                           //
// Purpose:   This function takes a text filename as an input parameter      //
//			  and it creates a Installation Normal/Error Logs Uninstallation //
//			  Normal/Error Logs Database Normal/Error Logs                   //
///////////////////////////////////////////////////////////////////////////////

function number CreateLogFile(szFileName)
number nvResult,nvFileHandle; 
string szPath;
begin         
szPath = WINDISK + "\\";
OpenFileMode(FILE_MODE_APPEND); 


nvResult = CreateFile(nvFileHandle,szPath,szFileName); 
if(nvResult < 0) then
	MessageBox("Log File "+szFileName +" Cannot be Created",INFORMATION);
endif;

return 1;
end;          


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ReadFromINI                                                    //
//                                                                           //
// Purpose:   This function is used to read a section and a key/value pair   //
//			  present in the Config.INI file                                 //
///////////////////////////////////////////////////////////////////////////////
 
 function number ReadFromINI(szSection,listKeynames,listValueNames)
 number nvVal,nvResult; 
 string szINIPath,szSPPFileName; 
 begin
	 
	 nvResult = FindFile(SETUPEXEDIR,"Config.ini",szSPPFileName); 
	 if(nvResult = 0) then
	 	szINIPath = SETUPEXEDIR ^"Config.ini";
		nvVal = GetProfStringList (szINIPath,szSection,listKeynames,listValueNames);  
	 	if (nvVal >= 0) then
	 		return 1;
	 	else                                
	 		return -1;
	 	 endif;
	 else      
	  		return -1;
	 endif;
end;          

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ReadODBCFromINI                                                    //
//                                                                           //
// Purpose:   This function is used to read a section and a key/value pair   //
//			  present in the Config.INI file                                 //
///////////////////////////////////////////////////////////////////////////////
 
 function number ReadODBCFromINI(szSection,listKeynames,listValueNames)
 number nvVal,nvResult; 
 string szINIPath,szScriptpath; 
 begin
	szScriptpath = SRCDIR ^ "scripts";
	szINIPath =szScriptpath ^ "Config.ini";
	nvVal = GetProfStringList (szINIPath,szSection,listKeynames,listValueNames);  
	if (nvVal >= 0) then
		return 1;
	else                                
		return -1;
	endif; 

 end; 

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ReplaceICCSNumber                                              //
//                                                                           //
// Purpose:   This function is used to place the Input ICCS number in case   //
//			  of Fresh installation into the ICCS Sql Script file for        //
//			  execution into the Sirius DB                                   //
///////////////////////////////////////////////////////////////////////////////

function number ReplaceICCSNumber(szFile)
number nvLineNumber,nvResult;
string szReturnLine,szPath;
begin
     
     szPath = WINDISK + "\\";
     //XCopyFile ( szFile, gTemp, COMP_NORMAL ); 
     XCopyFile ( szFile, szPath, COMP_NORMAL );    
     szFile= szPath ^ ICCSFILENAME;
     
     SetFileInfo(szFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");
     	 
	 nvResult = FileGrep (szFile, "[replace]", szReturnLine, nvLineNumber, RESTART);
	 while (nvResult != END_OF_FILE) 
	     if (FileInsertLine (szFile, g_szICCSNumber, nvLineNumber, REPLACE) < 0) then 
	     	MessageBox ("File InsertLine failed.", SEVERE);
		 endif;
		 nvResult = FileGrep (szFile, "[replace]", szReturnLine, nvLineNumber, CONTINUE);
     endwhile; 
	 
	return 1;
end;     


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  CheckTypeofInstallation                                        //
//                                                                           //
// Purpose:   This function is check the type of installation in the         //
//			  target machine as Fresh Installation or Upgrade Installation   //
//			  or Product Upgrade/Fresh Installation	                         //
///////////////////////////////////////////////////////////////////////////////

function number CheckTypeofInstallation()
number nvVersion,nvRootKey;
string szPMRegPath, szFile, Strtrusted;
begin   
nvVersion=VerProductCompareVersions(); 
szPMRegPath = "SOFTWARE\\Pure";

// Make sure that valid data was returned by VerProductCompareVersions
if( nvVersion < ISERR_SUCCESS ) then
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_VERSION_COMPARE_FAILURE );
		//MessageBox( szMsg, SEVERE );
		//abort;
endif;

// Compare version for Fresh/upgrade/Maintanance
CompareVersion();
GetPureInstallLocation();


CheckAccess();




switch (gInstallMode)
case "Upgrade":
             WriteToLogFile(INSTALL_LOG,"Type of installation is Upgrade Installer");
             g_bFreshInstaller  = FALSE;
			 g_bUpgradeInstaller= TRUE;
			 g_bProductUpgradeNewInstaller = FALSE;
			 //Get all the required registry entries for the pure upgrade installation
			 //GetPMRegistryInstalledValuesforUpgradeInstall();
			 GetPureInstallLocation();
			 	szFile = g_InstallLocation +"\\" + "PureConfiguration.xml";  // or INSTALLDIR ^ "PureConfiguration.xml", depending where it is
g_szDBServer = GetPureConfig(szFile, "Server");
g_szSiriusDBName = GetPureConfig(szFile, "Database");
g_TrustedSTR  = GetPureConfig(szFile, "Trusted");

if g_TrustedSTR = "1" then

else
	g_szMasterUser = GetPureConfig(szFile, "SQLLogin");
	DecryptData(g_szMasterUser);
	g_szMasterUser = RemoveBOM(DecryptedData);
	g_szMasterPassword = GetPureConfig(szFile, "SecureKey");
	DecryptData(g_szMasterPassword);
	g_szMasterPassword = RemoveBOM(DecryptedData);

endif;


			CheckAccess();
			
			
CheckOrCreateRegistrySettingsTable();
			                          
			 GetPMDBRegistryInstalledValuesforUpgradeInstall();                                               
		     onUpgradeUIBefore(); 
		     
		     UPDATEMODE = MAINTENANCE && ( nvVersion != VERSION_COMPARE_RESULT_SAME );
		     
case "Same":
			 
			 WriteToLogFile(INSTALL_LOG,"Type of installation is Upgrade Product (Same version)");
             g_bFreshInstaller  = FALSE;
			 g_bUpgradeInstaller= TRUE;
			 g_bProductUpgradeNewInstaller = FALSE;
			 //Get all the required registry entries for the pure upgrade installation
			 //GetPMRegistryInstalledValuesforUpgradeInstall();  
			szFile = g_InstallLocation +"\\" + "PureConfiguration.xml";  // or INSTALLDIR ^ "PureConfiguration.xml", depending where it is
g_szDBServer = GetPureConfig(szFile, "Server");
g_szSiriusDBName = GetPureConfig(szFile, "Database");

g_TrustedSTR  = GetPureConfig(szFile, "Trusted");

if g_TrustedSTR = "1" then
	OnSQLServerInitialize(1);
else
	g_szMasterUser = GetPureConfig(szFile, "SQLLogin");
	DecryptData(g_szMasterUser);
	g_szMasterUser = RemoveBOM(DecryptedData);
	g_szMasterPassword = GetPureConfig(szFile, "SecureKey");
	DecryptData(g_szMasterPassword);
	g_szMasterPassword = RemoveBOM(DecryptedData);

endif;


//CheckAccess();
CheckOrCreateRegistrySettingsTable();

                    
			 GetPMDBRegistryInstalledValuesforUpgradeInstall();                         
		     onUpgradeUIBefore(); 
		     
		     UPDATEMODE = MAINTENANCE && ( nvVersion = VERSION_COMPARE_RESULT_SAME );
		      
		                  
case "Fresh":    
			 
             RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
 			 if (RegDBKeyExist (szPMRegPath) = 1) then 
 			 	if GetFromRegistry("SOFTWARE\\Pure\\SiriusSolutions\\Setup","Version") != "" then
 			 		WriteToLogFile(INSTALL_LOG,"Type of installation is Upgrade Product");
 			 		g_bProductUpgradeNewInstaller = TRUE;
	 				g_bFreshInstaller  = FALSE;
					g_bUpgradeInstaller= FALSE;
					//Get all the required registry entries for the pure upgrade installation
					GetPMRegistryInstalledValuesforUpgradeInstall();                         
					//Check whether any Sirius Users are logged on to the Machine before Upgrades			 
				else   
					WriteToLogFile(INSTALL_LOG,"Type of installation is Fresh Install");
					DeleteRegistryInformation();
					g_bFreshInstaller  = TRUE;
					g_bUpgradeInstaller= FALSE;
					g_bProductUpgradeNewInstaller =  FALSE;      
					//Initializing the Sirius Database Name with "Sirius"
					g_szSiriusDBName = "Pure";
					g_szMDFDirPath =  "";
					g_szLDFDirPath =  "";                                                 
					
				endif;
		     else    
				WriteToLogFile(INSTALL_LOG,"Type of installation is Fresh Install");
				g_bFreshInstaller  = TRUE;
				g_bUpgradeInstaller= FALSE;
				g_bProductUpgradeNewInstaller =  FALSE;      
				//Initializing the Sirius Database Name with "Sirius"
				g_szSiriusDBName = "Pure";
				g_szMDFDirPath =  "";
				g_szLDFDirPath =  "";                                                
			endif; 
			
			//UPDATEMODE= VERSION_COMPARE_RESULT_NOT_INSTALLED;

case "Older":
			 
			 WriteToLogFile(INSTALL_LOG,"A later version of 'Pure Insurance' is already installed on this machine. The setup cannot continue.");
			 MessageBox("A later version of 'Pure Insurance' is already installed on this machine. The setup cannot continue.", SEVERE);
			exit;
			
endswitch; 

 

/*
switch (nvVersion)
case VERSION_COMPARE_RESULT_NEWER:
             WriteToLogFile(INSTALL_LOG,"Type of installation is Upgrade Installer");
             g_bFreshInstaller  = FALSE;
			 g_bUpgradeInstaller= TRUE;
			 g_bProductUpgradeNewInstaller = FALSE;
			 //Get all the required registry entries for the pure upgrade installation
			 GetPMRegistryInstalledValuesforUpgradeInstall();                         
		     onUpgradeUIBefore(); 
		     
case VERSION_COMPARE_RESULT_SAME:
             WriteToLogFile(INSTALL_LOG,"Type of installation is Upgrade Product (Same version)");
             g_bFreshInstaller  = FALSE;
			 g_bUpgradeInstaller= TRUE;
			 g_bProductUpgradeNewInstaller = FALSE;
			 //Get all the required registry entries for the pure upgrade installation
			 GetPMRegistryInstalledValuesforUpgradeInstall();                         
		     onUpgradeUIBefore(); 
		                  
case VERSION_COMPARE_RESULT_NOT_INSTALLED:    
             RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
 			 if (RegDBKeyExist (szPMRegPath) = 1) then 
 			 	if GetFromRegistry("SOFTWARE\\Pure\\SiriusSolutions\\Setup","Version") != "" then
 			 		WriteToLogFile(INSTALL_LOG,"Type of installation is Upgrade Product");
 			 		g_bProductUpgradeNewInstaller = TRUE;
	 				g_bFreshInstaller  = FALSE;
					g_bUpgradeInstaller= FALSE;
					//Get all the required registry entries for the pure upgrade installation
					GetPMRegistryInstalledValuesforUpgradeInstall();                         
					//Check whether any Sirius Users are logged on to the Machine before Upgrades			 
				else   
					WriteToLogFile(INSTALL_LOG,"Type of installation is Fresh Install");
					DeleteRegistryInformation();
					g_bFreshInstaller  = TRUE;
					g_bUpgradeInstaller= FALSE;
					g_bProductUpgradeNewInstaller =  FALSE;      
					//Initializing the Sirius Database Name with "Sirius"
					g_szSiriusDBName = "Pure";
					g_szMDFDirPath =  "";
					g_szLDFDirPath =  "";                                                 
					
				endif;
		     else    
				WriteToLogFile(INSTALL_LOG,"Type of installation is Fresh Install");
				g_bFreshInstaller  = TRUE;
				g_bUpgradeInstaller= FALSE;
				g_bProductUpgradeNewInstaller =  FALSE;      
				//Initializing the Sirius Database Name with "Sirius"
				g_szSiriusDBName = "Pure";
				g_szMDFDirPath =  "";
				g_szLDFDirPath =  "";                                                
			endif; 

case VERSION_COMPARE_RESULT_OLDER:
			 WriteToLogFile(INSTALL_LOG,"A later version of 'Pure Insurance' is already installed on this machine. The setup cannot continue.");
			 MessageBox("A later version of 'Pure Insurance' is already installed on this machine. The setup cannot continue.", SEVERE);
			 exit;
  
endswitch; 
*/

if(g_bFreshInstaller = FALSE && g_bUpgradeInstaller = FALSE &&  g_bProductUpgradeNewInstaller = FALSE) then
	//Represents an Uninstallation Condition
	//Get all the required registry entries for the pure upgrade installation
	GetPMRegistryInstalledValuesforUpgradeInstall();                         
endif;
return 1;
end;   


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  onUpgradeUIBefore                                              //
//                                                                           //
// Purpose:   This function is used to show up the UI dialogs that may       //
//			  be required in case of upgrade installation or product         //       
//			  upgrade/fresh installation                                     //
///////////////////////////////////////////////////////////////////////////////

function number onUpgradeUIBefore()   
string szTitle,szMsg,szQuestion,szUser, szPassword, szKey;
number nvResult,nvDefault,nvAskButtonRetValue,nResult;  
HWND hMSI;  
STRING szApplicationPortal,szAppPoolPortal,szPhysicalPathPortal,szBasePath, svBasePath;
NUMBER nAppServerOnly,nWebServices,nWebPortal,nWCFServices,nSize,nType;
LIST lAppInUse;

begin

Dlg_UpgradeSdWelcome:
		g_bAppServerOnly = TRUE;
		g_bAppServerWithDB = TRUE;
		g_bWebServices = FALSE;
		g_bPortal = FALSE;
		g_bDashBoard=FALSE;
		g_WCFServices=TRUE;
		g_SkipDb=FALSE;

		//This Dialog is used to show the Welcome Screen indicating the Start of Upgrade Installation
	    szTitle = "SSP Pure Insurance Installation";  
	    szMsg   = "Welcome to the Upgrade Installation of Pure Back Office Version "+ g_szTobeInstalledFullVersion +" from Current Version "+ g_szInstalledFullVersion;

		Disable(BACKBUTTON);    
	    nvResult = SdWelcome(szTitle,szMsg);  
	    //goto  Dlg_AskInstallationType;
	  	
	  	Disable( DIALOGCACHE );
	  	StopPureService();

		// Check for file in use 
		SdShowMsg ( "Checking for files in use . . . please wait." , TRUE );
		while(CheckApplicationInUse(lAppInUse) == TRUE)
				//nResult = SdRMFilesInUse( "", "", "", lAppInUse,FALSE);
				nResult = SdFilesInUse("", "", "", lAppInUse);
				if (nResult == IDCANCEL) then
					if (IDYES = SprintfBox(MB_YESNO|MB_ICONEXCLAMATION|MB_DEFBUTTON2, 
											SdLoadString(SD_STR_ONCANCELING_TITLE), 
											SdLoadString(SD_STR_ONCANCELING_MSG))) then
                       
						EndCurrentDialog();
						Enable(USE_LOADED_SKIN);
						abort;
					endif;	
				
				endif;
		endwhile;
		SdShowMsg ( "Checking for files in use . . . please wait." , FALSE );
		Enable( DIALOGCACHE );    
	    
Dlg_AskInstallationType:
	szTitle    = "SSP Pure Installation Type";
    szMsg      = "This specifies the type of upgrade you require";   
	
	  
	if (ExistsDir (SRCDIR ^ "Portal") != EXISTS) then
				g_bPortal = FALSE;
	else
				g_bPortal = TRUE;
				GetPortalFileName();
				if(gPortalFileName="")then
					g_bPortal = FALSE;
				else
					g_bPortal = TRUE;
				endif;
	endif;
		
	if(g_bPortal=FALSE) then
            nvResult    = AskOptions(NONEXCLUSIVE,"Select the type of Installation Required","Back Office",g_bAppServerOnly,"Pure Database",g_bAppServerWithDB, "Dashboard",g_bDashBoard,"Pure WCF Services",g_WCFServices, "Bypass Database Installer", g_SkipDb); 
	endif;
	
	if(g_bPortal=TRUE) then
			nvResult    = AskOptions(NONEXCLUSIVE,"Select the type of Installation Required","Back Office",g_bAppServerOnly,"Pure Database",g_bAppServerWithDB, "Pure Portal", g_bPortal,"Dashboard",g_bDashBoard,"Pure WCF Services",g_WCFServices, "Bypass Database Installer", g_SkipDb ); 
	endif;
	
	//If same build is run again then allow only dashboard to install
	//if upgrade then don't allow dashbaord to install unless backoffice is installed
	
	if(gInstallMode="Upgrade")then
		if(g_bDashBoard=TRUE && g_bAppServerOnly=FALSE) then
			MessageBox("You cannot install Dashboard unless Back Office is also installed.",INFORMATION);
			g_bAppServerOnly = TRUE;
			g_bDashBoard=TRUE;
			goto Dlg_AskInstallationType;
		endif;
	endif;
	    
	if(g_bWebServices=TRUE && g_bAppServerOnly=FALSE) then
			MessageBox("You cannot install Web Services unless Back Office is also installed.",INFORMATION);
			g_bAppServerOnly = TRUE;
			g_bWebServices=TRUE;
			goto Dlg_AskInstallationType;
	endif;
	    
	if(g_WCFServices=TRUE && g_bAppServerOnly=FALSE) then
			MessageBox("You cannot install Pure WCF Services unless Back Office is also installed.",INFORMATION);
			g_bAppServerOnly = TRUE;
			g_WCFServices=TRUE;
			goto Dlg_AskInstallationType;
	endif;
	
	
	if(nvResult = BACK) then 
		goto Dlg_UpgradeSdWelcome; 
	endif;
	
	nAppServerOnly = FeatureIsItemSelected(MEDIA, "SiriusBackOffice");
	nWebServices = FeatureIsItemSelected(MEDIA, "WebServices");
	nWebPortal = FeatureIsItemSelected(MEDIA, "WebPortal");
	nWCFServices = FeatureIsItemSelected(MEDIA, "WCFServices");
	
	//select features based on selection
	if(g_bAppServerOnly=TRUE || nAppServerOnly=1) then
			FeatureSelectItem (MEDIA, "SiriusBackOffice", TRUE);
			//FeatureSelectItem (MEDIA, "SiriusBackOffice\\AppServer", TRUE);
	else
			FeatureSelectItem (MEDIA, "SiriusBackOffice", FALSE);
	endif;
	
	if(g_bWebServices=TRUE || nWebServices=1) then
			FeatureSelectItem (MEDIA, "WebServices", TRUE);
	else
			FeatureSelectItem (MEDIA, "WebServices", FALSE);
	endif;
	
	if(g_bPortal=TRUE || nWebPortal=1) then
			FeatureSelectItem (MEDIA, "WebPortal", TRUE);
	else
			FeatureSelectItem (MEDIA, "WebPortal", FALSE);
	endif;
	
	if(g_WCFServices=TRUE || nWCFServices=1) then
			FeatureSelectItem (MEDIA, "WCFServices", TRUE);
	else
			FeatureSelectItem (MEDIA, "WCFServices", FALSE);
	endif;
    
    //Pre-requisiste Checks based on Installation option
	if(g_bAppServerOnly=TRUE) then
		
		CheckNET4version();
		//if(g_SkipDb=FALSE) then	
			//IsMSXML4Installed();
		//endif;
		//CheckMSOfficeversion();
	endif;
	    
	if(g_bWebServices=TRUE || g_WCFServices=TRUE) then
		//if(g_SkipDb=FALSE) then	
			//IsMSXML4Installed();
		//endif;
		//IsWSE3Installed();
		CheckIISversion();
		CheckNET4version();
		IsASPNETRoleInstalled();
	endif;
	
	if(g_bPortal=TRUE) then
		//if(g_SkipDb=FALSE) then	
			//IsMSXML4Installed();
		//endif;
		//IsWSE3Installed();
		CheckIISversion();
		CheckNET4version();
		IsASPNETRoleInstalled();
		//CheckSilverLightversion();
	endif;
	
  
    
Dlg_UserInformation:
	 if(g_bWebServices=TRUE || g_bPortal=TRUE || g_WCFServices=TRUE) then
	  g_szAppPoolPortal="PurePortalAppPool";
	  g_szApplicationPortal="Pure.Portal";
	  g_szPhysicalPathPortal=IISROOTFOLDER ; //^ g_PortalFolderName;
	  if(g_bPortal=TRUE) then
		nSize= -1;
		nType= REGDB_STRING;
		szBasePath="BasePath";
		szKey="SOFTWARE\\Pure\\PureInstallation\\Portal";
		RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
		if(RegDBKeyExist(szKey)=1) then
			if(RegDBGetKeyValueEx (szKey, szBasePath, nType, svBasePath, nSize) <0 ) then
				g_PortalExists=FALSE;
			else
				g_szPhysicalPathPortal=svBasePath;
			endif;
		endif;
	  endif;
	  //g_szWebServiceUrl="http://" + g_szHostName + "/PureWebServices/SAMForInsuranceV2.asmx";
	  g_szDocumentsLocation=TARGETDIR ^ "DocZipTemp";
	  g_szReportsLocation=TARGETDIR ^ "Reports";
	  g_szTempFileLocation=TARGETDIR ^ "DocZipTemp";
	
	 szTitle = "";
	 //szMsg   = "Specify the User and Password for configuring Web Services and setting permissions on Pure Application folders. Make sure user is a member of the IIS_IUSRS group on the Web server so that the account can access the appropriate resources.";  
	 szMsg = "Specify the User and Password for configuring Web Services and setting permissions on Pure Application folders. Make sure user is a member of the IIS_IUSRS group on the Web server. User accounts must be in the format DOMAIN\\Username";  
	 szUser="User:";
	 szPassword="Password:";
	 
	  //log Mode 
	 if (MODE=SILENTMODE) then 
	   	  WriteToLogFile(INSTALL_LOG,"SilentMode" );
		Delay(40);
		else
		  WriteToLogFile(INSTALL_LOG,"MSI Mode" );
        endif;
		 
	// if (MODE = SILENTMODE) then
			nvResult= SdShowDlgEdit2 ( szTitle, szMsg, szUser, szPassword, g_szWebservicesUser,g_szWebservicesPassword);
	//	else
		//	nvResult= SdLogonUserInformation ("", szMsg,  g_szWebservicesUser, g_szWebservicesPassword);
	// endif;
		 
	 if(nvResult = BACK) then 
		goto Dlg_AskInstallationType; 
	 endif;    
	 if(g_szWebservicesUser="")then
		       MessageBox("Username cannot be empty, Please specify a valid user.",INFORMATION);
		       goto Dlg_UserInformation;
	 endif;
		 
	 if(g_szWebservicesPassword="")then
	    	  MessageBox("Password cannot be empty, Please specify a valid password.",INFORMATION);
		      goto Dlg_UserInformation;
	 endif;	 
	 
	 
	
	 if (ValidateUserCredentials() = FALSE) then
				MessageBox("Login failed, please provide the Username and Password correctly.\n\n",INFORMATION);
				goto Dlg_UserInformation;
	 endif;
	
	 
	 TextSubSetValue("<APPPOOLUSERID>", g_szWebservicesUser, TRUE);
	 TextSubSetValue("<APPPOOLPASSWORD>", g_szWebservicesPassword, TRUE);
	 
	 //MsiSetProperty( ISMSI_HANDLE, "APPPOOLUSERID", g_szWebservicesUser );
	 //MsiSetProperty( ISMSI_HANDLE, "APPPOOLPASSWORD", g_szWebservicesPassword ); 
	 endif;
	 
	
    	
Dlg_EmailConfiguration:
	if(g_bWebServices=TRUE) then
		GetPureWebServicesRegistry();
		if(g_EmailConfigExists=FALSE)then
			nvResult = EmailConfiguration();
		endif;
		if(nvResult = BACK) then
			goto Dlg_UserInformation;
		endif;  
	endif;
	
	
	
Dlg_PortalDetails:
	if(g_bPortal=TRUE) then
		GetPortalFileName();
		GetPortalRegistry();
		if(g_PortalExists=FALSE)then
				g_szPhysicalPathPortal=IISROOTFOLDER ; //^ g_PortalFolderName;
				nvResult = SdPurePortal();
		endif;		
		
		//MessageBox(g_szPhysicalPathPortal,INFORMATION);
		LongPathToQuote(g_szPhysicalPathPortal,FALSE);
		//TextSubGetValue("<PUREPORTALAPP>", szApplicationPortal, TRUE,TRUE);
		//TextSubGetValue("<PUREPORTALAPPPOOL>", szAppPoolPortal, TRUE,TRUE);
		//TextSubGetValue("<PUREPORTALPATH>", szPhysicalPathPortal, TRUE,TRUE);
		//MessageBox("App="+ szApplicationPortal + "AppPool="+ szAppPoolPortal + "Phy Path="+ szPhysicalPathPortal, INFORMATION);
		//TextSub.Value("PUREPORTALAPP") =	g_szApplicationPortal;
		//TextSub.Value("PUREPORTALAPPPOOL") =	g_szAppPoolPortal;
		//TextSub.Value("PUREPORTALPATH") =	g_szPhysicalPathPortal;
		//szApplicationPortal=g_szApplicationPortal;
		//szAppPoolPortal=g_szAppPoolPortal;
		//szPhysicalPathPortal=g_szPhysicalPathPortal;
		//MessageBox(TextSub.Value("PUREPORTALAPP"), INFORMATION);
		//MessageBox(TextSub.Value("PUREPORTALAPPPOOL"), INFORMATION);
		//MessageBox(TextSub.Value("PUREPORTALPATH"), INFORMATION);
		TextSubSetValue("<PUREPORTALAPP>", g_szApplicationPortal, TRUE);
		TextSubSetValue("<PUREPORTALAPPPOOL>", g_szAppPoolPortal, TRUE);
		TextSubSetValue("<PUREPORTALPATH>", g_szPhysicalPathPortal ^ g_PortalFolderName, TRUE);
		//MessageBox("App="+ szApplicationPortal + "AppPool="+ szAppPoolPortal + "Phy Path="+ szPhysicalPathPortal, INFORMATION);
		if(nvResult = BACK) then
					goto Dlg_UserInformation;
		endif; 
	endif;
	
Dlg_PureSTSDetails:
		 if(g_bPortal=TRUE) then
			if(g_PortalExists=FALSE)then
				nvResult = PureSTSConfiguration();
				
				if(nvResult = BACK) then
					goto Dlg_PortalDetails;
				endif; 
			endif;
		 endif;		
	
Dlg_PortalConfigPath:
	if(g_bPortal=TRUE) then
		if(g_PortalExists=FALSE)then
				nvResult = SdPortalConfigPath();
		endif;
		if(nvResult = BACK) then
					goto Dlg_PureSTSDetails;
		endif; 
		CopyPortalFiles();
	endif;
	
    if((g_bAppServerOnly = TRUE || g_bAppServerWithDB = TRUE ) && g_SkipDb=FALSE) then 
    	szQuestion = "Please take a backup of the database \""+g_szSiriusDBName+"\"  Version \""+g_szInstalledFullVersion+"\" from the DBServer \""+g_szDBServer+"\".Click YES to proceed,if backup is taken already or Click No to abort the installation";
	  	nvDefault = NO;
		nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
		if(nvAskButtonRetValue = YES) then
			goto Dlg_TestConnectDBforUpgradeInstall;
		else
			abort;
		endif;
	endif;  
	
Dlg_TestConnectDBforUpgradeInstall:	
	  //nvResult =OnSQLLogin(NEXT);
	if((g_bAppServerOnly = TRUE || g_bAppServerWithDB = TRUE || g_bDashBoard=TRUE) && g_SkipDb = FALSE) then

	  
	  
	  nvResult=OnSQLServerInitialize(NEXT);


	endif;
	
	  if(nvResult = BACK) then 
			if(g_bPortal=TRUE) then
				  	//goto Dlg_PortalConfigPath;
					goto Dlg_UserInformation;
		    else
					if(g_bWebServices=TRUE) then
					goto Dlg_EmailConfiguration;
					else
						goto Dlg_AskInstallationType;
					endif;
			endif;  
	  endif;
	
if((g_bAppServerOnly = TRUE || g_bAppServerWithDB = TRUE ) && g_SkipDb = FALSE ) then
	CompareDatabaseServerDateTime();
	CompareDatabaseCollation();
	
	//Set the Compatibility level of the newly created DB to SQLSERVER 2000 format
	nvResult = SetFreshDBCompatibilityLevel();
	
   if (nvResult = -2) then
		MessageBox("Could not connect to database. Please check database name.",WARNING);
	    goto Dlg_TestConnectDBforUpgradeInstall;
	else   
		 // Method Call to do Pure Upgrade Installation of DB Scripts 
		 //Create database normal/error log files 
		 CreateLogFile(DATABASE_LOG);       
		 CreateLogFile(DATABASE_ERRORLOG);
		 //Get the Scripts Folder Version for the pure upgrade installation
		 SetPMLogicalDatabaseFolderVersionsToInstallerVariables(); 
		 //Start the Pure Upgrade Installation DB Scripts Execution
		 Disable( DIALOGCACHE );
		 StartUpgradeDBScriptsExecution(SRCDIR ^ "Scripts");
		 Enable( DIALOGCACHE );
		 //Update the PMLogicalDatabase with the Current Version of the Installation
		 SetUpgradedFolderVersionsToPMLogicalDatabase();
	 endif;
endif;
	if(g_bWebServices=TRUE) then
		CreatePureWebServicesRegistry();
		if(g_SkipDb=FALSE) then	
			UpdatePureWebServicesWebConfig();
		endif;
	endif;
	 //Update Portal database
	 if(g_bPortal=TRUE && g_SkipDb = FALSE) then
			if(g_PortaDB="")then
					szQuestion= "Do you want to create a new Pure Portal database?\n\n" +
								"Click YES to 'create a new Pure Portal database' or Click NO to 'update the existing Pure Portal database'.";
					nvDefault = NO;
					nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
					if(nvAskButtonRetValue = YES) then
						// Ask SQL Server Connection details
					Dlg_SdSQLConnectionPortal:	
						//nvResult = SdSQLConnectionPortal();	
							nvResult=PurePortalDatabaseDetails();
							WriteToLogFile(INSTALL_LOG,"Portal DB Server=" + g_PortalDBServer);
							WriteToLogFile(INSTALL_LOG,"Pure Portal Login ID=" + g_PortalUser);
							WriteToLogFile(INSTALL_LOG,"Pure Portal Password=" + g_PortalPwd);
							WriteToLogFile(INSTALL_LOG,"Pure Portal DB Name=" + g_PortaDB);
							if(StrCompare(g_PortalDBServer,g_szHostName)=0)  then
								g_bPortalRemoteDBServer = FALSE;
							elseif(StrFind(g_PortalDBServer,"(local)") >= 0) then
								g_bPortalRemoteDBServer = FALSE;
							elseif(StrFind(g_PortalDBServer,g_szHostName) >= 0) then
								g_bPortalRemoteDBServer = FALSE;
							else 
								g_bPortalRemoteDBServer = TRUE;
							endif;   
							if(g_bPortalRemoteDBServer = TRUE) then
								// Pass default backup DB name 
								//Don't do anything, currently hardcoded backup file name is provided already 
								//SelectDir ( "", "Select the Shared location:", gSharedPath, FALSE );
								SetDialogTitle ( DLG_ASK_PATH, "Select the Share location" );
								AskPath ( "Select the Shared folder location(UNC Path) on the database server", "", gPortalSharedPath ); 
								StrRemoveLastSlash ( gPortalSharedPath ); 
							endif;
							if(g_bPortalRemoteDBServer = TRUE) then
								SdShowMsg ( "Copying database backup file to database server . . . please wait." , TRUE );
								CopyPortalDatabasebackupToRemoteServer();
								SdShowMsg ( "Copying database backup file to database server . . . please wait." , FALSE );
							endif;
						// Ask new DB details
					Dlg_SdPortalnewdbdetails:
						nvResult = SdPortalnewdbdetails(hMSI,g_PortalDBServer,g_PortalUser,g_PortalPwd,g_PortaDB,g_PortalMDFDirPath,g_PortalDFDirPath);
						if(nvResult = BACK) then
							goto Dlg_SdSQLConnectionPortal;
						endif;
						//Create Portal database
						CreatePortalDatabaseFromBackup();
						
						//Set Compatibility Level
						SetPortalCompatibilityLevel();
						//Update Tbl_Portal table
						AddEditTbl_Portal();
					else
						// Ask SQL Server Connection details
						//nvResult = SdSQLConnectionPortal();	
						nvResult = PurePortalDatabaseDetails();	
						
						//Set Compatibility Level
						SetPortalCompatibilityLevel();
						//Update Tbl_Portal table
						//AddEditTbl_Portal();
					endif;
			else
				    // Ask SQL Server Connection details
					//nvResult = SdSQLConnectionPortal();	
					nvResult = PurePortalDatabaseDetails();	

					
					//Set Compatibility Level
					SetPortalCompatibilityLevel();
					//Update Tbl_Portal table
					//AddEditTbl_Portal();
			endif;
		    // Create Portal registry
		    Disable( DIALOGCACHE );
			CreatePortalRegistry();
			Enable( DIALOGCACHE );
			szQuestion= "Do you want to copy existing web.config file to new Pure Portal location?\n\n" +
						"Click YES to 'copy existing web.config file' or Click NO to 'copy new web.config file'.";
			nvDefault = NO;
			nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
			if(nvAskButtonRetValue = YES) then
					//Browse for path of OLD web.config
					//Copy web.config
					//nvResult=SdBrowseFile(hMSI,g_szWebFileName);
					//g_OLDWebConfigPath
					if(g_PortalExists=FALSE)then
						//nvResult = SelectFile ( g_szWebFileName);
						nvResult=SelectWebConfigFile(g_szWebFileName);
					else
						WriteToLogFile(INSTALL_LOG,"Copy existing web.config file.");
						if(gInstallMode="Same")then
							g_szWebFileName=g_OLDWebConfigPath ^ "web_old.config";
						else
							g_szWebFileName=g_OLDWebConfigPath ^ "web.config";
						endif;
					endif;
					
					CopyOLDWebConfig();	
					MessageBox("Please update the portal web.config file manually after Installation, please refer to release notes for the details.",INFORMATION);
			else
				   //
				   //Update Portal web config
				   if(g_SkipDb=FALSE) then
					UpdatePortalWebConfig();
				   endif;
			endif;
			DeleteFile(g_OLDWebConfigPath ^ "web_old.config");
	 endif;
	 
	 
	 //DashBoard database creation
	//g_DashBoardDB="SiriusMonitorDB";
	if(g_bDashBoard=TRUE)then
		GetDashBoardRegistry();
		if(g_DashBoardDB="")then
		
		    szQuestion= "Do you want to create a new Pure Dashboard database?\n\n" +
						"Click YES to 'create a new Pure Dashboard database' or Click NO to 'update the existing Pure Dashboard database'.";
			
			nvDefault = NO;
			nvAskButtonRetValue = AskYesNo(szQuestion,nvDefault); 
			
			if(nvAskButtonRetValue = YES) then
				
				Dlg_SdSQLConnectionDashBoard:
				
					if(StrCompare(g_szDBServer,g_szHostName)=0)  then
						g_bRemoteDBServer = FALSE;
					elseif(StrFind(g_szDBServer,"(local)") >= 0) then
						g_bRemoteDBServer = FALSE;
					elseif(StrFind(g_szDBServer,g_szHostName) >= 0) then
						g_bRemoteDBServer = FALSE;
					else 
						g_bRemoteDBServer = TRUE;
					endif;   
				
					if(g_bRemoteDBServer = TRUE) then
						// Pass default backup DB name 
						//Don't do anything, currently hardcoded backup file name is provided already 
						//SelectDir ( "", "Select the Shared location:", gSharedPath, FALSE );
						SetDialogTitle ( DLG_ASK_PATH, "Select the Share location" );
						AskPath ( "Select the Shared folder location(UNC Path) on the database server", "", gDashBoardSharedPath ); 
						StrRemoveLastSlash ( gDashBoardSharedPath ); 
					endif;
				
					if(g_bRemoteDBServer = TRUE) then
						SdShowMsg ( "Copying database backup file to database server . . . please wait." , TRUE );
						CopyDashBoardDatabasebackupToRemoteServer();
						SdShowMsg ( "Copying database backup file to database server . . . please wait." , FALSE );
					endif;
					// Ask new DB details
				Dlg_SdDashBoardnewdbdetails:
					nvResult = SdDashBoardnewdbdetails(hMSI,g_szDBServer,g_szMasterUser,g_szMasterPassword,g_DashBoardDB,g_DashBoardMDFDirPath,g_DashBoardLDFDirPath);
					if(nvResult = BACK) then
						goto Dlg_SdSQLConnectionDashBoard;
					endif;
					//Create DashBoard database
					Disable( DIALOGCACHE );
					CreateDashBoardDatabaseFromBackup();
					Enable( DIALOGCACHE );
				
			else
				// DO not create DashBoard database
				SdSQLConnectionDashBoard();
			endif; //if(nvAskButtonRetValue = YES) then
		else
				// DO not create DashBoard database
				//SdSQLConnectionDashBoard();
				
		endif;//if(g_DashBoardDB="")then
	endif; //if(g_bDashBoard=TRUE)then
        

Dlg_UpgradeDialogEnd:
     //End of Upgrade Installation
     
 
     
return 1;
end; 
 
