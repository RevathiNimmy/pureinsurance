///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function: CheckPMUsersLoggedOn                                            //
//                                                                           //
// Purpose:  This function calls a VB program that determines if any users   //
//			 are logged on during upgrade or product upgrade installation    //
//			 for logging off the users to carry out the installation         //
//                                                                           //
///////////////////////////////////////////////////////////////////////////////

function number CheckPMUsersLoggedOn()
	number	nvResult, nvFileHandle, nvUsers;
	string	szProgram, szCmdLine, szQuestion, szMsg, szLine, svResult;
begin   
	// SET not working so removed from install for now
	//return 1;
	
    //Try to run program from common dlls folder
    if ( FindAllFiles ( g_szPMInstallPath ^ PURE_APPLICATION_FOLDER, "UsersLoggedOn.exe", svResult, RESET ) == 0 ) then      
    	szProgram = svResult;
    else
		// Run VB program to check for the Users Logged on to the system
		szProgram = g_szPMInstallPath ^ "Sirius Architecture\\Server\\Programs\\UsersLoggedOn.exe";
	endif;
	 	
	szCmdLine = "";
	//nvResult = LaunchApplication( szProgram, szCmdLine, "", SW_SHOW, 300000, LAAW_OPTION_USE_SHELLEXECUTE | LAAW_OPTION_WAIT );
	nvResult = LaunchApplication( szProgram, szCmdLine, "", SW_SHOW, INFINITE, LAAW_OPTION_USE_SHELLEXECUTE | LAAW_OPTION_WAIT );
	if(nvResult < 0) then
		NumToStr ( szQuestion , nvResult );
		szQuestion = "Failed to check if all users are logged off: " + szQuestion + "\n\n" +
                     "Do you wish to continue with this installation?";
        nvResult = AskYesNo(szQuestion,NO);
        if(nvResult = NO)then
        	g_bPreRequisiteFailure = TRUE;
        	abort;
        else
	       	return 0;
        endif;
    endif;

// Check output file
	nvResult = OpenFileMode(FILE_MODE_NORMAL);
	if nvResult < 0 then
		NumToStr(szQuestion,nvResult);
		szQuestion = "Error setting Open File Mode for C:\\UsersLoggedOn.txt: " + szQuestion + "\n\n" +
                     "Do you wish to continue with this installation?";
		nvResult = AskYesNo ( szQuestion , NO );
		if(nvResult = NO) then
			g_bPreRequisiteFailure = TRUE;
			abort;
	   else
			return 0;
		endif;
	endif;
	
	nvResult = OpenFile(nvFileHandle,WINDISK,"UsersLoggedOn.txt");
	if(nvResult < 0) then
		NumToStr(szQuestion,nvResult);
		szQuestion = "Error opening "+ WINDISK + "\\UsersLoggedOn.txt: " + szQuestion + "\n\n" +
                     "Do you wish to continue with this installation?";
		nvResult = AskYesNo(szQuestion,NO);
		if(nvResult = NO)then
			g_bPreRequisiteFailure = TRUE;
			abort;
	        	
		else
			return 0;
		endif;
	endif;
	
	nvResult = GetLine(nvFileHandle,szLine);
	CloseFile(nvFileHandle);
	if(nvResult < 0) then
		NumToStr(szQuestion,nvResult);
		szQuestion = "Error reading C:\\UsersLoggedOn.txt: " + szQuestion + "\n\n" +
                     "Do you wish to continue with this installation?";
		nvResult = AskYesNo(szQuestion,NO);
		if(nvResult = NO) then
			g_bPreRequisiteFailure = TRUE;
			abort;
	    else
			return 0;
		endif;
	endif;
	
	if szLine = "Error" then
    	szQuestion = "VB Error checking if all users are logged off." + "\n\n" +
                     "Do you wish to continue with this installation?";
        nvResult = AskYesNo(szQuestion,NO);
        if(nvResult = NO)then
        	g_bPreRequisiteFailure = TRUE;
			abort;
        else
	       	return 0;
        endif;
    endif;

    StrToNum(nvUsers,szLine);
    if(nvUsers > 0) then
    	szMsg = "There are still "+szLine+ " users logged on.\n\n" +
    			"Installation can not continue.";
    	MessageBox(szMsg,INFORMATION);
    	g_bPreRequisiteFailure = TRUE;
		abort;
    endif;

return 1;
end;
            


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  IsUserMemberOfGroup                                            //
//                                                                           //
// Purpose:   This function is used to find out whether the user of a        //
//			  particular system belongs to any group like                    //
//			  administrators group                                           //
///////////////////////////////////////////////////////////////////////////////

function BOOL IsUserMemberOfGroup(szHostName, szUserName, szGroupName)
OBJECT objComputer, objGroup, objUser; 
BOOL bIsMember;
begin
try
	// Get an object to the Computer.
	set objComputer = CoGetObject("WinNT://" + szHostName + ",Computer", "");
	// Get an object to the Group.
	set objGroup = CoGetObject("WinNT://" + szHostName + "/" + szGroupName, "");
	// Get an object to the User.
	set objUser = objComputer.GetObject("user", szUserName);

	// Find out if the user is a member.    
	if(IsObject(objComputer)) then
		if(IsObject(objUser)) then
			if(IsObject(objGroup)) then
				bIsMember = objGroup.IsMember(objUser.AdsPath);
				if(bIsMember = FALSE) then
					return FALSE;
				else
					return TRUE;
				endif;
			endif;
		endif;
	endif;
catch
	// Usually means either the user doesn't exist, but could mean group doesn't exist or the oComputer object is null.
	// Do your own error handling and object checking around each statement in the try block if you want to check for each error.

	return TRUE;
endcatch;

return TRUE;
end;  
    
                                                    
/* As per Bal's Comments on May 22 2009 ,Licensing would use the 
   updatesystem.exe application instead of the installer file input dialog */                                                    
///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  RegisterLicenseKey(Not Used as of now)                                             //
//                                                                           //
// Purpose:   This function is used to register the License key              //
//			  available in the PMLicense.INI file to the PMSystem table      //
//			  of the Sirius Database                                         //
///////////////////////////////////////////////////////////////////////////////

function number RegisterLicenseKey()
number nvResult;
string szPMSystemInsertScript; 
string szGetNewSystemIdScript; 
string szLicenseKeyValue,szLicenseKeyLimit;
string szReturnValue;   
number nvSystemIDValue; 
string szHostNameCheckSQLScript;
NUMBER nLicenseKeyLimit;
STRING szPMWrk_Task_CategoryInsertScript,sz1KeyValue,szLicenceLimit,szLicenceKey,szExceedLimitAction;
begin     

szHostNameCheckSQLScript ="if exists(select system_name from pmsystem where system_name like '" + g_szHostName + "') select sRetValue='YES' else select sRetValue='NO' ";
szReturnValue = ADODBConnectExecuteAndReturn(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szHostNameCheckSQLScript,"sRetValue");
if(szReturnValue = "YES") then
	WriteToLogFile(INSTALL_LOG,"LicenseKey entry already exists for this system "+g_szHostName+".No Licensing required");
else
	szHostNameCheckSQLScript = "select system_name from pmsystem where "; 
	szGetNewSystemIdScript = "select max(system_id) as sRetValue  from pmsystem";
	szReturnValue = ADODBConnectExecuteAndReturn(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szGetNewSystemIdScript,"sRetValue");
	if(szReturnValue = "") then
		 szReturnValue = "0";
	endif;
	StrToNum(nvSystemIDValue,szReturnValue);
	NumToStr(szReturnValue,nvSystemIDValue+1);
	//PMSystem table Insert Script for Licensing  
	if(g_bFreshInstaller = TRUE) then
		if(g_bAppServerWithDB = TRUE) then
			//g_szLicensing = SUPPORTDIR ^ "PMLicence.ini";
			nvResult = GetProfString(gPMLicenceFile,"SYSTEM_SIRIUS","LicenceKey",szLicenseKeyValue); 
			nvResult = GetProfString(gPMLicenceFile,"SYSTEM_SIRIUS","LicenceLimit",szLicenseKeyLimit); 
		
			//
		
			nvResult = GetProfString(gPMLicenceFile,"INSTALLED_PRODUCTS","1",sz1KeyValue); 
		
			nvResult = GetProfString(gPMLicenceFile,"PRODUCT_SBO","LicenceLimit",szLicenceLimit); 
			nvResult = GetProfString(gPMLicenceFile,"PRODUCT_SBO","LicenceKey",szLicenceKey); 
			nvResult = GetProfString(gPMLicenceFile,"PRODUCT_SBO","ExceedLimitAction",szExceedLimitAction); 
		
			WriteToLogFile(INSTALL_LOG, "License file path= " + gPMLicenceFile );
		
		
			//Public Const ACExceedLimitBlock As String = "Block"
			//Public Const ACExceedLimitWarn As String = "Warn"
			//Public Const ACExceedLimitNone As String = "None"
				
			if(nvResult = 0) then
				WriteToLogFile(INSTALL_LOG,"LicenseKey Value Retrieved Successfully from PMLicence.ini file");
			else
				WriteToLogFile(INSTALL_ERRORLOG,"Error Retrieving LicenseKey in PMLicence.ini file");
			endif;
			//Update PMSYTEM table
			szPMSystemInsertScript = "insert into pmsystem values("+szReturnValue+",1,\'"+g_szHostName+"\',1,1,26,1,"+szLicenseKeyLimit+",\'"+szLicenseKeyValue+"\',4,4,NULL,NULL,NULL)";
			WriteToLogFile(INSTALL_LOG, "Inserting default License Key into database using sql:");
		
		
			//Update PMWrk_Task_Category
			//UPDATE PMWrk_Task_Category SET code = 'SBO',licence_limit = 40,licence_key = 'xxx',is_block_above_licence_limit = 0,is_warn_above_licence_limit = 1 WHERE pmwrk_task_category_id = 2
		
			if(szExceedLimitAction="Block") then
				szPMWrk_Task_CategoryInsertScript= "UPDATE PMWrk_Task_Category SET code =" + " \'"+sz1KeyValue+"\' , licence_limit =" + szLicenceLimit + ",licence_key = " +  " \'"+szLicenceKey+"\' , is_block_above_licence_limit =1,is_warn_above_licence_limit = 0,warns_since_licence_upgrade=0 WHERE pmwrk_task_category_id = 2";
			endif;
		
			if(szExceedLimitAction="Warn") then
				szPMWrk_Task_CategoryInsertScript= "UPDATE PMWrk_Task_Category SET code =" + " \'"+sz1KeyValue+"\' , licence_limit =" + szLicenceLimit + ",licence_key = " +  " \'"+szLicenceKey+"\' , is_block_above_licence_limit =0,is_warn_above_licence_limit = 1,warns_since_licence_upgrade=0 WHERE pmwrk_task_category_id = 2";
			endif;
		
			if(szExceedLimitAction="None") then
				szPMWrk_Task_CategoryInsertScript= "UPDATE PMWrk_Task_Category SET code =" + " \'"+sz1KeyValue+"\' , licence_limit =" + szLicenceLimit + ",licence_key = " +  " \'"+szLicenceKey+"\' , is_block_above_licence_limit =0,is_warn_above_licence_limit = 0,warns_since_licence_upgrade=0 WHERE pmwrk_task_category_id = 2";
			endif;
		
		
			WriteToLogFile(INSTALL_LOG, szPMWrk_Task_CategoryInsertScript);
		  
		else   
			szPMSystemInsertScript = "insert into pmsystem (system_id,product_id,system_name,default_source_id,home_country_id,currency_id,language_id,licence_limit,licence_key,log_level,pool_size,AD_OU_Path,AD_OU_Domain)";
			szPMSystemInsertScript = szPMSystemInsertScript + " select " + szReturnValue + ",product_id,'"+g_szHostName+"',default_source_id,home_country_id,currency_id,language_id,licence_limit,licence_key,log_level,pool_size,AD_OU_Path,AD_OU_Domain";
			szPMSystemInsertScript = szPMSystemInsertScript + " from pmsystem where system_id = (select max(system_id) from pmsystem)";
			WriteToLogFile(INSTALL_LOG, "Inserting existing License Key into database using sql: ");
		endif;
	else
	
		szPMSystemInsertScript = "insert into pmsystem (system_id,product_id,system_name,default_source_id,home_country_id,currency_id,language_id,licence_limit,licence_key,log_level,pool_size,AD_OU_Path,AD_OU_Domain)";
		szPMSystemInsertScript = szPMSystemInsertScript + " select " + szReturnValue + ",product_id,'"+g_szHostName+"',default_source_id,home_country_id,currency_id,language_id,licence_limit,licence_key,log_level,pool_size,AD_OU_Path,AD_OU_Domain";
		szPMSystemInsertScript = szPMSystemInsertScript + " from pmsystem where system_id = (select max(system_id) from pmsystem)";
		WriteToLogFile(INSTALL_LOG, "Inserting existing License Key into database using sql: ");
		
	endif;
	
	//Update PMSystem
	WriteToLogFile(INSTALL_LOG, szPMSystemInsertScript);	
	nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szPMSystemInsertScript);
	if(nvResult = 1) then
	 	WriteToLogFile(INSTALL_LOG,"LicenseKey entry put into the PMSystem");
	else
		WriteToLogFile(INSTALL_ERRORLOG,"LicenseKey entry into the PMSystem caused error.Do Manually");
	endif;
	
	
	//Update PMWrk_Task_Category
	WriteToLogFile(INSTALL_LOG, szPMSystemInsertScript);	
	nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szPMWrk_Task_CategoryInsertScript);
	if(nvResult = 1) then
	 	WriteToLogFile(INSTALL_LOG,"LicenseKey entry put into the PMWrk_Task_Category");
	else
		WriteToLogFile(INSTALL_ERRORLOG,"LicenseKey entry into the PMWrk_Task_Category caused error.Do Manually");
	endif;
	
endif;
		
return 1;            
end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  GetPatchVersionFromTextFile                                    //
//                                                                           //
// Purpose:   This function is used to get the Patch Version from the        //
//			  name of the text file available along with the Patch Package   //
//			  delivered											             //
///////////////////////////////////////////////////////////////////////////////

function number GetPatchVersionFromTextFile()
number nvResult;  
string szPatchFileName;
number nvPatchFileExtnLocation;
begin
nvResult = FindFile("","*.txt",szPatchFileName);
if(nvResult < 0 ) then
 	MessageBox("Patch Version Text File Not Found.Unable to proceed installation",SEVERE);
	abort;
else
	nvPatchFileExtnLocation = StrFind(szPatchFileName,".txt");
	StrSub(g_szPatchVersion,szPatchFileName,0,nvPatchFileExtnLocation);
endif;
 
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  UpdateLicenseInformation                                       //
//                                                                           //
// Purpose:   This function is used to get the PMLicense.ini file            //
//			  as input and updates the license information in the database   //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function number UpdateLicenseInformation()
number nvResult;  
string szProgram,szDirectory;
begin  
szDirectory = g_szPMInstallPath ^ PURE_APPLICATION_FOLDER;
szProgram = szDirectory ^ "UpdateSystem.exe";
nvResult = LaunchAppAndWait(szProgram,"",WAIT);
if(nvResult < 0) then
	WriteToLogFile(INSTALL_ERRORLOG,"Licensing Application cannot be launched.Do Manually");
else                                                                                    
	WriteToLogFile(INSTALL_LOG,"Licensing Application launched and executed successfully");
endif;

return 1;
end;              

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  InstallODBCDSNs                                                //
//                                                                           //
// Purpose:   This function is used to install the DSNs used by the Sirius   //
//			  Back Office applications for accessing Sirius Database 		 //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function number InstallODBCDSNs()
number nvResult,nvType,nvSize,nvVal;    
string szDSNDescription,szODBCDriverFile,szSQLDriverFileName;
LIST listODBCKeyName,listODBCKeyValue; 
string szODBCDSNName;
begin    

szDSNDescription = "SSP Ltd - DO NOT MODIFY";
nvSize = -1;
listODBCKeyName  = ListCreate(STRINGLIST);
listODBCKeyValue = ListCreate(STRINGLIST);
RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
//Get the File Specifications of the SQL Server Driver dll
nvResult = RegDBGetKeyValueEx ( "SOFTWARE\\ODBC\\ODBCINST.INI\\"+ODBCSQLDriverName,"Driver",nvType,szSQLDriverFileName,nvSize);
if(nvResult < 0) then
    WriteToLogFile(INSTALL_ERRORLOG,"ODBC Driver File Access Problem.Configure Manually");
else
	WriteToLogFile(INSTALL_LOG,"ODBC Driver File Accessed Successfully for DSN's Creation");
endif;   

nvResult =ReadODBCFromINI("ODBCDSN",listODBCKeyName,listODBCKeyValue);
if(nvResult = 1) then	     
	    nvVal = ListGetFirstString(listODBCKeyValue,szODBCDSNName);
	 	while(nvVal = 0) 
	 	 	nvResult = RegDBCreateKeyEx("SOFTWARE\\ODBC\\ODBC.INI",szODBCDSNName);
	        if(nvResult =0) then  
	            WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"AnsiNPW",REGDB_STRING,"Yes");
			 	WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"AutoTranslate",REGDB_STRING,"Yes");
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Database",REGDB_STRING,g_szSiriusDBName);
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Description",REGDB_STRING,szDSNDescription);
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Driver",REGDB_STRING,szSQLDriverFileName);
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"QuotedId",REGDB_STRING,"Yes");
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Regional",REGDB_STRING,"No");
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Server",REGDB_STRING,g_szDBServer);
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"UseProcForPrepare",REGDB_STRING,"0");
				if(g_bWinLoginAuthenticate = TRUE) then
					WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Trusted_Connection",REGDB_STRING,"Yes");
				else
					WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Trusted_Connection",REGDB_STRING,"");
				endif;
				//Writing to the ODBC file list,the newly created DSN  with its driver name
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\ODBC Data Sources",szODBCDSNName,REGDB_STRING,ODBCSQLDriverName);
				WriteToLogFile(INSTALL_LOG,"ODBC created Successfully for : " + szODBCDSNName);
			endif;
			nvVal = ListGetNextString(listODBCKeyValue,szODBCDSNName);
		endwhile; 
endif;
return 1;
end;      

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  UpdateODBCDSNs                                                 //
//                                                                           //
// Purpose:   This function is used to update the DSNs used by the Sirius    //
//			  Back Office applications for accessing Sirius Database and it  //
//			  is done during Pure Upgrade or Product Upgrade 				 //
//			  but Fresh Installation			                             //
///////////////////////////////////////////////////////////////////////////////

function number UpdateODBCDSNs()
number nvResult,nvType,nvSize,nvVal;    
string szDSNDescription,szODBCDriverFile,szSQLDriverFileName;
LIST listODBCKeyName,listODBCKeyValue; 
string szODBCDSNName;
begin     
nvSize = -1;
listODBCKeyName  = ListCreate(STRINGLIST);
listODBCKeyValue = ListCreate(STRINGLIST);
RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
nvResult =ReadODBCFromINI("ODBCDSN",listODBCKeyName,listODBCKeyValue);
if(nvResult = 1) then	     
	    nvVal = ListGetFirstString(listODBCKeyValue,szODBCDSNName);
	 	while(nvVal = 0) 
	 	 	nvResult = RegDBKeyExist("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName); 
	        if(nvResult =1) then  
	    		WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Database",REGDB_STRING,g_szSiriusDBName);
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Server",REGDB_STRING,g_szDBServer);
				WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"LastUser",REGDB_STRING,SIRIUSUSER);
				if(g_bWinLoginAuthenticate = TRUE) then
					WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Trusted_Connection",REGDB_STRING,"Yes");
				else
					WriteToRegistry("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName,"Trusted_Connection",REGDB_STRING,"");
				endif;
			endif;
			nvVal = ListGetNextString(listODBCKeyValue,szODBCDSNName);
		endwhile; 
endif;
return 1;
end;      
     

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  RemoveODBCDSNs                                                //
//                                                                           //
// Purpose:   This function is used to uninstall the DSNs used by the Sirius   //
//			  Back Office applications for accessing Sirius Database 		 //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function number RemoveODBCDSNs()
number nvResult,nvType,nvSize,nvVal;    
string szDSNDescription,szODBCDriverFile,szSQLDriverFileName;
LIST listODBCKeyName,listODBCKeyValue; 
string szODBCDSNName;
begin    

szDSNDescription = "Sirius Financial Systems plc - DO NOT MODIFY";
nvSize = -1;
listODBCKeyName  = ListCreate(STRINGLIST);
listODBCKeyValue = ListCreate(STRINGLIST);
RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);

nvResult =ReadODBCFromINI("ODBCDSN",listODBCKeyName,listODBCKeyValue);
if(nvResult = 1) then	     
	    nvVal = ListGetFirstString(listODBCKeyValue,szODBCDSNName);
	 	while(nvVal = 0)
	 		nvResult = RegDBKeyExist("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName);
	 		if(nvResult = 1) then
	 			nvResult = RegDBDeleteKey("SOFTWARE\\ODBC\\ODBC.INI\\"+szODBCDSNName);
	            if(nvResult < 0) then
	     			WriteToLogFile(UNINSTALL_ERRORLOG,szODBCDSNName +" DSN name cannot be deleted from ODBC data sources registry");
	   			else
	   	 			WriteToLogFile(UNINSTALL_LOG,szODBCDSNName +" DSN name deleted from ODBC data sources registry");
	   	 		endif;
	 	    endif;   
	 	    nvResult = RegDBDeleteValue("SOFTWARE\\ODBC\\ODBC.INI\\ODBC Data Sources",szODBCDSNName);
	        if(nvResult < 0) then
	     		WriteToLogFile(UNINSTALL_ERRORLOG,szODBCDSNName +" DSN name cannot be deleted from ODBC data sources registry or not available in the registry");
	   		else
	   	 		WriteToLogFile(UNINSTALL_LOG,szODBCDSNName +" DSN name deleted from ODBC data sources registry");
	   	 	endif;
	 	    nvVal = ListGetNextString(listODBCKeyValue,szODBCDSNName);
		endwhile; 
endif;
return 1;
end;     

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetPMLogicalDatabaseFolderVersionsToInstallerVariables         //
//                                                                           //
// Purpose:   This function is used to set the folder versions of the		 //
//			  Upgrade Database folders from the PMLogicalDatabase Table	to	 //
//			  the Installer Variables to use for Database Upgrading			 //
///////////////////////////////////////////////////////////////////////////////
 
function number SetPMLogicalDatabaseFolderVersionsToInstallerVariables()
number nvResult,nvVal,nvCounter; 
LIST listDBFolderKey,listDBFolderValue;
string szFolderName;
begin
listDBFolderKey = ListCreate(STRINGLIST);
listDBFolderValue = ListCreate(STRINGLIST);

nvCounter = 0;
nvResult =ReadFromINI("DBFolderOrder",listDBFolderKey,listDBFolderValue);
if(nvResult = 1) then	
    nvVal = ListGetFirstString(listDBFolderValue,szFolderName);
    if(szFolderName = "Install") then
    	goto GetNextString;
    else
   		while(nvVal = 0)  
	   		switch(nvCounter)
		   		case 0:
		   		       g_szFolder1_InstalledVersion = GetPMLogicalDatabaseFolderVersions(szFolderName);
		   		case 1:
		   			   g_szFolder2_InstalledVersion = GetPMLogicalDatabaseFolderVersions(szFolderName);   		
		   		case 2:
		   		       g_szFolder3_InstalledVersion = GetPMLogicalDatabaseFolderVersions(szFolderName);
		   		case 3:
		   			   g_szFolder4_InstalledVersion = GetPMLogicalDatabaseFolderVersions(szFolderName);
	   		endswitch;
   			nvCounter =  nvCounter + 1;
	   		GetNextString:  
	   		nvVal = ListGetNextString(listDBFolderValue,szFolderName);
	   	endwhile; 
	  endif;
endif;

return 1;
end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetUpgradedFolderVersionsToPMLogicalDatabase        			 //
//                                                                           //
// Purpose:   This function is used to set the folder versions of the		 //
//			  Upgrade Database folders from the Installer Source Folder to   //
//			  the PMLogicalDatabase table after DB Upgrade Installation		 //
///////////////////////////////////////////////////////////////////////////////

function number SetUpgradedFolderVersionsToPMLogicalDatabase()
number nvResult,nvVal,nvCounter; 
LIST listDBFolderKey,listDBFolderValue;
string szFolderName;
begin
listDBFolderKey = ListCreate(STRINGLIST);
listDBFolderValue = ListCreate(STRINGLIST);
//Sets the Counter Variable to Zero
nvCounter = 0;
nvResult =ReadFromINI("DBFolderOrder",listDBFolderKey,listDBFolderValue);
if(nvResult = 1) then	
    nvVal = ListGetFirstString(listDBFolderValue,szFolderName);
    if(szFolderName = "Install") then
    	goto GetNextString;
    else
   		while(nvVal = 0)  
	   		switch(nvCounter)
		   		case 0:
		   			   SetFolderVersionsToPMLogicalDatabase(g_szFolder1_TobeInstalledVersion,szFolderName);
		   		case 1:
		   			   SetFolderVersionsToPMLogicalDatabase(g_szFolder2_TobeInstalledVersion,szFolderName);
		   		case 2:
		   		       SetFolderVersionsToPMLogicalDatabase(g_szFolder3_TobeInstalledVersion,szFolderName);
		   		case 3:
		   			   SetFolderVersionsToPMLogicalDatabase(g_szFolder4_TobeInstalledVersion,szFolderName);
	   		endswitch;
   			nvCounter =  nvCounter + 1;
	   		GetNextString:  
	   		nvVal = ListGetNextString(listDBFolderValue,szFolderName);
	   	endwhile; 
	  endif;
endif;

return 1;
end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetFolderVersionsToPMLogicalDatabase        			 		 //
//                                                                           //
// Purpose:   This function is used to update the tobe Installed or   		 //
//			  Currently Installed folder version of DB Scripts Folder to 	 //
//			  PMLogicaldatabase table of Sirius DB						 	 //
///////////////////////////////////////////////////////////////////////////////

function number SetFolderVersionsToPMLogicalDatabase(szFolderVersion,szFolderName)
number nvResult;
string szFolderVersionUpdateScript;
begin       
               
szFolderVersionUpdateScript = "update pmlogicaldatabase set version='"+ szFolderVersion + "' where name='"+ szFolderName + "'";
nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szFolderVersionUpdateScript);
if(nvResult = 1) then
	WriteToLogFile(DATABASE_LOG,"PMLogical database updated with folder "+szFolderName+" version successfully");
else	
	WriteToLogFile(DATABASE_ERRORLOG,"PMLogical database not updated with folder "+szFolderName+" version.Do Manually");
endif;   

return 1;
end;


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  GetPMLogicalDatabaseFolderVersions                             //
//                                                                           //
// Purpose:   This function is used to get the Folder Versions for Database  //
//			  Upgrades from PMLogicalDatabase Table							 //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function string GetPMLogicalDatabaseFolderVersions(szFolderName)
number nvResult;
string szFolderVersionSQLScript; 
string szFolderVersion;
begin
szFolderVersionSQLScript = "select version from pmlogicaldatabase where name like '"+szFolderName +"'";     
WriteToLogFile(INSTALL_LOG, "SiriusDBServer:" + g_szDBServer);
WriteToLogFile(INSTALL_LOG, "SiriusDBName:" + g_szSiriusDBName);
WriteToLogFile(INSTALL_LOG, "SiriusUserName:" + g_szSiriusUserName);   
WriteToLogFile(INSTALL_LOG, "SiriusPassord:" + g_szSiriusPassword);
WriteToLogFile(INSTALL_LOG, "DBFolderName:" + szFolderName);   
szFolderVersion = ADODBConnectExecuteAndReturn(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szFolderVersionSQLScript,"version");  
if(szFolderVersion = "") then
	MessageBox("PMLogicalDatabase Version Information not available.Check the Database",WARNING);
	abort;
endif;
    
return szFolderVersion;    
end;    
                                             
                                             
                                             
//////////////////////////////////////////////////////////////////////////////////
//                                                                           	//
// Function:  GetMajorandServiceReleaseVersionandBuildNumberforInstalledProduct //
//                                                                           	//
// Purpose:   This function is used to get the Installed Major Version,      	//
//			  Service Release and Build Version of the Product				 	//
//			  						                                        	//
//////////////////////////////////////////////////////////////////////////////////

function number GetMajorandServiceReleaseVersionandBuildNumberforInstalledProduct()
number nvResult;  
LIST listInstalledProductSplitVersions; 
string szServiceReleaseAndBuildNumber;   

begin   
listInstalledProductSplitVersions = ListCreate(STRINGLIST);
listInstalledProductSplitVersions = SplitStringintoList(g_szInstalledProductVersion);
g_szInstalledMajorVersion =  ConcatenateListContentintoString(listInstalledProductSplitVersions);
//Replace the SubVersion and Use it seperately   
if(StrLengthChars(g_szInstalledMajorVersion) = 4) then
	StrSub(g_szInstalledSubVersion,g_szInstalledMajorVersion,3,1);
	StrSub(g_szInstalledMajorVersion,g_szInstalledMajorVersion,0,3);
else 
	g_szInstalledSubVersion = "0";
endif;
ListDestroy(listInstalledProductSplitVersions);            
listInstalledProductSplitVersions = ListCreate(STRINGLIST);
listInstalledProductSplitVersions = SplitStringintoList(g_szInstalledServiceReleaseAndBuildNumber);
nvResult = ListGetFirstString(listInstalledProductSplitVersions,g_szInstalledServiceRelease);
ListGetNextString(listInstalledProductSplitVersions,g_szInstalledBuildNumber);
g_szInstalledProductVersionforDBStructure  = ConstructProductVersionforDBStructure(g_szInstalledMajorVersion,g_szInstalledServiceRelease,g_szInstalledBuildNumber,g_szInstalledSubVersion);
 
return 1;
end;          


//////////////////////////////////////////////////////////////////////////////////////
//                                                                           		//
// Function:  GetMajorandServiceReleaseVersionandBuildNumberforTobeInstalledProduct //
//                                                                           		//
// Purpose:   This function is used to get the  Major Version,      				//
//			  Service Release and Build Version of the Product Version to be    	//
//			  Installed						                                        //
////////////////////////////////////////////////////////////////////////////////////// 

function number GetMajorandServiceReleaseVersionandBuildNumberforTobeInstalledProduct()
number nvResult;  
LIST listTobeInstalledProductSplitVersions; 
string szServiceReleaseAndBuildNumber; 
string szFullVersion;   
string szMajorVersion1,szMajorVersion2;
begin   

listTobeInstalledProductSplitVersions = ListCreate(STRINGLIST);
listTobeInstalledProductSplitVersions = SplitStringintoList(IFX_PRODUCT_VERSION);
szFullVersion =  ConcatenateListContentintoString(listTobeInstalledProductSplitVersions);

ListGetFirstString(listTobeInstalledProductSplitVersions,g_szTobeInstalledMajorVersion);
WriteToLogFile(INSTALL_LOG, "Major version no. of the product is: " + g_szTobeInstalledMajorVersion);

ListGetNextString(listTobeInstalledProductSplitVersions,g_szTobeInstalledMinorVersion);  
WriteToLogFile(INSTALL_LOG, "Minor version no. of the product is: " + g_szTobeInstalledMinorVersion);

if(StrFind(g_szTobeInstalledMinorVersion,"0") = 0) then
	g_szTobeInstalledSubVersion = "0";
else
	StrSub(g_szTobeInstalledSubVersion,g_szTobeInstalledMinorVersion,0,1);  
endif; 
WriteToLogFile(INSTALL_LOG, "Sub version no. of the product is: " + g_szTobeInstalledSubVersion);

StrSub(g_szTobeInstalledServiceRelease,g_szTobeInstalledMinorVersion,1,2);
if(StrFind(g_szTobeInstalledServiceRelease,"0") = 0) then
  StrSub(g_szTobeInstalledServiceRelease,g_szTobeInstalledServiceRelease,1,1);
endif;
WriteToLogFile(INSTALL_LOG, "Service release no. of the product is: " + g_szTobeInstalledServiceRelease);

ListGetNextString(listTobeInstalledProductSplitVersions,g_szTobeInstalledBuildNumber);
//Cutting down on the preceding zeros in case of 5 digit Build Number
if(StrFind(g_szTobeInstalledBuildNumber,"0000") = 0) then
	StrSub(g_szTobeInstalledBuildNumber,g_szTobeInstalledBuildNumber,4,1);
elseif(StrFind(g_szTobeInstalledBuildNumber,"000") = 0) then           
	StrSub(g_szTobeInstalledBuildNumber,g_szTobeInstalledBuildNumber,3,2);
elseif(StrFind(g_szTobeInstalledBuildNumber,"00") = 0) then
	StrSub(g_szTobeInstalledBuildNumber,g_szTobeInstalledBuildNumber,2,3);
elseif(StrFind(g_szTobeInstalledBuildNumber,"0")= 0) then
	StrSub(g_szTobeInstalledBuildNumber,g_szTobeInstalledBuildNumber,1,4);
endif;
WriteToLogFile(INSTALL_LOG, "Build no. of the product is: " + g_szTobeInstalledBuildNumber);

ListDestroy(listTobeInstalledProductSplitVersions);            

StrSub(szMajorVersion1,g_szTobeInstalledMajorVersion,0,1);
StrSub(szMajorVersion2,g_szTobeInstalledMajorVersion,1,2);

if(g_szTobeInstalledSubVersion != "" && g_szTobeInstalledSubVersion !="0") then
	g_szTobeInstalledFullVersion =  szMajorVersion1 + "." + szMajorVersion2 + "." + g_szTobeInstalledSubVersion + " Service Release " + g_szTobeInstalledServiceRelease + " Build "+ g_szTobeInstalledBuildNumber;
else
	g_szTobeInstalledFullVersion =  szMajorVersion1 + "." + szMajorVersion2 + " Service Release " + g_szTobeInstalledServiceRelease + " Build "+ g_szTobeInstalledBuildNumber;
endif;
WriteToLogFile(INSTALL_LOG, "Fully specified version of the product is: " + g_szTobeInstalledFullVersion);

//Get the Product Version for DB Folder Structure
g_szTobeInstalledProductVersionforDBStructure  = ConstructProductVersionforDBStructure(g_szTobeInstalledMajorVersion,g_szTobeInstalledServiceRelease,g_szTobeInstalledBuildNumber,g_szTobeInstalledSubVersion);
WriteToLogFile(INSTALL_LOG, "Fully specified version for DB Structure of the product is: " + g_szTobeInstalledProductVersionforDBStructure);
 
return 1;
end; 


//////////////////////////////////////////////////////////////////////////////////////
//                                                                           		//
// Function:  ConstructProductVersionforDBStructure									//
//                                                                           		//
// Purpose:   This function is used to construct the Product Version in the 		//
//			  format to be used by the Upgrade Database Folder Conventions for	   	//
//			  using in the DB Scripts execution						                //
////////////////////////////////////////////////////////////////////////////////////// 

function string ConstructProductVersionforDBStructure(szMajorVersion,szServiceRelease,szBuildNumber,szSubVersion)
number nvResult;  
string szFullMajorVersion,szFullBuildNumber; 
string szProductVersionforDBStructure;
begin                               
szFullMajorVersion = MakeMajorVersionforDBStructure(szMajorVersion,szSubVersion);
szFullBuildNumber  = MakeBuildNumberForDBStructure(szBuildNumber);
szProductVersionforDBStructure = szFullMajorVersion + "." + szServiceRelease + "." + szFullBuildNumber;
return szProductVersionforDBStructure;
end;    


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  MakeBuildNumberForDBStructure                					 //
//                                                                           //
// Purpose:   This function is used to construct the Build number in         //
//			  the 5-digit format for use by DB Structure Folder				 //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function string MakeBuildNumberForDBStructure(szBuildNumber)
number nvBuildNumberLength;
string szFullBuildNumber;
begin

nvBuildNumberLength = StrLengthChars(szBuildNumber);
switch(nvBuildNumberLength)
case 1:
  		szFullBuildNumber = "0000" +  szBuildNumber;
case 2:
		szFullBuildNumber = "000"  +  szBuildNumber;
case 3:
		szFullBuildNumber = "00"   +  szBuildNumber;
case 4:		                                     
		szFullBuildNumber = "0"   +  szBuildNumber;
case 5:	
		szFullBuildNumber = szBuildNumber;	
endswitch;

return szFullBuildNumber;
end;     


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  MakeMajorVersionforDBStructure                				 //
//                                                                           //
// Purpose:   This function is used to construct the Major Version number in //
//			  the 5-digit format for use by DB Structure Folder				 //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function string MakeMajorVersionforDBStructure(szMajorVersion,szSubVersion)
string szFullMajorVersion;
begin
if(szSubVersion != "" && szSubVersion != "0") then
    szFullMajorVersion =  szMajorVersion + szSubVersion + "0";
else                                         
    szFullMajorVersion =  szMajorVersion + "00";
endif;
return szFullMajorVersion;
end;


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SplitStringintoList                				 			 //
//                                                                           //
// Purpose:   This function is used to split the product version string      //
//			  Splitted by "." into a list variable							 //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function LIST SplitStringintoList(szFullString)
number nvResult;                               
LIST listSplitContent;
begin                
listSplitContent = ListCreate(STRINGLIST);
nvResult = StrGetTokens(listSplitContent,szFullString,".");
if(nvResult < 0) then
	//Write to log that the Installed ProductVersion Number Cannot be Splitted
else
   //Write to log that the Installed Product Version is Split Successfully
endif;

return listSplitContent;
end;

 
///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ConcatenateListContentintoString                				 //
//                                                                           //
// Purpose:   This function is used to concatenate the List Variable		 //
//			  containing the product version content into a single string    //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function string ConcatenateListContentintoString(listSplitContent)
number nvResult;
string szConcatenatedString; 
string szListValue;
begin
szConcatenatedString = "";
nvResult = ListGetFirstString(listSplitContent,szListValue);
while(nvResult = 0)  
szConcatenatedString = szConcatenatedString	+ szListValue;   		
nvResult = ListGetNextString(listSplitContent,szListValue);
endwhile; 

return szConcatenatedString;
end;  

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetFreshDBCompatibilityLevel  							     //
//                                                                           //
// Purpose:   This function is used to set the DB compatibility level        //
//			  to SQLSERVER 2000 to newly created Sirius DB in SQLServer 2005 //
///////////////////////////////////////////////////////////////////////////////

function number SetFreshDBCompatibilityLevel()
number nvResult;
string szDBCompatScript;
STRING szProductVersionSQL,svProductVersion,svMajorProductVersion;
begin   

	szProductVersionSQL="SELECT SERVERPROPERTY('ProductVersion') ProductVersion";
	svProductVersion = ADODBConnectExecuteAndReturn(g_szDBServer,"master",g_szSiriusUserName,g_szSiriusPassword,szProductVersionSQL,"ProductVersion");  
	
	//MessageBox("Product version=" + svProductVersion ,INFORMATION);
	StrSub(svMajorProductVersion,svProductVersion,0,2); 
	//MessageBox("Major version=" + svMajorProductVersion ,INFORMATION);

	if(svMajorProductVersion= "11") then
		szDBCompatScript = "execute sp_dbcmptlevel '"+ g_szSiriusDBName +"',110";
	endif;
	
	if(svMajorProductVersion= "10") then
		szDBCompatScript = "execute sp_dbcmptlevel '"+ g_szSiriusDBName +"',100";
	endif;
	
	nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szDBCompatScript);
	if(nvResult = 1) then
		WriteToLogFile(INSTALL_LOG,g_szSiriusDBName +" Database Compatibility set to SQL Server 2008");
	elseif(nvResult = -2) then 
		return -2;
	else
		WriteToLogFile(INSTALL_ERRORLOG,g_szSiriusDBName +" Database Compatibility cannot to SQL Server 2008. Please perform this step manually.");
	endif; 

return 1;
end;       

   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetUpWord  								                     //
//                                                                           //
// Purpose:   This function sets up a word macro into the installed          //
//			  word document of the target machine                            //
///////////////////////////////////////////////////////////////////////////////

function number SetupWord()
string  szFile;
number nvResult;
begin    

SdShowMsg ( "Setting Up Word Macros . . . please wait." , TRUE );
szFile = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "iPMUCopyFile.exe";

// Stick some quotes around the path
if (LongPathToQuote(szFile,TRUE) != 0) then
	MessageBox ("Unable to convert path to quoted path.\n" + szFile, SEVERE );
else
	nvResult = LaunchAppAndWait(szFile,"", LAAW_OPTION_WAIT);
   if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Unable to launch the following file : \n" +" " + szFile + "\nYou need to run this for the macros to be installed.");
   else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"Setting up Word Macros Operation Completed Successfully");
   endif;
endif;
   
SdShowMsg ( "Setting Up Word Macros . . . please wait." , FALSE );

return 1;
end; 

/////////////////////////////////////////////////////////////////////////////
//                                                                         //
// Function:  RegisterEventLogSupport                                      //
//                                                                         //
//  Purpose:  Call VB program that registers the SA event log support DLLs //
//                                                                         //
/////////////////////////////////////////////////////////////////////////////
function number RegisterEventLogSupport()
	number nvResult;
	string szResult,szFilePath,szFile,szMsg;
begin

szFilePath = TARGETDIR ^ PURE_APPLICATION_FOLDER;
szFile = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ EVENTLOG_SUPPORTFILE;

nvResult =  FindFile(szFilePath,EVENTLOG_SUPPORTFILE,szResult);
if(nvResult < 0) then
		// couldn't find it
    szMsg = "Failed to locate PMRegELSupport.exe\n\n" +
            "Customers should contact support for further details.";
    MessageBox(szMsg,SEVERE);
    WriteToLogFile(INSTALL_ERRORLOG,szMsg);
	return 1;
endif;	

// installer located
SdShowMsg ( "Running event log support program - please wait",TRUE);
	
// Call app with command line parm.
// Path to program
// Path to support DLLs
LaunchAppAndWait(szFile,TARGETDIR ^ PURE_APPLICATION_FOLDER,WAIT);
	
SdShowMsg ( "" , FALSE );
WriteToLogFile(INSTALL_LOG,"Event Log Support Program run successfully");

return 1;
end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  GetPathforScriptsDirectoryinPatch  							 //
//                                                                           //
// Purpose:   This function gets the DBScripts Folder path required for      //
//			  executing DBScripts during Patch Installation                  //
///////////////////////////////////////////////////////////////////////////////

function string GetPathforScriptsDirectoryinPatch()
number nvResult;
string szScriptsPath;
LIST listPatchDIRs;
begin
listPatchDIRs = ListCreate(STRINGLIST);
nvResult = FindAllDirs("",EXCLUDE_SUBDIR,listPatchDIRs);
if(nvResult < 0) then
	MessageBox("Patch DB Scripts cannot be executed as Scripts Folder not found",SEVERE);
 	abort;
endif;
//Get the Scripts Folder Root Path for the Patch Application from the List Variable
ListGetFirstString(listPatchDIRs,szScriptsPath);
//Trim the Scripts Root Path at the Start and End
szScriptsPath = TrimStart(szScriptsPath,".\\");
szScriptsPath = TrimEnd(szScriptsPath,"\\");

return szScriptsPath;
end;
        
       
        
//////////////////////////////////////////////////////////////////////////
//                                                                      //
// Function:  CopyInstallSet                                            //
//                                                                      //
//  Purpose:  This function copies SA installation files to location on //
//            server where auto client installs can access them.        //
//                                                                      //
//////////////////////////////////////////////////////////////////////////
function number CopyInstallSet()
number nvResult,nvLineNumber;
string szResult, szMsg,szReturnLine,szProgram,szCmdLine;
string szZipInstallerApplicationPath,szZipInstallSetPath;
begin   

szZipInstallerApplicationPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "Server\\Programs";
szZipInstallSetPath  = TARGETDIR ^ ZIPPEDINSTALLSET_ROOT;

nvResult =  FindFile(szZipInstallerApplicationPath,ZIPINSTALLERAPPLICATION,szResult);
if(nvResult < 0) then
		// couldn't find it
    szMsg = "Failed to locate "+ZIPINSTALLERAPPLICATION +
            "Customers should contact support for further details.";
    MessageBox(szMsg,SEVERE);
    WriteToLogFile(INSTALL_ERRORLOG,szMsg);
	return -1;
endif;	

nvResult =  FindFile(szZipInstallSetPath,ZIPINSTALLSET,szResult);
if(nvResult < 0) then
		// couldn't find it
    szMsg = "Failed to locate "+ZIPINSTALLSET +
            "Customers should contact support for further details.";
    MessageBox(szMsg,SEVERE);
    WriteToLogFile(INSTALL_ERRORLOG,szMsg);
	return -1;
endif;	

SdShowMsg("Installing zipped Sirius Architecture install set - please wait",TRUE);

// add @PRODUCT_CODE to the string
// Parameters: version eg. V1.6.5
//             code eg. product code on PmProduct table
//             zip file location
szProgram = szZipInstallerApplicationPath ^ ZIPINSTALLERAPPLICATION;
szCmdLine =  @PRODUCT_VERSION + "," + @PRODUCT_CODE + "," + szZipInstallSetPath ^ ZIPINSTALLSET;

nvResult = LaunchAppAndWait(szProgram,szCmdLine,WAIT);

if(nvResult < 0) then
	WriteToLogFile(INSTALL_ERRORLOG,ZIPINSTALLERAPPLICATION +" cannot be run successfully for "+ZIPINSTALLSET+".Contact Sirius Support");
	return -1; 
else                                                                                    
	WriteToLogFile(INSTALL_LOG,ZIPINSTALLERAPPLICATION +" run successfully for "+ZIPINSTALLSET+".");
endif;


SdShowMsg("",FALSE);

// Search log file for COMPLETE: NO ERRORS message
// Logfile will be Product Code + "Unzipper.log"
nvResult = FileGrep("C:\SiriusUnzipper.log","COMPLETE: NO ERRORS",szReturnLine,nvLineNumber,RESTART);

// how'd we do?
if(nvResult = 0) then
  	szMsg = "Install of zipped Sirius Architecture install set has failed.\n\n" +
        	    "Auto client updates will not be performed.";
    MessageBox(szMsg,SEVERE);
endif;

// even if zip install failed, SA may have installed successfully
return 1;
end;
       

///////////////////////////////////////////////////////////////////////////
//                                                                       //
// Function:  RegisterPMFieldManager                                     //
//                                                                       //
//  Purpose:  This function regsiters the .Net assembly iPMBFieldManager //
//            for COM interoperability.                                  //
//                                                                       //
///////////////////////////////////////////////////////////////////////////
function number RegisterPMFieldManager()   
string svResult, svPath, szOfficeDir, szWordTARGETDIR, szDocTemplateDll, svMessage, szDocTemplateDllPath;	
LIST listDocTemplateDlls;
number nvResult, nvCopyResult;
begin
   if ( FindAllFiles ( WINDIR ^ "Microsoft.NET" ^ "Framework64" ^ "v4.0.30319", "regasm.exe", svResult, RESET ) == 0 ) then
		svPath = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "iPMBFieldManager.dll";
		WriteToLogFile(INSTALL_LOG,"Path of the utility" +svResult + ".");
		// Stick some quotes around the path
		if (LongPathToQuote(svPath,TRUE) != 0) then
			MessageBox ("Unable to convert path to quoted path.\n" + svPath, SEVERE );		
			WriteToLogFile(INSTALL_ERRORLOG,"Unable to convert path to quoted path.\n" + svPath + ".");
			return -1;
		else   
			svPath = svPath + " /codebase /tlb";
			nvResult = LaunchAppAndWait ( svResult, svPath, LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
			if ( nvResult < 0) then
				WriteToLogFile(INSTALL_ERRORLOG, "Unable to launch " + svPath + ".");
				return -1; 
			else
				WriteToLogFile(INSTALL_LOG, "Successfully executed the command " + svPath + " to register iPMBFieldManager.dll.");
			endif;
		endif;    
	endif;
	
	return 0;
end;   

///////////////////////////////////////////////////////////////////////////
//                                                                       //
// Function:  DeleteRegistryInformantion                                 //
//                                                                       //
//  Purpose:  This function deleted the registry information created by  //
//            setup in case of installation abort or error.              //
//                                                                       //
///////////////////////////////////////////////////////////////////////////
function number DeleteRegistryInformation()   
string szKey, szRoot;	
number nvResult;
begin
   	if(RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE) < 0 ) then
   		WriteToLogFile(INSTALL_ERRORLOG, "Unable to set default registry key.");
		return -1; 	                                                               
	elseif(RegDBDeleteKey("SOFTWARE\\Pure") < 0) then
		WriteToLogFile(INSTALL_ERRORLOG, "Unable to set delete registry keys.");
		return -1; 	                                                               	
    endif;
	return 1;
end; 

//////////////////////////////////////////////////////////////////////////////////
//
// Procedure:	DataModelRebuild
//
// Description:	Rebuild the data model
//
//////////////////////////////////////////////////////////////////////////////////
function number DataModelRebuild()
	STRING	svValue, szProgram, szCmdLine, szMsg, szKey;	
	NUMBER	nvType, nvSize, nResult, nvExitCode;
	begin	
	// setup the command line and program name
	szCmdLine = "";
	szProgram = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "datamodelrebuild.exe";
		
	if (LongPathToQuote(szProgram,TRUE) != 0) then
		MessageBox ("Unable to convert path to quoted path.\n" + szProgram, SEVERE );		
		WriteToLogFile(INSTALL_ERRORLOG,"Unable to convert path to quoted path.\n" + szProgram + ".");
		return -1;
	else
		// rebuild datamodel now
		SdShowMsg ( "Datamodel Rebuild . . . please wait." , TRUE );
		WriteToLogFile(INSTALL_LOG,"Launching " + szProgram + " to rebuild datamodels.");
		//nvExitCode = LaunchApplication( szProgram, szCmdLine, "", SW_SHOW, 30000, LAAW_OPTION_USE_SHELLEXECUTE | LAAW_OPTION_WAIT ); 
		LAAW_SHELLEXECUTEVERB = "runas"; 
		nvExitCode = LaunchApplication( szProgram, szCmdLine, "", SW_SHOW, INFINITE, LAAW_OPTION_USE_SHELLEXECUTE | LAAW_OPTION_WAIT ); 
		if (nvExitCode < 0 ) then
			szMsg = "Unable to launch : " + szProgram + " it will need to be run manually.";
			MessageBox ( szMsg, SEVERE );   
			WriteToLogFile(INSTALL_ERRORLOG,szMsg);  
			return -1;   
		else
	 	   szMsg = "Data models built sucessfully using " + szProgram + ".";
	 	   WriteToLogFile(INSTALL_LOG,szMsg);
		endif;
		SdShowMsg ( "Datamodel Rebuild . . . please wait." , FALSE );
	endif;
	
	// if re-boot is required then rebuild upon reboot
	
	if ( BATCH_INSTALL = TRUE ) then
		RegDBSetDefaultRoot ( HKEY_LOCAL_MACHINE );
		szKey = "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce"; 
		WriteToLogFile(INSTALL_LOG,"Successfully configured " + szProgram + "to run at startup.");
		RegDBSetKeyValueEx ( szKey , "DatamodelRebuild" , REGDB_STRING , '"' + szProgram + '"' , -1 );
		//return 0;
	endif;    
	
	// exit the procedure
	return 0;
end;

//---------------------------------------------------------------------------
// OnMaintUIAfter
//
// The OnMaintUIAfter event called by the framework after the file transfer
// of the setup when the setup is running in maintenance mode. By default
// this event displays UI that informs the end user that the maintenance setup
// has been completed successfully.
//---------------------------------------------------------------------------
function OnMaintUIAfter()
    STRING szTitle, szMsg1, szMsg2, szOpt1, szOpt2,szFileName;
    NUMBER bOpt1, bOpt2;
    STRING  svBackupLocation,svTargetLocation;
begin
	REGDB_OPTIONS = REGDB_OPTIONS | REGDB_OPTION_WOW64_64KEY;
	Disable(WOW64FSREDIRECTION);
	Disable(STATUSEX);

	ConfigureAspDotNetSateService();
	
	
	if (MAINTENANCE) then 
	
		szFileName = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "WCFSecurityTokenFile.txt";
	
	
		if(g_bAppServerOnly=TRUE || g_WCFServices=TRUE) then
	
			if Is(FILE_EXISTS, szFileName) = TRUE then
				ReadWCFSecurityTokenFile();
			else
				RunGenerateWCFTokenID();
		
				ReadWCFSecurityTokenFile();
			endif;
		    if(g_SkipDb=FALSE) then	
				ReadPureConfigFiles();
			endif;
		endif;
		
		if(g_bAppServerOnly=TRUE || g_bWebServices=TRUE || g_WCFServices=TRUE) then
		
			RemoveFilesDuringInstall();
	
		endif;
	
		/*
		if(g_bAppServerOnly=TRUE) then
			UpdatePMWorkManagerConfig();
		endif;
	
		if(g_WCFServices=TRUE) then
			UpdateWCFServiceConfig();
		endif;
		*/

		if(g_bPortal=TRUE || g_WCFServices=TRUE) then
			LoadAppPoolUserProfile();
		endif;
	
		if(g_bPortal=TRUE) then
			ModifyPortalApplicationSetting();
			
			//BSJ Call the registry functions after upgrade 
			UpdateDBRegistryEntriesAfterInstallation();
			
			//Configure ASP .NET state service
			ConfigureAspDotNetSateService();
			
		endif;
		
		/*if(g_bPortal=TRUE) then
			CopyCrystalReportWebFormViewer4Files();
		endif;*/
		
		if(g_bAppServerOnly=TRUE || g_WCFServices=TRUE) then
		
			RemovePureWebServicesDuringInstall();
	
		endif;

	endif; 



    if( REMOVEALLMODE ) then
        szTitle = SdLoadString(IFX_SDFINISH_REMOVE_TITLE);
        szMsg1 = SdLoadString(IFX_SDFINISH_REMOVE_MSG1);
    else
        szTitle = SdLoadString(IFX_SDFINISH_MAINT_TITLE);    
        szMsg1  = SdLoadString(IFX_SDFINISH_MAINT_MSG1);
    endif;
    
    if( REMOVEALLMODE ) then
		if(DeleteDir(TARGETDIR, ALLCONTENTS) < 0) then
			WriteToLogFile(UNINSTALL_ERRORLOG, "An error occured while removing installation directory:" + TARGETDIR + ". Please remove it manually");	
		else
			WriteToLogFile(UNINSTALL_LOG, "Successfully removed installation directory: " + TARGETDIR);	
		endif;
	endif;
    
  	bOpt1   = FALSE;
    bOpt2   = FALSE;    
    
    if(gRestoreBackupFile=TRUE)then
		svBackupLocation=gBackupPath;
		svTargetLocation=TARGETDIR;
		RestoreFiles(svBackupLocation,svTargetLocation);
	endif;

    if ( BATCH_INSTALL ) then
    	SdFinishReboot ( szTitle , szMsg1 , SYS_BOOTMACHINE , szMsg2 , 0 );
    else    
       	SdFinish ( szTitle , szMsg1 , szMsg2 , szOpt1 , szOpt2 , bOpt1 , bOpt2 );
    endif;

end;   

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  CompareDatabaseServerDateTime			                             //
//                                                                           //
// Purpose:   This function is used to check whether date and time at SQL    //
//			  Server is same as that of target machine                       //  														 //
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function number CompareDatabaseServerDateTime()
number nvResult;   
number nvDateDiff;  
number nvTimeDiff;
string svSystemDateTime;
string svServerDateTime;
string svDate;
string svTime;  
string svMessage;
string szQuestion;
string szDateDiff; 
string szTimeDiff; 
string szServerDateSQL;
begin   
 	
 	// Get the current date. 
    if (FormatDate(DATE_EU, 4, "-", svDate) < 0) then  
	     Sprintf(szQuestion, "An Error occured while retrieving system date.\nDo you wish to continue?");
   		 nvResult = AskYesNo(szQuestion,NO);
         if(nvResult = NO)then
        	abort;
		 endif;
    endif; 
    
 	// Get the current time. 
    if (GetSystemInfo (TIME, nvResult, svTime) < 0) then   
	     Sprintf(szQuestion, "An Error occured while retrieving system time.\nDo you wish to continue?");
   		 nvResult = AskYesNo(szQuestion,NO);
         if(nvResult = NO)then
        	abort;
		 endif;
	endif; 
	
	if(StrLength(svDate) > 0 && StrLength(svTime) > 0) then  
		svSystemDateTime = svDate + " " + svTime;
	   	WriteToLogFile(INSTALL_LOG,"System DATE TIME: " + svSystemDateTime);	   
	else
		WriteToLogFile(INSTALL_ERRORLOG,"Could not get database server datetime");	   
	endif; 
    
	szServerDateSQL = "select Convert(varchar,GETDATE(), 120) ServerDate";
	svServerDateTime = ADODBConnectExecuteAndReturn(g_szDBServer,"master",g_szSiriusUserName,g_szSiriusPassword,szServerDateSQL,"SERVERDATE");  

	if(StrLength(svServerDateTime) == 0) then    
 	 	Sprintf(szQuestion, "An Error occured while retrieving database server datetime.\nDo you wish to continue?");
   		nvResult = AskYesNo(szQuestion,NO);
        if(nvResult = NO)then
     		abort;
		endif;    
	    WriteToLogFile(INSTALL_ERRORLOG,"Could not get database server datetime");  
	else
	    WriteToLogFile(INSTALL_LOG,"Database server DATE TIME: " + svServerDateTime);  
    endif;
    
	szServerDateSQL = "select DATEDIFF(mi, GetDate(),Convert(datetime,'" + svSystemDateTime + "', 120)) [DATEDIFF]";     
	szDateDiff = ADODBConnectExecuteAndReturn(g_szDBServer,"master",g_szSiriusUserName,g_szSiriusPassword,szServerDateSQL,"DATEDIFF");  
	
	if(StrLength(szDateDiff) == 0) then    
 	 	Sprintf(szQuestion, "An Error occured while comparing system datetime with database server datetime.\nDo you wish to continue?");
   		nvResult = AskYesNo(szQuestion,NO);
        if(nvResult = NO)then
     		abort;
		endif;    
	    WriteToLogFile(INSTALL_ERRORLOG,"An Error occured while comparing system datetime with database server datetime");  
	else
 		StrToNum(nvDateDiff, szDateDiff);
		Sprintf(svMessage, "Datetime difference: %ld", nvDateDiff) ;
		WriteToLogFile(INSTALL_LOG,svMessage);    
		if( nvDateDiff != 0) then    
			Sprintf(szQuestion, "WARNING: Installation machine datetime: %s is different from server time: %s\n\nDo you wish to continue?",
							svSystemDateTime, svServerDateTime) ;
			nvResult = AskYesNo(szQuestion,NO);
        	if(nvResult = NO)then
        		abort;
        	else
	       		return 0;
        	endif;
		endif;   
	endif;
	return 0;
end;  

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  CompareDatabaseCollation			                             //
//                                                                           //
// Purpose:   This function is used to check required SQL Server collation   //
//			  order															 //
//			  Server is same as that of target machine                       //  					
//			  						                                         //
///////////////////////////////////////////////////////////////////////////////

function number CompareDatabaseCollation()
string szCollationOrder;
string dbCollationOrder;  
string szServerSQL; 
string svMessage;  
string szQuestion; 
number nvResult;
begin   
 	       
 	szCollationOrder = "SQL_Latin1_General_CP1_CI_AS";       
 	
 	// Get the current collation. 
	szServerSQL = "SELECT SERVERPROPERTY('collation') CollationOrder";     
	dbCollationOrder = ADODBConnectExecuteAndReturn(g_szDBServer,"master",g_szSiriusUserName,g_szSiriusPassword,szServerSQL,"CollationOrder");  
	   
	if(StrLength(dbCollationOrder) == 0) then
	     Sprintf(szQuestion, "An Error occured while retrieving database collation order.\nDo you wish to continue?");
   		 nvResult = AskYesNo(szQuestion,NO);
         if(nvResult = NO)then
        	abort;
		 endif;
	endif;
	
	WriteToLogFile(INSTALL_LOG,"Database Collation Order: " + dbCollationOrder);    
	
	if(StrCompare ( szCollationOrder, dbCollationOrder )!= 0) then
     	Sprintf(szQuestion, "DB Collation order is incorrect.\nExpected: %s\nActual: %s\.\nDo you wish to continue?",szCollationOrder, dbCollationOrder) ;
   		nvResult = AskYesNo(szQuestion,NO);
        if(nvResult = NO)then
        	abort;
        else
	       	return 0;
        endif;
	endif; 
	return 0;  
end; 

function UpdateProductClientInstall()
    number nvResult, nvPMProductIdValue;
    string szReturnValue, szGetNewPMProductIdScript;
    string szDMEInstallEntryExistSQL, szDMEInstallUpdateSQL;
    string szBOInstallEntryExistSQL, szBOInstallUpdateSQL; 
    string szDocDeviceUpdateSQL;   
    string szInstallPath;
begin;
   if(SRCDIR % ":") then
   		ParsePath(szInstallPath, SRCDIR, DIRECTORY);
   		szInstallPath = "\\\\" + g_szHostName ^ szInstallPath;
   else
      	ParsePath(szInstallPath, SRCDIR, PATH);
   endif;
                                              
   WriteToLogFile(INSTALL_LOG, "Installation path is: " + szInstallPath);                                           
   
   szBOInstallEntryExistSQL = "if exists(select pmproduct_id from PMProduct_Client_Install where rtrim(ltrim(lower(client_install_description))) like 'sirius back-office client installation') select sRetValue='YES' else select sRetValue='NO' ";
   szReturnValue = ADODBConnectExecuteAndReturn(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szBOInstallEntryExistSQL,"sRetValue");
   
   WriteToLogFile(INSTALL_LOG, "Checking client install information for SSP Pure BO using SQL: " +  szBOInstallEntryExistSQL);
   if(szReturnValue = "YES") then	 
   		szBOInstallUpdateSQL = "UPDATE PMProduct_Client_Install SET client_install_program='Setup.exe',client_install_path='"+ szInstallPath +"',required_server_version = '" + IFX_PRODUCT_VERSION + "', client_software_date = getdate(), latest_client_version = '" + IFX_PRODUCT_VERSION + "', server_software_date = getdate() where rtrim(ltrim(lower(client_install_description))) like 'sirius back-office client installation'";
   else  
   		szGetNewPMProductIdScript = "select max(pmproduct_id) as sRetValue from PMProduct_Client_Install";
		szReturnValue = ADODBConnectExecuteAndReturn(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szGetNewPMProductIdScript,"sRetValue");
		if(szReturnValue = "") then
			szReturnValue = "0";
		endif;
		StrToNum(nvPMProductIdValue,szReturnValue);
		NumToStr(szReturnValue,nvPMProductIdValue+1);
        szBOInstallUpdateSQL = "INSERT INTO PMProduct_Client_Install(pmproduct_id,required_server_version,server_software_date,";
        szBOInstallUpdateSQL = szBOInstallUpdateSQL + "latest_client_version,client_software_date,is_latest_client_mandatory,is_client_auto_installable,client_install_path,client_install_program,client_install_description,client_reboot_level) VALUES";
        szBOInstallUpdateSQL = szBOInstallUpdateSQL + "(" + szReturnValue +",'" + IFX_PRODUCT_VERSION + "',getdate(),'" ;
        szBOInstallUpdateSQL = szBOInstallUpdateSQL + IFX_PRODUCT_VERSION + "',getdate(),1,1,'" +szInstallPath+"', 'Setup.exe','sirius back-office client installation',0)";
   endif;  
   
   WriteToLogFile(INSTALL_LOG, "Updating client install information for SSP Pure BO using SQL: " +  szBOInstallUpdateSQL);
   nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword, szBOInstallUpdateSQL);
   if(nvResult < 0) then
   		WriteToLogFile(INSTALL_ERRORLOG, "Product client install failed for SSP Pure Back-office failed");
   else
    	WriteToLogFile(INSTALL_LOG, "Product client install success for SSP Pure Back-office");
   endif; 
   
   //Updating DME install info
   szDMEInstallEntryExistSQL = "if exists(select pmproduct_id from PMProduct_Client_Install where rtrim(ltrim(lower(client_install_description))) like 'documaster client installation') select sRetValue='YES' else select sRetValue='NO' ";
   szReturnValue = ADODBConnectExecuteAndReturn(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szDMEInstallEntryExistSQL,"sRetValue");
   
   WriteToLogFile(INSTALL_LOG, "Checking client install information for SSP Pure DME using SQL: " +  szDMEInstallEntryExistSQL);
   if(szReturnValue = "YES") then	 
   		szDMEInstallUpdateSQL = "UPDATE PMProduct_Client_Install SET client_install_program='Setup.exe',client_install_path='"+ szInstallPath +"',required_server_version = '" + IFX_PRODUCT_VERSION + "', client_software_date = getdate(), latest_client_version = '" + IFX_PRODUCT_VERSION + "', server_software_date = getdate() where rtrim(ltrim(lower(client_install_description))) like 'documaster client installation'";
   else  
   		szGetNewPMProductIdScript = "select max(pmproduct_id) as sRetValue from PMProduct_Client_Install";
		szReturnValue = ADODBConnectExecuteAndReturn(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szGetNewPMProductIdScript,"sRetValue");
		if(szReturnValue = "") then
			szReturnValue = "0";
		endif;
		StrToNum(nvPMProductIdValue,szReturnValue);
		NumToStr(szReturnValue,nvPMProductIdValue+1);
        szDMEInstallUpdateSQL = "INSERT INTO PMProduct_Client_Install(pmproduct_id,required_server_version,server_software_date,";
        szDMEInstallUpdateSQL = szDMEInstallUpdateSQL + "latest_client_version,client_software_date,is_latest_client_mandatory,is_client_auto_installable,client_install_path,client_install_program,client_install_description,client_reboot_level) VALUES";
        szDMEInstallUpdateSQL = szDMEInstallUpdateSQL + "(" + szReturnValue +",'" + IFX_PRODUCT_VERSION + "',getdate(),'" ;
        szDMEInstallUpdateSQL = szDMEInstallUpdateSQL + IFX_PRODUCT_VERSION + "',getdate(),1,1,'" +szInstallPath+"', 'Setup.exe','documaster client installation', 0)";
   endif;  
   
   WriteToLogFile(INSTALL_LOG, "Updating client install information for SSP Pure DME using SQL: " +  szDMEInstallUpdateSQL);
   nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword, szDMEInstallUpdateSQL);
   if(nvResult < 0) then
   		WriteToLogFile(INSTALL_ERRORLOG, "Product client install failed for SSP Pure DME failed");
   else
    	WriteToLogFile(INSTALL_LOG, "Product client install success for SSP Pure DME");
   endif;  
   
   // Doc Device Update
   
   if(g_bFreshInstaller = TRUE) then  
		szDocDeviceUpdateSQL = "update doc_device SET server_unc='" + TARGETDIR + "\\DocuMaster Enterprise'"; 
   
		WriteToLogFile(INSTALL_LOG, "Updating Doc Device using SQL: " +  szDocDeviceUpdateSQL);
		nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword, szDocDeviceUpdateSQL);
		if(nvResult < 0) then
			WriteToLogFile(INSTALL_ERRORLOG, "Updating Doc Device failed");
		else
			WriteToLogFile(INSTALL_LOG, "Updating Doc Device success");
		endif;  
	endif;  
end; 

///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  RunCompleteWebServicesInstallCmdFile  								                     //
//                                                                                                       //
// Purpose:   This function run CompleteWebServicesInstall.cmd to complete the installation by           //
//            copying additional files from the Application folder into the Services binary folder.      //
//            It needs to be run after every new build is installed.                                     //
///////////////////////////////////////////////////////////////////////////////////////////////////////////

function number RunCompleteWebServicesInstallCmdFile()
string  szFile,szFolder;
number nvResult;
begin    

SdShowMsg ( "Running CompleteWebServicesInstall.cmd . . . please wait." , TRUE );

szFile = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "CompleteWebServicesInstall.cmd";
szFolder=TARGETDIR ^ PURE_APPLICATION_FOLDER;

nvResult = ClearReadOnly(szFolder);	

StrRemoveLastSlash ( szFolder ); 

ChangeDirectory(szFolder);

if (LongPathToQuote(szFile,TRUE) != 0) then
	MessageBox ("Unable to convert path to quoted path.\n" + szFile, SEVERE );
else
   nvResult = LaunchAppAndWait(szFile,"", LAAW_OPTION_WAIT | LAAW_OPTION_HIDDEN);
   if (nvResult < 0) then
      WriteToLogFile(INSTALL_ERRORLOG,"Unable to launch the following file : \n" +" " + szFile + "\nYou need to run this for copying additional files from the Application folder into the Services binary folder.");
   else                                                                                     
   	  WriteToLogFile(INSTALL_LOG,"Running CompleteWebServicesInstall.cmd Completed Successfully");
   endif;
endif;
   
SdShowMsg ( "Running CompleteWebServicesInstall.cmd . . . please wait." , FALSE );

return 1;
end; 


///////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                                                                       //
// Function:  UpdateSsceINIFile  								                                         //
//                                                                                                       //
// Purpose:   This function updates the Ssce.ini.                                                        //
//            It needs to be run after every new build is installed.                                     //
///////////////////////////////////////////////////////////////////////////////////////////////////////////

function UpdateSsceINIFile()
string  szFile,szMainLexPath,szUserLexPath,szHelpFilePath,svPath;

begin    

SdShowMsg ( "Updating  Ssce.ini . . . please wait." , TRUE );
szFile = TARGETDIR ^ PURE_APPLICATION_FOLDER ^ "Ssce.ini";

szMainLexPath=TARGETDIR ^ "Spellchecker\\lex";
szUserLexPath=TARGETDIR ^ "Spellchecker\\lex";
szHelpFilePath=TARGETDIR ^ "Spellchecker";

SetFileInfo(szFile, FILE_ATTRIBUTE, FILE_ATTR_NORMAL, "");

WriteProfString (szFile, "SSCE User", "MainLexPath",szMainLexPath);
WriteProfString (szFile, "SSCE User", "UserLexPath",szUserLexPath);
WriteProfString (szFile, "SSCE User", "HelpFile",szHelpFilePath);

WriteToLogFile(INSTALL_LOG,"Updating  Ssce.ini Completed Successfully");
   
SdShowMsg ( "Updating  Ssce.ini . . . please wait." , FALSE );

return 0;

end; 

