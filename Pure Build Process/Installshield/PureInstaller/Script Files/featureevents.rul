///////////////////////////////////////////////////////////////////////////////
// Function: RestoreConfigFiles
// Purpose:  Restores all *.config files from backup to INSTALLDIR\APPLICATION and removes backup folder
// Returns:  0 on success, -1 on failure
///////////////////////////////////////////////////////////////////////////////
function number RestoreConfigFiles()
    STRING svConfigDir, svBackupDir;
begin
    svBackupDir = SUPPORTDIR ^ "_config_backup";
    
    if (ExistsDir(svBackupDir) != EXISTS) then
        return 0;
    endif;
    
    svConfigDir = g_InstallLocation ^ "APPLICATION";
    XCopyFile(svBackupDir ^ "*.config", svConfigDir, COMP_NORMAL);
    DeleteDir(svBackupDir, ALLCONTENTS);
    
    return 0;
end;

/***********************FeatureEvents.rul File Coding Ends*********************************************/

