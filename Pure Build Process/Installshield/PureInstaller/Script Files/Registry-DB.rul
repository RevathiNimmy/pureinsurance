function number CheckOrCreateRegistrySettingsTable()
    STRING sConnectionString, sSQL;
    OBJECT oConnection, oRecordset;
    NUMBER bError, bTableExists;
begin
    set oConnection = NULL;
    set oRecordset = NULL;
    bError = FALSE;
    bTableExists = FALSE;
    
    SdShowMsg("Checking for registry settings table", TRUE);
    
    // === Step 1: Create ADODB.Connection ===
    try
        set oConnection = CreateObject("ADODB.Connection");
        if (IsObject(oConnection) = FALSE) then
            bError = TRUE;
        endif;
    catch
        bError = TRUE;
    endcatch;
    if (bError) then
        goto cleanup;
    endif;
    
    // === Step 2: Open Connection ===
    try
      sConnectionString = "Provider=SQLOLEDB;Data Source=" + g_szDBServer + 
                            ";Initial Catalog=" + g_szSiriusDBName;
                            
        if g_TrustedSTR = "1" then
            sConnectionString = sConnectionString + ";Trusted_Connection=yes";
        else 
            sConnectionString = sConnectionString + ";User ID=" + g_szMasterUser + 
                            ";Password=" + g_szMasterPassword;
        endif;
        oConnection.Open(sConnectionString);
    catch
        bError = TRUE;
    endcatch;
    if (bError) then
        goto cleanup;
    endif;
    
    // === Step 3: Check if Registry_Setting table exists ===
    try
        set oRecordset = CreateObject("ADODB.Recordset");
        sSQL = "SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES " +
               "WHERE TABLE_NAME = 'Registry_Setting'";
        oRecordset.Open(sSQL, oConnection);
        
        if (oRecordset.EOF = FALSE) then
            if (oRecordset.Fields(0).Value > 0) then
                bTableExists = TRUE;
            endif;
        endif;
        
        oRecordset.Close();
    catch
        bError = TRUE;
    endcatch;
    
    // === Step 4: Close Connection ===
    try
        if (IsObject(oConnection) && oConnection.State = 1) then
            oConnection.Close();
        endif;
    catch
        // Ignore
    endcatch;
    
    if (bError) then
        goto cleanup;
    endif;
    
    // === Step 5: Run ExportRegistrySettings.exe if table doesn't exist ===
    if (bTableExists = FALSE) then
        SdShowMsg("Registry settings table not found. Creating table...", TRUE);
        CreateRegistrySettingTable();
        if (LaunchAppAndWait(SUPPORTDIR ^ "ExportRegistry.exe", "", WAIT) < 0) then
            MessageBox("Failed to run ExportRegistrySettings.exe", SEVERE);
            return -1;
        endif;
    else
        SdShowMsg("Registry settings table already exists", TRUE);
    endif;
    
    return 1;
    
cleanup:
    if (IsObject(oRecordset)) then
        try
            if (oRecordset.State = 1) then
                oRecordset.Close();
            endif;
        catch
            // Ignore
        endcatch;
    endif;
    
    if (IsObject(oConnection)) then
        try
            if (oConnection.State = 1) then
                oConnection.Close();
            endif;
        catch
            // Ignore
        endcatch;
    endif;
    
    MessageBox("Error checking registry settings table", SEVERE);
    return -1;
end;




function CreateRegistrySettingTable()
    STRING sConnectionString, sSQL, sCheckTableSQL;
    OBJECT oConnection, oRecordSet;
    NUMBER bError;
begin
    // Initialize
    set oConnection = NULL;
    set oRecordSet = NULL;
    bError = FALSE;

    // === Step 1: Create ADODB.Connection ===
    try
        set oConnection = CreateObject("ADODB.Connection");
        if (IsObject(oConnection) = FALSE) then
            //WriteToLogFile(INSTALL_LOG, "ERROR: Failed to create ADODB.Connection object.");
            bError = TRUE;
        endif;
    catch
        //WriteToLogFile(INSTALL_LOG, "ERROR: CreateObject failed - " + Err.Description);
        bError = TRUE;
    endcatch;

    // If error, skip to cleanup
    if (bError) then
        goto cleanup;
    endif;

    // === Step 2: Open Connection ===
    try
        //sConnectionString = "Provider=SQLOLEDB;Data Source=ZAL-5CG3233J0T;Initial Catalog=PureUAT;User ID=sa;Password=P@SSW0RD;";
sConnectionString = "Provider=SQLOLEDB;Data Source=" + g_szDBServer + 
                            ";Initial Catalog=" + g_szSiriusDBName;
                            
        if g_TrustedSTR = "1" then
            sConnectionString = sConnectionString + ";Trusted_Connection=yes";
        else 
            sConnectionString = sConnectionString + ";User ID=" + g_szMasterUser + 
                            ";Password=" + g_szMasterPassword;
        endif;
              
      
      
      
      
        oConnection.ConnectionString = sConnectionString;
        oConnection.Open();
    catch
       // WriteToLogFile(INSTALL_LOG, "ERROR: Failed to open database connection - " + Err.Description);
        bError = TRUE;
    endcatch;

    if (bError) then
        goto cleanup;
    endif;

    // === Step 3: Check if Table Exists and Create if Needed ===
    try
        sCheckTableSQL = "SELECT * FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME = 'Registry_Setting'";
        set oRecordSet = oConnection.Execute(sCheckTableSQL);

        if (oRecordSet.EOF) then
            sSQL = 
                "CREATE TABLE [dbo].[Registry_Setting] (" +
                "   [registry_setting_id] [int] IDENTITY(1,1) NOT NULL PRIMARY KEY," +
                "   [KeyPath] [nvarchar](255) NULL," +
                "   [KeyName] [nvarchar](255) NULL," +
                "   [KeyType] [nvarchar](MAX) NULL," +
                "   [keydata] [nvarchar](255) NULL," +
                "   [System_id] [int] NULL," +
				"	[System_Logged_in_User] [varchar](255) NULL" +
                ")";

            oConnection.Execute(sSQL);
           // WriteToLogFile(INSTALL_LOG, "Registry_Setting table created successfully.");
        else
           // WriteToLogFile(INSTALL_LOG, "Registry_Setting table already exists.");
        endif;
    catch
        //WriteToLogFile(INSTALL_LOG, "ERROR: SQL execution failed - " + Err.Description);
        bError = TRUE;
    endcatch;

    // === Step 4: Close RecordSet (if open) ===
    try
        if (IsObject(oRecordSet) && oRecordSet.State = 1) then
            oRecordSet.Close();
        endif;
    catch
        // Ignore close errors
    endcatch;

    // === Step 5: Close Connection (if open) ===
    try
        if (IsObject(oConnection) && oConnection.State = 1) then
            oConnection.Close();
        endif;
    catch
        // Ignore close errors
    endcatch;

    // === Success — exit ===
    return 1 ;

    // === Cleanup Label ===
cleanup:
    // Close RecordSet if open
    if (IsObject(oRecordSet)) then
        try
            if (oRecordSet.State = 1) then
                oRecordSet.Close();
            endif;
        catch
            // Ignore
        endcatch;
    endif;

    // Close Connection if open
    if (IsObject(oConnection)) then
        try
            if (oConnection.State = 1) then
                oConnection.Close();
            endif;
        catch
            // Ignore
        endcatch;
    endif;

end;



///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  UpdateUpgradeInstallationHistory                               //
//                                                                           //
// Purpose:   This function writes the installed values and parameters       //
//            to the database under "HKEY_LOCAL_MACHINE\SOFTWARE\Pure" folder//
//            after every upgrade/Productupgrade but Fresh Installation      //                                                        //
///////////////////////////////////////////////////////////////////////////////
function number UpdateDBUpgradeInstallationHistory()
number nvResult,g_nSystemID;
string szFoldername,szCurrentDate,szCurrentTime,szRegValue; 
string szProductVersionFolder;  
string szTempVersion;
begin 

g_nSystemID = CurrentSystemID();

szFoldername = GetCurrentDateTime("DATETIME");
szRegValue = "1";
szProductVersionFolder = IFX_PRODUCT_VERSION;
//nvResult = RegDBCreateKeyEx("SOFTWARE\\Pure\\PureInstallation\\Installation History",szProductVersionFolder);
if(nvResult =0) then  
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Product Version","String",IFX_PRODUCT_VERSION,g_nSystemID);
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Full Version","String",g_szTobeInstalledFullVersion,g_nSystemID);
	if(g_bFreshInstaller = TRUE) then
		InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Type","String","Fresh",g_nSystemID);
	else
		InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Type","String","Upgrade",g_nSystemID);
	endif;
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Setup","String","SERVER",g_nSystemID);
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Product Name","String","PureInstallation",g_nSystemID);
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Component Client","String",szRegValue,g_nSystemID);
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Component Server","String",szRegValue,g_nSystemID);
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Component Update Databases","String",szRegValue,g_nSystemID);
	//Set the Date and Time for the Product Installation
	GetSystemInfo(TIME,nvResult,szCurrentTime);
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Time","String",szCurrentTime,g_nSystemID);
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Setup","Time Installed","String",szCurrentTime,g_nSystemID);
	FormatDate("UK",4,"/",g_szFDate);
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Installation History\\"+szProductVersionFolder,"Install Date","String",g_szFDate,g_nSystemID);    
	InsertRegistrySetting("HKEY_LOCAL_MACHINE\\SOFTWARE\\Pure\\PureInstallation\\Setup","Date Installed","String",g_szFDate,g_nSystemID);    
	
	WriteToLogFile(INSTALL_LOG,"Upgrade Installation History updated in the database");
 endif;     
 
return 1;
end;
