///////////////////////////////////////////////////////////////////////////////
//
// Function:	NewRunSetupDB
//
// Description:	Calls the SetupDB which will do all the database setup and
//           	install all the scripts
//
//				Using the new command line
//
///////////////////////////////////////////////////////////////////////////////
function number NewRunSetupDB()
    NUMBER  nResult, nvType, nvSize, nvCopyResult;
    STRING  szProgram , szCmdLine, svResult, svDir, svDirTemp, svStatus, szCommandTimeout;
    STRING	sProductType, sBackupFlag, sDatabaseName, sDatabaseServer, sSQLPath, sInstallOrder;
    STRING  szMainCmdLine, sOverNight, szKey, szMsg, szMSMAPI32Path;  
    STRING  szScriptsFolder;
begin

   	SdShowMsg ( "Database Setup . . . please wait." , TRUE );
    
	// Setup the program filename
	szProgram = SRCDIR ^ "Scripts" ^ "SetupDB.exe";		

	// Set the source directory as the CDRom\Scripts directory
	szScriptsFolder = SRCDIR ^ "Scripts";
		
	// Set product type
	sProductType = "Underwriting" ;

	// Set the backup flag to 'no' as this is now asked at the start of the installation
	sBackupFlag = "No" ;

	// Get some registry settings
	RegDBSetDefaultRoot ( HKEY_LOCAL_MACHINE );

	nResult = RegDBGetKeyValueEx (	"SOFTWARE\\Pure\\Architecture\\Server",
										"InstallCommandTimeOut",
									 	nvType,
									 	szCommandTimeout,
									 	nvSize );											

								
	// Set the registry root	
	if (nResult < 0) then
			RegDBSetDefaultRoot ( HKEY_LOCAL_MACHINE );	
			szKey = "SOFTWARE\\Pure\\Architecture\\Server";
			//RegDBCreateKeyEx (szKey, "");
			RegDBSetDefaultRoot ( HKEY_LOCAL_MACHINE );	
			szKey = "SOFTWARE\\Pure\\Architecture\\Server";
		// Need to up the registry setting for InstallCommandTimeOut to 3600 from 60 seconds.
			//RegDBSetKeyValueEx ( szKey , "InstallCommandTimeOut" , REGDB_STRING , "3600" , -1 );
	endif;

	nResult = RegDBGetKeyValueEx ( 	"SOFTWARE\\PM\\SiriusArchitecture\\Server\\Databases\\SiriusSolutions",
										"Server",
	                                    nvType,
	                                    sDatabaseServer,
                                   		nvSize );	

	//nResult = RegDBGetKeyValueEx ( 	"SOFTWARE\\PM\\SiriusArchitecture\\Server\\Databases\\SiriusSolutions",
	  //                                  "Database",
	  //                                  nvType,
	  //                                  sDatabaseName,
      //                             		nvSize );	
      
   	sDatabaseName = g_szSiriusDBName;   
   	sDatabaseServer= g_szDBServer;

	nResult = RegDBGetKeyValueEx ( "SOFTWARE\\Microsoft\\MSSQLServer\\Setup",
										"SQLDataRoot",
                                   		nvType,
										sSQLPath,
										nvSize );	

	sInstallOrder = "";
	
	// Setup the main command line
	szMainCmdLine = '"act=install", ' +
				'"if=' + szScriptsFolder + '", ' +
				'"pdf=' + sProductType + '", ' +
				'"sn=' + sDatabaseServer + '", ' +
				'"dn=' + sDatabaseName + '", ' +
				'"dbk=' + sBackupFlag + '", ' +
				'"ddf=' + sSQLPath ^ 'Data' + '", ' +
				'"dlf=' + sSQLPath ^ 'Data' + '", ' +
				'"lic=yes", ' +
				'"lss=yes", ' +
				'"iff=' + szScriptsFolder ^ 'config.xml' + '", ' +
				'"aui=yes", ' + 
				'"evlog=no", ' +
				'"loginname=' + g_szSiriusUserName + '", ' +
				'"loginpwd=' + g_szSiriusPassword + '", ' +
				sInstallOrder;

	// Setup the command line
	szCmdLine = szMainCmdLine +
				'"ldv=Install\\1.0", ' +
				'"ldv=Structure\\1.0", ' +
				'"ldv=Procedures\\1.0", ' +
				'"ldv=Views\\1.0", ' +
				'"ldv=SA\\2.3.0.21", ' +
				'"ldv=GIS\\1.9.5.21", ' +
				'"ldv=SBO\\1.8.6.21", ' +
				'"ldv=CLM\\1.8.6.21", ' +
				'"ldv=ORION\\1.8.6.21", ' +
				'"ldv=Query\\(max)", ' +
				'"ldv=GII\\(max)", ' +
				'"ldv=Data\\1.0"' ;
								
		//nResult = LaunchAppAndWait ( szProgram , szCmdLine , WAIT );
		//if (nResult < ISERR_SUCCESS) then
		//	szMsg = "Unable to launch : " + szProgram + " it will need to be run manually.";
		//	MessageBox ( szMsg, SEVERE );
		//	return 0;
		//endif;

		// Setup the command line
		//szCmdLine = szMainCmdLine +
		//		'"ldv=Install\\(max)", ' +
		//		'"ldv=Structure\\(max)"' ;
									
		//nResult = LaunchAppAndWait ( szProgram , szCmdLine , WAIT );
		//if (nResult < ISERR_SUCCESS) then
		//	szMsg = "Unable to launch : " + szProgram + " it will need to be run manually.";
		//	MessageBox ( szMsg, SEVERE );
		//	return 0;
		//endif;

		
		// Setup the command line
		szCmdLine = szMainCmdLine +
				'"ldv=Install\\(max)", ' +
				'"ldv=Structure\\(max)", ' +
				'"ldv=Procedures\\(max)", ' +
				'"ldv=Views\\(max)", ' +
				'"ldv=SA\\(max)", ' +
				'"ldv=GIS\\(max)", ' +
				'"ldv=SBO\\(max)", ' +
				'"ldv=CLM\\(max)", ' +
				'"ldv=ORION\\(max)", ' +
				'"ldv=Query\\(max)", ' +
				'"ldv=GII\\(max)", ' +
				'"ldv=Data\\(max)"' ;
								
		//nResult = LaunchAppAndWait ( szProgram , szCmdLine , WAIT );
		nResult = LaunchApplication( szProgram, szCmdLine, "", SW_SHOW, INFINITE, LAAW_OPTION_USE_SHELLEXECUTE | LAAW_OPTION_WAIT ); 
		if (nResult < ISERR_SUCCESS) then
			szMsg = "Unable to launch : " + szProgram + " it will need to be run manually.";
			MessageBox ( szMsg, SEVERE );
			return 0;
		endif;
		
	

	
	SdShowMsg ( "Database Setup . . . please wait." , FALSE );  
	
	return 1;
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ADODBConnectAndExecute                                         //
//                                                                           //
// Purpose:  This function connects to the DB Server and executes            //
//			 a SQL Script on the database specified in the                   //
//			 function parameters                                             //
///////////////////////////////////////////////////////////////////////////////

function number ADODBConnectAndExecute(g_szDBServer,szDBName,szUser,szPassword,szSQLScript)
   
 string szADOObjID,szDriver,szConnString,szADOCommObjID,szErrorLog;
 object objADO,objADOComm;  
 number nvRecords;
 begin 
 
   	szADOObjID = "ADODB.Connection";
	set objADO = CreateObject(szADOObjID);	
	szConnString = GetConnectionString(szDBName);
	
        try
		// Open the ADO Connection 
		objADO.Open(szConnString);
	catch
			szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n"; 
				
			//WritetoDatabaseLog(szErrorLog,TRUE);	
			WriteToLogFile(DATABASE_ERRORLOG,szErrorLog);
			set objADO = NOTHING; 
			return -2;
	endcatch;     


       try              
		// Create the ADO Command object to execute the script                           	
		szADOCommObjID = "ADODB.Command";
		set objADOComm = CreateObject(szADOCommObjID);
		objADOComm.CommandTimeout = 600;  
		objADOComm.ActiveConnection = objADO;
	
	   
	 	 	// Execute the call to run the script
			objADOComm.CommandText = szSQLScript;
			objADOComm.Execute(nvRecords ,0x81);
			    
			
	catch
			szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n"; 
				
			//WritetoDatabaseLog(szErrorLog,TRUE);	
			WriteToLogFile(DATABASE_ERRORLOG,szErrorLog);
			objADO.Close(); 
			set objADO = NOTHING; 
			return -1;
	endcatch;     
	//Close the Connections after executing SQL Scripts
	objADO.Close(); 
	set objADO = NOTHING;
	
   return 1;
end;


///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ADODBConnectAndExecutePortal                                         //
//                                                                           //
// Purpose:  This function connects to the DB Server and executes            //
//			 a SQL Script on the database specified in the                   //
//			 function parameters                                             //
///////////////////////////////////////////////////////////////////////////////
function number ADODBConnectAndExecutePortal(g_PortalDBServer,sz_PortaDB,g_PortalUser,g_PortalPwd,szSQLScript)
 string szADOObjID,szDriver,szConnString,szADOCommObjID,szErrorLog;
 object objADO,objADOComm;  
 number nvRecords;
 begin 
   	szADOObjID = "ADODB.Connection";
	set objADO = CreateObject(szADOObjID);	
	szConnString = GetPortalConnectionString(sz_PortaDB);

	try
		// Open the ADO Connection 
		objADO.Open(szConnString);
	catch
			szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n"; 
			//WritetoDatabaseLog(szErrorLog,TRUE);	
			WriteToLogFile(DATABASE_ERRORLOG,szErrorLog);
			set objADO = NOTHING; 
			return -1;
	endcatch;     

         try
   		// Create the ADO Command object to execute the script                           	
		szADOCommObjID = "ADODB.Command";
		set objADOComm = CreateObject(szADOCommObjID); 
		objADOComm.CommandTimeout = 600;   
		objADOComm.ActiveConnection = objADO;
	  
	 	 	// Execute the call to run the script
			objADOComm.CommandText = szSQLScript;
			objADOComm.Execute(nvRecords ,0x81);
	catch
			szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n"; 
			//WritetoDatabaseLog(szErrorLog,TRUE);	
			WriteToLogFile(DATABASE_ERRORLOG,szErrorLog);
			objADO.Close(); 
			set objADO = NOTHING; 
			return -1;
	endcatch;     
	//Close the Connections after executing SQL Scripts
	objADO.Close(); 
	set objADO = NOTHING;
   return 1;
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  ADODBConnectExecuteAndReturn                                   //
//                                                                           //
//  Purpose:  This function connects to the DB Server and executes a 		 //
//			  SQL Script on the database specified in the function 			 //
//			  parameters  and returns a value as a String Result        	 //
///////////////////////////////////////////////////////////////////////////////

function string ADODBConnectExecuteAndReturn(g_szDBServer,szDBName,szUser,szPassword,szSQLScript,szReturnParameter)  
 string szADOObjID,szDriver,szConnString,szReturnValue,szErrorLog;
 object objConnection,objRecordSet;  
 begin 
   	try
   			szReturnValue = "";
			szADOObjID = "ADODB.Connection";
			set objConnection = CreateObject(szADOObjID);	
		    szConnString = GetConnectionString(szDBName);
			objConnection.ConnectionString = szConnString;
			// Open the ADO Connection 
			objConnection.Open;
	catch
	         szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n";
	         return szReturnValue;  
	endcatch;
    try    
	 	 	set objRecordSet = objConnection.Execute(szSQLScript);
	        szReturnValue = objRecordSet(szReturnParameter);     
	        
	        return szReturnValue;    
	         //sRetValue
	catch
	     	szErrorLog = szErrorLog
				+ "Error:  " + Err.Description + "\n"
				+ "Source: " + Err.Source + "\n"
				+ "Script:\n" + szSQLScript 	+ "\n\n";
			//WritetoDatabaseLog(szErrorLog,TRUE);	
			WriteToLogFile(DATABASE_ERRORLOG,szErrorLog);
			objConnection.Close();
			set objConnection = NOTHING;
			return szReturnValue;   
			
	endcatch;  
	//Close the Connections after executing SQL Scripts
	objConnection.Close();
	set objConnection = NOTHING;
  return szReturnValue;
end;   

