//---------------------------------------------------------------------------
// SQLRTSetMetaData
//
// Sets the metadata of the database server used by the SQL runtime.
//
// Uses SQLRT.dll and settings from the SQL settings file, so can only be 
// called after SQLRTInitalize has already been called.
//---------------------------------------------------------------------------
function void SQLRTSetMetadata( szName, nPropId, szPropValue )
begin
    if( g_bSQLRTInitialized ) then
    
		ISSQLServerSetMetadata( szName, nPropId, szPropValue );
	
	endif;
end;

#include "EventsSetup.rul"