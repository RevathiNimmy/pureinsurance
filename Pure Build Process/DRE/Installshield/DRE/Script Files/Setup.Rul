//===========================================================================
//
//  File Name:    Setup.rul
//
//  
//  Comments:     This rule file is the entry point of the Installation Script Execution
//				  and it handles all the installation events from beginning to end as well as various 
//				  miscalleneous functions.
//
//===========================================================================

STRING g_szUserName;// Varibale for holding the username
string g_szHostName;  //Variable for holding the Host Name or Computer name of the target machine
string g_szShareDrive;//Variable used in the sirius_clientinstallset rule file to find out the Shared Drive for PMSetup Folder
string g_szMDFDirPath,g_szLDFDirPath;//Variables for Setting Sirius Database MDF Path and LDF Path in case of fresh installations
string g_szWindowsAuthenticate; //Variable to hold the Windows Authentication Flag done during a previous installation

BOOL g_bPreRequisiteFailure; // Variable for setting Installer Prerequisite Failure Flag

BOOL g_bSiriusDBCreatedFlag; // Variable for setting SiriusDB/Login Created  Flag in case of Fresh Installation for use in 
BOOL g_bSiriusDBUpgradedFlag; // Variable for setting SiriusDB upgraded  Flag in case of Fresh Installation for use in 
BOOL g_bPatchInstallation;//Variable for setting a flag to indicate a patch installation is happening
BOOL g_bWinLoginAuthenticate; //Variable to hold whether the SQL Server authentication is Windows or SQL Server Authentication
BOOL g_bRemoteDBServer;//Flag Variable which holds whether the DB to be installed is on a Remote DB Server or Local DB Server

//Variables to hold Installed Product DB Version Structure
string g_szTobeInstalledFullVersion,g_szTobeInstalledSubVersion;
string g_szInstalledFullVersion;  
// UserID and Password for webservices Installation
string g_szWebservicesUser,g_szWebservicesPassword;

number g_nvSQLFileSuccessCount,g_nvSQLFileErrorCount;//Variable to hold the count of SQL Files Executed Successfully and with Errors
number g_nvSQLFileSuccessTotalCount,g_nvSQLFileErrorTotalCount; //Variable to hold the total count of SQL Files Executed Successfully and with Errors


//New variable for database restore
NUMBER g_blankDB,g_brestoreDB;
STRING g_szRestoreDBFileName;
STRING gTemp;
STRING gSharedPath;

// List for file in use
LIST listInUseApplications;

STRING gLogiaclDataFileName,gLogiaclLogFileName;
BOOL gRestoreBackupFile;
STRING gBackupPath;

STRING g_szApplicationDRESite,g_szPhysicalPathDRESite,g_szAppPoolDRESite;
STRING g_szApplicationDREServices,g_szPhysicalPathDREServices,g_szAppPoolDREServices;

BOOL  g_bDRESite,g_bDREServices,g_bDREDatabase;

//
STRING g_PureDBServer,g_PureDB,g_PureUser,g_PurePassword;

//
STRING g_ProcutVersion, g_InstalledVersion;
STRING gInstallMode;


//Default SQL Server defined MDF and LDF PATH
#define DEFAULTMDFPATH 		"Microsoft SQL Server\\MSSQL10.MSSQLSERVER\\MSSQL\\Data"
#define DEFAULTLDFPATH      "Microsoft SQL Server\\MSSQL10.MSSQLSERVER\\MSSQL\\Data"
#define DEFAULTBAKUPPATH    "Microsoft SQL Server\\MSSQL10.MSSQLSERVER\\MSSQL\\Backup"


//Log File Names used for Installation/Uninstallation for logging normal operations as well as errors
#define INSTALL_LOG	 			"DREInstallLog.txt"
#define UNINSTALL_LOG	 		"DREUnInstallLog.txt"
#define UNINSTALL_ERRORLOG	 	"DREUnInstallErrorLog.txt"
#define INSTALL_ERRORLOG	 	"DREInstallErrorLog.txt"
#define DATABASE_ERRORLOG		"DREDatabaseErrorLog.txt"
#define DATABASE_LOG			"DREDatabaseFinishLog.txt"  

//ODBC Driver Constants
#define ODBCSQLDriverName  "SQL Server"

//Sirius User Name and Password used by the Sirius Back Office Application
#define SIRIUSUSER     	"SIRIUS"
#define SIRIUSPASSWORD  "$1R1U5" 

//Share Name for the Sirius Installer Folder
#define SIRIUSSHARENAME  "DISK1"          

// Path to logo
#define SSPLOGO "SSP.jpg" 
// web services XML
#define ERROR_SUCCESS 0
#define ERROR_XML_FILE_CREATION "Setup could not find the web.config file."
//#define ERROR "Error"
#define ERROR_XML_FILE_STRUCTURE "The web.config file structure is corrupted."
#define ERROR_XML_FILE_LOAD "The web.config file was not loaded."
 
 
