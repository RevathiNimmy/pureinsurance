///////////////////////////////////////////////////////////////////////////////////////
//                                                                                   //
// Function:  CompareVersion  	                                                     //
//				                                                                     //
// Purpose:   This function                                                                       //
//			                                                                         //
///////////////////////////////////////////////////////////////////////////////////////
function CompareVersion()
    NUMBER nResult,nPos, nLastPos, nLoop;
	STRING svMajor,svMinor,svBuild,svRegMajor,svRegMinor,svRegBuild; 
    NUMBER nMajor,nMinor,nBuild,nRegMajor,nRegMinor,nRegBuild; 
    STRING	sProductVersionArray(3),sRegProductVersionArray(3), sTemp;
    STRING szUninstallKey, szDisplayVersion;
    NUMBER nSize,nType;
        
begin

    // Read Product Version of Installer from ProductVersion property
    g_ProcutVersion = IFX_PRODUCT_VERSION;
	
  	//Look for three values - Major, Minor,Build Number
	nLastPos = 0;
	for nLoop = 0 to 2  
		nPos = StrFind ( g_ProcutVersion, "." );
		if ( nPos <= 0 ) then 
			nPos = StrLength ( g_ProcutVersion );
		endif;
		StrSub ( sTemp, g_ProcutVersion, 0, nPos );
		sProductVersionArray ( nLoop ) = sTemp; 
		StrSub ( g_ProcutVersion, g_ProcutVersion, nPos + 1, StrLength ( g_ProcutVersion ) );
	endfor;
	
	svMajor =sProductVersionArray (0);  
	StrToNum(nMajor,svMajor); 
	svMinor =sProductVersionArray (1);
  	StrToNum(nMinor,svMinor);
  	svBuild =sProductVersionArray (2); 
  	StrToNum(nBuild,svBuild);
  
    // Read Product Version from regsitry
	szUninstallKey="SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{15F8BC19-DD4F-4825-8FDB-F8348F8B66E8}";
    szDisplayVersion= "DisplayVersion"; 
    
    nSize= -1;
    nType= REGDB_STRING;   
    
	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
    
    if((RegDBKeyExist(szUninstallKey)=1)) then
		RegDBGetKeyValueEx (szUninstallKey, szDisplayVersion, nType, g_InstalledVersion, nSize); 
	else
		// Not Installed, so it is Fresh Install
		gInstallMode="Fresh";
	endif;
	
	if(gInstallMode="Fresh") then
		//
	
	else

		//Look for three values - Major, Minor,Build Number
		nLastPos = 0;
		for nLoop = 0 to 2  
			nPos = StrFind ( g_InstalledVersion, "." );
			if ( nPos <= 0 ) then 
				nPos = StrLength ( g_InstalledVersion );
			endif;
			StrSub ( sTemp, g_InstalledVersion, 0, nPos );
			sRegProductVersionArray ( nLoop ) = sTemp; 
			StrSub ( g_InstalledVersion, g_InstalledVersion, nPos + 1, StrLength ( g_InstalledVersion ) );
		endfor;
	
		svRegMajor =sRegProductVersionArray (0);
		StrToNum(nRegMajor,svRegMajor);
		svRegMinor =sRegProductVersionArray (1);
		StrToNum(nRegMinor,svRegMinor);
		svRegBuild =sRegProductVersionArray (2); 
		StrToNum(nRegBuild,svRegBuild);
  	
		// Compare the Installed Version and New version for each of the three values
  	  	
		if(nMajor < nRegMajor)then
  	     	gInstallMode="Older"; 
		else
			if((nMajor = nRegMajor)&&(nMinor < nRegMinor))then 
  			 		gInstallMode="Older"; 
			else
				if((nMajor = nRegMajor)&&(nMinor = nRegMinor)&&(nBuild < nRegBuild)) then
  				 		gInstallMode="Older"; 
				else
					if((nMajor = nRegMajor)&&(nMinor = nRegMinor)&&(nBuild = nRegBuild)) then 
  					 		gInstallMode="Same";
							
					else
						gInstallMode="Upgrade";
					endif;
				endif;
			endif;
		endif;
	endif;//if(gInstallMode="Fresh") then
		
   return 0; 
    
end;

//---------------------------------------------------------------------------
// OnSetUpdateMode
//
// OnSetUpdateMode is called directly by the framework to set the UPDATEMODE
// InstallShield system variable appropriately to control which UI events
// are called by OnShowUI.
//
// Note: This event is called for all setups.
//---------------------------------------------------------------------------
function OnSetUpdateMode()
	number	nIgnore, nMediaFlags, nInstalledVersion, nUpdateVersion, nResult;
	string	szVersion, szIgnore, szMsg;
begin
	
	UPDATEMODE = FALSE; // Non-update mode by default.

	// Added 11.5 - Don't set UPDATEMODE when running from Add/Remove
	if( ADDREMOVE ) then
		return ISERR_SUCCESS;
	endif;

	// Added 11.5 - Don't set UPDATEMODE when REMOVEONLY is specified
	if( REMOVEONLY ) then
		return ISERR_SUCCESS;
	endif;

	// Get the media flags.
	MediaGetData( MEDIA, MEDIA_FIELD_MEDIA_FLAGS, nMediaFlags, szIgnore );

	// TODO: If you are updating an application that was installed by a previous
	// version of InstallShield, IFX_INSTALLED_VERSION will be empty, and
	// VERSION_COMPARE_RESULT_NOT_INSTALLED will be returned by
	// VerProductCompareVersions. Change the value of IFX_INSTALLED_VERSION (and
	// IFX_INSTALLED_DISPLAY_VERSION) here based on application specific version
	// information determined by the setup. Only do this if IFX_INSTALLED_VERSION
	// is empty.
	//if ( !StrLengthChars( IFX_INSTALLED_VERSION ) && MAINTENANCE ) then
	//	IFX_INSTALLED_VERSION = "X.XX.XXX";
	//	IFX_INSTALLED_DISPLAY_VERSION = IFX_INSTALLED_VERSION;
	//endif;

	// Verify that the installed version is valid.
	if( !StrLengthChars( IFX_INSTALLED_VERSION ) && MAINTENANCE ) then
		// If this error occurs, IFX_INSTALLED_VERSION needs to be set manually.
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_NO_INSTALLED_VERSION );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Verify that the product version is valid.
	if( !StrLengthChars( IFX_PRODUCT_VERSION ) ) then
		// If this error occures, IFX_PRODUCT_VERSION was not initialized correctly.
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_NO_PRODUCT_VERSION );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Do the version comparison.
	nResult = VerProductCompareVersions();

	// Make sure that valid data was returned by VerProductCompareVersions
	if( nResult < ISERR_SUCCESS ) then
		//szMsg = SdLoadString( IDS_IFX_ERROR_UPDATE_VERSION_COMPARE_FAILURE );
		//MessageBox( szMsg, SEVERE );
		//abort;
	endif;

	// Set update mode if this is a differential media or the product is already installed and the versions do not match.
	UPDATEMODE = ( nMediaFlags & MEDIA_FLAG_FORMAT_DIFFERENTIAL || ( MAINTENANCE && ( nResult != VERSION_COMPARE_RESULT_SAME ) ) );

end;

////////////////////////////////////////////////////////////////////////
//                                                                    //
// Function:  CheckPrerequisites                                            //
//                                                                    //
// Purpose:                                                           //
////////////////////////////////////////////////////////////////////////
function CheckPrerequisites()
STRING szInstalledMajorVersionVersion,szPureInstalledVersion,szPureCompatibleVersion,szPureFullInstalledVersion;
NUMBER nMajorversion;
begin
	

	RegDBSetDefaultRoot(HKEY_LOCAL_MACHINE);
	szPureInstalledVersion = GetFromRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Version");
	szPureFullInstalledVersion = GetFromRegistry("SOFTWARE\\Pure\\PureInstallation\\Setup","Full Version");
	
	StrSub(szInstalledMajorVersionVersion,szPureInstalledVersion,0,1);
	
	StrToNum(nMajorversion,szInstalledMajorVersionVersion);
	
	if(nMajorversion >= 3)then
		 WriteToLogFile(INSTALL_LOG,"Pure version 3.0 is  installed in the system");
	else
		 MessageBox("The current version of PURE Insurance " + szPureFullInstalledVersion + " is not compatible with DRE. You must be running PURE 3.0 or higher. \n\nPlease upgrade your PURE version then re-run the DRE installation.", SEVERE);
		 abort;
	endif;
	
	//g_PureCompatibleVersion 
	return 0;
end;

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  SetFreshDBCompatibilityLevel  							     //
//                                                                           //
// Purpose:   This function is used to set the DB compatibility level        //
//			  to SQLSERVER 2000 to newly created Sirius DB in SQLServer 2005 //
///////////////////////////////////////////////////////////////////////////////

function number SetFreshDBCompatibilityLevel()
number nvResult;
string szDBCompatScript;
STRING szProductVersionSQL,svProductVersion,svMajorProductVersion;
begin   

	szProductVersionSQL="SELECT SERVERPROPERTY('ProductVersion') ProductVersion";
	svProductVersion = ADODBConnectExecuteAndReturn(g_szDBServer,"master",g_szSiriusUserName,g_szSiriusPassword,szProductVersionSQL,"ProductVersion");  
	
	//MessageBox("Product version=" + svProductVersion ,INFORMATION);
	StrSub(svMajorProductVersion,svProductVersion,0,2); 
	//MessageBox("Major version=" + svMajorProductVersion ,INFORMATION);

	if(svMajorProductVersion= "11") then
		szDBCompatScript = "execute sp_dbcmptlevel '"+ g_szSiriusDBName +"',110";
	endif;
	
	if(svMajorProductVersion= "10") then
		szDBCompatScript = "execute sp_dbcmptlevel '"+ g_szSiriusDBName +"',100";
	endif;
	
	nvResult = ADODBConnectAndExecute(g_szDBServer,g_szSiriusDBName,g_szSiriusUserName,g_szSiriusPassword,szDBCompatScript);
	if(nvResult = 1) then
		WriteToLogFile(INSTALL_LOG,g_szSiriusDBName +" Database Compatibility set to SQL Server 2008");
	else
		WriteToLogFile(INSTALL_ERRORLOG,g_szSiriusDBName +" Database Compatibility cannot to SQL Server 2008. Please perform this step manually.");
	endif; 

return 1;
end;      

///////////////////////////////////////////////////////////////////////////////
//                                                                           //
// Function:  BackupWebConfigFile  							                 //
//                                                                           //
// Purpose:   This function is used to take backup of DRE Site and           //
//			   DRE Services web.config file                                  //
///////////////////////////////////////////////////////////////////////////////
function BackupWebConfigFile()
STRING szDRESiteSrcFile,szDRESiteTargetFile,szDREServicesSrcFile,szDREServicesTargetFile;
begin
	
	//DRE Site web.config file backup
	szDRESiteSrcFile= TARGETDIR ^ "Site" ^ "web.config";
	szDRESiteTargetFile= TARGETDIR ^ "Site" ^ "web.config.bak";

	if Is(FILE_EXISTS, szDRESiteTargetFile) = TRUE then
		  DeleteFile(szDRESiteTargetFile);
	
	endif;
	
	if Is(FILE_EXISTS, szDRESiteSrcFile) = TRUE then
		CopyFile ( szDRESiteSrcFile, szDRESiteTargetFile ); 
	endif;
	
	//DRE Services web.config file backup
	szDREServicesSrcFile= TARGETDIR ^ "Services" ^ "web.config";
	szDREServicesTargetFile= TARGETDIR ^ "Services" ^ "web.config.bak";
	
	if Is(FILE_EXISTS, szDREServicesTargetFile) = TRUE then
		  DeleteFile(szDREServicesTargetFile);
	
	endif;
	
	if Is(FILE_EXISTS, szDREServicesSrcFile) = TRUE then
		CopyFile ( szDREServicesSrcFile, szDREServicesTargetFile ); 
	endif;
	
	
	MessageBox("Please note during DRE upgrade, your DRE Site and Services web.config files will be replaced.\n\nBackup of current web.config files containing your settings has been created to " + szDRESiteTargetFile + " and " +  szDREServicesTargetFile + "." + "\n\nPlease update the new config files with your settings from the backup files." ,INFORMATION);
	//"Please note during DRE upgrade, your DRE Site and Services web.config files will be replaced, Backup of current web.config files containing your settings has been created to <full file path and name>, You should update the new config files with your settings from the backup files”
	return 0;

end;
